    self.showLargeImage = function(url,options,ev){
      var student = options.student;
      var text = options.text;
      var task = options.task;
      var folderItem = options.folderItem;

      self.showDialog({
        templateUrl: "showLargeImage.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        targetEvent : ev ? ev : null,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.student = student;
          $scope.allowedToChange = false;
          $scope.imageURLOrg = url;

          if(self.user.Teacher == "1"){
            $scope.allowedToChange = true;
          } else {
            if(url.indexOf("https://learningview.org/uploads/"+self.user.ID+"/") === 0){
              $scope.allowedToChange = true;
            }
          }
          $scope.url = url;

          if(url.indexOf("&r=") > 0){
            url = url.replace(/\&r=[0-9.]+/,"&r="+Math.random());
          }else
          if(url.indexOf("?r=") > 0){
            url = url.replace(/\?r=[0-9.]+/,"?r="+Math.random());
          }else
          if(url.indexOf("?") > 0){
            url = url + "&r="+Math.random();
          }else
            url = url + "?r="+Math.random();

          $scope.imageUrl = url; // for rotated image
          $scope.text = text;
          $scope.task = task;
          $scope.folderItem = folderItem;

          $scope.rotateImage = function(angle){
            self.rotateImage($scope.url,angle).then(function(){

            });
          };

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.rotateImage = function(url,angle){
      var deferred = $q.defer();
      self.isRotatingImage = true;
      $timeout(function(){self.isRotatingImage = false;},1100);

      if(url.indexOf("&r=") > 0){
        url = url.replace(/\&r=[0-9.]+/,"");
      }else
      if(url.indexOf("?r=") > 0){
        url = url.replace(/\?r=[0-9.]+/,"");
      }

      var r = "https://learningview.org/api/rotateImage.php?url="+encodeURIComponent(url)+"&angle="+angle+"&r="+Math.random();

      var image = new Image();
      image.src = r;
      image.crossOrigin = "Anonymous";
      image.onload = function(){
        // done rotating
        $("img").each(function(i,e){
          if(e.src && e.src.indexOf(url) === 0){
            setTimeout(function(){
              if(e.src && e.src.indexOf(url) === 0){
                if(e.src.indexOf("&r=") > 0){
                  e.src = e.src.replace(/\&r=[0-9.]+/,"&r="+Math.random());
                }else
                if(e.src.indexOf("?r=") > 0){
                  e.src = e.src.replace(/\?r=[0-9.]+/,"?r="+Math.random());
                }else
                if(e.src.indexOf("?") > 0){
                  e.src = e.src + "&r="+Math.random();
                }else
                  e.src = e.src + "?r="+Math.random();
              }
            },1000);
          }
        });
        setTimeout(function(){
          $("img").each(function(i,e){
            if(e.src == r){
              var n = "";
              if(url.indexOf("?") > 0){
                n = url + "&r="+Math.random();
              }else
                n = url + "?r="+Math.random();
              e.src = n;
            }
          });
          deferred.resolve();
        },500);
      };

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showTaskClassResultMedia = function(task,ev){
      //self.currentClass
      var deferred = $q.defer();
      var type = task.ResultType;
      var results = self.getClassTaskResultData(task);

      var template = "";

      if(type == "text")       template = "showClassTaskResultTexts.html";
      if(type == "image")      template = "showClassTaskResultImages.html";
      if(type == "drawing")    template = "showClassTaskResultAnnotations.html";
      if(type == "annotation") template = "showClassTaskResultAnnotations.html";
      if(type == "audio")      template = "showClassTaskResultAudios.html";
      if(type == "video")      template = "showClassTaskResultVideos.html";
      if(type == "file")       template = "showClassTaskResultFiles.html";
      if(type == "link")       template = "showClassTaskResultLinks.html";
      if(type == "textnotes")  template = "showClassTaskResultNotes.html";
      if(type == "audionotes") template = "showClassTaskResultNotes.html";
      if(type == "videonotes") template = "showClassTaskResultNotes.html";


      if(task.Type == "learningapp") template = "showClassTaskResultLearningApp.html";

      self.showDialog({
        templateUrl: template,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = task;
          $scope.results = results;
          $scope.waitForDownload = false;

          $scope.exportClassTaskResults = function(filter, ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportUploads.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID+"&taskid="+task.ID;
            if(filter && filter.length > 0){
              url += '&filter='+filter.join(",");
            }
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = window.cleanFilename("LearningViewExport_"+self.currentClass.Name+"_"+task.Name)+".zip";
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve();
          };
        }
      });

      return deferred.promise;
    };

