    "                  ng-click=\"$ctrl.execCommand(button.command);$event.preventDefault();\"\n" +
    "                  ng-class=\"{ 'nw-button--active': !$ctrl.disabled && $ctrl.isEditorActive() && button.isActive() }\"\n" +
    "                  ng-disabled=\"$ctrl.editMode || $ctrl.disabled\">\n" +
    "            {{ button.title }}\n" +
    "          </button>\n" +
    "        </div>\n" +
    "        <div ng-if=\"button.isComplex\">\n" +
    "          <ng-wig-plugin\n" +
    "              exec-command=\"$ctrl.execCommand\"\n" +
    "              plugin=\"button\"\n" +
    "              container=\"$ctrl.container\"\n" +
    "              filename=\"$ctrl.filename\"\n" +
    "              edit-mode=\"$ctrl.editMode\"\n" +
    "              data-disabled=\"$ctrl.disabled\"\n" +
    "              options=\"$ctrl.options\"\n" +
    "              content=\"$ctrl.content\"></ng-wig-plugin>\n" +
    "        </div>\n" +
    "    </li><li class=\"nw-toolbar__item\">\n" +
    "      <button type=\"button\"\n" +
    "              class=\"needsclick nw-button nw-button--source\"\n" +
    "              title=\"HTML bearbeiten\"\n" +
    "              ng-class=\"{ 'nw-button--active': $ctrl.editMode }\"\n" +
    "              ng-if=\"$ctrl.isSourceModeAllowed\"\n" +
    "              touchstart=\"event.preventDefault()\"\n" +
    "              ng-click=\"$ctrl.toggleEditMode();$event.preventDefault();\"\n" +
    "              ng-disabled=\"$ctrl.disabled\">\n" +
    "        Edit HTML\n" +
    "      </button>\n" +
    "    </li>\n" +
    "  </ul>\n" +
    "\n" +
    "  <div class=\"nw-editor-container\">\n" +
    "    <div class=\"nw-editor__src-container ng-hide\" ng-show=\"$ctrl.editMode\">\n" +
    "      <textarea ng-model=\"$ctrl.content\" style=\"overflow-y:scroll\" aria-label=\"text\" \n" +
    "                ng-disabled=\"$ctrl.disabled\"\n" +
    "                class=\"nw-editor__src\"></textarea>\n" +
    "    </div>\n" +
    "    <div class=\"nw-editor\" ng-show=\"!$ctrl.editMode\" ng-class=\"{ 'nw-disabled': $ctrl.disabled }\">\n" +
    "      <div id=\"ng-wig-editable\"\n" +
    "           class=\"ng-wig-editable nw-editor__res\"\n" +
    "           ng-class=\"{'nw-invisible': $ctrl.editMode}\"\n" +
    "           ng-disabled=\"$ctrl.disabled\"\n" +
    "           contenteditable\n" +
    "           placeholder=\"{{$ctrl.placeholder}}\">\n" +
    "      </div>\n" +
    "    </div>\n" +
    "  </div>\n" +
    "</div>\n");
}]);

