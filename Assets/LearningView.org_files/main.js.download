    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getChecklistCount = function(checklist){
      if(checklist && checklist != ''){
        var count = (checklist.match(/1/g) || []).length;
        return count;
      }
      return 0;
    }
    self.getIconForStatusButton = function(s,task){ // for result table and result drop down (teacher)
      var teacher = s.FeedbackStatus;
      var answer = s.Answer;
      var status = s.Status;
      var checklist = s.Checklist;

      if(teacher && teacher != ""){
        if(teacher == "OK") return ('<i class="fa fa-check fa-fw" style="color:green; -webkit-text-stroke: 1px white; text-stroke: 1px white;"></i>');
        if(teacher == "x") return ('<i class="fa fa-exclamation-triangle fa-fw" style="color:red; -webkit-text-stroke: 1px white; text-stroke: 1px white;"></i>');
        if(teacher == "c") return ('<span style="position:relative"><i class="fa fa-lock fa-fw"></i>'+
                                   (status == "OK" || status == "FAIL" ? '<i class="fa fa-check" style="position:absolute;font-size:8px;left:12px;top:0px;color:#777"></i>':'')+
                                   (status == "x" ? '<i class="fa fa-times" style="position:absolute;font-size:8px;left:12px;top:0px;color:red"></i>':'')+'</span>');
      }
      if(status == "" || status == "w" || !status) {
        // checklist auswerten
        if(checklist && checklist != ''){
          var count = (checklist.match(/1/g) || []).length;
          if(count == 0) return '';
          return ('<span style="line-height:38px;font-weight:300;font-size:14px">'+count+'/'+checklist.length+'</span>');        
        }
        return ('<i class="fa fa-fw"></i>');
      }
      if(task && (task.Type == "test" || task.Type == "learningapp")){
        if(status == "OK" && answer && answer != ''){
          status = "FAIL";
        }
      }
      if(status == "OK") return ('<i class="fa fa-check fa-fw"></i>');
      //if(s == "w") return ('<i class="fa fa-pencil fa-fw"></i>');
      if(status == "?") return ('<i class="fa fa-comments fa-fw"></i>');
      if(status == "x") return ('<i class="fa fa-exclamation-triangle fa-fw" style="color:red;"></i>');
      if(status == "pw") return ('<i class="fa fa-hourglass-o fa-fw"></i>');
      if(status == "re") return ('<i class="fa fa-refresh fa-fw"></i>');
      if(status == "s") return ('<i class="fa fa-fw fa-hand-paper-o"></i>');
      if(status == "FAIL") return ('<span style="line-height:38px;font-weight:300;font-size:14px">'+ (answer ? answer.split("|")[0] : '')+'</span>');

      return '';
    };

    self.getUserStatusTaskIcon = function(s,task){ // for task buttons of students
      var teacher = s.FeedbackStatus;
      var answer = s.Answer;
      var status = s.Status;
      var checklist = s.Checklist;

      if(teacher && teacher != ""){
        if(teacher == "OK") return ('<i class="fa fa-check fa-fw"></i>');
        if(teacher == "x") return ('<i class="fa fa-exclamation-triangle fa-fw"></i>');
        if(teacher == "c") return ('<span style="position:relative"><i class="fa fa-lock fa-fw"></i>'+
                                   (status == "OK" || status == "FAIL" ? '<i class="fa fa-check" style="position:absolute; text-shadow: 0px 0px 4px white;left:8.5px;top:-9px;color:#009136"></i>':'')+
                                   (status == "x" ? '<i class="fa fa-times" style="position:absolute; text-shadow: 0px 0px 4px white;left:8.5px;top:-9px;color:red"></i>':'')+'</span>');

      }
      if(status == "" || status == "w" || !status) {
        // checklist auswerten
        if(checklist && checklist != ''){
          var count = (checklist.match(/1/g) || []).length;
          if(count == 0) return '';
          return ('<span style="line-height:38px;font-weight:300;font-size:18px">'+count+'/'+checklist.length+'</span>');        
        }
        return '';
      }
      if(task && (task.Type == "test" || task.Type == "learningapp")){
        if(status == "OK" && answer && answer != ''){
          status = "FAIL";
        }
      }
      if(status == "OK") return ('<i class="fa fa-check fa-fw"></i>');
      if(status == "?") return ('<i class="fa fa-comments fa-fw"></i>');
      if(status == "x") return ('<i class="fa fa-exclamation-triangle fa-fw"></i>');
      if(status == "pw") return ('<i class="fa fa-hourglass-o fa-fw"></i>');
      if(status == "re") return ('<i class="fa fa-refresh fa-fw"></i>');
      if(status == "s") return ('<i class="fa fa-fw fa-hand-paper-o"></i>');
      if(status == "FAIL") return ('<span style="line-height:38px;font-weight:300;font-size:18px">'+ (answer ? answer.split("|")[0] : '')+'</span>');

      return '';
    };

    self.getLevelForResultButton = function(level){
      if(level == 1) return ("<div></div>");
      if(level == 2) return ("<div></div><div></div>");
      if(level == 3) return ("<div></div><div></div><div></div>");
      if(level == 4) return ("<div></div><div></div><div></div><div></div>");
      if(level == 5) return ("<div></div><div></div><div></div><div></div><div></div>");
      return "";
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Content class Visibility
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addClassesContentVisibilityScope = function($scope){
      $scope.setScopeVariablesFromClassContent = function (localScope,c){
        var content = c ? self.classContent[c.ID] : self.userContent;
        localScope.mt = null;
        localScope.t = null;
        localScope.g = null;
        localScope.tt = null;

        if($scope.type == "maintopic"){
          localScope.mt = Object.assign({}, $scope.it);
          for(var z=0; z < content.mainTopics.length; z++){
            if(content.mainTopics[z].ID == $scope.it.ID){
              localScope.mt = content.mainTopics[z];
              break;
            }
          }
        }
        if($scope.type == "topic"){
          localScope.t = Object.assign({}, $scope.it);
          for(var z=0; z < content.mainTopics.length; z++){
            if(content.mainTopics[z].ID == $scope.it.MainTopic){
              localScope.mt = content.mainTopics[z];
              for(var x=0; x < content.mainTopics[z].topics.length; x++){
                if(content.mainTopics[z].topics[x].ID == $scope.it.ID){
                  localScope.t = content.mainTopics[z].topics[x];
                  break;
                }
              }
              break;
            }
          }
          if((!localScope.mt || !localScope.t) && c != self.userContent){
            // not yet in class content, try from user content
            $scope.setScopeVariablesFromClassContent(localScope,null);
          }
        }
        if($scope.type == "goal"){
          localScope.g = Object.assign({}, $scope.it);
          for(var z=0; z < content.mainTopics.length; z++){
            if(content.mainTopics[z].ID == self.currentMainTopic.ID){
              localScope.mt = content.mainTopics[z];
              for(var x=0; x < content.mainTopics[z].topics.length; x++){
                if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                  localScope.t = content.mainTopics[z].topics[x];
                  for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                    if(content.mainTopics[z].topics[x].goals[y].ID == $scope.it.ID){
                      localScope.g = content.mainTopics[z].topics[x].goals[y];
                      break;
                    }
                  }
                  break;
                }
              }
              break;
            }
          }
          if((!localScope.mt || !localScope.t || !localScope.g) && c != self.userContent){
            // not yet in class content, try from user content
            $scope.setScopeVariablesFromClassContent(localScope,null);
          }
        }

        if($scope.type == "task"){
          localScope.tt = Object.assign({}, $scope.it);
          for(var z=0; z < content.mainTopics.length; z++){
            if(content.mainTopics[z].ID == self.currentMainTopic.ID){
              localScope.mt = content.mainTopics[z];
              for(var x=0; x < content.mainTopics[z].topics.length; x++){
                if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                  localScope.t = content.mainTopics[z].topics[x];
                  for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                    if(content.mainTopics[z].topics[x].goals[y].ID == $scope.it.LearningGoal){
                      localScope.g = content.mainTopics[z].topics[x].goals[y];
                      for(var w=0; w < content.mainTopics[z].topics[x].goals[y].tasks.length; w++){
                        if(content.mainTopics[z].topics[x].goals[y].tasks[w].ID == $scope.it.ID){
                          localScope.tt = content.mainTopics[z].topics[x].goals[y].tasks[w];
                          break;
                        }
                      }
                      break;
                    }
                  }
                  break;
                }
              }
              break;
            }
          }
          if((!localScope.mt || !localScope.t || !localScope.g || !localScope.tt) &&
             content != self.userContent){
            // not yet in class content, try from user content
            $scope.setScopeVariablesFromClassContent(localScope,null);
          }
        }

        if($scope.type == "tasks"){
          localScope.tt = Object.assign({}, $scope.it[0]);
          for(var z=0; z < content.mainTopics.length; z++){
            if(content.mainTopics[z].ID == self.currentMainTopic.ID){
              localScope.mt = content.mainTopics[z];
              for(var x=0; x < content.mainTopics[z].topics.length; x++){
                if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                  localScope.t = content.mainTopics[z].topics[x];
                  for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                    if(content.mainTopics[z].topics[x].goals[y].ID == $scope.it[0].LearningGoal){
                      localScope.g = content.mainTopics[z].topics[x].goals[y];
                      for(var w=0; w < content.mainTopics[z].topics[x].goals[y].tasks.length; w++){
                        if(content.mainTopics[z].topics[x].goals[y].tasks[w].ID == $scope.it[0].ID){
                          localScope.tt = content.mainTopics[z].topics[x].goals[y].tasks[w];
                          break;
                        }
                      }
                      break;
                    }
                  }
                  break;
                }
              }
              break;
            }
          }
          if((!localScope.mt || !localScope.t || !localScope.g || !localScope.tt) &&
             content != self.userContent){
            // not yet in class content, try from user content
            $scope.setScopeVariablesFromClassContent(localScope,null);
          }
        }

        $scope.mt = localScope.mt;
        $scope.t = localScope.t;
        $scope.g = localScope.g;
        $scope.tt = localScope.tt;
        return true;
      };

      $scope.toggleSelect = function(c){
        var p = $scope.selection.indexOf(c.ID);
        if(p == -1)
          $scope.selection.push(c.ID); else
          $scope.selection.splice(p,1);
      };

      $scope.selectAll = function(){
        for(var i=0; i < self.classListCurrent.length; i++){
          if($scope.disabled.indexOf(self.classListCurrent[i].ID) != -1) continue;
          if($scope.selection.indexOf(self.classListCurrent[i].ID) == -1)
             $scope.selection.push(self.classListCurrent[i].ID);
        }
      };

      $scope.selectNone = function(){
        for(var i=0; i < self.classListCurrent.length; i++){
          if($scope.disabled.indexOf(self.classListCurrent[i].ID) != -1) continue;
          var p = $scope.selection.indexOf(self.classListCurrent[i].ID);
          if(p != -1) $scope.selection.splice(p,1);
        }
      };
      $scope.lastSelection = JSON.parse(angular.toJson($scope.selection));


      $scope.saveNow = function() {
        var refreshTimeout = null;
        var refresh = function(){
          // force refresh of all data again, because new content
          // was added but user data not changed yet
          $timeout(function(){
            self.lastUpdateTime = 0;
            self.keepAliveCallback().then(function(){
              self.updateClassesStatus();
            });
          },10);
          self.updateClassesStatus();
        };

        for(var i=0; i < self.classListCurrent.length; i++){
          if($scope.disabled.indexOf(self.classListCurrent[i].ID) >= 0) continue;
          var ls = $scope.lastSelection.indexOf(self.classListCurrent[i].ID);
          if(ls >= 0 && $scope.selection.indexOf(self.classListCurrent[i].ID) >= 0) continue;
          if(ls < 0 && $scope.selection.indexOf(self.classListCurrent[i].ID) < 0) continue;

          var changes = {"maintopics":[],"topics":[],"goals":[],"tasks":[]};
          var list = null;
          if($scope.type == "maintopic") list = changes.maintopics;
          if($scope.type == "topic") list = changes.topics;
          if($scope.type == "goal") list = changes.goals;
          if($scope.type == "task") list = changes.tasks;
          if(!list)return;

          list.push({"ID":$scope.it.ID,
                     "used":$scope.selection.indexOf(self.classListCurrent[i].ID) >= 0 ?
                       '1':'0'});

          if($scope.selection.indexOf(self.classListCurrent[i].ID) >= 0){
            // now selected, add all sub elements too
            if($scope.type == "maintopic"){
              for(var z=0; z < $scope.it.topics.length; z++){
                changes.topics.push({"ID":$scope.it.topics[z].ID, "used":'1'});
                for(var x=0; x < $scope.it.topics[z].goals.length; x++){
                  changes.goals.push({"ID":$scope.it.topics[z].goals[x].ID, "used":'1'});
                  for(var y=0; y < $scope.it.topics[z].goals[x].tasks.length; y++){
                    changes.tasks.push({"ID":$scope.it.topics[z].goals[x].tasks[y].ID, "used":'1'});
                  }
                }
              }
            }
            if($scope.type == "topic"){
              changes.maintopics.push({"ID":$scope.mt.ID, "used":'1'});
              for(var x=0; x < $scope.it.goals.length; x++){
                changes.goals.push({"ID":$scope.it.goals[x].ID, "used":'1'});
                for(var y=0; y < $scope.it.goals[x].tasks.length; y++){
                  changes.tasks.push({"ID":$scope.it.goals[x].tasks[y].ID, "used":'1'});
                }
              }
            }
            if($scope.type == "goal"){
              changes.maintopics.push({"ID":$scope.mt.ID, "used":'1'});
              changes.topics.push({"ID":$scope.t.ID, "used":'1'});
              for(var y=0; y < $scope.it.tasks.length; y++){
                changes.tasks.push({"ID":$scope.it.tasks[y].ID, "used":'1'});
              }
            }
            if($scope.type == "task"){
              changes.maintopics.push({"ID":$scope.mt.ID, "used":'1'});
              changes.topics.push({"ID":$scope.t.ID, "used":'1'});
              changes.goals.push({"ID":$scope.g.ID, "used":'1'});
            }
          }

          self.apiPost("ajax",{"action":"setClassesContentInUse",
                               "classid":self.classListCurrent[i].ID,
            "changes":angular.toJson(changes)}).then(function(data){
            if(refreshTimeout) $timeout.cancel(refreshTimeout);
            refreshTimeout = $timeout(refresh,100);
          });

        }
      };
    };

    self.getShowStudentResultsCurrentTask = function(scope){
      if(self.currentTask)
        return self.currentTask;
      if(scope && scope.it && scope.it.LearningGoal && scope.it.ID)
        return scope.it;
      if(self.shiftSelectedTasks && self.shiftSelectedTasks.length == 1)
        return self.shiftSelectedTasks[0];
      return null;
    }
    self.getShowStudentResultsCurrentGoal = function(scope){
      if(self.currentTask){
        var goal = self.getGoalByID(self.currentTask.LearningGoal);
        if(goal) return goal.goal;
      }
      if(scope && scope.it && scope.it.Topic && scope.it.ID){
        return scope.it;
      }
      var gg = null;
      for(var i=0; i < self.shiftSelectedTasks.length; i++){
        goal = self.getGoalByID(self.shiftSelectedTasks[i].LearningGoal);
        if(goal){
          if(gg == null || gg.ID == goal.goal.ID) gg = goal.goal; else {
            gg = null;
            break;
          }
        } 
      }   
      if(gg) return gg;
      return null;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Class content Visibility
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addContentVisibilityScope = function($scope){
      $scope.isTeacher = self.user.Teacher == 1;

      $scope.loadTimes = function(){
        if($scope.it && $scope.it.ID){
          $scope.use_vNow = true;
          $scope.use_vFrom = $scope.it.vFrom && $scope.it.vFrom != 0;
          $scope.use_vTo = $scope.it.vTo && $scope.it.vTo != 0;
          $scope.use_vNow = !($scope.use_vFrom || $scope.use_vTo);

          $scope.vFromDate = null;
          $scope.vFromTime = null;
          if($scope.use_vFrom){
            var p = $scope.it.vFrom.split(" ");
            $scope.vFromDate = moment(p[0]).toDate();
            var p2 = p[1].split(":");
            //if(p2[0].length > 1 && p2[0][0] == "0") p2[0] = p2[0][1]+"";
            $scope.vFromTime = p2[0]+":"+p2[1];
          }
          $scope.vToDate = null;
          $scope.vToTime = null;
          if($scope.use_vTo){
            var p = $scope.it.vTo.split(" ");
            $scope.vToDate = moment(p[0]).toDate();
            var p2 = p[1].split(":");
            //if(p2[0].length > 1 && p2[0][0] == "0") p2[0] = p2[0][1]+"";
            $scope.vToTime = p2[0]+":"+p2[1];
          }
        }
      };
      $scope.loadTimes();
      
      if(!$scope.c && !self.currentClass){
        self.showStudentsResults = null;
      }
      if(self.showStudentsResults == "task" && !self.getShowStudentResultsCurrentTask($scope)) 
         self.showStudentsResults = null;
      if(self.showStudentsResults == "goal" && !self.getShowStudentResultsCurrentGoal($scope)) 
         self.showStudentsResults = null;

      $scope.showSelectShowResultGoalDialog = function(ev){
        // show dialog to select a goal from the class
        var c = $scope.c ? $scope.c : self.currentClass;
        if(!c) return;
        var parent = $scope;
        self.pickLearningGoal(self.showStudentsResultsGoal,c.ID,function(g){
          self.showStudentsResultsGoal = g;
          $scope.changeShowStudentsResults("setgoal");
        });
      };
      $scope.selectShowResultGoal = function(ev){
        if(self.showStudentsResultsGoal){
          $scope.changeShowStudentsResults("setgoal");
        }else{
          $scope.showSelectShowResultGoalDialog(ev);
        }
      };
      $scope.showSelectShowResultTaskDialog = function(ev){
        // show dialog to select a task from the class
        var c = $scope.c ? $scope.c : self.currentClass;
        if(!c) return;
        var parent = $scope;
        self.pickTask(self.showStudentsResultsTask,c.ID,function(t){
          self.showStudentsResultsTask = t;
          $scope.changeShowStudentsResults("settask");
        });
      };
      $scope.selectShowResultTask = function(ev){
        if(self.showStudentsResultsTask){
          $scope.changeShowStudentsResults("settask");
        }else{
          $scope.showSelectShowResultTaskDialog(ev);
        }
      };

      $scope.changeShowStudentsResults = function(v){
        self.showStudentsResults = null;
        $timeout(function(){
          self.showStudentsResults = v;
        },1);
      }
      $scope.selectAllWith =function(action,type,status,it,value,c){
        if(!c) c = $scope.c ? $scope.c : self.currentClass;
        if(!c) return;
        if(type == "goal"){
          for(var i=0; i < c.students.length; i++){
            var s = self.getUserLearningGoalStatus(it,c.students[i],true);
            if(s[status] == value){
              var p = $scope.selection.indexOf(c.students[i].ID);
              if(action == "add" && p == -1)
                $scope.selection.push(c.students[i].ID);
              if(action == "remove" && p != -1)
                $scope.selection.splice(p,1);
            }
          }
        }
        if(type == "task"){
          for(var i=0; i < c.students.length; i++){
            var s = self.getUserTaskStatus(it,c.students[i],true);
            if(s[status] == value){
              var p = $scope.selection.indexOf(c.students[i].ID);
              if(action == "add" && p == -1)
                $scope.selection.push(c.students[i].ID);
              if(action == "remove" && p != -1)
                $scope.selection.splice(p,1);
            }
          }
        }
      }

      $scope.refreshTimes = function(){
        $scope.vFromDateTime = 0;
        $scope.vToDateTime = 0;
        $scope.use_vNow = !($scope.use_vFrom || $scope.use_vTo);

        if($scope.use_vFrom){
          if(!$scope.vFromDate) {
            $scope.vFromDate = new Date();
            // remember a last date used last time someone clicked today
            if(self.lastFromTime){
              var tp = self.lastFromTime.split(" ");
              $scope.vFromDate = moment(tp[0]).toDate();
            }
          }
          if(!$scope.vFromTime) {
            $scope.vFromTime = "00:00";
            if(self.lastFromTime){
              var tp = self.lastFromTime.split(" ");
              var tp2 = tp[1].split(":");
              $scope.vFromTime = tp2[0]+":"+tp2[1];
            }
          }
          $scope.vFromDateTime = moment($scope.vFromDate).format("YYYY-MM-DD") + " "+($scope.vFromTime ? $scope.vFromTime : '00:00')+":00";
        }
        if($scope.use_vTo){
          if(!$scope.vToDate) {
            $scope.vToDate = $scope.vFromDate ? $scope.vFromDate : new Date();
            if(self.lastToTime){
              var tp = self.lastToTime.split(" ");
              $scope.vToDate = moment(tp[0]).toDate();
            }
          }
          if(!$scope.vToTime) {
            $scope.vToTime = "23:59";
            if(self.lastToTime){
              var tp = self.lastToTime.split(" ");
              var tp2 = tp[1].split(":");
              $scope.vToTime = tp2[0]+":"+tp2[1];
            }
          }
          $scope.vToDateTime = moment($scope.vToDate).format("YYYY-MM-DD")+ " "+($scope.vToTime ? $scope.vToTime : '00:00')+":00";
        }
      };
      $scope.refreshTimes();

      $scope.toggleSelect = function(s){
        var p = $scope.selection.indexOf(s.ID);
        if(p == -1)
          $scope.selection.push(s.ID); else
          $scope.selection.splice(p,1);
      };

      $scope.selectAll = function(c){
        var skipDisabled = false;
        var skip = 0;
        for(var i=0; i < c.students.length; i++){
          if($scope.disabled.indexOf(c.students[i].ID) != -1) skip++;
        }
        if(skip < c.students.length / 2) skipDisabled = true;

        for(var i=0; i < c.students.length; i++){
          if(skipDisabled && $scope.disabled.indexOf(c.students[i].ID) != -1) continue;
          if($scope.selection.indexOf(c.students[i].ID) == -1)
             $scope.selection.push(c.students[i].ID);
        }
      };

      $scope.selectNone = function(c){
        for(var i=0; i < c.students.length; i++){
          if($scope.required && $scope.required.indexOf(c.students[i].ID) != -1) continue;
          var p = $scope.selection.indexOf(c.students[i].ID);
          if(p != -1) $scope.selection.splice(p,1);
        }
      };

      $scope.currentFavoriteGroups = [];

      $scope.addFavoriteGroup = function(c,ev){
        self.prompt($filter('trans')('ADDFAVORITEGROUP')+":",$filter('trans')('SAVE'),$filter('trans')('ADDFAVORITEGROUPNAME'),"",ev).then(function(name){
          self.apiPost("ajax",{"action":"addClassUserGroup", "classid":c.ID,
                               "name":name, "users":""})
           .then(function(data) {
              if(data.groups && c) c.groups = data.groups;
              $scope.editFavoriteGroup = data.group;
              $scope.selectFavoriteGroup(c,data.group);
            });
        });
      };

      $scope.deleteFavoriteGroup = function(c,g,ev){
        self.confirm($filter('trans')('REMOVEFAVORITEGROUP',g.Name),$filter('trans')('DELETE'),ev).then(function(){
          self.apiPost("ajax",{"action":"deleteClassUserGroup", "classid":c.ID, "ID":g.ID})
           .then(function(data) {
              if(data.groups && c) c.groups = data.groups;
              $scope.editFavoriteGroup = null;
            });
        });
      };
      $scope.saveFavoriteGroupName = function(c,g,name,ev){
        if(g.Name == name) return;
        g.Name = name;
        self.apiPost("ajax",{"action":"updateClassUserGroup", "classid":c.ID, "ID":g.ID, "name":g.Name,"users":g.Users});
      };

      $scope.selectFavoriteGroup = function(c,g){
        $scope.selection = [];
        if($scope.required) $scope.selection = $scope.required.slice(0);

        var skipDisabled = false;
        var skip = 0;
        for(var i=0; i < c.students.length; i++){
          if($scope.disabled.indexOf(c.students[i].ID) != -1) skip++;
        }
        if(skip < c.students.length / 2) skipDisabled = true;

        var ids = g.Users.split(",").map(Number);
        for(var i=0; i < ids.length; i++){
          if(ids[i] === "") continue;
          //if($scope.disabled.indexOf(ids[i]) != -1) continue;

          for(var s=0; s < c.students.length; s++){
            if(c.students[s].ID == ids[i]) {
              if(skipDisabled && $scope.disabled && $scope.disabled.indexOf(ids[i]) != -1) continue;
              if($scope.selection.indexOf(ids[i]) == -1)
                 $scope.selection.push(ids[i]);
              break;
            }
          }
        }
      };

      $scope.isFavoriteGroupSelected = function(g){
        if(!$scope.currentFavoriteGroups) return false;
        for(var i=0; i < $scope.currentFavoriteGroups.length; i++){
          if($scope.currentFavoriteGroups[i].ID == g.ID) return true;
        }
        return false;
      };
      $scope.isFavoriteGroup = function(c){
        $scope.currentFavoriteGroups = [];
        if($scope.selection.length == 0) return false;
        var matches = [];
        for(var i=0; i < c.groups.length; i++){
          var ids = c.groups[i].Users.split(",").map(Number);
          var distance = 0;
          isMatch = true;
          for(var s=0; s < $scope.selection.length; s++){
            if(ids.indexOf($scope.selection[s]) == -1){
              isMatch = false;
              break;
            }
          }
          if(isMatch)
          for(var z=0; z < ids.length; z++){
            if(ids[z] === "") continue;
            if($scope.selection.indexOf(ids[z]) == -1){
              for(var s=0; s < c.students.length; s++){
                if(c.students[s].ID == ids[z]) {
                  isMatch = false;
                  break;
                }
              }
              distance++;
            }
            if(!isMatch) break;
          }
          if(isMatch){
            if($scope.selection.length == c.students.length && distance > 0)
              continue; // all selected but some missing, not the same group
            matches.push([distance, c.groups[i]]);
          }
        }

        matches.sort(function(a,b){
          var oa = a[0];
          var ob = b[0];
          return oa < ob ? -1 : (oa > ob ? 1 : 0);
        });
        for(var i=0; i < matches.length; i++){
          $scope.currentFavoriteGroups.push(matches[i][1]);
        }
        return $scope.currentFavoriteGroups.length > 0;
      };

      $scope.setSubItemsVisibility = function(type,ev){
        var mt = null;
        var c = $scope.c;

        if(type == "maintopic"){
          mt = $scope.it.org ? $scope.it.org : $scope.it;
        }
        if(type == "topic"){
          mt = {ID:$scope.mt.ID, Name:$scope.mt.Name, topics:[$scope.it.org ? $scope.it.org : $scope.it]};
        }
        if(type == "goal"){
          mt = {ID:$scope.mt.ID, Name:$scope.mt.Name, topics:[{ID:$scope.t.ID, Name:$scope.t.Name, goals:[$scope.it.org ? $scope.it.org : $scope.it]}]};
        }

        self.showDialog({
          templateUrl: "classSubContentVisibility.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.items = [];
            $scope.c = c;
            $scope.invisible = {};
            for(var i=0; i <c.students.length; i++)
              $scope.invisible[c.students[i].ID] = [];

            for(var i=0; i < mt.topics.length; i++){
              var item = {};
              item.ID = mt.topics[i].ID;
              item.Name = mt.topics[i].Name;
              item.items = [];
              for(var z=0; z < mt.topics[i].goals.length; z++){
                var t = {};
                t.ID = mt.topics[i].goals[z].ID;
                t.Name = mt.topics[i].goals[z].Name;
                t.tasks = mt.topics[i].goals[z].tasks;
                if(t.tasks.length == 0) continue; // skip empty
                for(var x = 0; x < t.tasks.length; x++){
                  for(var s=0; s < c.students.length; s++){
                    var vis = self.isUserTaskVisible(t.tasks[x], c.students[s],c,true);
                    if(!vis) $scope.invisible[c.students[s].ID].push(t.tasks[x].ID);
                  }
                }
                item.items.push(t);
              }
              if(item.items.length == 0) continue; // skip empty
              $scope.items.push(item);
              $scope.selectedTopic = $scope.items[0];
            }
            $scope.toggleVisible = function(s,a){
              var p = $scope.invisible[s.ID].indexOf(a.ID);
              if(p != -1){
                $scope.invisible[s.ID].splice(p,1); // remove
              }else{
                $scope.invisible[s.ID].push(a.ID); // add
              }
            };
            $scope.toggleVisibleRow = function(s,tasks){
              var hasVisible = false;
              for(var i=0; i < tasks.length; i++){
                var a = tasks[i];
                var p = $scope.invisible[s.ID].indexOf(a.ID);
                if(p == -1) hasVisible = true;
              }
              if(hasVisible){
                for(var i=0; i < tasks.length; i++){
                  var a = tasks[i];
                  var p = $scope.invisible[s.ID].indexOf(a.ID);
                  if(p == -1)
                    $scope.invisible[s.ID].push(a.ID); // add
                }
              }else{
                for(var i=0; i < tasks.length; i++){
                  var a = tasks[i];
                  var p = $scope.invisible[s.ID].indexOf(a.ID);
                  if(p != -1)
                    $scope.invisible[s.ID].splice(p,1); // remove
                }
              }
            };
            $scope.toggleVisibleColumn = function(a){
              var hasVisible = false;
              for(var i=0; i < c.students.length; i++){
                var s = c.students[i];
                var p = $scope.invisible[s.ID].indexOf(a.ID);
                if(p == -1) hasVisible = true;
              }
              if(hasVisible){
                for(var i=0; i < c.students.length; i++){
                  var s = c.students[i];
                  var p = $scope.invisible[s.ID].indexOf(a.ID);
                  if(p == -1)
                    $scope.invisible[s.ID].push(a.ID); // add
                }
              }else{
                for(var i=0; i < c.students.length; i++){
                  var s = c.students[i];
                  var p = $scope.invisible[s.ID].indexOf(a.ID);
                  if(p != -1)
                    $scope.invisible[s.ID].splice(p,1); // remove
                }
              }
            };
            $scope.toggleVisibleColumnAndRow = function(tasks){
              var hasVisible = false;
              for(var i=0; i < c.students.length; i++){
                var s = c.students[i];
                for(var z=0; z < tasks.length; z++){
                  var a = tasks[z];
                  var p = $scope.invisible[s.ID].indexOf(a.ID);
                  if(p == -1) hasVisible = true;
                }
              }
              if(hasVisible){
                for(var i=0; i < c.students.length; i++){
                  var s = c.students[i];
                  for(var z=0; z < tasks.length; z++){
                    var a = tasks[z];
                    var p = $scope.invisible[s.ID].indexOf(a.ID);
                    if(p == -1)
                      $scope.invisible[s.ID].push(a.ID); // add
                  }
                }
              }else{
                for(var i=0; i < c.students.length; i++){
                  var s = c.students[i];
                  for(var z=0; z < tasks.length; z++){
                    var a = tasks[z];
                    var p = $scope.invisible[s.ID].indexOf(a.ID);
                    if(p != -1)
                      $scope.invisible[s.ID].splice(p,1); // remove
                  }
                }
              }                  
            };

            $scope.save = function (){
              self.closeDialog($scope.dialogElement);
              var tasksToChange = [];
              for(var i=0; i < mt.topics.length; i++){
                for(var z=0; z < mt.topics[i].goals.length; z++){
                  var tasks = mt.topics[i].goals[z].tasks;
                  if(tasks.length == 0) continue; // skip empty
                  for(var x = 0; x < tasks.length; x++){
                    for(var s=0; s < c.students.length; s++){
                      var vis = self.isUserTaskVisible(tasks[x], c.students[s],c,true);
                      var n = $scope.invisible[c.students[s].ID].indexOf(tasks[x].ID);
                      if( (n == -1 && !vis) || (n != -1 && vis) ){
                        // there was a change here
                        if(tasksToChange.indexOf(tasks[x]) == -1)
                           tasksToChange.push(tasks[x])
                      }
                    }
                  }
                }
              }
              for(var z=0; z < tasksToChange.length; z++){
                var hiddenFor = [];
                var a = tasksToChange[z];
                for(var i=0; i < c.students.length; i++){
                  var invis = $scope.invisible[c.students[i].ID].indexOf(a.ID);
                  if(invis != -1) hiddenFor.push(c.students[i].ID);
                }
                self.updateUserTaskVisibility(a,c,hiddenFor);
              }
            };
            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Teacher groups
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTeacherGroupsScope = function($scope){
      $scope.isTeacher = self.user.Teacher == 1;

      $scope.currentFavoriteGroups = [];

      if(self.userViewData && self.userViewData["teacherGroups"]){
        $scope.currentFavoriteGroups = JSON.parse(self.userViewData["teacherGroups"]);
      } 

      $scope.isInList = function(email){
        for(var i=0; i < $scope.invites.length; i++){
          if($scope.invites[i].Email.toLowerCase() == email.toLowerCase()) return true;
        }
        return false;
      };

      $scope.addFavoriteGroup = function(ev){
        var emails = [];
        for(var i=0; i < $scope.invites.length; i++){
          if($scope.invites[i].Email === "") continue;
          if($scope.invites[i].Email.toLowerCase() == self.user.Email.toLowerCase()) continue;
          emails.push($.trim($scope.invites[i].Email.toLowerCase()));
        }
        if(emails.length == 0){
          self.alert($filter('trans')('ADDFAVORITETEACHERGROUPHINT'));
          return;
        }

        self.prompt($filter('trans')('ADDFAVORITEGROUP')+":",$filter('trans')('SAVE'),$filter('trans')('ADDFAVORITEGROUPNAME'),"",ev).then(function(name){
          if(name == "") return;
          if(!self.userViewData["teacherGroups"]) self.userViewData["teacherGroups"] = "[]";
          var list = JSON.parse(self.userViewData["teacherGroups"]);
          for(var i=0; i < list.length; i++){
            if(list[i].Name == name){
              list.splice(i,1);
              break;
            }
          }
          list.push({"Name":name,"Users":emails.join(";")});
          self.userViewData["teacherGroups"] = angular.toJson(list);
          self.updateUserViewData();
          $scope.currentFavoriteGroups = list;
        });
      };

      $scope.deleteFavoriteGroup = function(g,ev){
        self.confirm($filter('trans')('REMOVEFAVORITEGROUP',g.Name),$filter('trans')('DELETE'),ev).then(function(){
          if(!self.userViewData["teacherGroups"]) return false;
          var list = JSON.parse(self.userViewData["teacherGroups"]);
          for(var i=0; i < list.length; i++){
            if(list[i].Name == g.Name){
              list.splice(i,1);
              self.userViewData["teacherGroups"] = angular.toJson(list);
              self.updateUserViewData();
              $scope.currentFavoriteGroups = list;
              return;
            }
          }
        });
      };

      $scope.saveFavoriteGroupName = function(g,name,ev){
        if(g.Name == name) return;
        if(!self.userViewData["teacherGroups"]) return false;
        var list = JSON.parse(self.userViewData["teacherGroups"]);
        for(var i=0; i < list.length; i++){
          if(list[i].Name == g.Name){
            list[i].Name = name;
            g.Name = name;
            self.userViewData["teacherGroups"] = angular.toJson(list);
            self.updateUserViewData();
            $scope.currentFavoriteGroups = list;
            return;
          }
        }
      };

      $scope.selectFavoriteGroup = function(g){
        if($scope.addNewInviteItem)
          if($scope.invites[$scope.invites.length-1].Email != "") $scope.addNewInviteItem();
        var emails = g.Users.split(";");
        for(var i=0; i< emails.length; i++){
          if($scope.isInList($.trim(emails[i]))) continue;
          if($scope.addNewInviteItem) {
            $scope.invites[$scope.invites.length-1].Email = $.trim(emails[i]).toLowerCase();
            $scope.addNewInviteItem();
          }else{
            $scope.invites.push({Email:$.trim(emails[i]).toLowerCase()});
          }
        }
      };

      $scope.isFavoriteGroupSelected = function(g){
        if(!self.userViewData["teacherGroups"]) return false;
        var list = JSON.parse(self.userViewData["teacherGroups"]);
        for(var i=0; i < list.length; i++){
          if(list[i].Name == g.Name){
            var emails = list[i].Users.split(";");
            var allset = true;
            for(var z=0; z < emails.length; z++){
              if($scope.isInList($.trim(emails[z]))) continue;
              allset = false;
              break;
            }
            return allset;
          }
        }
        return false;
      };

      $scope.isFavoriteGroup = function(){
        if(!self.userViewData["teacherGroups"]) return false;
        var list = JSON.parse(self.userViewData["teacherGroups"]);
        for(var i=0; i < list.length; i++){
          var emails = list[i].Users.split(";");
          var allset = true;
          for(var z=0; z < emails.length; z++){
            if($scope.isInList($.trim(emails[z]))) continue;
            allset = false;
            break;
          }
          if(allset) return true;
        }
        return false;
      };
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Class content Checks
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addContentChecksScope = function($scope){
      // reuse from Visibility
      self.addContentVisibilityScope($scope);

      $scope.setOne = function(s,v){
        $scope.values[s.ID] = v;
      };

      $scope.setMultiple = function(value,userids){
        if(userids == "*"){
          userids = [];
          for(var i=0; i < $scope.c.students.length; i++){
            userids.push($scope.c.students[i].ID);
          }
        }
        for(var i=0; i < userids.length; i++){
          $scope.values[userids[i]] = value;
        }
      };

      $scope.setRandom = function(value,percent){
        var userids = [];
        var num = Math.round(percent * $scope.c.students.length);
        for(var k in $scope.values){
          if($scope.values[k] == value) $scope.values[k] = 0;
        }
        var countFree = 0;
        for(var i=0; i < $scope.c.students.length; i++){
          if(!$scope.values[$scope.c.students[i].ID]) countFree++;
        }
        var canFill = false;
        if(countFree >= num) canFill = true;
        while(num > 0){
          var r = Math.floor(Math.random()*$scope.c.students.length);
          var id = $scope.c.students[r].ID;
          if(userids.indexOf(id) != -1) continue;
          if(canFill && $scope.values[id] != 0) continue;
          userids.push(id);
          num--;
        }
        for(var i=0; i < userids.length; i++){
          $scope.values[userids[i]] = value;
        }
      };

    };
