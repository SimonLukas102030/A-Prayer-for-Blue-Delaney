          for(var i=0; i < c.students.length; i++){
            var disabled = !self.isUserMainTopicVisible(it, c.students[i],c,true);
            if(disabled) $scope.disabled.push(c.students[i].ID);
            var value = self.getUserMainTopicChecks(it, c.students[i],c);
