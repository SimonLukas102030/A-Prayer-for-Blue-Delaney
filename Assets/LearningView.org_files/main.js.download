    self.setTaskCheckInClass = function(task,ev){
      // display a select dialog with all students to select all or some and the current closed status
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classTaskCheckSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.t = task;
          $scope.c = self.currentClass;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.required = [];
          $scope.smallScreen = self.isSmallScreen;

          for(var i=0; i < self.currentClass.students.length; i++){
            var r = self.findTaskInClass(self.currentClass,task.ID,self.currentClass.students[i]);
            if(!r){
              $scope.disabled.push(self.currentClass.students[i].ID);
              continue;
            }else{
              //$scope.selection.push(self.currentClass.students[i].ID);
              var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
              if(status.FeedbackStatus == 'OK') $scope.selection.push(self.currentClass.students[i].ID);
            }
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // apply $scope.selection
            var count = 0;

            for(var i=0; i < self.currentClass.students.length; i++){
              var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
              if($scope.selection.indexOf(self.currentClass.students[i].ID) != -1 && 
                (status.FeedbackStatus != 'OK')) {
                count++;
                self.saveTeacherTaskStatus(task,self.currentClass.students[i],{Status:'OK'},null,true).then(function(){
                  count--;
                  if(count == 0) self.keepAliveCallback();
                });
              } 
              if($scope.selection.indexOf(self.currentClass.students[i].ID) == -1 && 
                (status.FeedbackStatus == 'OK')) {
                count++;
                self.saveTeacherTaskStatus(task,self.currentClass.students[i],{Status:(status.Answer && status.Answer != '' ? '?':'w')},null,true).then(function(){
                  count--;
                  if(count == 0) self.keepAliveCallback();
                });
              }
            }

            self.closeDialog($scope.dialogElement);
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
