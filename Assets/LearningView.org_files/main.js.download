                self.downloadFile(url,filename,true);
                $timeout(function(){$scope.waitForDownload = false;},500);
              }else{
                $('body').append(frame);
                checkDownload();
              }
            };

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.lastClassOnReset = null;
    self.editInsideTopicSwitched = false;

    self.openSelectClassMenu = function(ev){
      self.showLoadingIndicator(ev,function(done){
        if(self.currentClass == null && self.lastClassOnReset){
          self.openClass(self.findClassByID(self.lastClassOnReset.ID),ev);
          return;
        }
        var position = $mdPanel.newPanelPosition()
        .relativeTo('#navbarTeachBtn')
        .addPanelPosition('align-start', 'below');

        var panel = self.showPanel({
          attachTo: angular.element(document.body),
          templateUrl: "selectclassmenu.html",
          position: position,
          openFrom: ev,
          clickOutsideToClose: true,
          escapeToClose: true,
          focusOnOpen: true,
          zIndex: 3,
          controller: function (mdPanelRef, $scope, $mdPanel) {
            $scope.self = self;
            $scope.openClass = function(it,$event){
              self.showLoadingIndicator(ev,function(done){
                self.openClass(it,$event);
                done();
                mdPanelRef.close();
              });

            };
          }
        });
        done();
      });
    };

    self.openMaterials = function(ev){
      var deferred = $q.defer();
      //self.runUpLearningGoalList();
      self.shiftSelectedTasks = [];

      if(self.currentTeacherNavigation != "Prep"){
        // close all popups when switching to materials
        while(self.dialogStack.length > 0){
          self.closeDialog();
        }
        if(self.currentOpenChatDialog){
          self.currentOpenChatDialog.close();
        }
        self.showLoadingIndicator(ev,function(done){
          var finish = function(){
            self.runUpMainTopicList();
            done();
            deferred.resolve();
            self.keepAliveCallback();
          };
          self.currentTeacherNavigation = "Prep";
          self.resetClass();
          if(self.currentMainTopic && !self.hasMaxPermission(self.currentMainTopic,1)){
            self.resetMainTopic().then(finish);
          }else {
            // fetch new from user content
            if(self.currentMainTopic){
              var mt = self.getMainTopicByID(self.currentMainTopic.ID);
              var it = null;
              if(!mt){
                self.resetMainTopic().then(finish);
                return;
              }
              for(var i=0; i < mt.topics.length; i++){
                if(mt.topics[i].ID == self.currentTopic.ID){
                  it = mt.topics[i];
                  break;
                }
              }
              if(!it){
                self.resetMainTopic().then(finish);
                return;
              }
              self.setCurrentTopic(mt,it);
            }
            finish();
          }
        });
      }else{
        deferred.resolve();
      }
      return deferred.promise;
    }

    self.waitForClassPageInit = false;

    self.openEditClasses = function(ev){
      if(self.currentOpenChatDialog){
        self.currentOpenChatDialog.close();
      }
      self.showLoadingIndicator(ev,function(done){
        self.currentTeacherNavigation = "Classes";
        self.manageClassView = true;
        self.waitForClassPageInit = true;
        if(self.currentClass != null){
          self.lastClassOnReset = self.currentClass;
          self.currentClass = null;
        }
        $timeout(function(){
          self.waitForClassPageInit = false;
          if(self.lastClassOnReset && self.lastClassOnReset.Archived == "0"){
            self.editClass(self.findClassByID(self.lastClassOnReset.ID),ev);
          }
        },100);

        self.resetMainTopic().then(done);
      });
    };


    // tab got selected - this also happens on page init
    self.selectEditClass = function(it, ev){
      if(self.waitForClassPageInit) return; // wait for init
      if(self.editingClass && self.editingClass.ID == it.ID) return; // already open
      self.editClass(it,ev);
    };

    self.archiveClass = function(it, ev){
      self.confirm($filter('trans')('ARCHIVECLASSASK',it.Name),$filter('trans')('ARCHIVE'),ev).then(function(){
        self.apiPost("ajax",{"action":"archiveClass", "ID":it.ID}).then(function(data){
          for(var i=0; i < self.classList.length; i++)
            if(self.classList[i].ID == it.ID) {
              self.classList[i].Archived = 1;
            }
          it.Archived = 1;
          self.editingClass = null;
          for(var i=0; i < self.classList.length; i++)
            if(self.classList[i].Archived == "0") {
              self.editClass(self.classList[i]);
              break;
            }
          self.getClasses();
        });
      });
    };

    self.unarchiveClass = function(it, ev){
      self.apiPost("ajax",{"action":"unarchiveClass", "ID":it.ID}).then(function(data){
        it.Archived = 0;
        self.getClasses().then(function(){
          for(var i=0; i < self.classList.length; i++)
            if(self.classList[i].ID == it.ID) {
              self.editClass(self.classList[i]);
              break;
            }
        });
      });
    };

    self.resetClass = function(ev){
      self.manageClassView = false;
      //self.apiPost("ajax",{"action":"setLastOpenClass","classid":0});
      if(self.currentClass) self.lastClassOnReset = self.currentClass;
      self.currentClass = null;
      self.toolCurrentSelectedStudents = null;
      self.editInsideTopicSwitched = self.currentMainTopic && self.currentTopic;
      self.closeClassFolder();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.resetMainTopicTimer = null;
    self.resetMainTopic = function(ev){
      var deferred = $q.defer();
      
      if(self.resetMainTopicTimer) return;
      
      self.shiftSelectedTasks = []; // clear selection

      self.resetMainTopicTimer = $timeout(function(){
        if(self.currentMainTopic){
          // $('#learningGoalsMainPage').fadeOut("fast");
        }
        self.currentMainTopic = null;
        if(self.currentTopic && self.currentClass){
          var lastOpenTopic = self.userClassViewData[self.currentClass.ID] && self.userClassViewData[self.currentClass.ID]["lastTopic"] ? self.userClassViewData[self.currentClass.ID]["lastTopic"] : 0;
          self.userClassViewData[self.currentClass.ID]["lastTopic"] = 0;
          if(lastOpenTopic != self.userClassViewData[self.currentClass.ID]["lastTopic"])
            self.updateUserClassViewData(self.currentClass.ID); 

          self.track('topicclosed',self.currentTopic);
          if(self.user.Teacher == "0"){
            for(var i=0; i < self.currentTopic.goals.length; i++){
              var taskIDs = [];
              for(var z=0; z < self.currentTopic.goals[i].tasks.length; z++){
                taskIDs.push(self.currentTopic.goals[i].tasks[z].ID);
              }
              if(taskIDs.length > 0)
                self.userViewData["U"+self.user.ID+"_gt_"+self.currentClass.ID+"-"+self.currentTopic.goals[i].ID] = taskIDs.join(",");
            }
          }
          self.setLastOpenTime("topic",self.currentClass.ID+'-'+self.currentTopic.ID);
          self.updateNewTaskBadges(true);
        }
        self.currentTopic = null;
        self.editInsideTopicSwitched = false;
        if(self.setFirstTaskNotification) {
          self.openTeacherTeachIntro();
          self.setFirstTaskNotification = false;
        }
        deferred.resolve();
        self.resetMainTopicTimer = null;
        if(self.previousFocusMainTopic){
          $timeout(function(){
            self.previousFocusMainTopic.focus();
            self.previousFocusMainTopic = null;
          },100);
        }      
      },100);

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getMainTopicClosed = function(it){
      var p = self.userViewData["mtc_"+it.ID];
      if(p !== null)it.Closed = p == 1 ? 1 : 0;
      return it.Closed == 1;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateMainTopicClosed = function(it,c,closed){
      if(closed == 1)
        self.userViewData["mtc_"+it.ID] = 1; else
        delete self.userViewData["mtc_"+it.ID];
      it.Closed = closed;
      self.updateUserViewData();
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Class "Aktuelles" (Current Info)
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getClassCurrentInfoBlockID = function(){
      return "ci_" + (new Date().getTime()) + "_" + Math.floor(Math.random() * 1000000);
    };

    self.parseClassDescriptionJSON = function(description){
      if(!description || description == "") return {};
      try{
        var js = JSON.parse(description);
        if(!js || typeof js != "object" || angular.isArray(js)) return {};
        return js;
      }catch(e){
        return {};
      }
    };

    self.normalizeClassCurrentInfoBlocks = function(info){
      if(!info || !angular.isArray(info.blocks)) return [];
      return info.blocks.slice(0);
    };

    self.normalizeClassCurrentInfo = function(info){
      info = (info && typeof info == "object" && !angular.isArray(info)) ? info : {};
      return {
        blocks:self.normalizeClassCurrentInfoBlocks(info),
        updatedAt:info.updatedAt ? info.updatedAt : 0
      };
    };

    self.getClassCurrentInfoCache = function(c,create){
      if(!c || !c.ID) return null;
      if(!self.classContent) self.classContent = {};
      if(!self.classContent[c.ID]){
        if(!create) return null;
        self.classContent[c.ID] = {};
      }
      var cache = self.classContent[c.ID];
      if(!cache.currentInfo && create){
        cache.currentInfo = self.normalizeClassCurrentInfo({});
        cache.currentInfoDescriptionRaw = "";
        cache.currentInfoSaveVersion = 0;
      }
      return cache;
    };

    self.syncClassCurrentInfoTaskIDsInPlace = function(target, source){
      if(!angular.isArray(target)) return;
      source = angular.isArray(source) ? source : [];
      target.splice(0,target.length);
      for(var i=0; i < source.length; i++) target.push(source[i]);
    };

    self.syncClassCurrentInfoBlocksInPlace = function(target, source){
      if(!angular.isArray(target)) return;
      if(!angular.isArray(source)) source = [];

      var mapped = {};
      for(var i=0; i < target.length; i++){
        if(target[i] && target[i].ID){
          mapped[target[i].ID] = target[i];
        }
      }

      var next = [];
      for(var z=0; z < source.length; z++){
        var s = source[z];
        if(!s || !s.ID) continue;
        var t = s && s.ID ? mapped[s.ID] : null;
        if(!t){
          t = {
            ID:s.ID,
            Type:s.Type,
            HiddenForStudents:s.HiddenForStudents,
            Title:s.Title,
            Text:s.Text,
            Tasks:angular.isArray(s.Tasks) ? s.Tasks.slice(0) : []
          };
        }else{
          t.ID = s.ID;
          t.Type = s.Type;
          t.HiddenForStudents = s.HiddenForStudents;
          t.Title = s.Title;
          if(t.Type == "tasks"){
            if(!angular.isArray(t.Tasks)) t.Tasks = [];
            self.syncClassCurrentInfoTaskIDsInPlace(t.Tasks,s.Tasks);
            t.Text = "";
          }else{
            t.Text = s.Text ? s.Text : "";
            if(!angular.isArray(t.Tasks)) t.Tasks = [];
            self.syncClassCurrentInfoTaskIDsInPlace(t.Tasks,[]);
          }
        }
        next.push(t);
      }

      target.splice(0,target.length);
      for(var x=0; x < next.length; x++) target.push(next[x]);
    };

    self.syncClassCurrentInfoInPlace = function(targetInfo, sourceInfo){
      if(!targetInfo || !sourceInfo) return;
      if(!angular.isArray(targetInfo.blocks)) targetInfo.blocks = [];
      self.syncClassCurrentInfoBlocksInPlace(targetInfo.blocks,sourceInfo.blocks);
      targetInfo.updatedAt = sourceInfo.updatedAt ? sourceInfo.updatedAt : 0;
    };

    self.classCurrentInfoTextShadows = {};

    self.getClassCurrentInfoTextShadowKey = function(c, block){
      if(!c || !block || !block.ID) return "";
      return c.ID + "_" + block.ID;
    };

    self.ensureClassCurrentInfoTextShadow = function(c, block){
      if(!c || !block || block.Type != "text") return null;
      var key = self.getClassCurrentInfoTextShadowKey(c,block);
      if(!key) return null;
      var currentText = typeof block.Text == "string" ? block.Text : "";
      if(!self.classCurrentInfoTextShadows[key]){
        self.classCurrentInfoTextShadows[key] = {
          value: currentText,
          dirty: false
        };
      }
      return self.classCurrentInfoTextShadows[key];
    };

    self.onClassCurrentInfoTextChanged = function(c, block){
      var shadow = self.ensureClassCurrentInfoTextShadow(c,block);
      if(!shadow) return;
      shadow.value = typeof block.Text == "string" ? block.Text : "";
      shadow.dirty = true;
    };

    self.applyClassCurrentInfoTextShadows = function(c, info){
      if(!c || !info || !angular.isArray(info.blocks)) return;
      for(var i=0; i < info.blocks.length; i++){
        var block = info.blocks[i];
        if(!block || block.Type != "text") continue;
        var shadow = self.ensureClassCurrentInfoTextShadow(c,block);
        if(!shadow) continue;
        if(shadow.dirty){
          block.Text = shadow.value;
        }else{
          shadow.value = typeof block.Text == "string" ? block.Text : "";
        }
      }
    };

    self.commitClassCurrentInfoTextShadows = function(c, info){
      if(!c || !info || !angular.isArray(info.blocks)) return;
      for(var i=0; i < info.blocks.length; i++){
        var block = info.blocks[i];
        if(!block || block.Type != "text") continue;
        var shadow = self.ensureClassCurrentInfoTextShadow(c,block);
        if(!shadow) continue;
        shadow.value = typeof block.Text == "string" ? block.Text : "";
        shadow.dirty = false;
      }
    };

    self.clearClassCurrentInfoTextShadow = function(c, blockID){
      if(!c || !blockID) return;
      var key = c.ID + "_" + blockID;
      if(self.classCurrentInfoTextShadows[key]){
        delete self.classCurrentInfoTextShadows[key];
      }
    };

    self.getClassCurrentInfo = function(c){
      if(!c) return {blocks:[], updatedAt:0};
      var cache = self.getClassCurrentInfoCache(c,true);
      return cache.currentInfo;
    };

    self.removeClassCurrentInfoUnlinkedTasks = function(c,saveIfChanged){
      if(!c || !c.ID) return 0;
      var info = self.getClassCurrentInfo(c);
      if(!info || !angular.isArray(info.blocks)) return 0;
      var removed = 0;
      var hasChanges = false;

      for(var i=0; i < info.blocks.length; i++){
        var b = info.blocks[i];
        if(!b || b.Type != "tasks" || !angular.isArray(b.Tasks)) continue;

        var nextTasks = [];
        var blockChanged = false;
        for(var z=0; z < b.Tasks.length; z++){
          var taskID = b.Tasks[z];
          if(c.taskMapped && c.taskMapped[taskID]){
            nextTasks.push(taskID);
          }else{
            removed++;
            blockChanged = true;
          }
        }

        if(blockChanged){
          hasChanges = true;
          b.Tasks.splice(0,b.Tasks.length);
          for(var x=0; x < nextTasks.length; x++) b.Tasks.push(nextTasks[x]);
        }
      }

      if(hasChanges && saveIfChanged && self.canEditClassCurrentInfo(c)){
        self.saveClassCurrentInfo(c);
      }
      return removed;
    };

    self.canEditClassCurrentInfo = function(c){
      return !!(c && self.hasClassChangePermission(c));
    };

    self.getClassCurrentInfoBlockDisplayTitle = function(block){
      if(!block) return "";
      if(block.Title && block.Title.trim() != "") return block.Title;
      return block.Type == "tasks" ? "Aufgabenblock" : "Textblock";
    };

    self.classCurrentInfoTitleEdit = {classID:null, blockID:null, draft:""};

    self.isEditingClassCurrentInfoBlockTitle = function(c, block){
      if(!c || !block || !self.classCurrentInfoTitleEdit) return false;
      return self.classCurrentInfoTitleEdit.classID == c.ID &&
             self.classCurrentInfoTitleEdit.blockID == block.ID;
    };

    self.startEditClassCurrentInfoBlockTitle = function(c, block, ev){
      if(!c || !block || !self.hasClassChangePermission(c)) return;
      if(ev){
        ev.preventDefault();
        ev.stopPropagation();
      }
      self.classCurrentInfoTitleEdit = {
        classID:c.ID,
        blockID:block.ID,
        draft:block.Title ? block.Title : ""
      };
      $timeout(function(){
        $('.editClassCurrentInfoBlockTitle').focus();
      },100);
    };

    self.finishEditClassCurrentInfoBlockTitle = function(c, block, save){
      if(!c || !block || !self.isEditingClassCurrentInfoBlockTitle(c,block)) return;
      var draft = self.classCurrentInfoTitleEdit.draft;
      var nextTitle = draft === null || draft === undefined ? "" : (""+draft).trim();
      self.classCurrentInfoTitleEdit = {classID:null, blockID:null, draft:""};
      if(!save) return;
      var currentTitle = block.Title ? block.Title : "";
      if(currentTitle != nextTitle){
        block.Title = nextTitle;
        self.saveClassCurrentInfo(c);
      }
    };

    self.handleClassCurrentInfoBlockTitleKeydown = function(c, block, ev){
      if(!ev) return;
      if(ev.keyCode == 13){
        ev.preventDefault();
        self.finishEditClassCurrentInfoBlockTitle(c,block,true);
        return;
      }
      if(ev.keyCode == 27){
        ev.preventDefault();
        self.finishEditClassCurrentInfoBlockTitle(c,block,false);
      }
    };

    self.isClassCurrentInfoBlockHiddenForStudents = function(block){
      return block && (block.HiddenForStudents == "1" || block.HiddenForStudents == 1);
    };

    self.classCurrentInfoTextBlockHasText = function(block){
      if(!block || block.Type != "text") return false;
      return block.Text && !self.isEmptyHTMLText(block.Text);
    };

    self.canShowClassCurrentInfoTask = function(c, taskRef, user){
      if(!taskRef || !taskRef.task) return false;
      var checkUser = user ? user : self.user;
      if(checkUser && checkUser.Teacher == "1") return true;
      return self.isUserTaskVisibleDeep(taskRef.mainTopic,taskRef.topic,taskRef.task,checkUser);
    };

    self.classCurrentInfoVisibleTaskIDsForBlock = function(c, block, user){
      var out = [];
      if(!block || block.Type != "tasks" || !angular.isArray(block.Tasks)) return out;
      for(var i=0; i < block.Tasks.length; i++){
        var ref = self.getTaskByID(block.Tasks[i],c) || self.getTaskByID(block.Tasks[i]);
        if(!self.canShowClassCurrentInfoTask(c,ref,user)) continue;
        out.push(block.Tasks[i]);
      }
      return out;
    };

    self.canShowClassCurrentInfoBlock = function(c, block, user){
      if(!block) return false;
      var checkUser = user ? user : self.user;
      if(checkUser && checkUser.Teacher == "1") return true;
      if(self.isClassCurrentInfoBlockHiddenForStudents(block)) return false;
      if(block.Type == "text") return self.classCurrentInfoTextBlockHasText(block);
      if(block.Type == "tasks") return self.classCurrentInfoVisibleTaskIDsForBlock(c,block,user).length > 0;
      return false;
    };

    self.classCurrentInfoHasContentForUser = function(c, user){
      var blocks = self.getClassCurrentInfo(c).blocks;
      for(var i=0; i < blocks.length; i++){
        if(self.canShowClassCurrentInfoBlock(c,blocks[i],user)) return true;
      }
      return false;
    };

    self.isClassCurrentInfoPlaceholder = function(c){
      if(!c || !self.user || self.user.Teacher != "1") return false;
      var hasStudentVisibleContent = false;
      if(c.students && c.students.length > 0){
        for(var i=0; i < c.students.length; i++){
          if(self.classCurrentInfoHasContentForUser(c,c.students[i])){
            hasStudentVisibleContent = true;
            break;
          }
        }
      }else{
        hasStudentVisibleContent = self.classCurrentInfoHasContentForUser(c,{ID:self.user.ID,Teacher:"0"});
      }
      return !hasStudentVisibleContent;
    };

    self.showClassCurrentInfo = function(c){
      if(!c) return false;
      self.getClassCurrentInfo(c);
      if(self.user && self.user.Teacher == "1") return true;
      return self.classCurrentInfoHasContentForUser(c,self.user);
    };

    self.getClassCurrentInfoClosedAt = function(c){
      if(!c || !self.userClassViewData || !self.userClassViewData[c.ID]) return 0;
      var t = parseInt(self.userClassViewData[c.ID].currentInfoClosedAt,10);
      if(isNaN(t) || t < 0) return 0;
      return t;
    };

    self.isClassCurrentInfoClosed = function(c){
      if(!c) return false;
      var closedAt = self.getClassCurrentInfoClosedAt(c);
      var currentInfoInitialized = false;
      if(self.userClassViewData && self.userClassViewData[c.ID]){
        currentInfoInitialized = (self.userClassViewData[c.ID].currentInfoInitialized == 1 ||
                                  self.userClassViewData[c.ID].currentInfoInitialized == "1");
      }
      if(self.user && self.user.Teacher == "1" && !closedAt){
        // Teacher default for new classes: start collapsed until explicitly opened.
        // Once initialized and opened manually, keep it open until closed again.
        return !currentInfoInitialized;
      }
      if(!closedAt) return false;
      var updatedAt = self.getClassCurrentInfo(c).updatedAt;
      if(updatedAt > closedAt) return false; // reopen when teacher changed it
      return true;
    };

    self.setClassCurrentInfoClosed = function(c, closed){
      if(!c) return;
      if(!self.userClassViewData) self.userClassViewData = [];
      if(!self.userClassViewData[c.ID]) self.userClassViewData[c.ID] = {};
      self.userClassViewData[c.ID].currentInfoInitialized = 1;
      if(closed){
        self.userClassViewData[c.ID].currentInfoClosedAt = new Date().getTime();
      }else{
        delete self.userClassViewData[c.ID].currentInfoClosedAt;
      }
      self.updateUserClassViewData(c.ID);

      if(!closed && self.user && self.user.Teacher == "1" && self.hasClassChangePermission(c)){
        if(!self.userViewData["IntroCurrentInfo"]){
          self.userViewData["IntroCurrentInfo"] = 1;
          self.updateUserViewData();
          self.openTeacherCurrentInfoIntro();
        }
      }
    };

    self.createClassCurrentInfoBlocksSortOptions = function(){
      return {
      longTouch:true,
      accept: function(sourceItemHandleScope, destSortableScope){
        if(!self.canEditClassCurrentInfo(self.currentClass)) return false;
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        return isInSameList;
      },
      orderChanged: function(event){
        if(self.canEditClassCurrentInfo(self.currentClass)){
          self.saveClassCurrentInfo(self.currentClass);
        }
        return true;
      },
      containment:'body',
      clone:false
      };
    };

    self.createClassCurrentInfoTasksSortOptions = function(){
      var saveAfterDnD = function(){
        if(!self.canEditClassCurrentInfo(self.currentClass)) return;
        // Let sortable finish model mutations first (source + destination lists).
        $timeout(function(){
          self.saveClassCurrentInfo(self.currentClass);
        },0,false);
      };
      return {
      longTouch:true,
      accept: function(sourceItemHandleScope, destSortableScope){
        if(!self.canEditClassCurrentInfo(self.currentClass)) return false;
        return true; // allow moving tasks between different task blocks
      },
      orderChanged: function(event){
        saveAfterDnD();
        return true;
      },
      itemMoved: function(event){
        saveAfterDnD();
        return true;
      },
      dragEnd: function(event){
        saveAfterDnD();
      },
      containment:'body',
      clone:false
      };
    };
    self.classCurrentInfoBlocksSortOptions = self.createClassCurrentInfoBlocksSortOptions();
    self.classCurrentInfoTasksSortOptions = self.createClassCurrentInfoTasksSortOptions();

    self.prepareClassCurrentInfoForSave = function(info){
      var deferred = $q.defer();
      var nextInfo = angular.copy(info ? info : {blocks:[],updatedAt:0});
      if(!angular.isArray(nextInfo.blocks)) nextInfo.blocks = [];
      var i = 0;

      var run = function(){
        if(i >= nextInfo.blocks.length){
          deferred.resolve(nextInfo);
          return;
        }
        var b = nextInfo.blocks[i];
        if(b.Type == "text"){
          b.Text = self.trimHTML(b.Text ? b.Text : "");
          if(self.isEmptyHTMLText(b.Text)){
            b.Text = "";
            i++;
            run();
            return;
          }
          self.replaceBase64Images(b.Text).then(function(desc){
            b.Text = self.trimHTML(desc ? desc : "");
            if(self.isEmptyHTMLText(b.Text)) b.Text = "";
            i++;
            run();
          });
          return;
        }
        if(!angular.isArray(b.Tasks)) b.Tasks = [];
        i++;
        run();
      };
      run();
      return deferred.promise;
    };

    self.saveClassCurrentInfo = function(c){
      if(!self.canEditClassCurrentInfo(c)) return;
      var cache = self.getClassCurrentInfoCache(c,true);
      if(!cache.currentInfoSaveVersion) cache.currentInfoSaveVersion = 0;
      cache.currentInfoSaveVersion++;
      var saveVersion = cache.currentInfoSaveVersion;
      var info = self.getClassCurrentInfo(c);

      self.prepareClassCurrentInfoForSave(info).then(function(nextInfo){
        if(cache.currentInfoSaveVersion != saveVersion) return;

        var baseDescription = typeof cache.currentInfoDescriptionRaw == "string"
          ? cache.currentInfoDescriptionRaw
          : (c.Description ? c.Description : "");
        var liveClass = self.findClassByID(c.ID);
        if((!baseDescription || baseDescription == "") && liveClass && typeof liveClass.Description == "string"){
          baseDescription = liveClass.Description;
        }
        var descJSON = self.parseClassDescriptionJSON(baseDescription);
        var prevInfo = descJSON.currentInfo ? descJSON.currentInfo : {blocks:[],updatedAt:0};
        if(!angular.isArray(prevInfo.blocks)) prevInfo.blocks = [];

        var changed = (angular.toJson(nextInfo.blocks) != angular.toJson(prevInfo.blocks));
        if(changed){
          nextInfo.updatedAt = new Date().getTime();
        }else{
          nextInfo.updatedAt = prevInfo.updatedAt;
        }

        descJSON.currentInfo = nextInfo;
        var newDescription = angular.toJson(descJSON);
        if(newDescription == baseDescription){
          self.syncClassCurrentInfoInPlace(cache.currentInfo,nextInfo);
          cache.currentInfoDescriptionRaw = newDescription;
          self.commitClassCurrentInfoTextShadows(c,cache.currentInfo);
          if(liveClass && liveClass.ID == c.ID){
            var liveCache = self.getClassCurrentInfoCache(liveClass,true);
            self.syncClassCurrentInfoInPlace(liveCache.currentInfo,nextInfo);
            liveCache.currentInfoDescriptionRaw = newDescription;
          }
          return;
        }

        self.syncClassCurrentInfoInPlace(cache.currentInfo,nextInfo);
        cache.currentInfoDescriptionRaw = newDescription;
        c.Description = newDescription;
        self.commitClassCurrentInfoTextShadows(c,cache.currentInfo);
        if(liveClass && liveClass.ID == c.ID){
          liveClass.Description = newDescription;
          var liveCache = self.getClassCurrentInfoCache(liveClass,true);
          self.syncClassCurrentInfoInPlace(liveCache.currentInfo,nextInfo);
          liveCache.currentInfoDescriptionRaw = newDescription;
        }
        if(self.currentClass && self.currentClass.ID == c.ID){
          self.currentClass.Description = newDescription;
          var currentCache = self.getClassCurrentInfoCache(self.currentClass,true);
          self.syncClassCurrentInfoInPlace(currentCache.currentInfo,nextInfo);
          currentCache.currentInfoDescriptionRaw = newDescription;
        }
        if(self.editingClass && self.editingClass.ID == c.ID){
          self.editingClass.Description = newDescription;
        }

        self.apiPost("ajax",{"action":"updateClass",
                             "Description":newDescription,
                             "Settings":c.Settings,
                             "ID":c.ID,
                             "Name":c.Name,
                             "AllowUserTasks":c.AllowUserTasks,
                             "noindicator":"1"}).then(function(){
          self.keepAliveCallback();                    
        });
      });
    };

    self.createClassCurrentInfoBlock = function(type, data){
      var t = type == "tasks" ? "tasks" : "text";
      var seed = data ? data : {};
      if(t == "tasks"){
        return {
          ID:self.getClassCurrentInfoBlockID(),
          Type:"tasks",
          Tasks:angular.isArray(seed.Tasks) ? seed.Tasks.slice(0) : [],
          HiddenForStudents: seed.HiddenForStudents ? seed.HiddenForStudents : "0",
          Title: typeof seed.Title == "string" ? seed.Title : "",
          Text:""
        };
      }
      return {
        ID:self.getClassCurrentInfoBlockID(),
        Type:"text",
        Text:typeof seed.Text == "string" ? seed.Text : "",
        Tasks:[],
        HiddenForStudents: seed.HiddenForStudents ? seed.HiddenForStudents : "0",
        Title: typeof seed.Title == "string" ? seed.Title : ""
      };
    };

    self.addClassCurrentInfoBlock = function(c, type){
      if(!self.canEditClassCurrentInfo(c)) return;
      var info = self.getClassCurrentInfo(c);
      var block = self.createClassCurrentInfoBlock(type);
      if(type == "tasks") block.Title = $filter('trans')('TASKS');
      if(type == "text") block.Title = $filter('trans')('HINT');
      info.blocks.push(block);
      self.saveClassCurrentInfo(c);
    };

    self.duplicateClassCurrentInfoBlock = function(c, block){
      if(!self.canEditClassCurrentInfo(c) || !block) return;
      var info = self.getClassCurrentInfo(c);
      var p = info.blocks.indexOf(block);
      if(p == -1) return;
      var copy = self.createClassCurrentInfoBlock(block.Type, angular.copy(block));
      info.blocks.splice(p + 1,0,copy);
      self.saveClassCurrentInfo(c);
    };

    self.removeClassCurrentInfoBlock = function(c, block){
      if(!self.canEditClassCurrentInfo(c) || !block) return;
      var info = self.getClassCurrentInfo(c);
      var p = info.blocks.indexOf(block);
      if(p == -1) return;
      self.clearClassCurrentInfoTextShadow(c,block.ID);
      info.blocks.splice(p,1);
      self.saveClassCurrentInfo(c);
    };

    self.toggleClassCurrentInfoBlockHidden = function(c, block){
      if(!self.canEditClassCurrentInfo(c) || !block) return;
      block.HiddenForStudents = self.isClassCurrentInfoBlockHiddenForStudents(block) ? "0" : "1";
      self.saveClassCurrentInfo(c);
    };

    self.findClassCurrentInfoBlockByID = function(c, blockID){
      if(!c || !blockID) return null;
      var blocks = self.getClassCurrentInfo(c).blocks;
      for(var i=0; i < blocks.length; i++){
        if(blocks[i].ID == blockID) return blocks[i];
      }
      return null;
    };

    self.pickClassCurrentInfoBlockTasks = function(c,block){
      if(!self.canEditClassCurrentInfo(c) || !block || block.Type != "tasks") return;
      var hasOwnMaterials = !!(self.userContent && self.userContent.mainTopics && self.userContent.mainTopics.length > 0);
      var hasClassContent = !!(c && self.classContent && self.classContent[c.ID] && self.classContent[c.ID].mainTopics && self.classContent[c.ID].mainTopics.length > 0);
      if(self.user.Teacher == 1 && !hasOwnMaterials && !hasClassContent){
        self.alert($filter('trans')('CREATEMATERIALSFIRSTHINT'));
        return;
      }
      var initialTasks = angular.isArray(block.Tasks) ? angular.copy(block.Tasks) : [];
      var initialTasksJSON = angular.toJson(initialTasks);
      self.pickTasks(angular.copy(initialTasks), c.ID, null, function(selected){
        var liveBlock = self.findClassCurrentInfoBlockByID(c,block.ID);
        if(!liveBlock) return;
        selected = angular.isArray(selected) ? selected : [];
        if(!angular.isArray(liveBlock.Tasks)) liveBlock.Tasks = [];

        // Keep existing order, append only newly selected tasks at the end.
        var selectedMap = {};
        for(var i=0; i < selected.length; i++){
          selectedMap[selected[i]] = true;
        }
        var merged = [];
        var mergedMap = {};

        for(var z=0; z < liveBlock.Tasks.length; z++){
          var existingID = liveBlock.Tasks[z];
          if(!selectedMap[existingID]) continue; // removed in picker
          if(mergedMap[existingID]) continue;
          merged.push(existingID);
          mergedMap[existingID] = true;
        }
        for(var x=0; x < selected.length; x++){
          var selectedID = selected[x];
          if(mergedMap[selectedID]) continue;
          merged.push(selectedID); // new tasks appended at the end
          mergedMap[selectedID] = true;
        }

        if(angular.toJson(merged) == angular.toJson(liveBlock.Tasks) &&
           angular.toJson(selected) == initialTasksJSON) return;

        liveBlock.Tasks = merged;
        self.saveClassCurrentInfo(c);
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateMainTopicsClosed = function(c,closed){
      var content = c ? self.classContent[c.ID] : self.userContent;
      for(var z=0; z < content.mainTopics.length; z++){
        var it = content.mainTopics[z];
        if(closed == 1)
          self.userViewData["mtc_"+it.ID] = 1; else
          delete self.userViewData["mtc_"+it.ID];
        it.Closed = closed;
      }
      self.updateUserViewData();      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.allMainTopicsClosed = function(c){
      var content = c ? self.classContent[c.ID] : self.userContent;
      for(var z=0; z < content.mainTopics.length; z++){
        if(!content.mainTopics[z].Closed) return false;
      }
      return true;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getLearningGoalClosed = function(it){
      var p = self.userViewData["gc_"+it.ID];
      if(p !== null)it.Closed = p == 1 ? 1 : 0;
      return it.Closed == 1;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateLearningGoalClosed = function(it,closed){
      if(closed == 1)
        self.userViewData["gc_"+it.ID] = 1; else
        delete self.userViewData["gc_"+it.ID];
      it.Closed = closed;
      self.updateUserViewData();
    };
