    self.showQRCodeClassList = function(it,ev){
      self.showDialog({
        templateUrl: "classqrcodelist.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.theClass = it;

          $scope.askRefreshCode = function(s,ev){
            self.confirm($filter('trans')('RESETACCOUNTPASSWORD',s.Name,s.Name),$filter('trans')('RESET'),ev).then(function(){
              self.apiPost("ajax",{"action":"resetStudentPassword","student":s.ID}).then(function(data) {
                s.Salt = data.student.Salt;
                s.InitPassword = data.student.InitPassword;
                self.getClasses();
              });
            });
          };
          $scope.askNewEmail = function(s,ev){
            var email = s.Email.replace('@learningview.org','');
            self.prompt($filter('trans')('SETNEWLOGINNAMEDESC'),$filter('trans')('SAVE'),$filter('trans')('SETNEWLOGINNAME'),email,ev).then(function(email){
              if(email == "") return;
              var email = email.replace('@learningview.org','');
              self.apiPost("ajax",{"action":"setStudentEmail", "student":s.ID,
                                   "classid":it.ID, "email":email})
               .then(function(data) {
                  s.Email = data.student.Email;
                  self.getClasses();
                },function(data){
                  if(data.error == "EMAILREQUIRED"){
                  }
                  if(data.error == "INVALIDEMAIL"){
                    self.alert($filter('trans')('INVALIDEMAIL'));
                  }
                  if(data.error == "ALREADYUSEDEMAIL"){
                    if(email.indexOf("@") > 0){
                      self.alert($filter('trans')('EMAILALREADYUSED'));
                    }else{
                      self.alert($filter('trans')('LOGINALREADYUSED'));
                    }
                  }
                });
            });
          };

          $scope.downloadPDFStudent = function(s){
            var doc = new jsPDF();
            var pageHeight = doc.internal.pageSize.height;

            var x = 20;
            var y = 20;
            // $filter('trans')('CLASS')+": "+

            doc.setFont(jsPDF.version != "1.5.3" ? 'Arial' : "helvetica","bold");
            doc.setFontSize(12);
            doc.text(x, y, it.Name); // can be long
            doc.setFont(jsPDF.version != "1.5.3" ? 'Arial' : "helvetica","normal");
            y = y + 10;

            doc.setFontSize(10);
            doc.text(x, y, $filter('trans')('LOGINCARDSTEP1') );
            y += 6;
            doc.text(x, y, $filter('trans')('LOGINCARDSTEP2') );
            y += 6;
            doc.text(x, y, $filter('trans')('LOGINCARDSTEP3') );
