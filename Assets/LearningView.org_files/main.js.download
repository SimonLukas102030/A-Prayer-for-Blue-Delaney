    self.showTaskMedia = function(type,it, ev, allowDownload){
      var filename = '';
      if(it && it.URL) {
        var parts = it.URL.split("/");
        var last = parts[parts.length-1];
        parts = last.split("?");
        filename = parts[0];
      }

      var deferred = $q.defer();
      var template = "";
      if(type == "text")  template = "showTaskMediaText.html";
      if(type == "image") {
        template = "showTaskMediaImage.html";
      }
      if(type == "audio") {
        template = "showTaskMediaAudio.html";
      }
      if(type == "video") {
        template = "showTaskMediaVideo.html";
      }
      if(type == "file") {
        deferred.resolve();
        return deferred;
      }

      allowDownload = allowDownload || self.user.Teacher == 1;

      self.showDialog({
        state:template == "showTaskMediaAudio.html" || template == "showTaskMediaVideo.html" ? "one" :"multi",
        templateUrl: template,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          self.track('closePopupView',null);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.speed = 1;
          $scope.speedLabel = "×1.0";
          $scope.setSpeed = function(v){
            if(v > 0){
              if($scope.speed == 0.5){
                $scope.speed = 0.75;
                $scope.speedLabel = "×0.8";
              }else
              if($scope.speed == 0.75){
                $scope.speed = 1;
                $scope.speedLabel = "×1.0";
              }else
              if($scope.speed == 1){
                $scope.speed = 1.1;
                $scope.speedLabel = "×1.2";
              }else
              if($scope.speed == 1.1){
                $scope.speed = 1.25;
                $scope.speedLabel = "×1.5";
              }else
              if($scope.speed == 1.25){
                $scope.speed = 1.5;
                $scope.speedLabel = "×2.0";
              }else
              if($scope.speed == 1.5){
                $scope.speed = 1.75;
                $scope.speedLabel = "×2.5";
              }
            }else{
              if($scope.speed == 0.75){
                $scope.speed = 0.5;
                $scope.speedLabel = "×0.5";
              }else
              if($scope.speed == 1){
                $scope.speed = 0.75;
                $scope.speedLabel = "×0.8";
              }else
              if($scope.speed == 1.1){
                $scope.speed = 1;
                $scope.speedLabel = "×1.0";
              }else
              if($scope.speed == 1.25){
                $scope.speed = 1.1;
                $scope.speedLabel = "×1.2";
              }else
              if($scope.speed == 1.5){
                $scope.speed = 1.25;
                $scope.speedLabel = "×1.5";
              }else
              if($scope.speed == 1.75){
                $scope.speed = 1.5;
                $scope.speedLabel = "×2.0";
              }
            }
          };
          $scope.allowDownload = allowDownload ? allowDownload : false;
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve();
          };
        }
      });
      return deferred;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.downloadFile = function(url, filename, nosizecheck, mimeType, doPrint) {
      if(url.indexOf("data:") !== 0)
        url = url + (url.indexOf("?") > 0 ? "&_download=1" : "?_download=1");
      if(typeof cordova != "undefined"){
        if(url.indexOf("data:") === 0){
          // convert base64 to raw binary data held in a string
          var byteString = atob(url.split(',')[1]);
          var mimeString = url.split(',')[0].split(':')[1].split(';')[0];
          var ab = new ArrayBuffer(byteString.length);
          var ia = new Uint8Array(ab);
          for (var i = 0; i < byteString.length; i++) {
              ia[i] = byteString.charCodeAt(i);
          }
          var blob = new Blob([ab], {type: mimeString});
          self.downloadAndOpenFile(filename,blob,mimeString);
        }else{
          if(!filename || filename == ""){
            filename = url.split('#')[0].split('?')[0].split('/').pop();
          }
          var parts = filename.split(".");
          var ext = filename.split(".").pop();
          var mimeString = fileMimeTypes[ext] ? fileMimeTypes[ext] : (mimeType ? mimeType : null);
          var openInBrowser = function(){
            self.tryCloseLastWindow();
            window.lastOpenWindow = window.open(url,self.getNewWindowName(),"location=yes,enableViewportScale=yes,hidden=no");            
          };

          if(cordova.plugins && cordova.plugins.fileOpener2 && mimeString){
            try{
              // fetch file size and if < 100MB open it right away 
              var xhr = new XMLHttpRequest();
              xhr.open('HEAD', url, true);
              xhr.onload = function() {
                if (xhr.status >= 200 && xhr.status < 300) {
                  // Get the 'Content-Length' header, which gives the file size in bytes
                  var fileSize = xhr.getResponseHeader('Content-Length');

                  if (nosizecheck || (fileSize && parseInt(fileSize, 10) < 100 * 1024 * 1024)) {
                    var xhr2 = new XMLHttpRequest();
                    xhr2.open("GET", url);
                    xhr2.responseType = "blob";
                    xhr2.onerror = openInBrowser;
                    xhr2.onload = function() {
                      if (xhr.status === 200) {
                        self.downloadAndOpenFile(filename,xhr2.response,mimeString,doPrint);
                      }
                    };
                    xhr2.send();
                  } else {
                    openInBrowser();
                  }
                } else {
                  openInBrowser();
                }
              };
              // Handle errors
              xhr.onerror = openInBrowser;
              // Send the request
              xhr.send();
            }catch(e){
              openInBrowser();
            }      
          }else{
            openInBrowser();   
          }
        }
      }else{
        var e;
        if(window.electron){
          var e = document.createElement("a");
          e.href = url;
          e.download = (filename ? filename : '');
          e.click();
          e.remove();
        }else{
          var e = document.createElement("a");
          e.href = url;
          e.download = (filename ? filename : '');
          e.click();
          e.remove();
        }
      }
      self.track('downloadFile',{url:url, filename:filename});
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.showTaskResultMedia = function(type, status, gallery, student, noedit, ev){
      var deferred = $q.defer();
      if(ev) ev.stopPropagation();
      var keyboardEvent = null;

      var filename = "";
      if(status.Answer) {
        var parts = status.Answer.split("/");
        var last = parts[parts.length-1];
        parts = last.split("?");
        filename = parts[0];
      }

      var template = "";
      var allowDownload = status.Answer && status.Answer != "";

      if(type == "text")       template = "showUserTaskResultText.html";
      if(type == "textnotes")  template = "showUserTaskResultText.html";
      if(type == "image")      template = "showUserTaskResultAnnotation.html"
      if(type == "drawing")    template = "showUserTaskResultAnnotation.html";
      if(type == "annotation") template = "showUserTaskResultAnnotation.html";
      if(type == "audio")      template = "showUserTaskResultAudio.html";
      if(type == "video")      template = "showUserTaskResultVideo.html";
      if(type == "videonotes") template = "showUserTaskResultNotes.html";
      if(type == "audionotes") template = "showUserTaskResultNotes.html";
      
      if(type == "file")  {
        allowDownload = true;
        if(status.Answer && status.Answer != "" && status.Answer.indexOf("http") === 0){
          var url = status.Answer;

          if(url.toLowerCase().match(/\.png$/) || url.toLowerCase().match(/\.jpg$/)|| url.toLowerCase().match(/\.jpeg$/)|| url.toLowerCase().match(/\.gif$/)){
            type = "image";
            template = "showUserTaskResultAnnotation.html";
          }else
          if(url.toLowerCase().match(/\.m4a$/)){
            type = "audio";
            template = "showUserTaskResultAudio.html";
          }else
          if(url.toLowerCase().match(/\.mp4$/)){
            type = "video";
            template = "showUserTaskResultVideo.html";
          }else
          if(url.indexOf("https://learningview.org/") != -1 && 
            (url.toLowerCase().match(/\.zip/) || 
             url.toLowerCase().match(/\.pdf/) || 
             url.toLowerCase().match(/\.docx/) || 
             url.toLowerCase().match(/\.pptx/) || 
             url.toLowerCase().match(/\.xlsx/))){
            // open pdf view with feedback panel
            type = "file";
            template = "showUserTaskResultFile.html";            
          }else{
            self.openWeblink({DataJSON:{URL:url}},ev,'auto',student,gallery);
            return;
          }
        }else{
          return; // no file
        }
      }
      if(type == "link")  {
        if(status.Answer && status.Answer != "" && status.Answer.indexOf("http") === 0){
          var url = status.Answer;
          if(url.toLowerCase().match(/\.png$/) || url.toLowerCase().match(/\.jpg$/)|| url.toLowerCase().match(/\.jpeg$/)|| url.toLowerCase().match(/\.gif$/)){
            type = "image";
            template = "showUserTaskResultAnnotation.html";
          }else
          if(url.toLowerCase().match(/\.m4a$/)){
            type = "audio";
            template = "showUserTaskResultAudio.html";
          }else
          if(url.toLowerCase().match(/\.mp4$/)){
            type = "video";
            template = "showUserTaskResultVideo.html";
          }else
          if(url.indexOf("https://learningview.org/") != -1 && 
            (url.toLowerCase().match(/\.pdf/) || 
             url.toLowerCase().match(/\.docx/) || 
             url.toLowerCase().match(/\.pptx/) || 
             url.toLowerCase().match(/\.xlsx/))){
            // open pdf view with feedback panel
            type = "file";
            template = "showUserTaskResultFile.html";
          }else{
            // show dialog with the link to copy or open
            template = "showUserTaskResultLinks.html";
            
            //self.openWeblink({DataJSON:{URL:url}},ev,'auto',student,gallery);
            //return;
          }
        }else{
          self.alert($filter('trans')('NOHANDINYET'));
          return; // no weblink
        }
      }

      var postMessage = null;
      var classCollaborationWatch = null;
      var textedit = null;

      self.showDialog({
          state:"one",
          targetEvent: ev ? ev : null,
          templateUrl: template,
          clickOutsideToClose: type != "annotation" && type != "image" && type != "drawing",
          escapeToClose: type != "annotation" && type != "image" && type != "drawing",
          skipHide:true, // keep other dialog open
          onRemoving: function (event, removePromise) {
            if(postMessage)
              window.removeEventListener("message",postMessage);
            postMessage = null;
          },
          controller: function ($scope, $mdDialog) {
            $scope.smallScreen = self.isSmallScreen;
            $scope.self = self;
            $scope.type = type;
            $scope.it = status;
            $scope.t = null;
            if($scope.it.Task){
              // for task description in left side panel
              $scope.t = $scope.it.Task;
              $scope.taskDescriptionWidth = self.getTaskDescriptionWidth($scope.t,'(max-width: 900px)');
            }
            $scope.student = student;
            if(status && status.ColleaguesIDs && status.ColleaguesIDs != ''){
              $scope.students = status.ColleaguesIDs.split(",").map(Number);
            }else{
              if($scope.t){
                var partners = self.getUserTaskStatusColleagues($scope.t,$scope.student);
                if(partners) $scope.students = partners.split(",").map(Number);
              }
            }
            $scope.sendingStatus = null;
            $scope.allowDownload = allowDownload;
            $scope.canEdit = self.user.Teacher == 1 && self.hasClassReviewPermission(self.currentClass);
            if($scope.student == null ||
              ($scope.student && $scope.student.ID == self.user.ID) || 
              ($scope.students && $scope.students.indexOf(self.user.ID) != -1)) {
              $scope.canEdit = true;
            }
            if(noedit) $scope.canEdit = false;


            if(type == "annotation" || type == "image" || type == "drawing"){
              self.addAnnotationRecorderScope($scope);
            }
            if(type == "text" || type == "textnotes"){
              self.addTextRecorderScope($scope);
              $scope.textedit.onClose = function(){
                if($scope.it.Task && !self.isSameContentHTML($scope.textedit.current.Text,$scope.textedit.current.Old)){
                  // called when the text was changed and the editor gets closed
                  // save also for Colleagues if there are some
                  var action = {"action":"saveTeacherTaskStatus",
                                "ID":$scope.it.Task.ID,
                                "status":$scope.it.Status,
                                "answer":'<doc id="'+$scope.textedit.docID+'"></doc>'+$scope.textedit.current.Text,
                                "partners":($scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != '' ? $scope.it.ColleaguesIDs : ""),
                                "user": $scope.student.ID,
                                "classid":self.currentClass.ID};
                  self.apiPost("ajax",action).then(function(){
                    $scope.it.Answer = '<doc id="'+$scope.textedit.docID+'"></doc>'+$scope.textedit.current.Text;
                    self.keepAliveCallback();
                  });                                  
                }
              };
            }

            postMessage = $scope.postMessage;

            $scope.gallery = [];

            $scope.setText = function(text){
              window.removeEventListener("message",postMessage);
              window.addEventListener("message",postMessage);
              var canEdit = (self.user.Teacher == "1" && self.hasClassReviewPermission(self.currentClass)) || !$scope.student;

              if(self.user.Teacher == "0" && $scope.student && $scope.student.ID != self.user.ID)
                canEdit = false;

              var title = "Dokument";

              $scope.textedit.editable = canEdit;
              if($scope.it.task) {
                title = task.Name;
                $scope.textedit.task = $scope.it.task;
              }

              if(!text) text = "";
              var editable = true;
              var docID = "doc-"+($scope.student ? $scope.student.ID : self.user.ID) + "-"+($scope.textedit.task ? $scope.textedit.task.ID : 0)+'-'+new Date().getTime();
              // <doc id=""></doc> 
              if(text && text != ""){
                var regex = /<doc id="([^"]+)"><\/doc>/;
                var found = text.match(regex);
                if(found && found.length == 2){
                  docID = found[1];
                  text = text.replace(regex,""); // remove it          
                }
              }
              var username = self.user.Name + " "+self.user.Surname;
              if(self.user.Teacher == 1)
                username = (self.user.Name.length > 0 ?  self.user.Name[0]+'. ' : '') + self.user.Surname;

              $scope.textedit.docID = docID;
              $scope.textedit.current.Text = text;
              $scope.textedit.current.Old = text;
              $scope.textedit.title = title + ($scope.student && $scope.student.ID != self.user.ID ? ' - '+username:"");

              self.currentTaskPartners = ($scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != '' ? $scope.it.ColleaguesIDs : "");
              if(self.currentTaskPartners == "" && $scope.t)
                 self.currentTaskPartners = self.getUserTaskStatusColleagues($scope.t,$scope.student ? $scope.student.ID : self.user.ID);
              $scope.refreshTextEditorUrl();
            };

            $scope.rotateImageRefresh = 0;
            $scope.lastURL = "";

            $scope.setImage = function(url,forcerefresh){
              if(forcerefresh) {
                $scope.lastURL = null;
                $scope.rotateImageRefresh++;
              }
              $scope.imageURL = url && url != "" ? url+"?r="+Math.random() : "";
              $scope.imageURLOrg = url && url != "" ? url : "";

              $scope.annotationURL = url && url != "" ? url : "";
              if($scope.annotationURL != ""){
                if($scope.lastURL != url) $scope.isReady = false;
                $scope.lastURL = url;
                $scope.myAnnotationData = null;
                $scope.myLastAnnotationData = null;
                $scope.feedbackData = null;

                $scope.annotationHistory = [];
                var image = new Image();
                image.crossOrigin = "Anonymous";
                image.onload = function(){
                  $scope.imgWidth = image.width;
                  $scope.imgHeight = image.height;
                };
                image.src = $scope.imageURL;

                self.getImageAnnotationHistoryData($scope.student ? $scope.student : self.user,$scope.annotationURL,($scope.it && $scope.it.TaskID ? $scope.it.TaskID:0)).then(function(r){
                  if(r && r.length > 1){
                    $scope.annotationHistory = r;
                  }
                });
                $scope.loadAnnotationData();
                window.removeEventListener("message",postMessage);
                window.addEventListener("message",postMessage);
                var canEdit = (self.user.Teacher == "1" && self.hasClassReviewPermission(self.currentClass)) || !$scope.student;
                if(self.user.Teacher == "0" && $scope.student && $scope.student.ID != self.user.ID)
                  canEdit = false;
                $scope.canEdit = canEdit;
                $scope.annotationImageEditorURL = ("https://learningview.org/imageeditor/?noedit="+(canEdit ? 0 : 1)+"&waitfordata=1&rotatebuttons="+(type == "annotation" || type == "drawing" ? "0":"1")+"&imagebutton=1&printbutton=1&audiobutton=1&weblinkbutton=1&image="+encodeURIComponent($scope.annotationURL)+(forcerefresh ? '&r='+$scope.rotateImageRefresh:''));
              }
            };

            $scope.updateNotes = function(answer){
              $scope.bindWavesurfer = true; 
              $scope.bindVideplayer = true;
              $scope.URL = $scope.t.ResultType == "audionotes" ? $scope.t.DataJSON.audio : $scope.t.DataJSON.video;
              $scope.notes = answer && answer != '' ? JSON.parse(answer) : [];
              for(var i = 0; i < $scope.notes.length; i++){
                // remove position marker
                if(!$scope.notes[i].id) {
                  $scope.notes.splice(i,1);
                  i--;
                }
              }
              
              if($scope.t.ResultType == 'audionotes' && $scope.t.DataJSON.audioNotes){
                for(var i = 0; i < $scope.t.DataJSON.audioNotes.length; i++){
                  var n = JSON.parse(angular.toJson($scope.t.DataJSON.audioNotes[i]));
                  n.predefined = true;
                  var maxID = 0;
                  var washere = false;
                  for(var i=0; i < $scope.notes.length; i++){
                    if(typeof $scope.notes[i].id == "undefined") continue;
                    if($scope.notes[i].from == n.id) washere = true;                    
                    maxID = Math.max($scope.notes[i].id,maxID);
                  }
                  n.id = maxID+1;
                  if(!washere)
                    $scope.notes.push(n);
                }
              }
              if($scope.t.ResultType == 'videonotes' && $scope.t.DataJSON.videoNotes){
                for(var i = 0; i < $scope.t.DataJSON.videoNotes.length; i++){
                  var n = JSON.parse(angular.toJson($scope.t.DataJSON.videoNotes[i]));
                  n.predefined = true;
                  var maxID = 0;
                  var washere = false;
                  for(var i=0; i < $scope.notes.length; i++){
                    if(typeof $scope.notes[i].id == "undefined") continue;
                    if($scope.notes[i].from == n.id) washere = true;
                    maxID = Math.max($scope.notes[i].id,maxID);
                  }
                  n.id = maxID+1;
                  if(!washere)
                    $scope.notes.push(n);
                }
              }
              // sort now
              $scope.notes.sort(function(a,b){
                return a.t < b.t ? -1 : (a.t > b.t ? 1 : (a.ID < b.ID ? -1 : 1));
              })

              $scope.seekNote = function(n,noplay){
                // seek to n.time
                if($scope.t.ResultType == "audionotes"){
                  $scope.wavesurfer.seekTo(n.t,noplay);
                }
                if($scope.t.ResultType == "videonotes"){
                  $scope.videoplayer.seekTo(n.t,noplay);
                }
              };

            };

            $scope.updateFileURL = function(url){
              $scope.url = null;
              $scope.noPreview = false;
              var parts = url.split("/");
              parts = parts[parts.length-1].split("?");
              parts = parts[0].split(".");
              $scope.fileType = parts[parts.length-1].toLowerCase();

              if($scope.fileType == "zip"){
                $scope.url = "https://learningview.org/api/openZIP.php?file="+encodeURIComponent(url);
                if(!postMessage){
                  postMessage = function(event){
                    // from zip folder
                    if(event.data && event.data.indexOf && event.data.indexOf("DOWNLOADFILE|") === 0){
                      var data = event.data.substring(("DOWNLOADFILE|").length);
                      // '/api/openZIP.php?file=&f=kitten-4794761_1280.webp'
                      var parts = data.split("=");
                      var file = parts[parts.length-1];
                      var parts = file.split("/");
                      self.downloadFile(data,parts[parts.length-1]);
                      return;
                    }
                    if(event.data && event.data.indexOf && event.data.indexOf("OPENLINK|") === 0){
                      var data = event.data.substring(("OPENLINK|").length);
                      // open with student data here
                      self.openWeblink({DataJSON:{URL:data}},null,'auto',$scope.student ? $scope.student : self.user);
                      return;
                    }
                    if(event.data && event.data.indexOf && event.data.indexOf("OPENHTML|") === 0){
                      var data = event.data.substring(("OPENHTML|").length);
                      self.openHTMLViewFromURL(data);
                      return;
                    }
                  };
                  window.addEventListener("message",postMessage);
                }
              }else
              if($scope.fileType == "pdf"){
                $scope.url = "https://learningview.org/pdfviewer/web/viewer.html?file="+encodeURIComponent(url);
              }else{
                // convert first
                if($scope.fileType == "docx" || $scope.fileType == "pptx" || $scope.fileType == "xlsx"){
                  var pdfURL = "https://learningview.org/api/ajax.php?action=toPDF&url=" + encodeURIComponent(url);
                  $.getJSON(pdfURL+"&generate=1",function(data){
                    if(data && !data.error){
                      $timeout(function(){
                        $scope.url = "https://learningview.org/pdfviewer/web/viewer.html?file="+encodeURIComponent(pdfURL);
                      },0);
                    }
                  });
                }else{
                  $scope.url = url;
                  $scope.noPreview = true;
                }
              }
            };

            if(type == "annotation" || type == "image" || 
               type == "drawing") $scope.setImage(status.Answer);
            if(type == "text" || type == "textnotes") $scope.setText(status.Answer);
            if(type == "file") $scope.updateFileURL(status.Answer);
            if(type == "link") $scope.webLink = status.Answer;
            if(type == "videonotes") $scope.updateNotes(status.Answer);
            if(type == "audionotes") $scope.updateNotes(status.Answer);

            if(gallery)
            for(var i=0; i < gallery.length; i++)
              if(gallery[i].status && gallery[i].student && gallery[i].status.Answer && gallery[i].status.Answer != "") $scope.gallery.push(gallery[i]);


            var p = -1;
            if($scope.gallery)
            for(var i=0; i < $scope.gallery.length; i++){
              if($scope.gallery[i].student.ID == $scope.it.UserID) p = i;
            }
            var tt = self.getTaskByID($scope.it.TaskID);
            $scope.it.Task = tt ? tt.task : null;
            $scope.showLast = $scope.gallery && p > 0;
            $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;

            $scope.goLast = function(){
              if(self.currentTaskFeedbackDialog){
                self.closeDialog(self.currentTaskFeedbackDialog);
                self.currentTaskFeedbackDialog = null;
              }

              if(type == "text" || type == "textnotes" || type == "annotation" || type == "image" || type == "drawing") {
                $scope.requestClose(function(){
                  $scope.goLastNow();
                });
              }else{
                $scope.goLastNow();
              }
            };

            $scope.goLastNow = function(){
              $scope.sendingStatus = null;
              if(!$scope.gallery) return;
              //var canEdit = self.user.Teacher == "1" || !$scope.student;
              //if(self.user.Teacher == "0" && $scope.student && $scope.student.ID != self.user.ID)
              //    canEdit = false;
              //if(canEdit && $scope.updateAnnotationData) $scope.updateAnnotationData();

              var p = -1;
              for(var i=0; i < $scope.gallery.length; i++){
                if($scope.gallery[i].student.ID == $scope.it.UserID) p = i;
              }
              if(p > 0) {
                $scope.it = $scope.gallery[p-1].status;
                $scope.student = $scope.gallery[p-1].student;
                if($scope.it && $scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != ''){
                  $scope.students = $scope.it.ColleaguesIDs.split(",").map(Number);                  
                }

                var tt = self.getTaskByID($scope.it.TaskID);
                $scope.it.Task = tt ? tt.task : null;
                if(type == "text" || type == "textnotes") $scope.setText($scope.it.Answer);
                if(type == "annotation" || type == "image" || type == "drawing") $scope.setImage($scope.it.Answer);
                if(type == "file") $scope.updateFileURL($scope.it.Answer);
                if(type == "link") $scope.webLink = status.Answer;
                if(type == "videonotes") $scope.updateNotes($scope.it.Answer);
                if(type == "audionotes") $scope.updateNotes($scope.it.Answer);
                p--;
              }
              $scope.showLast = $scope.gallery && p > 0;
              $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;
            };

            $scope.goNext = function(){
              if(self.currentTaskFeedbackDialog){
                self.closeDialog(self.currentTaskFeedbackDialog);
                self.currentTaskFeedbackDialog = null;
              }

              if(type == "text" || type == "textnotes" || type == "annotation" || type == "image" || type == "drawing") {
                $scope.requestClose(function(){
                  $scope.goNextNow();
                });
              }else{
                $scope.goNextNow();
              }
            };

            $scope.goNextNow = function(){
              $scope.sendingStatus = null;
              if(!$scope.gallery) return;
              //var canEdit = self.user.Teacher == "1" || !$scope.student;
              //if(self.user.Teacher == "0" && $scope.student && $scope.student.ID != self.user.ID)
              //    canEdit = false;
              //if(canEdit && $scope.updateAnnotationData) $scope.updateAnnotationData();

              var p = -1;
              for(var i=0; i < $scope.gallery.length; i++){
                if($scope.gallery[i].student.ID == $scope.it.UserID) p = i;
              }
              if(p >= 0 && p < $scope.gallery.length-1) {
                $scope.it = $scope.gallery[p+1].status;
                $scope.student = $scope.gallery[p+1].student;
                if($scope.it && $scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != ''){
                  $scope.students = $scope.it.ColleaguesIDs.split(",").map(Number);
                }

                var tt = self.getTaskByID($scope.it.TaskID);
                $scope.it.Task = tt ? tt.task : null;
                if(type == "text" || type == "textnotes") $scope.setText($scope.it.Answer);
                if(type == "annotation" || type == "image" || type == "drawing") $scope.setImage($scope.it.Answer);
                if(type == "file") $scope.updateFileURL($scope.it.Answer);
                if(type == "link") $scope.webLink = status.Answer;
                if(type == "videonotes") $scope.updateNotes($scope.it.Answer);
                if(type == "audionotes") $scope.updateNotes($scope.it.Answer);
                p++;
              }
              $scope.showLast = $scope.gallery && p > 0;
              $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;
            };

            $scope.cancel = function() {
              var r = null;
              if(type == "text" || type == "textnotes"){
                $scope.requestClose(function(){
                  self.closeDialog($scope.dialogElement);
                  deferred.resolve();
                });
              }else
              if(type == "annotation" || type == "image" || type == "drawing"){
                $scope.requestClose(function(){
                  //var canEdit = self.user.Teacher == "1" || !$scope.student;
                  //if(self.user.Teacher == "0" && $scope.student && $scope.student.ID != self.user.ID)
                  //    canEdit = false;
                  //if(canEdit && $scope.updateAnnotationData) r = $scope.updateAnnotationData();
                  r = $scope.annotationDataChangedAndSaved;                  
                  self.closeDialog($scope.dialogElement);
                  deferred.resolve(r);
                });
              }else{
                self.closeDialog($scope.dialogElement);
                deferred.resolve(r);
              }
            };
          }
        });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countLearningGoalJournalItems = function(goal,student,filterOnlyUserContent){
      var n = 0;
      if(!goal) return 0;
      if(student) {
        if(!self.users[student.ID] || !self.users[student.ID].journalLearningGoalMapped[goal.ID]) return 0;
        if(filterOnlyUserContent){
          // filter items
          for(var k in self.users[student.ID].journalLearningGoalMapped[goal.ID]){
            var m = self.users[student.ID].journalLearningGoalMapped[goal.ID][k];
            if(m.Type == 'goalteacherdone' || m.Type == 'goaldone') continue;
            n++;
          }
          return n;
        }

        return Object.keys(self.users[student.ID].journalLearningGoalMapped[goal.ID]).length;
      }else{
        if(!self.users[self.user.ID] || !self.users[self.user.ID].journalLearningGoalMapped[goal.ID]) return 0;
        return Object.keys(self.users[self.user.ID].journalLearningGoalMapped[goal.ID]).length;
      }
      return n;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.countTaskJournalItems = function(task,student){
      var n = 0;
      if(!task) return 0;
      if(student) {
        if(!self.users[student.ID] || !self.users[student.ID].journalTaskMapped[task.ID]) return 0;
        if(self.currentClass){
          for(i in self.users[student.ID].journalTaskMapped[task.ID]){
            if(self.users[student.ID].journalTaskMapped[task.ID][i].Class == self.currentClass.ID) n++;
          }
          return n;
        }
        return Object.keys(self.users[student.ID].journalTaskMapped[task.ID]).length;
      }else{
        if(!self.users[self.user.ID] || !self.users[self.user.ID].journalTaskMapped[task.ID]) return 0;
        if(self.currentClass){
          for(i in self.users[self.user.ID].journalTaskMapped[task.ID]){
            if(self.users[self.user.ID].journalTaskMapped[task.ID][i].Class == self.currentClass.ID) n++;
          }
          return n;
        }
        return Object.keys(self.users[self.user.ID].journalTaskMapped[task.ID]).length;
      }
      return n;
    };


    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getTaskPeerFeedbacks = function($scope,task,student){
      $scope.feedbacks = [];
      $scope.feedbackAverage = 0;
      if(!task) return;

      if(!student) student = self.user;

      var totalStars = 0;
      var usedStudents = [];
      for(var i=0; i < self.users[student.ID].journal.length; i++){
        if(self.users[student.ID].journal[i].Type == "taskpeerfeedbackget")
          if(self.users[student.ID].journal[i].DataJSON && self.users[student.ID].journal[i].DataJSON.taskid == task.ID){
            if(usedStudents.indexOf(self.users[student.ID].journal[i].DataJSON.Peer) != -1){
              continue; // already have one feedback from this student, only show newest
            }
            if(self.users[student.ID].journal[i].DataJSON.Peer && !self.users[student.ID].journal[i].DataJSON.PeerStudent){
              var s = self.users[self.users[student.ID].journal[i].DataJSON.Peer];
              if(s) {
                self.users[student.ID].journal[i].DataJSON.PeerStudent = s;
              }else{
                // Student is no longer there
                self.users[student.ID].journal[i].DataJSON.PeerStudent = {Name:$filter('trans')('UNKNOWNUSERNAME'),Surname:""};
              }
            }
            usedStudents.push(self.users[student.ID].journal[i].DataJSON.Peer);
            $scope.feedbacks.push(self.users[student.ID].journal[i]);
            totalStars += parseInt(self.users[student.ID].journal[i].DataJSON.Stars);
          }
      }
      if($scope.feedbacks.length > 0) $scope.feedbackAverage = Math.round(totalStars / $scope.feedbacks.length);

      return true;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.showTaskPeerFeedbacks = function (task,student,ev){
      self.showDialog({
        templateUrl: "taskPeerFeedbacks.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
         controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = task;
          $scope.student = student;
          $scope.feedbacks = [];

          self.getTaskPeerFeedbacks($scope,task,student);
          $scope.deletePeerFeedback = function(it,ev){
            self.deleteJournalItem(it,student,ev).then(function(){
              self.getTaskPeerFeedbacks($scope,task,student);
            });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showOpenTasksList = function(student,tasklist,ev){
      self.showLoadingIndicator(ev,function(done){
        if(self.user.Teacher == 0) self.updateStudentClassesStatus();
        if(self.user.Teacher == 1) self.updateClassesStatus();
        self.track('opentasklistopened',null);
        self.showDialog({
          templateUrl: "openTasksList.html",
          targetEvent: ev,
          clickOutsideToClose: true,
          state:"one",
          skipHide:true, // keep other dialog open
          onRemoving: function (event, removePromise) {
            self.track('opentasklistclosed',null);
          },
          controller: function ($scope, $mdDialog) {
             $scope.self = self;
             self.currentTaskStudent = student;
             $scope.student = student;
             $scope.studentTasks = tasklist;

             $scope.exportOpenTaskList = function(format,ev){
              $scope.waitForDownload = true;

              var url = "https://learningview.org/api/exportTaskList.php?format="+format+"&user="+student.ID+"&code="+student.Salt+(self.filterCurrentClassOnly ? "&classid="+self.currentClass.ID : '')+(student.ID == self.user.ID ? '&own=1':'');
              var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
              function checkDownload(){
                if(document.cookie.indexOf("fileDownload=true") > -1) {
                  var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                  document.cookie = cookieData;
                  setTimeout(function(){ frame.remove();},1000);
                  $scope.waitForDownload = false;
                }else
                  $timeout(checkDownload,100);
              }
              var filename = window.cleanFilename("LearningViewExport_"+(self.filterCurrentClassOnly ? self.currentClass.Name+"_" : "")+"Liste_"+moment().format('YYYY_MM_DD'))+"."+format;
              if(window.electron){
                window.downloadElectronSaveAs(url,filename,function(){
                  $timeout(function(){$scope.waitForDownload = false;},0);
                });
              }else
              if(typeof cordova != "undefined"){
                self.downloadFile(url,filename,true);
                $timeout(function(){$scope.waitForDownload = false;},500);
              }else{
                $('body').append(frame);
                checkDownload();
              }
            };

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

