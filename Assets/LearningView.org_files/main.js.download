    self.classesListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { return true; },
      dragStart : function(obj){

      },
      dragEnd : function(obj){

      },
      orderChanged: function (event) {
        self.updateClassesOrder();
        return true;
      },
      containment: 'body',
      clone:false
    };

    self.tabButtonListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { 
        console.log(destSortableScope.element.get(0).id);
        return destSortableScope.element.get(0).id == "classTabButtons" &&
               sourceItemHandleScope.itemScope.sortableScope.element.get(0).id == "classTabButtons";
      },
      dragStart : function(obj){

      },
      dragEnd : function(obj){

      },
      orderChanged: function (event) {
        if(!self.currentClass) return false;
        var order = [];
        for(var i=0; i < self.tabButtons[self.currentClass.ID].length; i++){
          if(self.tabButtons[self.currentClass.ID][i].classCollaboration){
            order.push(self.tabButtons[self.currentClass.ID][i].classCollaboration.ID);
          }
        }
        if(order.length > 1){
          if(!self.userClassViewData[self.currentClass.ID]) self.userClassViewData[self.currentClass.ID] = {};
          self.userClassViewData[self.currentClass.ID]["classDocumentsOrder"] = order.join(",");
          self.updateUserClassViewData(self.currentClass.ID);
        }

        return true;
      },
      containment: '#classTabButtons',
      clone:false
    };

    self.classFolderItemsSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { 
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        return false;
      },
      dragStart : function(obj){
        if(isIOSDevice || isAndroidDevice)
          $(".classFolderItemsWrapper").css({"overflow":"hidden"});
