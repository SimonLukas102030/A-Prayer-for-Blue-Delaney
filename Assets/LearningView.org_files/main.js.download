    self.getClasses = function(update){
      var deferred = $q.defer();
      self.keepAliveCallback(null,true).then(function(){
        deferred.resolve();
      });
      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateStudentClassStatus = function (student,c,bindTo){
      var b = bindTo ? bindTo : c;
      b.feedbacks = []; 
      b.feedbackColors = [];
      b.userTasks = [];
      b.userTaskColors = [];
      b.noteTasks = [];
      b.noteTaskColors = [];
      b.noteTaskNotes = [];
      b.searchingPartners = [];
      b.waitingPeerFeedback = [];
      b.importantTasks = [];


      if(self.users[student.ID].userTasks && self.users[student.ID].userTasks[c.ID])
        for(var ut = 0; ut < self.users[student.ID].userTasks[c.ID].length; ut++){
          var task = self.users[student.ID].userTasks[c.ID][ut];
          if(!task.DataJSON || task.DataJSON.Class != c.ID) continue;

          var ts = self.getUserTaskStatus(task,student);
          if(ts.Status == "OK") continue; // skip done tasks here
          // put this task on the open task list because of various reasons
          if(ts.Important == "-1" || ts.FeedbackStatus == "c") continue; // do not add to the list

          item = {"status":ts,"Type":"usertask","Class":c, "Updated":ts.Updated,
                  "Task":task, "Topic":null, "MainTopic":null};
          b.userTasks.push(item);
          var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
          if(b.userTaskColors.indexOf(itemColor) < 0)
             b.userTaskColors.push(itemColor);
        }

      for(var m = 0; m < self.classContent[c.ID].mainTopics.length; m++){
        if(self.classContent[c.ID].mainTopics[m].topics)
        for(var t = 0; t < self.classContent[c.ID].mainTopics[m].topics.length; t++){
          if(self.classContent[c.ID].mainTopics[m].topics[t].goals)
          for(var g = 0; g < self.classContent[c.ID].mainTopics[m].topics[t].goals.length; g++){
            if(self.classContent[c.ID].mainTopics[m].topics[t].goals[g].tasks)
            for(var x = 0; x < self.classContent[c.ID].mainTopics[m].topics[t].goals[g].tasks.length; x++){
              var ct = self.classContent[c.ID].mainTopics[m].topics[t].goals[g].tasks[x];
              delete ct.isStudentNote;
              delete ct.isStudentTask;

              var ts = self.getUserTaskStatus(ct,student);

              // tasks notes
              if(ts.Note && ts.Note != ""){
                var item = {"status":ts,"Type":"noteTasks", "Class":c, "Updated":ts.Updated,
                            "Task":self.classContent[c.ID].mainTopics[m].topics[t].goals[g].tasks[x],
                            "Topic":self.classContent[c.ID].mainTopics[m].topics[t],
                            "MainTopic":self.classContent[c.ID].mainTopics[m]}
                b.noteTasks.push(item);

                var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
                if(b.noteTaskColors.indexOf(itemColor) < 0)
                   b.noteTaskColors.push(itemColor);

                var nn = ts.Note.replace('¶','');
                if(b.noteTaskNotes.indexOf(nn) < 0)
                   b.noteTaskNotes.push(nn);
              }

              // put this task on the open task list because of various reasons
              if(ts.Important == "-1" || ts.FeedbackStatus == 'c') continue; // do not add to the list

              // open feedback
              if(ts.Status == "x" || ts.Status == "re"){
                var item = {"status":ts,"Type":"feedbacks","Class":c, "Updated":ts.Updated,
                            "Task":self.classContent[c.ID].mainTopics[m].topics[t].goals[g].tasks[x],
                            "Topic":self.classContent[c.ID].mainTopics[m].topics[t],
                            "MainTopic":self.classContent[c.ID].mainTopics[m]}
                b.feedbacks.push(item);
                var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
                if(b.feedbackColors.indexOf(itemColor) < 0)
                   b.feedbackColors.push(itemColor);
              }

              // important tasks
              if((ct.Important == "1" || ts.Important == "1" || ts.Important == "2") && ts.Status != "OK"){
                var item = null;
                for(var xx = 0; xx < b.importantTasks.length; xx++){
                  if(b.importantTasks[xx].Task.ID == ct.ID){
                    item = b.importantTasks[xx];
                    break;
                  }
                }

                if(!item){
                  item = {"status":ts,"Type":"importantTask","Updated":ts.Updated, "Task":ts.Task, "Topic":self.classContent[c.ID].mainTopics[m].topics[t], "MainTopic":self.classContent[c.ID].mainTopics[m], "Class":c};
                  b.importantTasks.push(item);
                }

                var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
                if(b.feedbackColors.indexOf(itemColor) < 0)
                   b.feedbackColors.push(itemColor);
              }

              // peer feedback
              if(ts.Status == "pw" && ts.Task){
                var item = null;
                for(var xx = 0; xx < b.waitingPeerFeedback.length; xx++){
                  if(b.waitingPeerFeedback[xx].Task.ID == ts.TaskID){
                    item = b.waitingPeerFeedback[xx];
                    break;
                  }
                }
                if(!item){
                  item = {"status":ts,"Type":"waitingPeerFeedback","Updated":ts.Updated, "Task":ts.Task, "Topic":self.classContent[c.ID].mainTopics[m].topics[t], "MainTopic":self.classContent[c.ID].mainTopics[m], "Class":c, "students":[]};
                  b.waitingPeerFeedback.push(item);
                }

                var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
                if(b.feedbackColors.indexOf(itemColor) < 0)
                   b.feedbackColors.push(itemColor);
              }

              // searching partner
              if(ts.Status == 's' && ts.Task){
                var item = null;
                for(var xx = 0; xx < b.searchingPartners.length; xx++){
                  if(b.searchingPartners[xx].Task.ID == ts.TaskID){
                    item = b.searchingPartners[xx];
                    break;
                  }
                }
                if(!item){
                  item = {"status":ts,"Type":"searchingPartners", "Updated":ts.Updated, "Task":ts.Task,
                        "Topic":self.classContent[c.ID].mainTopics[m].topics[t], "MainTopic":self.classContent[c.ID].mainTopics[m], "Class":c, "students":[]};
                  b.searchingPartners.push(item);
                }

                // task where this user is searching partners for
                for(var s2 = 0; s2 < c.students.length; s2++){
                  if(c.students[s2].ID == student.ID) continue;
                  if(self.users[c.students[s2].ID] &&
                     self.users[c.students[s2].ID].taskStatusMapped &&
                     self.users[c.students[s2].ID].taskStatusMapped[ts.TaskID] &&
                     self.users[c.students[s2].ID].taskStatusMapped[ts.TaskID].Status == "s")
                     item.students.push(c.students[s2]);
                }

                var itemColor = item.Task.Color && item.Task.Color != '' ? item.Task.Color : '#03a9f4';
                if(b.feedbackColors.indexOf(itemColor) < 0)
                   b.feedbackColors.push(itemColor);
              }


            }
          }
        }
      }

      b.noteTaskNotes.sort();

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(b.userTaskColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);

      b.userTaskColors = sortedColors;

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(b.noteTaskColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);

      b.noteTaskColors = sortedColors;

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(b.feedbackColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);

      b.feedbackColors = sortedColors;

      b.feedbackCounter = 0;

      var totalCounter = {};
      for(var cc = 0; cc < b.userTasks.length; cc++){
        if(!totalCounter[b.userTasks[cc].Task.ID]){
          totalCounter[b.userTasks[cc].Task.ID] = 1;
          b.feedbackCounter++;
        }
      }
      for(var cc = 0; cc < b.feedbacks.length; cc++){
        if(!totalCounter[b.feedbacks[cc].Task.ID]){
          totalCounter[b.feedbacks[cc].Task.ID] = 1;
          b.feedbackCounter++;
        }
      }
      for(var cc = 0; cc < b.importantTasks.length; cc++){
        if(!totalCounter[b.importantTasks[cc].Task.ID]){
          totalCounter[b.importantTasks[cc].Task.ID] = 1;
          b.feedbackCounter++;
        }
      }
      for(var cc = 0; cc < b.searchingPartners.length; cc++){
        if(!totalCounter[b.searchingPartners[cc].Task.ID]){
          totalCounter[b.searchingPartners[cc].Task.ID] = 1;
          b.feedbackCounter++;
        }
      }
      for(var cc = 0; cc < b.waitingPeerFeedback.length; cc++){
        if(!totalCounter[b.waitingPeerFeedback[cc].Task.ID]){
          totalCounter[b.waitingPeerFeedback[cc].Task.ID] = 1;
          b.feedbackCounter++;
        }
      }

      b.noteTasksCounter = b.noteTasks.length;
    };

    self.combineStudentClassesStatus = function (u,classList){
      if(!u.studentNotes) u.studentNotes = [];
      u.studentNotes.splice(0,u.studentNotes.length);
      u.studentNoteCounter = 0;
      if(!u.studentTasks) u.studentTasks = [];
      u.studentTasks.splice(0,u.studentTasks.length);
      u.studentTaskCounter = 0;

      u.studentUserTaskColors = [];
      u.studentFeedbackColors = [];
      u.studentNoteTaskColors = [];
      u.studentNoteTaskNotes  = [];

      for(var run=0; run < 2; run++){
        for(var i=0; i < classList.length; i++){
          // current class on first run
          if(run == 0 && (!self.currentClass || classList[i].ID != self.currentClass.ID)) continue;
          // other classes on second run
          if(run == 1 && self.currentClass && classList[i].ID == self.currentClass.ID) continue;

          if(classList[i].Active == 0) continue; // deleted
          if(classList[i].Archived == "1" && (!self.currentClass || self.currentClass.ID != classList[i].ID)) continue;

          for(var x=0; x < classList[i].userTasks.length; x++){
            var exists = false;
            for(var z=0; z < u.studentTasks.length; z++){
              if(u.studentTasks[z].Task.ID == classList[i].userTasks[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentTasks.push(classList[i].userTasks[x]);          
          }
          for(var x=0; x < classList[i].noteTasks.length; x++){
            var exists = false;
            for(var z=0; z < u.studentNotes.length; z++){
              if(u.studentNotes[z].Task.ID == classList[i].noteTasks[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentNotes.push(classList[i].noteTasks[x]);
          }
          for(var x=0; x < classList[i].feedbacks.length; x++){
            var exists = false;
            for(var z=0; z < u.studentTasks.length; z++){
              if(u.studentTasks[z].Task.ID == classList[i].feedbacks[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentTasks.push(classList[i].feedbacks[x]);
          }
          for(var x=0; x < classList[i].importantTasks.length; x++){
            var exists = false;
            for(var z=0; z < u.studentTasks.length; z++){
              if(u.studentTasks[z].Task.ID == classList[i].importantTasks[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentTasks.push(classList[i].importantTasks[x]);
          }
          for(var x=0; x < classList[i].searchingPartners.length; x++){
            var exists = false;
            for(var z=0; z < u.studentTasks.length; z++){
              if(u.studentTasks[z].Task.ID == classList[i].searchingPartners[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentTasks.push(classList[i].searchingPartners[x]);
          }
          for(var x=0; x < classList[i].waitingPeerFeedback.length; x++){
            var exists = false;
            for(var z=0; z < u.studentTasks.length; z++){
              if(u.studentTasks[z].Task.ID == classList[i].waitingPeerFeedback[x].Task.ID){
                exists = true; break;
              }
            }
            if(!exists) u.studentTasks.push(classList[i].waitingPeerFeedback[x]);
          }

          for(var x=0; x < classList[i].userTaskColors.length; x++){
            if(u.studentUserTaskColors.indexOf(classList[i].userTaskColors[x]) < 0)
               u.studentUserTaskColors.push(classList[i].userTaskColors[x]);
          }
          for(var x=0; x < classList[i].feedbackColors.length; x++){
            if(u.studentFeedbackColors.indexOf(classList[i].feedbackColors[x]) < 0)
               u.studentFeedbackColors.push(classList[i].feedbackColors[x]);
          }
          for(var x=0; x < classList[i].noteTaskColors.length; x++){
            if(u.studentNoteTaskColors.indexOf(classList[i].noteTaskColors[x]) < 0)
               u.studentNoteTaskColors.push(classList[i].noteTaskColors[x]);
          }
          for(var x=0; x < classList[i].noteTaskNotes.length; x++){
            if(u.studentNoteTaskNotes.indexOf(classList[i].noteTaskNotes[x]) < 0)
               u.studentNoteTaskNotes.push(classList[i].noteTaskNotes[x]);
          }
        }
      }

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(u.studentUserTaskColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);
      u.studentUserTaskColors = sortedColors;

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(u.studentFeedbackColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);
      u.studentFeedbackColors = sortedColors;

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(u.studentNoteTaskColors.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);
      u.studentNoteTaskColors = sortedColors;

      u.studentNoteCounter = u.studentNotes.length;
      u.studentTaskCounter = u.studentTasks.length;

      for(var i=0; i < u.studentTasks.length; i++)
        u.studentTasks[i].Task.isStudentTask = true;
      for(var i=0; i < u.studentNotes.length; i++)
        u.studentNotes[i].Task.isStudentNote = true;

      u.studentTasks.sort(function(a,b){
        return a.Updated < b.Updated ? 1 : (a.Updated > b.Updated ? -1 : 0);
      });
      u.studentNotes.sort(function(a,b){
        return a.Updated < b.Updated ? 1 : (a.Updated > b.Updated ? -1 : 0);
      });
    };

    self.updateStudentClassesStatus = function (){
      var c = self.classList;
      for(var i=0; i < c.length; i++){
        if(c[i].Active == 0) continue; // deleted
        if(c[i].Archived == "1" && (!self.currentClass || self.currentClass.ID != c[i].ID)) continue;
        self.updateStudentClassStatus(self.user,c[i],c[i]);
      }
      // for all classes combined - bind arrays to users object
      self.combineStudentClassesStatus(self.users[self.user.ID],c);
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findGoalInClass = function(c,goalID,student){
      // reset classGoalMapped when change to
      // classContent happens
      if(!self.classContent[c.ID].classGoalMapped)
          self.classContent[c.ID].classGoalMapped = {};

      var r = self.classContent[c.ID].classGoalMapped[goalID];
      if(r == -1) return null; // not there, not search again
      if(r){
        if(student){
          if(!self.isUserMainTopicVisible(r.mainTopic,student,c)) return null;
          if(!self.isUserTopicVisible(r.topic,student,c)) return null;
          if(!self.isUserLearningGoalVisible(r.goal,student,c)) return null;
        }
        return r.goal;
      }else{
        // not yet in cache, find it
        self.classContent[c.ID].classGoalMapped[goalID] = -1; // set to -1 we search for

        if(self.classContent[c.ID].mainTopics)
        for(var mt = 0; mt < self.classContent[c.ID].mainTopics.length; mt++){
          if(self.classContent[c.ID].mainTopics[mt].topics)
          for(var to = 0; to < self.classContent[c.ID].mainTopics[mt].topics.length; to++){
            if(self.classContent[c.ID].mainTopics[mt].topics[to].goals)
            for(var g = 0; g < self.classContent[c.ID].mainTopics[mt].topics[to].goals.length; g++){
              if(self.classContent[c.ID].mainTopics[mt].topics[to].goals[g].ID == goalID){
                var r = {};
                r.mainTopic = self.classContent[c.ID].mainTopics[mt];
                r.topic = self.classContent[c.ID].mainTopics[mt].topics[to];
                r.goal = self.classContent[c.ID].mainTopics[mt].topics[to].goals[g];
                self.classContent[c.ID].classGoalMapped[goalID] = r;
                return self.findGoalInClass(c,goalID,student);
              }
            }
          }
        }
      }
      return null;      
    }

    self.findTaskInClass = function(c,taskID,student){
      // reset classTasksMapped when change to
      // classContent happens
      if(!self.classContent[c.ID].classTasksMapped)
          self.classContent[c.ID].classTasksMapped = {};

      var r = self.classContent[c.ID].classTasksMapped[taskID];
      if(r == -1) return null; // not there, not search again
      if(r){
        if(student){
          if(!self.isUserMainTopicVisible(r.mainTopic,student,c)) return null;
          if(!self.isUserTopicVisible(r.topic,student,c)) return null;
          if(!self.isUserLearningGoalVisible(r.goal,student,c)) return null;
          if(!self.isUserTaskVisible(r.task,student,c)) return null;
        }
        return r.task;
      }else{
        // not yet in cache, find it
        self.classContent[c.ID].classTasksMapped[taskID] = -1; // set to -1 we search for

        if(self.classContent[c.ID].mainTopics)
        for(var mt = 0; mt < self.classContent[c.ID].mainTopics.length; mt++){
          if(self.classContent[c.ID].mainTopics[mt].topics)
          for(var to = 0; to < self.classContent[c.ID].mainTopics[mt].topics.length; to++){
            if(self.classContent[c.ID].mainTopics[mt].topics[to].goals)
            for(var g = 0; g < self.classContent[c.ID].mainTopics[mt].topics[to].goals.length; g++){
              if(self.classContent[c.ID].mainTopics[mt].topics[to].goals[g].tasks)
              for(var ts = 0; ts < self.classContent[c.ID].mainTopics[mt].topics[to].goals[g].tasks.length; ts++)
              if(self.classContent[c.ID].mainTopics[mt].topics[to].goals[g].tasks[ts].ID == taskID){
                var r = {};
                r.mainTopic = self.classContent[c.ID].mainTopics[mt];
                r.topic = self.classContent[c.ID].mainTopics[mt].topics[to];
                r.goal = self.classContent[c.ID].mainTopics[mt].topics[to].goals[g];
                r.task = self.classContent[c.ID].mainTopics[mt].topics[to].goals[g].tasks[ts];
                self.classContent[c.ID].classTasksMapped[taskID] = r;
                return self.findTaskInClass(c,taskID,student);
              }
            }
          }
        }
      }
      return null;
    };

    self.getTaskHandoutDateInClass = function(task,c){
      var x = self.findTaskInClass(c,task.ID,null);
      if(x && x.Changed) return $filter('trans')('DISTRIBUTEDON', self.shortDateTime(x.Changed));
      return null;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getImportantTasksInClass = function(c,student){
      var tasks = [];
      if(!self.classContent[c.ID]) return tasks;

      for(var k in self.classContent[c.ID].classTasksMapped){
        if(self.classContent[c.ID].classTasksMapped[k].task && self.classContent[c.ID].classTasksMapped[k].task.Important == "1"){
          if(!student || self.findTaskInClass(c,k,student)){
            var theTask = self.getTaskByID(k);
            if(theTask) tasks.push(theTask);
          }
        }
      }

      return tasks;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    //1007 main topics filtering

    self.updateFilterMainTopicIsOwn = function(){
      self.classContent[self.currentClass.ID].filterMainTopicsIsOwn = self.userClassViewData[self.currentClass.ID].filterMainTopics.length > 0;

      for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++) {
        if(self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(self.classContent[self.currentClass.ID].mainTopics[i].ID) != -1){
          if(self.classContent[self.currentClass.ID].mainTopics[i].Owner != self.user.ID) {
            self.classContent[self.currentClass.ID].filterMainTopicsIsOwn = false;
            return;
          }
        }else{
          if(self.classContent[self.currentClass.ID].mainTopics[i].Owner == self.user.ID) {
            self.classContent[self.currentClass.ID].filterMainTopicsIsOwn = false;
            return;
          }
        }
      }
    };

    self.chooseFilterMainTopicList = function(filter) {
      self.selectedClassActivityPlace = "maintopics";

      if(!filter) filter = { statement : "all" };

      if(!self.userClassViewData) self.userClassViewData = [];
      if(!self.userClassViewData[self.currentClass.ID]) self.userClassViewData[self.currentClass.ID] = {};

      if(!self.userClassViewData[self.currentClass.ID].filterColor) self.userClassViewData[self.currentClass.ID].filterColor = [];
      if(!self.userClassViewData[self.currentClass.ID].filterMainTopics) self.userClassViewData[self.currentClass.ID].filterMainTopics = [];

      if(filter.color &&
        (!self.userClassViewData[self.currentClass.ID].filterColor || self.userClassViewData[self.currentClass.ID].filterColor.length == 0)) {
        self.userClassViewData[self.currentClass.ID].filterMainTopics = [];
      }

      // new color is clicked
      if(filter.color && self.userClassViewData[self.currentClass.ID].filterColor.indexOf(filter.color) == -1) {
        for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++) {
          if(filter.color == self.classContent[self.currentClass.ID].mainTopics[i].Color) {
            if(self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(self.classContent[self.currentClass.ID].mainTopics[i].ID) == -1) {
               self.userClassViewData[self.currentClass.ID].filterMainTopics.push(self.classContent[self.currentClass.ID].mainTopics[i].ID);
            }
          }
        }
      }
      // selected color is clicked again, unselected
      if(filter.color && self.userClassViewData[self.currentClass.ID].filterColor.indexOf(filter.color) != -1) {
        for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++) {
          if(filter.color == self.classContent[self.currentClass.ID].mainTopics[i].Color) {
            var p = self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(self.classContent[self.currentClass.ID].mainTopics[i].ID);
            if(p != -1) {
              self.userClassViewData[self.currentClass.ID].filterMainTopics.splice(p, 1);
            }
          }
        }
      }
      // add color to filterColor list now
      if(filter.color) {
        if(self.userClassViewData[self.currentClass.ID].filterColor.indexOf(filter.color) == -1) {
          self.userClassViewData[self.currentClass.ID].filterColor.push(filter.color);
        }
        else {
          self.userClassViewData[self.currentClass.ID].filterColor.splice(self.userClassViewData[self.currentClass.ID].filterColor.indexOf(filter.color), 1);
        }
      }

      // main topic is clicked
      if(filter.mt) {
        var p = self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(filter.mt.ID);
        if(p != -1) {
          self.userClassViewData[self.currentClass.ID].filterMainTopics.splice(p, 1);
        } else {
          self.userClassViewData[self.currentClass.ID].filterMainTopics.push(filter.mt.ID);
          if(self.userClassViewData[self.currentClass.ID].filterMainTopics.length == self.classContent[self.currentClass.ID].mainTopics.length) {
            self.userClassViewData[self.currentClass.ID].filterMainTopics = [];
            self.selectedClassActivityPlace = "all";
          }
        }
        self.userClassViewData[self.currentClass.ID].filterColor = [];
      }

      if(filter.statement) {
        self.userClassViewData[self.currentClass.ID].filterMainTopics = [];
        self.userClassViewData[self.currentClass.ID].filterColor = [];

        if(filter.statement == "all") {
          self.selectedClassActivityPlace = "all";
        }
        else if(filter.statement == "own") {
          for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++ ) {
            if(self.classContent[self.currentClass.ID].mainTopics[i].Owner == self.user.ID) {
              self.userClassViewData[self.currentClass.ID].filterMainTopics.push(self.classContent[self.currentClass.ID].mainTopics[i].ID);
            }
          }
        }
      }


      if(self.selectedClassActivityPlace != "all") {
        self.currentClassResultMainTopicFilter = self.userClassViewData[self.currentClass.ID].filterMainTopics;
      }
      else {
        self.currentClassResultMainTopicFilter = [];
      }

      self.updateUserClassViewData(self.currentClass.ID);
      self.updateFilterMainTopicIsOwn();
    }

///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getSearchString = function(obj,attributes){
      var s = "";
      if(obj instanceof Array){
        for(var i=0; i < obj.length; i++){
          s += self.getSearchString(obj[i],attributes)+ " ";
        }
      }else{
        for(var k in obj){
          if(attributes.indexOf(k) != -1)
            s += obj[k] + " ";
        }
      }

      return s;
    }
    self.matchSearchTerm = function(searchterm, texts){
      // if element in texts is an array, check all items and use attributes of it
      if(!searchterm || searchterm == "") return false;
      var words = searchterm.toLowerCase().split(/\W+/);
      var partMatch = [];
      for(var i=0; i < words.length; i++){
        partMatch[i] = false;
      }
      for(var z=0; z < texts.length; z++){
        var s = texts[z].toLowerCase();
        var matches = true;
        for(var i=0; i < words.length; i++){
          if(s.indexOf(words[i]) == -1) {
            matches = false;
          }else{
            partMatch[i] = true;
          }
        }
        if(matches) return true;          
      }
      if(partMatch.indexOf(false) == -1) return true;
      return false;
    }

///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateClassesStatus = function (c){
      if(self.user.Teacher == 0) return; // only for teachers, count feedbacks and stuff
      // update with new data from keepalive
      if(!c) c = self.classList; // update with self
      //if(c)

      for(var i=0; i < c.length; i++){
        var currentClass = null;
        for(var fi=0; fi < self.classList.length; fi++){
          if(self.classList[fi].ID == c[i].ID){
            currentClass = self.classList[fi];
          }
        }
        // class not existed yet
        if(!currentClass){
          self.classList.push(c[i]);
          currentClass = c[i];
        }

        if(currentClass.Archived == "1") continue;

        currentClass.hasUserFolders = false;
        currentClass.hasUserGroupFolders = false;

        if(self.classContent[currentClass.ID] && self.classContent[currentClass.ID].folders){
          for(z = 0; z < self.classContent[currentClass.ID].folders.length; z++){
            if(self.classContent[currentClass.ID].folders[z].Share == 3){
              currentClass.hasUserGroupFolders = true;
              break;
            }
          }
        }

        currentClass.feedbacks = [];
        currentClass.hasFilteredCorrections = 0;

        currentClass.questionCounter = 0;
        currentClass.feedbackCounter = 0;

        if(!currentClass.tasksMapped) currentClass.tasksMapped = [];

        // list of important tasks
        var importantTasksInClass = self.getImportantTasksInClass(currentClass);

        // for students inside classe fetch and map status
        for(var z=0; z < c[i].students.length; z++){
          if(self.currentClass && self.currentClass.ID == currentClass.ID &&
             self.currentClassResultStudentFilter &&
             self.currentClassResultStudentFilter.length > 0){
            if(self.currentClassResultStudentFilter.indexOf(c[i].students[z].ID) == -1)
              continue; // skip student
          }

          if(self.users[currentClass.students[z].ID] &&
             self.users[currentClass.students[z].ID].classContent &&
             self.users[currentClass.students[z].ID].classContent[currentClass.ID] &&
             self.users[currentClass.students[z].ID].classContent[currentClass.ID].folders &&
             self.users[currentClass.students[z].ID].classContent[currentClass.ID].folders.length > 0) 
              currentClass.hasUserFolders = true;

          if(!currentClass.students[z].openTasks)
              currentClass.students[z].openTasks = [];

          currentClass.students[z].openTasks.splice(0,
              currentClass.students[z].openTasks.length);

          if(!currentClass.students[z].studentNotes)
              currentClass.students[z].studentNotes = [];

          currentClass.students[z].studentNotes.splice(0,
              currentClass.students[z].studentNotes.length);

          var userTasks = null;
          if(self.users[currentClass.students[z].ID] &&
             self.users[currentClass.students[z].ID].userTasks &&
             self.users[currentClass.students[z].ID].userTasks[currentClass.ID] )
            userTasks = self.users[currentClass.students[z].ID].userTasks[currentClass.ID];

          // add all user tasks to the list
          if(userTasks)
            for(var ut = 0; ut < userTasks.length; ut++){
              var task = userTasks[ut];
              var ts = self.getUserTaskStatus(task,currentClass.students[z]);
              if(ts.Status == "OK") continue;
              if(ts.Important == "-1") continue; // do not add to the list
              if(ts.FeedbackStatus == "c") continue; // do not add to the list

              item = {"status":ts,"Type":"usertask","Class":currentClass,"Updated":ts.Updated,
                      "Task":task, "Topic":null, "MainTopic":null};
              currentClass.students[z].openTasks.push(item);
            }

          // list of important tasks
          var importantTasks = importantTasksInClass.slice(0);

          // build feedbacks from status items
          for(var k in self.users[currentClass.students[z]["ID"]].taskStatusMapped){
            if(!currentClass.tasksMapped[k]){
                currentClass.tasksMapped[k] = self.getTaskByID(k,currentClass);
                if(!currentClass.tasksMapped[k]) currentClass.tasksMapped[k] = -1;
            }
            var task = currentClass.tasksMapped[k];
            if(!task || task == -1) { continue;} // task not found anymore
            var ts = self.users[currentClass.students[z]["ID"]].taskStatusMapped[k];

            // fetch last saved mainTopic filter for this class
            var mainTopicFilter = null;
            if(self.userClassViewData && self.userClassViewData[currentClass.ID] &&
               self.userClassViewData[currentClass.ID].filterMainTopics){
              mainTopicFilter = self.userClassViewData[currentClass.ID].filterMainTopics;
            }

            if(mainTopicFilter && mainTopicFilter.length > 0){
              if(!task.mainTopic || mainTopicFilter.indexOf(task.mainTopic.ID)== -1){
                continue; // skip
              }
            }

            if(ts.Important == "-1" || ts.FeedbackStatus == "c") {
              for(var xx = 0; xx < importantTasks.length; xx++){
                if(importantTasks[xx].task.ID == task.task.ID){
                  importantTasks.splice(xx,1);
                  break;
                }
              }
              continue; // skip this task, it was deleted from list on purpose
            }

            var studentTask = -1;
            var checkStudentTaskExists = function(){
              // is task still visible for this user?
              if(studentTask == -1) {
                 studentTask = self.findTaskInClass(currentClass,k);
                 if(studentTask)
                   studentTask = self.findTaskInClass(currentClass,k,currentClass.students[z]);
              }
            };

            // open feedback
            if(ts.Status == "x" || ts.Status == "re"){
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore

              var item = null;
              for(var xx = 0; xx < currentClass.students[z].openTasks.length; xx++){
                if(currentClass.students[z].openTasks[xx].Task.ID == task.task.ID){
                  item = currentClass.students[z].openTasks[xx];
                  break;
                }
              }

              if(!item){
                item = {"status":ts,"Updated":ts.Updated,"Type":"feedbacks",
                        "Class":currentClass,
                        "Task":task.task,
                        "Topic":task.topic,
                        "MainTopic":task.mainTopic}
                currentClass.students[z].openTasks.push(item);
              }
            }

            // important tasks
            if((task.task.Important == "1" || ts.Important == "1" || ts.Important == "2") && ts.Status != "OK"){
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore

              for(var xx = 0; xx < importantTasks.length; xx++){
                if(importantTasks[xx].task.ID == task.task.ID){
                  importantTasks.splice(xx,1);
                  break;
                }
              }
              var item = null;
              for(var xx = 0; xx < currentClass.students[z].openTasks.length; xx++){
                if(currentClass.students[z].openTasks[xx].Task.ID == task.task.ID){
                  item = currentClass.students[z].openTasks[xx];
                  break;
                }
              }

              if(!item){
                item = {"status":ts,"Type":"importantTask","Updated":ts.Updated, 
                        "Task":task.task, "Topic":task.topic, "MainTopic":task.mainTopic, "Class":currentClass};
                currentClass.students[z].openTasks.push(item);
              }
            }

            // task task note stickers
            if(ts.Note && ts.Note != '') {
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore
              var item = null;
              for(var xx = 0; xx < currentClass.students[z].studentNotes.length; xx++){
                if(currentClass.students[z].studentNotes[xx].Task.ID == task.task.ID){
                  item = currentClass.students[z].studentNotes[xx];
                  break;
                }
              }
              if(!item){
                item = {"status":ts,"Type":"noteTasks", "Updated":ts.Updated,
                        "Task":task.task, "Topic":task.topic, "MainTopic":task.mainTopic, 
                        "Class":currentClass};
                currentClass.students[z].studentNotes.push(item);
              }
            }

            // peer feedback
            if(ts.Status == "pw"){
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore

              var item = null;
              for(var xx = 0; xx < currentClass.students[z].openTasks.length; xx++){
                if(currentClass.students[z].openTasks[xx].Task.ID == task.task.ID){
                  item = currentClass.students[z].openTasks[xx];
                  break;
                }
              }
              if(!item){
                item = {"status":ts,"Type":"waitingPeerFeedback","Updated":ts.Updated, 
                        "Task":task.task, "Topic":task.topic, "MainTopic":task.mainTopic, 
                        "Class":currentClass, "students":[]};
                currentClass.students[z].openTasks.push(item);
              }
            }

            // searching partner
            if(ts.Status == 's'){
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore

              var item = null;
              for(var xx = 0; xx < currentClass.students[z].openTasks.length; xx++){
                if(currentClass.students[z].openTasks[xx].Task.ID == task.task.ID){
                  item = currentClass.students[z].openTasks[xx];
                  break;
                }
              }
              if(!item){
                item = {"status":ts,"Type":"searchingPartners","Updated":ts.Updated, "Task":task.task, 
                        "Topic":task.topic, "MainTopic":task.mainTopic, 
                        "Class":currentClass, "students":[]};
                currentClass.students[z].openTasks.push(item);
              }
            }

            // Feedbacks per class (correction Panel content)

            var hasOpenQuestion = false;
            var hasManualAnswers = false;
            if(ts.Feedback != '' && ts.FeedbackJSON && ts.FeedbackJSON.length > 0){
              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore

              for(var fi=ts.FeedbackJSON.length-1; fi >= 0; fi--){
                if(ts.FeedbackJSON[fi].Deleted == "1" || ts.FeedbackJSON[fi].Class != currentClass.ID) continue;

                // filter student sysMessages as they are no questions
                if(ts.FeedbackJSON[fi].isSys == "1" && ts.FeedbackJSON[fi].User == currentClass.students[z].ID) continue; 

                // last message was from the student
                if(ts.FeedbackJSON[fi].User == currentClass.students[z].ID){
                  hasOpenQuestion = self.lastFeedbackActionFromUser(ts.FeedbackJSON[fi],currentClass.students[z],currentClass);
                  if(hasOpenQuestion) currentClass.questionCounter++;
                  break;
                }else{
                  break;
                }
              }
              if(!hasOpenQuestion)
              for(var fi=ts.FeedbackJSON.length-1; fi >= 0; fi--){
                if(ts.FeedbackJSON[fi].Deleted == "1" || ts.FeedbackJSON[fi].Class != currentClass.ID) continue;
                if(ts.FeedbackJSON[fi].isSys == "1" && 
                   ts.FeedbackJSON[fi].Message.match(/%%ASKACCESS%%/)){
                  var parts = ts.FeedbackJSON[fi].Message.split("|");
                  var accepted = self.getUserTaskHintApproved(parts[2], {ID:parts[1]}, {ID:ts.FeedbackJSON[fi].User});
                  if(accepted == -1 || accepted == -3){
                    hasOpenQuestion = true;
                    currentClass.questionCounter++;
                    break;
                  }
                }
              }

              // will not work for already skipped "closed" tasks
              if(self.selectedClassCorrectionFilter == 'answers'){
                var hasQ = false;
                var hasA = false;
                for(var fi=ts.FeedbackJSON.length-1; fi >= 0; fi--){
                  if(ts.FeedbackJSON[fi].Deleted == "1" || ts.FeedbackJSON[fi].Class != currentClass.ID) continue;
                  if(ts.FeedbackJSON[fi].isSys == "1") continue;
                  if(ts.FeedbackJSON[fi].User == currentClass.students[z].ID){
                    hasQ = true;
                  }else{
                    hasA = true;
                  }
                  if(hasQ && hasA){
                    hasManualAnswers = true;
                    break;
                  }
                }
              }

            }

            var asksFeedback = ts["Status"] == '?' || 
                              (ts["Status"] == 'x' && (ts["FeedbackStatus"] && ts["FeedbackStatus"] != ''));

            var wasAnswered = (self.selectedClassCorrectionFilter == 'answers' && hasManualAnswers);

            if(asksFeedback || hasOpenQuestion || wasAnswered) {

              checkStudentTaskExists();
              if(!studentTask) continue; // task not found anymore
  
              var item = {"status":ts,"Updated":ts.Updated,
                          "TaskID":ts["TaskID"],
                          "student":currentClass.students[z],                          
                          "Task":task.task, "LearningGoal":task.goal,
                          "Topic":task.topic, "MainTopic":task.mainTopic };

              // feedback counter counts all for the badge icon, 
              // counter before filters 
              // issue with ColleaguesIDs counting double
              if (ts.Status == "?"){
                var parts = ts.ColleaguesIDs && ts.ColleaguesIDs != '' ? ts.ColleaguesIDs.split(',').map(Number) : [];
                parts.push(currentClass.students[z].ID);
                parts.sort();
                // only count lowest UserID of group
                if(parts[0] == currentClass.students[z].ID){
                  currentClass.feedbackCounter++; 
                }
              }

              if(self.correctionSearchTerm && self.correctionSearchTerm != ""){
                var match = self.matchSearchTerm(self.correctionSearchTerm,
                  [currentClass.students[z].Name,
                   currentClass.students[z].Surname,
                   ts.Feedback ? ts.Feedback : "",
                   task.task.Name,
                   task.goal.Name,
                   task.topic.Name,
                   task.mainTopic.Name,
                   ]);
                if(!match){
                  currentClass.hasFilteredCorrections++;
                  continue; // skip                    
                }
              }

              if(self.selectedClassCorrectionFilter == 'rejected'){
                if(ts["Status"] != 'x') {
                  currentClass.hasFilteredCorrections++;
                  continue; // skip
                }
              }
              if(self.selectedClassCorrectionFilter == 'corrected'){
                if(ts["FeedbackStatus"] != 'wasx' || ts["Status"] != '?') {
                  currentClass.hasFilteredCorrections++;
                  continue; // skip
                }
              }
              if(self.selectedClassCorrectionFilter == 'questions'){
                if(!hasOpenQuestion) {
                  currentClass.hasFilteredCorrections++;
                  continue; // skip
                }
              }
              if(self.selectedClassCorrectionFilter == 'answers'){
                if(!hasManualAnswers) {
                  currentClass.hasFilteredCorrections++;
                  continue; // skip
                }
              }
              if(self.selectedClassCorrectionFilter == 'new'){
                if(ts.Status != '?' && !hasOpenQuestion){
                  currentClass.hasFilteredCorrections++;
                  continue; // skip
                }
              }
              currentClass.feedbacks.push(item);
            }
          }

          // if unhandeled tasks remain
          for(var xx = 0; xx < importantTasks.length; xx++){
            var ts = self.users[currentClass.students[z]["ID"]].taskStatusMapped[importantTasks[xx].task["ID"]];
            if(ts && ts["Status"] == 'OK') continue;
            // check if task is visible to student
            var studentTask = self.findTaskInClass(currentClass,importantTasks[xx].task["ID"]);
            if (studentTask)
                studentTask = self.findTaskInClass(currentClass,importantTasks[xx].task["ID"],currentClass.students[z]);

            if(!studentTask) continue; // task not found anymore

            item = {"status":ts,"Type":"importantTask","Updated":ts ? ts.Updated : 0, "Task":importantTasks[xx].task, 
                    "Topic":importantTasks[xx].topic, "MainTopic":importantTasks[xx].mainTopic, 
                    "Class":currentClass};
            currentClass.students[z].openTasks.push(item);
          }

          currentClass.students[z].openTasks.sort(function(a,b){
            return a.Updated < b.Updated ? 1 : (a.Updated > b.Updated ? -1 : 0);
          });
          currentClass.students[z].studentNotes.sort(function(a,b){
            return a.Updated < b.Updated ? 1 : (a.Updated > b.Updated ? -1 : 0);
          });

        }

        // group feedbacks by Tasks
        var groups = {};
        var hasFeedback = false;

        for(var z = 0; z < currentClass.feedbacks.length; z++){
          var f = currentClass.feedbacks[z];
          if(!groups[f.TaskID]) {
            groups[f.TaskID] = {"Task":f.Task,"LearningGoal":f.LearningGoal,"Topic":f.Topic,"MainTopic":f.MainTopic, "Feedbacks":[]};
            if(f.Task.DataJSON && f.Task.DataJSON.hints){
              for(var h = 0; h < f.Task.DataJSON.hints.length; h++){
                if(f.Task.DataJSON.hints[h].type == "rubric"){
                  if(!groups[f.TaskID].Rubrics)
                      groups[f.TaskID].Rubrics = [];
                  var exists = false;
                  for(var he = 0; he <  groups[f.TaskID].Rubrics.length; he++){
                    if(groups[f.TaskID].Rubrics[he].rubric == f.Task.DataJSON.hints[h].rubric){
                      exists = true;
                      break;
                    }
                  }
                  if(!exists)
                    groups[f.TaskID].Rubrics.push(f.Task.DataJSON.hints[h]);                    
                }
              }
            }
          }
          if(groups[f.TaskID] && groups[f.TaskID].Feedbacks){
            // keep only one for all item in group for all ColleaguesIDs
            // so we do not get 3 identical items with other Colleagues order 
            var parts = f.status.ColleaguesIDs && f.status.ColleaguesIDs != '' ? f.status.ColleaguesIDs.split(',').map(Number) : [];
            var isThere = false;
            for(var x = 0; x < groups[f.TaskID].Feedbacks.length; x++){
              var parts2 = groups[f.TaskID].Feedbacks[x].status.ColleaguesIDs && groups[f.TaskID].Feedbacks[x].status.ColleaguesIDs != '' ?
                           groups[f.TaskID].Feedbacks[x].status.ColleaguesIDs.split(',').map(Number) : [];
              // check if this is a partner in the other direction too, so we can remove the double entry now        
              if(parts.indexOf(groups[f.TaskID].Feedbacks[x].student.ID) != -1 && 
                 parts2.indexOf(f.student.ID) != -1 ){ 
                isThere = true; 
                break;
              }
            }            
            if(isThere) { 
              // we skip adding feedback
              continue; 
            }

            groups[f.TaskID].Feedbacks.push({"student":f.student,"status":f.status });
            if(!groups[f.TaskID].Updated) groups[f.TaskID].Updated = f.status.Updated;
            if(groups[f.TaskID].Updated < f.status.Updated) groups[f.TaskID].Updated = f.status.Updated;
            hasFeedback = true;

            //if(f.status["Status"] != "x" || self.selectedClassCorrectionFilter == 'rejected' || self.selectedClassCorrectionFilter == 'questions')
          }
        }

        currentClass.feedbacks = hasFeedback ? groups : null;
      }

      // sort feedbacks by student names
      for(var i=0; i < self.classList.length; i++){
        if(self.classList[i].feedbacks)
        for(var k in self.classList[i].feedbacks){
          if(self.classList[i].feedbacks[k].Feedbacks)
            self.classList[i].feedbacks[k].Feedbacks.sort(function(a,b){
              var r = a.student[self.user.ClassNameSorting].localeCompare(b.student[self.user.ClassNameSorting]);
              if(r == 0) {
                var sn = self.user.ClassNameSorting == "Surname" ? "Name" : "Surname";
                r = a.student[sn].localeCompare(b.student[sn]);
                if(r == 0) {
                  r = parseInt(a.student.ID) - parseInt(b.student.ID);
                }
              }
              return r;
            });          
        }
      }

      self.classList.sort(function(a,b){
        if(a.OrderIndex == b.OrderIndex){
          return a.ID > b.ID ? 1 : -1;
        }
        return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
      });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateChatMessages = function(newmessages){
      var now = self.currentChatMessages ? self.currentChatMessages.length : 0;
      for(var i=0; i < newmessages.length; i++){
        var isThere = false;
        if(newmessages[i].Data){
          newmessages[i].DataJSON = JSON.parse(newmessages[i].Data);
        }
        for(var z=0; z < self.currentChatMessages.length; z++){
          if(self.currentChatMessages[z].ID == newmessages[i].ID){
            isThere = true;
            // if message changed, update it
            self.currentChatMessages[z].Changed = newmessages[i].Changed;
            self.currentChatMessages[z].Deleted = newmessages[i].Deleted;
            self.currentChatMessages[z].Message = newmessages[i].Message;
            self.currentChatMessages[z].Data    = newmessages[i].Data;
            if(self.currentChatMessages[z].Data){
              self.currentChatMessages[z].DataJSON = newmessages[i].DataJSON;
            }
            break;
          }
        }
        if(!isThere){
          self.currentChatMessages.push(newmessages[i]);
          if(self.chatRoomRingSound && now > 0 && newmessages[i].User != self.user.ID &&
             (!self.chatRoomRingPlayed || self.chatRoomRingPlayed < new Date().getTime() - 60000)){
            var ringSound = new Audio("https://learningview.org/app/sounds/ring.mp3");
            ringSound.play();
          }
          self.chatRoomRingPlayed = new Date().getTime();
        }
      }
      // sort by ID, so sort by create date
      self.currentChatMessages.sort(function(a,b){
        var oa = parseInt(a.ID);
        var ob = parseInt(b.ID);
        return oa < ob ? -1 : (oa > ob ? 1 : (a.ID < b.ID ? -1 : (a.ID > b.ID ? 1 : 0)));
      });
    };

    self.getClassSettingDefaults = function(){
      return {
        useTaskRatings:false, 
        useChats:true, 
        useAsk:true,
        useFolders:true, 
        useOwnFolders:true, 
        useShareFolders:true, 
        useCalendars:true, 
        useNotes:true,
        useSelfRatings:true,
        useNotelists:false,
        useSRLToolbox:false
      };
    };

    self.isClassSet = function(setting, c){
      var defaults = self.getClassSettingDefaults();
      if(!c) c = self.currentClass;
      if(!c) return defaults[setting];
      if(!c.Settings) return defaults[setting];
      if(!c.SettingsJSON) return defaults[setting];
      if(defaults[setting] == false){
        if(c.SettingsJSON[setting] === true) return true;
        return false;
      }else{
        if(c.SettingsJSON[setting] === false) return false;
        return true;
      }
    };

    self.updateClassList = function(classes){
      // update all students goal/task status and class mainTopics in global mapping
      if(!classes) classes = [];
      for(var i=0; i < classes.length; i++){
        if(classes[i].viewData && classes[i].viewData != ''){
          self.loadUserClassViewData(classes[i].ID, JSON.parse(classes[i].viewData));
          delete classes[i].viewData; // remove from class object
        }
        if(classes[i].mainTopics){
          self.updateClassContent(classes[i]);
          delete classes[i].mainTopics; // remove from class object
        }
        if(classes[i].folders){
          self.updateClassFolders(classes[i]);
          delete classes[i].folders; // remove from class object
        }
        if(classes[i].collaborations){
          self.updateClassCollaborations(classes[i]);
          delete classes[i].collaborations; // remove from class object
        }
        if(classes[i].notelists && self.user.ID != -1){
          self.updateClassNotelists(classes[i]);
          delete classes[i].notelists; // remove from class object
        }

        if(classes[i].students)
          self.updateClassStudents(classes[i]);
        if(classes[i].teachers)
          self.updateClassTeachers(classes[i]);

        if(classes[i].toolSettings)
          self.updateClassToolSettings(classes[i]);

        if(classes[i].classCalendar){
          self.updateClassCalendars(classes[i]);
          delete classes[i].classCalendar; // remove from class object
          delete classes[i].classCalendarNotes; // remove from class object
        }  

        // only for student user
        if(classes[i].calendar){
          var cal = {};
          cal[classes[i].ID] = classes[i].calendar;
          self.updateUser({ID:self.user.ID, calendars:cal});
        }
        // only for student user
        if(classes[i].calendarNotes){
          var cal = {};
          cal[classes[i].ID] = classes[i].calendarNotes;
          self.updateUser({ID:self.user.ID, calendarNotes:cal});
        }
        if(classes[i].userTasks){
          var uts = {};
          uts[classes[i].ID] = classes[i].userTasks;
          self.updateUser({ID:self.user.ID, userTasks:uts});
        }

        if(classes[i].Settings)
          self.updateClassSettings(classes[i]);

        var online = 0;
        for(var z=0; z < classes[i].students.length; z++)
          if(self.isUserOnline(classes[i].students[z])) online++;
        classes[i].onlineStudents = online;
      }

      // this is bad as we may have references to the old classList elements
      //self.classList = classes;

      // remove old entries
      for(var i=0; i < self.classList.length; i++){
        var found = false;
        for(var z=0; z < classes.length; z++){
          if(classes[z].ID == self.classList[i].ID){
            found = true;
            break;
          }
        }
        if(!found){
          self.classList.splice(i,1);
          i--;
        }
      }
      // update entries & add new entries
      for(var z=0; z < classes.length; z++){
        var found = false;
        for(var i=0; i < self.classList.length; i++){
          if(classes[z].ID == self.classList[i].ID){
            found = true;
            // attention: removes everything from old class object and adds new data from server now
            // will also remove student list and all counters and so on on class object
            for(k in self.classList[i]){
              delete self.classList[i][k];
            }
            // update everything
            for(k in classes[z]){
              self.classList[i][k] = classes[z][k];
            }

            break;
          }
        }
        if(!found){
          self.classList.push(classes[z]);
        }
      }

      var currentClassExists = false;

      if(self.editingClass)
        for(var i=0; i < self.classList.length; i++){
          if(self.editingClass.ID == self.classList[i]["ID"]){
            // update editing class on change too
            self.editingClass["Owner"] = self.classList[i]["Owner"];
            self.editingClass["GUID"] = self.classList[i]["GUID"];
            self.editingClass["Name"] = self.classList[i]["Name"];
            self.editingClass["Groups"] = self.classList[i]["Groups"];
            self.editingClass["AllowUserTasks"] = self.classList[i]["AllowUserTasks"];
            self.editingClass["Description"] = self.classList[i]["Description"];
            break;
          }
        }

      if(self.currentClass){
        for(var i=0; i < self.classList.length; i++){
          if(self.currentClass.ID == self.classList[i].ID) {
            currentClassExists = true;
            self.currentClass = self.classList[i];
            // 1007
            self.updateFilterMainTopicIsOwn();
            self.updateMainTopicFilterColors();
            break;
          }
        }
      }

      if(!currentClassExists && self.currentClass){
        self.resetClass();
        self.lastClassOnReset = null;
        if(self.user.Teacher == 1) self.openEditClasses(null);
        self.apiPost("ajax",{"action":"setLastOpenClass","classid":0});
      }

      self.classListCurrent = [];
      self.hasArchivedClasses = false;

      for(var i=0; i < self.classList.length; i++){
        self.classList[i].chatCounter = self.countNewChatsInClass(self.classList[i]);

        if(self.classList[i].Archived == "0" && self.classList[i].Active == "1"){
          self.classListCurrent.push(self.classList[i]);
        }else
        if(self.classList[i].Archived == "1" && self.classList[i].Active == "1") 
          self.hasArchivedClasses = true;
      }
      // if user save a custom class order, apply it now
      if(self.userViewData["classorder"]){
        var list = self.userViewData["classorder"].split(",").map(Number);
        for(var i=0; i < list.length; i++){
          for(var z=0; z < self.classListCurrent.length; z++){
            if(self.classListCurrent[z].ID == list[i]){
              self.classListCurrent[z].OrderIndex = i+1;
              break;
            }
          }
        }
      }

      self.classListCurrent.sort(function(a,b){
        if(a.OrderIndex == b.OrderIndex){
          return a.ID > b.ID ? 1 : -1;
        }
        return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
      });

      if(self.currentClassFolder){
        self.currentClassFolder = self.findClassFolder(self.currentClassFolder.ID);
        if((!self.currentClassFolder || !self.isClassSet('useFolders')) && self.currentClassFolderDialog ){
          self.closeClassFolder();
        }else
        if(self.currentClassFolderItem){
          var found = false;
          for(var i=0; i < self.currentClassFolder.items.length; i++){
            if(self.currentClassFolderItem.ID == self.currentClassFolder.items[i].ID){
              self.currentClassFolderItem = self.currentClassFolder.items[i];
              found = true;
              break;
            }
          }
          if(!found) self.currentClassFolderItem = null;
        }
      }

      self.updateNewTaskBadges();
      self.updateNewActivityBadge();
      self.updateNewFolderItemsBadge();

      return true;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateNewFolderItemsBadge = function(resetNewItems){
      function countNewItemsInFolder(folder){
        folder.itemCounter = 0;
        if(resetNewItems) folder.isNew = false;
        var lastTime = self.getLastOpenTime("folder",c.ID+'-'+folder.ID);
        var d = new Date().fromMysqlFormat(folder.Changed);
        if (d > lastTime) {
          folder.isNew = true;
        }
        if(folder.items)
          for (var i=0; i < folder.items.length; i++){
            var item = folder.items[i];

            if((item.Type == "task" || item.Type == "goal" || item.Type == "rubric") && !item.DataJSON){
              item.DataJSON = JSON.parse(item.Content);
            }
            if(resetNewItems) {
              item.isNew = false;
            }
            var d = new Date().fromMysqlFormat(item.Changed);
            var itemCounted = false;
            if (d > lastTime) { //  && item.Owner != self.user.ID
              if(self.currentClassFolderItem && self.currentClassFolderItem.ID == item.ID) {
                self.setLastOpenTime("folder",self.currentClass.ID+'-'+folder.ID);
                continue;
              }
              folder.itemCounter++;
              item.isNew = true;
              itemCounted = true;
            }
          }
        /*  
        if(folder.itemCounter == 0){
          folder.isNew = false;
        }
        */
        if(folder.isNew && self.currentClassFolder && self.currentClassFolder.ID == folder.ID){
          folder.isNew = false;
          folder.itemCounter = 0;
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+folder.ID);
        }
      }

      for(var cl=0; cl < self.classList.length; cl++){
        var c = self.classList[cl];

        c.folderCounter = 0;

        // find new items in class folders
        if(self.classContent && self.classContent[c.ID] && self.classContent[c.ID].folders){
          for (var z=0; z < self.classContent[c.ID].folders.length; z++){
            var folder = self.classContent[c.ID].folders[z];
            countNewItemsInFolder(folder);
            c.folderCounter += folder.itemCounter;
            if(folder.itemCounter > 99) folder.itemCounter = "99+";
          }
        }

        c.classFolderCounter = c.folderCounter;
        if(self.user.Teacher == 1){
          // check all student folders and count new items too
          c.studentFolderCounter = 0;
          for(var cs = 0; cs < c.students.length; cs++){
            var s = c.students[cs];

            if(self.users[s.ID] &&
               self.users[s.ID].classContent &&
               self.users[s.ID].classContent[c.ID] &&
               self.users[s.ID].classContent[c.ID].folders){

              self.users[s.ID].classContent[c.ID].userFolderItemCounter = 0;
              for (var z=0; z < self.users[s.ID].classContent[c.ID].folders.length; z++){
                var folder = self.users[s.ID].classContent[c.ID].folders[z];
                countNewItemsInFolder(folder);
                c.studentFolderCounter += folder.itemCounter;
                self.users[s.ID].classContent[c.ID].userFolderItemCounter += folder.itemCounter;
                if(folder.itemCounter > 99) folder.itemCounter = "99+";
              }

            }
          }
          // c.folderCounter += c.studentFolderCounter;
          if(c.studentFolderCounter > 99) c.studentFolderCounter = "99+";
        }
        if(c.folderCounter > 99) c.folderCounter = "99+";
      }
    };

    self.updateNewActivityBadge = function(){
      return; // deprecated Juli 2022

      if(!self.user || self.user.Teacher != "1") return;

      for(var cl=0; cl < self.classList.length; cl++){
        var c = self.classList[cl];
        var t = 0;
        for(var i=0; i < c.students.length; i++){
          var j = self.getStudentFilteredJournal(
                        c.students[i],{WHEN:'new',WHAT:'all',WHERE:'all'},c.ID);

          for(var z=0; z < j.length; z++){
            if(j[z].Type == 'userentry' ||
               j[z].Type == 'teacherentry' ||
               j[z].Type == 'teachertaskentry' ||
               j[z].Type == 'teachergoalentry') {
              t++;
            }
          }
        }

        c.totalActivityBadgeCount = t;
        c.filteredActivityBadgeCount = 0;

        if(self.currentClass && c.ID == self.currentClass.ID){
          var t = 0;
          for(var i=0; i < c.students.length; i++){
            if(self.currentClassResultStudentFilter &&
               self.currentClassResultStudentFilter.length > 0){
              if(self.currentClassResultStudentFilter.indexOf(c.students[i].ID) == -1)
                continue; // skip student
            }
            // this time we use the global setting cross dialogs for
            // selected MainTopic filter
            var place = (self.currentClassResultMainTopicFilter &&
                         self.currentClassResultMainTopicFilter.length > 0) ?
                          'maintopics':'all';

            var filter = self.currentClassResultMainTopicFilter;

            var j = self.getStudentFilteredJournal(
                        c.students[i],{WHEN:'new',WHAT:'all',WHERE:place,WHERETOPICS:filter},c.ID);

            for(var z=0; z < j.length; z++){
              if(j[z].Type == 'userentry' ||
                 j[z].Type == 'teacherentry' ||
                 j[z].Type == 'teachertaskentry' ||
                 j[z].Type == 'teachergoalentry') {
                t++;
              }
            }
          }
          c.filteredActivityBadgeCount = t;
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    //1007
    self.updateMainTopicFilterColors = function() {
      self.currentClassMTColorChoice = [];
      if(self.currentClass && self.classContent[self.currentClass.ID].mainTopics) {
        for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++) {
          if(self.currentClassMTColorChoice.indexOf(self.classContent[self.currentClass.ID].mainTopics[i].Color) < 0)
            self.currentClassMTColorChoice.push(self.classContent[self.currentClass.ID].mainTopics[i].Color);
        }

        var sortedColors = [];
        for(var x = 0; x < self.colorChoice.length; x++)
          if(self.currentClassMTColorChoice.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);

        self.currentClassMTColorChoice = sortedColors;
      }
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateNewTaskBadges = function(reset){
      // mark new tasks as new based on last open topic
      if(self.currentClass && self.user && self.user.Teacher == "0"){
        for(var m=0; m < self.classContent[self.currentClass.ID].mainTopics.length; m++){
          var mt = self.classContent[self.currentClass.ID].mainTopics[m];
          for(var t=0; t < mt.topics.length; t++){
            var it = mt.topics[t];
            var lastTime = self.getLastOpenTime("topic",self.currentClass.ID+'-'+it.ID);

            if(!lastTime) continue; // never opend, don't show new badges!
            var cc = 0;
            for(var i=0; i < it.goals.length;i++){
              var goalItems = self.userViewData["U"+self.user.ID+"_gt_"+self.currentClass.ID+"-"+it.goals[i].ID];
              if(goalItems === undefined) continue;
              var goalItemIDs = [];
              if(goalItems && goalItems != "") 
                 goalItemIDs = goalItems.split(",").map(Number); 

              for(var z=0; z < it.goals[i].tasks.length; z++){
                if(!self.currentTopic || self.currentTopic.ID != it.ID) 
                  delete it.goals[i].tasks[z].isNew;                
                if(goalItemIDs.indexOf(it.goals[i].tasks[z].ID) == -1){
                  var status = self.getUserTaskStatus(it.goals[i].tasks[z],self.user,true);
                  if(status.Status == "OK") continue;
                  it.goals[i].tasks[z].isNew = 1;
                  cc++;
                }
                /*
                var d1 = new Date().fromMysqlFormat(it.goals[i].tasks[z].Changed);
                if(d1 > lastTime) { // && it.goals[i].tasks[z].userTask != 1
                  if(!self.currentTopic || self.currentTopic.ID != it.ID){
                    var status = self.getUserTaskStatus(it.goals[i].tasks[z],self.user,true);
                    if(status.Status != "OK")
                      it.goals[i].tasks[z].isNew = 1;
                  }
                  cc++;
                } else {
                  if(reset){
                    delete it.goals[i].tasks[z].isNew;
                  }else if(it.goals[i].tasks[z].isNew == 1) cc++;
                }
                */
              }
            }
            it.hasNew = cc;
          }
        }
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getMainTopicByID = function(id){
      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        if(self.userContent.mainTopics[i].ID == id) return self.userContent.mainTopics[i];
      }
      if(self.classList)
      for(var c=0; c < self.classList.length; c++){
        if(self.classContent[self.classList[c].ID] &&
           self.classContent[self.classList[c].ID].mainTopics)
        for(var i=0; i < self.classContent[self.classList[c].ID].mainTopics.length; i++){
          if(self.classContent[self.classList[c].ID].mainTopics[i].ID == id)
            return self.classContent[self.classList[c].ID].mainTopics[i];
        }
      }
      return null;
    };

