    self.removeTasksFromClass = function(c,list,ev){
      var json = {"tasks":[]};
      for(var i=0; i < list.length; i++){
        json["tasks"].push({"ID":list[i].ID,"used":0});
      }
      self.confirm($filter('trans')('REMOVEFROMCLASSASK',list.length+" "+$filter('trans')('TASKS')),$filter('trans')('REMOVE'),ev).then(function(){
        self.apiPost("ajax",{"action":"setClassesContentInUse","classid":c.ID,
                             "changes":angular.toJson(json)}).then(function(data) {
          while(list.length > 0) list.pop(); // clear list
          self.getClasses();
        });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editMainTopic = function(it,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "editmaintopic.html",
        targetEvent: ev,

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.isEdit = 1;
          $scope.item = JSON.parse(angular.toJson(it));
          $scope.colorChoice = self.colorChoice;

          self.addEditMainTopicScope($scope);

          $scope.save = function() {
            // try save now
            var tags = [];
            for(var i=0; i < $scope.tags.length; i++){
              if($.trim($scope.tags[i].text) === "") continue;
              tags.push($scope.tags[i].text+"☐"+$scope.tags[i].color);
            }
            $scope.item.Tags = tags.join("|");

            if($scope.item.Name == "") { $('#inputName').focus(); return;}
            $scope.item.Description = self.trimHTML($scope.item.Description);

            self.replaceBase64Images($scope.item.Description).then(function(desc){        
              $scope.item.Description = desc;
              self.apiPost("ajax",{"action":"updateMainTopic", "ID":it.ID, "Name":$scope.item.Name,
                                   "Tags" : $scope.item.Tags,
                                   "Description":$scope.item.Description, "Color":$scope.item.Color})
               .then(function(data) {
                 it.Name = $scope.item.Name;
                 it.Description = $scope.item.Description;
                 it.Tags = $scope.item.Tags;
                 it.Color = $scope.item.Color;
                 self.closeDialog($scope.dialogElement);
                 deferred.resolve();
                 self.keepAliveCallback();
                 if(self.searchTerm && self.searchTerm != '')
                   self.addedAfterLastSearchTermChange.mainTopics.push(it.ID);
               });
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.previewAllShares = function(ev){
      if(self.openSharesToAccept && self.openSharesToAccept.length == 1){
        // directly open it
        self.acceptSharedContent(self.openSharesToAccept[0]);
        return;
      }
      self.showDialog({
        state:"modal",
        templateUrl: "previewAllShares.html",
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          self.acceptShareContentOpen = true;
          $scope.self = self;
          // self.openSharesToAccept

          $scope.discardAll = function(ev){
            self.confirm('<span style="color:red">'+$filter('trans')('ASKSHAREREJECTALL')+'</span>','<span style="color:red">'+$filter('trans')('DELETE')+'</span>',ev).then(function(){
              self.showLoadingIndicator(ev,function(done){
                var c = self.openSharesToAccept.length;
                for(var i=0; i < self.openSharesToAccept.length; i++){
                  self.apiPost("ajax",{"action":"discardSharedContent","value": 0,
                           "data":self.openSharesToAccept[i].Data, "type":self.openSharesToAccept[i].Type}).then(function(data) {
                    c--;
                    if(c == 0){
                      self.closeDialog($scope.dialogElement);
                      done();
                      self.keepAliveCallback(); // refresh now
                    }
                  });             
                }
              });
            });
          };

          $scope.open = function(it){
            $scope.cancel();
            self.acceptSharedContent(it);            
          };

          $scope.cancel = function() {
            self.acceptShareContentOpen = false;
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.previewSharedContent = function(type,item,hash,share){
      self.showDialog({
        state:"one",
        templateUrl: "previewSharedContent.html",
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          self.acceptShareContentOpen = true;
          $scope.self = self;
          $scope.item = item;
          $scope.type = type;
          $scope.target = null;
          $scope.share = share;
          $scope.derivations = [];
          // switch to material
          if(self.currentTeacherNavigation != 'Prep') {
            self.openMaterials(null);
          }
          $scope.shareDone = false;

          $scope.getTypeID = function(type){
            var typeID = 0;
            if(type == "MainTopic") typeID = 1;
            if(type == "Topic") typeID = 2;
            if(type == "LearningGoal") typeID = 3;
            if(type == "Task") typeID = 4;
            return typeID;
          }

          $scope.copy = function(ev){
            self.selectMoveTarget("copy",type, item, ev,
              function(target,id,type,position,follow,isLocal){
                if(share) $scope.discard(1);
                self.closeDialog($scope.dialogElement);
                self.apiPost("ajax",{"action":"copySharedContentByHash", "type":type,"position":position, "id":item.ID, "target":target, "hash":hash}).then(function(data) {

                  self.keepAliveCallback().then(function(){
                    if(follow) {
                      self.openContentFollow(type,null,data);
                    }
                  });
                });
              });            
          };

          // TODO: if this was already copied, provide an update button
          //self.apiPost("ajax",{"action":"getDerivations", "type":$scope.getTypeID(type), "parent":item.ID}).then(function(data) {
          //  $scope.derivations = data.derivations;
          //});

          $scope.update = function(ev){
            // TODO
          };

          $scope.updateElement = function(type2,item2,parents){
            // TODO
            self.apiPost("ajax",{"action":"getDerivations", "type":$scope.getTypeID(type2), "parent":item2.ID}).then(function(data) {
              if(data.derivations.length > 0){
                self.confirm('Möchtest du ?').then(function(){
                });

              }else{
                self.confirm('Das Element existiert noch nicht in deinen Materialien. Soll es jetzt erstellt werden?').then(function(){
                  
                  // parents durchgehen
                  // durchgehen $scope.derivations  
                  // 
                });
              }
            });
          };

          $scope.copyElement = function(type,item,ev){
            var old = self.lastFollowContent;
            self.lastFollowContent = false;
            self.selectMoveTarget("copy",type, item, ev,
              function(target,id,type,position,follow,isLocal){
                if(share) $scope.discard(1);
                self.lastFollowContent = old || follow;
                self.apiPost("ajax",{"action":"copySharedContentByHash", "type":type,"position":position, "id":item.ID, "target":target, "hash":item.Hash}).then(function(data) {
                  self.keepAliveCallback().then(function(){
                    if(follow) {
                      self.closeDialog($scope.dialogElement);
                      self.openContentFollow(type,null,data);
                    }
                  });
                });
              });            
          };

          $scope.discard = function(value){
            self.apiPost("ajax",{"action":"discardSharedContent","value":value,
                     "data":share.Data, "type":share.Type}).then(function(data) {
              self.acceptShareContentOpen = false;
              $scope.shareDone = true;
              if(value == 0){
                self.closeDialog($scope.dialogElement);
                self.keepAliveCallback(); // refresh now
              }
            },function(data, status, headers, config) {
              self.alert("Error: "+data.error);
            });
          };

          $scope.cancel = function() {
            self.acceptShareContentOpen = false;
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.shareMainTopic = function(it,ev){
      self.showDialog({
        templateUrl: "sharecodepanel.html",
        targetEvent: ev,

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          self.apiPost("ajax",{"action":"requestShareMainTopicLink", "id":it.ID}).then(function(data) {
            if(data.link){
              $scope.link = data.link;
            }
          });
          $scope.copy = function(){
            copyTextToClipboard($scope.link);
            self.closeDialog($scope.dialogElement);
            self.alert($filter('trans')('COPYEDLINKTOCLIPBOARD'),null);                
          };
          $scope.email = self.getLocalStorage("lastShareEmail") ? self.getLocalStorage("lastShareEmail") : "";
          $scope.share = function() {
            self.setLocalStorage("lastShareEmail",$scope.email);
            var successCount = 0;
            var successCountTry = 0;
            var mails = $scope.email.split(";");
            $(mails).each(function(i,e){
              e = $.trim(e);
              if(e == "") return;
              successCountTry++;
              self.apiPost("ajax",{"action":"shareMainTopic", "mainTopic":it.ID, "email":e})
               .then(function(data) {
                 successCount++;
                 if(successCountTry == successCount) self.closeDialog($scope.dialogElement);
               },function(data, status, headers, config) {
                 if(data.error == "USER_NOT_FOUND")
                   self.alert($filter('trans')('SHAREUSERNOTFOUND',$scope.email));
                 else if(data.error == "NO_TEACHER")
                   self.alert($filter('trans')('SHAREUSERNOTEACHER',$scope.email));
                 else $scope.error = "Fehlgeschlagen: "+data.error;
               });
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

