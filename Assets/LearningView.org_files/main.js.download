    self.countClassesTaskVisible = function(it){
      var c = 0;
      if(!self.currentMainTopic) return 0;
      if(!self.currentTopic) return 0;
      for(var i=0; i < self.classListCurrent.length; i++){
        var found = false;
        var hasPath = false;
        var content = self.classContent[self.classListCurrent[i].ID];
        for(var z=0; z < content.mainTopics.length; z++){
          if(content.mainTopics[z].ID == self.currentMainTopic.ID){
            for(var x=0; x < content.mainTopics[z].topics.length; x++){
              if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                  if(content.mainTopics[z].topics[x].goals[y].ID == it.LearningGoal){
                    hasPath = true;
                    for(var w=0; w < content.mainTopics[z].topics[x].goals[y].tasks.length; w++){
                      if(content.mainTopics[z].topics[x].goals[y].tasks[w].ID == it.ID){
                        found = true; break;
                      }
                    }
                  }
                }
                break;
              }
            }
            break;
          }
        }
        if(found) c++;
      }
      return c;
    }

    self.showClassesTaskVisibility = function(it,ev){
      // dialog for selected classes to use this maintopic
      self.showDialog({
        templateUrl: "contentClassesVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.it = it;
          $scope.type = "task";
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.suggestions = [];          
          for(var i=0; i < self.classListCurrent.length; i++){
            var found = false;
            var hasPath = false;
            var content = self.classContent[self.classListCurrent[i].ID];
            for(var z=0; z < content.mainTopics.length; z++){
              if(content.mainTopics[z].ID == self.currentMainTopic.ID){
                for(var x=0; x < content.mainTopics[z].topics.length; x++){
                  if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                    for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                      if(content.mainTopics[z].topics[x].goals[y].ID == it.LearningGoal){
                        hasPath = true;
                        for(var w=0; w < content.mainTopics[z].topics[x].goals[y].tasks.length; w++){
                          if(content.mainTopics[z].topics[x].goals[y].tasks[w].ID == it.ID){
                            found = true; break;
                          }
                        }
                      }
                    }
                    break;
                  }
                }
                break;
              }
            }

            if( !self.hasClassChangePermission(self.classListCurrent[i])){
              $scope.disabled.push(self.classListCurrent[i].ID);
            } else {
              if(found) $scope.selection.push(self.classListCurrent[i].ID);
              if(hasPath) $scope.suggestions.push(self.classListCurrent[i].ID);
            }
          }

          self.addClassesContentVisibilityScope($scope);
          
          $scope.applyParentVisibility = function(){
            $scope.selection = [];
            for(var i=0; i < $scope.suggestions.length; i++){
              if($scope.disabled.indexOf($scope.suggestions[i]) == -1 &&
                 $scope.selection.indexOf($scope.suggestions[i]) == -1)
                $scope.selection.push($scope.suggestions[i]);
            }
          }

          $scope.save = function() {
            $scope.saveNow();
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.showClassesTasksVisibility = function(tasks,ev){
      // dialog for selected classes to use this maintopic
      self.showDialog({
        templateUrl: "contentClassesVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.it = tasks;
          $scope.type = "tasks";
          $scope.selection = [];
          $scope.disabled = [];

          $scope.smallScreen = self.isSmallScreen;
          for(var i=0; i < self.classListCurrent.length; i++){
            var content = self.classContent[self.classListCurrent[i].ID];
            var foundAll = true;
            var hasPathAll = true;
            for(var t=0; t < tasks.length; t++){
              var it = tasks[t];
              var found = false;
              var hasPath = false;
              for(var z=0; z < content.mainTopics.length; z++){
                if(content.mainTopics[z].ID == self.currentMainTopic.ID){
                  for(var x=0; x < content.mainTopics[z].topics.length; x++){
                    if(content.mainTopics[z].topics[x].ID == self.currentTopic.ID){
                      for(var y=0; y < content.mainTopics[z].topics[x].goals.length; y++){
                        if(content.mainTopics[z].topics[x].goals[y].ID == it.LearningGoal){
                          hasPath = true;
                          for(var w=0; w < content.mainTopics[z].topics[x].goals[y].tasks.length; w++){
                            if(content.mainTopics[z].topics[x].goals[y].tasks[w].ID == it.ID){
                              found = true; break;
                            }
                          }
                        }
                      }
                      break;
                    }
                  }
                  break;
                }
              }
              foundAll = foundAll && found;
              hasPathAll = hasPathAll && hasPath;
            }

            if( !self.hasClassChangePermission(self.classListCurrent[i])){
              $scope.disabled.push(self.classListCurrent[i].ID);
            } else {
              if(foundAll) $scope.selection.push(self.classListCurrent[i].ID);
            }
          }

          self.addClassesContentVisibilityScope($scope);

          $scope.save = function() {            
            for(var t=0; t < tasks.length; t++){
              $scope.it = tasks[t];
              $scope.type = "task";
              $scope.setScopeVariablesFromClassContent($scope);
              $scope.saveNow();
            }
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showMainTopicVisibility = function(it,ev,cc){
      if((cc ? cc : self.currentClass).students.length == 0){
        self.alert($filter('trans')('NOSTUDENTSINCLASS'));
        return;
      }
      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.it = it;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.hasSubItems = 'maintopic';

          for(var i=0; i < c.students.length; i++){
            var hidden = !self.isUserMainTopicVisible(it, c.students[i],c,true);
            if(!hidden) $scope.selection.push(c.students[i].ID);
          }


          self.addContentVisibilityScope($scope);
          


          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            var hiddenFor = [];
            for(var i=0; i < c.students.length; i++){
              var isIn = false;
              for(var z=0; z < $scope.selection.length; z++){
                if($scope.selection[z] == c.students[i].ID) isIn = true;
              }
              if(!isIn) hiddenFor.push(c.students[i].ID);
              var isThere = false;
              if(self.users[c.students[i].ID] &&
                 self.users[c.students[i].ID].classContent[c.ID] &&
                 self.users[c.students[i].ID].classContent[c.ID].mainTopics &&
                 self.users[c.students[i].ID].classContent[c.ID].mainTopics[it.ID]){
                 self.users[c.students[i].ID].classContent[c.ID].mainTopics[it.ID].Hidden =
                   isIn ? "0" : "1";
                 isThere = true;
              }

              if(!isThere){
                if(!self.users[c.students[i].ID].classContent)
                    self.users[c.students[i].ID].classContent = {};
                if(!self.users[c.students[i].ID].classContent[c.ID].mainTopics)
                    self.users[c.students[i].ID].classContent[c.ID].mainTopics = {};

                self.users[c.students[i].ID].classContent[c.ID].mainTopics[it.ID] =
                  {MainTopic:it.ID, Hidden:isIn ? "0" : "1"};
              }
            }

            self.updateUserMainTopicVisibility(it,c,hiddenFor);

            if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
              if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime))
                self.updateClassMainTopicTimes(it,c,$scope.vFromDateTime,
                                                    $scope.vToDateTime);
            }

            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.showTopicVisibility = function(mt,it,ev,cc){
      if((cc ? cc : self.currentClass).students.length == 0){
        self.alert($filter('trans')('NOSTUDENTSINCLASS'));
        return;
      }
      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.it = it;
          $scope.mt = mt;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.hasSubItems = 'topic';

          for(var i=0; i < c.students.length; i++){
            var disabled = !self.isUserMainTopicVisible(mt, c.students[i],c,true);
            var hidden = !self.isUserTopicVisible(it, c.students[i],c,true);
            if(!hidden) $scope.selection.push(c.students[i].ID);
            if(disabled) $scope.disabled.push(c.students[i].ID);
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            var hiddenFor = [];
            for(var i=0; i < c.students.length; i++){
              var isIn = false;
              for(var z=0; z < $scope.selection.length; z++){
                if($scope.selection[z] == c.students[i].ID) isIn = true;
              }
              if(!isIn) hiddenFor.push(c.students[i].ID);
              var isThere = false;
              if(self.users[c.students[i].ID] &&
                 self.users[c.students[i].ID].classContent[c.ID] &&
                 self.users[c.students[i].ID].classContent[c.ID].topics &&
                 self.users[c.students[i].ID].classContent[c.ID].topics[it.ID]){
                 self.users[c.students[i].ID].classContent[c.ID].topics[it.ID].Hidden =
                   isIn ? "0" : "1";
                 isThere = true;
              }
              if(!isThere) {
                if(!self.users[c.students[i].ID].classContent)
                    self.users[c.students[i].ID].classContent = {};
                if(!self.users[c.students[i].ID].classContent[c.ID].topics)
                    self.users[c.students[i].ID].classContent[c.ID].topics = {};

                self.users[c.students[i].ID].classContent[c.ID].topics[it.ID] =
                  {Topic:it.ID, Hidden:isIn ? "0" : "1"};
              }
            }

            self.updateUserTopicVisibility(it,c,hiddenFor);

            if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
              if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime))
                self.updateClassTopicTimes(it,c,$scope.vFromDateTime,
                                                $scope.vToDateTime);
            }

            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.lastShowStudentStatus = false;

    self.showLearningGoalVisibility = function(mt,t,it,ev,cc){
      if((cc ? cc : self.currentClass).students.length == 0){
        self.alert($filter('trans')('NOSTUDENTSINCLASS'));
        return;
      }
      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.mt = mt;
          $scope.t = t;
          $scope.it = it;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.goal = it; // for status display
          $scope.hasSubItems ='goal';

          for(var i=0; i < c.students.length; i++){
            var disabled = !self.isUserMainTopicVisible(mt, c.students[i],c,true) || !self.isUserTopicVisible(t, c.students[i],c,true);
            var hidden = !self.isUserLearningGoalVisible(it, c.students[i],c,true);
            if(!hidden) $scope.selection.push(c.students[i].ID);
            if(disabled) $scope.disabled.push(c.students[i].ID);
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            var hiddenFor = [];
            for(var i=0; i < c.students.length; i++){
              var isIn = false;
              for(var z=0; z < $scope.selection.length; z++){
                if($scope.selection[z] == c.students[i].ID) isIn = true;
              }
              if(!isIn) hiddenFor.push(c.students[i].ID);
              var isThere = false;
              if(self.users[c.students[i].ID] &&
                 self.users[c.students[i].ID].classContent[c.ID] &&
                 self.users[c.students[i].ID].classContent[c.ID].goals &&
                 self.users[c.students[i].ID].classContent[c.ID].goals[it.ID]){
                 self.users[c.students[i].ID].classContent[c.ID].goals[it.ID].Hidden =
                   isIn ? "0" : "1";
                 isThere = true;
              }
              if(!isThere) {
                if(!self.users[c.students[i].ID].classContent)
                    self.users[c.students[i].ID].classContent = {};
                if(!self.users[c.students[i].ID].classContent[c.ID].goals)
                    self.users[c.students[i].ID].classContent[c.ID].goals = {};

                self.users[c.students[i].ID].classContent[c.ID].goals[it.ID] =
                  {LearningGoal:it.ID, Hidden:isIn ? "0" : "1"};
              }
            }
            self.updateUserLearningGoalVisibility(it,c,hiddenFor);
            if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
              if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime))
                self.updateClassLearningGoalTimes(it,c,$scope.vFromDateTime,
                                                       $scope.vToDateTime);
            }

            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.toggleUserLearningGoalVisibility = function(student, goal, c){
      var hiddenFor = [];
      var hiddenNow = false;
      for(var i=0; i < c.students.length; i++){
        var hidden = !self.isUserLearningGoalVisible(goal, c.students[i],c,true);
        if(c.students[i].ID == student.ID){
          hiddenNow = hidden;
          continue;
        }
        if(hidden) hiddenFor.push(c.students[i].ID);
      }
      // if not hidden now, add it
      if(!hiddenNow){
        hiddenFor.push(student.ID);

        if(!self.users[student.ID].classContent)
            self.users[student.ID].classContent = {};
        if(!self.users[student.ID].classContent[c.ID].goals)
            self.users[student.ID].classContent[c.ID].goals = {};

        if(!self.users[student.ID].classContent[c.ID].goals[goal.ID])
            self.users[student.ID].classContent[c.ID].goals[goal.ID] =
                  {Class:c.ID, LearningGoal:goal.ID, Hidden:"1"};
            else
            self.users[student.ID].classContent[c.ID].goals[goal.ID].Hidden = "1";
      }else{

        self.users[student.ID].classContent[c.ID].goals[goal.ID].Hidden = "0";
      }
      self.updateUserLearningGoalVisibility(goal,c,hiddenFor);
    };

    self.toggleUserTaskVisibility = function(student, task, c){
      var hiddenFor = [];
      var hiddenNow = false;
      for(var i=0; i < c.students.length; i++){
        var hidden = !self.isUserTaskVisible(task, c.students[i],c,true);
        if(c.students[i].ID == student.ID){
          hiddenNow = hidden;
          continue;
        }
        if(hidden) hiddenFor.push(c.students[i].ID);
      }
      // if not hidden now, add it
      if(!hiddenNow){
        hiddenFor.push(student.ID);

        if(!self.users[student.ID].classContent)
            self.users[student.ID].classContent = {};
        if(!self.users[student.ID].classContent[c.ID].tasks)
            self.users[student.ID].classContent[c.ID].tasks = {};

        if(!self.users[student.ID].classContent[c.ID].tasks[task.ID])
            self.users[student.ID].classContent[c.ID].tasks[task.ID] =
                  {Class:c.ID, Task:task.ID, Hidden:"1"};
            else
            self.users[student.ID].classContent[c.ID].tasks[task.ID].Hidden = "1";
      }else{

        self.users[student.ID].classContent[c.ID].tasks[task.ID].Hidden = "0";
      }
      var ts = self.getUserTaskStatus(task,student,true);
      ts.taskVisibilityUpdate = true;
      self.updateUserTaskVisibility(task,c,hiddenFor);
    };

    self.showTaskVisibility = function(it,ev,cc){
      if((cc ? cc : self.currentClass).students.length == 0){
        self.alert($filter('trans')('NOSTUDENTSINCLASS'));
        return;
      }
      var mt,t,g;
      var find = self.getTaskByID(it.ID);
      if(find && find.mainTopic){
        mt = find.mainTopic;
        t = find.topic;
        g = find.goal;
      }else{
        return;
      }

      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.it = it;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.task = it; // for status display

          if(!g)
          for(var i=0; i < t.goals.length; i++){
            if(t.goals[i].ID == it.LearningGoal){
              g = t.goals[i];
            }
          }
          if(!g) return; // error case, parent goal not selected

          for(var i=0; i < c.students.length; i++){
            var disabled = !self.isUserMainTopicVisible(mt, c.students[i],c,true) ||
                           !self.isUserTopicVisible(t, c.students[i],c,true) ||
                           !self.isUserLearningGoalVisible(g, c.students[i],c,true);
            var hidden = !self.isUserTaskVisible(it, c.students[i],c,true);
            if(!hidden) $scope.selection.push(c.students[i].ID);
            if(disabled) $scope.disabled.push(c.students[i].ID);
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            var now = new Date().toMysqlFormat();
            var hiddenFor = [];
            for(var i=0; i < c.students.length; i++){
              var isIn = false;
              for(var z=0; z < $scope.selection.length; z++){
                if($scope.selection[z] == c.students[i].ID) isIn = true;
              }
              if(!isIn) hiddenFor.push(c.students[i].ID);
              var isThere = false;
              if(self.users[c.students[i].ID] &&
                 self.users[c.students[i].ID].classContent[c.ID] &&
                 self.users[c.students[i].ID].classContent[c.ID].tasks &&
                 self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID]){
                 self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID].Hidden =
                   isIn ? "0" : "1";
                 isThere = true;
              }
              if(!isThere){
                if(!self.users[c.students[i].ID].classContent)
                    self.users[c.students[i].ID].classContent = {};
                if(!self.users[c.students[i].ID].classContent[c.ID].tasks)
                    self.users[c.students[i].ID].classContent[c.ID].tasks = {};

                self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID] =
                  {Class:c.ID, Task:it.ID, Hidden:isIn ? "0" : "1"};
              }

            }
            self.updateUserTaskVisibility(it,c,hiddenFor);
            if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
              if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime))
                self.updateClassTaskTimes(it,c,$scope.vFromDateTime,
                                               $scope.vToDateTime);
            }
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.showTasksVisibility = function(tasks,ev,cc){
      if((cc ? cc : self.currentClass).students.length == 0){
        self.alert($filter('trans')('NOSTUDENTSINCLASS'));
        return;
      }

      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;

          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;

          for(var i=0; i < c.students.length; i++){
            var hidden = false;
            var disabled = false;
            for(var t=0; t < tasks.length; t++){
              var it = tasks[t];
              hidden = hidden || !self.isUserTaskVisible(it, c.students[i],c,true);
              var f = self.getTaskByID(it.ID);
              disabled = disabled || 
                          !self.isUserMainTopicVisible(f.mainTopic, c.students[i],c,true) ||
                          !self.isUserTopicVisible(f.topic, c.students[i],c,true) ||
                          !self.isUserLearningGoalVisible(f.goal, c.students[i],c,true);
            }
            if(!hidden) $scope.selection.push(c.students[i].ID);
            if(disabled) $scope.disabled.push(c.students[i].ID);
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            var now = new Date().toMysqlFormat();
            var hiddenFor = [];
            for(var t=0; t < tasks.length; t++){
              var it = tasks[t];
              for(var i=0; i < c.students.length; i++){
                var isIn = false;
                for(var z=0; z < $scope.selection.length; z++){
                  if($scope.selection[z] == c.students[i].ID) isIn = true;
                }
                if(!isIn) hiddenFor.push(c.students[i].ID);
                var isThere = false;
                if(self.users[c.students[i].ID] &&
                   self.users[c.students[i].ID].classContent[c.ID] &&
                   self.users[c.students[i].ID].classContent[c.ID].tasks &&
                   self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID]){
                   self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID].Hidden =
                     isIn ? "0" : "1";
                   isThere = true;
                }
                if(!isThere){
                  if(!self.users[c.students[i].ID].classContent)
                      self.users[c.students[i].ID].classContent = {};
                  if(!self.users[c.students[i].ID].classContent[c.ID].tasks)
                      self.users[c.students[i].ID].classContent[c.ID].tasks = {};

                  self.users[c.students[i].ID].classContent[c.ID].tasks[it.ID] =
                    {Class:c.ID, Task:it.ID, Hidden:isIn ? "0" : "1"};
                }

              }
              self.updateUserTaskVisibility(it,c,hiddenFor);
              if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
                if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime))
                  self.updateClassTaskTimes(it,c,$scope.vFromDateTime,
                                                 $scope.vToDateTime);
              }
            }

            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
