     var prevent = app.preventReloadNow;
     if(prevent){
       console.log("From:"+oldUrl+" to "+newUrl+" prevented.");
       //event.preventDefault(); // This prevents the navigation from happening
       return false;
     }
    });
  }]);

  app.run(function() {
    if(window.FastClick) FastClick.attach(document.body);
  });

  // accessability focus reset on md-menu close
  app.run(function($rootScope) {
    var lastTrigger = null;
    var keydownHandler = null;

    $rootScope.$on('$mdMenuOpen', function(ev, el) {
      if(el && el[0] && el[0].children.length > 0)
        lastTrigger = el[0].children[0]; // md-menu-origin element

      // attach focus trap to menu content
      if(!el || !el[0]) return;
      var menuContent = el[0].querySelector('md-menu-content');

      if(!menuContent && el[0].children.length > 0){
        var id = el[0].children[0].getAttribute("aria-owns");
        var container = document.getElementById(id);
        if(container){
          menuContent = container.children[0];
        }
      }
      if (!menuContent) return;

      var focusable = menuContent.querySelectorAll('button, [tabindex]:not([tabindex="-1"])');
      keydownHandler = function(e) {
        if (e.key !== 'Tab') return;

        var first = focusable[0];
        var last = focusable[focusable.length - 1];

        if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        } else if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      };
      menuContent.addEventListener('keydown', keydownHandler);

      setTimeout(function(){
        if(focusable && focusable.length > 0) focusable[0].focus();
      },10);
    });

    $rootScope.$on('$mdMenuClose', function(ev, el) {
      if (lastTrigger) {
        if(lastTrigger.offsetParent) lastTrigger.focus();
        lastTrigger = null;
      }
      // remove focus trap
      if (el && el[0]) {
        var menuContent = el[0].querySelector('md-menu-content');
        if (menuContent && keydownHandler) {
          menuContent.removeEventListener('keydown', keydownHandler);
          keydownHandler = null;
        }
      }
    });
  });

  app.controller('AppController', function () { });

  app.translationsLoading = {};

  app.fetchTranslation = function(lang){
    app.translationsLoading[lang] = true;
    $.getJSON("https://learningview.org/i18n/"+lang+".json?r="+Math.random(),function(data){
      app.translations[lang] = data;
    }).error(function(){
      app.translationsLoading[lang] = false;
    });
  };

  app.fetchTranslation("DE"); // for reference

  app.setLanguage = function(lang){
    for(var k in app.translations){
      if(k == lang){
        app.currentLanguage = lang;
        app.fetchTranslation(lang);
        moment.locale(app.currentLanguage);
        try{
          localStorage.setItem("displayLanguage",lang);
        }catch(e){}
      }
    }
  };

  app.patchWKWebviewPath = function(url){
    if(url.indexOf("file://") != -1){
      if(window.Ionic && window.Ionic.WebView && window.Ionic.WebView.convertFileSrc){
        var converted = window.Ionic.WebView.convertFileSrc(url);
        if (!converted || converted.indexOf("undefined/") === 0) {
          converted = converted.replace(/^undefined\//, "ionic://localhost/");
        }
        url = converted;
      }
    }
    return url;
  }

  app.filter('limitObjectsTo', [function(){
      return function(obj, limit){
          if(!obj) return [];
          var keys = Object.keys(obj);
          if(keys.length < 1) return [];

          var ret = new Object();
          var count = 0;
          angular.forEach(keys, function(key, arrayIndex){
              if(count >= limit) return false;
              ret[key] = obj[key];
              count++;
          });
          return ret;
      };
  }]);

  app.filter('trustUrl', ['$sce', function ($sce) {
    return function(url) {
      var u = String(url || '').trim();
      if (!u) return '';
      if (!/^(https?:|blob:|data:image\/(?:png|gif|jpe?g|webp);base64,|file:|cdvfile:)/i.test(u)) {
        return '';
      }
      return $sce.trustAsResourceUrl(u);
    };
  }]);

  app.filter("addLineBreaks", function() {
    var f = function(input) {
      if(!input || !input.replace) return "";
      return input.replace(/\u00A0/g,"\n");
    };
    f.$stateful = true;
    return f;
  });

  app.filter("trans", function() {
    var f = function(input, data, data2, data3, data4, data5) {
      if(!app.translations[app.currentLanguage]){
        // fetch i18n file
        if(!app.translationsLoading[app.currentLanguage]){
          app.fetchTranslation(app.currentLanguage);
        }
        return input;
      }
      var a = app.translations[app.currentLanguage];
      if(!a) return input;
      if(!a[input]) return input;
      var r = a[input];
      if(typeof(data) != "undefined") r = r.replace(/%[^% ]+%/,data);
      if(typeof(data2) != "undefined") r = r.replace(/%[^% ]+%/,data2);
      if(typeof(data3) != "undefined") r = r.replace(/%[^% ]+%/,data3);
      if(typeof(data4) != "undefined") r = r.replace(/%[^% ]+%/,data4);
      if(typeof(data5) != "undefined") r = r.replace(/%[^% ]+%/,data5);
      return r;
    };
    f.$stateful = true;
    return f;
  });

  app.filter("filterByIDList", function() {
    return function(elements, selection, param) {
      if(!selection || selection.length == 0) return elements; // no filter
      var items = [];
      for(var i=0; i < elements.length; i++) {
        if(param && typeof(param) == "string"){
          if(selection.indexOf(elements[i][param].ID) >= 0) items.push(elements[i]);
        }else{
          if(selection.indexOf(elements[i].ID) >= 0) items.push(elements[i]);
        }
      }
      return items;
    };
  });


  app.filter("filterClassContent", function($filter) {
    return function(elements, self, parent ) {
      // remove all items from list, without change permissions
      // 1007
      var items = [];
      for(var i=0; i < elements.length; i++){
        if(self.user.Teacher != '1' || (
            !self.userClassViewData[self.currentClass.ID] ||
            !self.userClassViewData[self.currentClass.ID].filterMainTopics || (
              self.userClassViewData[self.currentClass.ID].filterMainTopics && (
                self.userClassViewData[self.currentClass.ID].filterMainTopics.length == 0 ||
                self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(elements[i].ID) != -1
              )
            )
          )
        ) {
          items.push(elements[i]);
        }
      }
      return items;
    };
  });

  app.filter("filterSearchContent", function($filter) {
    return function(elements, type, self, parent ) {      
      // apply level or sticker filter 
      if(type == "task" && self.user.Teacher == 0){
        if(self.getUserLevelFilter(self.currentTopic) > 0){
          var items = [];
          for(var i=0; i < elements.length; i++){
            if(!elements[i].Level || elements[i].Level == '0'|| self.isUserLevelInFilter(self.currentTopic,elements[i].Level)) items.push(elements[i]);
          }
          elements = items; // override variable now
        }
        var sticker = self.getUserStickerFilter(parent);
        if(sticker){
          var items = [];
          for(var i=0; i < elements.length; i++){
            var s = self.getUserTaskStatus(elements[i],self.user,true);
            if(s.Note && s.Note != '' && s.Note.replace('¶','') == sticker) items.push(elements[i]);
          }
          elements = items; // override variable now
        }

      }

      if(!self.searchTerm || self.searchTerm == "") {
        // reset the list
        self.addedAfterLastSearchTermChange = {mainTopics:[], tasks:[], goals:[], topics:[]};
        return elements;
      }
      var escaped = self.searchTerm.replace(/[-[\]{}()*+?.,\\^$|#]/g, '\\$&');
      escaped = escaped.replace(/  /g," ");
      var parts = escaped.split(" ");
      var regexps = [];
      for(var i=0; i < parts.length; i++){
        if($.trim(parts[i]) === "") continue;
        regexps.push(new RegExp(parts[i],"i"));
      }
      if(regexps.length > 1)
        for(var i=0; i < regexps.length; i++){
          regexps[i] = new RegExp("\\b"+regexps[i].source+"\\b","i");
        }

      escaped = escaped.replace(/ /g,"|");

      var recursiveCall = function(items, type, regexps){
        for(var i=0; i < items.length; i++){
          if(self.addedAfterLastSearchTermChange[type] && 
             self.addedAfterLastSearchTermChange[type].indexOf(items[i].ID) != -1){
            return true;
          }
          var hasAll = true;
          for(var r=0; r < regexps.length; r++){
            var regexp = regexps[r];
            if(items[i].Name && items[i].Name.match(regexp)) continue;
            if(type != "tasks") if(items[i].Description && items[i].Description.match(regexp)) continue;
            hasAll = false;
            break;
          }
          if(hasAll) return true;
        }
        if(type == "topics"){
          for(var i=0; i < items.length; i++){
            var hasOne = recursiveCall(items[i].goals,"goals",regexps);
            if(hasOne) return true;
          }
        }
        if(type == "goals"){
          for(var i=0; i < items.length; i++){
            var hasOne = recursiveCall(items[i].tasks,"tasks",regexps);
            if(hasOne) return true;
          }
        }
        return false;
      }

      if(type == "goal" || type == "task") {
        hasAll = true;
        if(self.addedAfterLastSearchTermChange.mainTopics.indexOf(self.currentMainTopic.ID) != -1){
          return elements;
        }
        if(self.addedAfterLastSearchTermChange.topics.indexOf(self.currentTopic.ID) != -1){
          return elements;
        }

        for(var r=0; r < regexps.length; r++){
          var regexp = regexps[r];
          if(self.currentMainTopic.Name.match(regexp)){
            continue;
          }
          if(self.currentMainTopic.Description.match(regexp)){
            continue;
          }
          if(self.currentMainTopic.Tags.match(regexp)){
            continue;
          }
          if(self.currentTopic.Name.match(regexp)){
            continue;
          }
          if(self.currentTopic.Description.match(regexp)){
            continue;
          }
          hasAll = false;
          break;
        }
        if(hasAll)
        return elements; // disable for second page for now
      }
      if(type == "task" && parent) {
        // if goal is a match, display all
        if(self.addedAfterLastSearchTermChange.goals.indexOf(parent.ID) != -1){
          return elements;
        }
        hasAll = true;
        for(var r=0; r < regexps.length; r++){
          var regexp = regexps[r];
          if(parent.Name.match(regexp)){
            continue;
          }
          if(parent.Description.match(regexp)){
            continue;
          }
          hasAll = false;
          break;
        }
        if(hasAll)
        return elements; // disable for second page for now
      }

      var items = [];
      var hasParentMatch = false;
      if(type == "topic" && parent){
        if(self.addedAfterLastSearchTermChange.mainTopics.indexOf(parent.ID) != -1){
          hasParentMatch = true;
        }else{
          var hasAll = true;
          for(var r=0; r < regexps.length; r++){
            var regexp = regexps[r];
            if(parent.Name.match(regexp)){
              continue;
            }
            if(parent.Description.match(regexp)){
              continue;
            }
            if(parent.Tags.match(regexp)){
              continue;
            }
            hasAll = false;
            break;
          }
          hasParentMatch = hasAll;          
        }
      }

      for(var i=0; i < elements.length; i++){
        if(self.addedAfterLastSearchTermChange[type+"s"] && 
           self.addedAfterLastSearchTermChange[type+"s"].indexOf(elements[i].ID) != -1){
          items.push(elements[i]);
          continue;
        }
        hasAll = true;
        for(var r=0; r < regexps.length; r++){
          var regexp = regexps[r];
          if(elements[i].Name.match(regexp)){
            continue;
          }
          if(elements[i].Tags && elements[i].Tags != '' && elements[i].Tags.match(regexp)){
            continue;
          }
          if(type != "task" && elements[i].Description.match(regexp)){
            continue;
          }
          hasAll = false;
          break;
        }
        if(!hasAll && type == "mainTopic"){
          hasAll = recursiveCall(elements[i].topics,'topics',regexps);
        }
        if(!hasAll && type == "topic"){
          hasAll = hasParentMatch || recursiveCall(elements[i].goals,'goals',regexps);
        }
        if(!hasAll && type == "goal"){
          hasAll = recursiveCall(elements[i].tasks,'tasks',regexps);
        }
        if(hasAll) items.push(elements[i]);

      }
      return items;
    };
  });

  app.filter("journalFilter", function() {
    return function(elements, classid, filterdate, filtertype, filtertypesub,
                    filterplace,filtermaintopics, filteritem, filtercustomdate,
                    filtercustomhour, filtercustomminute, filterlasttime,
                    filtersearchterm) {

      var items = [];
      var regexp = null;
      if(filtertype == 'searchterm' && filtersearchterm && filtersearchterm != ""){
        regexp = new RegExp(filtersearchterm.replace(/[-[\]{}()*+?.,\\^$|#\s]/g, '\\$&'),"i");
      }

      for(var i=0; i < elements.length; i++) {
        // skip entries not from this class
        if(classid && elements[i].Class && (classid != elements[i].Class)) continue;

        // filter by type
        var typeOK = filtertype == 'all' || filtertype == 'searchterm';
        typeOK = typeOK || (filtertype == 'foldersonly' && (elements[i].Type == 'folderadded'  || elements[i].Type == 'folderremoved' ||
           elements[i].Type == 'folderitemadded' || elements[i].Type == 'folderitemchanged' || elements[i].Type == 'folderitemremoved'));
        typeOK = typeOK || (filtertype == 'tasksonly' && (elements[i].Type == 'taskdone'  || elements[i].Type == 'teachertaskdone' || elements[i].Type == 'taskhintaccess'));
        typeOK = typeOK || (filtertype == 'goalsonly' && (elements[i].Type == 'goaldone'  || elements[i].Type == 'goalteacherdone'));
        typeOK = typeOK || (filtertype == 'peersonly' && (elements[i].Type == 'taskpeerfeedbacksend' || elements[i].Type == 'taskpeerfeedbackget' || elements[i].Type == 'taskcollectionfeedbacksend' || elements[i].Type == 'taskcollectionfeedbackget'));
        if(!typeOK && (filtertype == 'textsonly' &&
            (elements[i].Type == 'userentry' ||
             elements[i].Type == 'teacherentry' ||
             elements[i].Type == 'teachertaskentry' ||
             elements[i].Type == 'teachergoalentry'))){
          if(filtertypesub && filtertypesub != ""){
            typeOK = typeOK || (filtertypesub == "own" && elements[i].Type == 'userentry');
            typeOK = typeOK || (filtertypesub == "other" && elements[i].Type != 'userentry');
          }else{
            typeOK = true;
          }
        }
        // filter by content source
        var placeOK = (filterplace == 'all');
        if(typeOK){
          if(filterplace == 'maintopics' && filtermaintopics && filtermaintopics.length > 0){
            placeOK = false;
            placeOK = (elements[i].Type == 'userentry' ||
                       elements[i].Type == 'teacherentry' ||
                       elements[i].Type == 'teachertaskentry' ||
                       elements[i].Type == 'teachergoalentry') ||
                     (elements[i].DataJSON &&
                      elements[i].DataJSON.MainTopic &&
                      filtermaintopics.indexOf(elements[i].DataJSON.MainTopic.ID) >= 0);
          }
          if(filterplace == 'task' && filteritem){
            placeOK = false;
            placeOK = elements[i].DataJSON &&
                      elements[i].DataJSON.taskid == filteritem.ID;
          }
          if(filterplace == 'goal' && filteritem){
            placeOK = false;
            placeOK = elements[i].DataJSON &&
                      elements[i].DataJSON.goalid == filteritem.ID ||
                     (elements[i].DataJSON &&
                      elements[i].DataJSON.LearningGoal &&
                      elements[i].DataJSON.LearningGoal.ID == filteritem.ID);
          }
          if(filterplace == 'topic' && filteritem){
            placeOK = false;
            placeOK = elements[i].DataJSON &&
                      elements[i].DataJSON.Topic &&
                      elements[i].DataJSON.Topic.ID == filteritem.ID;
          }
        }
        var searchOK = true;
        if(typeOK && placeOK && filtertype == 'searchterm' && filtersearchterm && filtersearchterm != ""){
          searchOK = false;
          if(!searchOK && elements[i].Data.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.Task &&
              elements[i].DataJSON.Task.Name.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.Task &&
              elements[i].DataJSON.Task.Description.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.Topic &&
              elements[i].DataJSON.Topic.Name.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.Topic &&
              elements[i].DataJSON.Topic.Description.match(regexp)){
            searchOK = true;
          }

          if(!searchOK && elements[i].DataJSON.LearningGoal &&
              elements[i].DataJSON.LearningGoal.Name.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.LearningGoal &&
              elements[i].DataJSON.LearningGoal.Description.match(regexp)){
            searchOK = true;
          }

          if(!searchOK && elements[i].DataJSON.MainTopic &&
              elements[i].DataJSON.MainTopic.Name.match(regexp)){
            searchOK = true;
          }
          if(!searchOK && elements[i].DataJSON.MainTopic &&
              elements[i].DataJSON.MainTopic.Description.match(regexp)){
            searchOK = true;
          }

        }
        if(typeOK && placeOK && searchOK) {
          items.push(elements[i]);
        }
      }

      // filter by time
      var result = [];
      var now = null;
      var day = (24*60*60*1000); //1 day

      if(filterdate == 'ever'){
        for (var i=0; i<items.length; i++)
          result.push(items[i]);
      }else
      if(filterdate == 'new'){
        for (var i=0; i<items.length; i++){
          var c = new Date().fromMysqlFormat(items[i].Created);
          if (c > filterlasttime) result.push(items[i]);
        }
      }else
      if(filterdate == 'today'){
        now = new Date();
        now.setHours(0, 0, 0, 0);
        for (var i=0; i<items.length; i++){
          var c = new Date(new Date().fromMysqlFormat(items[i].Created));
          c.setHours(0, 0, 0, 0);
          if (c.getTime() == now.getTime()) result.push(items[i]);
        }
      }else
      if(filterdate == 'todayfrom'){
        now = new Date();
        now.setHours(filtercustomhour, filtercustomminute, 0, 0);
        for (var i=0; i<items.length; i++){
          var c = new Date().fromMysqlFormat(items[i].Created);
          if (c.getTime() >= now.getTime()) result.push(items[i]);
        }
      }else
      if(filterdate == 'yesterday'){
        now = new Date();
        now.setHours(0, 0, 0, 0);
        now.setTime(now.getTime() - day);
        for (var i=0; i<items.length; i++){
          var c = new Date(new Date().fromMysqlFormat(items[i].Created));
          c.setHours(0, 0, 0, 0);
          if (c.getTime() == now.getTime()) result.push(items[i]);
        }
      }else
      if(filterdate == 'thisweek'){
        now = new Date();
        now.setHours(0, 0, 0, 0);
        var wday = now.getDay();
        var first = now.getDate() - wday + (wday == 0 ? -6:1);
        now.setDate(first);
        for (var i=0; i<items.length; i++){
          var c = new Date(new Date().fromMysqlFormat(items[i].Created));
          c.setHours(0, 0, 0, 0);
          if (c >= now) result.push(items[i]);
        }
      }else
      if(filterdate == 'lastweek'){
        now = new Date();
        now.setHours(0, 0, 0, 0);
        var wday = now.getDay();
        var first = now.getDate() - wday + (wday == 0 ? -6:1);
        now.setDate(first);
        var now2 = new Date(now);
        now2.setTime(now.getTime() - 7*day);

        for (var i=0; i<items.length; i++){
          var c = new Date(new Date().fromMysqlFormat(items[i].Created));
          c.setHours(0, 0, 0, 0);
          if (c >= now2 && c < now) result.push(items[i]);
        }
      }else
      if(filterdate == 'customdate'){
        for (var i=0; i<items.length; i++){
          var c = new Date().fromMysqlFormat(items[i].Created);
          if (c >= filtercustomdate) result.push(items[i]);
        }
      }else
      if(filterdate == 'last5'){
        for (var i=0; i<items.length && i < 5; i++){
          result.push(items[i]);
        }
      }



      var c = 0;
      var cn = 0;
      for (var i=0; i < result.length; i++) {
        if(result[i].Type == 'userentry' ||
           result[i].Type == 'teacherentry' ||
           result[i].Type == 'teachertaskentry' ||
           result[i].Type == 'teachergoalentry') {
          c++;

          var d1 = new Date().fromMysqlFormat(result[i].Created);
          if(d1 > filterlasttime) cn++;
        }
      }

      result.userEntryCount = c; // add property to array
      result.newUserEntryCount = cn;

      return result;
    };
  });

  app.factory("$exceptionHandler",  function() {
    return function (exception, cause) {
     console.log(exception);
    };
  });

  app.controller('MainController',
  function ( $scope, $route, $injector, $compile, $templateCache, $location, $mdDialog, $mdMenu, $mdSelect, $mdPanel,$mdToast, $filter, $mdUtil, $window,
             $mdMedia, $http, $mdSidenav, $mdBottomSheet, $timeout, $interval, $sce, $log, $q, $animate) {
    //
//$animate.enabled(false);
    var storedLang =  null;
    try{
      storedLang = localStorage.getItem("displayLanguage");
    }catch(e){}

    //if(storedLang) app.setLanguage(storedLang); else
    app.setLanguage("DE");

    $scope.$location = $location;

    var self = this;
    mc = self;
    self.debugLog = window.__lvDebugLogStore || [];
    self.app = app;
    self.sha1 = function(s){ return sha1(s); };

    self.isWindowsDevice = window.isWindowsDevice;

    self.getNumberArray = function(n){
      return new Array(n);
    };

    self.filterByID = function(id){
      return function(item) {
        return item.ID !== id; // Exclude the specific ID
      };      
    }

    self.appZoom = 1.0;
    try{
      var zoomStored = localStorage.getItem("appZoom");
      if(zoomStored) self.appZoom = parseFloat(zoomStored);
    }catch(e){}

    self.changeAppZoom = function(value){
      self.appZoom = value;
      try{
        localStorage.setItem("appZoom",self.appZoom);        
      }catch(e){}

      // for mobile screens
      var scale = self.appZoom;
      if(window.isIOSDevice || window.isAndroidDevice){
        var viewport = document.querySelector("meta[name=viewport]");
        if (!viewport) {
          viewport = document.createElement("meta");
          viewport.name = "viewport";
          document.head.appendChild(viewport);
        }
        if(window.isIOSDevice){
          viewport.setAttribute('content', 'user-scalable=no, width=device-width, height=device-height, viewport-fit=cover, initial-scale='+scale);
        }

        if(window.isAndroidDevice){
          viewport.setAttribute('content', 'user-scalable=no, width=device-width, height=device-height, initial-scale='+scale);
        }
      }
    };

    if(self.appZoom != 1.0) self.changeAppZoom(self.appZoom);

    var reportError = function(e,m,lineNumber){
      console.log(m,e,lineNumber);
    };

    window.addEventListener("error", function (message, url, lineNumber, error) {
      if((error instanceof Error) || (error instanceof ErrorEvent)){
        reportError(error,message,lineNumber);
        return;
      }
      if((message instanceof Error) || (message instanceof ErrorEvent)){
        reportError(message,error,lineNumber);
        return;
      }
      reportError(error ? error : message, message ? message : error,lineNumber);
    });

    window.addEventListener('unhandledrejection', function(event) {
        console.log('unhandledrejection '+event.reason);
        reportError(event.reason,event);
    });

    self.initLoadingDone = true;
    self.currentClassResultStudentFilter = [];
/*
    self.currentClassStudentClasses = [];
// deprecated of performance
            <div style="background:white;margin-top:-56px;" ng-if="self.currentClassStudentClasses.length > 0">
              <md-input-container style="margin-top:5p;padding-bottom: 5px;">
                <label>{{'CLASSFILTERSTUDENTS' | trans}}</label>
                <md-select ng-model="self.currentClassResultStudentFilter" ng-change="self.runUpMainClassProgressList()">
                  <md-option value="0">{{'SHOWALL' | trans}}</md-option>
                  <md-option ng-repeat="sc in self.currentClassStudentClasses" value="{{sc.ID}}">
                  {{sc.Name}}
                  </md-option>
                </md-select>
              </md-input-container>
            </div>
*/
    self.searchTerm = "";

    self.addedAfterLastSearchTermChange = {mainTopics:[], tasks:[], goals:[], topics:[]};

    self.classCorrectionMode = 'tasks';

    self.selectedClassCorrectionFilter = 'all';

    self.selectedClassActivityTime = "new";
    self.selectedClassActivityTimeDate = moment().subtract(10, 'days').startOf('day').toDate(); // format('l');

    self.selectedClassActivityTimeDateLabel = moment(new Date(self.selectedClassActivityTimeDate)).startOf('day').format("DD.MM.YYYY");
    self.selectedClassActivityTimeHour = 0;
    self.selectedClassActivityTimeMinute = 0;
    self.selectedClassActivityTimeHourLabel = "00:00";

    self.selectedClassActivityType = "all";
    self.selectedClassActivityTypeSub = "";
    self.selectedClassActivityItem = null;
    self.selectedClassActivityPlace = "all";
    self.selectedClassActivitySearchterm = "";


    self.setClassActivityTimeDate = function(){
      if(!self.selectedClassActivityTimeDate) self.selectedClassActivityTimeDate = new Date();
      self.selectedClassActivityTimeDate = moment(new Date(self.selectedClassActivityTimeDate)).startOf('day').toDate();

      self.selectedClassActivityTimeDateLabel = moment(new Date(self.selectedClassActivityTimeDate)).startOf('day').format("DD.MM.YYYY");
      self.setLocalStorage("selectedClassActivityTimeDate",self.selectedClassActivityTimeDate);

      self.selectedClassActivityTimeHourLabel =
        (self.selectedClassActivityTimeHour < 10 ? '0' :'')+self.selectedClassActivityTimeHour+':'+
        (self.selectedClassActivityTimeMinute < 10 ? '0' :'')+self.selectedClassActivityTimeMinute;

      self.setLocalStorage("selectedClassActivityTimeHour",self.selectedClassActivityTimeHour);
      self.setLocalStorage("selectedClassActivityTimeMinute",self.selectedClassActivityTimeMinute);
    };

    self.currentTeacherNavigation = "Classes";

    self.theme = $scope.theme;
    self.user = null; // loged in user
    self.isCordova = typeof(cordova) != "undefined";
    self.isMobile = (window.isIOSDevice || window.isAndroidDevice);

    self.lastPushNotification = "";
    self.newsCounter = 0;
    self.userViewData = {};

    self.showClassTaskTable = false;
    self.journalDisplayLimit = 10;
    self.classStudents = []; // list of all other students in class for student view
    self.classList = [];
    self.classcodeinput = "";
    self.orderClassesBy = "";
    //////////////////////////////////////////////////////////////////////////////////////////
    self.isNumber = function(v){
      return /^\d+$/.test(v);
    };
    self.roundNumber = function(v,up){
      if(up) return Math.ceil(v);
      return Math.round(v);
    };

    //////////////////////////////////////////////////////////////////////////////////////////
    self.isMenuOpen = function(){
      var openMenus = $(".md-open-menu-container.md-active");
      if(openMenus.length > 0) return true;
      var dialogs = $("md-dialog.md-transition-in");
      if(dialogs.length > 0) return true;
      return false;
    };

    self.limitPanelToViewport = function(p){
      var first = 10;
      var reposition = function(){
        // limit viewport constrains
        $("body").scrollTop(0);
        var ww = window.innerWidth;
        var hh = window.innerHeight;
        var ew = p.outerWidth();
        var eh = p.outerHeight();
        var pos  = p.offset();
        var adjusted = false;
        if(pos.left+ew > ww) {adjusted = true; pos.left = ww-ew; }
        if(pos.top+eh > hh)  {adjusted = true; pos.top = hh-eh-16;}
        if(pos.left < 0) {adjusted = true; pos.left = 0;}
        if(pos.top < 0)  {adjusted = true; pos.top = 0;}
        if (adjusted) {
          p.offset(pos);
        }
        if(adjusted || first > 0){
          if(first > 0) first--;
          setTimeout(reposition,10);
        }
      };

      $timeout(function(){ reposition(); },10);
    };
    //////////////////////////////////////////////////////////////////////////////////////////
    // Android back button pressed
    //////////////////////////////////////////////////////////////////////////////////////////
    self.backButtonPushed = function(){
      var openMenus = $(".md-open-menu-container.md-active");
      if(openMenus.length > 0){
        $timeout(function(){
          $mdMenu.cancel();
        },0);
        return false;
      }
      if(self.progressMainTopic){
        $timeout(function(){
          self.progressMainTopic = null;
          self.progressTopic = null;
          self.runUpMainClassProgressList();
        },0);
        return false;
      }
      var dialogs = $("md-dialog.md-transition-in");
      if(dialogs.length > 0){
        $timeout(function(){
          self.closeDialog(null);
        },0);
        return;
      }
      if(self.backToClass){
        self.backToClassClicked(null);
        return;
      }
      if(self.currentMainTopic){
        self.resetMainTopic();
        return;
      }
      return false;
    };

    self.secureBuffer = {};
    self.taskDescriptionClosed = {};
    self.getLocalStorage = function(p){
      try{
        var r = localStorage.getItem(p);
        if(r) return r;
      }catch(e){}
      if(self.secureBuffer[p]) return self.secureBuffer[p];
      return null;
    };
    self.getSessionStorage = function(p){
      try{
        var r = sessionStorage.getItem(p);
        if(r) return r;
      }catch(e){}
      return null;
    };
    self.setSessionStorage = function(p,v){
      try{
        if(v === null){
          sessionStorage.removeItem(p);
        }else{
          sessionStorage.setItem(p,v);
        }
      }catch(e){}
    };
    

    self.setLocalStorage = function(p,v){
      self.secureBuffer[p] = v;
      try{
        if(v === null){
          localStorage.removeItem(p);
          self.secureBuffer[p] = null;
        }else{
          localStorage.setItem(p,v);
        }
      }catch(e){}
    };
    self.hasTaskDescriptionContent = function(task){
      return !!(task && ((task.Description && task.Description != '') || (task.DataJSON && task.DataJSON.hints && task.DataJSON.hints.length > 0)));
    };
    self.wasTaskDescriptionClosed = function(task){
      return !!(task && task.ID && self.taskDescriptionClosed && self.taskDescriptionClosed[task.ID]);
    };
    self.setTaskDescriptionClosed = function(task, closed){
      if(!task || !task.ID) return;
      if(!self.taskDescriptionClosed) self.taskDescriptionClosed = {};
      if(closed){
        self.taskDescriptionClosed[task.ID] = true;
      }else{
        delete(self.taskDescriptionClosed[task.ID]);
      }
    };
    self.getTaskDescriptionWidth = function(task, maxWidthQuery, preventAutoOpen){
      var width = {now:self.hasTaskDescriptionContent(task) ? 1 : 0,last:2};
      // pre open on large screen unless the user closed this task manually before
      if(width.now == 1 && !self.wasTaskDescriptionClosed(task) && !preventAutoOpen && !$mdMedia(maxWidthQuery)){
        width.now = 2;
        width.last = 1;
      }
      return width;
    };
    self.toggleTaskDescriptionWidth = function(taskDescriptionWidth, task){
      if(!taskDescriptionWidth) return;
      taskDescriptionWidth.now = taskDescriptionWidth.now <= 1 ? 2 : 1;
      self.setTaskDescriptionClosed(task, taskDescriptionWidth.now <= 1);
      taskDescriptionWidth.now == 2 ? self.track('openTaskDescriptionSidePanel',task) : self.track('closeTaskDescriptionSidePanel',task);
    };

    self.removeLocalStorage = function(p){
      try{
        $.each(localStorage, function(key, value){
          if(key.indexOf(p) === 0){
            self.secureBuffer[key] = null;
            try{
              localStorage.removeItem(key);
            }catch(e){}
          }
        });
      }catch(e){}
    };

    self.userFontHEXPStyle = null;
    self.getUserFontHEXP = function(){
      var value = 0;
      if(self.userViewData && self.userViewData["HEXP"] !== null && self.userViewData["HEXP"] !== undefined && self.userViewData["HEXP"] !== ""){
        value = parseInt(self.userViewData["HEXP"],10);
      }
      if([0,10,20,30].indexOf(value) === -1) value = 0;
      return value;
    };
    self.applyUserFontHEXP = function(){
      var value = self.getUserFontHEXP();
      if(!self.userFontHEXPStyle){
        self.userFontHEXPStyle = document.createElement('style');
        self.userFontHEXPStyle.id = "lv-user-font-hexp";
        document.head.append(self.userFontHEXPStyle);
      }
      self.userFontHEXPStyle.textContent = "* { font-variation-settings: 'HEXP' "+value+"; }";
      return value;
    };
    self.setUserFontHEXP = function(value, skipSave){
      if(!self.userViewData) self.userViewData = {};
      var normalized = parseInt(value,10);
      if([0,10,20,30].indexOf(normalized) === -1) normalized = 0;
      self.userViewData["HEXP"] = normalized;
      self.applyUserFontHEXP();
      if(!skipSave) self.updateUserViewData();
    };

    // Sync view state settings to server and devices
    self.updateUserViewData = function(callback){
      try{
        /*
        var itemsToStore = {};
        $.each(localStorage, function(key, value){
          if((key.indexOf("U"+self.user.ID+"_time_") === 0) ||
             (key.indexOf("U"+self.user.ID+"_muteChat_") === 0) ||
             (key.indexOf("U"+self.user.ID+"_ringChat") === 0) ||
             (key.indexOf("mtc_") === 0) ||
             (key.indexOf("latestNews") === 0)){
            itemsToStore[key] = value;
          }
        });
        */
        self.apiPost("ajax",{"action":"setUserViewData", "noerror":1, "data":JSON.stringify(self.userViewData)})
         .then(function(data) {
           if(callback) callback();
         });
      }catch(e){}
    };
    self.loadUserViewData = function(data){
      if(!self.userViewData) self.userViewData = {};
      $.each(data, function(key, value){
        var old = self.userViewData[key];
        self.userViewData[key] = value;
        if(old != value && key.indexOf("plugins_") != -1){
          for(var i=0; i < self.plugins.plugins.length; i++){
            if(key == "plugins_"+self.plugins.plugins[i].name){
              if(self.plugins.plugins[i].dataChanged){
                self.plugins.plugins[i].dataChanged("user", value, old);
              }
            }
          }
        }
        //self.setLocalStorage(key,value);
      });
      self.chatRoomRingSound = self.userViewData["U"+self.user.ID+"_ringChat"] == 1;
      self.mirrorCameraX = self.userViewData["vmx"] == 1 ? 1 : 0;
      self.mirrorCameraY = self.userViewData["vmy"] == 1 ? 1 : 0;
      self.applyUserFontHEXP();
    };

    self.knownSurveys = ["Survey26"];
    self.surveyLastPromptDay = null;
    self.surveyDialogOpen = false;
    self.surveySubmitting = false;
    self.currentSurveyName = null;
    self.currentSurveyDialog = null;

    self.parseSurveyDate = function(value){
      if(!value) return null;
      var m = moment(value);
      if(!m.isValid()) {
        try{
          m = moment(new Date().fromMysqlFormat(value));
        }catch(e){}
      }
      return m && m.isValid() ? m : null;
    };

    self.isSurveyAnswered = function(name){
      if(!self.userViewData || !name) return false;
      return self.userViewData[name] == 1 || self.userViewData[String(name).toUpperCase()] == 1;
    };

    self.markSurveyAnswered = function(name){
      if(!self.userViewData) self.userViewData = {};
      self.userViewData[name] = 1;
      self.userViewData[String(name).toUpperCase()] = 1;
    };

    self.isSurveyEligible = function(name){
      if(!self.user || String(self.user.Teacher) != "1") return false;
      if(!self.initLoadingDone) return false;
      if(!self.user.Created || !self.user.lastActivity) return false;
      if(self.isSurveyAnswered(name)) return false;

      var created = self.parseSurveyDate(self.user.Created);
      var lastActivity = self.parseSurveyDate(self.user.lastActivity);
      if(!created || !lastActivity) return false;

      var now = moment();
      if(created.isAfter(moment(now).subtract(1, "year"))) return false;
      if(lastActivity.isBefore(moment(now).subtract(7, "days"))) return false;

      return true;
    };

    self.getNextOpenSurvey = function(){
      for(var i=0; i < self.knownSurveys.length; i++){
        if(self.isSurveyEligible(self.knownSurveys[i])) return self.knownSurveys[i];
      }
      return null;
    };

    self.showSurveyDialog = function(name){
      if(self.surveyDialogOpen || self.surveySubmitting) return;
      if(!self.isSurveyEligible(name)) return;

      self.surveyDialogOpen = true;
      self.surveyLastPromptDay = moment().format("YYYY-MM-DD");
      self.currentSurveyName = name;

      self.currentSurveyDialog = self.showDialog({
        template:
          '<md-dialog dialog-draggable style="width:610px;height:88vh;max-width:96vw;max-height:96vh;overflow:hidden" class="maxSize">' +
          '  <md-toolbar layout="row" layout-align="space-between center" style="flex-shrink:0">' +
          '    <span style="margin:8px 16px"><i class="fa fa-fw fa-question-circle-o" style="font-size: 120%;"></i></span>' +
          '    <md-button class="md-icon-button" aria-label="Schliessen" ng-click="closeSurvey()"><i class="fa fa-fw fa-times"></i></md-button>' +
          '  </md-toolbar>' +
          '  <md-content style="height:100%;overflow:hidden;padding:0;background:#eef5f7">' +
          '    <iframe title="LearningView Umfrage" src="' + "https://learningview.org/surveys/" + encodeURIComponent(name) + ".html" + '" style="display:block;width:100%;height:100%;border:0;background:white"></iframe>' +
          '  </md-content>' +
          '</md-dialog>',
        clickOutsideToClose: false,
        escapeToClose: true,
        skipHide: true,
        onRemoving: function(){
          self.surveyDialogOpen = false;
          self.currentSurveyDialog = null;
          self.currentSurveyName = null;
        },
        controller: function($scope){
          $scope.closeSurvey = function(){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.checkSurveys = function(force){
      if(self.surveyDialogOpen) return;
      if(!force && self.surveyLastPromptDay == moment().format("YYYY-MM-DD")) return;
      var surveyName = self.getNextOpenSurvey();
      if(surveyName) self.showSurveyDialog(surveyName);
    };

    window.addEventListener("message", function(e){
      if(!e || !e.data || (e.data.type != "teacher-impact-survey-submit" && e.data.type != "survey-submit")) return;
      if(e.origin && e.origin != "https://learningview.org") return;
      if(self.surveySubmitting) return;

      $timeout(function(){
        var payload = e.data.payload ? e.data.payload : {};
        var surveyName = e.data.name || e.data.survey || payload.survey || self.currentSurveyName;
        if(self.surveySubmitting || self.isSurveyAnswered(surveyName)) return;
        self.surveySubmitting = true;
        var surveySource = e.source;
        var surveyOrigin = e.origin || "https://learningview.org";
        var dataJSONString = "";
        try{
          dataJSONString = JSON.stringify(payload);
        }catch(err){
          dataJSONString = "{}";
        }

        self.apiPost("ajax",{"action":"saveSurvey", "name":surveyName, "data":dataJSONString}).then(function(){
          self.markSurveyAnswered(surveyName);
          self.updateUserViewData();
          self.surveySubmitting = false;
          self.alert("Deine Angaben wurden gespeichert. Vielen Dank für deine Unterstützung!");
          if(self.surveyDialogOpen && self.currentSurveyDialog) self.closeDialog(self.currentSurveyDialog.container);
        },function(){
          self.surveySubmitting = false;
          self.surveyLastPromptDay = null;
        });
      },0);
    });

    self.updateUserClassViewData = function(classid){
      if(!self.userClassViewData) self.userClassViewData = [];
      if(!self.userClassViewData[classid]) self.userClassViewData[classid] = {};
      self.apiPost("ajax",{"action":"setUserClassViewData","noerror":1, "classid":classid, "data":JSON.stringify(self.userClassViewData[classid])})
       .then(function(data) {
       });
    };

    self.loadUserClassViewData = function(classid, data){
      if(!self.userClassViewData) self.userClassViewData = [];
      if(!self.userClassViewData[classid]) self.userClassViewData[classid] = {};
      $.each(data, function(key, value){
        var old = self.userClassViewData[classid][key];
        self.userClassViewData[classid][key] = value;
        if(old != value && key.indexOf("plugins_") != -1){
          for(var i=0; i < self.plugins.plugins.length; i++){
            if(key == "plugins_"+self.plugins.plugins[i].name){
              if(self.plugins.plugins[i].dataChanged){
                self.plugins.plugins[i].dataChanged("userclass", value, old);
              }
            }
          }
        }
      });

      // update global filter settings on change
      if(self.currentClass && classid == self.currentClass.ID){
        if(self.userClassViewData[classid] &&
           self.userClassViewData[classid].filterMainTopics &&
           self.userClassViewData[classid].filterMainTopics.length > 0){
          self.selectedClassActivityPlace = "maintopics";
          self.currentClassResultMainTopicFilter = self.userClassViewData[classid].filterMainTopics;
        }

        // refresh user timers here comming from userClassViewData
        if(self.userClassViewData[classid] && self.userClassViewData[classid]["userTimers"]){
          for(var i=0; i < self.userClassViewData[classid]["userTimers"].length; i++){
            var found = null;
            for(var z=0; z < self.tabButtons[classid].length; z++){
              if(self.tabButtons[classid][z].timer == self.userClassViewData[classid]["userTimers"][i].ID){
                found = self.tabButtons[classid][z];
                break;
              }
            }
            if(!found){
              var t = self.userClassViewData[classid]["userTimers"][i];
              var btn = self.setupTimerButton(t,classid);
            }
          }
        }
      }
    };

    self.searchMatch = function(a){
      if(!self.searchTerm || self.searchTerm == "") return false;
      var escaped = self.searchTerm.replace(/[-[\]{}()*+?.,\\^$|#]/g, '\\$&');
      escaped = escaped.replace(/  /g," ");
      var parts = escaped.split(" ");
      var regexps = [];
      for(var i=0; i < parts.length; i++){
        if($.trim(parts[i]) === "") continue;
        regexps.push(new RegExp(parts[i],"i"));
      }

      escaped = escaped.replace(/ /g,"|");
      for(var i=0; i < a.length; i++){
        var matchAll = true;
        for(var r=0; r < regexps.length; r++){
          var regexp = regexps[r];
          if(!a[i].match(regexp)){
            matchAll = false; break;
          }
        }
        if(matchAll){
          return true;
        }
      }
      return false;
    };


    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showPanel = function(config){
      var previousFocus = document.activeElement;
      if(config.onRemoving){
        config._onRemoving = config.onRemoving;
      }
      if(config.onDomAdded){
        config._onDomAdded = config.onDomAdded;
      }
   
      // focus trap for tabs
      var keydownHandler = function(e) {
        if (e.key !== 'Tab') return;
        var focusable = config.menuContent.querySelectorAll('button, [tabindex]:not([tabindex="-1"])');

        var first = focusable[0];
        var last = focusable[focusable.length - 1];

        if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        } else if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        }
      };

      config.onRemoving = function(){
        if(config._onRemoving) config._onRemoving();
        if (previousFocus) {
          if(previousFocus.offsetParent) previousFocus.focus();
          previousFocus = null;
        }        
        if(config.menuContent){
          config.menuContent.removeEventListener('keydown', keydownHandler);
          config.menuContent = null;
        }
      };

      config.onDomAdded = function(el){
        if(config._onDomAdded) config._onDomAdded(el);
        config.menuContent = null;
        if(el[1] && el[1]._panelEl){
          config.menuContent = el[1]._panelEl[0];
          config.menuContent.addEventListener('keydown', keydownHandler);          
        }
      };
    
      return $mdPanel.open(config);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Dialog-System open/close with a dialog stack
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.dialogStack = [];

    self.hasDialogOpen = function(templateUrl){
      for(var i = self.dialogStack.length-1; i >= 0; i--){
        if(self.dialogStack[i].options.templateUrl == templateUrl){
          return true;
        }
      }               
      return false;           
    }
    self.showDialog = function(options){
      var d = {promise:null, container:null, options:options};
      options.unlockScreenReader = function(){}; // angular material bugfix

      if(options.state){
        if(!options.state || options.state == "modal"){
          // normal case
        }
        if(options.state == "one"){
          // it is not modal, but only a single window of this type can exist
          for(var i = self.dialogStack.length-1; i >= 0; i--){
            if(self.dialogStack[i].options.templateUrl == options.templateUrl){
              self.closeDialog(self.dialogStack[i].container,true);
            }
          }                    
          options.clickOutsideToClose = false; // can stay open
          options.disableParentScroll = false;
          options.escapeToClose = false;
          options.hasBackdrop = false;
          options.skipHide = true;          
        }
        if(options.state == "multi"){
          // multiple instances of those windows can exist, 
          // make sure no global variables are set from there
          // should not bind file drop handlers
          options.clickOutsideToClose = false; // can stay open
          options.disableParentScroll = false;
          options.escapeToClose = false;
          options.hasBackdrop = false;
          options.skipHide = true;          
        }
        if(options.state == "top"){
          // top most position z-index 101
        }
        if(options.state == "modalTop"){
          // top most position z-index 101
          // add focus-trap under this window so nothing else can be clicked until closed
          var bd = $('<div style="position: fixed;top: 0;bottom: 0;left: 0;right: 0;transition: opacity 450ms;position: fixed;z-index:79;background-color: rgba(33,33,33,0.48);" aria-hidden="true"></div>');
          $('body').append(bd);          
          options.modalTopBackdrop = bd;
        }
        if(options.dismiss){
          // we need to close other windows of this template type
          for(var i = self.dialogStack.length-1; i >= 0; i--){
            if(self.dialogStack[i].options.templateUrl == options.dismiss){
              self.closeDialog(self.dialogStack[i].container,true);
            }
          }                              
        }
      }
      if(options.onShowing) options._onShowing = options.onShowing;
      if(options.onRemoving) options._onRemoving = options.onRemoving;

      var previousFocus = document.activeElement;
      if(previousFocus && previousFocus.nodeName == "BODY"){
        // try from targetEvent
        if(options.targetEvent && options.targetEvent.currentTarget){
          previousFocus = options.targetEvent.currentTarget;
        }
      }
      var lastTrigger = null;
      if(options.targetEvent && options.targetEvent.currentTarget){
        if (options.targetEvent.currentTarget.getAttribute("role") === "menuitem") {
          var menu = $(options.targetEvent.currentTarget).parents('.md-open-menu-container').get(0);
          if(menu){
            var menuId = menu.getAttribute('id');
            lastTrigger = document.querySelector('[aria-owns="'+menuId+'"]');
          }
        }
      }     

      options.onRemoving = function(element){
        if(options.state == "modalTop" && options.modalTopBackdrop){
          options.modalTopBackdrop.remove();
          options.modalTopBackdrop = null;
        }
        if(options.state == "one" || options.state == "multi") {
          // if last of this
          var last = true;
          for(var i = self.dialogStack.length-1; i >= 0; i--){
            var d = self.dialogStack[i];
            if(d.container == element) continue; // self
            if(d.options.state == "one" || d.options.state == "multi"){
              last = false;
            }
          }
          if(last)
            $('body').removeClass("preventClickOutside");
        }
        if(options._onRemoving) options._onRemoving(element);
        self.closeDialog(element,true);
        if (previousFocus) {
          if(previousFocus.offsetParent) previousFocus.focus();
          previousFocus = null;
        }
        if(lastTrigger){
          if(lastTrigger.offsetParent) lastTrigger.focus();
          lastTrigger = null;         
        }
      };

      options.onShowing = function($scope, element, options, controller){
        d.container = element;        
        d.$scope = $scope;
        $scope.dialogElement = element;
        var bringToFront = function(){
          for(var i = self.dialogStack.length-1; i >= 0; i--){
            var d = self.dialogStack[i];
            if(d.container == element) continue; // self
            $(d.container).css("z-index",79); // send to back
          }
          if(!options.stayBack){
            if(options.state == "top")
              // top most position z-index 101
              $(element).css("z-index",101); // forground
            else
              $(element).css("z-index",80); // forground
          }
        };

        if(options.state == "one" || options.state == "multi") {
          $('body').addClass("preventClickOutside");
        }
        self.dialogOppening = true;
        $(element).on("click",function(){
          if(!self.dialogOppening) bringToFront();
        });
        bringToFront(); // now 
        setTimeout(function(){ self.dialogOppening = false;},500);
        if(options._onShowing) options._onShowing($scope, element, options, controller);

        // tab trap to go back to last element before md-dialog reached
        var lastTabElement = null;
        element.on('keydown',function (e) {
          if (e.key !== 'Tab') return;
          if (!e.shiftKey && document.activeElement) {
            var thisLast = document.activeElement;
            setTimeout(function(){
              if(document.activeElement && document.activeElement.nodeName == "MD-DIALOG"){
                lastTabElement = thisLast;
              }
            },0);
          } else if (e.shiftKey && document.activeElement) {
            if(document.activeElement.nodeName == "MD-DIALOG"){
              if(lastTabElement) {
                lastTabElement.focus();
                e.preventDefault();
              }
            }
          }
        });
      };

      d.promise = $mdDialog.show(options);
      self.dialogStack.push(d);
      return d;
    };

    self.closeDialog = function(element,fromRemoving){
      // without element, take top most element
      if(!element && self.dialogStack.length > 0){
        element = self.dialogStack[self.dialogStack.length-1].container;
      }

      for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
        if(self.dropHandler[i].dialog == element) {
          self.dropHandler.splice(i, 1);
        }
      }

      for(var i = self.dialogStack.length-1; i >= 0; i--){
        if(self.dialogStack[i].container == element){
          // hide from returned value
          var d = self.dialogStack[i];

          self.dialogStack.splice(i,1);
          try{
            if(!fromRemoving && (d.options.state != "one" && d.options.state != "multi") && d.promise) $mdDialog.hide(d.promise); else {
              if(d.options.state == "modalTop" && d.options.modalTopBackdrop){
                d.options.modalTopBackdrop.remove();
                d.options.modalTopBackdrop = null;
              }
              $mdDialog.destroy(d.container.children(0));
            }
            if(d.$scope) d.$scope.$destroy();
          }catch(e){}
          // will call onRemoving
          element = null;
          d.container = null;
          d.promise = null;
          d.$scope = null;
          return;
        }
      }
      // not found
      if(element){
        try{
          $mdDialog.destroy(element.children(0));
        }catch(e){}
      }
    };

    self.showJournalFilterPanel = function(scope,ev, isStudentMenu){
      //

      var position = $mdPanel.newPanelPosition()
                      .absolute().relativeTo(ev.currentTarget)
                      .addPanelPosition('align-start', 'below')
                      .addPanelPosition('align-start', 'center')
                      .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.SCALE);

      var config = {
        attachTo: angular.element(document.body),
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        templateUrl: "journalFilterMenuPanel.html",
        controller: function ($scope, $mdPanel, mdPanelRef) {
          $scope.self = self;
          $scope.filterSettings = scope.filterSettings; // use parent scope settings

          $scope.isStudentMenu = isStudentMenu;
          $scope.isClassMenu = scope.isClassMenu;

          $scope.maintopic = scope.maintopic;
          $scope.task = scope.task ? scope.task :
          ($scope.filterSettings && $scope.filterSettings.WHEREITEM &&
           $scope.filterSettings.WHERE == 'task' ? $scope.filterSettings.WHEREITEM : null);
          $scope.goal = scope.goal ? scope.goal :
          ($scope.filterSettings && $scope.filterSettings.WHEREITEM &&
           $scope.filterSettings.WHERE == 'goal' ? $scope.filterSettings.WHEREITEM : null);
          $scope.topic = scope.topic ? scope.topic :
          ($scope.filterSettings && $scope.filterSettings.WHEREITEM &&
           $scope.filterSettings.WHERE == 'topic' ? $scope.filterSettings.WHEREITEM : null);

          $scope.close = function(){ mdPanelRef.close(); };
        },
        position: position,
        animation: panelAnimation,
        openFrom: ev,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true,
        zIndex: 200
      };

      self.showPanel(config);
    };

    //1002
    self.showContentFilterPanel = function(scope,ev, type){
      //
      var position = $mdPanel.newPanelPosition()
                      .absolute().relativeTo(ev.target)
                      .addPanelPosition('align-start', 'below')
                      .addPanelPosition('align-start', 'center')
                      .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.SCALE);

      var config = {
        attachTo: angular.element(document.body),
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        templateUrl: "contentFilterMenuPanel.html",
        controller: function ($scope, $mdPanel, mdPanelRef) {
          $scope.self = self;
          // use parent scope filterSettings
          // all changes will be made to filterSettings only,
          // parent scope will handle saving back to global settings

          $scope.filterSettings = scope ? scope.filterSettings : {};

          $scope.close = function(){ mdPanelRef.close(); };
          $scope.type = type;
          if(scope != null) {
            $scope.isStudentMenu = scope.isStudentMenu;
            $scope.task = scope.task ? scope.task : (self.selectedClassActivityItem && self.selectedClassActivityPlace == 'task' ? self.selectedClassActivityItem : null);
            $scope.goal = scope.goal ? scope.goal : (self.selectedClassActivityItem && self.selectedClassActivityPlace == 'goal' ? self.selectedClassActivityItem : null);
            $scope.topic = scope.topic ? scope.topic : (self.selectedClassActivityItem && self.selectedClassActivityPlace == 'topic' ? self.selectedClassActivityItem : null);
          }
        },
        position: position,
        animation: panelAnimation,
        openFrom: ev,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true,
        zIndex: 200
      };

      self.showPanel(config);
    };

    //filterSettings: WHERE, WHEN, WHAT ... , inclass (Leave empty for global settings)
    self.getStudentFilteredJournal = function(s,filterSettings,inclass){
      if(!self.users[s.ID]) return;

      var classid = inclass ? inclass : (self.currentClass ? self.currentClass.ID : 0);

      // always map journal items to tasks and topics for correct filtering
      if(!self.users[s.ID].hasMappedJournalItems){
        for(var i=0; i < self.users[s.ID].journal.length; i++)
          self.mapJournalItem(self.users[s.ID].journal[i]);
        self.users[s.ID].hasMappedJournalItems = true;
      }

      var lastTime = self.getLastOpenTime("lastjournal",classid+'-'+s.ID);

      return $filter('journalFilter')(self.users[s.ID].journal,classid,
        filterSettings && filterSettings.WHEN ? filterSettings.WHEN : 'ever',
        filterSettings && filterSettings.WHAT ? filterSettings.WHAT : 'all',
        filterSettings && filterSettings.WHATSUB ? filterSettings.WHATSUB : null,
        filterSettings && filterSettings.WHERE ? filterSettings.WHERE : 'all',
        filterSettings && filterSettings.WHERETOPICS ? filterSettings.WHERETOPICS : null,
        filterSettings && filterSettings.WHEREITEM ? filterSettings.WHEREITEM : null,
        filterSettings && filterSettings.WHENDATE ? filterSettings.WHENDATE : null,
        filterSettings && filterSettings.WHENHOUR ? filterSettings.WHENHOUR : null,
        filterSettings && filterSettings.WHENMINUTE ? filterSettings.WHENMINUTE : null,
        lastTime,
        filterSettings && filterSettings.WHATSEARCH ? filterSettings.WHATSEARCH : null);
    };

    self.isEditable = function(){
      return self.user && self.user.Teacher == '1' && self.currentClass == null;
    };

    self.currentMainTopicLimit = 0;
    self.currentLearningGoalLimit = 0;

    self.runUpMainTopicList = function(){
        self.currentMainTopicLimit = 0;
        // start run up
        var r = function(){
          var list = self.currentClass ? self.classContent[self.currentClass.ID] : self.userContent;

          if(self.currentMainTopicLimit < list.mainTopics.length)
            self.currentMainTopicLimit = self.currentMainTopicLimit + 1;
          else {
            $(window).trigger('resize')
            self.currentMainTopicLimit = 999999; // very high value for any later add data to array
            return;
          }
          $timeout(r,1);
        }
        $timeout(r,1);
      return true;
    };

    self.runUpLearningGoalList = function(){
        self.currentLearningGoalLimit = 0;
        // start run up
        var r = function(){
          if(!self.currentTopic) return;
          if(self.currentLearningGoalLimit < self.currentTopic.goals.length)
            self.currentLearningGoalLimit = self.currentLearningGoalLimit + 1;
          else {
            $(window).trigger('resize')
            self.currentLearningGoalLimit = 999999; // very high value for any later add data to array
            return;
          }
          $timeout(r,1);
        }
        $timeout(r,1);
      return true;
    };


    self.currentClassMainProgressListLimit = 0;
    self.currentClassStudentProgressListLimit = 0;

    self.runUpMainClassProgressList = function(){
      if(!self.currentClass) return;
      self.currentClassMainProgressListLimit = 3;
      self.currentClassStudentProgressListLimit = 1;
      // start run up
      var r = function(){
        if(!self.currentClass) return;
        if(self.currentClassStudentProgressListLimit < self.currentClass.students.length ||
           self.currentClassMainProgressListLimit < self.classContent[self.currentClass.ID].mainTopics.length) {
          if(self.currentClassStudentProgressListLimit < self.currentClass.students.length){
            self.currentClassStudentProgressListLimit = self.currentClassStudentProgressListLimit + 1;
          }else
            self.currentClassMainProgressListLimit = self.currentClassMainProgressListLimit + 1;

        } else {
          self.currentClassMainProgressListLimit = 999999; // very high value for any later add data to array
          self.currentClassStudentProgressListLimit = 99999;
          return;
        }
        $timeout(r,10);
      }
      $timeout(r,10);
      return true;
    };

    self.currentClassProgressListLimit = 0;

    self.runUpClassProgressList = function(topic){
      if(!self.currentClass || !topic) return;
      self.currentClassProgressListLimit = 2;
      self.currentClassStudentProgressListLimit = 1;
      // start run up
      var r = function(){
        if(!self.currentClass) return;
        if(self.currentClassStudentProgressListLimit < self.currentClass.students.length ||
           self.currentClassProgressListLimit < topic.goals.length) {

          if(self.currentClassStudentProgressListLimit < self.currentClass.students.length){
            self.currentClassStudentProgressListLimit = self.currentClassStudentProgressListLimit + 1;
          }else
            self.currentClassProgressListLimit = self.currentClassProgressListLimit + 1;

        } else {
          self.currentClassProgressListLimit = 999999; // very high value for any later add data to array
          self.currentClassStudentProgressListLimit = 99999;
          return;
        }
        $timeout(r,10);
      }
      $timeout(r,10);
      return true;
    };

    self.runUpClassCalendarProgressList = function(){
      if(!self.currentClass) return;
      self.currentClassStudentProgressListLimit = 1;
      // start run up
      var r = function(){
        if(!self.currentClass) return;
        if(self.currentClassStudentProgressListLimit < self.currentClass.students.length) {
          self.currentClassStudentProgressListLimit = self.currentClassStudentProgressListLimit + 1;  
        } else {
          self.currentClassStudentProgressListLimit = 99999;
          return;
        }
        $timeout(r,10);
      }
      $timeout(r,10);
      return true;
    };
    

    self.currentCorrectionListLimit = 10;
    self.getObjectKeyCount = function(o){
      if(!o) return 0;
      return Object.keys(o).length;
