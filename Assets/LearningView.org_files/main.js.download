    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showStudentFrame = function(ev){
      var postMessage = function(e){
        if(e.data == "LearningView|LOADED"){
          console.log("Loaded student frame");
          var frame = document.getElementById("studentFrame");
          if(frame){
            frame.contentWindow.postMessage("LOGIN|STUDENTVIEW|"+self.user.Salt+"|"+self.user.ID+"|"+self.currentClass.ID,"*");
          }
        }
      };
      $mdDialog.hide();
      self.showDialog({
        templateUrl: "studentiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          window.removeEventListener("message",postMessage);
        },

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          window.addEventListener("message",postMessage);
          $scope.url = ("https://stud.learningview.org/app");
          $scope.self = self;
          $scope.zoom = 1;
          $scope.isHorizontal = $(window).width() > $(window).height();
          $scope.turnScreen = function(){
            $scope.isHorizontal = !$scope.isHorizontal;
            $timeout(function(){
              $scope.setZoom (1);
            },100)            
          };
          $scope.setZoom = function(v){
            $scope.zoom = v;
            $('#studentFrame').css({width:(100/v)+"%",height:(100/v)+"%",'zoom':v,
              "-ms-transform-origin":"0 0",
              "-moz-transform-origin":"0 0",
              "-webkit-transform-origin":"0 0",
              "transform-origin":"0 0",
              "-ms-transform":"scale("+v+")",
              "-moz-transform":"scale("+v+")",
              "-webkit-transform":"scale("+v+")",
              "transform":"scale("+v+")"
            });
          };
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };          
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countWatchers = function () {
      var root = $(document.getElementsByTagName('body'));
      var watchers = [];

      var f = function (element) {
        if (element.data().hasOwnProperty('$scope')) {
            angular.forEach(element.data().$scope.$$watchers, function (watcher) {
                watchers.push(watcher);
            });
        }

        angular.forEach(element.children(), function (childElement) {
            f($(childElement));
        });
      };

      f(root);

      console.log(watchers.length);
    };

    // what happens on resume on mobile devices
    document.addEventListener("resume", function(event){
      console.log("resumed");
      // add a fake element to body and remove it again so we refresh the DOM to prevent iOS bug
      setTimeout(function(){
        $('html').get(0).scrollTop = 0;
        self.track('resume',null);
      },100);

      if(window.FCM && window.FCM.clearAllNotifications){
        FCM.clearAllNotifications();
      }
      if(window.onResumeEvent) window.onResumeEvent(event);
    }, false);


    var scrollEventTimeout = null;
    var lastScrollTop = 0;
    self.scrollEventTimeouts = {};
    self.scrollEventLast = {}
    self.trackScroll = function(source, ev){
      var now = $(ev.target).get(0).scrollTop;
      if(self.scrollEventTimeouts[source]) clearTimeout(self.scrollEventTimeouts[source]);
      self.scrollEventTimeouts[source] = setTimeout(function(){
        self.track(source+"_scrolled",{now:now, before:self.scrollEventLast[source] ? self.scrollEventLast[source] : 0});
        self.scrollEventLast[source] = now;
      },100);
    }

    self.resetAliveInterval = function(){
      if(self.aliveInterval) clearInterval(self.aliveInterval);
      self.aliveInterval = setInterval(function(){
        self.track('alive',null);
      },10000)
    };

    window.addEventListener("focus", function(event) {
      if(self.focusWasOnIframe){
        self.focusWasOnIframe = false;
        return;
      }
      var now = new Date().getTime();
      // sometimes fires twice so wait for millisecs here
      if(self.lastFocusEvent && now - self.lastFocusEvent > 10){
        self.track('focus',null);
      }

      self.lastFocusEvent = now;
      self.resetAliveInterval();
    });
    window.addEventListener("blur", function(event) { 
      self.focusWasOnIframe = false;
      if(document.activeElement){
        if(document.activeElement.tagName == 'IFRAME') {
          self.focusWasOnIframe = true;
          return; // skip iframes
        }
      }
      var now = new Date().getTime();
      // sometimes fires twice so wait for millisecs here
      if(self.lastLeaveEvent && now - self.lastLeaveEvent > 10)
        self.track('leave',null);

      self.lastLeaveEvent = now;
      if(self.aliveInterval) clearInterval(self.aliveInterval);
    });
    self.resetAliveInterval();

    if(window.parent != window){
      window.parent.postMessage("LearningView|LOADED","*");
      window.addEventListener("message",function(e){
        if(e.data && e.data.split){
          var parts = e.data.split("|");
          if(parts[0].toUpperCase() == "LOGIN"){
            self.QRCodeLogin(parts.slice(1).join("|"));
          }
        }
      });
    }

    // log 
    window.addEventListener("message",function(e){
      if(e.data && e.data.log){
        self.track(e.data.log,e.data.data);
      }
    });

    if(self.getSessionStorage("shareLinkUsed")){
      var content = JSON.parse(self.getSessionStorage("shareLinkUsed"));
      self.shareSignupData = content;
    }

    if(self.getSessionStorage("inviteLinkUsed")){
      var content = JSON.parse(self.getSessionStorage("inviteLinkUsed"));

      if(content.type == "school"){
        self.schoolSignup = content;
        self.schoolSignupData = null;
        self.apiPost("ajax",{"action":"getSchoolData", "id":content.id, "code":content.code})
         .then(function(data) {
           self.schoolSignupData = data;
         },function(){
           self.schoolSignup = false;   
           self.schoolSignupData = null;        
         });
      }
      if(content.type == "student"){
        self.studentSignup = content;
        self.studentSignupData = null;
        self.apiPost("ajax",{"action":"getClassData", "id":content.id, "code":content.code})
         .then(function(data) {
           self.studentSignupData = data;
         },function(){
           self.studentSignup = false;     
           self.studentSignupData = null;      
         });
      }
      if(content.type == "teacher"){
        self.teacherSignup = content;
        self.teacherSignupData = null;
        self.apiPost("ajax",{"action":"getClassData", "id":content.id, "code":content.code})
         .then(function(data) {
           self.teacherSignupData = data;
         },function(){
           self.teacherSignup = false;     
           self.teacherSignupData = null;      
         });
      }
      if(content.type == "mainTopic"){
        self.inviteMainTopicSignupData = content;
      }
    }

    self.relogin(); // auto login now

  });

})();

