    // not used
    self.showStudentClassList = function(ev){
      self.showDialog({
        templateUrl: "studentClassList.html",
        targetEvent: ev,
        skipHide:false, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;

          $scope.ok = function(){
            self.closeDialog($scope.dialogElement);
          };

          $scope.removeFromClass = function(c){
            self.confirm($filter('trans')('REMOVEMEFROMCLASS',c.Name),$filter('trans')('DELETE'),ev).then(function(){
              self.apiPost("ajax",{"action":"removeMeFromClass", "classid":c.ID})
                .then(function(data) {
                  // change active class
                  for(var i=0; i < self.classList.length; i++){
                    if(self.classList[i].ID == c.ID){
                      self.classList.splice(i,1);
                      break;
                    }
                  }
                  if(self.classList.length > 0){
                    self.openClass(self.classList[0],ev);
                  }
                  self.keepAliveCallback();
                  self.closeDialog($scope.dialogElement);
                });
            });
          };
        }
      });
    };
