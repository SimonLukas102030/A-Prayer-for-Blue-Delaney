  app.dialogPositions = {};
  app.directive('dialogDraggable', ['$document', function($document) {
    return {
      restrict: 'A',
      link: function(scope, elm, attrs) {
        var startX, startY,startW,startH, initialMouseX, initialMouseY;
        var parentDialog = null;
        var dragTarget = null;
        var moving = false;

        var resizing = false;
        var mouseArea = null;
        var corner = null;

        // manual resize system, or use css resize:both
        if(attrs.resizeable){
          corner = $('<div class="corner"></div>');
          $(elm).append(corner);
          //$(elm).css({'resize':'both'});
        }
        if(attrs.restoreposition){
          if(app.dialogPositions[attrs.restoreposition]){
            // recover position
            $(elm).css("position","absolute");
            $(elm).css("transition","none");
            elm.css(app.dialogPositions[attrs.restoreposition]);
            setTimeout(function(){
              elm.css(app.dialogPositions[attrs.restoreposition]);
            },500);
          }
        }

        var touchHandler = function(event) {
            var touch = event.originalEvent.changedTouches[0];

            var simulatedEvent = document.createEvent("MouseEvent");
                simulatedEvent.initMouseEvent({
                touchstart: "mousedown",
                touchmove: "mousemove",
                touchend: "mouseup"
            }[event.type], true, true, window, 1,
                touch.screenX, touch.screenY,
                touch.clientX, touch.clientY, false,
                false, false, false, 0, null);

            $(touch.target).get(0).dispatchEvent(simulatedEvent);
            //event.preventDefault();
        };

        elm.bind("touchstart", touchHandler);
        elm.bind("touchmove", touchHandler);
        elm.bind("touchend", touchHandler);
        elm.bind("touchcancel", touchHandler);

        var lastMouseDown = {};

        elm.bind('mousedown', function($event) {
          var $target = $($event.target);
          initialMouseX = $event.clientX;
          initialMouseY = $event.clientY;
          var moveOrResize = 'move';

          if($target.hasClass("corner")){
              moveOrResize = 'resize';
          }else
          if(!$target.is("md-toolbar") &&
              $target.parents("md-toolbar").length == 0)  return;

          if($target.is("button") || $target.parents("button").length > 0) return;

          parentDialog = $($target.parents("md-dialog").get(0));
          dragTarget = parentDialog && parentDialog.length > 0 ? parentDialog : $(elm);
          $(elm).css("position","absolute");
          $(elm).css("transition","none");
          if(moveOrResize == "move"){
            var leftCss = parseFloat($(elm).css('left'));
            var topCss = parseFloat($(elm).css('top'));
            if(isNaN(leftCss)) leftCss = elm.prop('offsetLeft');
            if(isNaN(topCss)) topCss = elm.prop('offsetTop');
            startX = leftCss;
            startY = topCss;
            $document.bind('mousemove', mousemove);
            $document.bind('mouseup', mouseup);
          }else{
            startW = elm.width();
            startH = elm.height();
            if(!initWidthHeight) initWidthHeight = {w:startW, h:startH};
            $document.bind('mousemove', resizemousemove);
            $document.bind('mouseup', resizemouseup);
            mouseArea = $('<div class="cornerMouseArea"></div>');
            $("body").append(mouseArea);
          }
          return false;
        });
        
        var initWidthHeight = null;

        function mousemove($event) {
          var dx = $event.clientX - initialMouseX;
          var dy = $event.clientY - initialMouseY;
          var px = startX + dx;
          var py = startY + dy;

          var containerW = $('.bodywrapper').width();
          var containerH = $('.bodywrapper').height();
          if(!containerW || containerW <= 0) containerW = $(window).width();
          if(!containerH || containerH <= 0) containerH = $(window).height();

          var targetW = dragTarget ? dragTarget.width() : elm.width();
          var targetH = dragTarget ? dragTarget.height() : elm.height();

          if(px < 3*-targetW/4) px = 3*-targetW/4;
          if(py < 0) py = 0;
          if(py > containerH-targetH/2) py = containerH-targetH/2;
          if(px > containerW-targetW/4) px = containerW-targetW/4;
          elm.css({left: px + 'px',top: py + 'px'});
          if(attrs.dragstylemodel){
            var styleModel = scope.$eval(attrs.dragstylemodel);
            if(styleModel){
              styleModel.left = px + 'px';
              styleModel.top = py + 'px';
            }
          }

          if(attrs.restoreposition){
            if(!app.dialogPositions[attrs.restoreposition]) app.dialogPositions[attrs.restoreposition] = {};
            app.dialogPositions[attrs.restoreposition].left = px+'px';
            app.dialogPositions[attrs.restoreposition].top = py+'px';              
          }

          moving = true;
          return false;
        }

        function mouseup(event) {
          parentDialog = null;
          dragTarget = null;
          $(elm).css("transition","");
          $document.unbind('mousemove', mousemove);
          $document.unbind('mousesup', mouseup);
          if(!moving) return;
          moving = false;
          event.stopPropagation();
          event.preventDefault();
        }


        function resizemousemove($event) {
          var dx = $event.clientX - initialMouseX;
          var dy = $event.clientY - initialMouseY;
          var d = 1;
          if(elm.get(0).style.left == "") d = 2; // hack for initial case without moving
          var pw = startW + dx*d;
          var ph = startH + dy*d;
          if(pw < startW && pw < 200) pw = 200;
          if(ph < startH && ph < 200) ph = 200;
          if(attrs.resizeable == "min"){
            if(pw < initWidthHeight.w) pw = initWidthHeight.w;
            if(ph < initWidthHeight.h) ph = initWidthHeight.h;
          }
          if(pw > $('.bodywrapper').width()) pw = $('.bodywrapper').width();
          if(ph > $('.bodywrapper').height()) ph = $('.bodywrapper').height();
          elm.css({width: pw + 'px',height: ph + 'px'});
          if(attrs.restoreposition){
            if(!app.dialogPositions[attrs.restoreposition]) app.dialogPositions[attrs.restoreposition] = {};
            app.dialogPositions[attrs.restoreposition].width = pw+'px';
            app.dialogPositions[attrs.restoreposition].height = ph+'px';              
          }
          resizing = true;
          return false;
        }

        function resizemouseup(event) {
          parentDialog = null;
          dragTarget = null;
          $(elm).css("transition","");
          $document.unbind('mousemove', resizemousemove);
          $document.unbind('mousesup', resizemouseup);
          if(mouseArea) mouseArea.remove();
          mouseArea = null;
          if(!resizing) return;
          resizing = false;
          event.stopPropagation();
          event.preventDefault();
        }
      }
    };
  }]);

  app.directive('shadow', function() {
    return {
      scope: {
        target: '=shadow',
        observe: '=observe'
      },
      link: function(scope, el, att) {
        scope.$parent[att.shadowname] = angular.copy(scope.target);
        scope.$parent[att.observe];
        scope.$watch('observe', function(newValue, oldValue) {
          if (newValue || newValue === '' || newValue === false)
            scope.$parent[att.shadowname] = angular.copy(scope.target);
        });
        scope.$watch('target', function(newValue, oldValue) {
          if (el[0].contains(document.activeElement)) return; // skip if focus is here right now
          if ((newValue || newValue === '' || newValue === false) && 
              scope.$parent[att.shadowname] != newValue)
            scope.$parent[att.shadowname] = angular.copy(newValue);
        });
      }
    };
  });

  app.annotatedImageOverlayList = [];
  app.refreshAnnotationOverlaysTimer = null;

  app.refreshAnnotationOverlays = function(url){
    var refresh = function(){
      for(var i = 0; i < app.annotatedImageOverlayList.length; i++){
        if(app.annotatedImageOverlayList[i].url == url){
          app.annotatedImageOverlayList[i].refresh();
        }
      }
      app.refreshAnnotationOverlaysTimer = null;
    };
    if(!app.refreshAnnotationOverlaysTimer)
        app.refreshAnnotationOverlaysTimer = setTimeout(refresh,10);
  };
  app.directive('annotatedImageOverlay', ['$parse', function($parse) {
    return {
      restrict: 'A',
      link: function (scope, element, attrs) {

        $(element).css({'position':'relative'});
        var urlComp = $parse(attrs['annotatedImageOverlay']);
        var url = urlComp(scope);
        var user = $parse(attrs['annotatedUser']); 
        var folderItem = null;
        var task = null;

        if(attrs['annotatedFolderItem']){
          var folderItemScope = $parse(attrs['annotatedFolderItem']); 
          folderItem = folderItemScope(scope);
        }
        if(attrs['annotatedTask']){
          var taskScope = $parse(attrs['annotatedTask']); 
          task = taskScope(scope);
        }

        var uid = user(scope);
        if(uid == 0) return;
        var overlay = $('<img style=\'position:absolute;z-index: 2;pointer-events:none;left:0;top:0;max-height:100%;max-width:100%\' class=\'image overlay\'/>');
        $(element).append(overlay);
        var me = {};
        me.url = url;
        me.refresh = function(){
          var p = {"action":"getImageAnnotationOverlay", "user":uid,"noerror":1, url:url,'noindicator':true};
          if(folderItem) p.folderItem = folderItem;
          if(task) p.task = task;
          scope.self.apiPost("ajax",p)
           .then(function(result) {
            overlay.attr("src",result.data); // base64 image
           },function(){
            // no image, remove the src now
            overlay.attr("src",null);
           });
        };
        me.refresh();
        app.annotatedImageOverlayList.push(me);
        element.on('$destroy', function() {
          var p = app.annotatedImageOverlayList.indexOf(me);
          app.annotatedImageOverlayList.splice(p,1);
        });
        // how to dedect refresh of annotation data?
      }
    };
  }]);


  app.directive('tagList', ['$parse','$timeout', function($parse,$timeout) {
    return {
      restrict: 'A',
      transclude: true,
      scope: {
        tagList: '=ngModel',
      },
      link: function (scope, element, attrs) {
        function escapeHtml(unsafe) {
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
        }
        var placeholder = "";
        if(attrs.placeholder){
          placeholder = '<span style="color:#666"><i class="fa fa-fw fa-tags"></i> '+attrs.placeholder+'</span>';
        }
        var updateNow = function(){
          var tags = scope.tagList && scope.tagList.Tags ? scope.tagList.Tags : null;
          var list = tags && tags != '' ? tags.split("|") : [];
          $(element).html(list.length > 0 ? "" : placeholder);
          if(list.length > 0) {
            var s = "";
            var onClick = function(t,tag){
              t.on("click",function(){                
                scope.$parent.tagListClicked = tag[0];
                scope.$parent.tagListItemClicked = {text:tag[0], color:tag[1]};
              })
            };
            for(var i=0; i < list.length; i++){
              var tag = list[i].split("☐");
              if(isNaN(tag[1])) continue; // skip
              var col = mc.tagColors[tag[1]];
              var t = $('<span class="tag" style="background:'+(col)+'">'+escapeHtml(tag[0])+'</span>');
              onClick(t,tag);
              $(element).append(t);
            }
          }
          $("span",element).on("click",function(event){
            if(attrs.tagClick){
              $timeout(function(){  
                scope.$parent.$eval(attrs.tagClick);                
              },0);            
              event.stopPropagation();
            }
          });
        };
        scope.$watch('tagList', updateNow,true);
        updateNow();
      }
    }
  }]);

  app.directive('resultTableTaskButton', function () {
      return function (scope, element, attrs) {
        $(element).attr("data-tooltip",scope.a.Name);

        scope.userStatus = scope.self.getUserTaskStatus(scope.a,scope.s,true);

        var visibility = true;
        var btn = $('<div style="position:relative;background-color:'+ scope.a.Color+'" class="btn inactiveChilds '+(visibility ? '' : ' invisible')+'"></div>');
        btn.on("click",function($event){
          // somehow add parent correctly to $event for loading animation
          if(scope.self.currentClassToggleImportantMode){
            if(scope.a.Important != 1)
              scope.self.setClassUserTaskImportant(scope.s,scope.a,scope.userStatus.Important == '1' ? '0':'1');
          }else
          if(scope.self.currentClassToggleCheckMode){
            if(scope.userStatus.FeedbackStatus != "OK"){
              scope.self.saveTeacherTaskStatusFindTask(scope.a,scope.s,{Status:'OK'});
            }else{
              scope.self.saveTeacherTaskStatusFindTask(scope.a,scope.s,{Status:(scope.userStatus.Answer && scope.userStatus.Answer != '' ? '?':'w')});
            }
          }else
          if(scope.self.currentClassToggleRejectMode){
            if(scope.userStatus.FeedbackStatus != "x"){
              scope.self.saveTeacherTaskStatusFindTask(scope.a,scope.s,{Status:'x'});
            }else{
              scope.self.saveTeacherTaskStatusFindTask(scope.a,scope.s,{Status:(scope.userStatus.Answer && scope.userStatus.Answer != '' ? '?':'w')});
            }
          }else          
          if(scope.self.currentClassToggleCloseMode){
            scope.self.saveTeacherTaskFeedbackStatusFindTask(scope.a,scope.s,{FeedbackStatus:scope.userStatus.FeedbackStatus != 'c' ? 'c':(scope.userStatus.Status == 'x' ? 'x' : '')});
          }else
          if(scope.self.currentClassToggleVisibilityMode){
            scope.self.toggleUserTaskVisibility(scope.s,scope.a,scope.self.currentClass);
          }else
          if(scope.self.currentClassToggleNoteMode){
            scope.self.toggleUserTaskNote(scope.s,scope.a,scope.self.currentClass);
          }else          
          if(scope.self.currentClassToggleResetMode){
            if(scope.userStatus.Status && scope.userStatus.Status != ""){
              scope.self.saveTeacherTaskStatusFindTask(scope.a,scope.s,{Status:'',skipAsk:true});
            }
          }else
            scope.self.resulttaskClicked(scope.a,scope.s,$event,scope);
        });


        var icon = $('<i class="resulttablebuttonicon '+(scope.self.customIcon(scope.a.MainIcon))+'"></i>');
        btn.append(icon);

        var statusicon = $('<span></span>');
        btn.append(statusicon);

        var noteicon = $('<div class="resultButtonNote"><i class="fa fa-sticky-note"></i></div>');
        btn.append(noteicon);
        noteicon.hide();

        var note = $('<div class="taskButtonNote onResultBtn"></div>');
        btn.append(note);
        note.hide();

        var userimportanticon = null;
        userimportanticon = $('<div class="resultButtonImportant'+(scope.a.Important == '1' ? ' red':'')+'"><i class="fa fa-thumb-tack"></i></div>');
        btn.append(userimportanticon);

        if(scope.a.Level){
          var levelicon = $('<div class="resulttaskLevel">'+scope.self.getLevelForResultButton(scope.a.Level)+'</div>');
          btn.append(levelicon);
        }

        var feedbackicon = $('<div class="resultButtonJournal"><span class="largeHint" style="z-index:1002"><i class="fa fa-commenting"></i></span></div>');
        btn.append(feedbackicon);

        if(scope.self.countTaskFeedbacks(scope.userStatus) == 0)
          feedbackicon.hide();
   
        $(element).append(btn);

        var renderTaskNoteSafely = function(target, rawNote){
          var value = String(rawNote || "").replace('¶','').trim();
          target.empty();
          if(value === "") return;

          // Legacy icon notes are stored as "<i class=\"...\"></i>".
          // Allow this exact shape with a strict class whitelist.
          var iconMatch = value.match(/^<i\s+class=(?:"([^"]+)"|'([^']+)')\s*><\/i>$/i);
          if(iconMatch){
            var classAttr = (iconMatch[1] || iconMatch[2] || "").trim();
            if(classAttr !== ""){
              var icon = $('<i></i>');
              icon.attr("class", classAttr);
              target.append(icon);
              return;
            }
          }

          // Treat all non-icon notes as plain text.
          var lines = value.split(/\r?\n/);
          for(var lineIndex = 0; lineIndex < lines.length; lineIndex++){
            if(lineIndex > 0) target.append(document.createElement("br"));
            target.append(document.createTextNode(lines[lineIndex]));
          }
        };

        var updateNow = function(){
          if(scope.self.currentClassProgressRatingsMode){
            var icon = "";
            if(scope.userStatus.Rating && scope.userStatus.Rating != "0"){
              if(scope.userStatus.Rating == 1) icon += '<img class="resultTableRatingIcon" src="https://learningview.org/app/sun.svg">';
              if(scope.userStatus.Rating == 2) icon += '<img class="resultTableRatingIcon" src="https://learningview.org/app/clouds.svg">';
              if(scope.userStatus.Rating == 3) icon += '<img class="resultTableRatingIcon" src="https://learningview.org/app/thunder.svg">';
            }
            statusicon.html(icon);
          }else{
            statusicon.html(scope.self.getIconForStatusButton(scope.userStatus,scope.a));
          }

          var visibilityNow = scope.self.isUserTaskVisible(scope.a,scope.s,scope.self.currentClass);
          if(visibility != visibilityNow){
            if(visibilityNow == true) btn.removeClass("invisible"); else btn.addClass("invisible");
            visibility = visibilityNow;
          }

          if(scope.userStatus.Note && scope.userStatus.Note != ''){
            noteicon.show(); 
            if((scope.self.currentClassToggleNoteMode && !scope.isOverviewPanel) || 
               (scope.self.showUserClassOverviewNotes && scope.isOverviewPanel)){
              renderTaskNoteSafely(note, scope.userStatus.Note);
              note.show();              
            }else{
              note.hide();
            }
          }else{
            noteicon.hide();
            note.hide();
          }
          
          if(userimportanticon && scope.a.Important != '1'){
            if(scope.userStatus.Important && scope.userStatus.Important == '1')
              userimportanticon.show(); else userimportanticon.hide();
          }

          if(scope.self.countTaskFeedbacks(scope.userStatus) == 0){
            feedbackicon.hide(); 
          }else {
            feedbackicon.show();
            //addLastFeedbackHint();
          }

          if(scope.userStatus.taskVisibilityUpdate) scope.userStatus.taskVisibilityUpdate = false; // reset for next update
        };
        // taskVisibilityUpdate is only a trigger for changes here
        scope.$watchGroup(["userStatus.Status","userStatus.Checklist","userStatus.Answer",
                           "userStatus.taskVisibilityUpdate",
                           "userStatus.FeedbackStatus","userStatus.Note",
                           "userStatus.Important","self.users[s.ID].journal.length",
                           "self.currentClassProgressRatingsMode",
                           "self.currentClassToggleNoteMode",
                           "self.showUserClassOverviewNotes"],updateNow);
        updateNow();
      };
  });

  app.directive('resultTableGoalButton', function ($mdPanel, $filter) {
      return function (scope, element, attrs) {

        var rubricPanelRef = null;
        var rubricBtn = $('<button type="button" class="md-button" aria-label="rubrics" style="min-width:2em;margin:0;margin-left:4px;margin-right:4px;text-transform:none;text-align:left;padding-left:4px;display:none;"><i class="fa fa-fw fa-table" style="margin:0;color:grey"></i></button>');
        rubricBtn.attr("title", $filter('trans')('RUBRICS'));
        $(element).append(rubricBtn);

        var getGoalRubricsForButton = function(){
          if(!scope.g || !scope.self || !scope.self.getLearningGoalRubricsList) return [];
          var refs = scope.self.getLearningGoalRubricsList(scope.g);
          if(!refs || refs.length === 0) return [];
          var list = [];
          var seen = {};
          for(var i=0; i < refs.length; i++){
            var rubric = scope.self.getRubricByGUID(refs[i]);
            if(!rubric || !rubric.ID) continue;
            if(seen[rubric.ID]) continue;
            seen[rubric.ID] = true;
            list.push(rubric);
          }
          return list;
        };

        var openRubricsPanel = function(ev){
          var rubrics = getGoalRubricsForButton();
          if(!rubrics || rubrics.length === 0) return;

          if(rubricPanelRef){
            rubricPanelRef.close();
            rubricPanelRef = null;
          }

          // direkt öffnen wenn nur 1
          if(rubrics.length === 1){
            scope.self.showRubric(rubrics[0], scope.s, null, scope.g, null, ev);
            return;
          }

          var position = $mdPanel.newPanelPosition()
            .relativeTo(ev.currentTarget || ev.target)
            .addPanelPosition('align-start', 'below');

          $mdPanel.open({
            attachTo: angular.element(document.body),
            position: position,
            clickOutsideToClose: true,
            escapeToClose: true,
            focusOnOpen: false,
            openFrom: ev,
            template:
              '<div class="md-whiteframe-z2" style="background:white;min-width:220px;max-width:340px;padding:4px 0;">' +
              '  <div ng-repeat="r in rubrics track by r.ID">' +
              '    <md-button class="fullLeftText" style="padding-left:16px;padding-right:16px;height: 42px;text-overflow: ellipsis;min-width:2em;text-transform:none;margin:0;width:100%;text-align:left;" ng-click="openRubric(r,$event)">{{r.Name}}</md-button>' +
              '  </div>' +
              '</div>',
            locals: {
              rubrics: rubrics,
              student: scope.s,
              goal: scope.g
            },
            controller: function(mdPanelRef, $scope, rubrics, student, goal){
              $scope.rubrics = rubrics;
              $scope.openRubric = function(r, ev){
                mdPanelRef.close();
                scope.self.showRubric(r, student, null, goal, null, ev);
              };
            }
          }).then(function(panelRef){
            rubricPanelRef = panelRef;
          });
        };

        rubricBtn.on("click", function(ev){
          ev.preventDefault();
          ev.stopPropagation();
          scope.$applyAsync(function(){
            openRubricsPanel(ev);
          });
        });

        var statusicon = $('<span></span>');
        var hasSelfRating = scope.self.isClassSet('useSelfRatings');
        if(hasSelfRating){
          $(element).append(statusicon);
          // gray line in between
          $(element).append($('<div style="height:38px;width:1px;background:#ccc;display:inline-block;line-height:38px;vertical-align:top;flex-shrink: 0;"></div>'));          
        }

        var teacherstatusicon = $('<span style="width: 38px;"></span>');
        $(element).append(teacherstatusicon);

        var feedbackicon = $('<div class="resultButtonJournal" style="margin-right: -2px;"><i style="color:#aaa" class="fa fa-commenting"></i></div>');
        $(element).append(feedbackicon);

        var updateNow = function(){
          scope.userStatus = scope.self.getUserLearningGoalStatus(scope.g,scope.s,true);
          var statusColor = scope.userStatus.Status ? (scope.userStatus.Status == 'green' || scope.userStatus.Status == 'lightgreen' ? '#008000' : (scope.userStatus.Status == 'yellow' ? '#FFC107' : scope.userStatus.Status == 'red' ? '#FF5722':'')) : '';

          statusicon.css('color',statusColor);
          if(statusColor == '')
            statusicon.html('<i class="fa fa-fw"></i>');
          if(statusColor == '#008000')
            statusicon.html('<i class="fa fa-fw fa-thumbs-o-up"></i>');
          if(statusColor == '#FFC107')
            statusicon.html('<i class="fa fa-fw fa-thumbs-o-up fa-rotate-270"></i>');
          if(statusColor == '#FF5722')
            statusicon.html('<i class="fa fa-fw fa-thumbs-o-down fa-flip-horizontal"></i>');

          var teacherstatusColor = scope.userStatus.Teacher ? (scope.userStatus.Teacher == 'green' ? '#008000' : (scope.userStatus.Teacher == 'lightgreen' ? '#a5d6a7' : (scope.userStatus.Teacher == 'yellow' ? '#FFC107' : scope.userStatus.Teacher == 'red' ? '#FF5722':''))) : '';

          if(teacherstatusColor == '')
            teacherstatusicon.html('<i class="fa fa-fw"></i>');
          if(scope.userStatus.Teacher && scope.userStatus.Teacher != '')
            teacherstatusicon.html('<i class="fa fa-fw"><i class="certificateBadge '+scope.userStatus.Teacher+'" style="font-size: 0.3em;margin: 0;"></i></i>');

          var note = (scope.userStatus.Note && scope.userStatus.Note != '' ? '\n\n'+scope.userStatus.Note : '') + 
                     (scope.userStatus.TeacherNote && scope.userStatus.TeacherNote != '' ? '\n\n'+scope.userStatus.TeacherNote : '');

          $(element).attr("data-tooltip",scope.g.Name + note);

          if(note != '') feedbackicon.show(); else feedbackicon.hide();

          var goalRubrics = getGoalRubricsForButton();
          if(goalRubrics.length > 0){
            rubricBtn.show();
          }else{
            rubricBtn.hide();
            if(rubricPanelRef){
              rubricPanelRef.close();
              rubricPanelRef = null;
            }
          }

        };
        scope.userStatus = scope.self.getUserLearningGoalStatus(scope.g,scope.s,true);
        scope.$watchGroup(["g","g.Rubrics","s","userStatus.Status","userStatus.Teacher","userStatus.Note","userStatus.TeacherNote"],updateNow);
        scope.$on("$destroy", function(){
          if(rubricPanelRef){
            rubricPanelRef.close();
            rubricPanelRef = null;
          }
          rubricBtn.off("click");
        });
        updateNow();
      };
  });

  app.directive('pressEnter', function () {
      return function (scope, element, attrs) {
          element.bind("keydown keypress", function (ev) {
             var key = 0;
             var isShift = false;
             if (window.event) {
                key = window.event.keyCode;
                isShift = !!window.event.shiftKey; // typecast to boolean
             } else {
                key = ev.which;
                isShift = !!ev.shiftKey;
             }
             if(key === 13 && !isShift){
                scope.$apply(function (){
                    scope.$eval(attrs.pressEnter);
                });

                ev.preventDefault();
             }
          });
      };
  });

  app.directive('autofocus', ['$timeout', function($timeout) {
    return {
      restrict: 'A',
      link : function($scope, $element) {
        $timeout(function() {
          $element[0].focus();
        });
      }
    }
  }]);

  app.directive("scrollBottom", function(){
    return {
        link: function(scope, element, attr){
            $(element).on("click", function(){
               var $id= $("#" + attr.scrollBottom);
               setTimeout(function(){ if($id.length) $id.scrollTop($id[0].scrollHeight);},100);
            });
        }
    }
  });
  app.directive('scrollNewItemBottom', function ($timeout) {
    return {
      scope: {
        scrollNewItemBottom: "="
      },
      link: function (scope, element) {
        scope.$watchCollection('scrollNewItemBottom', function (newValue) {
          if (newValue){
            if(scope.$parent && scope.$parent.noScrollToBottom) return;
            $timeout(function(){
              $(element).stop().animate({scrollTop:$(element)[0].scrollHeight}, 500, 'swing');
            },100);
          }
        });
        $timeout(function(){$(element).scrollTop($(element)[0].scrollHeight);},10);
        $timeout(function(){$(element).scrollTop($(element)[0].scrollHeight);},500);
      }
    }
  });
  app.directive("whenScrolling", function() {
    return function(scope, elm, attr) {
      var raw = elm[0];

      elm.bind('scroll', function() {
        scope.$apply(attr.whenScrolling);
      });
    };
  });
  app.directive("whenScrolledTop", function() {
    return function(scope, elm, attr) {
      var raw = elm[0];

      elm.bind('scroll', function() {
        if (raw.scrollTop <= 0) {
          var $topItem = $('div:nth-child(2)',elm);
          var oScrollTop = raw.scrollTop;

          var oOffset = $topItem.length ? $topItem.position().top : 0;

          scope.$apply(attr.whenScrolledTop);
          if(attr.keepPosition)
            elm.scrollTop(oScrollTop + ($topItem.length ? $topItem.position().top : 0) - oOffset);
/*
          scope.$$postDigest(function() {
            // Executed after the dom has finished rendering
            elm.scrollTop(oScrollTop + ($topItem.length ? $topItem.position().top : 0) - oOffset);
          });
*/
        }
      });
    };
  });

  app.directive("whenScrolledBottom", function() {
    return function(scope, elm, attr) {
      var raw = elm[0];
      elm.bind('scroll', function() {
        if (raw.scrollTop + raw.offsetHeight >= raw.scrollHeight - 10) {
          scope.$apply(attr.whenScrolledBottom);
        }
      });
    };
  });


  app.directive('fileOnChange', ['$parse', function($parse) {
    return {
      restrict: 'A',
      link: function (scope, element, attrs) {

        var attrHandler = $parse(attrs['fileOnChange']);
        var handler = function (e) {
          scope.$apply(function () {
            attrHandler(scope, { $event: e, files: e.target.files });
          });
        };

        element.on('change', handler);
        element.on('$destroy', function() {
          element.off();
        });
      }
    };
  }]);

  app.directive('autoText', function($timeout) {
    return {
      restrict: 'A',
      scope: true,
      link: function(scope, element, attrs) {

        var parent          = element.parent()
          , domElem         = element[0];

        var current_step, inner_span, next_font_size, original_height, original_text, original_width, settings, div;
        settings = {
          // manually set a width/height if you haven't set one explicitly via CSS
          width: null,
          height: null,
          // the amount to change each time - bigger numbers are faster but fit less perfectly
          step_size: 1,
          // the number of font size iterations we should step through until we give up
          step_limit: 200,
          // set to false to NOT align middle (vertically)
          align_middle: true,
          // set to false this to NOT center the text (horizontally)
          align_center: true,
          // set to false to allow the big text to wrap (useful for when you want text to fill a big vertical area)
          multiline: true,
          // minimum font size (changing this may cause some 'shrink' scenarios to overflow instead)
          minimum_font_size: 1,
          // set to a number to limit the maximum font size allowed
          maximum_font_size: null,
          // set desired line-height
          line_height:'100%',
          padding : 4
        };


        function resize(){
          // take measurements
          if (settings.width) {
            original_width = settings.width;
            $(domElem).width(original_width + 'px');
          } else {
            original_width = $(domElem).width() - settings.padding*2;
          }
          if (settings.height) {
            original_height = settings.height;
            $(domElem).height(original_height + 'px');
          } else {
            original_height = $(domElem).height();
          }

          original_text = $(domElem).html();
          if ($('<div>' + original_text + '</div>').find('div.boxfitted').length === 0) {
            div = $($('<div></div>').addClass('boxfitted').html(original_text));
            $(domElem).html(div);
          } else {
            div = $($(domElem).find('div.boxfitted')[0]);
          }

          var minFontPixels = 3;
          var maxFontPixels = 40;
          var state = 1;
          while (minFontPixels < (maxFontPixels - 1)) {

            var fontSize = Math.floor((minFontPixels + maxFontPixels) / 2);
            div.css('font-size', fontSize);
            var w = div.width();
            var h = div.height();

            if(w == original_width && h <= original_height) break;

            if(state == 1 && w < original_width){
              minFontPixels = fontSize;
            }else
            if(state == 1 && w > original_width){
              maxFontPixels = fontSize;
            }else{
              state = 2;
              if(h < original_height){
                minFontPixels = fontSize;
              }else
              if(h > original_height){
                maxFontPixels = fontSize;
              }
            }
          }
          $(domElem).css('opacity', "1");
        }

        var resizePromise = null;
        function resizer() {
          if(resizePromise)
            $timeout.cancel(resizePromise);

          resizePromise = $timeout(function() {
            resizePromise = null;
            resize();
          }, 1);
        }
        scope.$watch(function() {
              return scope.$eval(attrs.ngBindHtml).toString();
            }, function() {
              resizer();
            });

        $timeout( function() { resizer() }, 2);

        angular.element(window).bind('resize', function(){ $timeout( function() { resizer() }, 0); });
      }
    }
  });

  app.directive('flashCardAutoTextSize', function($timeout, $window) {
    return {
      restrict: 'A',
      link: function(scope, element, attrs) {
        var node = element[0];
        var minSize = parseFloat(attrs.minSize || attrs.fcMinSize || "14");
        var maxSize = parseFloat(attrs.maxSize || attrs.fcMaxSize || "56");
        if(isNaN(minSize)) minSize = 14;
        if(isNaN(maxSize)) maxSize = 56;
        if(minSize > maxSize){
          var tmp = minSize;
          minSize = maxSize;
          maxSize = tmp;
        }

        var resizePromise = null;
        var resizeObserver = null;
        var mutationObserver = null;

        function isMediaTarget(target){
          if(!target || !target.closest) return false;
          return !!target.closest("video, audio");
        }

        function onCardContentClick(e){
          if(isMediaTarget(e.target)){
            e.stopPropagation();
          }
        }

        function hasComplexContent(){
          return !!node.querySelector('img,video,audio,iframe,canvas,svg,table,.ctable,pre,code');
        }

        function overflows(){
          // Browsers often report a 1px vertical overflow due to font metric rounding.
          return (node.scrollWidth - node.clientWidth > 1) || (node.scrollHeight - node.clientHeight > 2);
        }

        function applyOverflowPolicy(){
          var hDiff = node.scrollWidth - node.clientWidth;
          var vDiff = node.scrollHeight - node.clientHeight;
          node.style.overflowX = hDiff > 1 ? "auto" : "hidden";
          node.style.overflowY = vDiff > 2 ? "auto" : "hidden";
        }

        function applyWrapMode(emergency){
          if(emergency){
            // Last resort for single very long words/URLs.
            node.style.wordBreak = "break-word";
            node.style.overflowWrap = "anywhere";
            node.style.hyphens = "none";
          }else{
            // Prefer natural line breaks only at spaces/punctuation.
            // This forces font-size reduction before words are split.
            node.style.wordBreak = "normal";
            node.style.overflowWrap = "normal";
            node.style.hyphens = "none";
          }
        }

        function fitWithCurrentWrap(){
          node.style.fontSize = maxSize + "px";
          if(!overflows()) return;

          var low = minSize;
          var high = maxSize;
          for(var i = 0; i < 10; i++){
            var current = Math.round((low + high) / 2);
            node.style.fontSize = current + "px";
            if(overflows()){
              high = current;
            }else{
              low = current;
            }
          }
          node.style.fontSize = low + "px";
        }

        function fitText(){
          if(!node || !node.isConnected) return;
          if(node.clientWidth <= 1 || node.clientHeight <= 1) return;

          if(hasComplexContent()){
            node.style.fontSize = "";
            applyWrapMode(false);
            applyOverflowPolicy();
            return;
          }

          applyWrapMode(false);
          fitWithCurrentWrap();

          if(overflows()){
            applyWrapMode(true);
            fitWithCurrentWrap();
          }
          applyOverflowPolicy();
        }

        function scheduleFit(delay){
          if(resizePromise) $timeout.cancel(resizePromise);
          resizePromise = $timeout(function(){
            resizePromise = null;
            fitText();
          }, delay || 0, false);
        }

        var onWindowResize = function(){ scheduleFit(0); };
        angular.element($window).on('resize', onWindowResize);
        node.addEventListener('click', onCardContentClick, true);

        if(typeof ResizeObserver !== "undefined"){
          resizeObserver = new ResizeObserver(function(){ scheduleFit(0); });
          resizeObserver.observe(node);
        }
        if(typeof MutationObserver !== "undefined"){
          mutationObserver = new MutationObserver(function(){ scheduleFit(0); });
          mutationObserver.observe(node, {childList:true, subtree:true, characterData:true});
        }

        var unwatch = null;
        if(attrs.ngBindHtml){
          unwatch = scope.$watch(function(){
            return scope.$eval(attrs.ngBindHtml);
          }, function(){
            scheduleFit(0);
          });
        }

        scope.$on('$destroy', function(){
          if(resizePromise) $timeout.cancel(resizePromise);
          angular.element($window).off('resize', onWindowResize);
          node.removeEventListener('click', onCardContentClick, true);
          if(resizeObserver) resizeObserver.disconnect();
          if(mutationObserver) mutationObserver.disconnect();
          if(unwatch) unwatch();
        });

        scheduleFit(0);
        scheduleFit(60);
      }
    };
  });

  app.directive('videoplayer', function ($interval, $timeout, $window) {
    return {
      restrict : 'AE',
      scope    : {
          url     : '=',
          autoplay: '='
      },
      template : '<video style="width: 100%" preload="metadata" controls="controls" controlsList="nodownload" disablePictureInPicture></video>',
      link : function (scope, element) {

        if(scope.$parent && scope.$parent.bindVideplayer === true)
          scope.$parent.videoplayer = scope;
        if(scope.$parent.$parent && scope.$parent.$parent.bindVideplayer === true)
          scope.$parent.$parent.videoplayer = scope;

        scope.player = $("video", element).get(0);
        scope.player.src = scope.url;

        scope.$watch('url', function(newValue, oldValue) {
          if(scope.player && newValue != oldValue) {
            if(!newValue.toLowerCase().match(/^https?:\/\/.*\.(mp4)$/) &&
               !newValue.toLowerCase().match(/^blob:.*$/) )
              return; // no audio file?
            scope.url = newValue;
            if(!scope.player.paused) scope.player.pause();
            scope.player.poster = scope.url+'.jpg';
            scope.player.src = scope.url;
            scope.playing = false;
            scope.isReadyToPlay = false;
          }
        }, true);

        // try to add poster 
        scope.player.poster = scope.url+'.jpg';
        if(scope.autoplay)
          scope.player.autoplay = true;

        scope.player.addEventListener('play', function () {
            scope.playing = true;
            var was = Math.floor(scope.getTime());
            var length = Math.floor(scope.getDuration());
            mc.track('V_play',{url:scope.url,time:was, length:length});
        });
        scope.player.addEventListener('pause', function () {
            scope.playing = false;
            var was = Math.floor(scope.getTime());
            var length = Math.floor(scope.getDuration());
            mc.track('V_pause',{url:scope.url,time:was, length:length});
        });
        var timing = 0;    
        scope.player.addEventListener('timeupdate', function () {
            var previousTime = timing;       
            var currentTime = Math.floor(scope.getTime()); 
            var length = Math.floor(scope.getDuration());
            if (currentTime > previousTime + 1 || currentTime < previousTime - 1) {
              mc.track('V_seek',{url:scope.url,time:previousTime,to:currentTime, length:length});
            }            
            timing = currentTime;            
        });

        scope.playpause = function () {
          if(scope.player.paused)
             scope.player.play(); else
             scope.player.pause();
        };
        scope.getTime = function(){
          return scope.player.currentTime;
        }
        scope.getDuration = function(){
          return scope.player.duration;
        }
        scope.seekTo = function(t, noplay){
          var now = scope.player.currentTime;
          scope.player.currentTime = t;
          if(!noplay && scope.player.currentTime == now)
             scope.player.play();
        }
      }
    };
  });

  app.directive('wavesurfer', function ($interval, $timeout, $window) {
    var uniqueId = 1;
    if(!(window.AudioContext || window.webkitAudioContext)){
      // no support
      return {
        restrict : 'AE',
        scope    : {
            url     : '=',
            autoplay: '='
        },
        template : '<audio controls="controls"></audio>',
        link : function (scope, element) {
          $("audio", element).attr("src",scope.url);
          //if(scope.autoplay)
          //  $("audio", element).attr("autoplay","true");
        }
      };
    }

    if(!window.globalAudioContextPlay){
      window.globalAudioContextPlay = createAudioContext(0);
      window.globalAudioContextRecord = createAudioContext(0);
    }

    return {
      restrict : 'AE',
      scope    : {
        url        : '=',
        noDownload : '=',
        autoplay   : '=',
        playLimit  : '=?',
        playCount  : '=?'
      },
      template : '<div class="wavesurfer" ng-style="isLocked ? {\'pointer-events\':\'none\',\'opacity\':\'0.55\'} : {}">' +
                  '<div class="duration noselect" ng-if="hasLimitedPlays" style="top:0;bottom:auto; margin-bottom:4px;color:black">{{playsDone}} von {{playLimitValue}}</div>' +
                  '<div class="waveform" id="{{::uniqueId}}"></div>' +
                  '<div class="progress"><div class="progressInner"></div></div>'+
                  '<div class="duration noselect" ng-show="length">{{moment + " / " +length}}</div>'+
                  '<div class="speed noselect" ng-show="playing && !hasLimitedPlays"><span><i ng-click="setSpeed(-1)" class="fa fa-fw fa-caret-left"></i>{{speedLabel}}<i ng-click="setSpeed(1)" class="fa fa-fw fa-caret-right"></i> <md-tooltip md-direction="top">{{\'PLAYSPEED\' | trans}}</md-tooltip></span><span><i ng-click="toggleRepeatMode()" ng-style="{color:isRepeating?\'#0088d1\':\'\'}" class="fa fa-fw fa-refresh"></i> <md-tooltip md-direction="top">{{\'PLAYREPEAT\' | trans}}</md-tooltip></span></div>'+
                  '<md-button aria-label="play" class="md-icon-button" ng-class="{\'play-btn\': !playing, \'pause-btn\': playing}" ng-disabled="!isReadyToPlay || !canPlay" ng-click="playpause()"><i class="fa fa-play fa-fw" ng-class="{\'fa-play\': !playing, \'fa-pause\': playing}"></i></md-button>' +
                  '<a class="md-button md-icon-button download-btn" target="_system" style="display:none" download href=""><i class="fa fa-download fa-fw"></i></a>' +
                 '</div>',
      link : function (scope, element) {
        var id = uniqueId++;

        if(!(typeof cordova == "undefined")){
          $('.wavesurfer',element).css("padding-right","10px");
        }

        scope.uniqueId = 'waveform_' + id;
        scope.playing  = false;
        scope.isReadyToPlay = false;
        scope.canPlay = true;
        scope.isLocked = false;
        scope.hasLimitedPlays = false;
        scope.playLimitValue = 0;
        scope.playsDone = 0;

        var getPlayLimitValue = function(){
          if(scope.playLimit === null || typeof scope.playLimit == "undefined" || scope.playLimit === "") return 0;
          var l = parseInt(scope.playLimit,10);
          if(isNaN(l) || l < 1) return 0;
          return l;
        };

        var getPlayCountValue = function(){
          if(scope.playCount === null || typeof scope.playCount == "undefined" || scope.playCount === "") return 0;
          var c = parseInt(scope.playCount,10);
          if(isNaN(c) || c < 0) return 0;
          return c;
        };

        var updateCanPlay = function(){
          var l = getPlayLimitValue();
          var c = getPlayCountValue();
          scope.hasLimitedPlays = l > 0;
          scope.playLimitValue = l;
          scope.playsDone = c;
          scope.canPlay = l <= 0 || c < l || scope.playing;
          scope.isLocked = l > 0 && c >= l && !scope.playing;
        };

        scope.$watchGroup(['playLimit','playCount','playing'], function(){
          updateCanPlay();
        });
        updateCanPlay();

        var waveform = $('.waveform',element).get(0);
        $('.download-btn',element).attr("href",scope.url);

        if(scope.noDownload){
          $('.download-btn',element).css({"width": "0", "margin": "0", "padding": "0"});
          $('.download-btn',element).attr("inert","true");
          $('.wavesurfer',element).css("padding-right","10px");
        }

        // initialize the wavesurfer
        scope.options = {
          audioContext:window.globalAudioContextPlay,
          height:50,
          normalize:true,
          waveColor:'rgb(200,200,200)',
          container: waveform,
          progressColor: 'rgb(255,0,0)',
          cursorColor: 'transparent',
//          backend: 'MediaElement', // 'WebAudio'
//          backend: window.electron ? 'WebAudio' : 'MediaElement', // 'MediaElement'
          backend: 'MediaElement',
          interact: !scope.hasLimitedPlays,
          partialRender: false,
          barWidth:2
        };
        //if(scope.autoplay) scope.options.autoplay = true;
        scope.wavesurfer = WaveSurfer.create(scope.options);
        if(scope.$parent && scope.$parent.bindWavesurfer === true)
          scope.$parent.wavesurfer = scope;
        if(scope.$parent.$parent && scope.$parent.$parent.bindWavesurfer === true)
          scope.$parent.$parent.wavesurfer = scope;
        //scope.wavesurfer.init(scope.options);
        scope.moment = "0";
        scope.length = 0;

        scope.$watch('noDownload', function(newValue, oldValue) {
          if(newValue == oldValue) return;
          if(newValue){
            $('.download-btn',element).css({"width": "0", "margin": "0", "padding": "0"});
            $('.wavesurfer',element).css("padding-right","10px");
          }else{
            $('.download-btn',element).css({"width": "", "margin": "", "padding": ""});
            $('.wavesurfer',element).css("padding-right","");
          }
        }, true);

        scope.speed = scope.speed || 1.0;
        scope.speedLabel = "×1.0";
        scope.setSpeed = function(v){
          if(v > 0){
            if(scope.speed == 0.5){
              scope.speed = 0.75;
              scope.speedLabel = "×0.8";
            }else
            if(scope.speed == 0.75){
              scope.speed = 1;
              scope.speedLabel = "×1.0";
            }else
            if(scope.speed == 1){
              scope.speed = 1.1;
              scope.speedLabel = "×1.2";
            }else
            if(scope.speed == 1.1){
              scope.speed = 1.25;
              scope.speedLabel = "×1.5";
            }else
            if(scope.speed == 1.25){
              scope.speed = 1.5;
              scope.speedLabel = "×2.0";
            }else
            if(scope.speed == 1.5){
              scope.speed = 1.75;
              scope.speedLabel = "×2.5";
            }
          }else{
            if(scope.speed == 0.75){
              scope.speed = 0.5;
              scope.speedLabel = "×0.5";
            }else
            if(scope.speed == 1){
              scope.speed = 0.75;
              scope.speedLabel = "×0.8";
            }else
            if(scope.speed == 1.1){
              scope.speed = 1;
              scope.speedLabel = "×1.0";
            }else
            if(scope.speed == 1.25){
              scope.speed = 1.1;
              scope.speedLabel = "×1.2";
            }else
            if(scope.speed == 1.5){
              scope.speed = 1.25;
              scope.speedLabel = "×1.5";
            }else
            if(scope.speed == 1.75){
              scope.speed = 1.5;
              scope.speedLabel = "×2.0";
            }
          }
          scope.wavesurfer.setPlaybackRate(scope.speed);
        };

        scope.isRepeating = false;
        scope.toggleRepeatMode = function(){
          scope.isRepeating = !scope.isRepeating;
        };

        scope.$watch('url', function(newValue, oldValue) {
          if(scope.wavesurfer && newValue != oldValue) {
            if(!newValue.toLowerCase().match(/^https?:\/\/.*\.(m4a|mp3)$/) &&
               !newValue.toLowerCase().match(/^blob:.*$/) )
              return; // no audio file?
            scope.wavesurfer.load(scope.url);
            scope.playing = false;
            scope.isReadyToPlay = false;
            scope.loadStartTime = new Date().getTime();
          }
        }, true);

        scope.wavesurfer.on('error', function (err) {
          if(!scope.wavesurfer) return;
          if(err && err.name == "AbortError") return;
          console.error(err);
          if(err && err.message && err.message.indexOf("Not Found")>0){
            mc.handleAudioUploadError();
            return;
          }
          if(err && err.indexOf && err.indexOf("Not Found")>0){
            mc.handleAudioUploadError();
            return;
          }
        });
        scope.loadStartTime = new Date().getTime();
        scope.wavesurfer.on('loading', function (percents) {
          $('.progressInner',element).css("width",Math.round(percents*0.9)+"%");
          if(percents == 100){
            var delta = (new Date().getTime()) - scope.loadStartTime;
            var cp = 90;
            var incBar = function(){
              if(!scope.wavesurfer) return;
              cp = cp + 0.25;
              $('.progressInner',element).css("width",cp+"%");
              if(!scope.isReadyToPlay || cp < 100)
                $timeout(incBar,250);
            };
            $timeout(incBar,250);
          }
        });
        // on ready
        scope.wavesurfer.on('ready', function () {
            if(scope.refreshInterval) $interval.cancel(scope.refreshInterval);
            scope.length = secToMMSS(Math.floor(scope.wavesurfer.getDuration()));
            scope.refreshInterval = $interval(function () {
              scope.currentPosition = Math.floor(scope.wavesurfer.getCurrentTime());
              scope.moment = secToMMSS(scope.currentPosition);
            }, 200);
            $('.progress',element).fadeOut();
            if((typeof cordova == "undefined")){
              setTimeout(function(){
                $('.download-btn',element).fadeIn();
              },500);
            }
            scope.isReadyToPlay = true;
            if(scope.autoplay && !scope.playing)
              scope.playpause();
        });

        // what to be done on finish playing
        scope.wavesurfer.on('finish', function () {
            scope.playing = false;
            var l = getPlayLimitValue();
            if(l > 0){
              var c = getPlayCountValue();
              if(c < l) scope.playCount = c + 1;
            }
            if(scope.isRepeating){
              if(l > 0 && getPlayCountValue() >= l) return;
              scope.seekTo(0,true);
              scope.wavesurfer.playPause();
            }
        });
        scope.wavesurfer.on('play', function (err) {
            scope.playing = true;
            var was = Math.floor(scope.wavesurfer.getCurrentTime());
            var length = Math.floor(scope.wavesurfer.getDuration());
            mc.track('A_play',{url:scope.url,time:was, length:length});
        });
        scope.wavesurfer.on('pause', function (err) {
            scope.playing = false;
            var was = Math.floor(scope.wavesurfer.getCurrentTime());
            var length = Math.floor(scope.wavesurfer.getDuration());
            mc.track('A_pause',{url:scope.url,time:was,length:length});
        });
        scope.wavesurfer.on('seek', function (currentTime) {
            var length = Math.floor(scope.wavesurfer.getDuration());
           // mc.track('A_seek',{url:scope.url,time:scope.currentPosition, to:Math.floor(currentTime*scope.wavesurfer.getDuration()), length:length});
        });

        scope.destroy = function(){
            $interval.cancel(scope.refreshInterval);
            scope.wavesurfer.destroy();
            scope.wavesurfer = null;
        };
        // play/pause action
        scope.playpause = function () {
            if(!scope.wavesurfer) return;
            if(!scope.playing){
              var l = getPlayLimitValue();
              if(l > 0){
                var c = getPlayCountValue();
                var t = scope.wavesurfer.getCurrentTime();
                var d = scope.wavesurfer.getDuration();
                var nearEnd = d > 0 && (d - t) <= 0.25;
                if(nearEnd){
                  scope.wavesurfer.setCurrentTime(0);
                }
                if(c >= l) return;
              }
            }
            scope.wavesurfer.playPause();
        };

        scope.ff = function () {
            scope.wavesurfer.skipForward();
        };

        scope.bw = function () {
            scope.wavesurfer.skipBackward();
        };
        scope.seekTo = function(t,noplay){
            var was = scope.wavesurfer.getCurrentTime();
            scope.wavesurfer.setCurrentTime(parseFloat(t)); // seconds
            if(!noplay && was == scope.wavesurfer.getCurrentTime()){
              // play now 
              scope.wavesurfer.playPause();
            }
            var length = Math.floor(scope.wavesurfer.getDuration());
            mc.track('A_seek',{url:scope.url,time:Math.floor(was), to:Math.floor(parseFloat(t)), length:length});
        };
        scope.getTime = function(){
            return scope.wavesurfer.getCurrentTime().toFixed(2); // seconds
        };


        scope.checkAlive = function(){
          if($('#'+scope.uniqueId).length == 0){
            scope.destroy();
          }else{
            $timeout(scope.checkAlive,500);
          }
        };
        $timeout(scope.checkAlive,500);
        $timeout(function(){
          scope.wavesurfer.load(scope.url);
        },100);
      }
    };
  });

  app.directive('toolhovertip',['$document',
    function($document) {
        return {
            restrict: 'A',
            link: function(scope,element,attr) {
                var startX = 0, startY = 0, x = 0, y = 0;
                var tip = null;
                var creating = false;
                function click(event){
                  if(tip == null){
                    // show hint before click if it is not visible yet (android touch)
                    event.preventDefault();
                    event.stopImmediatePropagation();
                  }else{
                    event.stopPropagation();
                  }
                }
                function mouseover(event){
                  startX = event.pageX;
                  startY = event.pageY;

                  if(tip == null && !creating) {
                    creating = true;
                    setTimeout(function(){
                    $('.toolhovertip').remove();
                    tip = $('<div class="toolhovertip">'+(attr["tooltip"] ? attr["tooltip"] :'')+(attr["tooltipcaption"] ? '<br><span class="caption">'+attr["tooltipcaption"]+"</span>" : '')+'</div>');
                    var pos = $(element).offset();
                    x = pos.left;
                    y = pos.top+$(element).height()+5;
                    tip.css({
                      marginLeft:  (event.pageX - startX + x) + 'px',
                      marginTop: (event.pageY - startY + y) + 'px'
                    });
                    $("body").append(tip);
                    element.on('mousemove', mousemove);
                    element.on("mouseout",mouseout);
                    $(document).on("click",mouseout);
                    tip.show();
                    creating = false;
                    },1);
                  }
                };
                function mousemove(event){
                  tip.css({
                    marginLeft:  (event.pageX - startX + x) + 'px',
                    marginTop: (event.pageY - startY + y) + 'px'
                  });
                };
                function mouseout(event){
                  if(tip) tip.remove();
                  tip = null;
                  element.off("mouseout",mouseout);
                  element.off('mousemove', mousemove);
                  $(document).off("click",mouseout);
                };

                element.on("mouseover",mouseover);
                element.on("click",click);

            }
        };
    }]);

    //1001
    //directive for tape of pearls
    //Attributes to define: journal, limit, and inJournal
    app.directive('pearlsTape', function($compile, $timeout, $parse, $filter) {
      return function (scope, element, attrs) {
        var currentPearls = [];
        var currentLimit = 0;
        var journal = [];

        var wrappedPearls = $("<span class='wrappedPearls'></span>");
        var pearls = $('<span class="pearls"></span>');
        var pearlsPointer = $('<i id="pearlsPointer" class="fa fa-fw fa-caret-up">');

        if(scope.$eval(attrs.injournal)) {
          var removedPearlsLeft = $('<span class="removedPearlsLeft"></span>');

          $(element).append(removedPearlsLeft);

          wrappedPearls.append(pearls);
          wrappedPearls.append(pearlsPointer);
          $(element).append(wrappedPearls);
          $(element).append($('<span class="removedPearlsRight"></span>'));
        }
        else {
          wrappedPearls.append(pearls);
          $(element).append(wrappedPearls);
        }

        scope.$watch(attrs.journal, function(newValue, oldValue){
          journal = newValue; // can be undefined while loading
          updateElement();
        });

        scope.$watch(attrs.limit, function(){
          updateElement();
        });

        scope.$watch(attrs.start, function(newValue, oldValue){
          if(Math.abs(newValue - oldValue) > 2) {
            updateElement(oldValue);
          }
          else {
            moveInJournal(oldValue);
          }
        });

        var moveInJournal = function(oldPearlsStart = -1) {
          if(!journal) return;

          var inJournal = scope.$eval(attrs.injournal);
          var loopStart = scope.$eval(attrs.start);
          var limit = scope.$eval(attrs.limit);
          var student = scope.$eval(attrs.student);

          if(oldPearlsStart == -1) {
            oldPearlsStart = loopStart;
          }

          if(inJournal && oldPearlsStart != loopStart) {
            var jPStart = oldPearlsStart;
            do {
              if(loopStart > oldPearlsStart) {
                jPStart++;
              }
              else {
                jPStart--;
              }
              if(oldPearlsStart < jPStart) {
                if(typeof $(element).children(".wrappedPearls").children(".pearls") != 'undefined') {
                  $(element).children(".wrappedPearls").children(".pearls").children().eq(0).remove();

                  var it = journal[jPStart + limit-1];

                  var pearl = createPearl(it, jPStart + limit-1, inJournal, limit, student.ID)
                  $(element).children(".wrappedPearls").children(".pearls").append(pearl);
                  pearl.addClass('fadeInRight')
                      .one('webkitAnimationEnd oanimationend msAnimationEnd animationend', function(e) {
                          $(this).removeClass('fadeInRight');
                  });
                }
                if(typeof $(element).children(".removedPearlsLeft") != 'undefined') {
                  var it = journal[oldPearlsStart];

                  if(typeof it !== 'undefined') {
                    var pearl = createPearl(it, 0, inJournal, limit, student.ID, false);

                    var bubblePearl = $("<div class='bubblePearl'></div>");
                    bubblePearl.append(pearl);
                    $(element).children(".removedPearlsLeft").append(bubblePearl);

                    bubblePearl.addClass('fadeOutLeft')
                        .one('webkitAnimationEnd oanimationend msAnimationEnd animationend',
                         function(e) {
                           $(this).remove();
                         });
                  }
                }
              } else {
                if(typeof $(element).children(".wrappedPearls").children(".pearls") != 'undefined') {
                  $(element).children(".wrappedPearls").children(".pearls").children().eq(limit-1).remove()

                  var it = journal[jPStart];

                  var pearl = createPearl(it, jPStart, inJournal, limit, student.ID)
                  $(element).children(".wrappedPearls").children(".pearls").prepend(pearl);
                  pearl.addClass('fadeInLeft')
                      .one('webkitAnimationEnd oanimationend msAnimationEnd animationend', function(e) {
                          $(this).removeClass('fadeInLeft');
                  });
                }
                if(typeof $(element).children(".removedPearlsRight") != 'undefined') {
                  var it = journal[oldPearlsStart + limit-1];

                  if(typeof it !== 'undefined') {
                    var pearl = createPearl(it, 0, inJournal, limit, student.ID, false);

                    var bubblePearl = $("<div class='bubblePearl'></div>");
                    bubblePearl.append(pearl);
                    $(element).children(".removedPearlsRight").prepend(bubblePearl);

                    bubblePearl.addClass('fadeOutRight')
                        .one('webkitAnimationEnd oanimationend msAnimationEnd animationend', function(e) {
                            $(this).remove();
                    });
                  }
                }
              }

              $compile($(element).children(".wrappedPearls").children(".pearls"))(scope);
              if(loopStart > oldPearlsStart) {
                oldPearlsStart ++;
              }
              else {
                oldPearlsStart --;
              }
            } while (jPStart != loopStart);
          }
          currentLimit = limit;
        }


        var updateElement = function(oldPearlsStart = -1) {
          if(!journal) return;

          var inJournal = scope.$eval(attrs.injournal);
          var loopStart = scope.$eval(attrs.start);
          var limit = scope.$eval(attrs.limit);
          var loopLimit = !inJournal?limit+1:limit;
          var student = scope.$eval(attrs.student);

          if(oldPearlsStart == -1) {
            oldPearlsStart = loopStart;
          }

          if($(element).children(".wrappedPearls").children(".pearls")) {
            var overwriteCurrentPearls = [];

            //$(element).children(".wrappedPearls").children(".pearls").empty();

            var deleteElements = [];
             for(var key = loopStart; key < loopLimit + loopStart; key++) {

              var it = journal[key];

              if(typeof it !== 'undefined') {

                var currentKey = currentPearls.indexOf(journal[key].ID);

                var pearl = createPearl(it, key, inJournal, limit, student.ID);

                if(!inJournal) {
                  if(oldPearlsStart < loopStart) {
                    pearl.addClass('fadeInRight')
                        .one('webkitAnimationEnd oanimationend msAnimationEnd animationend', function(e) {
                            $(this).removeClass('fadeInRight');
                    });
                  }
                  else {
                    pearl.addClass('fadeInLeft')
                        .one('webkitAnimationEnd oanimationend msAnimationEnd animationend', function(e) {
                            $(this).removeClass('fadeInLeft');
                    });
                  }
                }

                if (!inJournal && key == limit && journal.length != limit) {
                  overwriteCurrentPearls.push(journal.length-limit);
                }
                else {
                  overwriteCurrentPearls.push(journal[key].ID);
                }

                if($(element).children(".wrappedPearls").children(".pearls").children().eq(key - loopStart).length != 0) {

                  var needReplacement = false;
                  needReplacement = currentKey != key - loopStart;
                  // in Class Activities List
                  if(!inJournal && key == limit) {
                    // +122 counter
                    needReplacement = currentPearls[limit] != journal.length - limit;
                  }

                  if(needReplacement) {
                    $(element).children(".wrappedPearls").children(".pearls").children().eq(key - loopStart).replaceWith(pearl);
                  }
                }
                else {
                  $(element).children(".wrappedPearls").children(".pearls").append(pearl);
                }
              }
              else {
                if($(element).children(".wrappedPearls").children(".pearls").children().eq(key - loopStart).length != 0) {
                  deleteElements.push(key - loopStart);
                }
              }
            }
            if(currentLimit > limit) {
              for(var key = loopStart + limit; key < currentLimit + loopStart; key++) {
                if($(element).children(".wrappedPearls").children(".pearls").children().eq(key - loopStart).length != 0) {
                  deleteElements.push(key - loopStart);
                }
              }
            }

            for(var i = deleteElements.length - 1; i >= 0; i--) {
              $(element).children(".wrappedPearls").children(".pearls").children().eq(deleteElements[i]).remove();
            }

            currentPearls = overwriteCurrentPearls;

            if(currentPearls.length != 0) {
              $(element).children(".wrappedPearls").addClass("wrappedPearlsBox");
            }
            else {
              $(element).children(".wrappedPearls").removeClass("wrappedPearlsBox");
            }

            $compile($(element).children(".wrappedPearls").children(".pearls"))(scope);
          }
          currentLimit = limit;
        }


        var createPearl = function(it, key, inJournal, limit, studentID, withToolTip = true) {
          // name="' + inJournal + '"
          var pearl = $('<span class="animatePearls '+
                      ((!inJournal && key == limit && journal.length != limit) ?
                          'additionalPearls ':'pearlString ') +'"></span>');

          pearlStyle = {}

          if(!(inJournal == false && key == limit && journal.length != limit)) {
            pearlStyle = {
              'background-color':
                (it.Type == 'folderadded' ||
                 it.Type == 'folderremoved' ||
                 it.Type == 'folderitemadded' ||
                 it.Type == 'folderitemchanged' ||
                 it.Type == 'folderitemremoved' ||
                 it.Type == 'teacherentry' ||
                 it.Type == 'userentry'||
                (it.DataJSON && it.DataJSON.Status)) ? 'none':
                (it.DataJSON && it.DataJSON.MainTopic && it.DataJSON.MainTopic.Color) ?
                 it.DataJSON.MainTopic.Color:(it.DataJSON && it.DataJSON.Task ? it.DataJSON.Task.Color : 'transparent'),

              'color':it.Type == 'teacherentry' ? '#7b1fa2' :
                      it.Type == 'userentry' ? '#0288d1' :
                      it.Type == 'teacherrubricstatus' ? '#0288d1' :
                      it.Type == 'folderadded' ? '#0288d1' :
                      it.Type == 'folderremoved' ? '#0288d1' :
                      it.Type == 'folderitemadded' ? '#0288d1' :
                      it.Type == 'folderitemchanged' ? '#0288d1' :
                      it.Type == 'folderitemremoved' ? '#0288d1' :
                (it.DataJSON && it.DataJSON.Status) ?
                (it.DataJSON && it.DataJSON.MainTopic && it.DataJSON.MainTopic.Color) ?
                 it.DataJSON.MainTopic.Color:'black':'white',

              'border-radius':
                (it.Type == 'teacherentry' ||
                 it.Type == 'userentry' ||
                (it.DataJSON && it.DataJSON.Status)) ? 'none':'5px',

              'font-size':
                (it.Type == 'teacherentry' ||
                 it.Type == 'userentry'||
                (it.DataJSON && it.DataJSON.Status)) ? '20px':'auto',

              'line-height':
                (it.Type == 'teacherentry'||
                 it.Type == 'userentry'||
                (it.DataJSON && it.DataJSON.Status)) ? '10px':'auto'
            }
          }

          pearl.css(pearlStyle);

          //make pearls clickable in journal
          if(inJournal) {
            pearl.on("click",function($event){
              scope.scrollToIndex(key, $event);
            });
          }

          function addTime(){
            return scope.self.shortDateTimePrivacy(it.Created)+": ";
          }
          //if over limit show counter else show pearl
          if(inJournal || key != limit) {
            var icon = $('<div></div>');

            if(it.Type == 'teacherrubricstatus'){
               icon.append($('<i class="pearlIcon fa-fw fa fa-table" style="margin:2px;font-size: 80% !important;"></i>'));
               icon.append($('<md-tooltip>'+addTime()+ '</md-tooltip>'));
            }else
            if(it.Type == 'folderadded' ||
               it.Type == 'folderremoved' ||
               it.Type == 'folderitemadded' ||
               it.Type == 'folderitemchanged' ||
               it.Type == 'folderitemremoved'){
               icon.append($('<i class="pearlIcon fa-fw fa fa-address-book-o" style="font-size: 100% !important;"></i>'));
               icon.append($('<md-tooltip>'+addTime()+ $filter('trans')(it.Type.toUpperCase(),it.DataJSON && it.DataJSON.Folder ? it.DataJSON.Folder.Name : '') + '</md-tooltip>'));
            }else
            if(typeof it.Type !== 'undefined') {
              if(it.Type!='teacherentry'&&it.Type!='userentry' &&
                typeof it.DataJSON !== 'undefined' &&
                typeof it.DataJSON.taskid !== 'undefined' &&
                typeof it.DataJSON.Task !== 'undefined') {

                // TODO: add rating icons here if there are some instead of task icon!
                var userStatus = scope.self.getUserTaskStatus(it.DataJSON.Task,{ID:studentID},true);
                if(userStatus.Rating && userStatus.Rating != "0"){
                  if(userStatus.Rating == 1) icon.append($('<img class="pearlIcon" src="https://learningview.org/app/sun.svg">'));
                  if(userStatus.Rating == 2) icon.append($('<img class="pearlIcon" src="https://learningview.org/app/clouds.svg">'));
                  if(userStatus.Rating == 3) icon.append($('<img class="pearlIcon" src="https://learningview.org/app/thunder.svg">'));
                  pearl.css({'background':''});
                }else
                  icon.append($('<i class="pearlIcon fa-fw ' + it.DataJSON.Task.MainIcon + '"></i>'));

                if(withToolTip) {
                  if(it.DataJSON.Task.Type == 'user') {
                    if(self.User && it.DataJSON.Task.Owner == self.User.ID) {
                      icon.append($('<md-tooltip>' +addTime()+ $filter('trans')('OWNTASK') + (it.DataJSON.Task&&it.DataJSON.Task.Name?': '+it.DataJSON.Task.Name:'')+ '</md-tooltip>'));
                    }
                    else {
                      icon.append($('<md-tooltip>' +addTime()+ $filter('trans')('USERTASKFROM', (scope.self.users[it.DataJSON.Task.Owner] ? scope.self.users[it.DataJSON.Task.Owner].Name : 'unbekannt')) + (it.DataJSON.Task&&it.DataJSON.Task.Name?': '+it.DataJSON.Task.Name:'')+'</md-tooltip>'));
                    }
                  }
                  else if(it.DataJSON.MainTopic) {
                    icon.append($('<md-tooltip>' +addTime()+ it.DataJSON.MainTopic.Name + ': ' + it.DataJSON.Topic.Name + ': ' + it.DataJSON.Task.Name + '</md-tooltip>'));
                  }
                }
              }
              else if(it.Type=='teacherentry'||it.Type=='userentry') {
                icon.append($('<i class="pearlIcon ' + (it.Type == 'teacherentry'?'fa-flip-horizontal':'') + ' fa fa-fw fa-commenting"></i>'));
                if(it.DataJSON && withToolTip) {
                  icon.append($('<md-tooltip>' +addTime()+ (it.DataJSON.MainTopic&&it.DataJSON.MainTopic.Name?it.DataJSON.MainTopic.Name:'') + (it.DataJSON.Topic&&it.DataJSON.Topic.Name?': '+it.DataJSON.Topic.Name:'') + (it.DataJSON.Task&&it.DataJSON.Task.Name?': '+it.DataJSON.Task.Name:'') + '</md-tooltip>'));
                }
              }
            }
            if(typeof it.DataJSON !== 'undefined' && typeof it.DataJSON.Status !== 'undefined') {
              if(it.Type == 'goalteacherdone') {
                if(it.DataJSON.Status == '') {
                  icon.append($('<i class="pearlIcon fa fa-fw fa-times"></i>'));
                }
                else {
                  icon.append($('<i class="pearlIcon certificateBadge ' + it.DataJSON.Status + '"></i>'));
                }
              }
              else {
                switch(it.DataJSON.Status) {
                  case '':
                    icon.append($('<i class="pearlIcon fa fa-fw fa-times"></i>'));
                    break;
                  case 'green':
                  case 'lightgreen':
                    icon.append($('<i class="pearlIcon fa fa-fw fa-thumbs-up"></i>'));
                    break;
                  case 'yellow':
                    icon.append($('<i class="pearlIcon fa fa-fw fa-thumbs-up fa-rotate-270"></i>'));
                    break;
                  case 'red':
                    icon.append($('<i class="pearlIcon fa fa-fw fa-thumbs-down fa-flip-horizontal"></i>'));
                    break;
                }
              }

              if(withToolTip) {
                icon.append($('<md-tooltip>' +addTime()+ (it.DataJSON && it.DataJSON.MainTopic && it.DataJSON.MainTopic.Name ? it.DataJSON.MainTopic.Name:'') + (it.DataJSON && it.DataJSON.Topic && it.DataJSON.Topic.Name ? ': '+it.DataJSON.Topic.Name:'') + (it.DataJSON && it.DataJSON.Task && it.DataJSON.Task.Name ? ': '+it.DataJSON.Task.Name:'') + '</md-tooltip>'));
              }
            }
            pearl.append(icon);
          }
          if (!inJournal && key == limit && journal.length != limit) {
            pearl.append('+' + (journal.length-limit));
          }

          return pearl;
        }
      };
  });

  app.directive('nonbreakingSpace', function () {
    return  {
      restrict: 'A',
      require: 'ngModel',
      link: function (scope, elm, attrs, ctrl) {
        elm.on('keydown', function (ev) {
            if (ev.keyCode === 13 || (ev.keyCode === 32 && (ev.shiftKey || ev.ctrlKey))) {
                var currValue = ctrl.$modelValue;
                var pos = ev.target.selectionStart;
                var s = currValue.split('');
                s.splice(ev.target.selectionStart,0,'\u00A0');

                ctrl.$setViewValue(s.join(''));
                ctrl.$render();
                ev.preventDefault();
                ev.target.selectionStart = pos+1;
                ev.target.selectionEnd = pos+1;
                scope.$apply();
                return false;
            } else {
                return true;
            }
        });
      }
    }
  });

  // add onProgress events in ajax calls
  app.decorator("$xhrFactory", [
    "$delegate", "$injector",
    function($delegate, $injector) {
      return function(method, url) {
        var xhr = $delegate(method, url);
        var $http = $injector.get("$http");
        var callConfig = $http.pendingRequests[$http.pendingRequests.length - 1];
        if (angular.isFunction(callConfig.onProgress))
          xhr.addEventListener("progress", callConfig.onProgress);
        return xhr;
      };
    }
  ]);

  // Back button in Browser or Android, hack AngularJS router
  app.decorator("$browser",  [
    "$delegate", "$injector",
    function($delegate, $injector) {
      $delegate.onUrlChange = function(){};
      $delegate.setUrl = function(){};
      $delegate.pollUrl = function(){};

      window.history.pushState({LV:Math.random()}, "", window.location.href);

      // Android Button
      document.addEventListener("backbutton", function(e) {
        //e.preventDefault();
        if(mc.silentBackButtonPushed){
          mc.silentBackButtonPushed = false;
          return;
        }
      });

      // Back Button in Browser pressed 
      window.addEventListener("popstate", function () {
        if(mc.silentBackButtonPushed){
          mc.silentBackButtonPushed = false;
          return;
        }
        if(mc.backButtonPushed){
           mc.backButtonPushed();
        }
        setTimeout(function(){
          // press forward again so we keep one state to work with
          mc.silentBackButtonPushed = true;
          window.history.forward();
        },1);         
      });
      return $delegate;
    }
  ]);
