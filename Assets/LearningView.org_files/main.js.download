var mc = {};
window.__lvDebugLogStore = window.__lvDebugLogStore || [];
var DEBUG_LOG_MAX_ENTRIES = 100;
var DEBUG_LOG_MAX_PART_LENGTH = 400;
var DEBUG_LOG_MAX_LINE_LENGTH = 800;

function cutLogText(text, maxLen) {
  var s = String(text == null ? "" : text);
  if (s.length <= maxLen) return s;
  return s.substring(0, maxLen) + " ...[cut]";
}

function formatLogArg(arg) {
  if (arg instanceof Error) {
    var errText = (arg.name || "Error") + ": " + (arg.message || "");
    if (arg.stack) errText += " | " + arg.stack;
    return cutLogText(errText, DEBUG_LOG_MAX_PART_LENGTH);
  }

  var t = typeof arg;
  if (arg == null || t === "number" || t === "boolean" || t === "bigint" || t === "undefined") {
    return String(arg);
  }
  if (t === "string") {
    return cutLogText(arg, DEBUG_LOG_MAX_PART_LENGTH);
  }
  if (Array.isArray(arg)) {
    return "[Array len=" + arg.length + "]";
  }
  if (t === "object") {
    try {
      var keys = Object.keys(arg);
      var preview = keys.slice(0, 8).join(",");
      return "[Object keys=" + keys.length + (preview ? " " + preview : "") + (keys.length > 8 ? ",..." : "") + "]";
    } catch (e) {
      return "[Object]";
    }
  }

  return cutLogText(String(arg), DEBUG_LOG_MAX_PART_LENGTH);
}

function writeLog(type, args) {
  var msg = Array.from(args).map(formatLogArg).join(" ");
  var line = cutLogText(new Date().toISOString() + " [" + type + "] " + msg, DEBUG_LOG_MAX_LINE_LENGTH);
  window.__lvDebugLogStore.push(line);
  if (window.__lvDebugLogStore.length > DEBUG_LOG_MAX_ENTRIES) {
    window.__lvDebugLogStore.splice(0, window.__lvDebugLogStore.length - DEBUG_LOG_MAX_ENTRIES);
  }
  if (mc) {
    mc.debugLog = window.__lvDebugLogStore;
  }
}

var oldLog = console.log;
console.log = function () {
  writeLog("LOG", arguments);
  oldLog.apply(console, arguments);
};
var oldWarn = console.warn;
if (oldWarn && oldWarn.apply) {
  console.warn = function () {
    writeLog("WARN", arguments);
    oldWarn.apply(console, arguments);
  };
}
var oldError = console.error;
if (oldError && oldError.apply) {
  console.error = function () {
    writeLog("ERR", arguments);
    oldError.apply(console, arguments);
  };
}

function detectRuntimeMobilePlatform() {
  var ua = (navigator.userAgent || "").toLowerCase();
  var platform = (navigator.platform || "").toLowerCase();
  var touchPoints = navigator.maxTouchPoints || 0;
  var isLikelyIOS = /iphone|ipad|ipod/.test(ua) || (platform === "macintel" && touchPoints > 2);
  var isLikelyAndroid = /android/.test(ua) || /linux armv7l/.test(ua);
  if (isLikelyIOS && !isLikelyAndroid) return "ios";
  if (isLikelyAndroid && !isLikelyIOS) return "android";
  return null;
}

function resolveCordovaDeviceParam(rawDeviceParam) {
  var requested = (rawDeviceParam || "").toLowerCase();
  var runtime = detectRuntimeMobilePlatform();
  if (requested === "ios" || requested === "android") {
    if (runtime && runtime !== requested) return runtime;
    return requested;
  }
  if (runtime) return runtime;
  return "android";
}

var isCordovaRedirected = false;

function getURLParam(strParamName){
 var strReturn = "";
 strParamName = strParamName.toLowerCase();
 var strHref = window.location.href;
 if (strHref.indexOf("#") > -1){
  strHref = strHref.substring(0, strHref.indexOf("#"));
 }
 if(strHref.indexOf("?") > -1 ){
  var strQueryString = strHref.substr(strHref.indexOf("?")+1);
  var a = strQueryString.split("&");
  for (var i = 0; i < a.length; i++ ){
   var b = a[i].split("=");
   if (b[0].toLowerCase() == strParamName){
    strReturn = decodeURIComponent((b[1] || "").replace(/\+/g, " "));
    break;
   }
  }
 }
 return strReturn;
}

if(getURLParam("requireCordova") == 1){
  var handoff = getURLParam("handoff");
  if(handoff){
    var res = fetch("https://learningview.org/api/loginUser.php", {
      method: "POST",
      credentials: "same-origin",
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      body: new URLSearchParams({
        usehandoff: handoff
      })
    }).then(function(res){return res.json();}).then(function(data){
      if (data.result == "OK") {
        localStorage.setItem("user",JSON.stringify(data.user));
        var url = new URL(window.location.href);
        url.searchParams.delete('handoff');
        window.location.replace(url.toString());        
      }
    });
  }
  var dev = resolveCordovaDeviceParam(getURLParam("device"));
  if(dev != 'ios' && dev != 'android') dev = 'android';
  console.log("Loading Cordova.js for "+dev);
  requireJavascript("https://learningview.org/app/"+dev+"/cordova.js",function(){
    // cordova is loaded later, so update global variables now
    console.log("Cordova.js loaded.");
  });
  document.addEventListener("deviceready", function() {
    console.log("deviceready fired.");
  }, false);
  setTimeout(function(){
    if(!initCordovaDone){
      console.warn("deviceready not fired after 5000ms.");
    }
  }, 5000);
  document.addEventListener("deviceready", initCordova, false);
  window.isCordovaRedirected = true;
}

console.log("Load location:"+window.location.href);

window.isElectron = !!window.electron;

if(window.location.href.indexOf("learningview.org") == -1 && !window.isElectron){
  // from ionic localhost 
  var userRaw = null;
  try {
    userRaw = localStorage.getItem("user");
    if (!userRaw) {
      window.location.replace("https://learningview.org/app?requireCordova=1");
    }
  }catch(e){
    window.location.replace("https://learningview.org/app?requireCordova=1");
  };
  var user = userRaw ? JSON.parse(userRaw) : null;
  if(user){
    var res = fetch("https://learningview.org/api/loginUser.php", {
      method: "POST",
      headers: {
        'Content-Type': 'application/x-www-form-urlencoded'
      },
      credentials: "include",
      body: new URLSearchParams({
        uid: user.ID,
        salt: user.Salt,
        handoff:1
      })
    }).then(function(res){return res.json();}).then(function(data){
      localStorage.removeItem("user"); // remove it now on localhost
      if (data.result != "OK") {
        window.location.replace("https://learningview.org/app?requireCordova=1");
      }else
        window.location.replace(
          "https://learningview.org/app?requireCordova=1" +
          "&handoff=" + encodeURIComponent(data.handoff) +
          "&device=" + (resolveCordovaDeviceParam("") === "ios" ? "ios" : "android") +
          "&version=" + encodeURIComponent(window.cordovaAppVersionNumber || "")
        );
    });    
  }else{
    localStorage.removeItem("user"); // remove it now on localhost
    window.location.replace("https://learningview.org/app?requireCordova=1");
  }
}

var today = new Date();
// Check if it's October 31st
var isHalloween = today.getMonth() === 9 && today.getDate() === 31;
if (isHalloween) {
  var d = $('<div style="z-index:999999;opacity:0.75;position:absolute;left:0;top:0;width:100%;height:100%;display:flex;background:black;justify-content:center;align-items:center">'+
            '<video poster="data:image/gif;base64,R0lGODlhAQABAAD/ACwAAAAAAQABAAACADs=" style="height:100vh;width:auto;pointer-events:none;" src="https://learningview.org/app/Halloween.mp4" autoplay muted playsinline></video></div>');
  $("body").append(d);
  var timer = setTimeout(function(){
    $(d).fadeOut(7000, function() {
      $(this).remove();
    });    
  },4000);
  $(d).on("click",function(){
    clearTimeout(timer);
    $(d).css("pointer-events","none");
    $(d).stop(true).fadeOut(1000, function() {
      $(this).remove();
    });  
  });
}

window.isIOSDevice = false;
window.isIOSDevice = (/iPad|iPhone|iPod/i).test(navigator.userAgent) && !window.MSStream;
window.isIOSDevice = window.isIOSDevice || (/MacIntel/.test(navigator.platform) && navigator.maxTouchPoints && navigator.maxTouchPoints > 2);
window.isIOSDevice = typeof(device) != "undefined" ? device.platform == "iOS" || device.platform.match(/iPad|iPhone|iPod/i) : window.isIOSDevice;
window.isIPad = (navigator.platform === 'iPad' || (navigator.platform === 'MacIntel' && navigator.maxTouchPoints > 2));

window.isAndroidDevice = false;
window.isAndroidDevice = (/android/i).test(navigator.userAgent);
window.isAndroidDevice = window.isAndroidDevice || (/linux armv7l/i).test(navigator.userAgent);
window.isAndroidDevice = typeof(device) != "undefined" ? device.platform == "Android" || device.platform.match(/Android/i) : window.isAndroidDevice;
if(window.isAndroidDevice){
  function getAndroidVersion(ua) {
    ua = (ua || navigator.userAgent).toLowerCase(); 
    var match = ua.match(/android\s([0-9\.]*)/i);
    return match ? match[1] : undefined;
  };
  window.androidVersion = parseInt(getAndroidVersion(), 10); // get only main version number
}

var windowsPlatforms = ['win32', 'win64', 'windows'];
window.isWindowsDevice = windowsPlatforms.indexOf(navigator.platform.toLowerCase()) >= 0;

window.isMacDevice = !window.isIOSDevice && navigator.platform.toLowerCase().indexOf("mac") >= 0;

window.cordovaAppVersionNumber = 0;
console.log("Device detected:"+(window.isMacDevice ? ' MAC ':'')
                              +(window.isAndroidDevice ? ' Android '+window.androidVersion+' ':'')
                              +(window.isIOSDevice ? ' iOS ':'')
                              +(window.isIPad ? ' iPad ':'')
);
if(window.isIOSDevice) $('html').addClass("iOSDevice");

var initCordovaDone = false;
function initCordova(){
  if(initCordovaDone) return;
  if(window.isElectron) return; // no cordova here
  initCordovaDone = true;
  if(cordova.getAppVersion){
    cordova.getAppVersion.getVersionNumber(function (version) {
        // get a version like "2.4.12" replace to 204012
        version = version.replace(/\./g,"0");
        window.cordovaAppVersionNumber = parseInt(version);
    });
  }

  if(window.androidVersion >= 13 && typeof(cordova) != "undefined" && cordova.plugins && cordova.plugins.permissions){
    var permissions = cordova.plugins.permissions;
    var notificationPermission = permissions.POST_NOTIFICATIONS;
    var notificationPermissionRequestStarted = false;

    var removeNotificationPermissionInteractionHooks = function(){
      document.removeEventListener("touchstart", onNotificationPermissionFirstInteraction, true);
      document.removeEventListener("mousedown", onNotificationPermissionFirstInteraction, true);
    };

    var requestNotificationPermission = function(trigger){
      if(notificationPermissionRequestStarted) return;
      notificationPermissionRequestStarted = true;
      removeNotificationPermissionInteractionHooks();

      permissions.checkPermission(notificationPermission, function(status){
        if(status && status.hasPermission){
          console.log("Notification permission already granted ("+trigger+")");
          return;
        }

        var onGrantResult = function(resultStatus){
          if(resultStatus && resultStatus.hasPermission ) {
            console.log("Notification permission granted ("+trigger+")");
          }else{
            console.log("Notification permission denied ("+trigger+")");
          }
        };
        var onGrantError = function(err){
          console.log("Notification permission denied ("+trigger+")");
          if(err) console.error("Notification permission request error:", err);
        };

        if(typeof permissions.requestPermission === "function"){
          permissions.requestPermission(notificationPermission, onGrantResult, onGrantError);
        }else{
          permissions.requestPermissions([notificationPermission], onGrantResult, onGrantError);
        }
      }, function(err){
        console.error("Notification permission check error:", err);
      });
    };

    var onNotificationPermissionFirstInteraction = function(){
      requestNotificationPermission("first-interaction");
    };

    // Ask slightly delayed to avoid blocking/frozen system dialog during startup.
    setTimeout(function(){
      requestNotificationPermission("delayed-startup");
    }, 800);

    // Fallback: if delayed request did not run yet, ask on first interaction.
    document.addEventListener("touchstart", onNotificationPermissionFirstInteraction, true);
    document.addEventListener("mousedown", onNotificationPermissionFirstInteraction, true);
  }

  var viewport = document.querySelector("meta[name=viewport]");
  if(window.isIOSDevice){
    viewport.setAttribute('content', 'user-scalable=no, width=device-width,height=device-height, viewport-fit=cover');
    
    // iPad hack with inset padding issue 
    setTimeout(function(){ 
      $('.bodywrapper').hide();
      $("body").css({height:"110%"}); 
      setTimeout(function(){ 
        $("body").css({height:"100%"}); 
        $('.bodywrapper').show();
      }, 50);
    }, 100);
  }

  if(window.isAndroidDevice){
    viewport.setAttribute('content', 'user-scalable=no, width=device-width, height=device-height');

    document.addEventListener("pause", function(){
      window.wasPaused = true;
      // save some state
    }, false);

    window.onResumeEvent = function(event){
      // check if a reload happend
      if(window.wasPaused){
        window.wasPaused = false;
        //return;
      }
      if(event.pendingResult) console.log(event.pendingResult);

      if(event && navigator.camera){
        if(event.pendingResult &&
           event.pendingResult.pluginServiceName == "Camera" &&
           event.pendingResult.pluginStatus === "OK"){
          // Android camera took image and app restarted
          // result URL to file will be part of event now
          console.log(event.pendingResult.result);
          var text = "Du hast ein Foto/Video aufgenommen, aber Android hat LearningView im Hintergrund beendet. Bitte gehe jetzt noch einmal an die Stelle, wo du deinen Beitrag einfügen wolltest und wähle diesmal das Foto/Video aus der Gallery aus.";
          setTimeout(function(){
            if(window.mc) mc.alert(text); else alert(text);
          },2000);
        }
      }
    }
  }

  if(cordova.InAppBrowser && window.open != cordova.InAppBrowser.open)
    window.open = cordova.InAppBrowser.open;

  screenWidth = $(window).width();

  if(typeof(screen.unlockOrientation) != "undefined"){
    screen.unlockOrientation();
  }

//  if(typeof(StatusBar) != "undefined" && device.platform != 'android' &&
//     device.platform != 'Android') StatusBar.hide();

  var hasFirebaseTokenApi = !!(window.FirebasePlugin && window.FirebasePlugin.getToken);
  var apnsPushPluginStarted = false;
  var apnsTokenAvailable = false;

  function initApnsPushPlugin(reason) {
    if (apnsPushPluginStarted) return;
    if (!window.isIOSDevice) return;
    if (typeof(window.APNSPushNotification) == "undefined" ||
        typeof(window.APNSPushNotification.init) == "undefined") {
      console.warn("APNSPushNotification init unavailable for reason:", reason);
      return;
    }
    apnsPushPluginStarted = true;
    console.log("Init APNSPushNotification (" + reason + ")");
    var push = window['APNSPushNotification'].init({
      ios: {
        apnsForce:"true",
        alert: "true",
        badge: "true",
        sound: "true",
        clearBadge:true
      }
    });
    push.on('registration', function(data) {
      console.log("APNSPushNotification:", data);
      if(data.registrationId && data.registrationId != ""){
        apnsTokenAvailable = true;
        try{
          localStorage.setItem("APNSToken",data.registrationId);
          console.log("APNSToken:"+data.registrationId);
        }catch(e){}
      }
    });
    push.on('notification', function(data) {
      //cordova.plugins.notification.local.schedule({
      //  title: data.title,
      //  text: data.message,
      //  sound: data.sound,
      //  at: new Date().getTime()
      //});
    });
  }

  // new APNS plugin for iOS 
  console.log("APNSPushNotification:" + ((typeof(window.APNSPushNotification) != "undefined") ? 'YES':'NO'));
  if(window.isIOSDevice && hasFirebaseTokenApi){
    console.log("Skip APNSPushNotification init because FirebasePlugin is active.");
  } else if(window.isIOSDevice){
    initApnsPushPlugin("primary");
  }

  console.log("FCM:" +((window.FCM && window.FCM.getToken) ? 'YES':'NO'));
  // will also register on iOS if it works
  // current android plugin cordova-plugin-push-notifications
  console.log("FirebasePlugin:" + ((window.FirebasePlugin && window.FirebasePlugin.getToken) ? 'YES':'NO'));

  if (hasFirebaseTokenApi) {
    console.log(
      "FirebasePlugin methods:",
      "hasPermission=" + (typeof window.FirebasePlugin.hasPermission === "function" ? "YES" : "NO"),
      "grantPermission=" + (typeof window.FirebasePlugin.grantPermission === "function" ? "YES" : "NO"),
      "getAPNSToken=" + (typeof window.FirebasePlugin.getAPNSToken === "function" ? "YES" : "NO"),
      "onTokenRefresh=" + (typeof window.FirebasePlugin.onTokenRefresh === "function" ? "YES" : "NO"),
      "onMessageReceived=" + (typeof window.FirebasePlugin.onMessageReceived === "function" ? "YES" : "NO"),
      "clearAllNotifications=" + (typeof window.FirebasePlugin.clearAllNotifications === "function" ? "YES" : "NO")
    );

    var isIOSPushPath = (device.platform === "iOS");
    var gotFcmToken = false;
    var gotApnsToken = !isIOSPushPath;
    var tokenReadAttempts = 0;
    var maxTokenReadAttempts = 1;
    var retryScheduled = false;

    function tokensComplete() {
      if (isIOSPushPath) return gotFcmToken || gotApnsToken || apnsTokenAvailable;
      return gotFcmToken && gotApnsToken;
    }

    function scheduleReadTokensRetry(reason) {
      if (tokensComplete()) return;
      if (retryScheduled) return;
      if (tokenReadAttempts >= maxTokenReadAttempts) {
        console.warn("stop token retries after " + tokenReadAttempts + " attempts");
        if (isIOSPushPath && !apnsTokenAvailable) {
          console.warn("activate APNS fallback after Firebase retries exhausted");
          initApnsPushPlugin("firebase-retries-exhausted");
        }
        return;
      }
      retryScheduled = true;
      console.warn("schedule token retry (" + (tokenReadAttempts + 1) + "/" + maxTokenReadAttempts + "): " + reason);
      setTimeout(function() {
        retryScheduled = false;
        readTokens();
      }, 2000);
    }

    function callPluginWithTimeout(label, invoker, onSuccess, onError) {
      var done = false;
      var timer = setTimeout(function() {
        if (done) return;
        done = true;
        console.warn(label + " callback timeout after 5000ms");
        if (onError) onError("timeout");
      }, 5000);
      try {
        invoker(function(result) {
          if (done) return;
          done = true;
          clearTimeout(timer);
          if (onSuccess) onSuccess(result);
        }, function(error) {
          if (done) return;
          done = true;
          clearTimeout(timer);
          if (onError) onError(error);
        });
      } catch (e) {
        if (done) return;
        done = true;
        clearTimeout(timer);
        if (onError) onError(e);
      }
    }

    function readTokens() {
      tokenReadAttempts++;
      console.log("readTokens attempt " + tokenReadAttempts + "/" + maxTokenReadAttempts);
      if (isIOSPushPath && tokenReadAttempts >= 3 && !apnsTokenAvailable) {
        initApnsPushPlugin("firebase-timeout-fallback");
      }
      if (isIOSPushPath && apnsTokenAvailable) {
        gotApnsToken = true;
      }

      if (window.FirebasePlugin.getToken) {
        console.log("calling FirebasePlugin.getToken");
        callPluginWithTimeout("getToken", function(success, error){
          window.FirebasePlugin.getToken(success, error);
        }, function(token) {
          console.log("FCM token:", token);
          if (token) {
            gotFcmToken = true;
            localStorage.setItem("FCMToken", token);
            localStorage.setItem("GCMToken", token);
          } else {
            scheduleReadTokensRetry("empty-fcm-token");
          }
        }, function(err) {
          console.error("getToken error:", err);
          scheduleReadTokensRetry("getToken-error");
        });
      } else {
        console.warn("FirebasePlugin.getToken missing");
      }

      if (isIOSPushPath) {
        if (window.FirebasePlugin.getAPNSToken) {
          console.log("calling FirebasePlugin.getAPNSToken");
          callPluginWithTimeout("getAPNSToken", function(success, error){
            window.FirebasePlugin.getAPNSToken(success, error);
          }, function(token) {
            console.log("APNS token:", token);
            if (token) {
              gotApnsToken = true;
              apnsTokenAvailable = true;
              localStorage.setItem("APNSToken", token);
            } else {
              scheduleReadTokensRetry("empty-apns-token");
            }
          }, function(err) {
            console.error("getAPNSToken error:", err);
            scheduleReadTokensRetry("getAPNSToken-error");
          });
        } else {
          console.warn("FirebasePlugin.getAPNSToken missing on iOS");
          gotApnsToken = true;
        }
      }

      if (!tokensComplete()) {
        scheduleReadTokensRetry("tokens-not-complete");
      } else {
        console.log("push tokens complete");
      }
    }

    if (isIOSPushPath && typeof window.FirebasePlugin.grantPermission === "function") {
      console.log("calling FirebasePlugin.grantPermission preflight on iOS");
      window.FirebasePlugin.grantPermission(function(result) {
        console.log("grantPermission preflight success:", result);
      }, function(error) {
        console.error("grantPermission preflight error:", error);
      });
    }

    if (typeof window.FirebasePlugin.hasPermission === "function") {
      console.log("calling FirebasePlugin.hasPermission");
      var permissionCallbackDone = false;
      window.FirebasePlugin.hasPermission(function(hasPermission) {
        permissionCallbackDone = true;
        console.log("hasPermission result:", hasPermission);
        if (hasPermission) {
          readTokens();
        } else {
          if (typeof window.FirebasePlugin.grantPermission === "function") {
            console.log("calling FirebasePlugin.grantPermission");

            window.FirebasePlugin.grantPermission(function(result) {
              console.log("grantPermission success:", result);
              readTokens();
            }, function(error) {
              console.error("grantPermission error:", error);
              readTokens();
            });

            // Fallback, falls Callback nicht kommt
            setTimeout(readTokens, 3000);
          } else {
            console.warn("FirebasePlugin.grantPermission missing, continue with readTokens");
            readTokens();
          }
        }
      }, function(err) {
        permissionCallbackDone = true;
        console.error("hasPermission error:", err);
        readTokens();
      });
      setTimeout(function(){
        if(!permissionCallbackDone){
          console.warn("hasPermission callback timeout after 3000ms, continue with readTokens");
          readTokens();
        }
      },3000);
    } else {
      console.warn("FirebasePlugin.hasPermission missing, continue with readTokens");
      readTokens();
    }

    if (typeof window.FirebasePlugin.onTokenRefresh === "function") {
      console.log("register FirebasePlugin.onTokenRefresh");
      window.FirebasePlugin.onTokenRefresh(function(token) {
        console.log("FCM token refresh:", token);
        if (token) {
          gotFcmToken = true;
          localStorage.setItem("FCMToken", token);
          localStorage.setItem("GCMToken", token);
          if (tokensComplete()) console.log("push tokens complete (token refresh)");
        }
      });
    } else {
      console.warn("FirebasePlugin.onTokenRefresh missing");
    }

    // Notification listener
    if (typeof window.FirebasePlugin.onMessageReceived === "function") {
      console.log("register FirebasePlugin.onMessageReceived");
      window.FirebasePlugin.onMessageReceived(function(payload) {
        console.log("Push Notification:", payload);
      });
    } else {
      console.warn("FirebasePlugin.onMessageReceived missing");
    }

    // Clear all notifications (Android only)
    if (device.platform === 'Android' && typeof window.FirebasePlugin.clearAllNotifications === "function") {
      window.FirebasePlugin.clearAllNotifications();
    }
  }else  
  if(window.FCM && window.FCM.getToken){
    if(device.platform == 'android' || device.platform == 'Android')
      window.FCM.getToken().then(function(key){
        try{
          if(key && key != '')
            localStorage.setItem("GCMToken",key);
        }catch(e){}
      });
    if(window.isIOSDevice)
      window.FCM.getAPNSToken().then(function(key){
        try{
          if(key && key != '')
            localStorage.setItem("APNSToken",key);
        }catch(e){}
      });
    FCM.onTokenRefresh(function(key){
      try{
        if(key && key != ''){
          if(device.platform == 'android' || device.platform == 'Android')
            localStorage.setItem("GCMToken",key);
          if(window.isIOSDevice)
            localStorage.setItem("APNSToken",key);
        }
      }catch(e){}
    });
    FCM.onNotification(function(payload){
      console.log("Push Notification:",payload);
    });
    FCM.clearAllNotifications(); // clear them now
  }else
  // old plugin for Android
  console.log("Old PushNotification:" +((typeof(PushNotification) != "undefined" && typeof(PushNotification.init) != "undefined" ) ? 'YES':'NO'));

  if(typeof(PushNotification) != "undefined" && typeof(PushNotification.init) != "undefined" ){

    var push = PushNotification.init({ "android": {"senderID": "1019033420306"}, "ios": {clearBadge:true}, "windows": {} } );
     // "icon": "whiteicon", "iconColor": "#03A9F4"
    push.on('registration', function(data) {
      if(data.registrationId != ""){
        try{
        if ( device.platform == 'android' || device.platform == 'Android' )
          localStorage.setItem("GCMToken",data.registrationId); else
          localStorage.setItem("APNSToken",data.registrationId);
        }catch(e){}
      }
    });

    push.on('notification', function(data) {
      if(!data.additionalData) data.additionalData = {};
      if(!data.additionalData.appdata) data.additionalData.appdata = "";

      if(mc && mc.lastPushNotification != data.message + data.additionalData.appdata) {
        var processed = false;
        if(data.additionalData && data.additionalData.appdata){
          var a = typeof data.additionalData.appdata == "string" ? JSON.parse(data.additionalData.appdata) : data.additionalData.appdata;
          if(a.action == "feedbackReceived"){
            //if(mc) mc.alert("Du hast zur Aufgabe &laquo;"+a.Name+"&raquo; ein Feedback erhalten. Schau in dein Lernjournal, um es zu lesen.");
            processed = true;
          }
          if(a.action == "taskStatusOK"){
            //if(mc) mc.alert("Die Aufgabe &laquo;"+a.Name+"&raquo; wurde als erledigt markiert.");
            processed = true;
          }
          if(a.action == "taskStatusRejected"){
            //if(mc) mc.alert("Die Aufgabe &laquo;"+a.Name+"&raquo; muss nochmals überarbeitet werden.");
            processed = true;
          }

          if(a.action == "newMainTopic"){
            //if(mc) mc.alert("Eine neuer Lernbereich &laquo;"+a.Name+"&raquo; wurde hinzugefügt.");
            processed = true;
          }
          if(a.action == "newTopic"){
            //if(mc) mc.alert("Ein neues Thema &laquo;"+a.Name+"&raquo; wurde zum Lernbereich &laquo;"+a.MainTopicName+"&raquo; hinzugefügt.");
            processed = true;
          }
          if(a.action == "newTask"){
            //if(mc) mc.alert("Eine neue Aufgabe &laquo;"+a.Name+"&raquo; wurde zum Thema &laquo;"+a.TopicName+"&raquo; hinzugefügt.");
            processed = true;
          }
          if(a.action == "goalStatusChanged"){
            //if(mc) mc.alert(data.message);
            processed = true;
          }
        }
        if(!processed && mc.alert) mc.alert(data.message);
      }
      mc.lastPushNotification = data.message + data.additionalData.appdata;
        // data.message,
        // data.title,
        // data.count,
        // data.sound,
        // data.image,
        // data.additionalData
    });

    push.on('error', function(e) {
        // e.message
      if(mc.alert) mc.alert(e.message);
    });
  }
}

