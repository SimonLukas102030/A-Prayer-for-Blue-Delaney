    self.removeMainTopic = function(it,ev,force){
      self.confirm($filter('trans')(it.shareSettings && it.shareSettings.length > 1 ? (it.Owner == self.user.ID ? 'REMOVESHAREDMAINTOPIC' : 'REMOVEMAINTOPICSHARE') : 'REMOVEMAINTOPIC',it.Name),$filter('trans')(it.Owner == self.user.ID ? 'DELETE':'REMOVE'),ev).then(function(){
        self.apiPost("ajax",{"action":"removeMainTopic", "ID":it.ID})
         .then(function(data) {
           self.userContent.mainTopics.splice(self.userContent.mainTopics.indexOf(it),1);
           self.updateMainTopicsOrder();
           $mdDialog.hide();
           self.keepAliveCallback();
         },function(data){
           self.alert("Entfernen fehlgeschlagen: "+data.error);
         });
      });
    };

