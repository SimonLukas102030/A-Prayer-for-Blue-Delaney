        self.lastToTime = vTo || self.lastToTime;
      }).then(self.keepAliveCallback);
    };
    self.updateClassTaskTimes = function(it,c,vFrom,vTo){
      self.apiPost("ajax",{"action":"setClassesTaskTimes","ID":it.ID, "classid":c.ID, "vFrom":vFrom, "vTo":vTo}).then(function(){
        it.vFrom = vFrom;
