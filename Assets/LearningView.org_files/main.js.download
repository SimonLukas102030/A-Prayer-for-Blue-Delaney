function AudioRecorderService() {
  window.AudioContext = window.AudioContext || window.webkitAudioContext;
  var self = this;

  self.state = 'inactive';
  self._didComplete = false;
  self.chunks = [];
  self.chunkType = '';

  self.encoderMimeType = 'audio/wav';

  self.config = {
    manualEncoderId: 'wav',
    micGain: 1.0,
    processorBufferSize: 4096,
    stopTracksAndCloseCtxWhenFinished: true,
    usingMediaRecorder: typeof window.MediaRecorder !== 'undefined',
    userMediaConstraints: { audio: { echoCancellation: false } }
    // echoCancellation = false will play audio on earpiece now not speakers anymore
    // all audio will be almost silent from now on, we need to reset it after recording
  };

  // android does not like echoCancellation:false, override
  if(window.isAndroidDevice){
    self.config.userMediaConstraints.audio = true;
  }
  if(window.isIOSDevice){
    if(navigator.audioSession) navigator.audioSession.type = 'play-and-record';
    /*
    self.config.userMediaConstraints.audio = { 
                        channels: 1, 
                        autoGainControl: false, 
                        echoCancellation: false, 
                        noiseSuppression: false,
                        voiceIsolation: false
                    };
    */
    self.config.userMediaConstraints.audio = true;
  }

  self._resetAudioSession = function(){
    if(navigator.audioSession) navigator.audioSession.type = 'playback';
    setTimeout(function(){
      if(navigator.audioSession) navigator.audioSession.type = 'auto';
    },100);
  };

  self._cleanupAfterStop = function () {
    if (self.meterNodeRaw) {
      self.meterNodeRaw.disconnect();
      self.meterNodeRaw.onaudioprocess = null;
      self.meterNodeRaw = null;
    }
    if (self.destinationNode) {
      self.destinationNode.disconnect();
      self.destinationNode = null;
    }
    if (self.outputGainNode) {
      self.outputGainNode.disconnect();
      self.outputGainNode = null;
    }
    if (self.processorNode) {
      self.processorNode.disconnect();
      self.processorNode = null;
    }
    if (self.recordProcessor) {
      self.recordProcessor.disconnect();
      self.recordProcessor = null;
    }
    if (self.encoderWorker) {
      try{
        self.encoderWorker.postMessage(['close']);
      }catch(e){
        console.log('encoder worker close failed', e);
      }
      self.encoderWorker = null;
    }
    if (self.micGainNode) {
      self.micGainNode.disconnect();
      self.micGainNode = null;
    }
    if (self.inputStreamNode) {
      self.inputStreamNode.disconnect();
      self.inputStreamNode = null;
    }
    if (self.config.stopTracksAndCloseCtxWhenFinished) {
      if (self.micAudioStreamClone && self.micAudioStreamClone.getTracks) {
        self.micAudioStreamClone.getTracks().forEach(function(track){track.stop()});
      }
      if (self.micAudioStream && self.micAudioStream.getTracks) {
        self.micAudioStream.getTracks().forEach(function(track){track.stop()});
      }
      self.micAudioStreamClone = null;
      self.micAudioStream = null;

      if (self.audioCtx && typeof self.audioCtx.close === 'function') {
        try{
          var closePromise = self.audioCtx.close();
          if(closePromise && closePromise.catch) closePromise.catch(function(){});
        }catch(e){
          console.log('audioCtx close failed', e);
        }
      }
      if(self.audioCtx == window.globalAudioContextRecord) window.globalAudioContextRecord = null;
      self.audioCtx = null;
      self._resetAudioSession();
    }
  };

  /* Returns promise */
  self.startRecording = function (success, err) {
    if (self.state !== 'inactive') {
      return;
    }

    if (!navigator || !navigator.mediaDevices || !navigator.mediaDevices.getUserMedia) {
      if(err) err();
      return;
    }


    // Create web worker for doing the encoding
    if (!self.config.usingMediaRecorder) {

      // URL.createObjectURL
      window.URL = window.URL || window.webkitURL;

      var workerCode = 'let BYTES_PER_SAMPLE=2,recorded=[];function encode(e){let t=e.length,n=new Uint8Array(t*BYTES_PER_SAMPLE);for(let d=0;d<t;d++){let t=d*BYTES_PER_SAMPLE,r=e[d];r>1?r=1:r<-1&&(r=-1),r*=32768,n[t]=r,n[t+1]=r>>8}recorded.push(n)}function dump(e){let t=recorded.length?recorded[0].length:0,n=recorded.length*t,d=new Uint8Array(44+n),r=new DataView(d.buffer);r.setUint32(0,1380533830,!1),r.setUint32(4,36+n,!0),r.setUint32(8,1463899717,!1),r.setUint32(12,1718449184,!1),r.setUint32(16,16,!0),r.setUint16(20,1,!0),r.setUint16(22,1,!0),r.setUint32(24,e,!0),r.setUint32(28,e*BYTES_PER_SAMPLE,!0),r.setUint16(32,BYTES_PER_SAMPLE,!0),r.setUint16(34,8*BYTES_PER_SAMPLE,!0),r.setUint32(36,1684108385,!1),r.setUint32(40,n,!0);for(var s=0;s<recorded.length;s++)d.set(recorded[s],s*t+44);recorded=[];let o=[d.buffer];postMessage(o,[o[0]])}onmessage=function(e){"encode"===e.data[0]?encode(e.data[1]):"dump"===e.data[0]?dump(e.data[1]):"close"===e.data[0]&&self.close()};';

      var blob;
      try {
          blob = new Blob([workerCode], {type: 'application/javascript'});
      } catch (e) { // Backwards-compatibility
          window.BlobBuilder = window.BlobBuilder || window.WebKitBlobBuilder || window.MozBlobBuilder;
          blob = new BlobBuilder();
          blob.append(workerCode);
          blob = blob.getBlob();
      }

      self.encoderWorker = new Worker(URL.createObjectURL(blob));
      self.encoderMimeType = 'audio/wav';

      self.encoderWorker.addEventListener('message', function(e) {
        var event = new Event('dataavailable');
        event.data = new Blob(e.data, { type: self.encoderMimeType });
        self._onDataAvailable(event);
      })
    }

    // This will prompt user for permission if needed
    return navigator.mediaDevices.getUserMedia(self.config.userMediaConstraints)
      .then(function(stream) {
        self._startRecordingWithStream(stream);
        if(success) success();
      })
      .catch(function(error) {
        if(err) err(error);
        console.log(error);
      })
  }

  function encodeWav(chunks, sampleRate) {
    var totalLength = chunks.reduce(function(sum, arr) {
      return sum + arr.length;
    }, 0);
    var input = new Float32Array(totalLength);
    let offset = 0;
    for (var chunk of chunks) {
      input.set(chunk, offset);
      offset += chunk.length;
    }

    function floatTo16BitPCM(output, offset, input) {
      for (var i = 0; i < input.length; i++, offset += 2) {
        var s = Math.max(-1, Math.min(1, input[i]));
        output.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
      }
    }

    function writeString(view, offset, string) {
      for (var i = 0; i < string.length; i++) {
        view.setUint8(offset + i, string.charCodeAt(i));
      }
    }

    var buffer = new ArrayBuffer(44 + input.length * 2);
    var view = new DataView(buffer);
    var channels = 1;
    /* RIFF identifier */
    writeString(view, 0, 'RIFF');
    /* RIFF chunk length */
    view.setUint32(4, 36 + input.length * 2, true);
    /* RIFF type */
    writeString(view, 8, 'WAVE');
    /* format chunk identifier */
    writeString(view, 12, 'fmt ');
    /* format chunk length */
    view.setUint32(16, 16, true);
    /* sample format (raw) */
    view.setUint16(20, 1, true);
    /* channel count */
    view.setUint16(22, channels, true);
    /* sample rate */
    view.setUint32(24, sampleRate, true);
    /* byte rate (sample rate * block align) */
    view.setUint32(28, sampleRate * channels * 2, true);
    /* block align (channel count * bytes per sample) */
    view.setUint16(32, channels * 2, true);
    /* bits per sample */
    view.setUint16(34, 16, true);
    /* data chunk identifier */
    writeString(view, 36, 'data');
    /* data chunk length */
    view.setUint32(40, input.length * 2, true);

    floatTo16BitPCM(view, 44, input);
    var audioBlob = new Blob([view], {type: "audio/wav"});
    return audioBlob;
  }

  self._startRecordingWithStream = function (stream) {
    self._didComplete = false;
    self.chunks = [];
    self.chunkType = '';
    self.recordProcessorData = [];

    self.micAudioStream = stream;
    self.micAudioStreamClone = stream.clone();

    if(!window.globalAudioContextRecord){
      window.globalAudioContextRecord = createAudioContext(0);
    }
    var audioCtx = window.globalAudioContextRecord;

    self.inputStreamNode = audioCtx.createMediaStreamSource(self.micAudioStreamClone);
    self.audioCtx = self.inputStreamNode.context;


    self.micGainNode = self.audioCtx.createGain();
    self.outputGainNode = self.audioCtx.createGain();
 
    if (!self.config.usingMediaRecorder) {
      self.processorNode = self.audioCtx.createScriptProcessor(self.config.processorBufferSize, 1, 1);
    }

    if (self.audioCtx.createMediaStreamDestination) {
      self.destinationNode = self.audioCtx.createMediaStreamDestination();
    }
    else {
      self.destinationNode = self.audioCtx.destination;
    }

    // Allow optionally hooking in to audioGraph inputStreamNode, useful for meters
    if (self.onGraphSetupWithInputStream) {
      self.onGraphSetupWithInputStream(self.inputStreamNode);
    }

    self.inputStreamNode.connect(self.micGainNode);
    self.micGainNode.gain.setValueAtTime(self.config.micGain, self.audioCtx.currentTime);

    self.state = 'recording';

    // special case for iOS 18+ issues even with MediaRecorder and missing chunks
    if (window.isIOSDevice) {
      self.recordProcessor = self.audioCtx.createScriptProcessor(self.config.processorBufferSize, 1, 1);
      self.recordProcessorData = [];
      self.recordProcessor.onaudioprocess = function(e){
        self.recordProcessorData.push(new Float32Array(e.inputBuffer.getChannelData(0)));
      };
      self.micGainNode.connect(self.recordProcessor);
      self.recordProcessor.connect(self.outputGainNode);
    }else
    if (self.processorNode) {
      self.micGainNode.connect(self.processorNode)
      self.processorNode.connect(self.outputGainNode)
      self.processorNode.onaudioprocess = function(e) { self._onAudioProcess(e); };
    }
    else {
      self.micGainNode.connect(self.outputGainNode);
    }

    self.outputGainNode.connect(self.destinationNode);

    if (self.config.usingMediaRecorder) {
      self.mediaRecorder = new MediaRecorder(self.micAudioStream //,{audioBitsPerSecond : 128000}
      );
      if (!window.isIOSDevice)
        self.mediaRecorder.addEventListener('dataavailable',function(evt) { self._onDataAvailable(evt);});
      self.mediaRecorder.addEventListener('error', function(evt){ self._onError(evt);} );
      self.mediaRecorder.start();
    }
    else {
      self.outputGainNode.gain.setValueAtTime(0, self.audioCtx.currentTime);
    }
  }

  self._onAudioProcess = function(e) {
    if (self.state === 'recording' && self.encoderWorker) {
      self.encoderWorker.postMessage(['encode', e.inputBuffer.getChannelData(0)])
    }
  }

  self.stopRecording = function () {
    if (self.state === 'inactive') {
      if (!self._didComplete && self.onError) self.onError({message:'Recorder already inactive'});
      return
    }

    if (self.config.usingMediaRecorder) {
      self.state = 'inactive';
      if (self.mediaRecorder && self.mediaRecorder.state !== "inactive") {
        try{
          self.mediaRecorder.stop();
        }catch(e){
          self._onError(e);
        }
        self.mediaRecorder = null;
      }
      if(self.recordProcessor){
        try{
          var wavBuffer = encodeWav(self.recordProcessorData,self.audioCtx.sampleRate);
          self._onDataAvailable({type:'audio/wav', data:wavBuffer});
        }catch(e){
          self._onError(e);
        }
      }
    }
    else {
      self.state = 'inactive';
      if (self.encoderWorker && self.audioCtx) {
        self.encoderWorker.postMessage(['dump', self.audioCtx.sampleRate]);
      } else {
        self._onError({message:'Encoder worker not ready'});
      }
    }
  }

  self._onDataAvailable = function (evt) {
    if (self._didComplete) return;
    self.chunks.push(evt.data)
    self.chunkType = evt.data.type

    if (self.state !== 'inactive') {      
      return;
    }
    try{
      self._didComplete = true;
      let blob = new Blob(self.chunks, { 'type': self.chunkType })
      let blobUrl = URL.createObjectURL(blob)
      var recording = {
        ts: new Date().getTime(),
        blob: blob,
        blobUrl: blobUrl,
        mimeType: blob.type,
        size: blob.size
      }
      self.chunks = []
      self.chunkType = null
      try{
        self._cleanupAfterStop();
      }catch(e){
        console.log('cleanup after error failed', e);
      }
      if(self.onComplete) self.onComplete(recording);
    }catch(e){
      self._onError(e);
    }      
  }

  self._onError = function (evt) {
    if (self._didComplete) return;
    self._didComplete = true;
    self.state = 'inactive';
    console.log('error', evt);
    self.chunks = [];
    self.chunkType = null;
    self._cleanupAfterStop();
    if(self.onError) self.onError(evt);
  };

  return self;
}

var isConsoleOpen = false;
var consoleThreshold = 160; // Change this value as needed based on the layout

setInterval(function () {
  var widthThreshold = window.outerWidth - window.innerWidth > consoleThreshold;
  var heightThreshold = window.outerHeight - window.innerHeight > consoleThreshold;
  
  if (widthThreshold || heightThreshold) {
    if(!isConsoleOpen){
      isConsoleOpen = true;
      console.log("%cStop!", "color: #F00; font-size: 30px; -webkit-text-stroke: 1px black; font-weight:bold");
      console.log("This is part of your browser intended for developers. If someone told you to copy-and-paste something here, don't do it! It could allow them to take over your LearningView account, delete your content, or do many other harmful things. If you don't understand what exactly you are doing here, you should close this window without doing anything.");
      console.log("%cStop!", "color: #F00; font-size: 30px; -webkit-text-stroke: 1px black; font-weight:bold");
      console.log("Das ist ein für Entwickler vorgesehener Teil des Browsers. Wenn dich jemand aufgefordert hat, hier etwas zu kopieren und einzufügen, tun es nicht! Dadurch könnten jemand dein LearningView-Konto übernehmen, deine Inhalte löschen oder viele andere böse Dinge tun. Wenn du nicht genau weisst, was du hier tust, solltest du dieses Fenster lieber schließen.");
    }
  } else isConsoleOpen = false;
}, 1000);

