angular.module('ngWig')
    .config(['ngWigToolbarProvider', function (ngWigToolbarProvider) {
       ngWigToolbarProvider.addCustomButton('emojis', 'nw-emojis-button');
    }])
    .component('nwEmojisButton', {
        bindings: {
          editMode: '=',
          disabled: '=',
          container: '=',
          content: '='
        },
        template: '<button class="nw-button emojis" title="Emoji" ng-click="$ctrl.click()">Emoji</button>',
        controller: function($scope,$timeout,$document) {
          var s = this;
          this.click = function(){  

            // save caret position
            var sel = null;
            var range = null;
            if (window.getSelection) {
              sel = window.getSelection();
              if (sel.getRangeAt && sel.rangeCount) {
                range = sel.getRangeAt(0);
              }
            }

            var openEmojiPicker = function(){
              var picker = null;
              mc.showDialog({
                template:
                    '<md-dialog style="min-width:300px;max-width:90%">' +
                    '  <md-content aria-label="Emoji" id="emojiPicker"></md-content>' +
                    '</md-dialog>',
                skipHide:true, // keep other dialog open
                clickOutsideToClose: true,
                onRemoving: function (event, removePromise) {
                  if(picker) picker.remove();
                },
                controller: function ($scope, $mdDialog) {
                  var pickerOptions = { 
                    data:emoji_data, // will come from emoji_data.js
                    i18n:emoji_de, 
                    locale:"de", 
                    perLine:8,
                    theme:"light", 
                    previewPosition:"none",
                    categories : ["frequent", "people", "nature", "foods", "activity", "places", "objects", "symbols"],  
                    exceptEmojis:[],
                    dynamicWidth:true,
                    emojiButtonSize: 50,
                    emojiSize: 38,
                    icons: 'solid',
                    onEmojiSelect: function(e){ 
                      console.log(e); 
                      mc.closeDialog($scope.dialogElement);
                      if(s.container[0] !== $document[0].activeElement){
                        s.container.focus();
                        // restore position
                        if(range){
                          window.getSelection().removeAllRanges();
                          document.getSelection().addRange(range);
                        }
                      }
                      var text = e.native;
                      var r = false;
                      if(s.content != "" && s.content != "<br>" && 
                         s.content != "<p></p>" && s.content != "<p><br></p>") r = pasteHtmlAtCaret(text);
                      if(!r)
                        $timeout(function(){
                          if(s.content != "" && s.content != "<br>" && 
                             s.content != "<p></p>" && s.content != "<p><br></p>"){
                            s.content = s.content + (text);
                          }else{
                            s.content = text;
                          }
                        },1);                  
                    }
                  };
                  setTimeout(function(){
                    pickerOptions.parent = document.querySelector('#emojiPicker');
                    picker = new EmojiMart.Picker(pickerOptions);
                  },100);
                }
              });                  
            };

            if(!window.hasEmojiPicker){
              loadScript("https://learningview.org/emojis/emoji_data.js",function(){
                loadScript("https://learningview.org/emojis/browser.js",function(){
                  window.hasEmojiPicker = true;
                  openEmojiPicker();
                });
              });
            } else {
              openEmojiPicker();
            }
          };
        }
    });

var tableSizeButtonsHTML = '';
for(var z=0; z < 6; z++){
  tableSizeButtonsHTML += '<tr>';
  for(var i=0; i < 6; i++)
    tableSizeButtonsHTML += '<td><button ng-mouseenter="doHighlight('+(i)+','+(z)+')" ng-style="{background:highlight['+(i)+']['+(z)+'] ? \'#0088d1\':\'\'}" style="cursor:pointer;border:1px solid #ddd; width:16px;height:16px;" class="needsclick" ng-click="insertTable('+(i+1)+','+(z+1)+',$event)"></button></td>';
  tableSizeButtonsHTML += '</tr>';
}

angular.module('ngWig')
    .config(['ngWigToolbarProvider', function (ngWigToolbarProvider) {
       ngWigToolbarProvider.addCustomButton('table', 'nw-table-button');
    }])
    .component('nwTableButton', {
        bindings: {
          editMode: '=',
          disabled: '=',
          container: '=',
          content: '='
        },
        template: '<button class="needsclick nw-button table" title="Tabelle" ng-click="$ctrl.click()">Table</button>'+
                  '<div style="position:absolute;z-index:10;" ng-show="showTableSize">'+
                  '<div style="background:white;border:1px solid #eee;padding:4px;text-align:center">'+
                  '<table>'+tableSizeButtonsHTML+'</table><div class="tableCellSize"></div></div></div>',

        controller: function($scope,$timeout,$document) {
          $scope.showTableSize = false;
          this.click = function(e){  
            if($scope.$parent.$parent.blendTimeout)
              $timeout.cancel($scope.$parent.$parent.blendTimeout);
            e = e || window.event;
            e.preventDefault();
            e.stopPropagation();
            $scope.showTableSize = !$scope.showTableSize;
            $(document).one("click",function(){
              $scope.showTableSize = false;
            });
          };

          var s = this;
          $scope.highlight = [];
          for(var i=0; i < 6; i++) {
            var a = [];
            for(var z=0; z < 6; z++) a.push(false);
            $scope.highlight[i] = a;
          }
          $scope.doHighlight = function(x,y){
            for(var i=0; i < 6; i++) {
              for(var z=0; z < 6; z++) $scope.highlight[i][z] = false;  
            }
            for(var i=0; i <= x; i++){
              for(var z=0; z <= y; z++){
                $scope.highlight[i][z] = true;    
              }
            }
            $('.tableCellSize').text((x+1)+' x '+(y+1));
          }
          $scope.insertTable = function(columns,rows){  
            $scope.showTableSize = false;
            var r = false;
            if(s.container[0] !== $document[0].activeElement){
              s.container.focus();
            }

            var text = '<table class="ctable">';
            for(var i=0; i < rows; i++){
              text += "<tr>";
              for(var z=0; z < columns; z++){
                text += '<td></td>'; // style="width:'+(Math.round(100*100 / columns)/100)+'%"
              }
              text += "</tr>";
            }
            text += '</table>';

            if(s.content != "" && s.content != "<br>" && 
               s.content != "<p></p>" && s.content != "<p><br></p>") r = pasteHtmlAtCaret(text);
            if(!r)
              $timeout(function(){
                if(s.content != "" && s.content != "<br>" && 
                   s.content != "<p></p>" && s.content != "<p><br></p>"){
                  s.content = s.content + textToHTML(text);
                }else{
                  s.content = textToHTML(text);
                }
              },1);
          };
        }
    });

