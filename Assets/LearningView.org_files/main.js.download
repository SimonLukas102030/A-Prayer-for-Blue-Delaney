    self.getServerTranslation = function(text,target){
      self.setLocalStorage("lastTranslationTarget",target);
      var data = {};
      data.uid = self.user ? self.user.ID : 0;
      data.salt = self.user ? self.user.Salt : '';
      data.s = text.replace(/&nbsp;/g," ").replace(/\s+/g,' ');
      data.t = target;
      var r = $http({
        url: "https://learningview.org/api/translate.php",
        method: "POST",
        withCredentials : true,
        ignoreLoadingBar: true,
        useXDomain : true,
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        transformRequest: function(obj) {
          var str = [];
          for(var p in obj)
            str.push(encodeURIComponent(p) + "=" + encodeURIComponent(obj[p]));
          return str.join("&");
        },
        data: data
      });

      var deferred = $q.defer();

      r.then(function(response){
        var data = response.data;
        if(data.result && data.result == "OK") {
          deferred.resolve(data.text);
        }else{
          deferred.reject(data);
        }
      },function(){
        // server error, no answer or no connection
        console.log(url+" failed.");
        deferred.reject({result:"FAILED", error:"CONNECTION_ERROR"});
      });

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTextContextMenu = function(text,ev){
      // will open up a context menu for text elements to be translated or read aloud

      var position = $mdPanel.newPanelPosition()
          .absolute().relativeTo(ev.target)
          .addPanelPosition('align-start', 'center')
          .addPanelPosition('align-start', 'below')
          .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.FADE);

      var config = {
        attachTo: angular.element(document.body),
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        templateUrl: "textContextMenu.html",
        controller: function ($scope, $mdPanel, mdPanelRef) {
          $scope.self = self;
          $scope.targetLanguage = self.getLocalStorage("lastTranslationTarget") ? self.getLocalStorage("lastTranslationTarget") : "en";
          $scope.setTargetLanguage = function(v){
            $scope.targetLanguage = v;
            self.setLocalStorage("lastTranslationTarget",$scope.targetLanguage);
          }
          $scope.translate = function(){
            mdPanelRef.close();
            self.showServerTranslation(text,ev);
          };
          $scope.close = function(){
            mdPanelRef.close();
          };
          $scope.readaloud = function(){
            mdPanelRef.close();
            self.showLoadingIndicator(null,function(done){
              self.getText2Speech(text,"de").then(done);
            },20000);
          };
        },
        position: position,
        openFrom: ev,
        animation: panelAnimation,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true,
        zIndex: 100
      };

      self.showPanel(config);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showServerTranslation = function(text,ev){
      self.showDialog({
        templateUrl: "showServerTranlation.html",
        skipHide:true, // keep other dialog open
        targetEvent : ev ? ev : null,
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          var t = text.replace(/<br>/g,"\n").replace(/<\/br>/g,"\n").replace(/<\/p>/g,"</p>\n")
                      .replace(/<li>/g,"\n<li> • ").replace(/<\/li>/g,"</li>\n").replace(/<\/ol>/g,"</ol>\n").replace(/<\/ul>/g,"</ul>\n");
          t = DOMPurify.sanitize(t, {ALLOWED_TAGS: [], ALLOWED_ATTR:[], KEEP_CONTENT: true});
          t = t.replace(/\n\n\n/g,"\n\n");

          $scope.text = t;
          $scope.target = self.getLocalStorage("lastTranslationTarget") ? self.getLocalStorage("lastTranslationTarget") : "en";
          $scope.translation = null;
          $scope.refresh = function(){
            $scope.translation = null;
            self.showLoadingIndicator({currentTarget:$('#serverTranslationContent').get(0)},function(done){
              // strip all html attributes from text, only keep most simple html
              self.getServerTranslation($scope.text,$scope.target).then(function(result){
                $scope.translation = result.replace(/\n/g,"<br>");
                done();
              });
            },30000);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
          $timeout(function(){ $scope.refresh(); },0)

        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getMediaID = function(){
      var today = new Date();
      var dd = today.getDate();
      var mm = today.getMonth()+1; //January is 0!
      var yyyy = today.getFullYear();
      var hh = today.getHours();
      var m = today.getMinutes();
      var ss = today.getSeconds();

      if(dd<10) dd='0'+dd;
      if(mm<10) mm='0'+mm;
      if(ss<10) ss='0'+ss;
      if(hh<10) hh='0'+hh;
      if(m<10) m='0'+m;

      return mm+'-'+dd+'-'+yyyy+'_'+hh+m+ss;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getCollectionItems = function(t,student){
      var results;
      if(student){
        var ts = self.getUserTaskStatus(t,student);
        results = [{'student': student,'status': ts}];
      }else{
        results = self.getClassTaskResultData(t);
      }
      for(var i=0; i < results.length; i++){
        results[i].collectionItems = [];
        if(results[i].status.Answer && results[i].status.Answer != ""){
          try {
            results[i].collectionItems = JSON.parse(results[i].status.Answer);
          } catch(e) {
            results[i].collectionItems = [];
          }
        }
      }
      return results;
    };

    self.getCollectionItemsCount = function(t,student){
      var count = 0;
      var results = self.getCollectionItems(t,student);
      for(var i=0; i < results.length; i++){
        count += results[i].collectionItems.length;
      }
      return count;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addCollectionRecorderScope = function($scope){
      $scope.getUserCollectionItems = function(t,withType,s){
        var current = self.getUserTaskStatus(t,s ? s : self.user,true).Answer;
        var myItems = [];
        if(current && current != "" && current[0] == "["){
          myItems = JSON.parse(current);
          if(!myItems) myItems = [];
        }
        if(withType){
          for(var i=0; i < myItems.length; i++){
            if(myItems[i].Type != withType){
              myItems.splice(i,1);
              i--;
            }
          }
        }
        return myItems;
      };


      $scope.askPartners = function(t,ev,callback){
        var now = self.currentTaskPartners;
        self.askTaskUserPartners(t,ev,self.currentTaskPartners,self.user,true).then(function(partners){
          self.currentTaskPartners = partners.join(",");
          self.currentTaskPartnerStudents = [];
          for(var i=0; i < partners.length; i++){
            var s = self.users[partners[i]];
            if(s) self.currentTaskPartnerStudents.push(s);
          }
          if(self.currentTaskPartners != now) $scope.currentTaskAnswerChanged = true;
          if(callback) callback();
        });
      };

      $scope.addCollectionItem = function(mediaType,s,ev){
        var taskStatus = self.getUserTaskStatus($scope.task,s ? s : self.user,true);
        if(self.user.Teacher == 0 && $scope.task.DataJSON.MaxItems > 0 &&
           $scope.getUserCollectionItems($scope.task,null,s).length >= $scope.task.DataJSON.MaxItems){
          self.alert($filter('trans')('NOMANYCOLLECTIONITEMS',$scope.task.DataJSON.MaxItems),ev).then(function(){
            if(!self.openCollectionResultsOpen)
                self.openCollectionResults($scope.task,s ? s : self.user,ev);
          });
          return;
        }

        var displayEditAnswer = function(){
          self.takeUserMedia(mediaType,null, function(results){
            $scope.uploadCollectionItem(results, ev);
          },{dialogMode: mediaType == 'file' ? 0 : 1, allowMultiple:true});
        }
        
        // reset for each new item created
        // will automatically use last saved getUserTaskStatus ColleaguesIDs
        self.currentTaskPartners = "";
          
        if(self.currentTaskPartners == "" && ($scope.task.Social == 'pair' || $scope.task.Social == 'group')){
          $scope.askPartners($scope.task,ev,displayEditAnswer);
        } else
          displayEditAnswer();

      };

      $scope.uploadCollectionItem = function(result, ev) {
        var filteredArray = result;
        var taskStatus = self.getUserTaskStatus($scope.task,$scope.selectedStudent ? $scope.selectedStudent : self.user,true);

        var nowItems = $scope.getUserCollectionItems($scope.task,null,$scope.selectedStudent ? $scope.selectedStudent : self.user);
        for(var i = 0; i < nowItems.length; i++){
          // item with this URL already there
          for(var ii = result.length-1; ii < 0; ii--) {
            if(nowItems[i].URL == result[ii].URL)
              filteredArray.splice(ii, 1);
          }
        }

        //t = var t = self.getTaskByID($scope.calendars[k][i].Task);?

        if(filteredArray.length == 0) return;

        if(self.user.Teacher == 0 &&
           $scope.task.DataJSON.MaxItems && $scope.task.DataJSON.MaxItems != 0 &&
           nowItems.length+filteredArray.length > $scope.task.DataJSON.MaxItems) {
           // too many items already
           if(!self.openCollectionResultsOpen)
               self.openCollectionResults($scope.task,$scope.selectedStudent ? $scope.selectedStudent : self.user,ev);
           return;
        }

        var saveStatusNow = function(status){
          // fetch again for sure
          var myItems = $scope.getUserCollectionItems($scope.task,null,$scope.selectedStudent ? $scope.selectedStudent : self.user);
          for(var i = 0; i < filteredArray.length; i++){
            if(filteredArray[i].Type == "text") {
              filteredArray[i].URL = new Date().getTime(); // fake URL for track by in collection
            }
            myItems.push(filteredArray[i]);
          }

          // if this is a peer check question, student cannot directly set OK
          if(status == "OK" && $scope.task.CheckType == 'peer' && taskStatus.Status != "OK") status = "pw";

          var overrideCheck = self.getUserTaskChecksDeep($scope.task,$scope.selectedStudent ? $scope.selectedStudent : self.user,self.currentClass);

          if(overrideCheck > 0){
            if(status == "OK" && overrideCheck >= 2) status = "?";
          }else{
            if(status == "OK" && ($scope.task.CheckType == 'teacher')) status = "?";
          }
          if(overrideCheck != 1){
            if(status == "OK" && (taskStatus.Status == "x")) status = "?";
          }

          self.track('saveTaskStatus',{ID:$scope.task.ID, status:status,"answer":JSON.stringify(myItems),
                                       "partners":self.currentTaskPartners ? self.currentTaskPartners : '',
                                       "classid":self.currentClass.ID});
          var action = {"action":"saveUserTaskStatus", "ID":$scope.task.ID,
                        "status":status,
                        "answer":JSON.stringify(myItems),
                        "delta":JSON.stringify(filteredArray),
                        "partners":self.currentTaskPartners ?
                                   self.currentTaskPartners : '',
                        "classid":self.currentClass.ID};
          if(self.user.Teacher == 1) {
            action.action = "saveTeacherTaskStatus";
            action.user = $scope.selectedStudent.ID;
            if(action.status == "?") action.status = "OK";
          }

          self.apiPost("ajax",action).then(function(){
            taskStatus.Updated = new Date();
            taskStatus.Status = action.status;
            taskStatus.Answer = JSON.stringify(myItems);
            if(action.status == "OK" && !self.openCollectionResultsOpen)
              self.openCollectionResults($scope.task,null,ev);
            self.keepAliveCallback();
          });
        };

        var saveNow = function(){
          // keep OK if already OK
          if(taskStatus.Status == "OK" &&
             nowItems.length+result.length >= $scope.task.DataJSON.MinItems){
            saveStatusNow("OK");
          } else
          if(nowItems.length+result.length >= $scope.task.DataJSON.MinItems){
            if(self.user.Teacher == 0){
              if($scope.task.CheckType == 'self' || $scope.task.CheckType == 'none'){
                saveStatusNow("OK");
              }else{
                self.confirm('<div style="text-align:center;font-weight:bold">'+$filter('trans')('ASKTOSUBMIT')+'</div>',
                             '<i class="fa fa-fw fa-check"></i> '+$filter('trans')('SUBMIT'),ev,
                             '<i class="fa fa-fw fa-pause" style="margin-top:-2px;color:#ccc;font-size:120%"></i> '+$filter('trans')('NOTDONEYET')).then(function(){
                  saveStatusNow("OK");
                },function(){
                  saveStatusNow("w");
                });                
              }
            }
            if(self.user.Teacher == 1) saveStatusNow("OK");
          } else saveStatusNow("w");
        };

        //self.currentTaskPartners = taskStatus.ColleaguesIDs && taskStatus.ColleaguesIDs != '' ? taskStatus.ColleaguesIDs : "";

        //if($scope.task.Social == 'pair' || $scope.task.Social == 'group'){
        //  self.currentTaskPartners = self.getUserTaskStatusColleagues($scope.task,self.user.Teacher == 1 ? $scope.selectedStudent : self.user); 
        //  var now = self.currentTaskPartners;
        //  self.askTaskUserPartners($scope.task,ev,self.currentTaskPartners,null,true).then(function(partners){
        //    self.currentTaskPartners = partners.join(",");
        //    if(self.currentTaskPartners != now) $scope.currentTaskAnswerChanged = true;
        //    saveNow();
        //  });
        //} else

        saveNow();

      }

      $scope.editCollectionItemTitle = function(r,item,ev){
        self.currentTaskPartners = "";
        if(item.colleagues){
          var t = [];
          for(var i=0; i < item.colleagues.length; i++){
            if(self.user.Teacher == 1 && item.colleagues[i] == r.student.ID) continue;
            if(self.user.Teacher == 0 && item.colleagues[i] == self.user.ID) continue;
            t.push(item.colleagues[i]);
          }
          self.currentTaskPartners = t.join(",");
        }        
        // should not edit while student is working on it, Answer may be overwritten
        self.prompt($filter('trans')('COLLECTINITEMTITLE'),$filter('trans')('SAVE'),$filter('trans')('COLLECTINITEMTITLEHINT'),item.Title ? item.Title : "",ev).then(function(name){
          if($.trim(name) == "") return;
          item.Title = name;
          r.status.Answer = JSON.stringify(r.collectionItems);
          self.track('saveTaskStatus',{ID:$scope.task.ID, status:r.status.Status,"answer":r.status.Answer,
                                       "partners":self.currentTaskPartners ? self.currentTaskPartners : '',
                                       "classid":self.currentClass.ID});
          var action = {"action":"saveUserTaskStatus", "ID":$scope.task.ID,
                        "status":r.status.Status,
                        "answer":r.status.Answer,
                        "delta":JSON.stringify([item]),
                        "partners":self.currentTaskPartners ? self.currentTaskPartners : '', // reuse the colleagues element here
                        "classid":self.currentClass.ID};
          if(self.user.Teacher == 1) {
            action.action = "saveTeacherTaskStatus";
            action.user = r.student.ID;
          }
          self.apiPost("ajax",action).then(function(){
            $scope.refresh();
          });
        });
      };

      $scope.editCollectionItemText = function(r,item,ev){
        // should not edit while student is working on it, Answer may be overwritten
        // here we need a docID based on the item
        self.currentTaskPartners = "";
        if(item.colleagues){
          var t = [];
          for(var i=0; i < item.colleagues.length; i++){
            if(self.user.Teacher == 1 && item.colleagues[i] == r.student.ID) continue;
            if(self.user.Teacher == 0 && item.colleagues[i] == self.user.ID) continue;
            t.push(item.colleagues[i]);
          }
          self.currentTaskPartners = t.join(",");
        }        

        self.showTextEditor($filter('trans')('TEXTEDITOR'),
          item.Text, $scope.task,self.user.Teacher == 1 ? r.student : self.user,($scope.task.Social == 'pair' || $scope.task.Social == 'group'),($scope.task.Groups && $scope.task.Groups != ''), null, 
          function(text){
            if(text !== null) {
              item.Text = text;
              r.status.Answer = JSON.stringify(r.collectionItems);
              self.track('saveTaskStatus',{ID:$scope.task.ID, status:r.status.Status,"answer":r.status.Answer,
                                         "partners":self.currentTaskPartners ? self.currentTaskPartners : '',
                                         "classid":self.currentClass.ID});
              var action = {"action":"saveUserTaskStatus", "ID":$scope.task.ID,
                            "status":r.status.Status,
                            "delta":JSON.stringify([item]),
                            "answer":r.status.Answer,
                            "partners":self.currentTaskPartners ? self.currentTaskPartners : '', // reuse the colleagues element here
                            "classid":self.currentClass.ID};
              if(self.user.Teacher == 1) {
                action.action = "saveTeacherTaskStatus";
                action.user = r.student.ID;
              }
              self.apiPost("ajax",action).then(function(){
                $scope.refresh();
              });
            }
          },null,false,false,ev);
      };

      $scope.editCollectionItemImage = function(r,item,ev){
        // should not edit while student is working on it, Answer may be overwritten
        // r.student
        self.showImageEditor(item.URL,$scope.task.Name,false,
                     $scope.task,r.student,ev);
      };

      $scope.deleteCollectionItem = function(r,item,ev){
        // should not edit while student is working on it, Answer may be overwritten
        // only item of this user is deleted - not for all Colleagues 
        var p = r.collectionItems.indexOf(item);
        if(p >= 0){
          self.confirm($filter('trans')('REMOVECOLLECTIONITEM',p+1),$filter('trans')('DELETE'),ev).then(function(){
            var deleted = r.collectionItems.splice(p,1);
            r.status.Answer = JSON.stringify(r.collectionItems);
            var status = r.status.Status;
            if(r.collectionItems.length < $scope.task.DataJSON.MinItems) status = "w";
            self.track('saveTaskStatus',{ID:$scope.task.ID, status:status,"answer":r.status.Answer,
                                       "partners":self.currentTaskPartners ? self.currentTaskPartners : '',
                                       "classid":self.currentClass.ID});
            var action = {"action":"saveUserTaskStatus", "ID":$scope.task.ID,
                          "status":status,
                          "answer":r.status.Answer,
                          "classid":self.currentClass.ID};
            if(self.user.Teacher == 1) {
              action.action = "saveTeacherTaskStatus";
              action.user = r.student.ID;
            }
            self.apiPost("ajax",action).then(function(){
              $scope.refresh();
            });
          });
        }
      };

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.askToZIPFiles = function(e, type, options, callback) {
      options = options || {};

      self.confirm($filter('trans')('ASKZIPFILE'), $filter('trans')('ZIP'))
        .then(function() {
          return self.buildZIPFromFiles(e.files); // -> Promise<File> (zipFile)
        })
        .then(function(zipFile) {

          // Synthetisches Event-Objekt wie ein Input-Event:
          var eZip = { files: [zipFile] };

          // neue Options für den erneuten Call
          var nextOptions = angular.copy(options);

          // wichtig: Index/IndexArray resetten, weil wir nun genau 1 Datei haben
          nextOptions.index = 0;
          nextOptions.indexArray = null;

          // jetzt denselben Flow erneut starten, aber mit ZIP
          callback(eZip, type, nextOptions);
        });
    };

    self.ensureJSZip = function() {
      return new Promise(function(resolve, reject){
        // bereits geladen
        if (window.JSZip) {
          resolve();
          return;
        }

        // Script schon im DOM (z.B. paralleler Load)
        var existing = document.querySelector('script[data-jszip]');
        if (existing) {
          existing.addEventListener("load", resolve);
          existing.addEventListener("error", reject);
          return;
        }

        // Script dynamisch laden
        var script = document.createElement("script");
        script.src = "https://learningview.org/app/libs/zip/jszip.min.js";
        script.async = true;
        script.setAttribute("data-jszip","true");

        script.onload = function(){
          resolve();
        };

        script.onerror = function(){
          reject("JSZip konnte nicht geladen werden");
        };
        document.head.appendChild(script);
      });
    };

    self.makeZipUploadObject = function(blob, zipName) {
      try {
        var f = new File([blob], zipName, { type: "application/zip", lastModified: Date.now() });

        // iOS/Polyfill-Bug erkennen: falsche Struktur oder size 0 oder name nicht string
        if (f && typeof f.name === "string" && f.name === zipName && typeof f.size === "number" && f.size > 0) {
          return f;
        }
      } catch (e) {}

      try {
        Object.defineProperty(blob, "name", { value: zipName, writable: false, configurable: true });
      } catch (e) {
        blob.name = zipName; 
      }
      try {
        Object.defineProperty(blob, "lastModified", { value: Date.now(), writable: false, configurable: true });
      } catch (e) {
        blob.lastModified = Date.now();
      }
      return blob;
    };
    self.buildZIPFromFiles = function(fileList) {
      return self.ensureJSZip().then(function(){
        var zip = new JSZip();
        self.isZipping = true;

        for (var i = 0; i < fileList.length; i++) {
          var f = fileList[i];
          zip.file(f.name, f);
        }

        if(self.zippingFilePanel) self.zippingFilePanel.remove();
        self.zippingFilePanel = $('<div style="display:none;background:rgb(2,136,209);color:white;position:absolute;z-index:9999999;top:0;left:0;width:100vw;height:100vh;"><div style="position:absolute;top:45%;left:0;right:0;text-align:center">Bitte warten ... <br><br><i class="fa fa-spinner fa-spin fa-4x"></i><br><br><span id="uploadFileProgress"></span><br><br><small id="uploadFileConverting">Das ist abhängig von der Dateigrösse und kann mehrere Minuten dauern.</small></div></div>');
        $("body").append(self.zippingFilePanel);
        self.zippingFilePanel.fadeIn();
        return zip.generateAsync({ type: "blob" });
      }).then(function(blob){
        var zipName;
        if (fileList.length === 1) {
          zipName = fileList[0].name + ".zip";
        } else {
          var now = new Date();
          var stamp =
            now.getFullYear() + "-" +
            String(now.getMonth()+1).padStart(2,"0") + "-" +
            String(now.getDate()).padStart(2,"0") + "_" +
            String(now.getHours()).padStart(2,"0") + "-" +
            String(now.getMinutes()).padStart(2,"0");
          zipName = "upload_" + stamp + ".zip";
        }
        return self.makeZipUploadObject(blob, zipName);
      }).catch(function(err){
        console.error(err);
        self.alert($filter('trans')('ZIP_FAILED'));
        throw err;
      }).finally(function(){
        if(self.zippingFilePanel){
          self.zippingFilePanel.fadeOut(400,function(){
            self.zippingFilePanel.remove();
          });
        }
        self.isZipping = false;
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    //1010
    self.addDropHandler = function($scope, dialogElement, possibleTypes, seperatedFiles, directSave, callback){
      //1010 / timeout for dialogElement
      if(dialogElement) {
        self.dropHandler.unshift({dialog: dialogElement, callback: function(files, text){
          if(files && files[0] && (!possibleTypes || (!(possibleTypes.length == 1 && possibleTypes[0] == "text")))) {
            if($scope.uploadFileSubmit && (possibleTypes && (possibleTypes[0] && possibleTypes.length == 1))) {
              $scope.uploadFileSubmit({files: files}, possibleTypes[0], {seperatedFiles: seperatedFiles, directSave: directSave});
              if(callback) {
                var resultArray = [];
                var d = {};

                d.URL = $scope.currentTaskAnswer;

                if($scope.audioFilename) d.Name = $scope.audioFilename;
                if($scope.videoFilename) d.Name = $scope.videoFilename;
                if($scope.fileName) d.Name = $scope.fileName;

                d.Type = $scope.type;
                resultArray.push(d);

                callback(resultArray);
              }
            }
            else {
              var resultArray = [];

              // create fake scope here
              var s = {};

              var uploadAsFile = false;
              var actualType = self.checkTypeFromFileName(files[0].name);
              for(var i = 1; i < files.length; i++) {
                if(self.checkTypeFromFileName(files[i].name) != actualType) {
                  actualType = 'file';
                  uploadAsFile = true;
                  break;
                }
              }

              s.type = actualType;

              if(possibleTypes && !uploadAsFile) {
                if(possibleTypes.indexOf(actualType) == -1)
                  actualType = possibleTypes[0];
              }

              switch(actualType) {
                case 'image':
                  self.addImageRecorderScope(s);
                  break;
                case 'audio':
                  self.addAudioRecorderScope(s);
                  break;
                case 'video':
                  self.addVideoRecorderScope(s);
                  break;
                default:
                  self.addFileRecorderScope(s);
                  break;
              }

              if(callback) {
                // we build a fake save methode to be called from uploadFileSubmit
                // and calls callback with result array
                s.save = function() {
                  if(s.multipleAnswers && s.multipleAnswers.length > 1) {
                    for(var ii = 0; ii < s.multipleAnswers.length; ii++) {
                      var d = {};

                      d.URL = s.multipleAnswers[ii].url;

                      if(s.multipleAnswers[ii].name)
                        d.Name = s.multipleAnswers[ii].name;

                      if(s.multipleAnswers[ii].type)
                        d.Type = s.multipleAnswers[ii].type;
                      else
                        d.Type = 'file';

                      resultArray.push(d);
                    }

                    if(files.length == resultArray.length)
                      callback(resultArray);
                  }
                  else {
                    var d = {};

                    d.URL = s.currentTaskAnswer;

                    if(s.audioFilename) d.Name = s.audioFilename;
                    if(s.videoFilename) d.Name = s.videoFilename;
                    if(s.fileName) d.Name = s.fileName;

                    d.Type = s.type;

                    resultArray.push(d);

                    callback(resultArray);
                  }
                };
                // calls the uploadFileSubmit function from the add...RecorderScope
                s.dialogMode = 0;
                s.uploadFileSubmit({files: files}, actualType, {dropped: true, seperatedFiles: seperatedFiles, directSave: directSave});
              }
            }
          }
          else if(!possibleTypes || (possibleTypes && possibleTypes.indexOf("text") != -1)) {
            if(text) {
              var result = [{Text: text, URL: new Date().getTime(), Type: "text"}];
              callback(result);
            }
            else {
              self.alert($filter('trans')('ONLYTEXTALLOWED'));
            }
          }
        }});
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addImageRecorderScope = function($scope, additionalFileTypes){
      $scope.imageURL = $scope.currentTaskAnswer;
      $scope.imageURLDisplay = $scope.imageURL != "" ?
        app.patchWKWebviewPath($scope.imageURL+"?r="+Math.random()) : "";
      $scope.imageFilename = "";

      $scope.showUpload = true;

      $scope.isIOSDevice = window.isIOSDevice;

      $scope.clipboardBlob = null;
      $scope.clipboardHasImage = false;

      if(!window.isIOSDevice) // skip this on ios
        readImageFromClipboard(function(blob){
          $timeout(function(){
            $scope.clipboardBlob = blob;
            $scope.clipboardHasImage = true;
          },10);
        });

      $scope.useInitialsImage = function(){
        // generate an image in memory and 
        var canvas = document.createElement("canvas");
        var context = canvas.getContext("2d");
        canvas.width = 100;
        canvas.height = 100;
        context.fillStyle = $scope.initialsImageColor;
        context.fillRect(0, 0, canvas.width, canvas.height);
        context.font = "bold 68px Roboto,Arial";
        context.fillStyle = "white";
        context.textAlign = "center";
        context.textBaseline = "middle";
        var user = $scope.avatarStudent ? $scope.avatarStudent : self.user;
        context.fillText((user.Name.length > 0 ? user.Name[0]:'')+
                         (user.Surname.length > 0 ? user.Surname[0]:''), 
                         50, 56  );
        var dataURI = canvas.toDataURL("image/png");
        var byteString = atob(dataURI.split(',')[1]);
        var mimeString = dataURI.split(',')[0].split(':')[1].split(';')[0];
        var ab = new ArrayBuffer(byteString.length);
        var ia = new Uint8Array(ab);
        for (var i = 0; i < byteString.length; i++) ia[i] = byteString.charCodeAt(i);
        var blob = new Blob([ab], {type: "image/png"});

        var id = self.getMediaID();
        self.uploadFile(blob, id + '.png', id, "image", false, function(result) {
          $scope.imageFilename = id + '.png';
          $scope.selectActivity({url:result});
        });
      };

      $scope.changeInitialsImageColor = function(){
        var backgroundColors = [
          '#588c7e','#d96459','#622569','#c83349','#5b9aa0',
          '#674d3c','#667292','#7a3b2e','#454140','#563f46',
          '#77a8a8','#4040a1','#36486b','#618685','#50394c',
          '#405d27','#ff7b25','#d64161','#6b5b95','#6b5b95'];
        var r = Math.floor(Math.random()*backgroundColors.length);
        $scope.initialsImageColor = backgroundColors[r];
      };
      $scope.changeInitialsImageColor(); // random color on start

      $scope.searchForImage = function(ev){
        self.searchForImage(ev).then(function(result){
          if($scope.isNested) {
            $scope.sendIsNested([{isNested:true, clipboardBlob:result.blob}]);
            return;
          }
          var id = 'searched_'+self.getMediaID();
          var parts = result.url.toLowerCase().split(".");
          var ext = parts[parts.length-1];
          self.uploadFile(result.blob, id + '.'+ext, id, "image", false, function(result) {
            $scope.imageFilename = id + '.'+ext;
            $scope.selectActivity({url:result});
          });
        });
      };

      $scope.uploadClipboardBlob = function(toAppend) {
        if($scope.isNested) {
          $scope.sendIsNested([{isNested:true, clipboardBlob:$scope.clipboardBlob}]);
          return;
        }


        if(toAppend) {
          var formData = new FormData();
          var file = new File([$scope.clipboardBlob], "image.png");
          var e = {files:[file]};
          $scope.uploadFileSubmit(e, "image", {seperatedFiles: false, imageToAppendTo: $scope.currentTaskAnswer});
        }
        else {
          var id = self.getMediaID();
          self.uploadFile($scope.clipboardBlob, id + '.png', id, "image", false, function(result) {
            $scope.imageFilename = id + '.png';
            $scope.selectActivity({url:result});
          });
        }
      }

      //1010
      $timeout(function(){
        self.addDropHandler($scope, $scope.dialogElement, ['image']);
      },0);

      //1009
      $scope.resetImage = function(){
        $scope.imageURLDisplay = '';
        $scope.imageURL = '';
        $scope.currentTaskAnswerChanged = $scope.currentTaskAnswer != '';
        $scope.currentTaskAnswer = '';
      };
      $scope.chooseImage = function(toAppend, type) {
        if(!type) type = "image";

        //delete currentImage from tempRecentFiles
        var fileIndex = -1;
        if(self.tempRecentFiles) {
          for(var i = 0; i < self.tempRecentFiles.images.length; i++) {
            if(self.tempRecentFiles.images[i].url == $scope.currentTaskAnswer) fileIndex = i;
            self.tempRecentFiles.images[i].hide = false;
          }
          if(fileIndex != -1) self.tempRecentFiles.images[fileIndex].hide = true;
        }

        var currentImage = $scope.currentTaskAnswer;
        //open 'choose image' dialog
        self.takeUserMedia(type,null,function(results){
          if(results && results == "RECORDINPARENT")
            $scope.startCaptureImage(toAppend);
          else if(results[0].isNested && results[0].data && results[0].type)
            if(toAppend)
              $scope.uploadFileSubmit(results[0].data, results[0].type, {seperatedFiles: false, imageToAppendTo: currentImage});
            else
              $scope.uploadFileSubmit(results[0].data, results[0].type);

          else if(results[0].isNested && results[0].clipboardBlob) {
            $scope.clipboardBlob = results[0].clipboardBlob;

            $scope.uploadClipboardBlob(toAppend);
          }
          else if(results && results[0].URL != '') {
            if(toAppend) {
              //create file to use in uploadFileAppend to append it to the current Image
              var xhr = new XMLHttpRequest();
              xhr.onreadystatechange = function(){
                if (this.readyState == 4 && this.status == 200){
                  //formdata? wird das genutzt?
                  var formData = new FormData();
                  var file = new File([this.response], "image.png");
                  var e = {files:[file]};
                  $scope.uploadFileSubmit(e, "image", {seperatedFiles: false, imageToAppendTo: currentImage});
                }
              }
              xhr.open('GET', results[0].URL);
              xhr.crossDomain = true;
              xhr.responseType = 'blob';
              xhr.send();
            }
            else {
              $scope.imageURL = results[0].URL;
              $scope.imageURLDisplay = app.patchWKWebviewPath(results[0].URL+"?r="+Math.random());
              $scope.currentTaskAnswerChanged = true;
              $scope.currentTaskAnswer = $scope.imageURL;
            }
          }
        }, {dialogMode: 0, isNested:true, student : $scope.avatarStudent ? $scope.avatarStudent : null});
      }

      $scope.clearRecentList = function(ev){
        self.confirm($filter('trans')('ASKCLEARLIST'),$filter('trans')('CLEARLIST'),ev).then(function(){
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.imageUploads){
            delete(self.userViewData.recentFiles.imageUploads);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.images){
            delete(self.tempRecentFiles.images);
          }
          $scope.mergedRecentFilesList = [];
          self.updateUserViewData();
        });
      }

      $scope.selectActivity = function(activity) {
        $scope.currentTaskAnswer = activity.url;
        $scope.currentTaskAnswerChanged = true;

        $scope.url = activity.url;
        $scope.imageURL = activity.url;
        $scope.imageURLDisplay = app.patchWKWebviewPath(activity.url+"?r="+Math.random());

        if($scope.dialogMode == 0) $scope.save();
      }

      $scope.editImageInEditor = function(ev){
        self.showTaskResultMedia('annotation',{Answer:$scope.imageURL, Task:$scope.t},null,null,false,ev).then(function(r){
          if(r) {
            $scope.currentTaskAnswerChanged = true;
          }
        });
      };

      //imageToAppendTo > null = First file is a normal upload, the rest is going to be appended
      //options: seperatedFiles, imageToAppendTo, index, indexArray
      $scope.uploadFileSubmit = function(e,type, options){
        if($scope.isNested) {
          $scope.sendIsNested([{isNested:true, data:e, type: type}]);
          return;
        }

        options = options ? options : [];

        var seperatedFiles = options.seperatedFiles ? options.seperatedFiles : null;
        var imageToAppendTo = options.imageToAppendTo ? options.imageToAppendTo : null;
        var index = options.index ? options.index : 0;
        var indexArray = options.indexArray ? options.indexArray : null;
        var dropped = options.dropped ? options.dropped : false;

        e = e && e.target && !e.files ? e.target : e;
        if(e.files.length == 0) return;

        if(!indexArray) {
          //get files as alphabetical sorted array
          var alphaArray = [];
          for(var i = 0; i < e.files.length; i++)
            alphaArray.push(e.files[i].name);
          alphaArray.sort();

          //get files as sorted index array
          indexArray = [];
          for(var i = 0; i < alphaArray.length; i++)
            for(var ii = 0; ii < e.files.length; ii++)
              if(alphaArray[i] == e.files[ii].name)
                indexArray.push(ii);
        }

        if(indexArray && (indexArray[index] || indexArray[index] === 0))
          fileIndex = indexArray[index];
        else
          fileIndex = index;

        var isImage = true;
        if(!self.checkFileType(e.files[fileIndex],type,additionalFileTypes)) {
          if(type == "file")
            self.askToZIPFiles(e,type, options, $scope.uploadFileSubmit);
          return;
        }
        if(isImage) e.files[fileIndex].myType = type;

        var filename = e.files[fileIndex].name;

        if(imageToAppendTo && !seperatedFiles){
          e.appendToImage = imageToAppendTo;
          var currentImage = new Image();
          currentImage.src = imageToAppendTo;
          currentImage.crossOrigin = "Anonymous";
          currentImage.onload = function(){
            if(currentImage.height > 16000){
              self.alert($filter('trans')('LARGEIMAGEHINT'),null);
            }
          };
        }

        self.uploadFileInput(e,function(url){
          if(index == 0)
            imageToAppendTo = url;
          else
            $scope.cleanUpRelatedRecentImages(imageToAppendTo, url);

          //5555 only makes sense when seperatedFiles is true, because else it will only be one item!
          if(seperatedFiles) {
            if(!$scope.multipleAnswers)
              $scope.multipleAnswers = [];

            $scope.multipleAnswers.push({url: url, name: filename, type: type});
          }

          var nextIndex = (indexArray && (indexArray[index] || indexArray[index] === 0)) ? indexArray[index+1] : index+1;

          if(e.files.length > index+1) {
            $scope.uploadFileSubmit(e, type, {dropped: dropped, seperatedFiles: seperatedFiles, imageToAppendTo: url, index: index+1, indexArray: indexArray});
          }
          else {
            $scope.selectActivity({url:url});
          }
        }, fileIndex);
      };

      $scope.cleanUpRelatedRecentImages = function(currentImage, appendedImage) {
        var currentTime = new Date().getTime();
        //when appending image and within 2 minutes delete related recentFiles.
        if(currentImage && appendedImage) {
          for(var i = 0; i < self.userViewData.recentFiles.imageUploads.length; i++) {
            if(self.userViewData.recentFiles.imageUploads[i].url == currentImage || self.userViewData.recentFiles.imageUploads[i].url == appendedImage) {
              if(currentTime <= self.userViewData.recentFiles.imageUploads[i].time + 1000*60*2) {
                self.userViewData.recentFiles.imageUploads.splice(i, 1);
                i--;
              }
            }
          }
          self.updateUserViewData();
        }
      }

      $scope.startCaptureImage = function(append,ev){
        $scope.startedCapture = true;
        $timeout(function(){
          $scope.startedCapture = false;
        },2000);

        if($scope.isNested) {
          $scope.sendRecordInParent();
          return;
        }

        self.capturePhoto(self.getMediaID(),function(url,filename,blob){
          var oldFile = null;
          if(append) {
            oldFile = $scope.currentTaskAnswer;
          }

          self.uploadFile(url.indexOf("blob") == 0 ? blob : url,filename,
            self.getMediaID(),'image',oldFile,function(url2){
            $scope.imageFilename = filename;
            //1009
            $scope.selectActivity({url:url2});
          });

        },ev);
      };
    };
