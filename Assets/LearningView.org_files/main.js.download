    self.deleteJournalItem = function(it,student,ev, $scope){
      var deferred = $q.defer();
      if(!it.ID) return deferred.promise;
      self.confirm('<span style="color:red;font-weight:bold">'+$filter('trans')('CONFIRMDELETEJOURNALITEM')+'</span>',$filter('trans')('DELETE'),ev).then(function(){
        self.apiPost("ajax",{"action":"deleteJournalItem", "ID":it.ID})
         .then(function(data) {
           if(!student) student = self.user;

           for(var k1 in self.users[student.ID].journalTaskMapped){
             for(var k2 in self.users[student.ID].journalTaskMapped[k1]){
               if(k2 == it.ID) {
                 delete self.users[student.ID].journalTaskMapped[k1][k2];
                 break;
               }
             }
           }
           for(var k1 in self.users[student.ID].journalLearningGoalMapped){
             for(var k2 in self.users[student.ID].journalLearningGoalMapped[k1]){
               if(k2 == it.ID) {
                 delete self.users[student.ID].journalLearningGoalMapped[k1][k2];
                 break;
               }
             }
           }
           for(var i=0; i < self.users[student.ID].journal.length; i++){
             if(self.users[student.ID].journal[i].ID == it.ID){
               self.users[student.ID].journal.splice(i,1);
               break;
             }
           }
           deferred.resolve();
           self.keepAliveCallback();

        });
      });
      return deferred.promise;
    };
