    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.backToClassClicked = function(ev){
      if(self.currentClass == null && self.backToClass){
        self.openClass(self.backToClass,ev);
        return;
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findAndShowTask = function(task,switchToMaterial,editTask){
      var deferred = $q.defer();
      var path = self.getTaskByID(task.ID);
      if(!path) return; // not found
      if(!path.topic) return; // not found
      var performAction = function(){
        if(!(self.currentTopic && self.currentTopic.ID == path.topic.ID)){
          self.openTopic(path.mainTopic,path.topic,null);
        }
        var retry = 0;
        var findElement = function(){
          if(retry > 50) return; // 10 sec waited
          var d = $("#task_tile_"+task.ID)[0];
          if(d) {
            d.scrollIntoView({
              behavior: "smooth", // or "auto" or "instant"
              block: "center" // or "start" or "end"
            });
            if(editTask){
              if(task.Type == 'user')
                self.editUserTask(task,path.goal,null); else
                self.editTask(task,path.goal,null);
            }
            deferred.resolve();
          }
          if(!d) { retry++; setTimeout(findElement,100); }
        };
        setTimeout(findElement,1);
      };
      if(switchToMaterial && self.currentClass){
        self.backToClass = self.currentClass;
        self.openMaterials(null).then(performAction);
      }else performAction();
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findAndShowLearningGoal = function(goal,switchToMaterial){
      var deferred = $q.defer();
      var path = self.getGoalByID(goal.ID);
      if(!path) return; // not found
      var performAction = function(){
        if(!(self.currentTopic && self.currentTopic.ID == path.topic.ID)){
          self.openTopic(path.mainTopic,path.topic,null);
        }
        var retry = 0;
        var findElement = function(){
          if(retry > 50) return; // 10 sec waited
          var d = $("#goal_tile_"+goal.ID)[0];
          if(d) {
            d.scrollIntoView({
              behavior: "smooth", // or "auto" or "instant"
              block: "start" // or "start" or "end"
            });
            deferred.resolve();
          }
          if(!d) { retry++; setTimeout(findElement,100); }
        };
        setTimeout(findElement,1);
      };
      if(switchToMaterial && self.currentClass){
        self.backToClass = self.currentClass;
        self.openMaterials(null).then(performAction);
      }else performAction();
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findAndShowTopic = function(topic,switchToMaterial){
      var deferred = $q.defer();
      var performAction = function(){
        if(self.currentTopic || self.currentMainTopic){
          self.resetMainTopic();
        }
        var retry = 0;
        var findElement = function(){
          if(retry > 50) return; // 10 sec waited
          var d = $("#topic_"+topic.ID)[0];
          if(d) {
            d.scrollIntoView({
              behavior: "smooth", // or "auto" or "instant"
              block: "start" // or "end"
            });
            deferred.resolve();
          }
          if(!d) { retry++; setTimeout(findElement,100); }
        };
        setTimeout(findElement,1);
      };
      if(switchToMaterial && self.currentClass){
        self.backToClass = self.currentClass;

        var isArchived = false;

        if(self.userContent.archivedMainTopics)
        for(var i=0; i < self.userContent.archivedMainTopics.length; i++){
          if(self.userContent.archivedMainTopics[i].ID == topic.MainTopic){
            isArchived = self.userContent.archivedMainTopics[i];
            break;
          }
        }
        if(isArchived){
          self.confirm($filter('trans')('RESTOREHIDDENMAINTOPICEDITHINT',isArchived.Name),$filter('trans')('UNHIDE'),null).then(function(){
            self.showLoadingIndicator(null,function(done){
              self.apiPost("ajax",{"action":"unarchiveMainTopic", "ID":isArchived.ID})
               .then(function(data) {
                 self.keepAliveCallback().then(function(){
                   self.openMaterials(null).then(performAction);
                   done();
                 });
               },function(data, status, headers, config) {
                  done();
                  self.alert("Error: "+data.error);
               });
             });
          });
        }else
          self.openMaterials(null).then(performAction);
      }else performAction();
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findAndShowMainTopic = function(maintopic,switchToMaterial){
      var deferred = $q.defer();
      var performAction = function(){
        if(self.currentTopic || self.currentMainTopic){
          self.resetMainTopic();
        }
        var retry = 0;
        var findElement = function(){
          if(retry > 50) return; // 10 sec waited
          var d = $("#mainTopic_"+maintopic.ID)[0];
          if(d) {
            d.scrollIntoView({
              behavior: "smooth", // or "auto" or "instant"
              block: "start" // or "end"
            });
            deferred.resolve();
          }
          if(!d) { retry++; setTimeout(findElement,100); }
        };
        setTimeout(findElement,1);
      };
      if(switchToMaterial && self.currentClass){
        self.backToClass = self.currentClass;

        if(maintopic.Archived == 1){
          self.confirm($filter('trans')('RESTOREHIDDENMAINTOPICEDITHINT',maintopic.Name),$filter('trans')('UNHIDE'),null).then(function(){
            self.showLoadingIndicator(null,function(done){
              self.apiPost("ajax",{"action":"unarchiveMainTopic", "ID":maintopic.ID})
               .then(function(data) {
                 self.keepAliveCallback().then(function(){
                   self.openMaterials(null).then(performAction);
                   done();
                 });
               },function(data, status, headers, config) {
                  done();
                  self.alert("Error: "+data.error);
               });
             });
          });
        }else
          self.openMaterials(null).then(performAction);
      }else performAction();
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.rubrics = []; // empty list by default
    self.getRubricByID = function(id){
      for(var i=0; i < self.rubrics.length; i++){
        if(self.rubrics[i].ID == id) return self.rubrics[i];
      }
      return null;
    };

    self.removeRubricFromLocalData = function(rubricOrIDOrGUID){
      if(!self.rubrics) self.rubrics = [];
      if(!self.getRubricByGUIDmap) self.getRubricByGUIDmap = {};

      var removeID = NaN;
      var removeGUID = "";

      if(typeof rubricOrIDOrGUID == "object" && rubricOrIDOrGUID){
        removeID = parseInt(rubricOrIDOrGUID.ID,10);
        removeGUID = $.trim(String(rubricOrIDOrGUID.GUID || ""));
      }else{
        var raw = $.trim(String(rubricOrIDOrGUID || ""));
        if(raw.match(/^\d+$/)){
          removeID = parseInt(raw,10);
        }else{
          removeGUID = raw;
        }
      }

      for(var i=self.rubrics.length-1; i >= 0; i--){
        var localRubric = self.rubrics[i];
        if(!localRubric) continue;
        var idMatches = !isNaN(removeID) && parseInt(localRubric.ID,10) == removeID;
        var guidMatches = removeGUID != "" && localRubric.GUID == removeGUID;
        if(idMatches || guidMatches){
          self.rubrics.splice(i,1);
        }
      }

      if(removeGUID != ""){
        delete self.getRubricByGUIDmap[removeGUID];
      }
      if(!isNaN(removeID)){
        for(var guid in self.getRubricByGUIDmap){
          if(!self.getRubricByGUIDmap[guid]) continue;
          if(parseInt(self.getRubricByGUIDmap[guid].ID,10) == removeID){
            delete self.getRubricByGUIDmap[guid];
          }
        }
      }
    };

    self.getRubricByGUIDmap = {};
    self.getRubricByGUID = function(guid){
      if(self.getRubricByGUIDmap[guid]) return self.getRubricByGUIDmap[guid];
      for(var i=0; i < self.rubrics.length; i++){
        self.getRubricByGUIDmap[self.rubrics[i].GUID] = self.rubrics[i];
        if(self.rubrics[i].GUID == guid) return self.rubrics[i];
      }
      // try fetch now
      if(self.fetchRubricsGuidsMissing.indexOf(guid) == -1) self.fetchRubrics([guid]);
      return null;
    };
    

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.isStudentOfCurrentClass = function(studentid){
      if(!self.currentClass) return false;
      for(var i=0; i < self.currentClass.students.length; i++){
        if(self.currentClass.students[i].ID == studentid) return true;
      }
      return false;
    };

    self.getTaskByIDmap = {};
    self.getTaskByID = function(id,onlyThisClass,notInClasses){
      // search for this task in current class
      if(self.currentClass){
        if(self.currentClass.taskMapped && self.currentClass.taskMapped[id]){
          var r = self.currentClass.taskMapped[id];
          r.currentClass = self.currentClass;
          return r;
        }        
      }
      // search for this task in all classes of teacher or student
      if(self.classList && !notInClasses)
      for(var c=0; c < self.classList.length; c++){
        if(onlyThisClass && onlyThisClass.ID != self.classList[c].ID) continue;

        if(self.classList[c].taskMapped && self.classList[c].taskMapped[id]){
          var r = self.classList[c].taskMapped[id];
          r.currentClass = self.classList[c];
          return r;
        }
      }

      if(self.getTaskByIDmap[id] == -1) return null;
      if(self.getTaskByIDmap[id]) return self.getTaskByIDmap[id];

      // search for this task in teacher pool
      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        if(self.userContent.mainTopics[i].topics)
        for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
          if(self.userContent.mainTopics[i].topics[z].goals)
          for(var g=0; g < self.userContent.mainTopics[i].topics[z].goals.length; g++){
            if(self.userContent.mainTopics[i].topics[z].goals[g].tasks)
            for(var t=0; t < self.userContent.mainTopics[i].topics[z].goals[g].tasks.length; t++){
              if(self.userContent.mainTopics[i].topics[z].goals[g].tasks[t].ID == id) {
                self.getTaskByIDmap[id] = {task:self.userContent.mainTopics[i].topics[z].goals[g].tasks[t],
                        goal:self.userContent.mainTopics[i].topics[z].goals[g],
                        topic:self.userContent.mainTopics[i].topics[z],
                        mainTopic:self.userContent.mainTopics[i],currentClass:null};
                  return self.getTaskByIDmap[id];
              }
            }
          }
        }
      }
      // search for this task in students user tasks
      for(var uid in self.users){
        if(self.users[uid].userTasks)
        for(var c in self.users[uid].userTasks){
          for(var i=0; i < self.users[uid].userTasks[c].length; i++){
            if(self.users[uid].userTasks[c][i].ID == id){
              self.getTaskByIDmap[id] = {task:self.users[uid].userTasks[c][i],
                      goal:null,topic:null,mainTopic:null,currentClass:null};
              return self.getTaskByIDmap[id];
            }
          }
        }
      }

      // task is not there anymore
      self.getTaskByIDmap[id] = -1;
      return null;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getUserContentByID = function(type,id){
      if(type == "maintopic")
        // search for this topic in teacher pool
        if(self.userContent && self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          if(self.userContent.mainTopics[i].ID == id){
            return self.userContent.mainTopics[i];
          }
        }

      if(type == "topic")
        // search for this topic in teacher pool
        if(self.userContent && self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          if(self.userContent.mainTopics[i].topics)
          for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
            if(self.userContent.mainTopics[i].topics[z].ID == id){
              return self.userContent.mainTopics[i].topics[z];

            }
          }
        }

      if(type == "goal") 
        // search for this goal in teacher pool
        if(self.userContent && self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          if(self.userContent.mainTopics[i].topics)
          for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
            if(self.userContent.mainTopics[i].topics[z].goals)
            for(var g=0; g < self.userContent.mainTopics[i].topics[z].goals.length; g++){
              if(self.userContent.mainTopics[i].topics[z].goals[g].ID == id) {
                return self.userContent.mainTopics[i].topics[z].goals[g];
              }
            }
          }
        }

      if(type == "task") 
        // search for this task in teacher pool
        if(self.userContent && self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          if(self.userContent.mainTopics[i].topics)
          for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
            if(self.userContent.mainTopics[i].topics[z].goals)
            for(var g=0; g < self.userContent.mainTopics[i].topics[z].goals.length; g++){
              if(self.userContent.mainTopics[i].topics[z].goals[g].tasks)
              for(var t=0; t < self.userContent.mainTopics[i].topics[z].goals[g].tasks.length; t++){
                if(self.userContent.mainTopics[i].topics[z].goals[g].tasks[t].ID == id) {
                  return self.userContent.mainTopics[i].topics[z].goals[g].tasks[t];
                }
              }
            }
          }
        }

      return null;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getGoalByIDmap = {};
    self.getGoalByID = function(id){
      // search for this task in current class
      if(self.currentClass){
        if(self.currentClass.goalMapped && self.currentClass.goalMapped[id]){
          var r = self.currentClass.goalMapped[id];
          r.currentClass = self.currentClass;
          return r;
        }
      }
      // search for this task in all classes of teacher or student
      if(self.classList)
      for(var c=0; c < self.classList.length; c++){
        if(self.classList[c].goalMapped && self.classList[c].goalMapped[id]){
          var r = self.classList[c].goalMapped[id];
          r.currentClass = self.classList[c];
          return r;
        }
      }

      if(self.getGoalByIDmap[id] == -1) return null;
      if(self.getGoalByIDmap[id]) return self.getGoalByIDmap[id];

      // search for this goal in teacher pool
      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        if(self.userContent.mainTopics[i].topics)
        for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
          if(self.userContent.mainTopics[i].topics[z].goals)
          for(var g=0; g < self.userContent.mainTopics[i].topics[z].goals.length; g++){
            if(self.userContent.mainTopics[i].topics[z].goals[g].ID == id) {
              self.getGoalByIDmap[id] = {goal:self.userContent.mainTopics[i].topics[z].goals[g],
                      topic:self.userContent.mainTopics[i].topics[z],
                      mainTopic:self.userContent.mainTopics[i],currentClass:null};
              return self.getGoalByIDmap[id];
            }
          }
        }
      }

      // goal is not there anymore
      self.getGoalByIDmap[id] = -1;
      return null;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getTopicByIDmap = {};
    self.getTopicByID = function(id){
      // search for this topic in current class
      if(self.currentClass){
        if(self.currentClass.topicMapped && self.currentClass.topicMapped[id]){
          var r = self.currentClass.topicMapped[id];
          r.currentClass = self.currentClass;
          return r;
        }
      }
      // search for this task in all classes of teacher or student
      if(self.classList)
      for(var c=0; c < self.classList.length; c++){
        if(self.classList[c].topicMapped && self.classList[c].topicMapped[id]){
          var r = self.classList[c].topicMapped[id];
          r.currentClass = self.classList[c];
          return r;
        }
      }

      if(self.getTopicByIDmap[id] == -1) return null;
      if(self.getTopicByIDmap[id]) return self.getTopicByIDmap[id];

      // search for this topic in teacher pool
      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        if(self.userContent.mainTopics[i].topics)
        for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
          if(self.userContent.mainTopics[i].topics[z].ID == id){
            self.getTopicByIDmap[id] = {topic:self.userContent.mainTopics[i].topics[z],
                    mainTopic:self.userContent.mainTopics[i],currentClass:null};
            return self.getTopicByIDmap[id];

          }
        }
      }

      // topic is not there anymore
      self.getTopicByIDmap[id] = -1;
      return null;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveMaterialFilter = function(){
      //self.userViewData["fm_share"] = angular.toJson(self.filterShare);
      self.userViewData["fm_owner"] = angular.toJson(self.filterOwner);
      self.userViewData["fm_color"] = angular.toJson(self.filterColor);
      self.userViewData["fm_tags"]  = angular.toJson(self.filterTags);
      self.updateUserViewData();      
    };
    self.loadMaterialFilter = function(){
      self.filterOwner = self.userViewData["fm_owner"] ? JSON.parse(self.userViewData["fm_owner"]) : null;
      self.filterColor = self.userViewData["fm_color"] ? JSON.parse(self.userViewData["fm_color"]) : null;
      self.filterTags  = self.userViewData["fm_tags"]  ? JSON.parse(self.userViewData["fm_tags"]) : null;

      if(self.filterTags)
        self.filterTags.toString = function(){
          var s = "";
          for(var i=0; i < self.filterTags.items.length; i++){
            s += (s == "" ? "" : ", ")+self.filterTags.items[i].text;
          }
          return s;
        };
    }

    self.updateClassesOrder = function(){
      if(self.classListCurrent.length == 0) return;
      var t = "";
      for(var i=0; i < self.classListCurrent.length; i++){
        t += (i > 0 ? ',' : '')+ self.classListCurrent[i].ID;
        self.classListCurrent[i].OrderIndex = (i+1);
      }

      self.userViewData["classorder"] = t;
      self.updateUserViewData();      
      self.apiPost("ajax",{"action":"updateClassesOrder", "order": t})
       .then(function(){
         self.getClasses();
       });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateMainTopicsOrder = function(){
      if(self.currentClass){
        var t = "";
        for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
          t += (i > 0 ? ',' : '')+ self.classContent[self.currentClass.ID].mainTopics[i].ID;
          self.classContent[self.currentClass.ID].mainTopics[i].OrderIndex = (i+1);
        }
        self.apiPost("ajax",{"action":"updateMainTopicsOrder", "classid": self.currentClass.ID, "order": t})
         .then(function(){
           self.keepAliveCallback();
         });

      }else{
        var t = "";
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          t += (i > 0 ? ',' : '')+ self.userContent.mainTopics[i].ID;
          self.userContent.mainTopics[i].OrderIndex = (i+1);
        }
        self.apiPost("ajax",{"action":"updateMainTopicsOrder", "order": t})
         .then(function(){
           self.keepAliveCallback();
         });
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateTopicsOrder = function(mainTopic){
      if(!mainTopic || mainTopic.topics.length == 0) return;
      var t = "";
      for(var i=0; i < mainTopic.topics.length; i++){
        t += (i > 0 ? ',' : '')+ mainTopic.topics[i].ID;
        mainTopic.topics[i].OrderIndex = (i+1);
      }

      self.apiPost("ajax",{"action":"updateTopicsOrder","mainTopic":mainTopic.ID, "classid": self.currentClass ? self.currentClass.ID : 0,  "order": t})
       .then(function(){
         self.keepAliveCallback();
       });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateLearningGoalsOrder = function(){
      if(self.learningGoalsList.length == 0) return;
      var t = "";
      var c = 0;
      for(var i=0; i < self.learningGoalsList.length; i++){
        t += (t != "" ? ',' : '')+ self.learningGoalsList[i].ID;
        self.learningGoalsList[i].OrderIndex = (c+1);
        c++;
      }
      self.apiPost("ajax",{"action":"updateLearningGoalsOrder","topic":self.currentTopic.ID, "classid": self.currentClass ? self.currentClass.ID : 0, "order": t})
       .then(function(){
         self.keepAliveCallback();
       });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateTaskOrder = function(goalsToUpdate){
      if(self.learningGoalsList.length == 0) return;
      var goals = [];
      for(var i=0; i < self.learningGoalsList.length; i++){
        if(goalsToUpdate && goalsToUpdate.indexOf(self.learningGoalsList[i].ID) == -1) continue;
        var order = "";
        for(var z=0; z < self.learningGoalsList[i].tasks.length; z++){
          order += (z > 0 ? ',' : '')+ self.learningGoalsList[i].tasks[z].ID;
          self.learningGoalsList[i].tasks[z].OrderIndex = (z+1);
        }
        if(order != "") goals.push({ID:self.learningGoalsList[i].ID,order:order});
      }
      var p = {"action":"updateTasksOrder","goals":angular.toJson(goals)};
      if(self.currentClass) p.classid = self.currentClass.ID;
      self.apiPost("ajax",p)
       .then(function(){
         self.keepAliveCallback();
       });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.replaceBase64Images = function (html) {
      var deferred = $q.defer();
      try {
        var parser = new DOMParser();
        var doc = parser.parseFromString(html, "text/html");

        var images = Array.from(doc.querySelectorAll("img"));
        var index = 0;

        function next() {
          if (index >= images.length) {
            deferred.resolve(doc.body.innerHTML);
            return;
          }

          var img = images[index++];
          var base64Data = img.getAttribute("src");

          if (!base64Data || !base64Data.startsWith("data:image/")) {
            next();
            return;
          }

          var extMatch = base64Data.match(/^data:image\/(\w+);base64,/);
          var ext = extMatch ? extMatch[1] : "png";

          var fileName = "image_" + Date.now() + "." + ext;

          var parts = base64Data.split(",");
          var mimeMatch = parts[0].match(/data:(.*?);base64/);
          if (!mimeMatch) {
            img.setAttribute("src", ""); // empty image
            next();
            return;
          }

          var mime = mimeMatch[1];
          var binary = atob(parts[1]);
          var len = binary.length;
          var buffer = new Uint8Array(len);

          for (var i = 0; i < len; i++) {
            buffer[i] = binary.charCodeAt(i);
          }

          var file = new File([buffer], fileName, { type: mime });

          if (!file) {
            img.setAttribute("src", ""); // empty image
            next();
            return;
          }

          self.uploadFileInput({ target: { files: [file] } }, function (url) {
            img.setAttribute("src", url);
            next();
          });
        }

        next();
      } catch (err) {
        console.log(err);
      }
      return deferred.promise;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.saveLearningGoal = function (it,scope){
      it.Description = self.trimHTML(it.Description);
      // search for src="data:image/ and replace
      self.replaceBase64Images(it.Description).then(function(desc){        
        if(scope && it.Description != desc) scope.newDescription = desc;
        it.Description = desc;
        self.apiPost("ajax",{"action":"updateLearningGoal", "ID":it.ID, "Name":it.Name, "Description":it.Description});
      }); 
      if(self.searchTerm && self.searchTerm != '')
        self.addedAfterLastSearchTermChange.goals.push(it.ID);
    };

    self.createLearningGoal = function(ev){
      var a = {"action":"createLearningGoal","topic":self.currentTopic.ID};
      if(self.currentClass) a.inclass = self.currentClass.ID;

      self.apiPost("ajax",a)
       .then(function(data) {
         var isThere = false;
         for(var i=0; i < self.learningGoalsList.length; i++){
           if(self.learningGoalsList[i].ID == data.learningGoal.ID){
             isThere = true;
             break;
           }
         }
         if(!isThere) self.learningGoalsList.push(data.learningGoal);
         if(self.searchTerm && self.searchTerm != '')
           self.addedAfterLastSearchTermChange.goals.push(data.learningGoal.ID);
         self.keepAliveCallback();
       },function(data){
         self.alert("Erstellung fehlgeschlagen: "+data.error);
       });
    };
    self.createLearningGoalWithTopic = function(name,topic,ev){
      var deferred = $q.defer();
      var a = {"action":"createLearningGoal","topic":topic.ID,"Name":name};
      self.apiPost("ajax",a)
       .then(function(data) {
         var isThere = false;
         for(var i=0; i < self.learningGoalsList.length; i++){
           if(self.learningGoalsList[i].ID == data.learningGoal.ID){
             isThere = true;
             break;
           }
         }
         if(!isThere) self.learningGoalsList.push(data.learningGoal);
         if(self.searchTerm && self.searchTerm != '')
           self.addedAfterLastSearchTermChange.goals.push(data.learningGoal.ID);
         self.keepAliveCallback().then(function(){
           deferred.resolve(data.learningGoal);
         });

       },function(data){
         self.alert("Erstellung fehlgeschlagen: "+data.error);
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.filterTags = null;
    self.addFilterTag = function(t){
      if(!self.filterTags) {
        self.filterTags = {} ;
        self.filterTags.items = [];
        self.filterTags.toString = function(){
          var s = "";
          for(var i=0; i < self.filterTags.items.length; i++){
            s += (s == "" ? "" : ", ")+self.filterTags.items[i].text;
          }
          return s;
        };
      }
      for(var i=0; i < self.filterTags.items.length; i++){
        if(self.filterTags.items[i].text == t.text && self.filterTags.items[i].color == t.color) {
          self.filterTags.items.splice(i,1);
          if(self.filterTags.items.length == 0) self.filterTags = null;
          return;  
        }
      }
      self.filterTags.items.push(t);
    };
    self.hasFilterTag = function(t){
      if(!self.filterTags) return false;
      for(var i=0; i < self.filterTags.items.length; i++){
        if(self.filterTags.items[i].text == t.text && self.filterTags.items[i].color == t.color) return true;
      }
      return false;
    }

    self.hasMainTopicTags = function(mt,tags){
      if(tags == null || tags.length == 0) return true;

      var n = mt.Tags && mt.Tags != "" ? mt.Tags.split("|") : [];
      for(var z=0; z < tags.length; z++){
        var match = false;
        for(var i=0; i < n.length; i++){
          var tag = n[i].split("☐");
          if(tags[z].text == tag[0] && tags[z].color == tag[1]){
            match = true;
            break;
          }
        }
        if(!match) return false;
      }

      return true;
    };
    self.knownMainTopicTags = [];
    self.updateKnownMainTopicTags = function(){
      self.knownMainTopicTags = [];
      if(self.userContent && self.userContent.mainTopics)
      for(var z=0; z < self.userContent.mainTopics.length; z++){
        var et = self.userContent.mainTopics[z].Tags;
        var list = et && et != '' ? et.split("|") : [];
        for(var i=0; i < list.length; i++){
          var tag = list[i].split("☐");
          var found = false;
          for(var c=0; c < self.knownMainTopicTags.length; c++){
            if(self.knownMainTopicTags[c].text == tag[0] && self.knownMainTopicTags[c].color == tag[1]){
              found = true;
              break;
            }
          }
          if(!found)
            self.knownMainTopicTags.push({text:tag[0],color:tag[1]});
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addEditMainTopicScope = function($scope){
      $scope.existingTags = [];
      $scope.tags = [];
      $scope.selected = null;
      // make a list of all existing tags in this folder to select from
      if(self.userContent && self.userContent.archivedMainTopics)
      for(var z=0; z < self.userContent.archivedMainTopics.length; z++){
        var et = self.userContent.archivedMainTopics[z].Tags;
        var list = et && et != '' ? et.split("|") : [];
        for(var i=0; i < list.length; i++){
          var tag = list[i].split("☐");
          var found = false;
          for(var c=0; c < $scope.existingTags.length; c++){
            if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
              found = true;
              break;
            }
          }
          if(!found)
            $scope.existingTags.push({text:tag[0],color:tag[1]});
        }
      }
      if(self.userContent && self.userContent.mainTopics)
      for(var z=0; z < self.userContent.mainTopics.length; z++){
        var et = self.userContent.mainTopics[z].Tags;
        var list = et && et != '' ? et.split("|") : [];
        for(var i=0; i < list.length; i++){
          var tag = list[i].split("☐");
          var found = false;
          for(var c=0; c < $scope.existingTags.length; c++){
            if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
              found = true;
              break;
            }
          }
          if(!found)
            $scope.existingTags.push({text:tag[0],color:tag[1]});
        }
      }
      var list = $scope.item.Tags && $scope.item.Tags != '' ? $scope.item.Tags.split("|") : [];
      for(var i=0; i < list.length; i++){
        var tag = list[i].split("☐");
        var found = false;
        for(var c=0; c < $scope.tags.length; c++){
          if($scope.tags[c].text == tag[0] && $scope.tags[c].color == tag[1]){
            found = true;
            break;
          }
        }
        if(!found)
          $scope.tags.push({text:tag[0],color:tag[1]});
      }

      $scope.hasTag = function(e){
        for(var i=0; i < $scope.tags.length; i++){
          if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return true;
        }            
        return false;
      };

      $scope.hasExistingTagsLeft = function(){
        var c = 0;
        for(var z=0; z < $scope.existingTags.length; z++){
          if($scope.hasTag($scope.existingTags[z])) c++;
        }
        return (c < $scope.existingTags.length);
      };
      
      $scope.append = function(e){
        var n = {color:e.color,text:e.text};
        for(var i=0; i < $scope.tags.length; i++){
          if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return;
        }
        $scope.tags.push(n);
      };
      $scope.add = function(){
        var n = {color:0,text:''};
        if($scope.tags.length > 0){
          n.color = $scope.tags[$scope.tags.length-1].color;
        }
        $scope.tags.push(n);
        $scope.selected = n;
        setTimeout(function(){
          $('.tagListEditor input').focus();
        },10);
      };
      $scope.remove = function(t){
        if($scope.selected == t) $scope.selected = null;
        $scope.tags.splice($scope.tags.indexOf(t),1); 
      }
    };

    self.createMainTopic = function(ev,topmost){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "editmaintopic.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open        
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.isNew = 1;
          $scope.item = {};
          $scope.item.Name = "";
          $scope.item.Tags = "";
          $scope.item.Description = "";
          $scope.item.Color = self.colorChoice[0];
          $scope.colorChoice = self.colorChoice;

          self.addEditMainTopicScope($scope);

          $scope.save = function() {
            // try save now
            var tags = [];
            for(var i=0; i < $scope.tags.length; i++){
              if($.trim($scope.tags[i].text) === "") continue;
              tags.push($scope.tags[i].text+"☐"+$scope.tags[i].color);
            }
            $scope.item.Tags = tags.join("|");

            if($scope.item.Name == "") { $('#inputName').focus(); return;}
            $scope.item.Description = self.trimHTML($scope.item.Description);

            self.replaceBase64Images($scope.item.Description).then(function(desc){        
              $scope.item.Description = desc;                

              var a = {"action":"createMainTopic","topmost":topmost ? 1 :0, "Name":$scope.item.Name,
                       "Tags":$scope.item.Tags, "Description":$scope.item.Description, "Color":$scope.item.Color};
              if(self.currentClass) a.inclass = self.currentClass.ID;

              self.apiPost("ajax",a)
               .then(function(data) {              
                 data.mainTopic.Visible = 1;
                 var isThere = false;
                 if(!self.userContent.mainTopics) self.userContent.mainTopics = [];
                 for(var i=0; i < self.userContent.mainTopics.length; i++){
                   if(self.userContent.mainTopics[i].ID == data.mainTopic.ID){
                     isThere = true;
                     break;
                   }
                 }
                 if(!isThere) {
                   if(topmost)
                     self.userContent.mainTopics.unshift(data.mainTopic); else
                     self.userContent.mainTopics.push(data.mainTopic);
                 }
                 self.closeDialog($scope.dialogElement);
                 self.keepAliveCallback().then(function(){
                   self.findAndShowMainTopic(data.mainTopic);
                   deferred.resolve(data.mainTopic);
                 });
                 if(self.searchTerm && self.searchTerm != '')
                   self.addedAfterLastSearchTermChange.mainTopics.push(data.mainTopic.ID);

               },function(data){
                 $scope.error = "Erstellung fehlgeschlagen: "+data.error;
               });
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

