      clone:false
    };

    self.classFolderItemContentsSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:false,
      accept: function (sourceItemHandleScope, destSortableScope) { 
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        return false;
      },
      dragStart : function(obj){
        if(isIOSDevice || isAndroidDevice)
          $(".folderItemContentsWrapper").css({"overflow":"hidden"});
      },
      dragEnd : function(obj){
        if(isIOSDevice || isAndroidDevice)
          $(".folderItemContentsWrapper").css({"overflow":"auto"});
      },
      orderChanged: function (event) {
        self.updateClassFolderItemContentsOrder();
        return true;
      },
      containment: '#folderItemContents',
      clone:false
    };

    self.mainTopicListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        if(self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }

        if(typeof(sourceItemHandleScope.modelValue.goals) != "undefined") return false; // cannot drop a Topic inside mainTopic list
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        return isInSameList;
      },
      orderChanged: function (event) {
        self.updateMainTopicsOrder();
      },
      dragStart : function(obj){
        self.draggingMainTopic = true;
        if(isIOSDevice || isAndroidDevice)
          $(".mainTopicList").css({"overflow":"hidden"});
      },
      dragEnd : function(obj){
        self.draggingMainTopic = false;
        if(isIOSDevice || isAndroidDevice)
          $(".mainTopicList").css({"overflow":"auto"});
      },
      containment: 'body',
      clone:false
    };

    self.topicListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        if(typeof(sourceItemHandleScope.modelValue.topics) != "undefined") return false; // cannot drop into a mainTopic list
        // check if we have permission to move here
        if(self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }

        var sourceMainTopic = null;
        var targetMainTopic = null;
        var mainTopics = null;

        if(self.currentClass && self.classContent[self.currentClass.ID].mainTopics){
          mainTopics = self.classContent[self.currentClass.ID].mainTopics;
        }else{
          mainTopics = self.userContent.mainTopics;
        }

        for(var i=0; i < mainTopics.length; i++){
          if(mainTopics[i].topics == sourceItemHandleScope.sortableScope.modelValue){
            sourceMainTopic = mainTopics[i];
          }
          if(mainTopics[i].topics == destSortableScope.modelValue){
            targetMainTopic = mainTopics[i];
          }
        }
        if(!sourceMainTopic || !targetMainTopic) return false;

        var canChange = self.checkChangePermission(sourceMainTopic) && self.checkChangePermission(targetMainTopic);
        if(canChange && !self.currentClass) return true;

        var inClass = (self.currentClass && self.hasClassChangePermission(self.currentClass));
        if(inClass && sourceMainTopic == targetMainTopic) return true;

        return false;
      },
      orderChanged: function (event) {
        //event.source.sortableScope.modelValue[event.source.index]
        //self.updateTopicsOrder(event.source.itemScope.$parent.mt);
        self.updateTopicsOrder(event.source.sortableScope.$parent.mt);
      },
      itemMoved: function (event) {
        // dragged to other list
        // element in hand: event.source.itemScope.modelValue
        // list from: event.source.sortableScope
        // list to: event.dest.sortableScope
        var sourceItem = self.topicListSortOptions.dragSourceItem;

        self.apiPost("ajax",{"action":"moveTopicToMainTopic",
                             "ID":sourceItem.ID,
                             "mainTopic":event.dest.sortableScope.$parent.mt.ID})
         .then(function(){
          //event.source.itemScope.modelValue.MainTopic = event.dest.sortableScope.$parent.mt.ID;
          self.updateTopicsOrder(self.getMainTopicByID(sourceItem.MainTopic));
          self.updateTopicsOrder(event.dest.sortableScope.mt);
         })
      },
      dragStart : function(event){
        self.draggingTopic = true;
        self.topicListSortOptions.dragSourceItem = event.source.sortableScope.itemData().topics[event.source.index];
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .mainTopicList").css({"overflow":"hidden"});

      },
      dragEnd : function(){
        self.draggingTopic = false;
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .mainTopicList").css({"overflow":"auto"});
      },
      containment: 'body',
      clone:false
    };

    self.learningGoalsListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        if(self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }else{
          var canChange = self.checkChangePermission(self.currentMainTopic);
          if(!canChange) return false;
        }
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        return false;
      },
      orderChanged: function (event) {
        self.updateLearningGoalsOrder();
      },
      dragStart : function(){
        self.draggingLearningGoal = true;
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .learningGoalsList").css({"overflow":"hidden"});
      },
      dragEnd : function(){
        self.draggingLearningGoal = false;
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .learningGoalsList").css({"overflow":"auto"});
      },
      containment: 'body',
      clone:false
    };

    self.taskListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      dragSourceItem:null,
      accept: function (sourceItemHandleScope, destSortableScope) {
        // only in same or similar lists
        if(self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }else{
          var canChange = self.checkChangePermission(self.currentMainTopic);
          if(!canChange) return false;
        }

        if(typeof sourceItemHandleScope.modelValue.Topic != "undefined") return false; // cannot drop a goal inside task list
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
//        if(sourceItemHandleScope.modelValue.Type == 'test'){
//          var d = destSortableScope.$parent.modelValue ? destSortableScope.$parent.modelValue.tasks : destSortableScope.$parent.$parent.it.tasks;
//          for(var i=0; i < d.length; i++) if(d[i].Type == 'test') return false; // already one test there
//        }
        if(self.currentClass) return false; // no move in other lists inside a class
        return true;  // dest is also a LearningGoal
      },
      itemMoved: function (event) {
        // dragged to other list
        // element in hand: event.source.itemScope.modelValue
        // list from: event.source.sortableScope
        // list to: event.dest.sortableScope

        var sourceItem = self.taskListSortOptions.dragSourceItem;

        self.apiPost("ajax",{"action":"moveTaskToLearningGoal",
                             "ID":sourceItem.ID,
                             "goal":event.dest.sortableScope.$parent.it.ID})
         .then(function(){
          sourceItem.LearningGoal = event.dest.sortableScope.$parent.it.ID;
          self.updateTaskOrder([event.dest.sortableScope.$parent.it.ID,event.source.sortableScope.$parent.it.ID ]);
         },function(){
           // revert on error
           event.dest.sortableScope.removeItem(event.dest.index);
           event.source.sortableScope.insertItem(event.source.index, sourceItem);
         });
      },
      dragStart : function(event){
        self.draggingTask = true;
        self.taskListSortOptions.dragSourceItem = event.source.sortableScope.itemData().tasks[event.source.index];
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .learningGoalsList").css({"overflow":"hidden"});
      },
      dragEnd : function(event){
        self.draggingTask = false;
        if(isIOSDevice || isAndroidDevice)
          $(".contentPanel, .learningGoalsList").css({"overflow":"auto"});
      },
      orderChanged: function (event) {
        self.updateTaskOrder([event.dest.sortableScope.$parent.it.ID]);
      },
      containment: 'body',
      clone:false
    };

    self.selfTestOrderSortOptions = {
      longTouch:false,
      accept: function (sourceItemHandleScope, destSortableScope) { 
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        return false;
      },
      dragStart : function(obj){

      },
      dragEnd : function(obj){

      },
      orderChanged: function (event) {
        if(event && event.source.itemScope && 
           event.source.itemScope.chooseOrder)
           event.source.itemScope.chooseOrder(event.source.itemScope.currentQuestion);
        return true;
      },
      containment: 'body',
      clone:false
    };

    self.templateSortOptions = {
      longTouch:false,
      accept: function (sourceItemHandleScope, destSortableScope) { 
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        return false;
      },
      dragStart : function(obj){

      },
      dragEnd : function(obj){

      },
      orderChanged: function (event) {
        if(event && event.source.itemScope && 
           event.source.itemScope.saveTemplateOrder)
           event.source.itemScope.saveTemplateOrder();
        return true;
      },
      containment: 'body',
      clone:false
    };

    self.calendarTasksSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        if(self.user && self.user.Teacher == 1 && self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;

        if(sourceItemHandleScope.itemScope.d && destSortableScope.d){
          if(sourceItemHandleScope.itemScope.d.date != destSortableScope.d.date ||
             sourceItemHandleScope.itemScope.classid != destSortableScope.classid){
            // if not in the same list, other day
            var task = sourceItemHandleScope.itemScope.modelValue.Task;
            if(!destSortableScope.calendarsByDate[destSortableScope.classid][destSortableScope.d.date]){
              destSortableScope.calendarsByDate[destSortableScope.classid][destSortableScope.d.date] = [];
            }
            var targetItems = destSortableScope.calendarsByDate[destSortableScope.classid][destSortableScope.d.date];

            if(targetItems)
              for(var i=0; i < targetItems.length; i++){
                if(targetItems[i].Task == task) return false; // already here
              }
            return true;
          }
        }
        return false;
      },
      itemMoved: function (event) {
        // dragged to other list
        // element in hand: event.source.itemScope.modelValue
        // list from: event.source.sortableScope
        // list to: event.dest.sortableScope
        self.addTasksToUsersCalendar(event.source.sortableScope.student,[event.source.itemScope.modelValue.Task],event.dest.sortableScope.d.date).then(function(){
          self.keepAliveCallback();
        });
        self.removeTaskFromCalendar(event.source.itemScope.modelValue,null,true);
      },
      orderChanged: function (event) {
        if(event && event.source.itemScope) {
          self.updateCalendarTasksOrder(event.source.itemScope.calendarsByDate[event.source.itemScope.classid][event.source.itemScope.d.date],event.source.itemScope.student,event.source.itemScope.classid);
        }
      },
      dragStart : function(event){
        if(event && event.source.itemScope) {
          self.calendarTasksSortDragging = event.source.itemScope.calendarsByDate[event.source.itemScope.classid][event.source.itemScope.d.date];
        }
      },
      dragEnd : function(event){
        self.calendarTasksSortDragging = false;
      },
      containment: 'body',
      clone:false
    };
    self.classCalendarTasksSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        if(self.currentClass){
          var canChange = self.hasClassChangePermission(self.currentClass);
          if(!canChange) return false;
        }
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(isInSameList) return true;
        if(sourceItemHandleScope.itemScope.d && destSortableScope.d){
          if(sourceItemHandleScope.itemScope.d.date != destSortableScope.d.date ||
             sourceItemHandleScope.itemScope.classid != destSortableScope.classid){
            // if not in the same list, other day
            var task = sourceItemHandleScope.itemScope.modelValue.Task;
            if(!destSortableScope.classCalendarByDate[destSortableScope.d.date]){
              destSortableScope.classCalendarByDate[destSortableScope.d.date] = [];
            }
            var targetItems = destSortableScope.classCalendarByDate[destSortableScope.d.date];

            if(targetItems)
              for(var i=0; i < targetItems.length; i++){
                if(targetItems[i].Task == task) return false; // already here
              }
            return true;
          }
        }

        return false;
      },
      itemMoved: function (event) {
        // dragged to other list
        // element in hand: event.source.itemScope.modelValue
        // list from: event.source.sortableScope
        // list to: event.dest.sortableScope
        self.addTasksToClassCalendar([event.source.itemScope.modelValue.Task],event.dest.sortableScope.d.date).then(function(){
          self.keepAliveCallback();
        });
        self.removeTaskFromClassCalendar(event.source.itemScope.modelValue,null,true);
      },
      orderChanged: function (event) {
        if(event && event.source.itemScope) {
          self.updateClassesCalendarTasksOrder(event.source.itemScope.classCalendarByDate[event.source.itemScope.d.date],event.source.itemScope.classid);
        }
      },
      dragStart : function(event){
        if(event && event.source.itemScope) {
          self.classCalendarTasksSortDragging = event.source.itemScope.classCalendarByDate[event.source.itemScope.d.date];
        }
      },
      dragEnd : function(event){
        self.classCalendarTasksSortDragging = false;
      },
      containment: 'body',
      clone:false
    };    

    self.folderTasksListSortOptions = {
      longTouch:false,
      accept: function (sourceItemHandleScope, destSortableScope) {
        var sourceContent = sourceItemHandleScope.itemScope.content;
        var destContent = destSortableScope.$parent && destSortableScope.$parent.content
          ? destSortableScope.$parent.content
          : null;

        if (!sourceContent || !sourceContent.selected) return false;

        // Rechte
        if (self.user.Teacher == 0) {
          if (sourceContent.Owner != self.user.ID) return false;
          if (destContent && destContent.Owner != self.user.ID) return false;
        }

        // Optional: Duplikate im Ziel verhindern
        var taskId = sourceItemHandleScope.modelValue;
        if (destContent && destContent !== sourceContent &&
            Array.isArray(destContent.DataJSON.tasks) &&
            destContent.DataJSON.tasks.indexOf(taskId) !== -1) {
          return false;
        }

        // innerhalb der Task-Listen erlauben (gleich + verschieden)
        return true;
      },

      itemMoved: function (event) {
        var sourceContent = event.source.itemScope.content;
        var destContent = event.dest.sortableScope.$parent && event.dest.sortableScope.$parent.content
          ? event.dest.sortableScope.$parent.content
          : null;

        if (sourceContent) self.saveClassFolderItemContent(sourceContent);
        if (destContent && destContent !== sourceContent) self.saveClassFolderItemContent(destContent);
        return true;
      },

      orderChanged: function (event) {
        var content = event.source.itemScope.content;
        if (!content.selected) return false;
        if (self.user.Teacher == 0 && content.Owner != self.user.ID) return false;

        self.saveClassFolderItemContent(content);
        return true;
      },

      containment: 'body',
      clone:false
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.updateCalendarTasksOrder = function(items,student,classid){
      if(!items || items.length == 0) return;
      var order = "";
      for(var i=0; i < items.length; i++){
        order += (i > 0 ? ',' : '')+ items[i].ID;
        items[i].OrderIndex = (i+1);
      }
      self.apiPost("ajax",{"action":"updateCalendarTasksOrder",
                           "student":student.ID, "classid":classid ? classid : self.currentClass.ID, 
                           "order":order}).then(function(){
         self.keepAliveCallback();
       });
    };    

    self.updateClassesCalendarTasksOrder = function(items,classid){
      if(!items || items.length == 0) return;
      var order = "";
      for(var i=0; i < items.length; i++){
        order += (i > 0 ? ',' : '')+ items[i].ID;
        items[i].OrderIndex = (i+1);
      }
      self.apiPost("ajax",{"action":"updateClassesCalendarTasksOrder",
                           "classid":classid ? classid : self.currentClass.ID, 
                           "order":order}).then(function(){
         self.keepAliveCallback();
       });
    };    


    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTeacherNotesIntro = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "introteachernotes.html",
        targetEvent: ev,
        onRemoving: function (event, removePromise) {
          deferred.resolve();
        },
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          var introscreenIndex = 1;
          var introscreenIndexMax = 3;
          $scope.introscreenBack = function(){
            if(introscreenIndex > 1) introscreenIndex--;
            $('.introscreen').each(function(i,e){
              if($(e).hasClass('introscreen'+introscreenIndex)) $(e).fadeIn(); else $(e).hide();
            });
          };
          $scope.introscreenNext = function(){
            if(introscreenIndex < introscreenIndexMax) introscreenIndex++;
            $('.introscreen').each(function(i,e){
              if($(e).hasClass('introscreen'+introscreenIndex)) $(e).fadeIn(); else $(e).hide();
            });
          };

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

