                  '<i class="fa fa-fw fa-caret-down"></i></button>'+
                  '<div style="position:absolute;z-index:10;" ng-show="showColors">'+
                  '<div style="background:white;border:1px solid #eee;padding:4px;display:flex;flex-wrap:wrap;max-width:40vw;">'+
