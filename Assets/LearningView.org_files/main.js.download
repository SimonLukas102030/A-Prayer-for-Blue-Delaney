    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Calendar
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.calendarNoteLineTimeChoices = ["-",1,2,3,5,10,15,20,25,30,35,40,45,50,60,90,120];

    self.parseCalendarItemContentLine = function(line){
      var raw = String(line || "");
      var checked = false;
      var teacherOnly = false;
      var time = null;

      if(raw != "" && raw[0] == "✓"){
        checked = true;
        raw = raw.slice(1);
      }
      if(raw != "" && raw[0] == "¶"){
        teacherOnly = true;
        raw = raw.slice(1);
      }

      var m = raw.match(/^(.*)\s\|\s(\d+)$/);
      if(m){
        var maybeTime = parseInt(m[2],10);
        if(self.calendarNoteLineTimeChoices.indexOf(maybeTime) != -1){
          raw = m[1];
          time = maybeTime;
        }
      }

      return {text:raw, checked:checked, teacherOnly:teacherOnly, time:time};
    };

    self.buildCalendarItemContentLine = function(line){
      var raw = line && line.text ? String(line.text) : "";
      var time = line && (line.time || line.time === 0) ? parseInt(line.time,10) : null;

      if(isNaN(time) || self.calendarNoteLineTimeChoices.indexOf(time) == -1){
        time = null;
      }
      if(time !== null){
        raw += " | " + time;
      }
      if(line && line.teacherOnly){
        raw = "¶" + raw;
      }
      if(line && line.checked){
        raw = "✓" + raw;
      }
      return raw;
    };

    self.getCalendarItemContentLineDisplay = function(line){
      var parsed = self.parseCalendarItemContentLine(line);
      return parsed.text;
    };

    self.getCalendarItemContentLineTime = function(it,index){
      if(!it || !it.DataJSON || !it.DataJSON.text) return null;
      var lines = it.DataJSON.text.split("\n");
      if(index < 0 || index >= lines.length) return null;
      return self.parseCalendarItemContentLine(lines[index]).time;
    };

    self.getCalendarItemContentLineTimeLabel = function(it,index){
      var t = self.getCalendarItemContentLineTime(it,index);
      return t === null ? "?" : (t+" "+$filter('trans')('MINUTESSHORT'));
    };

    self.setCalendarItemContentLineTime = function(it,index,time,ev){
      if(!it || !it.DataJSON || !it.DataJSON.text) return;
      var old = it.DataJSON.text;
      var lines = old.split("\n");
      if(index < 0 || index >= lines.length) return;

      var parsed = self.parseCalendarItemContentLine(lines[index]);
      if(parsed.teacherOnly && self.user.Teacher != 1){
        return;
      }

      var newTime = null;
      if(time !== "-" && time !== null && time !== ""){
        var t = parseInt(time,10);
        if(!isNaN(t) && self.calendarNoteLineTimeChoices.indexOf(t) != -1){
          newTime = t;
        }
      }
      parsed.time = newTime;
      lines[index] = self.buildCalendarItemContentLine(parsed);

      it.DataJSON.text = lines.join("\n");
      it.Data = JSON.stringify(it.DataJSON);
      self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":it.User, "date":it.Date, "ID":it.ID, "data":it.Data}).then(function(result){
        if(result.ID) it.ID = result.ID;
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
        it.DataJSON.text = old;
      });
    };

    self.countCalendarNoteLineTimes = function(text){
      if(!text || text == "") return 0;
      var r = 0;
      var lines = String(text).split("\n");
      for(var i=0; i < lines.length; i++){
        var t = self.parseCalendarItemContentLine(lines[i]).time;
        if(t !== null) r += t;
      }
      return r;
    };

    self.hasOpenCalendarTasksToday = function(){
      var now = moment().format("YYYY-MM-DD");
      if(!self.currentClass) return false;
      for(var i=0; i < self.classList.length; i++){
        if(self.filterCurrentClassOnly && self.classList[i].ID != self.currentClass.ID) continue;
        var classid = self.classList[i].ID;

        if(self.users[self.user.ID] && self.users[self.user.ID].calendars && self.users[self.user.ID].calendars[classid]){
          for(var z=0; z < self.users[self.user.ID].calendars[classid].length; z++){
            if(self.users[self.user.ID].calendars[classid][z].Date == now){
              var userStatus = self.getUserTaskStatus({ID:self.users[self.user.ID].calendars[classid][z].Task},self.user,true);
              if(userStatus.Status != "OK" && userStatus.Status != "?") return true;
            }
          }
        }
        if(self.users[self.user.ID] && self.users[self.user.ID].calendars && self.users[self.user.ID].calendarNotes[classid]){
          for(var z=0; z < self.users[self.user.ID].calendarNotes[classid].length; z++){
            if(self.users[self.user.ID].calendarNotes[classid][z].Date == now){
              var lines = self.users[self.user.ID].calendarNotes[classid][z].DataJSON.text.split("\n");
              for(var x=0; x < lines.length; x++){
                if(lines[x] != '' && lines[x][0] != "✓") return true;
              }
            }
          }
        }

        if(self.classContent[classid]){
          for(var z=0; z < self.classContent[classid].classCalendar.length; z++){
            if(self.classContent[classid].classCalendar[z].Date == now){
              var userStatus = self.getUserTaskStatus({ID:self.classContent[classid].classCalendar[z].Task},self.user,true);
              if(userStatus.Status != "OK" && userStatus.Status != "?") return true;
            }
          }
          for(var z=0; z < self.classContent[classid].classCalendarNotes.length; z++){
            if(self.classContent[classid].classCalendarNotes[z].Date == now &&
               self.classContent[classid].classCalendarNotes[z].DataJSON &&
               self.classContent[classid].classCalendarNotes[z].DataJSON.Coaching == 1) {
              var found = false;
              for(var x=0; x < self.classContent[classid].classCalendarNotes[z].Checked.length; x++){
                if(self.classContent[classid].classCalendarNotes[z].Checked[x].User == self.user.ID) {
                  found = true;
                  break;
                }
              }
              if(found) return true; // if we are signed up, show red dot
            }else
            if(self.classContent[classid].classCalendarNotes[z].Date == now &&
               self.classContent[classid].classCalendarNotes[z].Checked){
              var found = false;
              for(var x=0; x < self.classContent[classid].classCalendarNotes[z].Checked.length; x++){
                if(self.classContent[classid].classCalendarNotes[z].Checked[x].User == self.user.ID) {
                  found = true;
                  break;
                }
              }
              if(!found) return true;
            }
          }
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeTaskFromCalendar = function(item,ev,skipHide){
      var deferred = $q.defer();
      var p = {"action":"removeTaskFromCalendar", "itemid":item.ID, "classid":self.currentClass.ID};
      self.apiPost("ajax",p)
       .then(function(data) {
          deferred.resolve();
          if(!skipHide) $mdDialog.hide();

          if(self.user.Teacher == 1 && self.currentClass){
            // teacher can ask to delete all similar entries in other calendars too
            var found = 0;
            for(var i=0; i < self.currentClass.students.length; i++){
              var sid = self.currentClass.students[i].ID;
              for(var z=0; z < self.users[sid].calendars[self.currentClass.ID].length; z++){
                var item2 = self.users[sid].calendars[self.currentClass.ID][z];
                if(item2 != item && item2.Date == item.Date && item2.Task == item.Task){
                  found++;
                  break;
                }
              }
            }
            if(found){
              self.confirm('<div style="color:red;">'+$filter('trans')('ASKREMOVEALLCALENDARNOTE',found)+'</div>','<i class="fa fa-fw fa-trash-o"></i> '+$filter('trans')('DELETE'),ev).then(function(){
                for(var i=0; i < self.currentClass.students.length; i++){
                  var sid = self.currentClass.students[i].ID;
                  for(var z=0; z < self.users[sid].calendars[self.currentClass.ID].length; z++){
                    var item2 = self.users[sid].calendars[self.currentClass.ID][z];
                    if(item2 != item && item2.Date == item.Date && item2.Task == item.Task){
                      self.apiPost("ajax",{"action":"removeTaskFromCalendar", "itemid":item2.ID, "classid":self.currentClass.ID})
                      break;
                    }
                  }
                }              
              });
            }
          }        
          self.keepAliveCallback();
       },function(data){
          self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeTaskFromClassCalendar = function(item,ev,skipHide){
      var deferred = $q.defer();
      var p = {"action":"removeTaskFromClassCalendar", "itemid":item.ID, "classid":self.currentClass.ID};
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve();
         if(!skipHide) $mdDialog.hide();
         self.keepAliveCallback();
       },function(data){
         self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.copyUserTaskToOtherStudents = function(task,ev){
      self.showDialog({
        templateUrl: "copyUserTaskToOtherStudents.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.selection = [task.Owner];
          $scope.disabled = [task.Owner];
          $scope.required = [task.Owner];
          $scope.smallScreen = self.isSmallScreen;

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            self.closeDialog($scope.dialogElement);

            // copy now
            for(var z=0; z < $scope.selection.length; z++){
              var sid = $scope.selection[z];
              if(sid == task.Owner) continue;
              var t = JSON.parse(angular.toJson(task));
              t.Owner = sid;
              self.copyUserTask(t,null,ev);
            }                    
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.copyTasksIntoStudentsCalendars = function(selected,date,ev){
      self.showDialog({
        templateUrl: "copyStudentCalendarItem.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            self.closeDialog($scope.dialogElement);

            // copy now
            for(var z=0; z < $scope.selection.length; z++){
              var sid = $scope.selection[z];
              self.addTasksToUsersCalendar({ID:sid},selected,date);
            }                    
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasTaskInCalendarsOfClass = function(task){
      if(!self.currentClass) return false;
      var found = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        var cal = self.users[self.currentClass.students[i].ID].calendars;
        if(!cal) continue;
        var classcal = cal[self.currentClass.ID];
        if(classcal)
          for(var z=0; z < classcal.length; z++){
            if(classcal[z].Task == task.ID) {
              found++;
              break;
            }
          }
      }
      return found > self.currentClass.students.length / 2;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTaskToCalendarInClass = function(task,ev){
      self.openClassCalendarView(task,null,null,ev);
    };  
    self.addTasksToCalendarInClass = function(list,ev){
      self.openClassCalendarView(list,null,null,ev);
    }
    self.isTaskInCalendarInClass = function(task,currentClass){  
      if(!currentClass) return null;
      if(self.classContent[currentClass.ID].classCalendarByTask &&
         self.classContent[currentClass.ID].classCalendarByTask[task.ID] &&
         self.classContent[currentClass.ID].classCalendarByTask[task.ID].length > 0) {
        var t = self.classContent[currentClass.ID].classCalendarByTask[task.ID];
        var found = false;
        for(var i = t.length-1; i >= 0; i--){
          if(moment(t[i].Date).isBefore(moment().subtract(2, "week"))) continue;
          found = true;
          break;
        }   
        if(found)        
          return self.classContent[currentClass.ID].classCalendarByTask[task.ID];

      }

      if(self.user.Teacher == 0)        
        if(self.users[self.user.ID].calendarsByTask &&
           self.users[self.user.ID].calendarsByTask[currentClass.ID] &&
           self.users[self.user.ID].calendarsByTask[currentClass.ID][task.ID] &&
           self.users[self.user.ID].calendarsByTask[currentClass.ID][task.ID].length > 0) {
          var t = self.users[self.user.ID].calendarsByTask[currentClass.ID][task.ID];
          var found = false;
          for(var i = t.length-1; i >= 0; i--){
            if(moment(t[i].Date).isBefore(moment().subtract(2, "week"))) continue;
            found = true;
            break;
          }   
          if(found)        
            return self.users[self.user.ID].calendarsByTask[currentClass.ID][task.ID];
        }

      return null;
    }
    self.isTasksInCalendarPassed = function(list){
      var now = moment();
      for(var i=0; i < list.length; i++){
        if(moment(list[i].Date).diff(now, 'days') >= 0) return false;
      }
      return true;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTasksToUsersCalendar = function(student,taskids,date){
      var deferred = $q.defer();
      var p = {"action":"addTasksToCalendar", "taskids":taskids.join(","),
               "classid":self.currentClass.ID, "date":date};
      if(student.ID != self.user.ID) p.student = student.ID;
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve();
         self.keepAliveCallback();
       },function(data){
         self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTasksToClassCalendar = function(taskids,date){
      var deferred = $q.defer();
      var p = {"action":"addTasksToClassCalendar", "taskids":taskids.join(","),
               "classid":self.currentClass.ID, "date":date};
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve();
         self.keepAliveCallback();
       },function(data){
         self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.adjustCalendarTaskTime = function(calendaritem, task, change){
      if(!calendaritem.Time && calendaritem.Time !== 0){
        if(task.Time != '0') calendaritem.Time = parseInt(task.Time);
      }
      if(!calendaritem.Time) calendaritem.Time = 0;
      calendaritem.Time = parseInt(calendaritem.Time);
      calendaritem.Time += change;
      if(calendaritem.Time < 0) calendaritem.Time = 0;
      if(calendaritem.Time > 995) calendaritem.Time = 995;
      var p = {"action":"updateCalendarTaskItem", "ID":calendaritem.ID,
               "data":JSON.stringify(calendaritem)};
      self.apiPost("ajax",p)
       .then(function(data) {

       },function(data){
         self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
    };
    self.adjustClassCalendarTaskTime = function(calendaritem, task, change){
      if(!calendaritem.Time && calendaritem.Time !== 0){
        if(task.Time != '0') calendaritem.Time = parseInt(task.Time);
      }
      if(!calendaritem.Time) calendaritem.Time = 0;
      calendaritem.Time = parseInt(calendaritem.Time);
      calendaritem.Time += change;
      if(calendaritem.Time < 0) calendaritem.Time = 0;
      if(calendaritem.Time > 995) calendaritem.Time = 995;
      var p = {"action":"updateClassCalendarTaskItem", "ID":calendaritem.ID,
               "data":JSON.stringify(calendaritem)};
      self.apiPost("ajax",p)
       .then(function(data) {

       },function(data){
         self.alert($filter('trans')('ERROROCCURRED',data.error));
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // user calendar
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addCalendarItemContentLine = function(it,content,ev){
      var old = it.DataJSON.text;
      var n = content ? self.trimHTML(content) : "";
      if(n == "") return;
      function escapeHtml(unsafe) {
          return unsafe
               .replace(/&/g, "&amp;")
               .replace(/</g, "&lt;")
               .replace(/>/g, "&gt;")
               .replace(/"/g, "&quot;")
               .replace(/'/g, "&#039;");
      };
      n = escapeHtml(n);
      n = n.replace(/\n/g,"<br>"); // replace all line breaks if exist
      n = n.replace(/¶/g,"");

      if(!it.DataJSON.text) it.DataJSON.text = "";
      it.DataJSON.text += (it.DataJSON.text != "" ? "\n" : "")+(self.user.Teacher == 1 ? '¶':'')+n;      
      it.Data = JSON.stringify(it.DataJSON);
      self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":it.User, "date":it.Date, "ID":it.ID, "data":it.Data}).then(function(result){
        if(result.ID) it.ID = result.ID;
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
        it.DataJSON.text = old;
      });
    };

    self.getCalendarItemContentLine = function(it,index){
      var old = it.DataJSON.text;
      var lines = old.split("\n");
      var parsed = self.parseCalendarItemContentLine(lines[index]);
      var line = parsed.text;
      line = line.replace(/<br>/g, "\n");
      var div = document.createElement("div");
      div.innerHTML = line;
      line = div.textContent || div.innerText || "";      
      function unescapeHtml(safe) {
          return safe
               .replace(/&amp;/g, "&")
               .replace(/&lt;/g, "<")
               .replace(/&gt;/g, ">")
               .replace(/&quot;/g, '"')
               .replace(/&#039;/g, "'");
      };
      return unescapeHtml(line);
    };

    self.updateCalendarItemContentLine = function(it,index,value,ev){
      var old = it.DataJSON.text;
      var lines = old.split("\n");
      var parsedOld = self.parseCalendarItemContentLine(lines[index]);
      var n = value ? self.trimHTML(value) : "";
      n = n.replace(/¶/g,"");
      function escapeHtml(unsafe) {
          return unsafe
               .replace(/&/g, "&amp;")
               .replace(/</g, "&lt;")
               .replace(/>/g, "&gt;")
               .replace(/"/g, "&quot;")
               .replace(/'/g, "&#039;");
      };
      n = escapeHtml(n);
      n = n.replace(/\n/g,"<br>"); // replace all line breaks if exist
      if(n == "") {
        self.deleteCalendarItemContentLine(it,index,ev);
        return;
      };

      parsedOld.text = n;
      lines[index] = self.buildCalendarItemContentLine(parsedOld);
      it.DataJSON.text = lines.join("\n");
      it.Data = JSON.stringify(it.DataJSON);
      self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":it.User, "date":it.Date, "ID":it.ID, "data":it.Data}).then(function(result){
        if(result.ID) it.ID = result.ID;
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
        it.DataJSON.text = old;
      });
    };

    self.copyCalendarItemContentLine = function(it,index,ev){
      // ask for students to copy to
      var lines = it.DataJSON.text.split("\n");
      var cLine = (lines[index][0] == "✓" ? lines[index].slice(1) : lines[index]).replace(/¶/,"");

      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "copyStudentCalendarItem.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            self.closeDialog($scope.dialogElement);

            // copy now
            for(var i=0; i < $scope.selection.length; i++){
              var sid = $scope.selection[i];
              var hasItem = false;
              for(var z=0; z < self.users[sid].calendarNotes[self.currentClass.ID].length; z++){
                var item = self.users[sid].calendarNotes[self.currentClass.ID][z];
                // check if existing item
                if(item != it && item.Date == it.Date && item.DataJSON && item.DataJSON.text){
                  hasItem = true;
                  var found = false;
                  var lines = item.DataJSON.text.split("\n");
                  for(var x=0; x < lines.length; x++){
                    var nLine = (lines[x][0] == "✓" ? lines[x].slice(1) : lines[x]).replace(/¶/,"");
                    if(nLine == cLine){
                      found = true;
                      break;
                    }
                  }
                  if(found) break; // exists, not add again
                  lines.push(cLine);
                  item.DataJSON.text = lines.join("\n");
                  item.Data = JSON.stringify(item.DataJSON);
                  self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":item.Class, "user":sid, "date":item.Date, "ID":item.ID, "data":item.Data});
                  break;
                }
              }
              if(!hasItem){
                // add it now
                var nItem = {text:cLine};
                self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":sid, "date":it.Date, "ID":-1, "data":JSON.stringify(nItem)}).then(function(result){
                  self.keepAliveCallback();
                });
              }
            }                    
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.deleteCalendarItemContentLine = function(it,index,ev){
      self.confirm('<div style="color:red;">'+$filter('trans')('ASKREMOVECALENDARNOTE')+'</div>','<i class="fa fa-fw fa-trash-o"></i> '+$filter('trans')('DELETE'),ev).then(function(){
        var old = it.DataJSON.text;
        var lines = old.split("\n");
        var oldLine = (lines[index][0] == "✓" ? lines[index].slice(1) : lines[index]).replace(/¶/,"");
        lines.splice(index,1);
        it.DataJSON.text = lines.join("\n");
        it.Data = JSON.stringify(it.DataJSON);
        self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":it.User, "date":it.Date, "ID":it.ID, "data":it.Data}).then(function(result){
          if(result.ID) it.ID = result.ID;
          if(self.user.Teacher == 1 && self.currentClass){
            // teacher can ask to delete all similar entries in other calendars too
            var found = 0;
            for(var i=0; i < self.currentClass.students.length; i++){
              var sid = self.currentClass.students[i].ID;
              for(var z=0; z < self.users[sid].calendarNotes[self.currentClass.ID].length; z++){
                var item = self.users[sid].calendarNotes[self.currentClass.ID][z];
                if(item != it && item.Date == it.Date && item.DataJSON && item.DataJSON.text){
                  var lines = item.DataJSON.text.split("\n");
                  for(var x=0; x < lines.length; x++){
                    var nLine = (lines[x][0] == "✓" ? lines[x].slice(1) : lines[x]).replace(/¶/,"");
                    if(nLine == oldLine){
                      found++;
                      break;
                    }
                  }
                }
              }
            }
            if(found){
              self.confirm('<div style="color:red;">'+$filter('trans')('ASKREMOVEALLCALENDARNOTE',found)+'</div>','<i class="fa fa-fw fa-trash-o"></i> '+$filter('trans')('DELETE'),ev).then(function(){
                for(var i=0; i < self.currentClass.students.length; i++){
                  var sid = self.currentClass.students[i].ID;
                  for(var z=0; z < self.users[sid].calendarNotes[self.currentClass.ID].length; z++){
                    var item = self.users[sid].calendarNotes[self.currentClass.ID][z];
                    if(item != it && item.Date == it.Date && item.DataJSON && item.DataJSON.text){
                      var found = false;
                      var lines = item.DataJSON.text.split("\n");
                      for(var x=0; x < lines.length; x++){
                        var nLine = (lines[x][0] == "✓" ? lines[x].slice(1) : lines[x]).replace(/¶/,"");
                        if(nLine == oldLine){
                          lines.splice(x,1);
                          found = true;
                          break;
                        }
                      }
                      if(!found) continue;
                      item.DataJSON.text = lines.join("\n");
                      item.Data = JSON.stringify(item.DataJSON);
                      self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":item.Class, "user":item.User, "date":item.Date, "ID":item.ID, "data":item.Data});
                    }
                  }
                }                
              });
            }
          }        

        },function(data, status, headers, config) {
          self.alert("Speichern fehlgeschlagen: "+data.error);
          it.DataJSON.text = old;
        });
      });
    };

    self.toggleCalendarItemContentLine = function(it,index,ev){
      var old = it.DataJSON.text;
      var lines = old.split("\n");
      if(lines[index][0] == "✓"){
        lines[index] = lines[index].slice(1);
      }else{
        lines[index] = "✓"+lines[index];
      }
      it.DataJSON.text = lines.join("\n");
      it.Data = JSON.stringify(it.DataJSON);
      self.apiPost("ajax",{"action":"updateCalendarNoteItem", "classid":it.Class, "user":it.User, "date":it.Date, "ID":it.ID, "data":it.Data}).then(function(result){
        if(result.ID) it.ID = result.ID;
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
        it.DataJSON.text = old;
      });
    };


    self.lastCalendarDate = null;
    self.lastCalendarMode = "months";

    self.openCalendarView = function(student,taskToAdd,removeItem,dayToOpen,ev){
      var deferred = $q.defer();
      if(self.currentCalendarDialog){
        self.closeDialog(self.currentCalendarDialog);
        self.currentCalendarDialog = null;
      }
      self.track('calendaropened',null);

      self.lastCalendarMode = self.userViewData["calendarMode"] ? self.userViewData["calendarMode"] : self.lastCalendarMode;
      if(self.lastCalendarDate == null && self.lastCalendarMode == "day") self.lastCalendarMode = "months";

      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "showStudentCalendar.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: true,
          onRemoving:function(){
            self.currentCalendarDialog = null;
            if(self.user.Teacher == 0) self.showCalendarDot = self.hasOpenCalendarTasksToday();
            self.track('calendarclosed',null);
          },
          controller: function ($scope, $mdDialog) {
            setTimeout(function(){
              self.currentCalendarDialog = $scope.dialogElement;
              // scroll to current day
              var d = $('.calendarToday').get(0);
              if(d) d.scrollIntoView({ behavior: "smooth", block: "start" }, 50);               
            },100);
            $scope.self = self;
            $scope.taskToAdd = taskToAdd;
            $scope.student = student;
            $scope.mode = taskToAdd ? (self.lastCalendarMode == "weeks" ? self.lastCalendarMode : 'months') : self.lastCalendarMode;

            if(dayToOpen) {
              self.lastCalendarDate = moment(dayToOpen);
              $scope.mode = "day";
            }

            $scope.calendars = self.users[student.ID].calendars;
            $scope.calendarsByDate = self.users[student.ID].calendarsByDate;
            $scope.calendarsByTask = self.users[student.ID].calendarsByTask;
            $scope.calendarNotes = self.users[student.ID].calendarNotes;

            $scope.classCalendars = {};
            $scope.classCalendarsByDate = {};
            $scope.classCalendarsByTask = {};
            for(var i=0; i < self.classList.length; i++){              
              if(self.classContent && self.classContent[self.classList[i].ID] && 
                 self.classContent[self.classList[i].ID].classCalendar){
                $scope.classCalendars[self.classList[i].ID] = self.classContent[self.classList[i].ID].classCalendar;
                $scope.classCalendarsByDate[self.classList[i].ID] = self.classContent[self.classList[i].ID].classCalendarByDate;
                $scope.classCalendarsByTask[self.classList[i].ID] = self.classContent[self.classList[i].ID].classCalendarByTask;
              }
            }

            $scope.countTotalDayTime = function(d){
              // sum up all items in that day
              var r = 0;
              for(var k in $scope.calendars){
                if(self.filterCurrentClassOnly && k != self.currentClass.ID) continue;
                for(var i=0; i < $scope.calendars[k].length; i++){
                  if($scope.calendars[k][i].Date == d.date) {
                    var t = self.getTaskByID($scope.calendars[k][i].Task);
                    if(!t) continue;
                    if($scope.calendars[k][i].Time ||
                       $scope.calendars[k][i].Time === 0 ||
                       $scope.calendars[k][i].Time === '0'){
                      r += parseInt($scope.calendars[k][i].Time);
                    }else{
                      if(t.task && t.task.Time)
                        r += parseInt(t.task.Time);
                    }
                  }
                }
                if(self.classContent && self.classContent[k] && 
                   self.classContent[k].classCalendar)
                for(var i=0; i < self.classContent[k].classCalendar.length; i++){
                  if(self.classContent[k].classCalendar[i].Date == d.date) {
                    var t = self.getTaskByID(self.classContent[k].classCalendar[i].Task);
                    if(!t) continue;
                    if(self.classContent[k].classCalendar[i].Time ||
                       self.classContent[k].classCalendar[i].Time === 0 ||
                       self.classContent[k].classCalendar[i].Time === '0'){
                      r += parseInt(self.classContent[k].classCalendar[i].Time);
                    }else{
                      if(t.task && t.task.Time)
                        r += parseInt(t.task.Time);
                    }
                  }
                }

                if(self.classContent && self.classContent[k] && 
                   self.classContent[k].classCalendarNotes)
                for(var i=0; i < self.classContent[k].classCalendarNotes.length; i++){
                  if(self.classContent[k].classCalendarNotes[i].Date == d.date && 
                     self.classContent[k].classCalendarNotes[i].DataJSON){
                    var classNote = self.classContent[k].classCalendarNotes[i];
                    var classLineTimes = self.countCalendarNoteLineTimes(classNote.DataJSON.Text);
                    if(classLineTimes > 0){
                      r += classLineTimes;
                    }else
                    if(classNote.DataJSON.Time || classNote.DataJSON.Time === 0 || classNote.DataJSON.Time === '0'){
                      r += parseInt(classNote.DataJSON.Time);
                    }
                  }
                }

                if($scope.calendarNotes && $scope.calendarNotes[k])
                for(var i=0; i < $scope.calendarNotes[k].length; i++){
                  if($scope.calendarNotes[k][i].Date == d.date &&
                     $scope.calendarNotes[k][i].DataJSON &&
                     $scope.calendarNotes[k][i].DataJSON.text){
                    r += self.countCalendarNoteLineTimes($scope.calendarNotes[k][i].DataJSON.text);
                  }
                }
              }

              return r + " "+ $filter('trans')('MINUTESSHORT');
            };
            
            $scope.addTaskToCalendar = function(date,ev){
              self.showLoadingIndicator(ev,function(done){
                if($scope.taskToAdd.Type == 'user' && $scope.taskToAdd.Owner == $scope.student.ID && !$scope.taskToAdd.LearningGoal){
                  self.copyUserTask($scope.taskToAdd,date,ev).then(function(task){
                    $scope.taskToAdd = null;
                    console.log("Duplicate user task done.");
                    // moved from old date
                    if(removeItem) {
                      var t = self.getTaskByID(removeItem.Task).task;
                      if(t.Type == "user" && t.Owner == $scope.student.ID && !t.LearningGoal){
                        self.apiPost("ajax",{"action":"removeUserTask", "ID":t.ID});
                      }else
                        self.removeTaskFromCalendar(removeItem,ev,true);
                    }
                    deferred.resolve();
                    done();
                  });
                }else
                self.addTasksToUsersCalendar($scope.student,[$scope.taskToAdd.ID],date).then(function(){
                  if(self.user.Teacher == 1){
                    // ask to add it to other students too
                    var selected = [$scope.taskToAdd.ID];
                    self.confirmAndHide("COPYINTOCALENDARS",$filter('trans')('COPYCALENDARNOTEHINT')+"?",$filter('trans')('COPY'),ev).then(function(){
                      self.copyTasksIntoStudentsCalendars(selected,date);
                    },function(){});
                  }

                  $scope.taskToAdd = null;
                  // moved from old date
                  if(removeItem) self.removeTaskFromCalendar(removeItem,ev,true);
                  deferred.resolve();
                  done();
                });
              });
            };

            $scope.selectTasksForCalendar = function(student,date,ev){
              if(!self.currentClass) return;
              var current = [];
              // pick one or more tasks and add to selected date
              self.pickTasks(current, self.currentClass.ID, student, function(selected){
                if(selected.length == 0) return;
                self.showLoadingIndicator(ev,function(done){
                  self.addTasksToUsersCalendar(student,selected,date);

                  if(self.user.Teacher == 1){
                    // ask to add it to other students too
                    self.confirmAndHide("COPYINTOCALENDARS",$filter('trans')('COPYCALENDARNOTEHINT')+"?",$filter('trans')('COPY'),ev).then(function(){
                      self.copyTasksIntoStudentsCalendars(selected,date);
                    },function(){});
                  }
                });
              });
            };

            $scope.hasContentOnDate = function(d){
              for(var k in $scope.calendars){
                if(self.filterCurrentClassOnly && k != self.currentClass.ID) continue;
                for(var i=0; i < $scope.calendars[k].length; i++){
                  if($scope.calendars[k][i].Date == d.date) {
                    var t = self.getTaskByID($scope.calendars[k][i].Task);
                    if(!t) continue;
                    return true;
                  }
                }
                for(var i=0; i < $scope.calendarNotes[k].length; i++){
                  if($scope.calendarNotes[k][i].Date == d.date &&
                     $scope.calendarNotes[k][i].DataJSON &&
                     $scope.calendarNotes[k][i].DataJSON.text != '') {
                    return true;
                  }
                }
                if(self.classContent && self.classContent[k] && 
                   self.classContent[k].classCalendar)
                for(var i=0; i < self.classContent[k].classCalendar.length; i++){
                  if(self.classContent[k].classCalendar[i].Date == d.date) {
                    var t = self.getTaskByID(self.classContent[k].classCalendar[i].Task);
                    if(!t) continue;
                    return true;
                  }
                }

                if(self.classContent && self.classContent[k] && 
                   self.classContent[k].classCalendarNotes)
                for(var i=0; i < self.classContent[k].classCalendarNotes.length; i++){
                  if(self.classContent[k].classCalendarNotes[i].Date == d.date){
                    return true;
                  }
                }
              }
              return false;
            };

            self.addCalendarScope($scope);

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };
            done();
          }
        });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // class calendar 
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addClassCalendarNoteItem = function(classid,date,content,ev){
      var n = content ? self.trimHTML(content) : "";
      if(n == "") return;
      function escapeHtml(unsafe) {
          return unsafe
               .replace(/&/g, "&amp;")
               .replace(/</g, "&lt;")
               .replace(/>/g, "&gt;")
               .replace(/"/g, "&quot;")
               .replace(/'/g, "&#039;");
      };
      n = escapeHtml(n);

      var lastColor = self.userViewData["ClassCalCol"] ? self.userViewData["ClassCalCol"] : "#fff2cc"; // default yellow

      var data = {Color:lastColor,Text:n};

      self.apiPost("ajax",{"action":"addClassCalendarNoteItem", "classid":classid, "date":date, "data":JSON.stringify(data)}).then(function(result){
        self.userViewData["ClassCalCol"] = lastColor;
        self.keepAliveCallback();
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
      });    
    };

    self.getClassCalendarNoteItemText = function(s){
      function unescapeHtml(safe) {
          return safe
               .replace(/&amp;/g, "&")
               .replace(/&lt;/g, "<")
               .replace(/&gt;/g, ">")
               .replace(/&quot;/g, '"')
               .replace(/&#039;/g, "'");
      };
      return unescapeHtml(s);
    };

    self.updateClassCalendarNoteItem = function(it,value,ev){
      var n = value ? self.trimHTML(value) : "";
      function escapeHtml(unsafe) {
          return unsafe
               .replace(/&/g, "&amp;")
               .replace(/</g, "&lt;")
               .replace(/>/g, "&gt;")
               .replace(/"/g, "&quot;")
               .replace(/'/g, "&#039;");
      };
      n = escapeHtml(n);
      if(n == "") {
        self.deleteClassCalendarNoteItem(it,ev);
        return;
      };
      it.DataJSON.Text = n;
      it.Data = JSON.stringify(it.DataJSON);

      if(self.userViewData["ClassCalCol"] != it.DataJSON.Color){
         self.userViewData["ClassCalCol"] = it.DataJSON.Color;
         self.updateUserViewData();
      }

      self.apiPost("ajax",{"action":"updateClassCalendarNoteItem", 
                           "ID":it.ID, "data":it.Data}).then(function(result){
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
      });
    };

    self.getClassCalendarNoteItemTimeLabel = function(it){
      if(!it || !it.DataJSON || (!it.DataJSON.Time && it.DataJSON.Time !== 0 && it.DataJSON.Time !== '0')) return "?";
      return parseInt(it.DataJSON.Time,10) + " " + $filter('trans')('MINUTESSHORT');
    };

    self.setClassCalendarNoteItemTime = function(it,time,ev){
      if(!it || !it.DataJSON || self.user.Teacher != 1) return;
      var old = it.Data;
      if(time === "-" || time === null || time === ""){
        delete it.DataJSON.Time;
      }else{
        var t = parseInt(time,10);
        if(isNaN(t) || self.calendarNoteLineTimeChoices.indexOf(t) == -1){
          delete it.DataJSON.Time;
        }else{
          it.DataJSON.Time = t;
        }
      }
      it.Data = JSON.stringify(it.DataJSON);
      self.apiPost("ajax",{"action":"updateClassCalendarNoteItem","ID":it.ID, "data":it.Data}).then(function(result){
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
        try{ it.DataJSON = JSON.parse(old); it.Data = old; }catch(e){}
      });
    };

    self.deleteClassCalendarNoteItem = function(it,ev){
      self.confirm('<div style="color:red;">'+$filter('trans')('ASKREMOVECALENDARNOTE')+'</div>','<i class="fa fa-fw fa-trash-o"></i> '+$filter('trans')('DELETE'),ev).then(function(){
        self.apiPost("ajax",{"action":"deleteClassCalendarNoteItem", "ID":it.ID}).then(function(result){
          self.keepAliveCallback();
        },function(data, status, headers, config) {
          self.alert("Speichern fehlgeschlagen: "+data.error);
        });
      });
    };

    self.getClassCalendarNoteItemChecked = function(it,student){
      if(it.Checked){
        for(var i=0; i < it.Checked.length; i++){
          if(it.Checked[i].User == student.ID) return it.Checked[i];
        }
      }
      return false;
    };
    self.getClassCalendarNoteItemCheckedTeacher = function(it,student){
      if(it.Checked){
        for(var i=0; i < it.Checked.length; i++){
          if(it.Checked[i].User == student.ID) {
            if(!it.Checked[i].Owner || it.Checked[i].Owner == student.ID) return false;
            return true; // teacher
          }
        }
      }
      return false;
    };

    self.toggleClassCalendarNoteItem = function(it,student,ev){
      var value = self.getClassCalendarNoteItemChecked(it,student);
      var teacher = self.getClassCalendarNoteItemCheckedTeacher(it,student);
      if(self.user.Teacher == 1 && value && !teacher) {
        value = 1; // black checkmark by student, override with green now
      }else{
        value = value ? 0 : 1; //toggle
      }
      self.apiPost("ajax",{"action":"updateClassCalendarNoteItemChecked", 
                           "ID":it.ID,"student":student.ID, "value":value}).then(function(result){
        if(value == 0){
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].User == student.ID) {
               it.Checked.splice(i,1); 
               break;
            }
          }
        }else{
          if(!it.Checked) it.Checked = [];
          // remove existing
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].User == student.ID) {
               it.Checked.splice(i,1); 
               break;
            }
          }
          it.Checked.push({User:student.ID,Owner:self.user.ID});
        }
      },function(data, status, headers, config) {
        self.alert("Speichern fehlgeschlagen: "+data.error);
      });
    };

    self.signupClassCalendarNoteItem = function(it,student,slot,ev){
      if(slot){
        var value = 1;
        // already selected, save now
        for(var i=0; i < it.Checked.length; i++){
          if(it.Checked[i].User == student.ID && it.Checked[i].Slot == slot) {
             value = 0;
             break;
          }
        }
        self.apiPost("ajax",{"action":"updateClassCalendarNoteItemChecked", "slot":slot,
                             "ID":it.ID,"student":student.ID, "value":value}).then(function(result){
          self.keepAliveCallback();
        },function(e){
          if(e.error == "ALREADY_FULL"){
            self.alert($filter('trans')('COACHINGSIGNUPISFULL'));
          }else
            self.alert("Speichern fehlgeschlagen: "+data.error);
        });
      }
    };

    self.getSignupClassCalendarNoteItemComment = function(it,student,slot,ev){
      if(it.Checked){
        for(var i=0; i < it.Checked.length; i++){
          if(it.Checked[i].User == student.ID &&
             it.Checked[i].Slot == slot) return it.Checked[i].Text ? it.Checked[i].Text : '';
        }
      }
      return "";
    };

    self.signupClassCalendarNoteItemComment = function(it,student,slot,text,ev){
      var value = self.getClassCalendarNoteItemChecked(it,student);
      if(value){
        self.apiPost("ajax",{"action":"updateClassCalendarNoteItemChecked", "slot":slot,
                             "ID":it.ID,"student":student.ID, "value":1, "text":text}).then(function(result){
          self.keepAliveCallback();
        },function(e){
          self.alert("Speichern fehlgeschlagen: "+data.error);
        });
      }
    };

    self.editCoaching = function(week, mode, ev){
      if(!self.currentClass) return;

      if(!self.userViewData["IntroCoach"]){
        self.userViewData["IntroCoach"] = 1;
        self.updateUserViewData();
        self.openTeacherCoachingIntro().then(function(){
          self.editCoaching(week,ev);
        });
        return;
      }      

      if(!self.classToolSettings) self.classToolSettings = {};
      if(!self.classToolSettings[self.currentClass.ID])
          self.classToolSettings[self.currentClass.ID] = {};
      if(!self.classToolSettings[self.currentClass.ID].coaching)
          self.classToolSettings[self.currentClass.ID].coaching = [];

      self.showDialog({
        templateUrl: "showClassCalendarCoachingDialog.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        onRemoving:function(){

        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.week = week;
          $scope.mode = mode;
          $scope.item = {slots:[]};
          var nd = moment(week.currentDate, 'YYYY-MM-DD').startOf("isoWeek").format("YYYY-MM-DD");
          $scope.item.ID = nd;
          // copy & load existing
          for(var i=0; i < self.classToolSettings[self.currentClass.ID].coaching.length; i++){
            if(self.classToolSettings[self.currentClass.ID].coaching[i]["ID"] == nd){
              $scope.item = JSON.parse(angular.toJson(self.classToolSettings[self.currentClass.ID].coaching[i]));
              break;
            }
          }            

          if(mode == "weeks"){
            $scope.new = [{i:0,n:1000,text:''},{i:1,n:1000,text:''},{i:2,n:1000,text:''},
                          {i:3,n:1000,text:''},{i:4,n:1000,text:''}];             
          }
          if(mode == "day"){
            var day = moment(week.currentDate, 'YYYY-MM-DD').day();
            if(day == 0) day = 7;
            $scope.new = [{i:day-1,n:1000,text:''}];             
          }

          $scope.removeSlot = function(s){
            var p = $scope.item.slots.indexOf(s);
            $scope.item.slots.splice(p,1);
          }
          $scope.saveSlot = function(s,index){
            if(!s.text || $.trim(s.text) === '') {
              $scope.item.slots.splice(index,1);
            }
          }
          $scope.createSlotTimeout = null;
          $scope.setDelayCreateSlot = function(){
            if($scope.createSlotTimeout) {
               $timeout.cancel($scope.createSlotTimeout); // cancel delay timer now
              $scope.createSlotTimeoutDelayed = true;
            }
          }
          $scope.delayCreateSlot = function(day){
            if($scope.createSlotTimeoutDelayed){
              $scope.createSlot(day,true);
            }
          }
          $scope.createSlot = function(day,now){
            var createIt = function(){
              $scope.createSlotTimeout = null;       
              $scope.createSlotTimeoutDelayed = false;              
              if(!$scope.item.slots) $scope.item.slots = [];
              for(var i=0; i < $scope.new.length; i++){
                if($scope.new[i].i == day){
                  if(!$scope.new[i].text || $.trim($scope.new[i].text) === '') return;
                  $scope.item.slots.push({day:day,n:$scope.new[i].n,text:$scope.new[i].text});
                  $scope.new[i].text = '';       
                }
              }
            };
            if(now) createIt(); else $scope.createSlotTimeout = $timeout(createIt,500);
          };

          $scope.canUseLastWeek = function(){
            var lastWeek = moment(week.currentDate, 'YYYY-MM-DD').startOf("isoWeek").add(-1, 'weeks');
            var d = lastWeek.format("YYYY-MM-DD");
            for(var i=self.classToolSettings[self.currentClass.ID].coaching.length-1; i >= 0; i--){
              if(self.classToolSettings[self.currentClass.ID].coaching[i]["ID"] <= d){
                return true;
              }
            }
            return false;
          };

          var lastWeeks = -1;

          $scope.useLastWeek = function(){
            var lastWeek = moment(week.currentDate, 'YYYY-MM-DD').startOf("isoWeek").add(lastWeeks, 'weeks');
            var d = lastWeek.format("YYYY-MM-DD");
            lastWeeks = lastWeeks - 1;

            // copy from last week now
            var found = false;
            for(var i=self.classToolSettings[self.currentClass.ID].coaching.length-1; i >= 0; i--){
              if(self.classToolSettings[self.currentClass.ID].coaching[i]["ID"] == d){
                var last = JSON.parse(angular.toJson(self.classToolSettings[self.currentClass.ID].coaching[i]));
                if(mode == "day"){
                  var hasItemsForDay = false;
                  for(var z=0; z < last.slots.length; z++){
                    if(last.slots[z].day == $scope.new[0].i){
                      hasItemsForDay = true;
                      break;
                    }
                  }
                  if(hasItemsForDay) {
                    $scope.item.slots = [];
                    for(var z=0; z < last.slots.length; z++){
                      if(last.slots[z].day == $scope.new[0].i){
                        $scope.item.slots.push(last.slots[z]);
                        found = true;
                      }
                    }
                  }
                  if(!found) 
                    return $scope.useLastWeek(); // try again
                }
                if(mode == "weeks"){
                  $scope.item.slots = last.slots;
                  if($scope.item.slots.length == 0)
                    return $scope.useLastWeek(); // try again
                }
                return true;
              }
            }
            // not found 
            if(lastWeeks > -200){
              return $scope.useLastWeek();
            }else{
              self.alert($filter('trans')('NODATAFORDAYFOUND'),null);                
            }
          };

          $scope.save = function(){
            self.showLoadingIndicator(null,function(done){
              // wait for blur events to fire
              $timeout(function(){
                var found = false;
                // sort slots
                $scope.item.slots.sort(function(a,b){
                  return (a.day < b.day ? -1 : (a.day > b.day ? 1 : 0));
                });
                var doneSlotDay = -1;
                for(var i=0; i < self.classToolSettings[self.currentClass.ID].coaching.length; i++){
                  if(self.classToolSettings[self.currentClass.ID].coaching[i]["ID"] == $scope.item.ID){
                    // update existing item now
                    for(var x=0; x < $scope.item.slots.length; x++){
                      // remove old items 
                      if(doneSlotDay < $scope.item.slots[x].day)
                        for(var z=0; z < self.classToolSettings[self.currentClass.ID].coaching[i].slots.length; z++){
                          if(self.classToolSettings[self.currentClass.ID].coaching[i].slots[z].day == $scope.item.slots[x].day){
                            self.classToolSettings[self.currentClass.ID].coaching[i].slots.splice(z,1);
                            z--;
                          }
                        }
                      // add now
                      self.classToolSettings[self.currentClass.ID].coaching[i].slots.push($scope.item.slots[x]);
                      // sort them now
                      self.classToolSettings[self.currentClass.ID].coaching[i].slots.sort(function(a,b){
                        return (a.day < b.day ? -1 : (a.day > b.day ? 1 : 0));
                      });
                      doneSlotDay = $scope.item.slots[x].day;
                    }
                    found = true;
                    break;
                  }
                }
                if(!found) {
                  self.classToolSettings[self.currentClass.ID].coaching.push(JSON.parse(angular.toJson($scope.item)));

                  self.classToolSettings[self.currentClass.ID].coaching.sort(function(a,b){
                    return (a.ID < b.ID ? -1 : (a.ID > b.ID ? 1 : 0));
                  });
                }

                self.sendClassToolSettings(self.currentClass.ID);

                // create class calendar entries from settings now
                var createdNew = 0;
                var classCalendarNotes = self.classContent && self.classContent[self.currentClass.ID] && 
                                         self.classContent[self.currentClass.ID].classCalendarNotes ? 
                                         self.classContent[self.currentClass.ID].classCalendarNotes : []; 

                var saveDay = function(d){
                  var found = false;
                  var hasItems = [];
                  for(var s = 0; s < $scope.item.slots.length; s++){
                    var thisDay = moment($scope.item.ID , 'YYYY-MM-DD').add($scope.item.slots[s].day,"days").format("YYYY-MM-DD");
                    if(thisDay == d){
                      hasItems.push({n:$scope.item.slots[s].n,text:$scope.item.slots[s].text});
                    }
                  }

                  for(var i=0;i < classCalendarNotes.length; i++){
                    if(classCalendarNotes[i].DataJSON.Coaching && classCalendarNotes[i].Date == d){
                      found = true;

                      if(hasItems.length == 0){
                        // has no items anymore but still a Coaching Note, delete it now
                        self.apiPost("ajax",{"action":"deleteClassCalendarNoteItem", "ID":classCalendarNotes[i].ID});
                        classCalendarNotes.splice(i,1);
                      }else{
                        // update the calendar note now
                        classCalendarNotes[i].DataJSON.slots = hasItems;
                        classCalendarNotes[i].Data = angular.toJson(classCalendarNotes[i].DataJSON);
                        self.apiPost("ajax",{"action":"updateClassCalendarNoteItem", 
                               "ID":classCalendarNotes[i].ID, "data":classCalendarNotes[i].Data});
                      }
                      break;
                    }
                  }
                  if(!found && hasItems.length > 0){
                    // create calendar note item now
                    var data = {"Coaching":1,"Color":"#d9ead3","Text":"Coaching","slots":hasItems};
                    createdNew++;

                    self.apiPost("ajax",{"action":"addClassCalendarNoteItem", 
                                         "classid":self.currentClass.ID,
                                         "date":d, "data":angular.toJson(data)}).then(function(){
                      createdNew--;
                      if(createdNew <= 0) self.keepAliveCallback();
                    });
                  }
                };

                if(mode == "weeks"){
                  for(var z=0; z < 5; z++){
                    var d = moment(week.currentDate, 'YYYY-MM-DD').add(z, 'days').format("YYYY-MM-DD");
                    saveDay(d);
                  }
                }
                if(mode == "day"){
                  var d = moment(week.currentDate, 'YYYY-MM-DD').format("YYYY-MM-DD");
                  saveDay(d);
                }

                done();
                self.closeDialog($scope.dialogElement);              
              },600);
            });
          }
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.openClassCalendarView = function(taskToAdd,removeItem,dayToOpen,ev){
      var deferred = $q.defer();
      if(self.currentCalendarDialog){
        self.closeDialog(self.currentCalendarDialog);
        self.currentCalendarDialog = null;
      }

      if(!self.userViewData["IntroCC"]){
        self.userViewData["IntroCC"] = 1;
        self.updateUserViewData();
        self.openTeacherClassCalendarIntro().then(function(){
          self.openClassCalendarView(taskToAdd,removeItem,dayToOpen,ev);
        });
        return;
      }

      self.lastCalendarMode = self.userViewData["calendarMode"] ? self.userViewData["calendarMode"] : self.lastCalendarMode;
      if(self.lastCalendarDate == null && self.lastCalendarMode == "day") self.lastCalendarMode = "months";

      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "showClassCalendar.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: true,
          onRemoving:function(){
            self.currentCalendarDialog = null;
          },
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.taskToAdd = taskToAdd;
            
            $scope.colorChoice = self.folderColors;

            $scope.mode = taskToAdd ? (self.lastCalendarMode == "weeks" ? self.lastCalendarMode : 'months') : self.lastCalendarMode;

            $scope.classCalendar = self.classContent && self.classContent[self.currentClass.ID] && 
                                   self.classContent[self.currentClass.ID].classCalendar ? 
                                   self.classContent[self.currentClass.ID].classCalendar : []; 

            $scope.classCalendarByDate = self.classContent && self.classContent[self.currentClass.ID] && 
                                         self.classContent[self.currentClass.ID].classCalendarByDate ? 
                                         self.classContent[self.currentClass.ID].classCalendarByDate : []; 
            $scope.classCalendarByTask = self.classContent && self.classContent[self.currentClass.ID] && 
                                         self.classContent[self.currentClass.ID].classCalendarByTask ? 
                                         self.classContent[self.currentClass.ID].classCalendarByTask : []; 

            
            if(dayToOpen) {
              self.lastCalendarDate = moment(dayToOpen);
              $scope.mode = "day";
            }

            $scope.showCalendarProgress = function(ev){
              self.showClassProgress($scope.currentWeek.currentDate,ev);   
            };

            $scope.exportCalendarLink = function(ev){
              self.apiPost("ajax",{"action":"requestClassCalendarLink", "id":self.currentClass.ID}).then(function(data) {
                if(data.link){
                  copyTextToClipboard(data.link);
                  self.alert($filter('trans')('COPYEDCALENDARLINKTOCLIPBOARD'),null);                
                }
              });
            };

            $scope.switchClass = function(c){
              self.closeDialog($scope.dialogElement);
              self.openClass(c);
              $timeout(function(){
                self.openClassCalendarView();
              },500);
            };

            $scope.countChecked = function(it){
              var c = 0;
              for(var i=0; i < self.currentClass.students.length; i++)
                if(self.getClassCalendarNoteItemChecked(it,self.currentClass.students[i])){
                  c++;
                }  
              return c;
            };

            $scope.countTotalDayTime = function(d){
              // sum up all items in that day
              var r = 0;

              for(var i=0; i < $scope.classCalendar.length; i++){
                if($scope.classCalendar[i].Date == d.date) {
                  var t = self.getTaskByID($scope.classCalendar[i].Task);
                  if(!t) continue;
                  if($scope.classCalendar[i].Time ||
                     $scope.classCalendar[i].Time === 0 ||
                     $scope.classCalendar[i].Time === '0'){
                    r += parseInt($scope.classCalendar[i].Time);
                  }else{
                    if(t.task && t.task.Time)
                      r += parseInt(t.task.Time);
                  }
                }
              }
              if(self.classContent[self.currentClass.ID] && 
                 self.classContent[self.currentClass.ID].classCalendarNotes)
              for(var i=0; i < self.classContent[self.currentClass.ID].classCalendarNotes.length; i++){
                if(self.classContent[self.currentClass.ID].classCalendarNotes[i].Date == d.date && 
                   self.classContent[self.currentClass.ID].classCalendarNotes[i].DataJSON){
                  var classNote = self.classContent[self.currentClass.ID].classCalendarNotes[i];
                  var classLineTimes = self.countCalendarNoteLineTimes(classNote.DataJSON.Text);
                  if(classLineTimes > 0){
                    r += classLineTimes;
                  }else
                  if(classNote.DataJSON.Time || classNote.DataJSON.Time === 0 || classNote.DataJSON.Time === '0'){
                    r += parseInt(classNote.DataJSON.Time);
                  }
                }
              }

              return r + " "+ $filter('trans')('MINUTESSHORT');
            };

            $scope.addTaskToCalendar = function(date,ev){
              self.showLoadingIndicator(ev,function(done){
                var ids = [];
                if(Array.isArray($scope.taskToAdd)){
                  for(var i=0; i < $scope.taskToAdd.length; i++)
                    ids.push($scope.taskToAdd[i].ID);
                } else 
                  ids.push($scope.taskToAdd.ID);

                self.addTasksToClassCalendar(ids,date).then(function(item){
                  $scope.taskToAdd = null;
                  // moved from old date
                  if(removeItem) self.removeTaskFromClassCalendar(removeItem,ev,true);
//                  self.closeDialog($scope.dialogElement);
                  deferred.resolve({item:item,date:date});
                  done();
                });
              });
            };

            $scope.selectTasksForCalendar = function(student,date,ev){
              if(!self.currentClass) return;
              var current = [];
              // pick one or more tasks and add to selected date
              self.pickTasks(current, self.currentClass.ID, null, function(selected){
                if(selected.length == 0) return;
                self.showLoadingIndicator(ev,function(done){
                  self.addTasksToClassCalendar(selected,date);
                });
              });
            };

            $scope.hasContentOnDate = function(d){
              var k = self.currentClass.ID;
              if(self.classContent && self.classContent[k] && 
                 self.classContent[k].classCalendar)
              for(var i=0; i < self.classContent[k].classCalendar.length; i++){
                if(self.classContent[k].classCalendar[i].Date == d.date) {
                  var t = self.getTaskByID(self.classContent[k].classCalendar[i].Task);
                  if(!t) continue;
                  return true;
                }
              }

              if(self.classContent && self.classContent[k] && 
                 self.classContent[k].classCalendarNotes)
              for(var i=0; i < self.classContent[k].classCalendarNotes.length; i++){
                if(self.classContent[k].classCalendarNotes[i].Date == d.date){
                  return true;
                }
              }
              return false;
            };

            self.addCalendarScope($scope);

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };
            done();
          }
        });
      });
      return deferred.promise;
    };

    self.setJournalsLastOpenToNow = function(){
      if(!self.currentClass) return;
      for(var i=0; i < self.currentClass.students.length; i++){
        self.setLastOpenTime("lastjournal",
          self.currentClass.ID+'-'+self.currentClass.students[i].ID);
      }
      self.updateJournalNewstChangedTime = new Date().getTime();
      self.updateNewActivityBadge();
    };

    // like position = -1 or +1
    self.findRelativeStudentInCurrentClass = function(student, position){
      var pos = -1;
      for(var i=0; i < self.currentClass.students.length; i++){
        if(self.currentClass.students[i].ID == student.ID){
          pos = i;
          break;
        }
      }
      var moved = 0;
      if(pos != -1 && position < 0){
        for(var i=pos-1; i >= 0; i--){
          if(self.currentClassResultStudentFilter &&
             self.currentClassResultStudentFilter.length > 0){
            // filter is used, skip not in list
            if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) == -1) continue;
          }
          moved++;
          if(moved == Math.abs(position)){
            return self.currentClass.students[i];
          }
        }
      }
      if(pos != -1 && position > 0){
        for(var i=pos+1; i < self.currentClass.students.length; i++){
          if(self.currentClassResultStudentFilter &&
             self.currentClassResultStudentFilter.length > 0){
            // filter is used, skip not in list
            if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) == -1) continue;
          }
          moved++;
          if(moved == Math.abs(position)){
            return self.currentClass.students[i];
          }
        }
      }
      return null;
    };

    //in settings you can set {student: ,isStudent: ,topic: ,goal: ,task: ,onlyMessages: ,hasPages: ,disableFilter:}

    self.showUserJournal = function(settings, ev){
      self.showLoadingIndicator(ev,function(done){
        self.journalDisplayLimit = 15;

        $scope.disableFilter = false;

        var savedType = "";

        self.track('lastactivitiesopened',null);
        self.showDialog({
          templateUrl: "userJournal.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          state:"one",
          onRemoving: function (element, removePromise) {
            self.track('lastactivitiesclosed',null);
          },
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            // We reset "new" items on journal open now
            // there will be no "new" time type inside a journal

            // will store the current filter settings of the panel
            // load defaults from global settings

            $scope.filterSettings = {
              WHEN: self.selectedClassActivityTime,
              WHENHOUR : self.selectedClassActivityTimeHour,
              WHENMINUTE : self.selectedClassActivityTimeMinute,
              WHENDATE : self.selectedClassActivityTimeDate,
              WHERE: self.selectedClassActivityPlace,
              WHERETOPICS: self.currentClassResultMainTopicFilter.slice(0), // copy
              WHEREITEM: self.selectedClassActivityItem,
              WHAT: self.selectedClassActivityType,
              WHATSUB: self.selectedClassActivityTypeSub,
              WHATSEARCH: self.selectedClassActivitySearchterm,
              showCustom: self.selectedClassActivityTimeHour != 0 ||
                          self.selectedClassActivityTimeMinute != 0,
              isJournal:true
            };

            // override filter with parameter settings
            if(settings.onlyMessages) {
              $scope.filterSettings.WHEN = "ever";
              $scope.filterSettings.WHAT = "textsonly";
            }

            if(settings.disableFilter) {
              $scope.disableFilter = settings.disableFilter;
              $scope.filterSettings.WHEN = "ever";
              $scope.filterSettings.WHAT = "all";
              $scope.filterSettings.WHERE = "all";
            }

            $scope.topic = null;
            if(settings.topic) {
              $scope.filterSettings.WHERE = "topic";
              $scope.filterSettings.WHEREITEM = settings.topic;
              $scope.topic = settings.topic;
            }

            $scope.goal = null;
            if(settings.goal) {
              $scope.filterSettings.WHERE = "goal";
              $scope.filterSettings.WHEREITEM = settings.goal;
              $scope.goal = settings.goal;
            }

            $scope.task = null;
            if(settings.task) {
              $scope.filterSettings.WHERE = "task";
              $scope.filterSettings.WHEREITEM = settings.task;
              $scope.task = settings.task;
            }

            // we do not have 'new' inside the journal dialog anymore
            if($scope.filterSettings.WHEN == 'new' ||
               settings.topic || settings.goal || settings.task) {
              $scope.filterSettings.WHEN = "ever";
            }

            self.filterJournalScope($scope);

            self.currentStudent = null;
            if((typeof settings.isStudent == 'undefined') && settings.student) {
              self.currentStudent = settings.student;
            }
            $scope.student = settings.student ? settings.student : null;
            $scope.isStudent = settings.isStudent;

            $scope.selectedRefreshFilteredJournal = function() {
              $scope.refreshFilteredJournal($scope.student);
            }

            // observe changes and redraw pearls
            $scope.$watchGroup(['self.lastUpdateTime',
                                'self.journalDisplayLimit',
                                'self.updateJournalNewstChangedTime'],
                                $scope.selectedRefreshFilteredJournal);

            $scope.$watch("[filterSettings.WHEN,"+
                           "filterSettings.WHENHOUR,"+
                           "filterSettings.WHENMINUTE,"+
                           "filterSettings.WHENDATE,"+
                           "filterSettings.WHERE,"+
                           "filterSettings.WHERETOPICS,"+
                            // exlude WHEREITEM here because deep check will fail
                           "filterSettings.WHAT,"+
                           "filterSettings.WHATSUB,"+
                           "filterSettings.WHATSEARCH]", function() {
              // when filterSettings change ...

              // from the journal we do not save the global place settings
              // this will only be saved from the main panels (activities, corrections)

              if(!$scope.disableFilter) {
                if($scope.filterSettings.WHERETOPICS &&
                   $scope.filterSettings.WHERETOPICS.length == 0 &&
                   $scope.filterSettings.WHERE == 'maintopics'){
                  $scope.filterSettings.WHERE = 'all';
                }
                if($scope.filterSettings.WHERETOPICS &&
                   $scope.filterSettings.WHERETOPICS.length > 0){
                  $scope.filterSettings.WHERE = 'maintopics';
                }
              }

              $scope.filterSettings.WHENTIMELABEL =
                self.getFilterHourMinuteString($scope.filterSettings.WHENHOUR,
                                               $scope.filterSettings.WHENMINUTE);
              $scope.filterSettings.WHENDATELABEL =
                self.getFilterDateString($scope.filterSettings.WHENDATE);

              $scope.selectedRefreshFilteredJournal();

            },true); // deep watch all attributes of object


            $scope.changeTimeForMore = function(){
              if($scope.filterSettings.WHEN == "todayfrom" ||
                 $scope.filterSettings.WHEN == "yesterday") {
                $scope.filterSettings.WHEN = "thisweek";
              }else
              if($scope.filterSettings.WHEN == "thisweek" ||
                 $scope.filterSettings.WHEN == "lastweek") {
                $scope.filterSettings.WHEN = "ever";
              }
            };

            $scope.pearlLimit = 15;

            $scope.hasPages = settings.hasPages ? settings.hasPages : false;

            $scope.resetLastJournalDate = function(){
              if(self.currentClass && self.currentStudent) {
                if($scope.filterSettings.WHEN == "ever" &&
                   $scope.filterSettings.WHERE == "all"){

                  self.setLastOpenTime("lastjournal",
                    self.currentClass.ID+'-'+self.currentStudent.ID);

                  // we can listen on this changed time on all other
                  // windows, so we can update there if required
                  self.updateJournalNewstChangedTime = new Date().getTime();

                  self.updateNewActivityBadge();
                }
              }
            };

            // call now and set this journal as read
            $scope.resetLastJournalDate();

            if(self.isActivitiesPanelOpen || $scope.hasPages){
              $scope.useGallery = true;

              $scope.lastStudent = function(ev){
                var next = null;
                if($scope.task) {
                  var counter = -1;
                  do {
                    var isVisible = false;
                    next = self.findRelativeStudentInCurrentClass($scope.student,counter);
                    if(next) {
                      // TODO: this may not work from the progress table?
                      // currentTopic may not be the correct one, not sure
                      isVisible = self.isUserTaskVisibleDeep(self.currentMainTopic,
                                    self.currentTopic,$scope.task,next);
                    } else {
                      break;
                    }
                    counter--;
                  } while(next != null && isVisible == false);
                } else {
                  next = self.findRelativeStudentInCurrentClass($scope.student,-1);
                }

                if(next){
                  self.journalDisplayLimit = 15;
                  $scope.student = next;
                  self.currentStudent = next;
                  $scope.resetLastJournalDate();
                  $scope.scrollToTop();
                  $scope.selectedRefreshFilteredJournal();
                }
              };

              $scope.nextStudent = function(ev){
                var next = null;
                if($scope.task) {
                  var counter = 1;
                  do {
                    var isVisible = false;
                    next = self.findRelativeStudentInCurrentClass($scope.student,counter);
                    if(next) {
                      isVisible = self.isUserTaskVisibleDeep(self.currentMainTopic,
                                    self.currentTopic,$scope.task,next);
                    } else {
                      break;
                    }
                    counter++;
                  } while(next != null && isVisible == false);
                } else {
                  next = self.findRelativeStudentInCurrentClass($scope.student,+1);
                }

                if(next){
                  self.journalDisplayLimit = 15;
                  $scope.student = next;
                  self.currentStudent = next;
                  $scope.resetLastJournalDate();
                  $scope.scrollToTop();
                  $scope.selectedRefreshFilteredJournal();
                }
              };
            }

            $scope.smallScreen = self.isSmallScreen;

            $scope.setUpWriteJournalItem = function (ev) {
              if($scope.filterSettings.WHERE == "topic" ||
                 $scope.filterSettings.WHERE == "goal" ||
                 $scope.filterSettings.WHERE == "task")
                self.writeJournalItem(ev,
                   $scope.filterSettings.WHERE,
                   $scope.filterSettings.WHEREITEM); else
                self.writeJournalItem(ev);
            };

            //1001
            //watchers

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };


    // unused right now
    self.sendMenuToBack = function(){
      //  md-prevent-menu-close="md-prevent-menu-close"
      setTimeout(function(){
        $('.md-open-menu-container').css("z-index","79");
        $('md-backdrop.md-dialog-backdrop').css("z-index","78");
      },100);
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeLastOpenTime = function(t,id){
      self.userViewData["U"+self.user.ID+"_time_"+t+":"+id] = null;
      self.updateUserViewData();
    };
    self.setLastOpenTime = function(t,id){
      self.userViewData["U"+self.user.ID+"_time_"+t+":"+id] = new Date().getTime();
      self.updateUserViewData();
    };
    self.getLastOpenTime = function(t,id){
      var r = new Date();
      var s = self.userViewData["U"+self.user.ID+"_time_"+t+":"+id];
      if(s) r.setTime(parseInt(s)); else return 0;
      return r;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showUserClassOverviewDisplay = 'grid';
    self.showUserClassOverviewOnlyVisibleContent = true;
    self.showUserClassOverview = function(s,ev){
      self.showDialog({
        state:"one",
        targetEvent: ev,
        templateUrl: "userClassOverview.html",
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function(){

        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.s = s;
          self.currentTaskStudent = s;
          $scope.selection = {goal :null};
          $scope.keyPressed = function(e){
            if(e.keyCode == 37) $scope.lastStudent();
            if(e.keyCode == 39) $scope.nextStudent();
          };

          $scope.$watch('self.userClassViewData[self.currentClass.ID].filterMainTopics.length', function() {
            $scope.refreshGrid();
          });          


          $scope.exportClassResultsData = function(ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportProgress.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID+"&type=full&filter="+$scope.s.ID;
            var mainTopics = [];
            var mainTopic = null;
            for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
              var mt = self.classContent[self.currentClass.ID].mainTopics[i];
              
              if(self.userClassViewData[self.currentClass.ID] && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics.length > 0){
                if(self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(mt.ID) == -1) continue;
              }
              mainTopics.push(mt.ID);
              mainTopic = mt;
            }
            url += '&maintopics='+mainTopics.join(",");

            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var desc = "";
            if(mainTopics.length == 1) {
              desc += "_"+mainTopic.Name;
            }
            var filename = self.currentClass.Name+desc;
            filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
            var filename = window.cleanFilename("LearningViewExport_"+filename+"_"+moment().format('YYYY_MM_DD'))+".xlsx";
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          $scope.getRubrics = function(){
            var rubrics = [];
            for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
              var mt = self.classContent[self.currentClass.ID].mainTopics[i];
              
              if(self.userClassViewData[self.currentClass.ID] && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics.length > 0){
                if(self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(mt.ID) == -1) continue;
              }

              if(self.showUserClassOverviewOnlyVisibleContent &&
                !self.isUserMainTopicVisible(mt,$scope.s,self.currentClass)) continue; // skip this

              for(var z=0; z < mt.topics.length; z++){
                if(self.showUserClassOverviewOnlyVisibleContent && 
                  !self.isUserTopicVisible(mt.topics[z],$scope.s,self.currentClass)) continue; // skip
                if(mt.topics[z].goals.length == 0) continue;
                if(!$scope.isVisible("topic",mt.topics[z])) continue;

                for(var x=0; x < mt.topics[z].goals.length; x++){
                  if(mt.topics[z].goals[x].Rubrics && mt.topics[z].goals[x].Rubrics != ''){
                    var rs = mt.topics[z].goals[x].Rubrics.split(",");
                    for(var y = 0; y < rs.length; y++){
                      if($.trim(rs[y]) == "") continue;
                      if(rs[y][0] == "-") rs[y] = rs[y].slice(1); // remove - in front
                      if(rubrics.indexOf(rs[y]) == -1) rubrics.push(rs[y]);
                    }
                  }
                }
              }
            }       
            return rubrics;     
          };

          $scope.exportRubrics = function(format, ev){
            $scope.waitForDownload = true;
            $scope.showMode = "teacher";
            var rubrics = $scope.getRubrics();
            var url = "https://learningview.org/api/exportRubric.php?user="+self.user.ID+"&code="+self.user.Salt+"&rubrics="+encodeURIComponent(rubrics.join(","))+"&format="+format+"&mode="+$scope.showMode+'&student='+$scope.s.ID;
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = $filter('trans')('RUBRICS')+"_"+self.currentClass.Name+"_"+$scope.s.Name+"_"+$scope.s.Surname;
            filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
            var filename = window.cleanFilename('LearningView_'+filename+"_"+moment().format('YYYY_MM_DD'))+(format == "pdf" ? ".pdf" : ".xlsx");
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          $scope.refreshGrid = function(){
            $scope.columns = Math.floor(window.innerWidth / 400);
            if($scope.columns == 0) $scope.columns = 1; // min
            if(self.showUserClassOverviewDisplay == 'list') $scope.columns = 1;
            $scope.columnSize = [];
            $scope.columnItems = [];
            $scope.columnItemLength = {};
            for(var i=0; i < $scope.columns; i++){
              $scope.columnItems[i] = [];
              $scope.columnSize[i] = 0;
            }

            for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
              var mt = self.classContent[self.currentClass.ID].mainTopics[i];
              
              if(self.userClassViewData[self.currentClass.ID] && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics && 
                 self.userClassViewData[self.currentClass.ID].filterMainTopics.length > 0){
                if(self.userClassViewData[self.currentClass.ID].filterMainTopics.indexOf(mt.ID) == -1) continue;
              }

              if(self.showUserClassOverviewOnlyVisibleContent &&
                !self.isUserMainTopicVisible(mt,$scope.s,self.currentClass)) continue; // skip this
              var c = 0;
              var minSize = 99999999;
              for(var z = 0; z < $scope.columnSize.length; z++){
                if(minSize > $scope.columnSize[z]){
                  c = z;
                  minSize = $scope.columnSize[z];
                }
              }
              var len = 1; // for title
              for(var z=0; z < mt.topics.length; z++){
                if(self.showUserClassOverviewOnlyVisibleContent && 
                  !self.isUserTopicVisible(mt.topics[z],$scope.s,self.currentClass)) continue; // skip
                if(mt.topics[z].goals.length == 0) continue;
                if(!$scope.isVisible("topic",mt.topics[z])) continue;
                len++;
              }
              if(len == 1) continue; // no content here
              $scope.columnItems[c].push(mt);
              $scope.columnItemLength[mt.ID] = len;
              $scope.columnSize[c] += len;
            }    
            while(true){
              var minSize = 999999;
              var maxSize = 0;
              var minCol = 0;
              var maxCol = 0;
              for(var i=0; i < $scope.columnSize.length; i++){
                if(minSize > $scope.columnSize[i]){
                  minSize = $scope.columnSize[i];
                  minCol = i;
                }
                if(maxSize < $scope.columnSize[i]){
                  maxSize = $scope.columnSize[i];
                  maxCol = i;
                }
              }        
              if(maxCol == 0 && maxSize <= minSize+2) break; // wont get better
              if(maxSize <= minSize+1) break; // wont get better
              if($scope.columnItems[maxCol].length <= 1) break; // wont get better
              var minLength = 999999;
              var minItem = -1;

              for(var i=0; i < $scope.columnItems[maxCol].length; i++){                
                if($scope.columnItemLength[$scope.columnItems[maxCol][i].ID] == Math.floor((maxSize-minSize)/2)){
                  minLength = $scope.columnItemLength[$scope.columnItems[maxCol][i].ID];
                  minItem = i;
                  break;
                }
              }
              if(minItem == -1)
              for(var i=0; i < $scope.columnItems[maxCol].length; i++){                
                if(minLength > $scope.columnItemLength[$scope.columnItems[maxCol][i].ID]){
                  minLength = $scope.columnItemLength[$scope.columnItems[maxCol][i].ID];
                  minItem = i;
                }
              }
              if(minLength > maxSize-minSize) break; // no way to increse here
              $scope.columnSize[maxCol] -= minLength;
              $scope.columnSize[minCol] += minLength;
              $scope.columnItems[minCol].push($scope.columnItems[maxCol][minItem]);
              $scope.columnItems[maxCol].splice(minItem,1);
              if($scope.columnSize[minCol] == maxSize) break; // swapped only
            }

          }

          $scope.isVisible = function(type,item){
            var isInner = false;
            if(type == "maintopic"){
              for(var i=0; i < item.topics.length; i++){
                isInner = $scope.isVisible("topic",item.topics[i]);
                if(isInner) break;
              }
              if(!isInner) return false; // nothing inside to see
              if(self.showUserClassOverviewOnlyVisibleContent == false) return true;
              return self.isUserMainTopicVisible(item,$scope.s,self.currentClass);
            }
            if(type == "topic"){
              for(var i=0; i < item.goals.length; i++){
                isInner = $scope.isVisible("goal",item.goals[i]);
                if(isInner) break;
              }
              if(!isInner) return false; // nothing inside to see
              if(self.showUserClassOverviewOnlyVisibleContent == false) return true;
              return self.isUserTopicVisible(item,$scope.s,self.currentClass);
            }
            if(type == "goal"){
              for(var i=0; i < item.tasks.length; i++){
                isInner = $scope.isVisible("task",item.tasks[i]);
                if(isInner) break;
              }
              if(!isInner) return false; // nothing inside to see
              if(self.showUserClassOverviewOnlyVisibleContent == false) return true;
              return (self.isUserLearningGoalVisible(item, $scope.s, self.currentClass));
            }
            if(type == "task"){
              if(self.showUserClassOverviewOnlyVisibleContent == false) return true;
              return (self.isUserTaskVisible(item, $scope.s, self.currentClass));              
            }           
            return true;
          }

          $scope.openStudent = function(s) {
            if($scope.selection && $scope.selection.goal){
              var oldGoal = $scope.selection.goal;
              $scope.selection.goal = null;
              $timeout(function(){
                $scope.selection.goal = oldGoal;
              },0)
            }
            $scope.s = s;
            self.currentTaskStudent = s;
            $scope.refreshGrid();
          };

          $scope.nextStudent = function() {
            var next = $scope.getNextStudent();
            if(next){
              if($scope.selection && $scope.selection.goal){
                var oldGoal = $scope.selection.goal;
                $scope.selection.goal = null;
                $timeout(function(){
                  $scope.selection.goal = oldGoal;
                },0)
              }
              var s2 = next;
              $scope.s = s2;
              self.currentTaskStudent = s2;
              $scope.refreshGrid();
            }
          };
          $scope.lastStudent = function() {
            var next = $scope.getLastStudent();
            if(next){
              if($scope.selection && $scope.selection.goal){
                var oldGoal = $scope.selection.goal;
                $scope.selection.goal = null;
                $timeout(function(){
                  $scope.selection.goal = oldGoal;
                },100)
              }
              var s2 = next;
              $scope.s = s2;
              self.currentTaskStudent = s2;
              $scope.refreshGrid();
            }
          };
          $scope.getNextStudent = function() {
            return self.findRelativeStudentInCurrentClass($scope.s,+1);
          };
          $scope.getLastStudent = function() {
            return self.findRelativeStudentInCurrentClass($scope.s,-1);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };          

          $scope.refreshGrid();
        }
      });      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.recentNewJournalItems = [];
    self.recentNewJournalItemsCounter = 0;

    self.getRecentNewJournalItems = function(currentClassOnly) {
      self.recentNewJournalItemsCounter = 0;
      self.recentNewJournalItems = [];
      self.recentNewJournalItemsStacked = {};
      for(var i=0; i < self.users[self.user.ID].journal.length; i++) {

        var isNewItem = (self.users[self.user.ID].journal[i].isNew == "1" && (
        self.users[self.user.ID].journal[i].Type == 'folderadded' ||
        self.users[self.user.ID].journal[i].Type == 'folderremoved' ||
        self.users[self.user.ID].journal[i].Type == 'folderitemadded' ||
        self.users[self.user.ID].journal[i].Type == 'folderitemchanged' ||
        self.users[self.user.ID].journal[i].Type == 'folderitemremoved' ||
        self.users[self.user.ID].journal[i].Type == 'teachertaskreset' ||
        self.users[self.user.ID].journal[i].Type == 'teachertaskrejected' ||
        self.users[self.user.ID].journal[i].Type == 'teachertaskfeedback' ||
        self.users[self.user.ID].journal[i].Type == 'teachertaskdone' ||
        self.users[self.user.ID].journal[i].Type == 'teachergoalentry' ||
        self.users[self.user.ID].journal[i].Type == 'teachertaskentry' ||
        self.users[self.user.ID].journal[i].Type == 'teachertasknote' ||
        self.users[self.user.ID].journal[i].Type == 'taskpeerfeedbackget' ||
        self.users[self.user.ID].journal[i].Type == 'teacherrubricstatus' ||
        self.users[self.user.ID].journal[i].Type == 'taskcollectionfeedbackget' ||
        self.users[self.user.ID].journal[i].Type == 'teacherentry' ||
        self.users[self.user.ID].journal[i].Type == 'taskhintaccess' ||
        self.users[self.user.ID].journal[i].Type == 'goalteacherdone'));

        if(!isNewItem) continue;

        self.mapJournalItem(self.users[self.user.ID].journal[i]);

        if(self.users[self.user.ID].journal[i].notexists) continue;

        if((!self.currentClass || ((currentClassOnly && self.users[self.user.ID].journal[i].Class == self.currentClass.ID) || !currentClassOnly))) {
          self.mapJournalItem(self.users[self.user.ID].journal[i]);
          self.recentNewJournalItems.push(self.users[self.user.ID].journal[i]);
        }
        if((!self.currentClass || ((self.filterCurrentClassOnly && self.users[self.user.ID].journal[i].Class == self.currentClass.ID) || !self.filterCurrentClassOnly))) {
          self.recentNewJournalItemsCounter++;
        }

      }
      var mapping = {};
      for(var i=0; i < self.recentNewJournalItems.length; i++) {
        if(self.recentNewJournalItems[i].notexists) continue;
        if(self.recentNewJournalItems[i].DataJSON && self.recentNewJournalItems[i].DataJSON.Task){
          if(!mapping[self.recentNewJournalItems[i].DataJSON.Task.ID]){
            mapping[self.recentNewJournalItems[i].DataJSON.Task.ID] = 'item_'+i;
            self.recentNewJournalItemsStacked['item_'+i] = [];
          }
          self.recentNewJournalItemsStacked[mapping[self.recentNewJournalItems[i].DataJSON.Task.ID]].push(self.recentNewJournalItems[i]);
        }else{
          self.recentNewJournalItemsStacked['item_'+i] = [self.recentNewJournalItems[i]];
        }
      }
      // combine last feedbacks into taskdone / taskreject
      for(var k in self.recentNewJournalItemsStacked){
        if(self.recentNewJournalItemsStacked[k].length > 1){
          if(self.recentNewJournalItemsStacked[k][0].Type == "teachertaskdone" || 
             self.recentNewJournalItemsStacked[k][0].Type == "teachertaskrejected"){
             self.recentNewJournalItemsStacked[k][0].teacherFeedbacks = [];
            while(self.recentNewJournalItemsStacked[k][1].Type == "teachertaskfeedback"){
              self.recentNewJournalItemsStacked[k][0].teacherFeedbacks.push(self.recentNewJournalItemsStacked[k][1].DataJSON.feedback);
              // remove it from the journal, as we alrady combined it in taskdone / taskreject              
              self.recentNewJournalItemsStacked[k].splice(1,1);
              self.recentNewJournalItemsCounter--;
              if(self.recentNewJournalItemsStacked[k].length == 1) break;              
            }
          }
        }
      }
    }

    self.showNewJournalItems = function(checkMenuOpen, showJournal, ev){
      if(!self.users[self.user.ID].journal || self.newJournalItemPanelOpen || self.recentNewJournalItems.length == 0 || (checkMenuOpen && self.isMenuOpen())) {
        if(showJournal) {
          self.showUserJournal({student:self.user, isStudent:true}, ev);
        }
        return;
      }
      self.track('newactivitiesopened',null);
      self.showDialog({
        templateUrl: "showNewJournalItems.html",
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        //fullscreen:true,
        onRemoving: function(){
          self.newJournalItemPanelOpen = false;
          self.track('newactivitiesclosed',null);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.fromNewJournalItems = true;
          $scope.newfilterCurrentClassOnly = false;

          $scope.smallScreen = self.isSmallScreen;
          self.newJournalItemPanelOpen = true;

          $scope.later = function() {
            self.closeDialog($scope.dialogElement);
          };

          $scope.showAll = function(ev){
            self.closeDialog($scope.dialogElement);
            self.showUserJournal({student:self.user, isStudent:true}, ev);
          };

          $scope.ok = function() {
            self.setJournalRead($scope.newfilterCurrentClassOnly);
            self.closeDialog($scope.dialogElement);
            self.recentNewJournalItemsCounter = 0;
          };

          $scope.setFilterCurrentClassOnly = function() {
            self.getRecentNewJournalItems(self.filterCurrentClassOnly);
          }

          $scope.setnewfilterCurrentClassOnly = function() {
            $scope.newfilterCurrentClassOnly = !$scope.newfilterCurrentClassOnly;
            self.getRecentNewJournalItems($scope.newfilterCurrentClassOnly);
          }
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.setCurrentTopic = function(mt,it){
      self.previousFocusMainTopic = document.activeElement;

      $('.backButton').focus();

      self.track('topicopened',it);
      self.shiftSelectedTasks = []; // clear selection

      if(self.currentClass){
        var lastOpenTopic = self.userClassViewData[self.currentClass.ID] && self.userClassViewData[self.currentClass.ID]["lastTopic"] ? self.userClassViewData[self.currentClass.ID]["lastTopic"] : 0;
        self.userClassViewData[self.currentClass.ID]["lastTopic"] = it.ID;
        if(lastOpenTopic != self.userClassViewData[self.currentClass.ID]["lastTopic"])
          self.updateUserClassViewData(self.currentClass.ID); 
      } 

      self.learningGoalsList = it.goals;
      var ids = [];
      for(var i=0; i < self.learningGoalsList.length; i++)
        ids.push(self.learningGoalsList[i].ID);

      if(self.user.Teacher == 1 && ids.length > 0)
        self.apiPost("ajax",{action:'requestTeacherNotes',"noerror":1, type:'goals', ids:ids.join(',')}).then(function(data){
          for(var i=0; i < self.learningGoalsList.length; i++)
            if(data && data.texts[self.learningGoalsList[i].ID] != '') 
              self.learningGoalsList[i].hasTeacherNotes = true;
        });

      self.currentTopic = it;
      self.currentMainTopic = mt;
      if(self.user.Teacher == 0){
        self.userTaskLevels = self.getUserTaskLevelsInTopic();
        var levelFilter = self.getUserLevelFilter();
        if(levelFilter != 0){
          var reset = false;
          var p = [0,1,2,4,8,16,32];
          for(var n = 1; n < p.length; n++){
            if((levelFilter & p[n]) === p[n]){
              // level is in filter
              if(self.userTaskLevels.indexOf(n+"") == -1){
                reset = true;
                break;
              }
            }
          }
          if(reset) {
            self.userViewData["tlf_"+self.currentTopic.ID] = 0; // reset
            self.updateUserViewData();              
          }
        }
      }
      self.runUpLearningGoalList();
      if(self.currentClass){
        if(self.user.Teacher == "0"){
          for(var i=0; i < self.currentTopic.goals.length; i++){
            var taskIDs = [];
            for(var z=0; z < self.currentTopic.goals[i].tasks.length; z++){
              taskIDs.push(self.currentTopic.goals[i].tasks[z].ID);
            }
            if(taskIDs.length > 0)
              self.userViewData["U"+self.user.ID+"_gt_"+self.currentClass.ID+"-"+self.currentTopic.goals[i].ID] = taskIDs.join(",");
          }            
        }
        self.setLastOpenTime("topic",self.currentClass.ID+'-'+self.currentTopic.ID);
      }      
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////    
    self.openTopic = function (mt,it,ev){
      if(!it) return;
      self.showLoadingIndicator(ev,function(){
        self.setCurrentTopic(mt,it);
        //$scope.$$postDigest(function(){ $('#learningGoalsMainPage').fadeIn("fast"); });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findAndOpenTopicInClass = function(mt,it,c,ev){
      if(c && self.currentClass && c.ID != self.currentClass.ID){
        self.openClass(c);
      }

      if(self.currentClass){
        for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
          for(var z=0; z < self.classContent[self.currentClass.ID].mainTopics[i].topics.length; z++){
            if(mt.ID == self.classContent[self.currentClass.ID].mainTopics[i].ID &&
               it.ID == self.classContent[self.currentClass.ID].mainTopics[i].topics[z].ID) {
              mt = self.classContent[self.currentClass.ID].mainTopics[i];
              it = self.classContent[self.currentClass.ID].mainTopics[i].topics[z];
              break;
            }
          }
        }
      }
      self.openTopic(mt,it,ev);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.currentClassResultMainTopicFilter = [];

    self.toggleClassResultMainTopicFilter = function(mt,maintopics){
      maintopics = maintopics ? maintopics : self.currentClassResultMainTopicFilter;
      self.selectedClassActivityPlace = 'maintopics';
      var p = maintopics.indexOf(mt.ID);
      if(p >= 0) {
        maintopics.splice(p,1);
      }else{
        maintopics.push(mt.ID);
      }

      if(maintopics.length ==
         self.classContent[self.currentClass.ID].mainTopics.length ||
          maintopics.length == 0){
         while(maintopics.length > 0) maintopics.pop(); // all = none
         self.selectedClassActivityPlace = 'all';
      }
    };


    self.getFilterHourMinuteString = function(h,m){
      return ((h < 10 ? '0' :'')+h+':'+
              (m < 10 ? '0' :'')+m).toString();
    };

    self.getFilterDateString = function(d){
      return moment(new Date(d)).startOf('day').format("DD.MM.YYYY").toString();
    };

    self.getFilterMainTopicString = function(maintopics){
      maintopics = maintopics ? maintopics : self.currentClassResultMainTopicFilter;
      if(!self.currentClass || !self.classContent[self.currentClass.ID] || maintopics.length == 0)
        return $filter('trans')('FILTERALLMAINTOPICS');

      if(self.classContent[self.currentClass.ID].filterMainTopicsIsOwn)
        return $filter('trans')('FILTEROWNMATERIALSONLY');


      var names = [];
      for(var z=0; z < self.classContent[self.currentClass.ID].mainTopics.length; z++){
        var isIn = false;
        for(var i=0; i < maintopics.length; i++){
          if(maintopics[i] ==
             self.classContent[self.currentClass.ID].mainTopics[z].ID){
            isIn = true; break;
          }
        }
        if(isIn) {
          if(names.length == 3) names.push("...");
          if(names.length < 3)
             names.push(self.classContent[self.currentClass.ID].mainTopics[z].Name);
        }
      }
      if(names.length > 3) {
        return maintopics.length + " " + $filter('trans')('MAINTOPICS');
      }
      if(names.length > 0){
        return $filter('trans')('FILTERMAINTOPICSTO')+": "+ names.join(", ");
      }
      return $filter('trans')('FILTERALLMAINTOPICS');
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassCorrectionFilter = function(){
      self.currentCorrectionListLimit = Math.round($(window).height() / 140);
      if(self.selectedClassCorrectionFilter != "search")
        self.setLocalStorage("selectedClassCorrectionFilter",
                         self.selectedClassCorrectionFilter);
      self.updateClassesStatus();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showClassResultStudentFilter = function(ev,filterArray,saveBtnText,disabled){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classStudentSelection.html",
        state:"one",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.selection = [];
          $scope.disabled = disabled ? disabled : [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.saveBtnText = saveBtnText;

          if(!filterArray) filterArray = self.currentClassResultStudentFilter;

          if(filterArray &&
             filterArray.length > 0){
            for(var i=0; i < filterArray.length; i++){
              $scope.selection.push(filterArray[i]);
            }
          }else{
            for(var i=0; i < c.students.length; i++){
              $scope.selection.push(c.students[i].ID);
            }
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            while(filterArray.length > 0) filterArray.pop();

            if(c.students.length > $scope.selection.length)
              for(var i=0; i < $scope.selection.length; i++){
                filterArray.push($scope.selection[i]);
              }

            self.closeDialog($scope.dialogElement);
            // update class corrections too
            self.updateClassesStatus();
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.classHasOtherTeacherMaterials = function(c){
      var hasOwn = false;
      var hasOther = false;
      if(c){
        for(var i=0; i < self.classContent[c.ID].mainTopics.length; i++){
          var canChange = self.checkChangePermission(self.classContent[c.ID].mainTopics[i]);
          hasOwn = hasOwn || canChange;
          hasOther = hasOther || !canChange;
          if(hasOther && hasOwn) return true;
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findClassByID = function(id){
      for(var i=0; i < self.classList.length; i++){
        if(self.classList[i].ID == id) return self.classList[i];
      }
      return null;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openClass = function (it,ev, noPopups, noSaveLast){
      if(!it) return;
      if(self.currentClass && self.currentClass.ID == it.ID) return; // already open

      if(!self.userClassViewData) self.userClassViewData = [];
      if(!self.userClassViewData[it.ID]) self.userClassViewData[it.ID] = {};
      if(self.user && self.user.Teacher == "1" &&
         typeof self.userClassViewData[it.ID].currentInfoInitialized == "undefined"){
        self.userClassViewData[it.ID].currentInfoInitialized = 1;
        if(!self.userClassViewData[it.ID].currentInfoClosedAt)
          self.userClassViewData[it.ID].currentInfoClosedAt = new Date().getTime();
        self.updateUserClassViewData(it.ID);
      }

      self.track('openClass',it);
      console.log("Opening class "+it.Name+" ("+it.ID+")");
      
      if(self.currentClass){
        self.track('leaveClass',self.currentClass);
      } 

      self.currentTeacherNavigation = "Teach";
      self.manageClassView = false;
      self.shiftSelectedTasks = []; // clear selection
      
      // close notelist if open
      self.closeNotelist();

      // check if same class is already open
      var newClassOpened = !(self.currentClass && self.currentClass.ID == it.ID);

      if(newClassOpened && !noSaveLast) {
        self.apiPost("ajax",{"action":"setLastOpenClass","classid":it.ID, "noindicator":"1"});
        self.lastClassOnReset = it;
      }
      if((!self.user.lastOpenClass || self.user.lastOpenClass == "0") && !noSaveLast){
        self.apiPost("ajax",{"action":"setLastOpenClass","classid":it.ID, "noindicator":"1"});
        self.user.lastOpenClass = it.ID;
      }

      if(newClassOpened){
        self.runUpMainTopicList();
      }else{
        if(self.currentMainTopicLimit == 0) self.runUpMainTopicList();
        return; // do not perform anything else if this is already the open class now
      }

      self.currentClass = it;
      self.currentClassStudentSelection = [];
      self.toolCurrentSelectedStudents = null;
//      self.currentClassStudentClasses = [];
      self.currentClassResultStudentFilter = [];
      self.currentClassResultMainTopicFilter = [];

      if(self.userClassViewData && self.userClassViewData[self.currentClass.ID] &&
         self.userClassViewData[self.currentClass.ID].filterMainTopics){
        self.currentClassResultMainTopicFilter =
          self.userClassViewData[self.currentClass.ID].filterMainTopics;
      }
      if(self.currentClassResultMainTopicFilter.length > 0)
        self.selectedClassActivityPlace = "maintopics"; else
        self.selectedClassActivityPlace = "all";

      self.showOnlyMyMaterials = self.showOnlyMyMaterials &&
                                 self.classHasOtherTeacherMaterials(self.currentClass);

      var keep = false;
      var openLastTopic = self.userClassViewData[self.currentClass.ID] && self.userClassViewData[self.currentClass.ID]["lastTopic"] ? self.userClassViewData[self.currentClass.ID]["lastTopic"]  : 0; 

      if(openLastTopic != 0){
        for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
          for(var z=0; z < self.classContent[self.currentClass.ID].mainTopics[i].topics.length; z++){
            if(openLastTopic == self.classContent[self.currentClass.ID].mainTopics[i].topics[z].ID) {
              self.setCurrentTopic(self.classContent[self.currentClass.ID].mainTopics[i],
                                   self.classContent[self.currentClass.ID].mainTopics[i].topics[z]);
              keep = true;
            }
          }
        }
      }
      /*
      if(self.currentMainTopic && self.currentTopic)
        for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
          for(var z=0; z < self.classContent[self.currentClass.ID].mainTopics[i].topics.length; z++){
            if(self.currentMainTopic.ID == self.classContent[self.currentClass.ID].mainTopics[i].ID &&
               self.currentTopic.ID == self.classContent[self.currentClass.ID].mainTopics[i].topics[z].ID) {

              self.setCurrentTopic(self.classContent[self.currentClass.ID].mainTopics[i],
                                   self.classContent[self.currentClass.ID].mainTopics[i].topics[z]);
              keep = true;
            }
          }
        }
      */
      if(!keep){
        self.currentMainTopic = null;
        self.currentTopic = null;
      }

      //1007
      if (self.user.Teacher == 1) {
        if(!self.userClassViewData[it.ID].filterMainTopics)
          self.userClassViewData[it.ID].filterMainTopics = [];
        if(!self.userClassViewData[it.ID].filterColor)
          self.userClassViewData[it.ID].filterColor = [];
      }
      else {
        self.userClassViewData[it.ID].filterMainTopics = [];
        self.userClassViewData[it.ID].filterColor = [];
      }

      self.updateMainTopicFilterColors();
      self.updateFilterMainTopicIsOwn();

      self.updateStudentClassesStatus();
      self.updateClassesStatus();
      self.updateNewActivityBadge();
      self.updateNewFolderItemsBadge();

      if(self.setFirstTaskNotification) {
        self.openTeacherTeachIntro();
        self.setFirstTaskNotification = false;
      }

      if(!noPopups && self.user && self.user.Teacher != "1") {
        $timeout(function() {
          self.getRecentNewJournalItems(false);
          self.showNewJournalItems(false);
        }, 0);
      }

      self.keepAliveCallback(false,false); // fetch new data, no loading indicator
      return true;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.taskHintsListSortOptions = {
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { return true; },
      dragStart : function(obj){
        $('.taskHintsListSortWrapper').css({"user-select":"none"});
      },
      dragEnd : function(obj){
        $('.taskHintsListSortWrapper').css({"user-select":""});
      },
      orderChanged: function (event) {
        return true;
      },
      containment: 'body',
      clone:false
    };

    self.learningGoalRubricsSortOptions = {
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) {
        var isInSameList = sourceItemHandleScope.itemScope.sortableScope.$id === destSortableScope.$id;
        if(!isInSameList) return false;
        var goal = sourceItemHandleScope.itemScope.it || sourceItemHandleScope.itemScope.$parent.it;
        if(!goal) return false;
        return self.sortLearningGoalRubrics(goal);
      },
      orderChanged: function (event) {
        var goal = event && event.source && event.source.itemScope ? (event.source.itemScope.it || event.source.itemScope.$parent.it) : null;
        if(!goal) return false;
        self.saveLearningGoalRubricsList(goal);
        return true;
      },
      containment: 'body',
      clone:false
    };

    self.studentGroupsSortOptions = {
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { return true; },
      dragStart : function(obj){

      },
      dragEnd : function(obj){

      },
      orderChanged: function (event) {

        return true;
      },
      containment: 'body',
      clone:false
    };

    self.noteListSortOptions = {
      //restrict move across columns. move only within column.
      longTouch:true,
      accept: function (sourceItemHandleScope, destSortableScope) { return !self.teacherNotelistStudent; },
      dragStart : function(obj){

      },
