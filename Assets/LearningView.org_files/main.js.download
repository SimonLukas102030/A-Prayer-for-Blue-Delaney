    self.updateClassTaskGroups = function(it,c,groups){
      self.apiPost("ajax",{"action":"setClassesTaskGroups","ID":it.ID, "classid":c.ID, "groups":groups ? angular.toJson(groups) : ""}).then(function(){
        it.Groups = groups ? angular.toJson(groups) : "";
        self.lastGroups = groups || self.lastGroups;        
      }).then(self.keepAliveCallback);
    };


    // user tasks allowed in
    self.updateClassLearningGoalUserTasks = function(it,c,allow){
      if(!self.userViewData["IntroGUT"]){
        self.userViewData["IntroGUT"] = 1;
        self.updateUserViewData();
        self.openTeacherGoalUserTasksIntro().then(function(){
          self.updateClassLearningGoalUserTasks(it,c,allow);
        });
        return;
      }

      self.apiPost("ajax",{"action":"setClassesLearningGoalUserTasks","ID":it.ID, "classid":c.ID, "allow":allow}).then(function(){
        it.AllowUserTasks = allow;
      }).then(self.keepAliveCallback);
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // class MainTopic visibility checks and counters
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasClassesMainTopicClock = function(mt){
      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classMainTopicMapped[mt.ID]){
          if(content.classMainTopicMapped[mt.ID].mainTopic.vFrom ||
             content.classMainTopicMapped[mt.ID].mainTopic.vTo) return true;
        }
      }
      return false;
    };

    self.countClassesMainTopicVisible = function(mt){
      var c = 0;
      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classMainTopicMapped[mt.ID]){
          c++;
        }
      }
      return c;
    };

    self.countUserMainTopicVisible = function(mt,c){
      if(!self.user) return 0;
      if(!c || self.user.Teacher == "0") return 1;
      if(!mt) return 0;
      // check by visibility dates
      var now = new Date().toMysqlFormat();
      if(mt.vFrom && mt.vFrom > now) return 0;
      if(mt.vTo && mt.vTo < now) return 0;

      var total = c.students.length;
      for(var i=0; i < c.students.length; i++){
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID].Hidden == "1") total--;
        }
      }
      return total;
    };

    // uses current class, maybe add class as parameter too
    self.isUserMainTopicVisible = function(mt,s,c,withoutTime){
      if(!mt || !s || !c) return false;
      if(!withoutTime){
        var now = new Date().toMysqlFormat();
        if(mt.vFrom && mt.vFrom > now) return false;
        if(mt.vTo && mt.vTo < now) return false;
      }

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].mainTopics &&
         self.users[s.ID].classContent[c.ID].mainTopics[mt.ID]){
         if(self.users[s.ID].classContent[c.ID].mainTopics[mt.ID].Hidden == "1")
           return false;
      }
      return true;
    };

    self.getUserMainTopicChecks = function(mt,s,c){
      if(!mt || !s || !c) return 0;

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].mainTopics &&
         self.users[s.ID].classContent[c.ID].mainTopics[mt.ID]){
         return parseInt(self.users[s.ID].classContent[c.ID].mainTopics[mt.ID].Checks)|| 0;
      }
      return 0;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // class Topic visibility checks and counters
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasClassesTopicClock = function(mt,t){
      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classTopicMapped[t.ID]){
          if(content.classTopicMapped[t.ID].topic.vFrom ||
             content.classTopicMapped[t.ID].topic.vTo) return true;
        }
      }
      return false;
    };

    self.countClassesTopicVisible = function(mt,t){
      var c = 0;

      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classTopicMapped[t.ID]){
          c++;
        }
      }
      return c;
    };

    self.countUserTopicVisible = function(mt,topic,c){
      if(!self.user) return 0;
      if(!c || self.user.Teacher == "0") return 1;
      if(!mt || !topic) return 0;

      // check by visibility dates
      var now = new Date().toMysqlFormat();
      if(mt.vFrom && mt.vFrom > now) return 0;
      if(topic.vFrom && topic.vFrom > now) return 0;
      if(mt.vTo && mt.vTo < now) return 0;
      if(topic.vTo && topic.vTo < now) return 0;

      var total = c.students.length;
      for(var i=0; i < c.students.length; i++){
        var hidden = false;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].topics &&
           self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
      }
      return total;
    };

    self.isUserTopicVisible = function(t,s,c,withoutTime){
      if(!t || !s || !c) return false;
      if(!withoutTime){
        var now = new Date().toMysqlFormat();
        if(t.vFrom && t.vFrom > now) return false;
        if(t.vTo && t.vTo < now) return false;
      }

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].topics &&
         self.users[s.ID].classContent[c.ID].topics[t.ID]){
         if(self.users[s.ID].classContent[c.ID].topics[t.ID].Hidden == "1"){
           return false;
         }
      }

      return true;
    };
    self.getUserTopicChecks = function(t,s,c){
      if(!t || !s || !c) return 0;

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].topics &&
         self.users[s.ID].classContent[c.ID].topics[t.ID]){
         return parseInt(self.users[s.ID].classContent[c.ID].topics[t.ID].Checks)|| 0;
      }
      return 0;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // class LearningGoal visibility checks and counters
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.hasClassesLearningGoalClock = function(mt,t,g){
      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classGoalMapped[g.ID]){
          if(content.classGoalMapped[g.ID].goal.vFrom ||
             content.classGoalMapped[g.ID].goal.vTo) return true;
        }
      }
      return false;
    };

    self.countClassesLearningGoalVisible = function(mt,t,g){
      var c = 0;
      for(var i=0; i < self.classListCurrent.length; i++){
        var content = self.classContent[self.classListCurrent[i].ID];
        if(content.classGoalMapped[g.ID]){
          c++;
        }
      }
      return c;
    };

    self.countUserLearningGoalVisible = function(mt,topic,goal,c){
      if(!self.user) return 0;
      if(!c || self.user.Teacher == "0") return 1;
      if(!mt || !topic || !goal) return 0;

      // check by visibility dates
      var now = new Date().toMysqlFormat();
      if(mt.vFrom && mt.vFrom > now) return 0;
      if(topic.vFrom && topic.vFrom > now) return 0;
      if(goal.vFrom && goal.vFrom > now) return 0;
      if(mt.vTo && mt.vTo < now) return 0;
      if(topic.vTo && topic.vTo < now) return 0;
      if(goal.vTo && goal.vTo < now) return 0;

      var total = c.students.length;
      for(var i=0; i < c.students.length; i++){
        var hidden = false;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].topics &&
           self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].goals &&
           self.users[c.students[i].ID].classContent[c.ID].goals[goal.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].goals[goal.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
      }
      return total;
    };

    self.isUserLearningGoalVisible = function(goal,s,c,withoutTime){
      if(!goal || !s || !c) return false;
      if(!withoutTime){
        var now = new Date().toMysqlFormat();
        if(goal.vFrom && goal.vFrom > now) return false;
        if(goal.vTo && goal.vTo < now) return false;
      }

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].goals &&
         self.users[s.ID].classContent[c.ID].goals[goal.ID]){
         if(self.users[s.ID].classContent[c.ID].goals[goal.ID].Hidden == "1"){
           return false;
         }
      }
      return true;
    };

    self.isUserLearningGoalVisibleDeep = function(mt,topic,goal,student){
      if(topic == null) topic = self.currentTopic;
      if(topic == null) return true;
      if(mt == null) mt = self.currentMainTopic;
      if(mt == null) return true;

      var c = self.currentClass;

      if(!self.isUserMainTopicVisible(mt,student,c,true)) return false;
      if(!self.isUserTopicVisible(topic,student,c,true)) return false;
      if(!self.isUserLearningGoalVisible(goal,student,c,true)) return false;

      return true;
    };

    self.getUserLearningGoalChecks = function(goal,s,c){
      if(!goal || !s || !c) return 0;

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].goals &&
         self.users[s.ID].classContent[c.ID].goals[goal.ID]){
         return parseInt(self.users[s.ID].classContent[c.ID].goals[goal.ID].Checks)|| 0;
      }
      return 0;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // class Task visibility checks and counters
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countUserTasksVisible = function(tasks,c){
      var m = c.students.length;
      for(var i=0; i < tasks.length; i++){
        var t = self.getTaskByID(tasks[i].ID);
        var count = self.countUserTaskVisible(t.mainTopic,t.topic,t.goal,t.task,c);
        m = Math.min(count,m);
      }
      return m;
    };

    self.countUserTaskVisible = function(mt,topic,goal,task,c){
      if(!self.user) return 0;
      if(!c || self.user.Teacher == "0") return 1;
      if((!mt || !topic || !goal) && task){
        var t = self.getTaskByID(task.ID);
        if(t && t.mainTopic){
          mt = t.mainTopic;
          topic = t.topic;
          goal = t.goal;
        }
      }
      if(!mt || !topic || !goal || !task) return 1; // return 1; special case for popups without class data

      // check by visibility dates
      var now = new Date().toMysqlFormat();
      if(mt.vFrom && mt.vFrom > now) return 0;
      if(topic.vFrom && topic.vFrom > now) return 0;
      if(goal.vFrom && goal.vFrom > now) return 0;
      if(task.vFrom && task.vFrom > now) return 0;
      if(mt.vTo && mt.vTo < now) return 0;
      if(topic.vTo && topic.vTo < now) return 0;
      if(goal.vTo && goal.vTo < now) return 0;
      if(task.vTo && task.vTo < now) return 0;

      var total = c.students.length;
      for(var i=0; i < c.students.length; i++){
        var hidden = false;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics &&
           self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].mainTopics[mt.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].topics &&
           self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].topics[topic.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].goals &&
           self.users[c.students[i].ID].classContent[c.ID].goals[goal.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].goals[goal.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
        if(hidden) continue;
        if(self.users[c.students[i].ID] &&
           self.users[c.students[i].ID].classContent &&
           self.users[c.students[i].ID].classContent[c.ID] &&
           self.users[c.students[i].ID].classContent[c.ID].tasks &&
           self.users[c.students[i].ID].classContent[c.ID].tasks[task.ID]){
           if(self.users[c.students[i].ID].classContent[c.ID].tasks[task.ID].Hidden == "1"){
             hidden = true; total--;
           }
        }
      }
      return total;
    };

    self.isUserTaskVisible = function(task,s,c,withoutTime){
      if(!task || !s || !c) return false;
      if(!withoutTime && (task.vFrom || task.vTo)){
        var now = new Date().toMysqlFormat();
        if(task.vFrom && task.vFrom > now) return false;
        if(task.vTo && task.vTo < now) return false;
      }

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].tasks &&
         self.users[s.ID].classContent[c.ID].tasks[task.ID]){
         if(self.users[s.ID].classContent[c.ID].tasks[task.ID].Hidden == "1"){
           return false;
         }
      }
      return true;
    };

    self.getUserTaskChecks = function(task,s,c){
      if(!task || !s || !c) return 0;

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID] &&
         self.users[s.ID].classContent[c.ID].tasks &&
         self.users[s.ID].classContent[c.ID].tasks[task.ID]){
         return parseInt(self.users[s.ID].classContent[c.ID].tasks[task.ID].Checks)|| 0;
      }
      return 0;
    };

    self.getUserTaskChecksDeep = function(task,s,c){
      if(!task || !s || !c) return 0;

      if(self.users[s.ID] &&
         self.users[s.ID].classContent &&
         self.users[s.ID].classContent[c.ID]){
         var goal = null;
         var topic = null;
         var mainTopic = null;
         var t = self.getTaskByID(task.ID);
         if(t && t.mainTopic){
           mainTopic = t.mainTopic;
           topic = t.topic;
           goal = t.goal;
         } else return 0;

         if(self.user.Teacher == 0){
           var r = parseInt(t.task.Checks)|| 0;
           if(r != 0) return r;
           var r = parseInt(t.goal.Checks)|| 0;
           if(r != 0) return r;
           var r = parseInt(t.topic.Checks)|| 0;
           if(r != 0) return r;
           var r = parseInt(t.mainTopic.Checks)|| 0;
           if(r != 0) return r;
           return 0;
         }

         if(self.users[s.ID].classContent[c.ID].tasks &&
            self.users[s.ID].classContent[c.ID].tasks[task.ID]){
           var r = parseInt(self.users[s.ID].classContent[c.ID].tasks[task.ID].Checks) || 0;
           if(r != 0) return r;
         }
         if(self.users[s.ID].classContent[c.ID].goals &&
            self.users[s.ID].classContent[c.ID].goals[goal.ID]){
           var r = parseInt(self.users[s.ID].classContent[c.ID].goals[goal.ID].Checks)|| 0;
           if(r != 0) return r;
         }
         if(self.users[s.ID].classContent[c.ID].topics &&
            self.users[s.ID].classContent[c.ID].topics[topic.ID]){
           var r = parseInt(self.users[s.ID].classContent[c.ID].topics[topic.ID].Checks)|| 0;
           if(r != 0) return r;
         }
         if(self.users[s.ID].classContent[c.ID].tasks &&
            self.users[s.ID].classContent[c.ID].mainTopics[mainTopic.ID]){
           var r = parseInt(self.users[s.ID].classContent[c.ID].mainTopics[mainTopic.ID].Checks)|| 0;
           if(r != 0) return r;
         }
      }
      return 0;
    };

    self.getUserTaskHintApproved = function(index, task, student){
      // check if for this hint an approved message is in the task chat dialog for student
      var status = self.getUserTaskStatus(task, student ? student : self.user, true);
      if(status.FeedbackJSON && status.FeedbackJSON.length > 0){
         var asked = false;
         for(var i=status.FeedbackJSON.length-1; i >= 0; i--){
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].User == student.ID && 
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].Message == '%%ASKACCESS%%|'+task.ID+'|'+index) {
             // asked
             asked = true;
           }
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].User != student.ID && 
              status.FeedbackJSON[i].Message == '%%ACCESS%%|'+student.ID+"|"+task.ID+'|'+index) {
             // asked
             return 1;
           }
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].User != student.ID && 
              status.FeedbackJSON[i].Message == '%%DENY%%|'+student.ID+"|"+task.ID+'|'+index) {
             // asked
             return asked ? -3 : -2;
           }
        }
      }
      if(asked) return -1;
      return 0;
    };

    self.countUserTaskHintApproved = function(index, task){
      var c = 0;
      if(self.currentClass){
        for(var i=0; i < self.currentClass.students.length; i++){
          var r = self.getUserTaskHintApproved(index, task, self.currentClass.students[i]);
          if(r == 1) c++;
        }
      }
      return c;
    };
    self.countUserTaskHintAskApproved = function(index, task){
      var c = 0;
      if(self.currentClass){
        for(var i=0; i < self.currentClass.students.length; i++){
          var r = self.getUserTaskHintApproved(index, task, self.currentClass.students[i]);
          if(r == -1) c++;
        }
      }
      return c;
    };
    
    self.setUserTaskHintApproved = function(taskid,userid,hintIndex, pos){
      var p = {"action":"addTaskStatusFeedback", // position:pos+1,
          "ID":taskid,"user":userid,"classid":self.currentClass.ID, 
          "message":'%%ACCESS%%|'+userid+"|"+taskid+'|'+hintIndex, sys:1};
      if(pos || pos === 0) p.position = pos+1;    
      var t = self.getTaskByID(taskid);
      if(t.task && t.task.DataJSON.hints[hintIndex]){
        if(t.task.DataJSON.hints[hintIndex].visible == 4) p.silent = 1;
      }
      self.apiPost("ajax",p)
       .then(function(data) {
         self.keepAliveIntervalWorking = false;
         self.keepAliveCallback();
       });
    };
    self.setUserTaskHintDeny = function(taskid,userid,hintIndex, pos){
      var p = {"action":"addTaskStatusFeedback", // position:pos+1,
          "ID":taskid,"user":userid,"classid":self.currentClass.ID, 
          "message":'%%DENY%%|'+userid+"|"+taskid+'|'+hintIndex, sys:1};
      if(pos || pos === 0) p.position = pos+1;    

      self.apiPost("ajax",p)
       .then(function(data) {
         self.keepAliveIntervalWorking = false;
         self.keepAliveCallback();
       });
    };

    self.askUserTaskHintApprovel = function(taskid,userid,hintIndex){
      // append system message to task chat
      self.apiPost("ajax",{"action":"addTaskStatusFeedback",
          "ID":taskid,"user":userid,"classid":self.currentClass.ID, 
          "message":'%%ASKACCESS%%|'+taskid+'|'+hintIndex, sys:1})
       .then(function(data) {
         self.keepAliveCallback();
       });
    };

    self.setAllUsersTaskHintApproved = function(taskid,hintIndex){
      $timeout(function(){
        self.confirm($filter('trans')('ASKAPPROVEHINTFORALL'), $filter('trans')('APPROVEREQUEST'),null).then(function(){
          self.showLoadingIndicator(null,function(done){
            for(var i=0; i < self.currentClass.students.length; i++){
              if(self.getUserTaskHintApproved(hintIndex, {ID:taskid}, self.currentClass.students[i]) != 1){
                self.setUserTaskHintApproved(taskid,self.currentClass.students[i].ID,hintIndex,null);
              }
            }
          });
        });        
      },500);
    };
    self.setUsersTaskHintAskedApproved = function(taskid,hintIndex){
      $timeout(function(){
        var users = [];
        if(self.currentClass){
          for(var i=0; i < self.currentClass.students.length; i++){
            var r = self.getUserTaskHintApproved(hintIndex, {ID:taskid}, self.currentClass.students[i]);
            if(r == -1) {
              // is asking
              users.push(self.currentClass.students[i].ID);
            }
          }
          if(users.length > 0)
            self.confirm($filter('trans')('ASKAPPROVEHINTFORALLCOUNT',users.length), $filter('trans')('APPROVEREQUEST'),null).then(function(){
              self.showLoadingIndicator(null,function(done){
                for(var i=0; i < users.length; i++){
                  self.setUserTaskHintApproved(taskid,users[i],hintIndex,null);
                }
              });
            });        
        }
      },500);
    };
    self.removeAllUsersTaskHintApproved = function(taskid,hintIndex){
      $timeout(function(){
        self.confirm($filter('trans')('ASKREMOVEAPPROVEHINTFORALL'), $filter('trans')('REMOVE'),null).then(function(){
          self.showLoadingIndicator(null,function(done){
            for(var i=0; i < self.currentClass.students.length; i++){
              if(self.getUserTaskHintApproved(hintIndex, {ID:taskid}, self.currentClass.students[i]) == 1){
                self.toggleUserTaskHintApproved(taskid,self.currentClass.students[i].ID,hintIndex);
              }
            }
          });
        });        
      },500);
    }

    self.toggleUserTaskHintApproved = function(taskid,userid,hintIndex){
      // check if for this hint an approved message is in the task chat dialog for student
      var status = self.getUserTaskStatus({ID:taskid}, {ID:userid}, true);
      if(status.FeedbackJSON && status.FeedbackJSON.length > 0){
         var asked = false;
         var access = false;
         var deny = false;
         var askedPos = 0;
         var accessPos = -1;
         var denyPos = -1;
         for(var i=status.FeedbackJSON.length-1; i >= 0; i--){
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].User == userid && 
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].Message == '%%ASKACCESS%%|'+taskid+'|'+hintIndex) {
             // asked
             asked = true;
             if(askedPos == -1) askedPos = i;
           }
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].User != userid && 
              status.FeedbackJSON[i].Message == '%%ACCESS%%|'+userid+"|"+taskid+'|'+hintIndex) {
             // asked
             access = true;
             accessPos = i;
             break;
           }
           if(status.FeedbackJSON[i].Deleted != "1"  &&
              status.FeedbackJSON[i].isSys == 1 && 
              status.FeedbackJSON[i].User != userid && 
              status.FeedbackJSON[i].Message == '%%DENY%%|'+userid+"|"+taskid+'|'+hintIndex) {
             // asked
             deny = true;
             denyPos = i;
             break;
           }
        }
        if(deny){
          // remove deny again and clear logs
          self.apiPost("ajax",{"action":"removeTaskStatusFeedback",
                               "ID":taskid,
                               "user":userid,
                               "classid":self.currentClass.ID,
                               "index":denyPos}).then(function(data) {
            self.keepAliveCallback().then(function(){
              if(!access) self.setUserTaskHintApproved(taskid,userid,hintIndex,asked ? askedPos : null);
            });
          });
          return;
        }else
        if(access) {
          // remove access again and clear logs
          self.apiPost("ajax",{"action":"removeTaskStatusFeedback",
                               "ID":taskid,
                               "user":userid,
                               "classid":self.currentClass.ID,
                               "index":accessPos}).then(function(data) {
            self.keepAliveCallback();
          });
          return;
        }else
        if(asked) {
          // was asked, accept
          self.setUserTaskHintApproved(taskid,userid,hintIndex,askedPos);
          return;
        }
      }
      // not asked yet
      self.setUserTaskHintApproved(taskid,userid,hintIndex);
    };


    self.openTaskAttachment = function(hint, task, scope, ev){
      var copy = JSON.parse(JSON.stringify(hint));
      copy.index = scope.$index+1;
      copy.TaskID = task.ID;
      if(hint.visible == '5' && hint.code && hint.code != ''){
        self.prompt($filter('trans')('PROVIDEHINTCODE'),$filter('trans')('OK'),$filter('trans')('PROVIDEHINTCODEHINT'),"",ev).then(function(code){
          if(hint.code.toLowerCase() == $.trim(code.toLowerCase())){
            copy.visible = 1; 
            self.openTaskAttachment(copy,task,scope,ev);
          }else{
            self.alert($filter('trans')('PROVIDEDHINTCODEWRONG'));
          }
        });
        ev.stopPropagation();
        return;
      }
      self.track('showTaskAttachmentMedia',copy);
      if(hint.visible == '3'){
        // check / ask for approval
        var approved = self.user.Teacher == 1 ? 1 : self.getUserTaskHintApproved(scope.$index, task, self.user);
        if(approved == 0){
          // ask now
          self.confirm($filter('trans')('ASKSOLUTIONHINTAPPROVAL'), $filter('trans')('ASK'),ev).then(function(){
            self.askUserTaskHintApprovel(task.ID,self.user.ID,scope.$index);
          });
          return;
        }
        if(approved == -1 || approved == -3){
          // still waiting
          self.alert($filter('trans')('ASKSOLUTIONHINTAPPROVALOPEN'));
          return;
        }
        if(approved == -2){
          // ask now again
          self.confirm($filter('trans')('ASKHINTAPPROVALDENYED'), $filter('trans')('ASK'),ev).then(function(){
            self.askUserTaskHintApprovel(task.ID,self.user.ID,scope.$index);
          });
          return;
        }
        if(approved != 1){
          return;
        }
        // 1 = approved
      }
      if(hint.type == 'file'){
        var h = JSON.parse(JSON.stringify(hint));
        self.openWeblink({DataJSON:h,ID:task.ID},ev,'auto');
      }else
      if(hint.type == 'url'){
        self.openWeblink({DataJSON:hint,ID:task.ID},ev,hint.popup === true);
      }else
      if(hint.type == 'folder'){
        if(!scope.isPreview && scope.isStudent) 
          self.sendTaskToPredefinedClassFolder(task,hint,ev);

        if(!scope.isStudent && !scope.isPreview && !self.currentClass)
          self.alert('Portfolio-Links sind nur innerhalb eines Kurses aktiv. Teile diese Aufgabe zunächst in einem Kurs aus.');
      }else
      if(hint.type == 'ref'){
        if(!scope.isPreview) {
          if(hint.toResult == 1 && hint.taskid){
            if(!self.currentClass){
              self.alert('Ein Material-Link auf Abgaben funktioniert nur innerhalb eines Kurses.');
              return;
            }
            var t = self.getTaskByID(hint.taskid);
            if(t){
              t = t.task;
              if(self.user.Teacher == 1) {
                self.showTaskClassResultMedia(t,ev);
              }else{
                var userStatus = self.getUserTaskStatus(t,self.user,true);
                if(userStatus.Answer && userStatus.Answer != ''){
                  // ID = 0, view like peer student result, no edit
                  self.showTaskResultMedia(t.ResultType,userStatus,null,self.user,true,ev);
                }else{
                  self.alert('Zu dieser Aufgabe ist noch keine Lösung vorhanden.');
                }
              }
            }else{
              self.alert('Die Aufgabe wurde nicht gefunden.');
            }
          }else
            self.openWeblink({DataJSON:hint,ID:task.ID},ev,'auto');
        }
      }else
      if(hint.type == "rubric") {
        var r = self.getRubricByGUID(hint.rubric); 
        if(r){
          r = JSON.parse(angular.toJson(r));
          if(hint.text && hint.text != '') r.Name = hint.text;
          // collegues?
          var s = scope.student ? scope.student : self.user;
          var userStatus = self.getUserTaskStatus(task,s);
          self.showRubric(r,s, userStatus.ColleaguesIDs, null, task, ev);
        } else {
          self.alert($filter('trans')('RUBRICWASNOTFOUND'));
        }
      }else
      if(hint.type == "flashcards"){
        self.ensureFlashCardHintSetActive(hint).then(function(result){
          if(result && result.setAdded){
            var setName = result.setName ? result.setName : "";
            $timeout(function(){
              self.alert($filter('trans')('FLASHCARDS_SETADDED_HINT', setName));
            },250);
          }
          var targetSetID = hint && hint.ID ? hint.ID : "";
          if(!targetSetID && hint && hint.flashcards){
            var localSet = self.getFlashCardSetByGUID(hint.flashcards);
            if(localSet && localSet.Set) targetSetID = localSet.Set.ID;
          }
          self.showFlashcardsDialog(ev, targetSetID);
        });
      }else
      if(hint.type == "text" && hint.Collaborate == 1 && 
        ((!hint.visible && hint.visible != '0') || hint.visible == '1' || hint.visible == '2' || hint.visible == '3')){
        self.openClassDocumentFromHint(hint,task,scope.$index,ev);
      }else
        self.showTaskMedia(hint.type,hint,ev,true);        
    };

    self.showTaskAttachmentCode = function(hint, ev){
      if(self.user.Teacher == 1){
        self.prompt($filter('trans')('SETHINTCODE'),$filter('trans')('SAVE'),$filter('trans')('SETHINTCODEHINT'),hint.code ? hint.code : "",ev).then(function(code){
          hint.code = $.trim(code);
        });
        ev.stopPropagation();
      }
    };

    self.getCurrentTasksTimes = function(task,student){
      if(!task) return "";
      task = self.findTaskInClass(self.currentClass,task.ID,student ? student : (self.user.Teacher == 0 ? self.user : null));
      if(!task) return "";
      var find = self.getTaskByID(task.ID);
      if(!find) return "";
      var mt = find.mainTopic;
      var t = find.topic;
      if(!mt || !t) return "";

      //var mt = self.progressMainTopic ? self.progressMainTopic : self.currentMainTopic;
      //var t = self.progressTopic ? self.progressTopic : self.currentTopic;
      //if(!mt || !t || !t.goals) {
      //}
      for(var i=0; i < t.goals.length; i++){
        if(t.goals[i].ID == task.LearningGoal){
          // found the goal
          var r = "";
          var goal = t.goals[i];
          var f = "";
          var ff = "";
          // check by visibility dates
          var now = new Date().toMysqlFormat();
          if(mt.vFrom) f = mt.vFrom;
          if(t.vFrom) f = f == "" || f < t.vFrom ? t.vFrom : f;
          if(goal.vFrom) f = f == "" || f < goal.vFrom ? goal.vFrom : f;
          if(task.vFrom) f = f == "" || f < task.vFrom ? task.vFrom : f;

          if(mt.vTo) ff = mt.vTo;
          if(t.vTo) ff = ff == "" || ff > t.vTo ? t.vTo : ff;
          if(goal.vTo) ff = ff == "" || ff > goal.vTo ? goal.vTo : ff;
          if(task.vTo) ff = ff == "" || ff > task.vTo ? task.vTo : ff;

          var tf = f != "" ? (f < now ? self.shortDate(f) : self.shortDateTime(f)) : "";
          var tff = ff != "" ? self.shortDateTime(ff) : "";

          if(tf != "" && tf == tff) {
            r = $filter('trans')('TIMEAT')+" <b>"+tff+'</b>';
          }else{
            r = (self.user.Teacher == 1 ? (f != "" ? " "+$filter('trans')(f < now && (ff == "" || ff > now) ? 'TIMESINCE' : 'TIMEFROM')+" <b>"+tf+'</b>' : '') : "") + (ff != "" ? " "+$filter('trans')('TIMETO')+" <b>"+tff+'</b>' : '');
          }

          if(r != "") r = '<div style="font-size:70%;padding-bottom: 8px;"><i class="fa fa-fw fa-calendar"></i> '+r+'</div>';
          return self.trustAsHTML(r);
        }
      }
      return "";
    };

    self.isUserTaskVisibleDeep = function(mt,topic,task,student){
      var r = self.isUserLearningGoalVisibleDeep(mt,topic,{ID:task.LearningGoal},student);
      if(!r) return false;
      var c = self.currentClass;
      if(!self.isUserTaskVisible(task,student,c,true)) return false;
      return true;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.editClassContentUsed = function(c,ev,openMainTopic,openTopic,openLearningGoal){
      var hasOwnMaterials = !!(self.userContent && self.userContent.mainTopics && self.userContent.mainTopics.length > 0);
      var hasClassContent = !!(c && self.classContent && self.classContent[c.ID] && self.classContent[c.ID].mainTopics && self.classContent[c.ID].mainTopics.length > 0);
      if(self.user.Teacher == 1 && !hasOwnMaterials && !hasClassContent){
        self.alert($filter('trans')('CREATEMATERIALSFIRSTHINT'));
        return;
      }
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclasscontentUsed.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.currentClass = c;
            $scope.mainTopics = [];
            $scope.openMainTopic = openMainTopic;
            $scope.openTopic = openTopic;
            $scope.openLearningGoal = openLearningGoal;

            $scope.orderChanged = false;

            var preventD = function(e) { e.preventDefault(); };

            var remember = false;
            $scope.listSortOptions = {
              longTouch:false,
              accept: function (sourceItemHandleScope, destSortableScope) {
                return sourceItemHandleScope.itemScope.sortableScope.$parent.$id == destSortableScope.$parent.$id;
              },
              dragStart : function(obj){
                remember = obj.source.itemScope.modelValue.Clicked;
                obj.source.itemScope.modelValue.Clicked = false;
                $(document).on('touchstart', preventD);
              },
              dragEnd : function(obj){
                obj.source.itemScope.modelValue.Clicked = remember;
                $(document).off('touchstart', preventD);
              },
              orderChanged: function (obj) {
                var items = obj.source.sortableScope.modelValue;
                for(var i=0; i < items.length; i++)
                  items[i].orderChanged = true;
                $scope.orderChanged = true;
                return true;
              },
              clone:false
            };

            $scope.hasUnselectedMainTopics = function(){
              for(var i=0; i < $scope.mainTopics.length; i++){
                if(!$scope.mainTopics[i].Used) return true;
              }
              return false;
            };
            $scope.hasSelectedMainTopics = function(){
              for(var i=0; i < $scope.mainTopics.length; i++){
                if($scope.mainTopics[i].Used) return true;
              }
              return false;
            };

            $scope.selectAll = function(ev){
              self.showLoadingIndicator(ev,function(done){
                for(var i=0; i < $scope.mainTopics.length; i++){
                  var mt = $scope.mainTopics[i];
                  if(!mt.Used || $scope.countUnselected("MainTopic",mt) > 0){
                    mt.Used = true;
                    mt.changed = !mt.changed;
                    mt.Clicked = false;
                    $scope.propagateMainTopic(mt);
                  }
                }
                done();
              });
            };
            $scope.selectNone = function(ev){
              self.showLoadingIndicator(ev,function(done){
                for(var i=0; i < $scope.mainTopics.length; i++){
                  var mt = $scope.mainTopics[i];
                  if(mt.Used){
                    mt.Used = false;
                    mt.changed = !mt.changed;
                    mt.Clicked = false;
                    $scope.propagateMainTopic(mt);
                  }
                }
                done();
              });
            };

            $scope.countUnselected = function(type,d){
              var c = 0;
              if(type == "MainTopic"){
                for(var i=0; i < d.topics.length; i++){
                  var r = $scope.countUnselected("Topic",d.topics[i]);
                  c += r;
                }
              }
              if(type == "Topic"){
                for(var i=0; i < d.goals.length; i++){
                  var r = $scope.countUnselected("LearningGoal",d.goals[i]);
                  c += r;
                }
              }
              if(type == "LearningGoal"){
                for(var i=0; i < d.tasks.length; i++){
                  if(d.tasks[i].Used == false) c++;
                }
              }
              return c;
            }

            function scrollTo(type,e,retry){
              if($('#ecc_'+type+"_"+e.ID).length > 0){
                $('#ecc_'+type+"_"+e.ID).get(0).scrollIntoView({behavior: "smooth", block: "start", inline: "nearest"});
              }else{
                if(!retry) retry = 0;
                if(retry < 5)
                  setTimeout(function(){
                    scrollTo(type,e,retry+1);
                  },500);
              }
            };

            function addMainTopic(list,mainTopic,used,withLocal){
              var mt = {org:mainTopic,
                  'ID':mainTopic.ID,
                  'Owner':mainTopic.Owner,
                  'Teacher':mainTopic.TeacherName+" "+mainTopic.TeacherSurname,
                  'Name':mainTopic.Name,
                  'Tags':mainTopic.Tags,
                  'Color':mainTopic.Color,
                  "Permission":mainTopic.Permission,
                  "shareSettings":mainTopic.shareSettings,
                  "OrderIndex":parseInt(mainTopic.OrderIndex),
                  "topics":[],"changed":false, "Used":used};
              list.push(mt);

              if(withLocal){
                for(var i=0; i < self.userContent.mainTopics.length; i++){
                  if(self.userContent.mainTopics[i].ID == mt.ID) {
                    mt.local = self.userContent.mainTopics[i];
                    break;
                  }
                }
              }
              if(!openTopic && openMainTopic && openMainTopic.ID == mt.ID){
                mt.Clicked = true;
                scrollTo("mainTopic",mt);
              }

              for(var z=0; z < mainTopic.topics.length; z++){
                var t = {org:mainTopic.topics[z],
                         'ID':mainTopic.topics[z].ID,
                         'Name':mainTopic.topics[z].Name,
                         'changed':false, 'goals':[], 'Used':used};
                mt.topics.push(t);
                if(self.currentTopic && self.currentTopic.ID == t.ID){
                  t.Clicked = true;
                  mt.Clicked = true;
                  scrollTo("topic",t);
                }
                if(openTopic && openTopic.ID == t.ID){
                  t.Clicked = true;
                  mt.Clicked = true;
                  scrollTo("topic",t);
                }
                if(mt.local){
                  for(var x=0; x < mt.local.topics.length; x++){
                    if(mt.local.topics[x].ID == t.ID) {
                      t.local = mt.local.topics[x]; break;
                    }
                  }
                }
                for(var x=0; x < mainTopic.topics[z].goals.length; x++){
                  var g = {org:mainTopic.topics[z].goals[x],
                          'ID':mainTopic.topics[z].goals[x].ID,
                          'Name':mainTopic.topics[z].goals[x].Name,
                          'changed':false,'tasks':[], Used:used};
                  t.goals.push(g);
                  if(openLearningGoal && openLearningGoal.ID == g.ID){
                    g.Clicked = true;
                    t.Clicked = true;
                    mt.Clicked = true;
                    scrollTo("goal",g);
                  }
                  if(t.local){
                    for(var tx=0; tx < mt.local.topics.length; tx++){
                      for(var ty=0; ty < mt.local.topics[tx].goals.length; ty++){
                        if(mt.local.topics[tx].goals[ty].ID == g.ID) {
                          g.local = mt.local.topics[tx].goals[ty]; break;
                        }
                      }
                    }
                  }
                  for(var y=0; y < mainTopic.topics[z].goals[x].tasks.length; y++){
                    var tt = {org:mainTopic.topics[z].goals[x].tasks[y],
                             'ID':mainTopic.topics[z].goals[x].tasks[y].ID,
                             'Name':mainTopic.topics[z].goals[x].tasks[y].Name,
                             'changed':false, "Used":used};
                    g.tasks.push(tt);
                  }
                  if(g.local){
                    for(var y=0; y < g.local.tasks.length; y++){
                      var isThere = false;
                      for(var yy=0; yy < g.tasks.length; yy++){
                        if(g.tasks[yy].ID == g.local.tasks[y].ID){
                          isThere = true; break;
                        }
                      }
                      if(isThere) continue; // do not add
                      //if(g.local.tasks[y].userTask == "1") continue;
                      var tt = {org:g.local.tasks[y],
                               'ID':g.local.tasks[y].ID,
                               'Name':g.local.tasks[y].Name,
                               'changed':false, "Used":false};
                      g.tasks.push(tt);
                    }
                    g.tasks.sort(function(a,b){
                      if(a.org.OrderIndex == b.org.OrderIndex){
                        return a.org.ID > b.org.ID ? 1 : -1;
                      }
                      return parseInt(a.org.OrderIndex) > parseInt(b.org.OrderIndex) ? 1 : -1;
                    });
                  }
                }
                if(t.local){
                  for(var x=0; x < t.local.goals.length; x++){
                    var isThere = false;
                    for(var y=0; y < t.goals.length; y++){
                      if(t.goals[y].ID == t.local.goals[x].ID){
                        isThere = true; break;
                      }
                    }
                    if(isThere) continue; // do not add

                    var g = {org:t.local.goals[x],
                             'ID':t.local.goals[x].ID,
                             'Name':t.local.goals[x].Name,
                             'changed':false,'tasks':[],'Used':false};
                    t.goals.push(g);

                    for(var y=0; y < t.local.goals[x].tasks.length; y++){
                      //if(t.local.goals[x].tasks[y].userTask == "1") continue;
                      var tt = {org:t.local.goals[x].tasks[y],
                               'ID':t.local.goals[x].tasks[y].ID,
                               'Name':t.local.goals[x].tasks[y].Name,
                               'changed':false, "Used":false};
                      g.tasks.push(tt);
                    }
                  }
                  t.goals.sort(function(a,b){
                    if(a.org.OrderIndex == b.org.OrderIndex){
                      return a.org.ID > b.org.ID ? 1 : -1;
                    }
                    return parseInt(a.org.OrderIndex) > parseInt(b.org.OrderIndex) ? 1 : -1;
                  });
                }
              }
              if(mt.local){
                // this is a maintopic of current user, display everthing
                for(var z=0; z < mt.local.topics.length; z++){
                  var isThere = false;
                  for(var x=0; x < mt.topics.length; x++){
                    if(mt.topics[x].ID == mt.local.topics[z].ID){ isThere = true; break;}
                  }
                  if(isThere) continue; // do not add

                  var t = {org:mt.local.topics[z],
                           'ID':mt.local.topics[z].ID,
                           'Name':mt.local.topics[z].Name,
                           'changed':false, 'goals':[], Used:false};
                  mt.topics.push(t);

                  for(var x=0; x < mt.local.topics[z].goals.length; x++){
                    var g = {org:mt.local.topics[z].goals[x],
                             'ID':mt.local.topics[z].goals[x].ID,
                             'Name':mt.local.topics[z].goals[x].Name,
                             'changed':false, 'tasks':[], Used:false};
                    t.goals.push(g);

                    for(var y=0; y < mt.local.topics[z].goals[x].tasks.length; y++){
                      //if(mt.local.topics[z].goals[x].tasks[y].userTask == "1") continue;
                      var tt = {org:mt.local.topics[z].goals[x].tasks[y],
                               'ID':mt.local.topics[z].goals[x].tasks[y].ID,
                               'Name':mt.local.topics[z].goals[x].tasks[y].Name,
                               'changed':false, "Used":false};
                      g.tasks.push(tt);
                    }
                  }

                }
                mt.topics.sort(function(a,b){
                  if(a.org.OrderIndex == b.org.OrderIndex){
                    return a.org.ID > b.org.ID ? 1 : -1;
                  }
                  return parseInt(a.org.OrderIndex) > parseInt(b.org.OrderIndex) ? 1 : -1;
                });
              }
            }

            for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
              addMainTopic($scope.mainTopics,
                 JSON.parse(angular.toJson(
                   self.classContent[self.currentClass.ID].mainTopics[i])),
                   true,true);
            }

            for(var i=0; i < self.userContent.mainTopics.length; i++){
              var isThere = false;
              for(var z=0; z < $scope.mainTopics.length; z++){
                if($scope.mainTopics[z].ID == self.userContent.mainTopics[i].ID){
                  isThere = true;
                  break;
                }
              }
              if(!isThere)
                addMainTopic($scope.mainTopics,JSON.parse(angular.toJson(self.userContent.mainTopics[i])),false,true);
            }

            $scope.propagateMainTopic = function(mt){
              $timeout(function(){
                for(var z=0; z < mt.topics.length; z++){
                  if(mt.topics[z].Used != mt.Used) mt.topics[z].changed = !mt.topics[z].changed;
                  mt.topics[z].Used = mt.Used;
                  $scope.propagateTopic(mt.topics[z],mt);
                }

              },10);
            };

            $scope.propagateTopic = function(t,mt){
              $timeout(function(){
                for(var z=0; z < t.goals.length; z++){
                  if(t.goals[z].Used != t.Used) t.goals[z].changed = !t.goals[z].changed;
                  t.goals[z].Used = t.Used;
                  $scope.propagateGoal(t.goals[z],t,mt);
                }
                if(t.Used && !mt.Used){
                  mt.changed = !mt.changed;
                  mt.Used = true;
                }

              },10);
            };

            $scope.propagateGoal = function(g,t,mt){
              $timeout(function(){
                for(var z=0; z < g.tasks.length; z++){
                  if(g.tasks[z].Used != g.Used) g.tasks[z].changed = !g.tasks[z].changed;
                  g.tasks[z].Used = g.Used;
                  $scope.propagateTask(g.tasks[z],g,t,mt);
                }

                if(g.Used && !t.Used){
                  t.changed = !t.changed;
                  t.Used = true;
                }
                if(t.Used && !mt.Used){
                  mt.changed = !mt.changed;
                  mt.Used = true;
                }

              },10);
            };

            $scope.propagateTask = function(tt,g,t,mt){
              $timeout(function(){
                if(tt.Used && !g.Used){
                  g.changed = !g.changed;
                  g.Used = true;
                }
                if(g.Used && !t.Used){
                  t.changed = !t.changed;
                  t.Used = true;
                }
                if(t.Used && !mt.Used){
                  mt.changed = !mt.changed;
                  mt.Used = true;
                }
              },10);
            };

            $scope.importFromOtherClass = function(ev){
              var parent = $scope;
              self.showDialog({
                templateUrl: "importclasscontentUsed.html",
                targetEvent: ev,
                skipHide:true, // keep other dialog open

                clickOutsideToClose: false,
                escapeToClose: false,
                controller: function ($scope, $mdDialog) {
                  $scope.self = self;
                  $scope.currentClass = c;

                  $scope.propagateMainTopic = parent.propagateMainTopic;
                  $scope.propagateTopic = parent.propagateTopic;
                  $scope.propagateGoal = parent.propagateGoal;
                  $scope.propagateTask = parent.propagateTask;

                  $scope.tabs = [];
                  for(var i=0; i < self.classList.length; i++){
                    if(self.classList[i].ID == c.ID) continue; // not the current class
                    var tab = {"ID":self.classList[i].ID, "Name":self.classList[i].Name, "mainTopics":[]};

                    for(var z=0; z < self.classContent[self.classList[i].ID].mainTopics.length; z++){
                      addMainTopic(tab.mainTopics,JSON.parse(angular.toJson(self.classContent[self.classList[i].ID].mainTopics[z])),false,false);
                    }

                    $scope.tabs.push(tab);
                  }

                  $scope.currentTab = $scope.tabs[0];

/*
                  $scope.selectAll = function(selected) {
                    for(var i=0; i < $scope.currentTab.mainTopics.length; i++){
                      var mt = $scope.currentTab.mainTopics[i];
                      mt.changed = mt.changed | mt.Used != !selected;
                      mt.Used = !selected;
                      mt.Clicked = true;
                      $scope.propagateMainTopic(mt);
                    }
                  };
*/
                  $scope.selectAll = function(ev){
                    self.showLoadingIndicator(ev,function(done){
                      for(var i=0; i < $scope.currentTab.mainTopics.length; i++){
                        var mt = $scope.currentTab.mainTopics[i];
                        if(mt.Used){
                          mt.Used = false;
                          mt.Clicked = false;
                          $scope.propagateMainTopic(mt);
                        }
                      }
                      for(var i=0; i < $scope.currentTab.mainTopics.length; i++){
                        var mt = $scope.currentTab.mainTopics[i];
                        if(!mt.Used){
                          mt.Used = true;
                          mt.changed = !mt.changed;
                          mt.Clicked = false;
                          $scope.propagateMainTopic(mt);
                        }
                      }
                      done();
                    });
                  };
                  $scope.selectNone = function(ev){
                    self.showLoadingIndicator(ev,function(done){
                      for(var i=0; i < $scope.currentTab.mainTopics.length; i++){
                        var mt = $scope.currentTab.mainTopics[i];
                        if(mt.Used){
                          mt.Used = false;
                          mt.changed = !mt.changed;
                          mt.Clicked = false;
                          $scope.propagateMainTopic(mt);
                        }
                      }
                      done();
                    });
                  };
                  $scope.cancel = function() {
                    self.closeDialog($scope.dialogElement);
                  };

                  $scope.importMaterials = function() {
                    $scope.mainTopics = $scope.currentTab.mainTopics;

                    // add mainTopics
                    for(var i=0; i < $scope.mainTopics.length; i++){
                      if($scope.mainTopics[i].Used){
                        var mainTopic = null;
                        for(var z=0; z < parent.mainTopics.length; z++){
                          if(parent.mainTopics[z].ID == $scope.mainTopics[i].ID){
                            mainTopic = parent.mainTopics[z];
                            mainTopic.changed = mainTopic.changed || !mainTopic.Used;
                            mainTopic.Used = true;
                            break;
                          }
                        }
                        if(!mainTopic){
                          mainTopic = $scope.mainTopics[i];
                          parent.mainTopics.unshift(mainTopic);
                        }

                        // add topics
                        for(var t=0; t < $scope.mainTopics[i].topics.length; t++){
                          if($scope.mainTopics[i].topics[t].Used){
                            var topic = null;
                            for(var tt=0; tt < mainTopic.topics.length; tt++){
                              if(mainTopic.topics[tt].ID == $scope.mainTopics[i].topics[t].ID){
                                topic = mainTopic.topics[tt];
                                topic.changed = topic.changed || !topic.Used;
                                topic.Used = true;
                                break;
                              }
                            }
                            if(!topic){
                              topic = $scope.mainTopics[i].topics[t];
                              mainTopic.topics.push(topic);
                            }

                            // add goals
                            for(var g=0; g < $scope.mainTopics[i].topics[t].goals.length; g++){
                              if($scope.mainTopics[i].topics[t].goals[g].Used){

                                var goal = null;
                                for(var gg=0; gg < topic.goals.length; gg++){
                                  if(topic.goals[gg].ID == $scope.mainTopics[i].topics[t].goals[g].ID){
                                    goal = topic.goals[gg];
                                    goal.changed = goal.changed || !goal.Used;
                                    goal.Used = true;
                                    break;
                                  }
                                }
                                if(!goal){
                                  goal = $scope.mainTopics[i].topics[t].goals[g];
                                  topic.goals.push(goal);
                                }

                                // add tasks
                                for(var tt=0; tt < $scope.mainTopics[i].topics[t].goals[g].tasks.length; tt++){
                                  if($scope.mainTopics[i].topics[t].goals[g].tasks[tt].Used){

                                    var task = null;
                                    for(var ttt=0; ttt < goal.tasks.length; ttt++){
                                      if(goal.tasks[ttt].ID == $scope.mainTopics[i].topics[t].goals[g].tasks[tt].ID){
                                        task = goal.tasks[ttt];
                                        task.changed = task.changed || !task.Used;
                                        task.Used = true;
                                        //parent.propagateTask(task,goal,topic,mainTopic);
                                        break;
                                      }
                                    }
                                    if(!task){
                                      task = $scope.mainTopics[i].topics[t].goals[g].tasks[tt];
                                      goal.tasks.push(task);
                                    }
                                  }
                                }
                              }
                            }
                          }
                        }
                      }
                    }
                    self.updateClassesStatus();
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });
            };


            $scope.save = function() {
              // try save now
              var hadChanged = false;
              var hadAdded = false;
              var changes = {"maintopics":[],"topics":[],"goals":[],"tasks":[],"order":{}};

              for(var i=0; i < $scope.mainTopics.length; i++){
                if(!changes.order["maintopics"] &&
                   $scope.mainTopics[i].orderChanged){
                  changes.order["maintopics"] = [];
                  for(var o=0; o < $scope.mainTopics.length; o++)
                    changes.order["maintopics"].push($scope.mainTopics[o].ID);
                  hadChanged = true;
                }
                for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                  if(!changes.order["topics_"+$scope.mainTopics[i].ID] &&
                     $scope.mainTopics[i].topics[z].orderChanged){
                    changes.order["topics_"+$scope.mainTopics[i].ID] = [];
                    for(var o=0; o < $scope.mainTopics[i].topics.length; o++)
                      changes.order["topics_"+$scope.mainTopics[i].ID].push($scope.mainTopics[i].topics[o].ID);
                    hadChanged = true;
                  }
                  for(var w=0; w < $scope.mainTopics[i].topics[z].goals.length; w ++){
                    if(!changes.order["goals_"+$scope.mainTopics[i].topics[z].ID] &&
                       $scope.mainTopics[i].topics[z].goals[w].orderChanged){
                      changes.order["goals_"+$scope.mainTopics[i].topics[z].ID] = [];
                      for(var o=0; o < $scope.mainTopics[i].topics[z].goals.length; o++)
                        changes.order["goals_"+$scope.mainTopics[i].topics[z].ID].push($scope.mainTopics[i].topics[z].goals[o].ID);
                      hadChanged = true;
                    }

                    for(var tt=0; tt < $scope.mainTopics[i].topics[z].goals[w].tasks.length; tt ++){
                      if(!changes.order["tasks_"+$scope.mainTopics[i].topics[z].goals[w].ID] &&
                         $scope.mainTopics[i].topics[z].goals[w].tasks[tt].orderChanged){
                        changes.order["tasks_"+$scope.mainTopics[i].topics[z].goals[w].ID] = [];
                        for(var o=0; o < $scope.mainTopics[i].topics[z].goals[w].tasks.length; o++)
                          changes.order["tasks_"+$scope.mainTopics[i].topics[z].goals[w].ID].push($scope.mainTopics[i].topics[z].goals[w].tasks[o].ID);
                        hadChanged = true;
                      }
                    }
                  }
                }
              }

              var hasOtherUserContentChanged = false;
              for(var i=0; i < $scope.mainTopics.length; i++){
                var propagateChanged = false;
                if($scope.mainTopics[i].changed){
                  changes.maintopics.push({"ID":$scope.mainTopics[i].ID,
                                           "used":$scope.mainTopics[i].Used ? '1':'0'});
                  if($scope.mainTopics[i].Used) hadAdded = true;
                  if(!$scope.mainTopics[i].local &&
                     !$scope.mainTopics[i].Used)
                    hasOtherUserContentChanged = true;
                  propagateChanged = true;
                  hadChanged = true;
                }
                for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                  var propagateTopicChanged = false;
                  if(propagateChanged || $scope.mainTopics[i].topics[z].changed){
                    changes.topics.push({"ID":$scope.mainTopics[i].topics[z].ID,
                                         "used":$scope.mainTopics[i].topics[z].Used ? '1':'0'});
                    if($scope.mainTopics[i].topics[z].Used) hadAdded = true;
                    if(!$scope.mainTopics[i].local &&
                       !$scope.mainTopics[i].topics[z].Used)
                      hasOtherUserContentChanged = true;
                    propagateTopicChanged = true;
                    hadChanged = true;
                  }
                  for(var w=0; w < $scope.mainTopics[i].topics[z].goals.length; w ++){
                    var propagateLearningGoalChanged = false;
                    if(propagateTopicChanged || $scope.mainTopics[i].topics[z].goals[w].changed){
                      changes.goals.push({"ID":$scope.mainTopics[i].topics[z].goals[w].ID,
                                          "used":$scope.mainTopics[i].topics[z].goals[w].Used ? '1':'0'});
                      if($scope.mainTopics[i].topics[z].goals[w].Used) hadAdded = true;
                      if(!$scope.mainTopics[i].local &&
                         !$scope.mainTopics[i].topics[z].goals[w].Used)
                        hasOtherUserContentChanged = true;
                      propagateLearningGoalChanged = true;
                      hadChanged = true;
                    }
                    for(var tt=0; tt < $scope.mainTopics[i].topics[z].goals[w].tasks.length; tt ++){
                      if(propagateLearningGoalChanged || $scope.mainTopics[i].topics[z].goals[w].tasks[tt].changed){
                        changes.tasks.push({"ID":$scope.mainTopics[i].topics[z].goals[w].tasks[tt].ID,
                                            "used":$scope.mainTopics[i].topics[z].goals[w].tasks[tt].Used ? '1':'0'});
                        if($scope.mainTopics[i].topics[z].goals[w].tasks[tt].Used) hadAdded = true;
                        if(!$scope.mainTopics[i].local &&
                           !$scope.mainTopics[i].topics[z].goals[w].tasks[tt].Used)
                          hasOtherUserContentChanged = true;
                        hadChanged = true;
                      }
                    }

                  }
                }
              }

              if(hadChanged){
                var sendNow = function(){
                  self.closeDialog($scope.dialogElement);
                  self.apiPost("ajax",{"action":"setClassesContentInUse", "classid":c.ID,
                                       "changes":angular.toJson(changes)}).then(function(data){
                    self.keepAliveCallback().then(function(){
                      self.updateClassesStatus();

                      if(hadAdded) {
                        // force refresh of all data again, because new content
                        // was added but user data not changed yet
                        $timeout(function(){
                          self.lastUpdateTime = 0;
                          self.keepAliveCallback().then(function(){
                            self.updateClassesStatus();
                          });
                        },10);
                      }
                    });
                  });
                };
                if(hasOtherUserContentChanged) {
                  self.confirm($filter('trans')('REMOVEDOTHERUSERCONTENTHINT'),
                    $filter('trans')('SAVE'),ev).then(sendNow);
                } else sendNow();
              }else
                self.closeDialog($scope.dialogElement);
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Topics
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.createTopic = function(mt,ev){
      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "edittopic.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.Name = "";
            $scope.isNew = 1;
            $scope.Description = "";
            $scope.Image = "";
            $scope.coverFull = false;
            $scope.coverFullText = false;

            $scope.selectImage = function(ev){
              self.takeUserMedia("image",null,function(results){ $scope.Image = results[0].URL; }, {dialogMode:0});
            };
            $scope.removeImage = function(){
              $scope.Image = "";
            };

            $scope.save = function() {
              // try save now
              if(!$scope.Name || $scope.Name == "") { $('#inputName').focus(); return;}
              $scope.Description = self.trimHTML($scope.Description);

              self.replaceBase64Images($scope.Description).then(function(desc){        
                $scope.Description = desc;                

                var a = {"action":"createTopic","mainTopic":mt.ID, "Name":$scope.Name, "Description":$scope.Description};
                if(self.currentClass) a.inclass = self.currentClass.ID;
                if($scope.Image != "") a.Image = $scope.Image + (($scope.coverFull && $scope.Image.indexOf("#cover") == -1) ? '#cover' +($scope.coverFullText ? 'Text':'') : "");

                self.apiPost("ajax",a)
                 .then(function(data) {
                   data.topic.Visible = 1;

                   var isThere = false;
                   if(!mt.topics) mt.topics = [];
                   for(var i=0; i < mt.topics.length; i++){
                     if(mt.topics[i].ID == data.topic.ID){
                       isThere = true;
                       break;
                     }
                   }
                   if(!isThere) mt.topics.push(data.topic);
                   if(self.searchTerm && self.searchTerm != '')
                     self.addedAfterLastSearchTermChange.topics.push(data.topic.ID);

                   self.closeDialog($scope.dialogElement);
                   self.keepAliveCallback().then(function(){
                     deferred.resolve(data.topic);
                   });
                 });
               });
            };
            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });

        $timeout(function(){
          done();
        },10);
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeTopic = function(mt,it,ev,force){
      self.confirm($filter('trans')('REMOVETOPIC',it.Name)+(mt.shareSettings && mt.shareSettings.length > 1 ? " "+$filter('trans')('REMOVESHAREDHINT'):''),$filter('trans')('DELETE'),ev).then(function(){
            self.apiPost("ajax",{"action":"removeTopic", "ID":it.ID})
             .then(function(data) {
               mt.topics.splice(mt.topics.indexOf(it),1);
               self.updateTopicsOrder(mt);
               $mdDialog.hide();
               self.keepAliveCallback();
             });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editTopic = function(it,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "edittopic.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.Name = it.Name ? it.Name : "";
          $scope.isEdit = 1;
          $scope.Description = it.Description;
          $scope.Image = it.Image ? it.Image : "";
          $scope.coverFull = it.Image && it.Image.indexOf("#cover") > 0;
          $scope.coverFullText = it.Image && it.Image.indexOf("#coverText") > 0;

          $scope.selectImage = function(ev){
            self.takeUserMedia("image",null,function(results){ $scope.Image = results[0].URL; }, {dialogMode: 0});
          };
          $scope.removeImage = function(){
            $scope.Image = "";
          };

          $scope.save = function() {
            // try save now
            if(!$scope.Name || $scope.Name == "") { $('#inputName').focus(); return;}
            $scope.Description = self.trimHTML($scope.Description);
            $scope.Image = $scope.Image.replace("#coverText","").replace("#cover","") + ($scope.coverFull ? '#cover'+($scope.coverFullText ? 'Text':'') : "");

            self.replaceBase64Images($scope.Description).then(function(desc){        
              $scope.Description = desc;
              self.apiPost("ajax",{"action":"updateTopic", "ID":it.ID, "Name":$scope.Name, "Description":$scope.Description, "Image":$scope.Image})
               .then(function(data) {
                 it.Name = $scope.Name;
                 it.Image = $scope.Image;
                 it.Description = $scope.Description;
                 self.closeDialog($scope.dialogElement);
                 deferred.resolve();
                 self.keepAliveCallback();
                 if(self.searchTerm && self.searchTerm != '')
                   self.addedAfterLastSearchTermChange.topics.push(it.ID);
               });
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showLearningGoalSkill = function(s,it,ev){
      if(self.fetchingSkillSet) return;
      self.fetchingSkillSet = true;

      self.showLoadingIndicator(ev,function(done){
        self.fetchSkillSet(s.Set).then(function(skillSet){
          self.fetchingSkillSet = false;
          var path = [];
          var base = skillSet.DataJSON;
          // find text now
          if(skillSet){
            var parts = s.item.split(".");
            while(parts.length > 0){
              var p = parts.shift(); // take first
              if(base instanceof Array){
                path.push(base[p-1]);
                break;
              }
              if(base[p]){
                base = base[p];
                path.push(base);
              } else break;
            }   
            if(parts.length == 0){
              // all found
              self.showDialog({
                templateUrl: "showLearningGoalSkill.html",
                targetEvent: ev,
                skipHide:true, // keep other dialog open
                clickOutsideToClose: true,
                controller: function ($scope, $mdDialog) {
                  done();
                  $scope.self = self;
                  $scope.it = s;
                  $scope.Name = skillSet.Name;
                  var p = "";
                  for(var i=0; i < path.length-1; i++){ 
                    if(path[i].Name)
                      p += (p == "" ? "" : " › ")+path[i].Name;
                  }
                  $scope.path = p;
                  $scope.skill = path[path.length-1]; // last one
                  if($scope.skill instanceof Array){
                    var s = '<ul style="padding-top:0">';
                    for(var i=0; i < $scope.skill.length; i++){
                      s += '<li>'+$scope.skill[i]+'</li>'
                    }
                    s += '</ul>';
                    $scope.skill = s;
                  }
                  if(skillSet.ID == 1)
                    $scope.skill = "Die Schülerinnen und Schüler "+$scope.skill;

                  $scope.copyToClipboard = function(ev){
                    copyTextToClipboard($scope.skill,"html");
                    self.alert($filter('trans')('COPYEDTEXTTOCLIPBOARD'),ev);
                  };

                  $scope.cancel = function() {
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });
            }            
          }
        });
      });
    };

    self.editLearningGoalSkills = function(it,ev){
      var deferred = $q.defer();
      // no sets
      if(self.skillSets.length == 0) return deferred.promise;
      self.showDialog({
        templateUrl: "editLearningGoalSkills.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.currentSet = self.skillSets[0];
          if(self.userViewData["skills_set"]){
            for(var i=0; i < self.skillSets.length; i++){
              if(self.skillSets[i].ID == self.userViewData["skills_set"]){
                $scope.currentSet = self.skillSets[i];
                break;
              }
            }
          }
          $scope.Skills = it.Skills && it.Skills != '' ? JSON.parse(it.Skills) : [];
          
          self.fetchSkillSet($scope.currentSet.ID).then(function(){
            for(var k in $scope.currentSet.DataJSON){
              if(self.userViewData["skills_level1"] && self.userViewData["skills_level1"] == k){
                $scope.select($scope.currentSet.DataJSON[k],1,k);
                for(var k2 in $scope.currentSet.DataJSON[k]){
                  if(self.userViewData["skills_level2"] && self.userViewData["skills_level2"] == k2){
                    $scope.select($scope.currentSet.DataJSON[k][k2],2,k2);
                    for(var k3 in $scope.currentSet.DataJSON[k][k2]){
                      if(self.userViewData["skills_level3"] && self.userViewData["skills_level3"] == k3){
                        $scope.select($scope.currentSet.DataJSON[k][k2][k3],3,k3);
                      }
                    }

                  }
                }
              }
            }
          });
          
          $scope.selected = {};
          
          $scope.searchResults = [];

          $scope.search = function(s){
            $scope.searchResults = [];
            if(!$scope.selected[1]) return;
            var out = "";
            var searchParts = s.toLowerCase().split(/[ ]+/);
            for(var i=0; i < searchParts.length; i++){
                if(searchParts[i].trim() == ""){
                    searchParts.splice(i,1);
                    i--;
                }
                // remove duplicates
                if(searchParts.indexOf(searchParts[i]) != i){
                    searchParts.splice(i,1);
                    i--;
                }
            }

            var found = [];
            function check(str, path){
                var missing = searchParts.slice();
                var names = "";
                var label = "";
                for(var i=0; i < path.length; i++){
                    label += (label != "" ? ".":"") + path[i].key;
                    names += path[i].item.Name ? path[i].item.Name + " " : "";
                }
                label = label.toLowerCase();
                names = names.toLowerCase();

                for(var i=0; i < searchParts.length; i++){
                    if(label.indexOf(searchParts[i]) != -1){
                        missing.splice(missing.indexOf(searchParts[i]),1);
                        continue;
                    }
                    if(names.indexOf(searchParts[i]) != -1){
                        missing.splice(missing.indexOf(searchParts[i]),1);
                        continue;
                    }
                    if(str.toLowerCase().indexOf(searchParts[i]) != -1) {
                        // found this part
                        missing.splice(missing.indexOf(searchParts[i]),1);
                        continue;
                    }
                }
                if(missing.length == 0){
                    // all found 
                    found.push({txt:str, path:path});
                    return true;
                }
                return false;
            }

            function searchInside(p,path){
                if(p instanceof Array){
                    for(var i=0; i < p.length; i++){
                        var npath = path.slice();
                        npath.push({item:p[i], key:i+1});
                        check(p[i],npath);
                    }
                }else
                for(k in p){
                    if(k == "Name" || k == "Text" || k == "key") {
                        //check(p[k],p);
                        continue;
                    }
                    var npath = path.slice();
                    npath.push({item:p[k], key:k});
                    searchInside(p[k],npath);
                }

            }
            if($scope.selected[2]){
              $scope.selected[3] = null;
              searchInside($scope.selected[2],[{item:$scope.selected[1],key:$scope.selected[1].key},{item:$scope.selected[2],key:$scope.selected[2].key}]);
            }else{
              searchInside($scope.selected[1],[{item:$scope.selected[1],key:$scope.selected[1].key}]);
            }

            function highlight(txt){
                function escapeRegExp(text) {
                  return text.replace(/[-[\]{}()*+?.,\\^$|#\s]/g, '\\$&');
                }
                for(var i=0; i < searchParts.length; i++){
                    var regex = new RegExp(escapeRegExp(searchParts[i]),"i");
                    txt = txt.replace(regex,function(match, offset, string){
                        return '<b style="color:red">'+match+'</b>';
                    });
                }
                return txt;
            }
            for(var i=0; i < found.length; i++){
                var label = "";
                var categories = [];
                for(var z=0; z < found[i].path.length; z++){
                    categories.push({item:found[i].path[z].item,key:found[i].path[z].key, text:found[i].path[z].item.Name ? ((z > 0 ? ' › ':'')+highlight(found[i].path[z].item.Name)) : null});
                    label += (label != ''? '.':'')+found[i].path[z].key;
                }
                $scope.searchResults.push({label : (label), item:found[i].path[found[i].path.length-1].item,
                                           key:found[i].path[found[i].path.length-2].key,
                                           categories:categories, skill:highlight(found[i].txt)});
            }
          };

          $scope.deleteSkill = function(s){
            for(var i=0; i < $scope.Skills.length; i++){
              if($scope.Skills[i] == s){
                $scope.Skills.splice(i,1);
                return;
              }
            }
          };

          $scope.select = function (item, level, key){
            item.key = key;
            $scope.selected[level] = $scope.selected[level] ? null : item;
            for(var i=level+1; i < 100; i++){
              if($scope.selected[i]) $scope.selected[i] = null;
            }
            if($scope.searchTerm && $scope.searchTerm != '')
              $scope.search($scope.searchTerm);
          };
          $scope.selectFromSearch = function(item, c, index){
            $scope.searchTerm = ""; // remove search now
            $scope.searchResults = [];
            for(var i=1; i < 100; i++){
              if($scope.selected[i]) $scope.selected[i] = null;
            }

            for(var i=0; i < item.categories.length; i++){
              $scope.selected[i+1] = item.categories[i].item;
              item.categories[i].item.key = item.categories[i].key;
              if(i == index) break;
            }

          };
          $scope.choose = function(it,key, path){
            var ps = "";
            var last = null;
            while(path.length > 0) {
              var p = path.pop();
              last = p;
              ps += (ps == "" ? "" : ".") + p.key;
            }
            if(key && !(last && last instanceof Array && last.length == 1))
              ps += (ps == "" ? "" : ".") + key;

            for(var i=0; i < $scope.Skills.length; i++){

            }
            for(var i=0; i < $scope.Skills.length; i++){
              if($scope.Skills[i].Set == $scope.currentSet.ID && $scope.Skills[i].item == ps){
                return; // exists;
              }
            }
            $scope.Skills.push({Set:$scope.currentSet.ID,item: ps});
          };

          $scope.chooseFromSearch = function (item){
            var ps = item.label;

            if(item.categories[item.categories.length-2].item instanceof Array && 
               item.categories[item.categories.length-2].item.length == 1) {
              var parts = ps.split(".");
              parts.pop();
              ps = parts.join(".");
            }

            for(var i=0; i < $scope.Skills.length; i++){
              if($scope.Skills[i].Set == $scope.currentSet.ID && $scope.Skills[i].item == ps){
                return; // exists;
              }
            }
            $scope.Skills.push({Set:$scope.currentSet.ID,item: ps});
          };

          $scope.save = function() {
            // try save now
            var n = $scope.Skills.length == 0 ? "" : angular.toJson($scope.Skills);
            if(it.Skills == n){
              $scope.cancel();
              return;
            }
            self.apiPost("ajax",{"action":"updateLearningGoal", "ID":it.ID, "Skills":n})
             .then(function(data) {
               it.Skills = n;
               self.userViewData["skills_set"] = $scope.currentSet.ID;
               self.userViewData["skills_level1"] = $scope.selected[1] ? $scope.selected[1].key : null;
               self.userViewData["skills_level2"] = $scope.selected[2] ? $scope.selected[2].key: null;
               self.userViewData["skills_level3"] = $scope.selected[3] ? $scope.selected[3].key : null;
               self.updateUserViewData();

               self.closeDialog($scope.dialogElement);
               deferred.resolve();
               self.keepAliveCallback();
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getLearningGoalRubricGUID = function(r){
      if(!r || r == '') return null;
      r = r[0] == '-' ? r.slice(1) : r; // invisible 
      r = r[0] == '&' ? r.slice(1) : r; // linked
      return r;
    };
    self.getLearningGoalRubric = function(r){
      var guid = self.getLearningGoalRubricGUID(r);
      if(!guid) return null;
      return self.getRubricByGUID(guid);
    };
    self.getLearningGoalRubricName = function(r){
      var rubric = self.getLearningGoalRubric(r);
      return rubric ? rubric.Name : '';
    };
    self.openLearningGoalRubric = function(r,it,student,ev){
      var rubric = null;
      if(typeof r == "string"){
        rubric = self.getLearningGoalRubric(r);
      }else{
        rubric = r;
      }
      if(!rubric) return;
      self.showRubric(rubric, student ? student : (self.user.Teacher == 0 ? self.user : null), null, it, null, ev);
    };
    self.openTaskRubricsButton = function(rubrics, student, colleagues, task, ev, openMenu){
      if(!rubrics || rubrics.length === 0) return;
      var visibleRubrics = [];
      for(var i=0; i < rubrics.length; i++){
        var rubric = self.getRubricByGUID(rubrics[i].rubric);
        if(rubric) visibleRubrics.push(rubric);
      }
      if(visibleRubrics.length === 1){
        self.showRubric(visibleRubrics[0], student, colleagues, null, task, ev);
        return;
      }
      if(openMenu) openMenu(ev);
    };
    self.getLearningGoalRubricsList = function(it){
      if(!it) return [];
      var current = [];
      if(it.Rubrics && it.Rubrics != ''){
        var parts = it.Rubrics.split(",");
        for(var i=0; i < parts.length; i++){
          var entry = $.trim(parts[i]);
          if(entry == '') continue;
          // Skip stale rubric refs (e.g. rubric was deleted/disabled and no longer in self.rubrics).
          if(!self.getLearningGoalRubric(entry)) continue;
          current.push(entry);
        }
      }
      var normalized = current.join(",");
      if(!it.RubricsList || it.RubricsListSource != normalized){
        it.RubricsList = current;
        it.RubricsListSource = normalized;
      }
      return it.RubricsList;
    };
    self.saveLearningGoalRubricsList = function(it){
      if(!it) return;
      var list = self.getLearningGoalRubricsList(it);
      var normalizedList = [];
      var seen = {};
      for(var i=0; i < list.length; i++){
        var entry = $.trim(list[i] ? list[i] : "");
        if(entry == "" || seen[entry]) continue;
        seen[entry] = true;
        normalizedList.push(entry);
      }
      if(normalizedList.length != list.length){
        it.RubricsList = normalizedList;
        list = normalizedList;
      }
      var n = list.length == 0 ? '' : list.join(",");
      it.RubricsListSource = n;
      if(it.Rubrics == n) return;
      it.Rubrics = n;
      self.apiPost("ajax",{"action":"updateLearningGoal", "ID":it.ID, "Rubrics":it.Rubrics});
    };
    self.sortableLearningGoalRubrics = function(it){
      if(self.currentClass) return false;
      var canChange = self.checkChangePermission(self.currentMainTopic);
      if(!canChange) return false;
      return self.user && self.user.Teacher == 1;
    };
    self.editLearningGoalRubrics = function(it,ev){
      var current = [];
      var ids = [];
      var wasInvisible = [];
      var wasLinked = [];
      if(it.Rubrics && it.Rubrics != '') {
        current = it.Rubrics.split(",");        
        for(var i=0; i < current.length; i++){
          if($.trim(current[i]) == "") continue;
          if(current[i][0] == "-") {
            current[i] = current[i].slice(1); // remove - in front
            wasInvisible.push(current[i].replace("&",""));
          }
          if(current[i][0] == "&") {
            current[i] = current[i].slice(1); // remove - in front
            wasLinked.push(current[i]);
          }
          var r = self.getRubricByGUID(current[i]);
          if(r) ids.push(r.ID);
        }
      }
      self.pickRubrics(ids, false, function(results,wasCreated){
        /*
           // if rubric was selected from elsewhere, mark as link
          if(wasCreated){
            if(wasCreated[self.getRubricByID(results[0]).ID]){
              delete(json.linked); // no link
            }
          }
          */
       var guids = [];
        for(var i=0; i < results.length; i++){
          var guid = self.getRubricByID(results[i]).GUID;
          var wasCreated = false;
          if(wasCreated && wasCreated[self.getRubricByID(results[i]).ID]) wasCreated = true; 
          if(!wasCreated || wasLinked.indexOf(guid) != -1) guid = '&'+guid;  
          if(wasInvisible.indexOf(guid) != -1) guid = '-'+guid;          
          guids.push(guid);          
        }

        var n = guids.length == 0 ? '' : guids.join(",");
        if(it.Rubrics != n){
          self.apiPost("ajax",{"action":"updateLearningGoal", "ID":it.ID, "Rubrics":n});
          it.Rubrics = n;
          self.getLearningGoalRubricsList(it);
        }
      },{type:"goal",goal:it});
    };
    self.toggleLearningGoalRubricVisibility = function(it,rubric){
      if(rubric[0] == "-"){
        it.Rubrics = it.Rubrics.replace(rubric, rubric.slice(1));
      }else{
        it.Rubrics = it.Rubrics.replace(rubric, "-"+rubric);
      }
      self.getLearningGoalRubricsList(it);
      self.apiPost("ajax",{"action":"updateLearningGoal", "ID":it.ID, "Rubrics":it.Rubrics});
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveLearningGoalUserStatus = function(it,status,ev){
      if(self.preventDoubleClick()) return;
      self.showLoadingIndicator(ev,function(done){
        self.track("saveGoalStatus",{ID:it.ID,"classid":self.currentClass.ID, "status": status});
        self.apiPost("ajax",{"action":"saveLearningGoalUserStatus","learningGoal":it.ID,"classid":self.currentClass.ID, "status": status}).then(function(){
          self.getUserLearningGoalStatus(it,self.user,true).Status = status;
          // update any portfolio entries with this goal too
          self.updateLearningGoalStatusInPortfolios(it,self.user);
          done();
        });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveLearningGoalTeacherStatus = function(it,user,status,current,norefresh){
      self.apiPost("ajax",{"action":"saveLearningGoalTeacherStatus","learningGoal":it.ID, "classid":self.currentClass.ID, "user":user.ID, "status": status})
        .then(function(data) {
          // set current status
          var s = self.getUserLearningGoalStatus(it,user,true);
          s.Teacher = status;
          current.Teacher = status;
          //s.Status = status; // do override users status?
          self.updateClassesStatus();
          self.updateLearningGoalStatusInPortfolios(it,user);
          if(!norefresh) self.keepAliveCallback();
        });
    };

    self.updateLearningGoalStatusInPortfolios = function(it,user){
      var s = self.getUserLearningGoalStatus(it,user,true);
      var checkFolder = function(f){
        if(!f.items) return;
        for(var z=0; z < f.items.length; z++){
          if(f.items[z].Owner == user.ID && f.items[z].Goal == it.ID){
            var changed = false;
            if(!f.items[z].DataJSON) f.items[z].DataJSON = {};
            if(!f.items[z].DataJSON.Result) f.items[z].DataJSON.Result = {};
            if(f.items[z].DataJSON.Result.Teacher != s.Teacher){
              f.items[z].DataJSON.Result.Teacher = s.Teacher;
              changed = true;
            }
            if(f.items[z].DataJSON.Result.Status != s.Status){
              f.items[z].DataJSON.Result.Status = s.Status;
              changed = true;
            }
            if(changed){
              f.items[z].DataJSON.Result.Updated = new Date().toMysqlFormat();
              var p = {"action":"updateClassFolderItem", "ID":f.items[z].ID, "Content":JSON.stringify(f.items[z].DataJSON)};
              if(user && user.ID != self.user.ID) p.student = user.ID;
              self.apiPost("ajax",p);
            }
          }
        }
      };

      if(self.currentClass){
        // student and public folders
        if(self.classContent && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders)
          for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
            checkFolder(self.classContent[self.currentClass.ID].folders[i]);
          }
        // teacher
        if(self.users[user.ID] &&
           self.users[user.ID].classContent &&
           self.users[user.ID].classContent[self.currentClass.ID] &&
           self.users[user.ID].classContent[self.currentClass.ID].folders){
          for(var x=0; x < self.users[user.ID].classContent[self.currentClass.ID].folders.length; x++){
            checkFolder(self.users[user.ID].classContent[self.currentClass.ID].folders[x]);
          }
        }
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editLearningGoalTeacherNote = function(goal, user, status, ev){
      $mdMenu.hide(); // if this is from a <md-menu> close it now

      self.showDialog({
        templateUrl: "editLearningGoalTeacherNote.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;

          $scope.Note = status.Note ? status.Note : '';
          $scope.TeacherNote = status.TeacherNote ? status.TeacherNote : '';
          $scope.hasNotes = $scope.Note != '' || $scope.TeacherNote != '';

          $scope.save = function() {
            if(status.Note != $scope.Note)
            self.apiPost("ajax",{"action":"saveLearningGoalNote","ID":goal.ID,"user":user.ID, "text": $scope.Note}).then(function(){
              status.Note = $scope.Note;
            });

            if(status.TeacherNote != $scope.TeacherNote)
            self.apiPost("ajax",{"action":"saveLearningGoalTeacherNote","ID":goal.ID,"user":user.ID, "text": $scope.TeacherNote}).then(function(){
              status.TeacherNote = $scope.TeacherNote;
            });

            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.pickMaterial = function(current, classid, callback){
      self.showDialog({
        templateUrl: "pickMaterial.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = null;
          $scope.mainTopics = [];
          $scope.canSelectGoal = false;
          if(current && current.taskid){
            $scope.task = self.getTaskByID(current.taskid);
          }
          if(current && current.goalid){
            $scope.goal = self.getGoalByID(current.goalid);
          }

          function addMainTopic(list,mainTopic){
            var mt = {
                org:mainTopic,
                'ID':mainTopic.ID,
                'Owner':mainTopic.Owner,
                'Name':mainTopic.Name,
                'Description':mainTopic.Description,
                'Color':mainTopic.Color,
                "Permission":mainTopic.Permission,
                "shareSettings":mainTopic.shareSettings,
                "OrderIndex":parseInt(mainTopic.OrderIndex),
                "topics":[],"changed":false};

            list.push(mt);

            for(var z=0; z < mainTopic.topics.length; z++){
              var t = {org:mainTopic.topics[z],
                       'ID':mainTopic.topics[z].ID,
                       'Name':mainTopic.topics[z].Name,
                       'Description':mainTopic.topics[z].Description,
                       'OrderIndex':parseInt(mainTopic.topics[z].OrderIndex),
                       'changed':false, 'goals':[]};
              mt.topics.push(t);
              if(current == null && self.currentTopic && self.currentTopic.ID == t.ID){
                mt.Clicked = true;
                t.Clicked = true;
                t.openGoals = true;
              }

              for(var x=0; x < mainTopic.topics[z].goals.length; x++){
                var g = {org:mainTopic.topics[z].goals[x],
                        'ID':mainTopic.topics[z].goals[x].ID,
                        'Name':mainTopic.topics[z].goals[x].Name,
                        'Description':mainTopic.topics[z].goals[x].Description,
                        'OrderIndex':parseInt(mainTopic.topics[z].goals[x].OrderIndex),
                        'changed':false,'tasks':[]};
                t.goals.push(g);
                if($scope.goal && $scope.goal.goal && g.ID == $scope.goal.goal.ID) {
                  mt.Clicked = true;
                  t.Clicked = true;
                  g.Selected = true;
                }else
                if(t.openGoals){
                  g.Clicked = true;
                }

                for(var y=0; y < mainTopic.topics[z].goals[x].tasks.length; y++){
                  var tt = {org:mainTopic.topics[z].goals[x].tasks[y],
                           'ID':mainTopic.topics[z].goals[x].tasks[y].ID,
                           'Name':mainTopic.topics[z].goals[x].tasks[y].Name,
                           'Description':mainTopic.topics[z].goals[x].tasks[y].Description,
                           'OrderIndex':parseInt(mainTopic.topics[z].goals[x].tasks[y].OrderIndex),
                           'changed':false};
                  g.tasks.push(tt);
                  if($scope.task && $scope.task.task && tt.ID == $scope.task.task.ID) {
                    mt.Clicked = true;
                    t.Clicked = true;
                    g.Clicked = true;
                    tt.Clicked = true;
                  }
                }
              }
            }
          };

          if(classid == null){
            $scope.canSelectGoal = true; // in teacher materials can pick also goals
            for(var i=0; i < self.userContent.mainTopics.length; i++){
              addMainTopic($scope.mainTopics,self.userContent.mainTopics[i]);
            }
          }else{
            // inside class only show class content
            for(var i=0; i < self.classContent[classid].mainTopics.length; i++){
              addMainTopic($scope.mainTopics,self.classContent[classid].mainTopics[i]);
            }
          }

          $scope.selectTask = function(taskid) {
            if(callback) callback(taskid,"task");
            self.closeDialog($scope.dialogElement);
          };
          $scope.selectGoal = function(goalid) {
            if(callback) callback(goalid,"goal");
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
