      console.log(e);
      console.log(ev);
      self.alert($filter('trans')('VIDEONOTYETPROCESSED'),null);
    };
    self.handleAudioUploadError = function(e,ev){
      console.log(e);
      console.log(ev);
      self.alert($filter('trans')('AUDIONOTYETPROCESSED'),null);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    //1001
    self.filterJournalScope = function($scope) {

      $scope.refreshFilteredJournal = function(refreshStudent) {
        if(!$scope.filteredJournal) $scope.filteredJournal = [];

        if(refreshStudent == "*"){
          for(var key in self.currentClass.students) {
            var journalData =
              self.getStudentFilteredJournal(self.currentClass.students[key], $scope.filterSettings);

            journalData = $scope.mapJournalData(journalData);
            $scope.filteredJournal[self.currentClass.students[key].ID] = journalData;
          }
        }
        else {
          if($scope.isStudent) refreshStudent = self.user;
          var journalData =
            self.getStudentFilteredJournal(refreshStudent, $scope.filterSettings);
          journalData = $scope.mapJournalData(journalData);
          $scope.filteredJournal[refreshStudent.ID] = journalData;
        }
      };

      $scope.mapJournalData = function(journalData) {
        for(var i = 0; i < journalData.length; i++) {
          if(journalData[i].notexists) {
            journalData.splice(i, 1);
            i--;
          }
        }
        return journalData;
      };

      //inJournal
      $scope.firstItemInView;

      // will be used by pearlTape directive
      $scope.journalPearlsStart = 0;

      // scorll to top of journal
      $scope.scrollToTop = function(){
        if($scope.dialogElement) {
          journalContent = $(".journalContent", $scope.dialogElement);
          journalContent.scrollTop(0);
        }
      };
      // scrolls to the given journal item when clicked on pearl
      $scope.scrollToIndex = function (key, ev){
        var time = 0;

        var journalContent = [];
        journalContent = $(".journalContent", $scope.dialogElement);

        if(self.journalDisplayLimit <= key + 10) {
          $timeout(function() {
            self.journalDisplayLimit = key + 10;
            $timeout(function() {
              if(journalContent.children("#cd-timeline").children(".cd-timeline-block")[key]) {
                journalContent.children("#cd-timeline").children(".cd-timeline-block")[key].scrollIntoView({
                  behavior: "smooth", // or "auto" or "instant"
                  block: "start" // or "end"
                }, 50);
              }
            }, 0);
          }, 0);
        }
        else {
          if(journalContent.children("#cd-timeline").children(".cd-timeline-block")[key]) {
            journalContent.children("#cd-timeline").children(".cd-timeline-block")[key].scrollIntoView({
              behavior: "smooth", // or "auto" or "instant"
              block: "start" // or "end"
            }, 50);
          }
        }
      };

      // builds an array of all top values for all visible journal items
      // to increase performance while scrolling
      $scope.elementTopArray = [];
      $scope.$watch(
        function () {
          var journalContainer = $(".cd-container", $scope.dialogElement).get(0);
          if(journalContainer)
            return journalContainer.offsetHeight;
          return 0;
        },
        function (value) {
          $scope.refreshElementTopArray();
        }
      );

      $scope.refreshElementTopArray = function() {
        var parent = $scope.dialogElement;
        var studentID = $scope.student ? $scope.student.ID : 0;
        if(!studentID) return; // no journal yet
        var resetScrollTops = function(){
          var journalContent = $(".journalContent", parent);
          $scope.elementTopArray = [];
          var elements = journalContent.children("#cd-timeline").children(".cd-timeline-block");
          elements.each(function(i,element){
            var elementTop = element.offsetTop;
            $scope.elementTopArray[i] = [elementTop + 72, elementTop + element.offsetHeight + 72];
          });

          $scope.pearlInView({dialogElement:parent});

          var line = parent.find('.wrappedPearls');
          if(line.get(0)){
            var strings = line.children(".pearls").children('.pearlString');
            if($scope.filteredJournal[studentID].length == 0) {
              $('.fa-caret-up',line).css("display",  "none");
            }
            else {
              $('.fa-caret-up',line).css("display",  "block");
            }
          }
        };

        if($scope.refreshElementTopArrayTimeout)
          $timeout.cancel($scope.refreshElementTopArrayTimeout);

        $scope.refreshElementTopArrayTimeout = $timeout(function() {
          resetScrollTops();
        },100);
      };

      // updates the current pearl in the top most position of the scrolling area
      // uses elementTopArray cache for better performance
      // will be called from when-scrolling on journal panel
      $scope.pearlInView = function(s) {
        var parent = s.dialogElement;
        var journalContent = $(".journalContent", parent);
        var maxPearls = 2 * Math.floor(journalContent[0].offsetWidth / 50 / 2) + 1;

        // used by pearlTape directive
        $scope.pearlLimit = maxPearls;

        var old = $scope.firstItemInView;
        var contentTop = journalContent.scrollTop();
        var contentToBottom = journalContent.scrollTop() + journalContent[0].offsetHeight - journalContent[0].scrollHeight;
        var contentHeight = journalContent[0].offsetHeight;

        $scope.firstItemInView = 0;
        var stopSearchingLast = false;
        var lastItemInView = $scope.elementTopArray.length - 1;
        for(var i = $scope.elementTopArray.length-1; i >= 0; i--) {
          if(
              contentTop >= $scope.elementTopArray[i][0] &&
              contentTop <= $scope.elementTopArray[i][1]) {
            $scope.firstItemInView = i;
          }
          else if(
            !stopSearchingLast &&
            contentHeight + contentTop >= $scope.elementTopArray[i][0] &&
            contentHeight + contentTop <= $scope.elementTopArray[i][1] + 32
          ) {
            stopSearchingLast = true;
            lastItemInView = i;
          }
        }

        if(old != $scope.firstItemInView){
          var studentID = $scope.student.ID;
          var middlePearl = Math.ceil(maxPearls/2) - 1;
          if(typeof $scope.filteredJournal !== 'undefined') {
            if($scope.firstItemInView > middlePearl &&
               $scope.firstItemInView < $scope.filteredJournal[studentID].length - middlePearl) {
              if($scope.filteredJournal[studentID].length == $scope.elementTopArray.length &&
                 $scope.firstItemInView + middlePearl + 5 > $scope.filteredJournal[studentID].length &&
                 journalContent.scrollTop() + journalContent[0].offsetHeight > $scope.elementTopArray[$scope.firstItemInView + middlePearl][0]) {
                $scope.journalPearlsStart = lastItemInView - maxPearls + 1;
              } else {
                $scope.journalPearlsStart = $scope.firstItemInView - middlePearl;
              }
            } else
            if($scope.firstItemInView <= middlePearl ||
               $scope.filteredJournal[studentID].length <= maxPearls) {
              $scope.journalPearlsStart = 0;
            } else
            // if there are more items left on screen that pearls can handle, move pointer to the left
            if($scope.firstItemInView >= $scope.filteredJournal[studentID].length - middlePearl) {
              $scope.journalPearlsStart = $scope.filteredJournal[studentID].length - maxPearls;
            }
          }
        }

        var line = parent.find('.wrappedPearls');
        if(line.get(0)){
          var strings = line.children(".pearls").children('.pearlString');
          if(strings[$scope.firstItemInView - $scope.journalPearlsStart]){
            var pearlsOffsetLeft = line.get(0).offsetLeft;
            var elementOffsetLeft =
              strings[$scope.firstItemInView - $scope.journalPearlsStart].offsetLeft;
            $('.fa-caret-up',line).css("left",  elementOffsetLeft - pearlsOffsetLeft - 4 + "px");
          }
        }

      };
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addAudioRecorderScope = function($scope,additionalFileTypes, disableDropHandler){
      $scope.audioURL = $scope.currentTaskAnswer;
      $scope.audioBlob = null;
      $scope.audioFilename = "";
      $scope.audioPartID = 0;

      // attention: if already a recording is running, thant this will break the previous one
      self.capture = {recording : false};
      $scope.capture = self.capture;

      $scope.hideUploadFileBtn = false;

      if(!window.globalAudioContextPlay){
        try{
          window.globalAudioContextPlay = createAudioContext(0);
          window.globalAudioContextRecord = createAudioContext(0);
        }catch(e){
          console.log("AudioContext not supported by this browser");
        }
      }
      $scope.audioBuffers = [];

      var resampleRate = function(b,rate,callback){
        var OfflineAudioContext = window.OfflineAudioContext || window.webkitOfflineAudioContext;
        if(b.sampleRate == rate || !OfflineAudioContext) {
          callback(b);
          return;
        }
        try{
          console.log("Try to resample audio to "+rate);
          var offlineCtx = new OfflineAudioContext(1,b.duration * rate,rate);
          var offlineSource = offlineCtx.createBufferSource();
          var cloneBuffer = offlineCtx.createBuffer(1, b.length, b.sampleRate);
          cloneBuffer.copyToChannel(b.getChannelData(0), 0);
          offlineSource.buffer = cloneBuffer;
          offlineSource.connect(offlineCtx.destination);
          offlineCtx.oncomplete = function(e) {
            // resampled contains an AudioBuffer resampled at rate.
            callback(e.renderedBuffer);
            offlineCtx = null;
          };
          offlineCtx.onerror = function(){
            callback(b);
            offlineCtx = null;
          };
          offlineCtx.startRendering();
          offlineSource.start(0);
        }catch(e){
          callback(b);
          offlineCtx = null;
        }
      };

      //1010
      if(!disableDropHandler) {
        $timeout(function(){
          self.addDropHandler($scope, $scope.dialogElement, ['audio']);
        },0);
      }

      //1009
      $scope.resetAudio = function(){
        $scope.audioURL = '';
        $scope.audioFilename = '';

        self.capture.playable = false;
        $scope.capture = self.capture;

        $scope.audioBuffers = [];
        $scope.audioPartID = 0;
        $scope.audioBlob = null;

        $scope.currentTaskAnswerChanged = $scope.currentTaskAnswer != '';
        $scope.currentTaskAnswer = '';
      };
      $scope.chooseAudio = function(toAppend) {
        //delete currentAudio from tempRecentFiles
        var fileIndex = -1;
        if(self.tempRecentFiles) {
          for(var i = 0; i < self.tempRecentFiles.audios.length; i++) {
            if(self.tempRecentFiles.audios[i].url == $scope.currentTaskAnswer) fileIndex = i;
            self.tempRecentFiles.audios[i].hide = false;
          }
          if(fileIndex != -1) self.tempRecentFiles.audios[fileIndex].hide = true;
        }

        //open new dialog and either append or overwrite current audio
        var currentAudio = $scope.currentTaskAnswer;
        self.takeUserMedia("audio",null,function(results){
          if(results && results == "RECORDINPARENT")
            $scope.startCapture(toAppend);
          else if(results[0].isNested && results[0].data && results[0].type)
            if(toAppend) {
              $scope.uploadFileSubmit(results[0].data, results[0].type, {appendToBuffer: true});
            }
            else
              $scope.uploadFileSubmit(results[0].data,results[0].type);
          else if(results && results[0].URL != '') {
            self.showLoadingIndicator(null,function(done){
              if(toAppend) {
                var addNow = function(){
                  //maybe the upper URLToBuffer is not fast enough and audioBuffersArray is still empty
                  $scope.URLToBuffer(results[0].URL,function(b,blob){
                    $scope.audioPartID++;
                    $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b,length:Math.ceil(b.length / b.sampleRate), url:results[0].URL});

                    $scope.audioBlob = $scope.exportAudioBuffersToBlob();
                    $timeout(function(){
                      $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
                      $scope.currentTaskAnswerChanged = true;
                      $scope.currentTaskAnswer = $scope.audioURL;
                      done();
                    },0);
                  });

                  $scope.audioFilename = results.Name;
                };
                if($scope.audioBuffers.length == 0) {
                  $scope.URLToBuffer(currentAudio,function(b,blob){
                    $scope.audioPartID++;
                    $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b,length:Math.ceil(b.length / b.sampleRate), url:currentAudio});
                    addNow(); // buffer is filled, add now
                  });
                }else addNow();
              }
              else {
                $scope.audioURL = results[0].URL;
                $scope.audioFilename = results.Name;

                $scope.capture = self.capture;

                $scope.audioBuffers = [];
                $scope.audioPartID = 0;
                $scope.audioBlob = null;

                $scope.currentTaskAnswer = results[0].URL;
                $scope.currentTaskAnswerChanged = true;
                done();
              }
            });
          }
        }, {dialogMode: 0, toAppend: toAppend, isNested:true});
      }

      $scope.clearRecentList = function(ev){
        self.confirm($filter('trans')('ASKCLEARLIST'),$filter('trans')('CLEARLIST'),ev).then(function(){
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.audioUploads){
            delete(self.userViewData.recentFiles.audioUploads);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.audios){
            delete(self.tempRecentFiles.audios);
          }
          $scope.mergedRecentFilesList = [];
          self.updateUserViewData();
        });
      }

      $scope.selectActivity = function(activity) {
        $scope.currentTaskAnswer = activity.url;
        $scope.currentTaskAnswerChanged = true;
        self.capture.playable = true;
        $scope.capture = self.capture;

        $scope.audioURL = activity.url;
        $scope.audioFilename = activity.name;

        $scope.type = "audio";

        if($scope.dialogMode == 0) $scope.save();
      }

      $scope.BlobToBuffer = function(blob,callback){
        var fileReader = new FileReader();
        fileReader.onload = function(data){
          window.globalAudioContextPlay.decodeAudioData(data.target.result, function(decodedData) {
            resampleRate(decodedData,44100,function(resampled){
              if(callback) callback(resampled,blob);
            });
          });
        };
        fileReader.onerror = function(e){
          console.log(e);
        };
        fileReader.readAsArrayBuffer(blob);
      };

      $scope.URLToBuffer = function(URL,callback){
        if(typeof cordova != "undefined" && URL.indexOf(cordova.file.dataDirectory) === 0){
          $window.resolveLocalFileSystemURL(URL, function (fileEntry) {
            fileEntry.file(function (file) {
              var reader = new FileReader();
              reader.onloadend = function (fileReadResult) {
                var data = new Uint8Array(fileReadResult.target.result);
                var blob = self.createBlob(data, file.type);
                $scope.BlobToBuffer(blob,callback);
              };

              reader.onerror = function (e) {
                console.log(e);
              };
              reader.readAsArrayBuffer(file);
            });
          });
        }else{
          if(!window.globalAudioContextPlay) return; // not supported

          var request = new XMLHttpRequest();
          request.open("GET", URL, true);
          request.responseType = "arraybuffer";

          var loader = this;

          request.onload = function () {
              // Asynchronously decode the audio file data in request.response
              window.globalAudioContextPlay.decodeAudioData(
              request.response,

              function (buffer) {
                  if (!buffer) {
                      alert('error decoding file data: ' + url);
                      return;
                  }
                  resampleRate(buffer,44100,function(resampled){
                    if(callback) callback(resampled);
                  });
              },

              function (error) {
                  console.error('decodeAudioData error', error);
              });
          };

          request.onerror = function (e) {
              alert('BufferLoader: XHR error');
          };
          request.send();
        }
      };

      if($scope.currentTaskAnswer != ""){
        self.capture.playable = true;
        // self.capture.recordingDurationMS
        /*$scope.URLToBuffer($scope.currentTaskAnswer,function(b,blob){
          $scope.audioPartID++;
          $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b,
             length:Math.ceil(b.length / b.sampleRate), url:$scope.currentTaskAnswer});
        });*/
      }

      $scope.changeAudioPartsOrder = function(){
        $scope.audioBlob = $scope.exportAudioBuffersToBlob();
        $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
        $scope.currentTaskAnswer = $scope.audioURL;
        $scope.currentTaskAnswerChanged = true;
      };

      $scope.askDeleteAudioPart = function(index,ev){
        self.confirm($filter('trans')('REMOVEAUDIOPART'),$filter('trans')('DELETE'),ev).then(function(){
          $scope.audioBuffers.splice(index,1);
          $scope.audioBlob = $scope.exportAudioBuffersToBlob();
          $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
          $scope.currentTaskAnswerChanged = true;
          $scope.currentTaskAnswer = $scope.audioURL;
        });
      };

      $scope.exportAudioBuffersToBlob = function(callback) {
        var c = 0;
        var sampleRate = 44100;
        for(var i=0; i < $scope.audioBuffers.length; i++){
          c = c + $scope.audioBuffers[i].buffer.length;
          if(sampleRate != $scope.audioBuffers[i].buffer.sampleRate){
            // issue, wrong sample rate here.
            console.log("Wrong sample rate found.");
            self.alert("Ein Audio liegt in einer anderen Aufnahmefrequenz vor. Das Zusammenfügen der Audioteile wird eventuell nicht korrekt funktionieren.");
          }
        }

        var output = window.globalAudioContextPlay.createBuffer(1,c,sampleRate); //audioCtx.sampleRate);
        var offset = 0;
        for(var i=0; i < $scope.audioBuffers.length; i++) {
          output.getChannelData(0).set($scope.audioBuffers[i].buffer.getChannelData(0), offset);
          offset += $scope.audioBuffers[i].buffer.length;
        }

        var input = output.getChannelData(0);
/*
        var length = input.length * 2;
        var interleave = new Float32Array(length);
        var index = 0, inputIndex = 0;

        while (index < length) {
          interleave[index++] = input[inputIndex];
          interleave[index++] = input[inputIndex];
          inputIndex++;
        }
        input = interleave;
*/

        function floatTo16BitPCM(output, offset, input) {
          for (var i = 0; i < input.length; i++, offset += 2) {
            var s = Math.max(-1, Math.min(1, input[i]));
            output.setInt16(offset, s < 0 ? s * 0x8000 : s * 0x7FFF, true);
          }
        }

        function writeString(view, offset, string) {
          for (var i = 0; i < string.length; i++) {
            view.setUint8(offset + i, string.charCodeAt(i));
          }
        }

        var buffer = new ArrayBuffer(44 + input.length * 2);
        var view = new DataView(buffer);
        var channels = 1;
        /* RIFF identifier */
        writeString(view, 0, 'RIFF');
        /* RIFF chunk length */
        view.setUint32(4, 36 + input.length * 2, true);
        /* RIFF type */
        writeString(view, 8, 'WAVE');
        /* format chunk identifier */
        writeString(view, 12, 'fmt ');
        /* format chunk length */
        view.setUint32(16, 16, true);
        /* sample format (raw) */
        view.setUint16(20, 1, true);
        /* channel count */
        view.setUint16(22, channels, true);
        /* sample rate */
        view.setUint32(24, sampleRate, true);
        /* byte rate (sample rate * block align) */
        view.setUint32(28, sampleRate * 4, true);
        /* block align (channel count * bytes per sample) */
        view.setUint16(32, channels * 2, true);
        /* bits per sample */
        view.setUint16(34, 16, true);
        /* data chunk identifier */
        writeString(view, 36, 'data');
        /* data chunk length */
        view.setUint32(40, input.length * 2, true);

        floatTo16BitPCM(view, 44, input);

        var audioBlob = new Blob([view], {type: "audio/wav"});
        return audioBlob;
      }

      $scope.appendCapture = false;

      $scope.processCapture = function(url,filename,blob){
        $timeout(function(){
          if(!$scope.appendCapture){
            $scope.audioBuffers.pop(); // delete last
          }
          $scope.audioURL = "";
          $scope.audioFilename = filename;
          $scope.audioBlob = blob;
          self.capture.processing = true;
          self.showLoadingIndicator(null,function(done){
            if(url.indexOf("blob") == 0){
                $scope.BlobToBuffer(blob,function(b){
                  $scope.audioPartID++;
                  $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b, length:Math.ceil(b.length / b.sampleRate), url:url});
                  $scope.audioBlob = $scope.exportAudioBuffersToBlob();
                  $timeout(function(){
                    $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
                    $scope.currentTaskAnswerChanged = true;
                    $scope.currentTaskAnswer = $scope.audioURL;
                    if($scope.stopCaptureEvent) $scope.stopCaptureEvent();
                    done();
                    self.capture.processing = false;
                    if($scope.dialogMode == 0) $scope.save();
                  },0);
                });
            }else{
              $scope.URLToBuffer(url,function(b){
                $scope.audioPartID++;
                $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b, length:Math.ceil(b.length / b.sampleRate), url:url});
                $scope.audioBlob = $scope.exportAudioBuffersToBlob();
                $timeout(function(){
                  $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
                  $scope.currentTaskAnswerChanged = true;
                  $scope.currentTaskAnswer = $scope.audioURL;
                  if($scope.stopCaptureEvent) $scope.stopCaptureEvent();
                  self.capture.processing = false;
                  done();
                  if($scope.dialogMode == 0) $scope.save();
                },0);
              });
            }
          });

          if(self.capture.updateInterval) clearInterval(self.capture.updateInterval);
          self.capture.updateInterval = null;
        },0);
      };

      $scope.startCapture = function(doAppend){

        // sepcial case, send only recording info back to parent dialog and start recording there
        if($scope.isNested) {
          $scope.sendRecordInParent();
          return;
        }

        self.capture = {recording : false};
        self.capture.startRecording = true;
        self.capture.wasRecording = true;
        $scope.capture = self.capture;
        if(doAppend && $scope.audioBuffers.length == 0 && $scope.audioURL && $scope.audioURL != ""){
          // try read existing audio to buffer now
          $scope.URLToBuffer($scope.audioURL,function(b,blob){
            $scope.audioPartID++;
            $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b, length:Math.ceil(b.length / b.sampleRate), url:$scope.audioUR});
            // now try again
            $scope.startCapture(doAppend);
          });
          return;
        }
        if(self.capture.updateInterval) clearInterval(self.capture.updateInterval);
        self.capture.updateInterval = null;
        $scope.hideUploadFileBtn = true;
        $scope.appendCapture = doAppend;
        self.captureAudio(self.getMediaID(),$scope.processCapture);
        self.capture.updateInterval = setInterval(function(){
          $timeout(function(){
            var now = new Date();
            if(self.capture.recordingTimer){
              self.capture.recordtime = secToMMSS((now.getTime() - self.capture.recordingTimer.getTime())/ 1000);
            }
          },0);
        },500);
      };

      $scope.cancelCapture = function(){
        // used in small panel to cancel recordings like in chat
        if(self.capture.updateInterval) clearInterval(self.capture.updateInterval);
        self.capture.updateInterval = null;
        self.stopCaptureAudio(self.getMediaID(),true);
        $scope.currentTaskAnswerChanged = false;
        if($scope.cancelCaptureEvent) $scope.cancelCaptureEvent();
        $timeout(function(){
          var t = $('#changeToRecordingBtn').get(0);
          if(t) t.focus();          
        },100);
      }

      $scope.stopCapture = function(){
        if(self.capture.updateInterval) clearInterval(self.capture.updateInterval);
        self.capture.updateInterval = null;

        self.stopCaptureAudio(self.getMediaID());
        $scope.currentTaskAnswerChanged = true;
        $timeout(function(){
          var t = $('#changeToRecordingBtn').get(0);
          if(t) t.focus();          
        },100);
      };

      // audio url of uploaded audio
      //options: appendToBuffer, index, indexArray, seperatedFiles
      $scope.uploadFileSubmit = function(e,type, options){
        if($scope.isNested) {
          $scope.sendIsNested([{isNested:true, data:e, type: type}]);
          return;
        }

        options = options ? options : [];

        var index = options.index ? options.index : 0;
        var indexArray = options.indexArray ? options.indexArray : null;
        var seperatedFiles = options.seperatedFiles ? options.seperatedFiles : false;
        var appendToBuffer = options.appendToBuffer ? options.appendToBuffer : false;
        var directSave = options.directSave ? options.directSave : false;
        var dropped = options.dropped ? options.dropped : false;

        e = e && e.target && !e.files ? e.target : e;
        if(e.files.length == 0) return;

        if(!indexArray) {
          //get files as alphabetical sorted array
          var alphaArray = [];
          for(var i = 0; i < e.files.length; i++)
            alphaArray.push(e.files[i].name);
          alphaArray.sort();

          //get files as sorted index array
          indexArray = [];
          for(var i = 0; i < alphaArray.length; i++)
            for(var ii = 0; ii < e.files.length; ii++)
              if(alphaArray[i] == e.files[ii].name)
                indexArray.push(ii);
        }

        if(indexArray && (indexArray[index] || indexArray[index] === 0))
          fileIndex = indexArray[index];
        else
          fileIndex = index;

        if(!self.checkFileType(e.files[fileIndex],type,additionalFileTypes)) {
          if(type == "file")
            self.askToZIPFiles(e,type, options, $scope.uploadFileSubmit);
          return;
        }
        e.files[fileIndex].myType = type;

        var filename = e.files[fileIndex].name;

        var nextIndex = (indexArray && (indexArray[index] || indexArray[index] === 0)) ? indexArray[index+1] : index+1;

        if((index == 0 && !appendToBuffer) || seperatedFiles) {
          self.uploadFileInput(e,function(url){
            if(seperatedFiles) {
              if(!$scope.multipleAnswers)
                $scope.multipleAnswers = [];

              $scope.multipleAnswers.push({url: url, name: filename, type: type});
            }

            $scope.resetAudio();

            $scope.currentTaskAnswer = url;
            $scope.currentTaskAnswerChanged = true;
            self.capture.playable = true;

            //ned mitneh!
            $scope.capture = self.capture;

            $scope.audioURL = url;
            $scope.audioFilename = filename;

            if(e.files.length > index+1) {
              $scope.uploadFileSubmit(e, type, {dropped: dropped, seperatedFiles: seperatedFiles, appendToBuffer: !seperatedFiles, directSave: directSave, index: index+1, indexArray: indexArray});
            }
            else {
              //1009
              $scope.selectActivity({url:url, name:filename});
            }
          }, fileIndex);
        }

        if(appendToBuffer && e.files.length > index) {
          if($scope.audioBuffers.length == 0 && $scope.audioURL && $scope.audioURL != ""){
            // try read existing audio to buffer now
            $scope.URLToBuffer($scope.audioURL,function(b,blob){
              $scope.audioPartID++;
              $scope.audioBuffers.push({id:$scope.audioPartID, blob:blob, buffer:b, length:Math.ceil(b.length / b.sampleRate), url:$scope.audioUR});
              // now try again
              $scope.uploadFileSubmit(e, type, {dropped: dropped, appendToBuffer: true, directSave: directSave, index: index});
            });
          }
          else {
            $scope.BlobToBuffer(e.files[fileIndex],function(b){
              $scope.audioPartID++;
              $scope.audioBuffers.push({id:$scope.audioPartID, blob:e.files[fileIndex], buffer:b, length:Math.ceil(b.length / b.sampleRate)});
              $scope.audioBlob = $scope.exportAudioBuffersToBlob();
              $timeout(function(){
                $scope.audioURL = (window.URL || window.webkitURL).createObjectURL($scope.audioBlob);
                $scope.currentTaskAnswerChanged = true;
                $scope.currentTaskAnswer = $scope.audioURL;
                if($scope.stopCaptureEvent) $scope.stopCaptureEvent();
                if(e.files.length > index+1)
                  $scope.uploadFileSubmit(e, type, {dropped: dropped, appendToBuffer: true, directSave: directSave, index: index+1});
                else if(directSave) {
                  if($scope.audioURL.indexOf("blob:") != -1)
                    self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL,$scope.audioFilename, self.getMediaID(),'record',null,function(filename){
                      $scope.selectActivity({url:filename, name:$scope.audioFilename});
                    });
                }
              },0);
            });
          }
        }
      };
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addVideoRecorderScope = function($scope,additionalFileTypes){
      self.capture = {recording : false};

      $scope.videoURL = $scope.currentTaskAnswer;
      $scope.videoURLDisplay = $scope.videoURL != "" ?
        app.patchWKWebviewPath($scope.videoURL+"?r="+Math.random()) : "";
      $scope.videoFilename = "none";
      $scope.capture = self.capture;

      if($scope.currentTaskAnswer != ""){
        self.capture.playable = true;
      }

      //1010
      $timeout(function(){
        self.addDropHandler($scope, $scope.dialogElement, ['video']);
      },0);

      //1009
      $scope.resetVideo = function(){
        $scope.videoURLDisplay = '';
        $scope.videoURL = '';

        self.capture.playable = false;
        $scope.capture = self.capture;

        $scope.currentTaskAnswerChanged = $scope.currentTaskAnswer != '';
        $scope.currentTaskAnswer = '';
      };
      $scope.chooseVideo = function() {
        //delete currentVideo from tempRecentFiles
        var fileIndex = -1;
        if(self.tempRecentFiles) {
          for(var i = 0; i < self.tempRecentFiles.videos.length; i++) {
            if(self.tempRecentFiles.videos[i].url == $scope.currentTaskAnswer) fileIndex = i;
            self.tempRecentFiles.videos[i].hide = false;
          }
          if(fileIndex != -1) self.tempRecentFiles.videos[fileIndex].hide = true;
        }

        self.takeUserMedia("video",null,function(results){
          if(results && results == "RECORDINPARENT")
            $scope.startCapture();
          else if(results[0].isNested && results[0].data && results[0].type)
            $scope.uploadFileSubmit(results[0].data,results[0].type);
          else if(results && results[0].URL != '') {
            $scope.videoURL = results[0].URL;
            $scope.videoURLDisplay = app.patchWKWebviewPath(results[0].URL+"?r="+Math.random());
            $scope.currentTaskAnswer = results[0].URL;
            $scope.currentTaskAnswerChanged = true;
          }
        }, {dialogMode: 0, isNested: true});
      }

      $scope.clearRecentList = function(ev){
        self.confirm($filter('trans')('ASKCLEARLIST'),$filter('trans')('CLEARLIST'),ev).then(function(){
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.videoUploads){
            delete(self.userViewData.recentFiles.audioUploads);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.videos){
            delete(self.tempRecentFiles.videos);
          }
          $scope.mergedRecentFilesList = [];
          self.updateUserViewData();
        });
      }

      $scope.selectActivity = function(activity) {
        $scope.currentTaskAnswer = activity.url;
        $scope.currentTaskAnswerChanged = true;

        $scope.videoFilename = activity.name;
        $scope.videoURL = activity.url;
        if(activity.blob) $scope.videoBlob = activity.blob;

        $scope.type = "video";

        $scope.videoURLDisplay = activity.blob ? activity.url : app.patchWKWebviewPath(activity.url+"?r="+Math.random());
        self.capture.playable = true;
        $scope.capture = self.capture;

        if($scope.dialogMode == 0) $scope.save();
      }

      $scope.startCapture = function(ev){
        $scope.startedCapture = true;
        $timeout(function(){
          $scope.startedCapture = false;
        },2000);

        if($scope.isNested) {
          $scope.sendRecordInParent();
          return;
        }

        self.capture.wasRecording = true;
        self.captureVideo(self.getMediaID(),function(url,filename,blob){
          $timeout(function(){
            $scope.selectActivity({url:url, name:filename, blob:blob});
          },0);
        },ev);
      };

      $scope.uploadFileSubmit = function(e,type, options){
        if($scope.isNested) {
          $scope.sendIsNested([{isNested:true, data:e, type: type}]);
          return;
        }

        options = options ? options : [];

        var index = options.index ? options.index : 0;
        var indexArray = options.indexArray ? options.indexArray : null;
        var dropped = options.dropped ? options.dropped : false;

        e = e && e.target && !e.files ? e.target : e;
        if(e.files.length == 0) return;

        if(!indexArray) {
          //get files as alphabetical sorted array
          var alphaArray = [];
          for(var i = 0; i < e.files.length; i++)
            alphaArray.push(e.files[i].name);
          alphaArray.sort();

          //get files as sorted index array
          indexArray = [];
          for(var i = 0; i < alphaArray.length; i++)
            for(var ii = 0; ii < e.files.length; ii++)
              if(alphaArray[i] == e.files[ii].name)
                indexArray.push(ii);
        }

        if(indexArray && (indexArray[index] || indexArray[index] === 0))
          fileIndex = indexArray[index];
        else
          fileIndex = index;

        if(!self.checkFileType(e.files[fileIndex],type,additionalFileTypes)) {
          if(type == "file")
            self.askToZIPFiles(e,type, options, $scope.uploadFileSubmit);
          return;
        }

        var filename = e.files[fileIndex].name;
        e.files[fileIndex].myType = type;

        self.uploadFileInput(e,function(url){
          if(e.files.length > 1) {
            //ist das gut?
            if(!$scope.multipleAnswers)
              $scope.multipleAnswers = [];

            $scope.multipleAnswers.push({url: url, name: filename, type: type});
          }

          if(e.files.length > index+1)
            $scope.uploadFileSubmit(e, type, {dropped: dropped, index: index+1, indexArray: indexArray});
          else {
            $scope.selectActivity({url:url, name:filename});
          }
        }, fileIndex);
      };
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addFileRecorderScope = function($scope,additionalFileTypes){
      $scope.fileName = null;
      $scope.fileURL = '';
      $scope.multipleAnswers = [];
      $scope.fileTypes = additionalFileTypes;
      if($scope.currentTaskAnswer && $scope.currentTaskAnswer != ""){
        $scope.fileURL = $scope.currentTaskAnswer;
        $scope.fileName = self.getFilenameFromURL($scope.currentTaskAnswer);
        var re = /(?:\.([^.]+))?$/;
        var ext = re.exec($scope.fileName.toLowerCase())[1];
        if(ext == "zip"){
          self.showLoadingIndicator(null,function(done){
            // test for .list file now
            self.apiPost("ajax",{"action":"checkListFile","noerror":1, "url":$scope.fileURL}).then(function(data) {
              if(data.list){
                $scope.multipleAnswers = []; // reset array now
                for(var i=0; i < data.list.length; i++){
                  var parts = data.list[i].file.split("/");
                  var filename = parts[1];
                  filename = filename.replace(/_[a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9][a-z0-9]+\./,'.');
                  var type = self.checkTypeFromFileName(parts[1]);
                  $scope.multipleAnswers.push({url: "https://learningview.org/uploads/"+data.list[i].file, 
                                               name: filename, type: type});
                }              
              }
              done();
            });
          },10000);
        }
        var type = self.checkTypeFromFileName($scope.fileName);
        $scope.multipleAnswers.push({url: $scope.fileURL, name: $scope.fileName, type: type});
      }

      $scope.takeFileWithType = function(type){
        // only one file returned
        self.takeUserMedia(type,null,function(results){
          if(results)
            // close the dialog first 
            $timeout(function(){
              for(var i=0; i < results.length; i++){
                if(results[i].URL != ''){
                  $scope.selectActivity({url: results[i].URL, name: results[i].Name},i < results.length-1);
                }
              }              
            },100);
        },{dialogMode:type == "audio" ? 1 : 0, isNested: false});
      };

      $scope.removeFile = function(f){
        var p = $scope.multipleAnswers.indexOf(f);
        if(p != -1){
          $scope.multipleAnswers.splice(p,1);
          $scope.currentTaskAnswerChanged = true;
        }
        if($scope.multipleAnswers.length == 0)
          $scope.currentTaskAnswerChanged = false; // disable save button
      };

      $scope.clearRecentList = function(ev){
        self.confirm($filter('trans')('ASKCLEARLIST'),$filter('trans')('CLEARLIST'),ev).then(function(){
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.fileUploads){
            delete(self.userViewData.recentFiles.fileUploads);
          }
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.imageUploads){
            delete(self.userViewData.recentFiles.imageUploads);
          }
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.audioUploads){
            delete(self.userViewData.recentFiles.audioUploads);
          }
          if(self.userViewData && self.userViewData.recentFiles && self.userViewData.recentFiles.videoUploads){
            delete(self.userViewData.recentFiles.videoUploads);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.images){
            delete(self.tempRecentFiles.images);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.audios){
            delete(self.tempRecentFiles.audios);
          }
          if(self.tempRecentFiles && self.tempRecentFiles.videos){
            delete(self.tempRecentFiles.videos);
          }
          $scope.mergedRecentFilesList = [];
          self.updateUserViewData();
        });
      }

      //all types have selectActivity because of showRecentFilesPanel's callback
      $scope.selectActivity = function(activity,notlast) {
        $scope.currentTaskAnswer = activity.url;
        $scope.currentTaskAnswerChanged = true;

        $scope.fileURL = activity.url;
        $scope.fileName = activity.name;
        if($scope.fileName === '') {
          var parts = $scope.fileURL.split("/");
          $scope.fileName = parts[parts.length-1];
        }

        if(!$scope.multipleAnswers) $scope.multipleAnswers = [];
        var type = self.checkTypeFromFileName($scope.fileName);
        var alreadyThere = false;
        for(var i = 0; i < $scope.multipleAnswers.length; i++){
          if($scope.multipleAnswers[i].url == $scope.fileURL) {
            alreadyThere = true;
            break;
          }
        }
        if(!alreadyThere)
          $scope.multipleAnswers.push({url: $scope.fileURL, name: $scope.fileName, type: type});

        if(!notlast && $scope.dialogMode == 0) $scope.save();
      };


      //1010
      $timeout(function(){
        // calls $scope.uploadFileSubmit on file dropped
        self.addDropHandler($scope, $scope.dialogElement, ['file']);
      },0);

      $scope.uploadFileSubmit = function(e,type, options){
        if($scope.isNested) {
          $scope.sendIsNested([{isNested:true, data:e, type: type}]);
          return;
        }

        options = options ? options : [];

        var index = options.index ? options.index : 0;
        var indexArray = options.indexArray ? options.indexArray : null;
        var dropped = options.dropped ? options.dropped : false;

        e = e && e.target && !e.files ? e.target : e;
        if(e.files.length == 0) return;

        if(!indexArray) {
          //get files as alphabetical sorted array
          var alphaArray = [];
          for(var i = 0; i < e.files.length; i++)
            alphaArray.push(e.files[i].name);
          alphaArray.sort();

          //get files as sorted index array
          indexArray = [];
          for(var i = 0; i < alphaArray.length; i++)
            for(var ii = 0; ii < e.files.length; ii++)
              if(alphaArray[i] == e.files[ii].name)
                indexArray.push(ii);
        }

        if(indexArray && (indexArray[index] || indexArray[index] === 0))
          fileIndex = indexArray[index];
        else
          fileIndex = index;

        if(!self.checkFileType(e.files[fileIndex],"file",additionalFileTypes)) {
          self.askToZIPFiles(e,type, options, $scope.uploadFileSubmit);
          return;
        }

        var filename = e.files[fileIndex].name;

        var type = self.checkTypeFromFileName(filename);
        // reset list on first element
        e.files[fileIndex].myType = type;
        self.uploadFileInput(e,function(url){
          // continue if not last file
          $scope.selectActivity({url: url, name: filename},index < e.files.length-1);

          if(e.files.length > index+1)
            $scope.uploadFileSubmit(e, type, {dropped: dropped, index: index+1, indexArray: indexArray});
        }, fileIndex);
      };
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addGalleryRecorderScope = function($scope, gallery){
      // add gallery function and feedback if teacher is looking at student result here

      if($scope.t){
        $scope.taskDescriptionWidth = self.getTaskDescriptionWidth($scope.t,'(max-width: 900px)');
      }
      if($scope.student){
        $scope.it = self.getUserTaskStatus($scope.t, $scope.student,true);
        if($scope.it && $scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != ''){
          $scope.students = $scope.it.ColleaguesIDs.split(",").map(Number);
        }
      }

      $scope.gallery = [];
      
      if(gallery)
      for(var i=0; i < gallery.length; i++)
        if(gallery[i].status && gallery[i].student && gallery[i].status.Status && gallery[i].status.Status != "") $scope.gallery.push(gallery[i]);


      $scope.updateGallery = function(){
        var p = -1;
        if($scope.gallery)
        for(var i=0; i < $scope.gallery.length; i++){
          if($scope.gallery[i].student.ID == $scope.student.ID) p = i;
        }
        $scope.showLast = $scope.gallery && p > 0;
        $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;        
      }
      
      $scope.updateGallery();

      $scope.goLast = function(){
        if(self.currentTaskFeedbackDialog){
          self.closeDialog(self.currentTaskFeedbackDialog);
          self.currentTaskFeedbackDialog = null;
        }
        $scope.goLastNow();
      };

      $scope.goLastNow = function(){
        if(!$scope.gallery) return;
        var p = -1;
        for(var i=0; i < $scope.gallery.length; i++){
          if($scope.gallery[i].student.ID == $scope.student.ID) p = i;
        }
        if(p > 0) {

          $scope.student = $scope.gallery[p-1].student;
          $scope.it = $scope.gallery[p-1].status;

          if($scope.it && $scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != ''){
            $scope.students = $scope.it.ColleaguesIDs.split(",").map(Number);
          }

          $scope.updateURL();
          p--;
        }
        $scope.showLast = $scope.gallery && p > 0;
        $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;
      };

      $scope.goNext = function(){
        if(self.currentTaskFeedbackDialog){
          self.closeDialog(self.currentTaskFeedbackDialog);
          self.currentTaskFeedbackDialog = null;
        }
        $scope.goNextNow();
      };

      $scope.goNextNow = function(){
        if(!$scope.gallery) return;
        var p = -1;
        for(var i=0; i < $scope.gallery.length; i++){
          if($scope.gallery[i].student.ID == $scope.student.ID) p = i;
        }
        if(p >= 0 && p < $scope.gallery.length-1) {
          $scope.student = $scope.gallery[p+1].student;
          $scope.it = $scope.gallery[p+1].status;

          if($scope.it && $scope.it.ColleaguesIDs && $scope.it.ColleaguesIDs != ''){
            $scope.students = $scope.it.ColleaguesIDs.split(",").map(Number);
          }

          $scope.updateURL();
          p++;
        }
        $scope.showLast = $scope.gallery && p > 0;
        $scope.showNext = $scope.gallery && p < $scope.gallery.length-1;
      };

    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addCalendarScope = function($scope){

      $scope.keyPressed = function(e){
        if(self.user.Teacher == 0) return true;
        if(e.keyCode == 37) $scope.lastStudent();
        if(e.keyCode == 39) $scope.nextStudent();
      };

      $scope.currentDay = {};
      $scope.currentWeek = {};
      $scope.currentMonth = {};

      if(!self.lastCalendarDate) self.lastCalendarDate = moment();

      $scope.currentDay.currentDate = self.lastCalendarDate.clone();
      $scope.currentWeek.currentDate = self.lastCalendarDate.clone().startOf('isoWeek');
      $scope.currentMonth.currentDate = self.lastCalendarDate.clone().startOf('month');

      $scope.exportCalendarList = function(format,ev){
        $scope.waitForDownload = true;
        var date = null;
        if($scope.mode == "day") date = $scope.currentDay.currentDate.format("YYYY-MM-DD");
        if($scope.mode == "weeks") date = $scope.currentWeek.currentDate.format("YYYY-MM-DD");
        if($scope.mode == "months") date = $scope.currentMonth.currentDate.format("YYYY-MM-DD");
        if($scope.mode == "list") date = moment().format("YYYY-MM-DD");
        // (format == 'pdf' ? 'hideDetails=1&':'')
        var url = "https://learningview.org/api/exportCalendarList.php?format="+format+"&type="+$scope.mode+"&date="+date+"&user="+($scope.student ? $scope.student.ID : self.user.ID)+"&code="+($scope.student ? $scope.student.Salt : self.user.Salt)+(self.filterCurrentClassOnly ? "&classid="+self.currentClass.ID : '')+(!$scope.student || $scope.student.ID == self.user.ID ? '&own=1':'');
        var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
        function checkDownload(){
          if(document.cookie.indexOf("fileDownload=true") > -1) {
            var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
            document.cookie = cookieData;
            setTimeout(function(){ frame.remove();},1000);
            $scope.waitForDownload = false;
          }else
            $timeout(checkDownload,100);
        }
        var filename = "";
        filename = "LearningViewExport_"+(self.filterCurrentClassOnly ? self.currentClass.Name+"_" : "")+"Kalender_";
        if($scope.mode == "day") filename += $scope.currentDay.currentDate.format("YYYY-MM-DD");
        if($scope.mode == "weeks") filename += "Woche "+$scope.currentWeek.currentDate.isoWeek();
        if($scope.mode == "months") filename += $scope.currentMonth.currentDate.format("DDDD");
        if($scope.mode == "list") filename += 'ab_'+$scope.currentDay.currentDate.format("YYYY-MM-DD");;

        filename = window.cleanFilename(filename);
        filename = filename + "." + format;

        if(window.electron){
          window.downloadElectronSaveAs(url,filename,function(){
            $timeout(function(){$scope.waitForDownload = false;},0);
          });
        }else
        if(typeof cordova != "undefined"){
          self.downloadFile(url,filename,true);
          $timeout(function(){$scope.waitForDownload = false;},500);
        }else{
          $('body').append(frame);
          checkDownload();
        }
      };
      $scope.isTaskInClass = function(t, classid){
        var task = self.findTaskInClass({ID:classid},t.task.ID);
        if(!task) return false; else return true;
      };

      $scope.hasSignup = function(it,student){
        if(it.Checked){
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].User == student.ID) return true;
          }
        }
        return false;
      };

      $scope.countSignups = function(it,slot){
        var c = 0;
        if(it.Checked){
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].Slot == slot) c++;
          }
        }
        return c;
      };

      $scope.isSignup = function(it,slot,student){
        if(it.Checked){
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].Slot == slot && it.Checked[i].User == student.ID) return it.Checked[i];
          }
        }
        return false;
      };

      $scope.hasSignupText = function(it,slot){
        if(it.Checked){
          for(var i=0; i < it.Checked.length; i++){
            if(it.Checked[i].Slot == slot && it.Checked[i].Text && it.Checked[i].Text != '') return true;
          }
        }
        return false;
      };

      $scope.getCalendarNoteItem = function(classid,date,userid){     
        if(!$scope.calendarNotes) $scope.calendarNotes = {}; 
        if(!$scope.calendarNotes[classid]) $scope.calendarNotes[classid] = []; 
        for(var i=0; i < $scope.calendarNotes[classid].length; i++){
          if($scope.calendarNotes[classid][i].Class == classid && 
             $scope.calendarNotes[classid][i].User == userid && 
             $scope.calendarNotes[classid][i].Date == date){
            return $scope.calendarNotes[classid][i];
          }
        }
        var r = {};
        r.ID = -1;
        r.Date = date;
        r.Class = classid;
        r.User = userid;
        r.Data = '{"text":""}';
        r.DataJSON = JSON.parse(r.Data);
        $scope.calendarNotes[classid].push(r); // push a temp item for now
        return r;
      }

      $scope.moveLineUp = function(calendarItem,index){
        if(!calendarItem || !calendarItem.DataJSON || !calendarItem.DataJSON.text) return;
        index = parseInt(index,10);
        if(isNaN(index) || index <= 0) return;
        var calendarItemLines = calendarItem.DataJSON.text.split("\n");
        if(index >= calendarItemLines.length) return;
        var old = calendarItem.DataJSON.text;
        var tmp = calendarItemLines[index-1];
        calendarItemLines[index-1] = calendarItemLines[index];
        calendarItemLines[index] = tmp;
        calendarItem.DataJSON.text = calendarItemLines.join("\n");
        calendarItem.Data = JSON.stringify(calendarItem.DataJSON);
        self.apiPost("ajax",{"action":"updateCalendarNoteItem", 
          "classid":calendarItem.Class, "user":calendarItem.User, 
          "date":calendarItem.Date, "ID":calendarItem.ID, "data":calendarItem.Data}).then(function(result){
          if(result.ID) calendarItem.ID = result.ID;
        },function(data, status, headers, config) {
          self.alert("Speichern fehlgeschlagen: "+data.error);
          calendarItem.DataJSON.text = old;
          calendarItem.Data = JSON.stringify(calendarItem.DataJSON);
        });
      };

      $scope.getClassCalendarNoteOrder = function(item){
        if(!item) return 0;
        var orderIndex = item.DataJSON && (item.DataJSON.OrderIndex || item.DataJSON.OrderIndex === 0) ?
                         parseInt(item.DataJSON.OrderIndex,10) : NaN;
        if(isNaN(orderIndex)){
          orderIndex = parseInt(item.ID,10);
          if(isNaN(orderIndex)) orderIndex = 0;
        }
        return orderIndex;
      };

      $scope.moveClassCalendarNoteUp = function(item,index,date,classid,isCoaching,ev){
        if(ev) ev.stopPropagation();
        if(!item || !item.DataJSON || self.user.Teacher != 1) return;
        index = parseInt(index,10);
        if(isNaN(index) || index <= 0) return;

        if(!classid){
          classid = item.Class ? item.Class : (self.currentClass ? self.currentClass.ID : null);
        }
        if(!classid || !self.classContent || !self.classContent[classid] || !self.classContent[classid].classCalendarNotes) return;

        var day = date ? String(date) : (item.Date ? String(item.Date) : null);
        if(!day) return;
        var coaching = isCoaching ? true : false;
        var source = self.classContent[classid].classCalendarNotes;
        var list = [];
        for(var i=0; i < source.length; i++){
          var n = source[i];
          if(!n || !n.DataJSON || String(n.Date) != day) continue;
          var nCoaching = n.DataJSON.Coaching ? true : false;
          if(nCoaching != coaching) continue;
          list.push(n);
        }
        if(list.length < 2) return;

        list.sort(function(a,b){
          var ao = $scope.getClassCalendarNoteOrder(a);
          var bo = $scope.getClassCalendarNoteOrder(b);
          if(ao == bo){
            return parseInt(a.ID,10) > parseInt(b.ID,10) ? 1 : -1;
          }
          return ao > bo ? 1 : -1;
        });

        var pos = -1;
        for(var p=0; p < list.length; p++){
          if(list[p].ID == item.ID){
            pos = p;
            break;
          }
        }
        if(pos <= 0) return;

        var prev = list[pos-1];
        if(!prev || !prev.DataJSON) return;

        var oldItem = angular.toJson(item.DataJSON);
        var oldPrev = angular.toJson(prev.DataJSON);
        var itemOrder = $scope.getClassCalendarNoteOrder(item);
        var prevOrder = $scope.getClassCalendarNoteOrder(prev);

        item.DataJSON.OrderIndex = prevOrder;
        prev.DataJSON.OrderIndex = itemOrder;
        item.Data = JSON.stringify(item.DataJSON);
        prev.Data = JSON.stringify(prev.DataJSON);

        $q.all([
          self.apiPost("ajax",{"action":"updateClassCalendarNoteItem","ID":item.ID,"data":item.Data}),
          self.apiPost("ajax",{"action":"updateClassCalendarNoteItem","ID":prev.ID,"data":prev.Data})
        ]).then(function(){
        },function(data){
          try{
            item.DataJSON = JSON.parse(oldItem);
            prev.DataJSON = JSON.parse(oldPrev);
            item.Data = JSON.stringify(item.DataJSON);
            prev.Data = JSON.stringify(prev.DataJSON);
          }catch(e){}
          self.alert("Speichern fehlgeschlagen: "+(data && data.error ? data.error : ""));
        });
      };

      $scope.refreshMonth = function(){
        var d = $scope.currentMonth.currentDate.diff(moment().startOf('month'), 'months');

        $scope.currentMonth.startDate = moment($scope.currentMonth.currentDate).startOf('month');
        var startDay = $scope.currentMonth.startDate.day();
        if(startDay != 1 && startDay != 0 && startDay != 6){
          while(startDay != 1){
            $scope.currentMonth.startDate = $scope.currentMonth.startDate.add(-1,'days');
            startDay = $scope.currentMonth.startDate.day();
          }
        }

        $scope.currentMonth.endDate = moment($scope.currentMonth.currentDate).endOf('month');
        var endDay = $scope.currentMonth.endDate.day();
        if(endDay != 5 && endDay != 6 && endDay != 0){
          while(endDay != 5){
            $scope.currentMonth.endDate = $scope.currentMonth.endDate.add(1,'days');
            endDay = $scope.currentMonth.endDate.day();
          }
        }

        $scope.currentMonth.startDateShort = $scope.currentMonth.startDate.format("DD.MM.");
        $scope.currentMonth.endDateShort = $scope.currentMonth.endDate.format("DD.MM.");

        if(d < -1) $scope.currentMonth.label = $filter('trans')('MONTHSAGO',-d);
        if(d == -1) $scope.currentMonth.label = $filter('trans')('LASTMONTH');
        if(d == 0) $scope.currentMonth.label = $filter('trans')('THISMONTH');
        if(d == 1) $scope.currentMonth.label = $filter('trans')('NEXTMONTH');
        if(d > 1) $scope.currentMonth.label = $filter('trans')('MONTHSAHEAD',d);

        $scope.currentMonth.delta = d;
        // fetch all tasks for all 31 days
        $scope.currentMonth.days = [];
        for(var i=0; i < 50; i++){
          if($scope.currentMonth.endDate < moment($scope.currentMonth.startDate).add(i,'days')) break;
          var d = {id:i};
          d.isToday = moment($scope.currentMonth.startDate).add(i,'days').format("YYYY-MM-DD") == moment().format("YYYY-MM-DD");
          d.isCurrentWeek = moment($scope.currentMonth.startDate).add(i,'days').isoWeek() == moment().isoWeek() && moment($scope.currentMonth.startDate).add(i,'days').format("YYYY") == moment().format("YYYY");
          d.day = moment($scope.currentMonth.startDate).add(i,'days').format("dddd");
          d.dayNum = moment($scope.currentMonth.startDate).add(i,'days').day();
          d.date = moment($scope.currentMonth.startDate).add(i,'days').format("YYYY-MM-DD");

          if(moment($scope.currentMonth.startDate).add(i,'days').day() == 1){
            // each monday
            d.weekNumber = moment(moment($scope.currentMonth.startDate).add(i,'days')).isoWeek();
          }

          d.dateLabel = moment($scope.currentMonth.startDate).add(i,'days').format("D");
          d.dateHint = moment($scope.currentMonth.startDate).add(i,'days').format("dddd, D.MMMM");
          if(d.dayNum == 0 || d.dayNum == 6) continue; // skip Sa and So
          $scope.currentMonth.days.push(d);
        }

        var s = moment($scope.currentMonth.currentDate).startOf('isoWeek');
        $scope.currentMonth.dayLabels = [];
        for(var i = 0; i < 5; i++){
          $scope.currentMonth.dayLabels.push(moment(s).add(i,'days').format("dd"));
        }
        $scope.currentMonth.name = moment($scope.currentMonth.currentDate).startOf('month').format("MMMM YYYY");
      };

      $scope.refreshWeek = function(){
        var d = $scope.currentWeek.currentDate.diff(moment().startOf('isoWeek'), 'weeks');

        $scope.currentWeek.startDate = moment($scope.currentWeek.currentDate).startOf('isoWeek');
        $scope.currentWeek.endDate = moment($scope.currentWeek.currentDate).endOf('isoWeek');
        $scope.currentWeek.startDateShort = $scope.currentWeek.startDate.format("DD.MM.");
        $scope.currentWeek.endDateShort = $scope.currentWeek.endDate.format("DD.MM.");

        if(d < -1) $scope.currentWeek.label = $filter('trans')('WEEKSAGO',-d);
        if(d == -1) $scope.currentWeek.label = $filter('trans')('LASTWEEK');
        if(d == 0) $scope.currentWeek.label = $filter('trans')('THISWEEK');
        if(d == 1) $scope.currentWeek.label = $filter('trans')('NEXTWEEK');
        if(d > 1) $scope.currentWeek.label = $filter('trans')('WEEKSAHEAD',d);

        $scope.currentWeek.delta = d;
        $scope.currentWeek.weekNumber = moment($scope.currentWeek.startDate).isoWeek();

        // fetch all tasks for all 7 days
        $scope.currentWeek.days = [];
        for(var i=0; i < 7; i++){
          var d = {id:i};
          d.isToday = moment($scope.currentWeek.startDate).add(i,'days').format("YYYY-MM-DD") == moment().format("YYYY-MM-DD");
          d.day = moment($scope.currentWeek.startDate).add(i,'days').format("dddd");
          d.date = moment($scope.currentWeek.startDate).add(i,'days').format("YYYY-MM-DD");
          d.dateLabel = moment($scope.currentWeek.startDate).add(i,'days').format("DD.MM.YYYY");
          $scope.currentWeek.days.push(d);

        }
        
        // list view all days with content
        $scope.currentWeek.list = [];
        if($scope.mode == "list"){
          var n = moment().format("YYYY-MM-DD");

          for(var i=0; i < 360; i++){
            var d = {id:i};
            d.date = moment(n).add(i,'days').format("YYYY-MM-DD");
            if($scope.hasContentOnDate(d)){
              d.dayN = moment(n).add(i,'days').format("D");
              d.day = moment(n).add(i,'days').format("dddd");
              d.month = moment(n).add(i,'days').format("MMM");
              d.isToday = moment(n).add(i,'days').format("YYYY-MM-DD") == moment().format("YYYY-MM-DD");
              d.dateLabel = moment(n).add(i,'days').format("DD.MM.YYYY");
              $scope.currentWeek.list.push(d);
            }
          }
        }
      };

      $scope.refreshDay = function(){
        var d = $scope.currentDay.currentDate.diff(moment().format("YYYY-MM-DD"), 'days');


        if(d < -1) $scope.currentDay.label = $filter('trans')('DAYSAGO',-d);
        if(d == -1) $scope.currentDay.label = $filter('trans')('YESTERDAY');
        if(d == 0) $scope.currentDay.label = $filter('trans')('TODAY');
        if(d == 1) $scope.currentDay.label = $filter('trans')('TOMORROW');
        if(d > 1) $scope.currentDay.label = $filter('trans')('DAYSAHEAD',d);

        $scope.currentDay.delta = d;

        // fetch all tasks for all 7 days
        $scope.currentDay.days = [];
        for(var i=0; i < 1; i++){
          var d = {id:i};
          d.isToday = moment($scope.currentDay.currentDate).add(i,'days').format("YYYY-MM-DD") == moment().format("YYYY-MM-DD");
          d.day = moment($scope.currentDay.currentDate).add(i,'days').format("dddd");
          d.date = moment($scope.currentDay.currentDate).add(i,'days').format("YYYY-MM-DD");
          d.dateLabel = moment($scope.currentDay.currentDate).add(i,'days').format("DD.MM.YYYY");
          $scope.currentDay.days.push(d);
        }

        $scope.currentDay.name = moment($scope.currentDay.currentDate).format("dddd, D. MMMM");
        $scope.currentDay.monthLabel = moment($scope.currentDay.currentDate).format("MMMM");
      };

      $scope.refreshDay();
      $scope.refreshWeek();
      $scope.refreshMonth();

      $scope.hasCalendarNoteItems = function(date,notes){
        for(var i=0; i < notes.length; i++){
          if(notes[i].Date == date) return true;
        }
        return false;
      }
      $scope.hasCalendarItems = function(date,calendar){
        for(var i=0; i < calendar.length; i++){
          if(calendar[i].Date == date && self.getTaskByID(calendar[i].Task)) return true;
        }
        return false;
      }
      $scope.nextDay = function(){
        $scope.currentDay.currentDate.add(1, "days");
        self.lastCalendarDate = $scope.currentDay.currentDate;
        $scope.refreshDay();
      };
      $scope.lastDay = function(){
        $scope.currentDay.currentDate.add(-1, "days");
        self.lastCalendarDate = $scope.currentDay.currentDate;
        $scope.refreshDay();
      };
      $scope.thisDay = function(){
        $scope.currentDay.currentDate = moment(moment().format("YYYY-MM-DD"));
        self.lastCalendarDate = $scope.currentDay.currentDate;
        $scope.refreshDay();
      };
      $scope.goToDay = function(n){
        $scope.thisDay();
        $scope.currentDay.currentDate.add(n, "days");
        self.lastCalendarDate = $scope.currentDay.currentDate;
        $scope.refreshDay();
      };
      $scope.goToDate = function(d){
        $scope.currentDay.currentDate = moment(d);
        self.lastCalendarDate = $scope.currentDay.currentDate;
        $scope.refreshDay();
      };
      $scope.isDay = function(n){
        var d = moment(moment().format("YYYY-MM-DD")).add(n, "days");
        return d.isSame($scope.currentDay.currentDate);
      };

      $scope.nextWeek = function(){
        $scope.currentWeek.currentDate.add(1, "weeks");
        self.lastCalendarDate = $scope.currentWeek.currentDate;
        $scope.refreshWeek();
      };
      $scope.lastWeek = function(){
        $scope.currentWeek.currentDate.add(-1, "weeks");
        self.lastCalendarDate = $scope.currentWeek.currentDate;
        $scope.refreshWeek();
      };
      $scope.thisWeek = function(){
        $scope.currentWeek.currentDate = moment().startOf('isoWeek');
        self.lastCalendarDate = $scope.currentWeek.currentDate;
        $scope.refreshWeek();
      };
      $scope.goToWeek = function(n){
        $scope.thisWeek();
        $scope.currentWeek.currentDate.add(n, "weeks");
        self.lastCalendarDate = $scope.currentWeek.currentDate;
        $scope.refreshWeek();
      };
      $scope.isInWeek = function(n){
        var d = moment().startOf('isoWeek');
        d.add(n, "weeks");
        return d.isSame($scope.currentWeek.currentDate);
      };

      $scope.nextMonth = function(){
        $scope.currentMonth.currentDate.add(1, "months");
        self.lastCalendarDate = $scope.currentMonth.currentDate;
        $scope.refreshMonth();
      };
      $scope.lastMonth = function(){
        $scope.currentMonth.currentDate.add(-1, "months");
        self.lastCalendarDate = $scope.currentMonth.currentDate;
        $scope.refreshMonth();
      };
      $scope.thisMonth = function(){
        $scope.currentMonth.currentDate = moment().startOf('month');
        self.lastCalendarDate = $scope.currentMonth.currentDate;
        $scope.refreshMonth();
      };
      $scope.goToMonth = function(n){
        $scope.thisMonth();
        $scope.currentMonth.currentDate.add(n, "months");
        self.lastCalendarDate = $scope.currentMonth.currentDate;
        $scope.refreshMonth();
      };
      $scope.isInMonth = function(n){
        var d = moment().startOf('month');
        d.add(n, "months");
        return d.isSame($scope.currentMonth.currentDate);
      };

      $scope.changeMode = function(m,noSave){
        if($scope.closeMonthDayPopup) $scope.closeMonthDayPopup(null,true);
        self.lastCalendarMode = m;
        $scope.mode = self.lastCalendarMode;
        if($scope.mode == "list") 
          $scope.goToWeek(0); 
        $scope.refreshDay();
        $scope.refreshWeek();
        $scope.refreshMonth();
        if(!noSave){
          self.userViewData["calendarMode"] = self.lastCalendarMode;
          self.updateUserViewData();
        }
        return true;
      };

      $scope.switchStudent = function(s){
        if($scope.closeMonthDayPopup) $scope.closeMonthDayPopup(null,true);
        $scope.student = s;
        self.currentTaskStudent = s;
        $scope.calendars = self.users[s.ID].calendars;
        $scope.calendarsByDate = self.users[s.ID].calendarsByDate;
        $scope.calendarsByTask = self.users[s.ID].calendarsByTask;
        $scope.calendarNotes = self.users[s.ID].calendarNotes;
        $scope.refreshDay();
        $scope.refreshWeek();
        $scope.refreshMonth();
        $scope.updatedStudent = true;
        $timeout(function(){
          $scope.updatedStudent = false;
        },0);
      };

      $scope.nextStudent = function() {
        var next = $scope.getNextStudent();
        if(next){
          if($scope.closeMonthDayPopup) $scope.closeMonthDayPopup(null,true);
          var s2 = next;
          $scope.student = s2;
          self.currentTaskStudent = s2;
          $scope.calendars = self.users[s2.ID].calendars;
          $scope.calendarsByDate = self.users[s2.ID].calendarsByDate;
          $scope.calendarsByTask = self.users[s2.ID].calendarsByTask;
          $scope.calendarNotes = self.users[s2.ID].calendarNotes;
          $scope.refreshDay();
          $scope.refreshWeek();
          $scope.refreshMonth();
          $scope.updatedStudent = true;
          $timeout(function(){
            $scope.updatedStudent = false;
          },0);
        }
      };
      $scope.lastStudent = function() {
        var next = $scope.getLastStudent();
        if(next){
          if($scope.closeMonthDayPopup) $scope.closeMonthDayPopup(null,true);
          var s2 = next;
          $scope.student = s2;
          self.currentTaskStudent = s2;
          $scope.calendars = self.users[s2.ID].calendars;
          $scope.calendarsByDate = self.users[s2.ID].calendarsByDate;
          $scope.calendarsByTask = self.users[s2.ID].calendarsByTask;
          $scope.calendarNotes = self.users[s2.ID].calendarNotes;
          $scope.refreshDay();
          $scope.refreshWeek();
          $scope.refreshMonth();
          $scope.updatedStudent = true;
          $timeout(function(){
            $scope.updatedStudent = false;
          },0);
        }
      };

      $scope.getNextStudent = function() {
        return self.findRelativeStudentInCurrentClass($scope.student,+1);
      };
      $scope.getLastStudent = function() {
        return self.findRelativeStudentInCurrentClass($scope.student,-1);
      };

      $scope.monthDayPopup = {open:false,day:null,style:{},closing:false};
      $scope.monthDayPopupCloseTimer = null;
      var monthDayPopupRepositionTimer = null;
      var clampMonthDayPopupValue = function(value, min, max){
        return Math.max(min, Math.min(max, value));
      };
      var getMonthDayPopupViewport = function(){
        var vv = window.visualViewport;
        var width = vv && vv.width ? vv.width : (window.innerWidth || 1024);
        var height = vv && vv.height ? vv.height : (window.innerHeight || 768);
        var left = vv && typeof(vv.offsetLeft) == "number" ? vv.offsetLeft : 0;
        var top = vv && typeof(vv.offsetTop) == "number" ? vv.offsetTop : 0;
        return {
          left: left,
          top: top,
          width: width,
          height: height,
          right: left + width,
          bottom: top + height
        };
      };
      var getMonthDayPopupAnchor = function(){
        var anchorEl = $scope.monthDayPopup.anchorEl;
        if(anchorEl && anchorEl.getBoundingClientRect){
          var rect = anchorEl.getBoundingClientRect();
          var anchor = {
            left: rect.left,
            top: rect.top,
            right: rect.right,
            bottom: rect.bottom,
            width: rect.width,
            height: rect.height
          };
          $scope.monthDayPopup.anchorRect = anchor;
          return anchor;
        }
        return $scope.monthDayPopup.anchorRect || null;
      };
      $scope.repositionMonthDayPopup = function(delay){
        $timeout(function(){
          if(!$scope.monthDayPopup.open) return;
          var popupEl = document.querySelector(".calendarDayQuickPopup");
          $scope.positionMonthDayPopup(popupEl);
        },typeof(delay) == "number" ? delay : 0);
      };
      var requestMonthDayPopupReposition = function(delay){
        if(monthDayPopupRepositionTimer){
          $timeout.cancel(monthDayPopupRepositionTimer);
          monthDayPopupRepositionTimer = null;
        }
        monthDayPopupRepositionTimer = $timeout(function(){
          monthDayPopupRepositionTimer = null;
          $scope.repositionMonthDayPopup(0);
        },typeof(delay) == "number" ? delay : 180);
      };
      $scope.finishMonthDayPopupClose = function(){
        if($scope.monthDayPopupCloseTimer){
          $timeout.cancel($scope.monthDayPopupCloseTimer);
          $scope.monthDayPopupCloseTimer = null;
        }
        $scope.monthDayPopup.open = false;
        $scope.monthDayPopup.day = null;
        $scope.monthDayPopup.anchorEl = null;
        $scope.monthDayPopup.anchorRect = null;
        $scope.monthDayPopup.style = {};
        $scope.monthDayPopup.closing = false;
      };
      $scope.positionMonthDayPopup = function(popupEl){
        var margin = 12;
        var gap = 8;
        var defaultPopupHeight = 520;
        var viewport = getMonthDayPopupViewport();
        var popupWidth = Math.min(500, Math.max(0, viewport.width - (margin * 2)));
        var anchor = getMonthDayPopupAnchor();
        if(!anchor){
          var centerHeight = Math.min(defaultPopupHeight, Math.max(0, viewport.height - margin * 2));
          $scope.monthDayPopup.style = {
            width: popupWidth+"px",
            left: (viewport.left + ((viewport.width - popupWidth) / 2))+"px",
            top: (viewport.top + ((viewport.height - centerHeight) / 2))+"px",
            maxHeight: Math.max(0, viewport.height - margin * 2)+"px",
            "--popup-from-x":"0px",
            "--popup-from-y":"0px",
            "transform-origin":"50% 50%"
          };
          return;
        }

        var measuredHeight = popupEl && popupEl.offsetHeight ? popupEl.offsetHeight : defaultPopupHeight;
        var availableBelow = Math.max(0, viewport.bottom - anchor.bottom - gap - margin);
        var availableAbove = Math.max(0, anchor.top - viewport.top - gap - margin);
        var openBelow = availableBelow >= availableAbove;
        var maxHeight = openBelow ? availableBelow : availableAbove;
        if(maxHeight <= 0){
          maxHeight = Math.max(0, viewport.height - margin * 2);
        }
        var usedHeight = Math.min(measuredHeight, maxHeight);

        var desiredLeft = anchor.left + (anchor.width / 2) - (popupWidth / 2);
        var minLeft = viewport.left + margin;
        var maxLeft = viewport.right - margin - popupWidth;
        if(maxLeft < minLeft){
          minLeft = viewport.left;
          maxLeft = viewport.right - popupWidth;
        }
        var left = clampMonthDayPopupValue(desiredLeft, minLeft, maxLeft);

        var desiredTop = openBelow ? (anchor.bottom + gap) : (anchor.top - gap - usedHeight);
        var minTop = viewport.top + margin;
        var maxTop = viewport.bottom - margin - usedHeight;
        if(maxTop < minTop){
          minTop = viewport.top;
          maxTop = viewport.bottom - usedHeight;
        }
        var top = clampMonthDayPopupValue(desiredTop, minTop, maxTop);

        var originX = clampMonthDayPopupValue((anchor.left + anchor.width / 2) - left, 0, popupWidth);
        var originY = clampMonthDayPopupValue((anchor.top + anchor.height / 2) - top, 0, maxHeight);
        var popupCenterX = left + popupWidth / 2;
        var popupCenterY = top + usedHeight / 2;
        var fromX = (anchor.left + anchor.width / 2) - popupCenterX;
        var fromY = (anchor.top + anchor.height / 2) - popupCenterY;

        $scope.monthDayPopup.style = {
          width: popupWidth+"px",
          left: left+"px",
          top: top+"px",
          maxHeight: maxHeight+"px",
          "--popup-from-x": fromX+"px",
          "--popup-from-y": fromY+"px",
          "transform-origin": originX+"px "+originY+"px"
        };
      };
      $scope.closeMonthDayPopup = function(ev,immediate){
        if(ev) ev.stopPropagation();
        if(!$scope.monthDayPopup.open) return;
        if(immediate){
          $scope.finishMonthDayPopupClose();
          return;
        }
        if($scope.monthDayPopup.closing) return;
        $scope.monthDayPopup.closing = true;
        if($scope.monthDayPopupCloseTimer) $timeout.cancel($scope.monthDayPopupCloseTimer);
        $scope.monthDayPopupCloseTimer = $timeout(function(){
          $scope.finishMonthDayPopupClose();
        },220);
      };
      $scope.openMonthDayPopup = function(day,ev){
        if(ev) ev.stopPropagation();
        if(!day || !day.date) return;
        if($scope.monthDayPopupCloseTimer){
          $timeout.cancel($scope.monthDayPopupCloseTimer);
          $scope.monthDayPopupCloseTimer = null;
        }
        $scope.monthDayPopup.closing = false;
        if($scope.taskToAdd){
          $scope.addTaskToCalendar(day.date,ev);
          return;
        }
        var target = ev && (ev.currentTarget || ev.target) ? (ev.currentTarget || ev.target) : null;
        if(target && target.getBoundingClientRect){
          $scope.monthDayPopup.anchorEl = target;
          var rect = target.getBoundingClientRect();
          $scope.monthDayPopup.anchorRect = {
            left: rect.left,
            top: rect.top,
            right: rect.right,
            bottom: rect.bottom,
            width: rect.width,
            height: rect.height
          };
        }else{
          $scope.monthDayPopup.anchorEl = null;
          $scope.monthDayPopup.anchorRect = null;
        }
        $scope.goToDate(day.date);
        $scope.monthDayPopup.day = angular.copy($scope.currentDay.days[0]);
        $scope.monthDayPopup.open = true;
        $scope.repositionMonthDayPopup(0);
        requestMonthDayPopupReposition(180);
      };

      var onMonthDayPopupViewportChange = function(){
        if(!$scope.monthDayPopup.open) return;
        $scope.repositionMonthDayPopup(0);
        requestMonthDayPopupReposition(180);
      };
      var onMonthDayPopupFocusIn = function(ev){
        if(!$scope.monthDayPopup.open) return;
        var target = ev && ev.target ? ev.target : null;
        if(!target) return;
        if(target.closest && !target.closest(".calendarDayQuickPopup")) return;
        var tag = target.tagName ? target.tagName.toLowerCase() : "";
        var isEditable = target.isContentEditable || tag == "input" || tag == "textarea" || tag == "select";
        if(!isEditable) return;
        requestMonthDayPopupReposition(220);
      };
      window.addEventListener("resize", onMonthDayPopupViewportChange);
      window.addEventListener("orientationchange", onMonthDayPopupViewportChange);
      if(window.visualViewport && window.visualViewport.addEventListener){
        window.visualViewport.addEventListener("resize", onMonthDayPopupViewportChange);
        window.visualViewport.addEventListener("scroll", onMonthDayPopupViewportChange);
      }
      document.addEventListener("focusin", onMonthDayPopupFocusIn, true);

      $scope.$on("$destroy", function(){
        if(monthDayPopupRepositionTimer){
          $timeout.cancel(monthDayPopupRepositionTimer);
          monthDayPopupRepositionTimer = null;
        }
        window.removeEventListener("resize", onMonthDayPopupViewportChange);
        window.removeEventListener("orientationchange", onMonthDayPopupViewportChange);
        if(window.visualViewport && window.visualViewport.removeEventListener){
          window.visualViewport.removeEventListener("resize", onMonthDayPopupViewportChange);
          window.visualViewport.removeEventListener("scroll", onMonthDayPopupViewportChange);
        }
        document.removeEventListener("focusin", onMonthDayPopupFocusIn, true);
      });
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addChatMessageScope = function($scope){
      $scope.addMessage = function(array, index) {
          if(array[index].Type == "text" && array[index].Text)
            $scope.state.message = array[index].Text;
          else
            $scope.state.message = array[index].URL;

          $scope.sendMessage(function() {
            if(array.length > index+1)
              $scope.addMessage(array, index+1);
          });
      }

      $scope.insertEmoji = function(ev){
        self.pickEmoji(ev,function(result){
          $timeout(function(){
            var textarea = $("textarea",$(ev.target).parent().parent()).get(0);
            textarea.focus();
            // Get the current cursor position
            var position = textarea.selectionStart;

            // Get the text before and after the cursor position
            var before = textarea.value.substring(0, position);
            var after = textarea.value.substring(position, textarea.value.length);

            // Insert the new text at the cursor position
            textarea.value = before + result + after;

            // Set the cursor position to after the newly inserted text
            textarea.selectionStart = textarea.selectionEnd = position + result.length;

            $scope.state.message = textarea.value;
          },0);
        });
      };

      //1010
      $timeout(function(){
        self.addDropHandler($scope, $scope.dialogElement, null, true, false, function(results) { $scope.addMessage(results, 0); });
      });

      $scope.messageSeenByAll = function(m,room){
        if(room.isPrivate == 0 && self.currentClass && self.currentOpenChatLastReads && self.currentOpenChatLastReads.length < self.currentClass.students.length) return false;
        if(self.currentOpenChatLastReads){
          for(var i=0; i < self.currentOpenChatLastReads.length; i++)
            if(m.Changed > self.currentOpenChatLastReads[i].LastRead) return false;
          return true;
        } else
          return false;
      };
      $scope.messageNotSeenBy = function(m,room){
        var r = "";
        var users = [];
        var read = [];
        if(self.currentOpenChatLastReads)
          for(var i=0; i < self.currentOpenChatLastReads.length; i++){
            if(m.Changed > self.currentOpenChatLastReads[i].LastRead)
              users.push(self.currentOpenChatLastReads[i].User); else
              read.push(self.currentOpenChatLastReads[i].User);
          }
        if(room.isPrivate == 0){
          for(var i=0; i < self.currentClass.students.length; i++){
            if(read.indexOf(self.currentClass.students[i].ID) != -1) continue;
            if(users.indexOf(self.currentClass.students[i].ID) != -1) continue;
            users.push(self.currentClass.students[i].ID);
          }
        }
        var names = [];
        // all missing reads in users now
        for(var i=0; i < users.length; i++)
          if(self.users[users[i]])
            names.push(self.users[users[i]].Name+(self.users[users[i]].Surname && self.users[users[i]].Surname.length > 0 ? " "+self.users[users[i]].Surname[0]+". " : ''));
        return names.join(", ");
      };

      $scope.needsTimestamp = function (list,i){
        var m = list[i];
        var lastMessage = i > 0 ? list[i-1] : null;
        var needs = false;
        if(lastMessage){
          if(lastMessage.isSys == "1" || lastMessage.Deleted == "1" || lastMessage.User != m.User) {
            needs = true;
          }else{
            var d1 = new Date().fromMysqlFormat(lastMessage.Created);
            var d2 = new Date().fromMysqlFormat(m.Created);
            // more than 20 minutes past?
            if(Math.abs(d2.getTime() - d1.getTime()) > 1000*60*20) needs = true;
          }
        } else needs = true;
        return needs;
      };
      $scope.isURL = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*/) ? true : false;
      };
      $scope.isAudio = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(m4a)/) ? true : false;
      };
      $scope.isImage = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(jpg|jpeg|png|gif)/) ? true : false;
      };
      $scope.isVideo = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(mp4)/) ? true : false;
      };
      $scope.isTaskRef = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/m[0-9]+/) ? true : false;
      };
      $scope.isRubricRef = function(m){
        return m.Message.toLowerCase().match(/https:\/\/learningview\.org\/r[0-9a-zA-Z]{10}/) ? true : false;
      };
      $scope.isAskAccept = function(m){
        return m.isSys == 1 && m.Message.match(/%%ASKACCESS%%/) ? true : false;
      }
      $scope.isAnswered = function(list,m){
        var parts = m.Message.split("|");
        var pos = list.indexOf(m);
        if(pos < list.length-1) {
          if(list[pos+1].Deleted != 1 && list[pos+1].isSys == 1 && 
            (list[pos+1].Message.match(/%%ACCESS%%/) || 
             list[pos+1].Message.match(/%%DENY%%/))) return true;
        } else return false;
        return false;
      };
      $scope.getTaskRefID = function(m){
        return m.Message.replace("https://learningview.org/m","");
      };
      $scope.getRubricRefGUID = function(m){
        return m.Message.replace("https://learningview.org/r","");
      };
      $scope.isFile = function(m){
        if($scope.isImage(m)) return false;
        if($scope.isAudio(m)) return false;
        if($scope.isVideo(m)) return false;
        return $scope.isURL(m);
      };
      $scope.getFilename = function(url){
        return self.getFilenameFromURL(url);
      };

      $scope.getChatStudentUser = function(m){
        if(self.user.Teacher == '1' && self.users[m.User] && self.isStudentOfCurrentClass(m.User)){
          return self.users[m.User];
        }else{
          if(self.currentOpenChat && self.user.Teacher == 1){
            var countStudents = 0;
            for(var i =0; i < self.currentOpenChat.users.length; i++){
              if(self.isStudentOfCurrentClass(self.currentOpenChat.users[i].User)) countStudents++;
            }
            if(countStudents == 1){
              var foundSelf = false;
              var foundUser = false;
              for(var i =0; i < self.currentOpenChat.users.length; i++){
                if(self.currentOpenChat.users[i].User == self.user.ID) foundSelf = true;
                if(self.currentOpenChat.users[i].User != self.user.ID && self.isStudentOfCurrentClass(self.currentOpenChat.users[i].User))
                  foundUser = self.currentOpenChat.users[i].User;
              }
              if(foundSelf && foundUser){
                return self.users[foundUser];
              }
            }
          }          
          if($scope.userList && $scope.userList.length > 0){
            return self.users[$scope.userList[0]];
          }
          return self.user;
        }
      };

      $scope.getRefTaskStatus = function(t,m){
        var s = $scope.getChatStudentUser(m);
        return self.getUserTaskStatus(t, s, true);
      };

      $scope.getTasksFromMessage = function(m){
        var tasks = [];
        var parts = m.Message.split(" ");
        for(var i=0; i < parts.length; i++){
          var n = self.getTaskByID(parts[i].replace("https://learningview.org/m",""));
          if(!n) continue;
          tasks.push(n);
        }
        return tasks;
      }

      $scope.openTaskRef = function(m,task,ev){
        var s = $scope.getChatStudentUser(m);
        this.fromChat = true;
        if(self.user.Teacher == '1' && s.ID != self.user.ID){
          self.openResultButtonWindow(task,s,ev,this);
        }else{
          self.openTaskButtonWindow(task,ev,this);
        }
      }
/*
      $scope.openTaskRef = function(m,ev){
        var n = self.getTaskByID(m.Message.replace("https://learningview.org/m",""));
        if(!n) return;
        var s = $scope.getChatStudentUser(m);
        this.fromChat = true;
        if(self.user.Teacher == '1' && s.ID != self.user.ID){
          self.openResultButtonWindow(n.task,s,ev,this);
        }else{
          self.openTaskButtonWindow(n.task,ev,this);
        }
      };
*/
      $scope.openRubricRef = function(m,ev){
        var n = self.getRubricByGUID(m.Message.replace("https://learningview.org/r",""));
        if(!n) {
          self.alert($filter('trans')('RUBRICWASNOTFOUND'));
          return;
        }
        var s = $scope.getChatStudentUser(m);
        self.showRubric(n,s,$scope.userList ? $scope.userList : null, null, self.currentTask ? self.currentTask : null, ev);
      };

      $scope.getMessage = function(m){
        var s = m.Message;
        function escapeHtml(unsafe) {
            return unsafe
                 .replace(/&/g, "&amp;")
                 .replace(/</g, "&lt;")
                 .replace(/>/g, "&gt;")
                 .replace(/"/g, "&quot;")
                 .replace(/'/g, "&#039;");
         }
        s = escapeHtml(s);

        if(s.indexOf("%%TXT%%") === 0){
          s = m.Message.replace("%%TXT%%","");
        }
        if(s.indexOf("%%TASKINREVIEW%%") === 0){
          s = '<i class="fa fa-fw fa-comments"></i> ' + $filter('trans')('TASKINREVIEW') + " - "+self.shortDateTimePrivacy(m.Created);
        }else
        if(s.indexOf("%%TASKCLOSED%%") === 0){
          s = '<i class="fa fa-fw fa-lock"></i> ' + $filter('trans')('TASKCLOSED') + " - "+self.shortDateTimePrivacy(m.Created);
        }else
        if(s.indexOf("%%TASKREJECTED%%") === 0){
          s = '<i class="fa fa-fw fa-exclamation-triangle"></i> ' + $filter('trans')('STATUSNOTOK') + " - "+self.shortDateTimePrivacy(m.Created);
        }else
        if(s.indexOf("%%RESOLVED%%") === 0){
          s = self.user.Teacher == 1 ? $filter('trans')('CHATQUESTIONRESOLVED') : "";
        }else
        if(s.indexOf("%%NEWTITLE%%") === 0){
          var p = s.split("|"); p.shift();
          s = $filter('trans')('CHATTITLECHANGED','<b>'+p.join('')+'</b>');
        }else
        if(s.indexOf("%%CANWRITE0%%") === 0){
          s = $filter('trans')('CHATCANWRITETEACHERS');
        }else
        if(s.indexOf("%%CANWRITE1%%") === 0){
          s = $filter('trans')('CHATCANWRITEALL');
        }else
        if(s.indexOf("%%SETVISIBILITY0%%") === 0){
          s = self.user.Teacher == 1 ? $filter('trans')('CHATCANSEEALL') : "";
        }else
        if(s.indexOf("%%SETVISIBILITY1%%") === 0){
          s = self.user.Teacher == 1 ? $filter('trans')('CHATCANSEEONLYME') : "";
        }else
        if(s.indexOf("%%SETVISIBILITY2%%") === 0){
          s = self.user.Teacher == 1 ? $filter('trans')('CHATCANSEETEACHERS') : "";
        }else
        if(s.indexOf("%%URL%%") === 0){
          var p = s.split("|"); p.shift();
          p2 = p.pop(); // last one
          p1 = p.join("|");
          if(p2 == "") p2 = p1;
          s = '<a href="'+p1+'">'+p2+'</a>';
        }else
        if(s.indexOf("%%INVITE%%") === 0){
          var p = s.split("|"); p.shift();
          var u = self.users[m.User];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);
          s = $filter('trans')('INVITEDTOCHAT',from,'<b>'+p.join(", ")+'</b>');
        }else
        if(s.indexOf("%%KICK%%") === 0){
          var p = s.split("|"); p.shift();
          var u = self.users[m.User];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);
          s = $filter('trans')('KICKEDFROMCHAT',from,'<b>'+p.join(", ")+'</b>');
        }else
        if(s.indexOf("%%CREATED%%") === 0){
          var p = s.split("|"); p.shift();
          var u = self.users[m.User];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);
          if(self.currentOpenChat && self.currentOpenChat.isPrivate == "1")
            s = $filter('trans')('CREATEDCHAT',from,'<b>'+self.currentOpenChat.Title+'</b>'); else
            s = $filter('trans')('CREATEDCLASSCHAT',from,'<b>'+self.currentOpenChat.Title+'</b>');
          if(p.length > 0)
            s += '<br>'+
              $filter('trans')('INVITEDTOCHAT',from,'<b>'+p.join(", ")+'</b>');
        }else
        if(s.indexOf("%%ASKACCESS%%") === 0){
          var p = s.split("|"); p.shift();
          var task = self.getTaskByID(p[0]);
          if(task) task = task.task;

          var us = self.getUserTaskStatus(task,{ID:m.User},true);
          var u = self.users[m.User];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);

          if(task){
            var partners = self.getUserTaskStatusColleagues(task,u);
            if(partners && partners != ""){
              from = $filter('trans')('GROUP');            
            }
          }

          if(us.ColleaguesIDs && us.ColleaguesIDs != '') from = $filter('trans')('GROUP');

          var index = parseInt(p[1]);
          var name = $filter('trans')("ATTACHMENTS")+' '+(index+1);
          if(task && task.DataJSON && task.DataJSON.hints && task.DataJSON.hints.length > index){
            if(task.DataJSON.hints[index].text && task.DataJSON.hints[index].text != ''){
              name = task.DataJSON.hints[index].text;
            }
          }
          s = $filter('trans')('REQUESTEDACCESS',from,'<b>'+name+'</b>')+' '+self.shortDateTimePrivacy(m.Created);
        }else
        if(s.indexOf("%%ACCESS%%") === 0 || s.indexOf("%%DENY%%") === 0){
          var p = s.split("|"); p.shift();
          var u = self.users[p[0]];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);
          var task = self.getTaskByID(p[1]);
          if(task) task = task.task;
          var index = parseInt(p[2]);
          var name = $filter('trans')("ATTACHMENTS")+' '+(index+1);
          if(task && task.DataJSON && task.DataJSON.hints && task.DataJSON.hints.length > index){
            if(task.DataJSON.hints[index].text && task.DataJSON.hints[index].text != ''){
              name = task.DataJSON.hints[index].text;
            }
          }
          if(s.indexOf("%%DENY%%") === 0)
            s = $filter('trans')('DENYEDACCESS','<b>'+name+'</b>',from)+' '+self.shortDateTimePrivacy(m.Created);
          if(s.indexOf("%%ACCESS%%") === 0)
            s = $filter('trans')('APPROVEDACCESS','<b>'+name+'</b>',from)+' '+self.shortDateTimePrivacy(m.Created);
        }      

        if(m.Deleted == "1"){
          var u = self.users[m.User];
          var from = u ? u.Name + " " + u.Surname : $filter('trans')('SOMEBODY');
          from = from.charAt(0).toUpperCase() + from.slice(1);
          s = $filter('trans')('CHATMESSAGEDELETED','<b>'+from+'</b>');
        }
        // strip tags before here?

        // single emoji? enlarge it
        if(s.match(/^[\u{200D}-\u{E007F}]+$/u)){
          s = '<span style="font-size:300%">'+s+'</span>';
        }

        return self.trustAsHTML(s,true,true);
      };

      $scope.openMessageContextMenu = function(m,ev){
        if(m.isSys == '1') return;
        if(m.Deleted == '1' && self.user.Teacher != "1") return;
        var position = $mdPanel.newPanelPosition()
            .absolute().relativeTo(ev.target)
            .addPanelPosition('align-start', 'below')
            .addPanelPosition('align-start', 'center')
            .addPanelPosition('align-start', 'above');

        var panelAnimation = $mdPanel.newPanelAnimation()
            .openFrom(ev)
            .withAnimation($mdPanel.animation.SCALE);

        var parentScope = $scope;
        var config = {
          attachTo: angular.element(document.body),
          onDomAdded: function(e){
            var menu = e[1];
            self.limitPanelToViewport(menu._panelEl);
            var container = menu._panelContainer.get(0);
            container.addEventListener("click", function (e) {
              if (e.target === container) {
                menu.close();
              }
            });          
          },
          templateUrl: "messageContextMenu.html",
          controller: function ($scope, $mdPanel, mdPanelRef) {
            $scope.self = self;
            $scope.m = m;
            $scope.isTranslateable = m.Deleted == '0' && (!parentScope.isURL(m) && !parentScope.isTaskRef(m) && !parentScope.isRubricRef(m));
           
            $scope.targetLanguage = self.getLocalStorage("lastTranslationTarget") ? self.getLocalStorage("lastTranslationTarget") : "en";
            $scope.setTargetLanguage = function(v){
              $scope.targetLanguage = v;
              self.setLocalStorage("lastTranslationTarget",$scope.targetLanguage);
            }
            $scope.reply = function(){
              mdPanelRef.close();         
              parentScope.state.reply = m;
            }
            $scope.translate = function(){
              mdPanelRef.close();
              self.showServerTranslation(parentScope.getMessage(m).$$unwrapTrustedValue(),ev);
            };
            $scope.addEmoji = function(value){
              mdPanelRef.close();
              self.apiPost("ajax",{"action":"emojiChatMessage", "ID":m.ID, "value":value})
               .then(function(data) {
                  if(data.message)
                    self.updateChatMessages([data.message]);
                });
            };
            $scope.close = function(){
              mdPanelRef.close();
            };
            $scope.readaloud = function(){
              mdPanelRef.close();
              self.showLoadingIndicator(null,function(done){
                self.getText2Speech(parentScope.getMessage(m).$$unwrapTrustedValue(),"de").then(done);
              },20000);
            };
            $scope.unread = function(){
              mdPanelRef.close();
              self.showLoadingIndicator(null,function(done){
                self.lastOpenChat = null; // close open chat now!
                parentScope.closeChatRoom(null);
                self.chatRoomClosed = new Date().getTime();
                self.apiPost("ajax",{"action":"unreadChatMessage", "ID":m.ID})
                 .then(function(data) {
                    self.keepAliveCallback();
                    done();
                  });
              },20000);
            };

            $scope.undeleteMessage = function(){
              mdPanelRef.close();
              parentScope.updateChatRoomLastScroll();
              self.apiPost("ajax",{"action":"undeleteChatMessage", "ID":m.ID})
               .then(function(data) {
                  if(data.message)
                    self.updateChatMessages([data.message]);
                });
            };
            $scope.deleteMessage = function(){
              mdPanelRef.close();
              self.confirm($filter('trans')(m.Deleted == '0' ? 'DELETECHATMESSAGEASK' : 'DELETEFINALCHATMESSAGEASK'),$filter('trans')('DELETE'),ev).then(function(){
                parentScope.updateChatRoomLastScroll();
                self.apiPost("ajax",{"action":"deleteChatMessage", "ID":m.ID})
                 .then(function(data) {
                    if(data.message)
                      self.updateChatMessages([data.message]);
                  });
              });
            };
          },
          position: position,
          openFrom: ev,
          animation:panelAnimation,
          clickOutsideToClose: true,
          escapeToClose: true,
          focusOnOpen: true,
          zIndex: 100
        };

        self.showPanel(config);
      };

      $scope.openFeedbackContextMenu = function(m,ev){
        if(m.Deleted == '1') return;
        //if(m.Deleted == '1' && self.user.Teacher != "1") return;

        var position = $mdPanel.newPanelPosition()
            .absolute().relativeTo(ev.target)
            .addPanelPosition('align-start', 'below')
            .addPanelPosition('align-start', 'center')
            .addPanelPosition('align-start', 'above');

        var panelAnimation = $mdPanel.newPanelAnimation()
            .openFrom(ev)
            .withAnimation($mdPanel.animation.SCALE);

        var parentScope = $scope;
        var config = {
          attachTo: angular.element(document.body),
          onDomAdded: function(e){
            var menu = e[1];
            self.limitPanelToViewport(menu._panelEl);
            var container = menu._panelContainer.get(0);
            container.addEventListener("click", function (e) {
              if (e.target === container) {
                menu.close();
              }
            });          
          },
          templateUrl: "messageContextMenu.html",
          controller: function ($scope, $mdPanel, mdPanelRef) {
            $scope.self = self;
            $scope.m = m;
            $scope.isTranslateable = (!m.Deleted || m.Deleted == '0') && (!parentScope.isURL(m) && !parentScope.isTaskRef(m) && !parentScope.isRubricRef(m));
            
            $scope.targetLanguage = self.getLocalStorage("lastTranslationTarget") ? self.getLocalStorage("lastTranslationTarget") : "en";
            $scope.setTargetLanguage = function(v){
              $scope.targetLanguage = v;
              self.setLocalStorage("lastTranslationTarget",$scope.targetLanguage);
            }
            $scope.reply = function(){
              mdPanelRef.close();         
              parentScope.state.reply = m;
            }
            $scope.translate = function(){
              mdPanelRef.close();
              self.showServerTranslation(parentScope.getMessage(m).$$unwrapTrustedValue(),ev);
            };
            $scope.close = function(){
              mdPanelRef.close();
            };
            $scope.readaloud = function(){
              mdPanelRef.close();
              self.showLoadingIndicator(null,function(done){
                self.getText2Speech(parentScope.getMessage(m).$$unwrapTrustedValue(),"de").then(done);
              },20000);
            };

            $scope.addEmoji = function(value){
              mdPanelRef.close();
              self.apiPost("ajax",{"action":"addTaskStatusFeedbackEmoji",
                                   "ID":parentScope.task.ID, 
                                   "user":parentScope.student.ID,
                                   "index":parentScope.status.FeedbackJSON.indexOf(m), 
                                   "value":value})
               .then(function(data) {
                  self.keepAliveCallback();
                });
            };

            $scope.duplicateToClass = function(){
              mdPanelRef.close();
              self.showDialog({
                templateUrl: "classStudentSelectionStatus.html",
                targetEvent: ev,
                skipHide:true, // keep other dialog open
                clickOutsideToClose: true,
                controller: function ($scope, $mdDialog) {
                  $scope.self = self;
                  $scope.c = self.currentClass;
                  $scope.t = parentScope.task;
                  $scope.saveBtnText = $filter('trans')("DUPLICATE");

                  $scope.selection = [];
                  $scope.disabled = parentScope.userList;
                  $scope.smallScreen = self.isSmallScreen;

                  self.addContentVisibilityScope($scope);

                  $scope.save = function() {
                    self.closeDialog($scope.dialogElement);
                    var done = 0;
                    for(var i=0; i < $scope.selection.length; i++){
                      if($scope.disabled.indexOf($scope.selection[i]) != -1) continue;
                      done++;
                      self.apiPost("ajax",{"action":"addTaskStatusFeedback",
                          "ID":parentScope.task.ID,
                          "user":$scope.selection[i],
                          "classid":self.currentClass.ID, 
                          "reply":m.reply ? JSON.stringify(m.reply) : '',
                          "message":m.Message}).then(function(){
                            done--;
                            if(done == 0){
                              self.keepAliveCallback();
                            }
                          });
                    }
                  };

                  $scope.cancel = function (){
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });              
            };

            $scope.deleteMessage = function(){
              mdPanelRef.close();
              self.confirm($filter('trans')(m.Deleted == '0' ? 'DELETECHATMESSAGEASK' : 'DELETEFINALCHATMESSAGEASK'),$filter('trans')('DELETE'),ev).then(function(){
                parentScope.updateChatLastScroll();
                self.apiPost("ajax",{"action":"removeTaskStatusFeedback",
                                     "ID":parentScope.task.ID,
                                     "user":parentScope.student.ID,
                                     "classid":self.currentClass.ID,
                                     "index":parentScope.status.FeedbackJSON.indexOf(m)})
                 .then(function(data) {
                    self.keepAliveCallback();
                  });
              });
            };
          },
          position: position,
          openFrom: ev,
          clickOutsideToClose: true,
          animation:panelAnimation,
          escapeToClose: true,
          focusOnOpen: true,
          zIndex: 200
        };

        self.showPanel(config);
      };

      $scope.currentTaskAnswer = ""; // used for record scope

      self.addAudioRecorderScope($scope, null, true);

      $scope.removeUploadFileButton = true;

      $scope.takePhoto = function(ev){
        self.takeUserMedia("image",null,function(results){ $scope.addMessage(results, 0); },{dialogMode:0});
      };
      $scope.takeAudio = function(ev){
        self.takeUserMedia("audio",null,function(results){ $scope.addMessage(results, 0); },{dialogMode:1});
      };
      $scope.takeVideo = function(ev){
        self.takeUserMedia("video",null,function(results){ $scope.addMessage(results, 0); },{dialogMode:1, allowMultiple:true});
      };
      $scope.takeFile = function(ev){
        self.takeUserMedia("file",null,function(results){ $scope.addMessage(results, 0); },{dialogMode:0, allowMultiple:true});
      };
      $scope.takeWeblink = function(ev){
        var parent = $scope;
        self.showDialog({
          templateUrl: "addWeblinkDialog.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          onRemoving:function(){
          },
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.URL = "";
            $scope.Name = "";
            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
            $scope.save = function() {
              if(!$scope.URL || $scope.URL == "") return;
              if(!$scope.Name) $scope.Name = "";
              parent.addMessage([{Type:"text", Text:'%%URL%%|'+$scope.URL+'|'+$scope.Name}], 0);
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };

      $scope.selectTask = function(ev){
        var classid = self.currentClass ? self.currentClass.ID : null;
        if(self.currentOpenChat && self.currentOpenChat.Class && self.classContent[self.currentOpenChat.Class])
          classid = self.currentOpenChat.Class;

        var s = $scope.getChatStudentUser({ID:-1});

        self.pickTasks([], classid, s, function(selected){
          var s = "";
          for(var i=0; i < selected.length; i++){
            s += "https://learningview.org/m"+selected[i] + " ";
          }
          $scope.state.message = $.trim(s); 
          $scope.sendMessage();
        });              
        /*
        self.pickMaterial(null, classid, function(id,type){
          $scope.state.message = "https://learningview.org/m"+id;
          $scope.sendMessage();
        });
        */
      };

      $scope.selectRubric = function(ev){
        var classid = self.currentClass ? self.currentClass.ID : null;
        if(self.currentOpenChat && self.currentOpenChat.Class && self.classContent[self.currentOpenChat.Class])
          classid = self.currentOpenChat.Class;
        self.pickRubrics(null, true, function(results){
          $scope.state.message = "https://learningview.org/r"+self.getRubricByID(results[0]).GUID;
          $scope.sendMessage();
        },{type:"chat"});
      };

      $scope.changeToRecording = function(ev){
        $scope.state.message = "";
        $scope.state.isRecording = true;
        $scope.startCapture(false,ev);
        $scope.stopCaptureEvent = function(){
          if($scope.audioURL.indexOf("blob:") == -1 &&
             $scope.audioURL.indexOf("://learningview.org/") > 0){
            $scope.state.message = $scope.audioURL;
            $scope.sendMessage();
          }else
            self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL, $scope.audioFilename,
              self.getMediaID(), 'record',null,function(filename){
              $scope.state.message = filename;
              $scope.sendMessage();
            });
        };
        $scope.cancelCaptureEvent = function(){
          $scope.state.message = "";
          $scope.state.isRecording = false;
        };
      }

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addJournalRecorderScope = function($scope){

    };    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openResultButtonWindow = function(t,student,ev,scope){
      self.currentTask = t;
      self.currentTaskStudent = student;
      self.currentTaskAction = null; // reset

      if(self.currentTaskResultDialog){
        self.closeDialog(self.currentTaskResultDialog);
        self.currentTaskResultDialog = null;
      }
      if(self.currentTaskDialog){
        self.closeDialog(self.currentTaskDialog);
        self.currentTaskDialog = null;
      }
      self.showDialog({
        templateUrl: "openResultButtonWindow.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving:function(){
          self.currentTaskResultDialog = null;
          // only remove this data if we dont use it anymore
          self.currentTaskStudent = null;
          self.currentTask = null;
        },
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          self.currentTask = t;
          $scope.self = self;
          $scope.isOpenResultButtonWindow = true;
          self.feedbackTyped = false;

          setTimeout(function(){
            self.currentTaskResultDialog = $scope.dialogElement;
          },100);

          $scope.t = t;
          $scope.student = student;
          // try to find the student in current class as there he might have a .openTasks list
          if(self.currentClass && student)
            for(var i = 0; i < self.currentClass.students.length; i++){
              if(self.currentClass.students[i].ID == student.ID){
                $scope.student = self.currentClass.students[i];
                break;
              }
            }

          $scope.userStatus = scope.userStatus ? scope.userStatus : self.getUserTaskStatus(t,student);

          $scope.fromCalendar = scope.fromCalendar;
          $scope.fromClassCalendar = scope.fromClassCalendar;
          $scope.fromFolder = scope.fromFolder;
          $scope.fromClassFolder = scope.fromClassFolder;
          $scope.fromChat = scope.fromChat;
          $scope.fromResults = scope.fromResults;
          $scope.fromJournal = scope.fromJournal;
          $scope.fromOpenTasks = scope.fromOpenTasks;
          $scope.isFromCorrection = scope.isFromCorrection;

          $scope.openTaskInParentJournal = function(task,ev){
            if(!scope.fromJournal || !scope) return;
            var topic = self.getTopicFromTask(task);
            var goal = null;
            for(var i=0; i < topic.goals.length; i++){
              if(topic.goals[i].ID == task.LearningGoal) goal = topic.goals[i];
            }
            $scope.cancel();
            scope.ok(); // close previous panel to reopen new
            self.showUserJournal({student: $scope.student, topic:topic, goal:goal, task:task}, ev);
          };

          $scope.nextStudent = function() {
            var next = $scope.getNextStudent();
            if(next){
              var s2 = next;
              $scope.userStatus = self.getUserTaskStatus(t,s2);
              $scope.student = s2;
              self.currentTaskStudent = s2;
            }
          };
          $scope.lastStudent = function() {
            var next = $scope.getLastStudent();
            if(next){
              var s2 = next;
              $scope.userStatus = self.getUserTaskStatus(t,s2);
              $scope.student = s2;
              self.currentTaskStudent = s2;
            }
          };

          $scope.keyPressed = function(e){
            if(self.user.Teacher == 0) return;
            if(e.keyCode == 37) $scope.lastStudent();
            if(e.keyCode == 39) $scope.nextStudent();
          };          

          $scope.getNextStudent = function() {
            var next = null;
            if(scope.group){
              for(var i=0; i < scope.group.Feedbacks.length; i++){
                if(scope.group.Feedbacks[i].student.ID == $scope.student.ID && i < scope.group.Feedbacks.length-1){
                  next = scope.group.Feedbacks[i+1].student;
                  break;
                }
              }
            }else{
              next = self.findRelativeStudentInCurrentClass($scope.student,+1);
            }
            return next;
          };
          $scope.getLastStudent = function() {
            var next = null;
            if(scope.group){
              for(var i=0; i < scope.group.Feedbacks.length; i++){
                if(scope.group.Feedbacks[i].student.ID == $scope.student.ID && i > 0){
                  next = scope.group.Feedbacks[i-1].student;
                  break;
                }
              }
            }else{
              next = self.findRelativeStudentInCurrentClass($scope.student,-1);
            }
            return next;
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.isSameContentHTML = function(a,b){
      // remove style tags as the can be transformed in order
      var strippedA = a.replace(/style="[^"]*"/g,'');
      var strippedB = b.replace(/style="[^"]*"/g,'');
      if(strippedA == strippedB){
        var psA = [];
        a.replace(/style="([^"]*)"/g,function(m,p1){
          psA.push(p1);
        });
        var psB = [];
        b.replace(/style="([^"]*)"/g,function(m,p1){
          psB.push(p1);
        });
        if(psA.length != psB.length) return false;
        for(var i=0; i < psA.length; i++){
          if(psA[i].length != psB[i].length) return false;
          var rearangedA = psA[i].split(/\s+/).sort().join(' ');
          var rearangedB = psB[i].split(/\s+/).sort().join(' ');
          if(rearangedA != rearangedB) return false;
        }
        return true; 
      }else return false;
    };

    self.currentTextEditor = null;

    self.showTextEditor = function (caption, text, task, student, showCollababoration, preventChangeCollaboration, collaborateDocID, callback, classCollaboration, readonly, annotateonly, ev){
      if(!text) text = "";
      text = text.replace(/#\.°\.#/,"");
      self.currentTextEditor = null;

      self.showDialog({
        state:"modal",
        templateUrl: "textEditor.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        onRemoving:function(){
          if(self.currentTextEditor && self.currentTextEditor.onClose){
            // it is still open, request close now
            self.currentTextEditor.onClose();
          }
          self.currentTextEditor = null;
          self.track('TE_closed',task);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.showCollababoration = showCollababoration; // show invite button
          $scope.preventChangeCollaboration = preventChangeCollaboration; // allow to invite somebody now
          $scope.classCollaboration = classCollaboration;
          $scope.student = student ? student : self.user;
          $scope.taskStatus = null;
          $scope.noSaveIcon = !!collaborateDocID; // a doc id from a collaboration button, from invite


          self.addTextRecorderScope($scope); // adds handlers 
          self.currentTextEditor = $scope.textedit; // from recorder scope

          $scope.textedit.onClose = function(){
            if($scope.postMessage) window.removeEventListener("message", $scope.postMessage);
            if($scope.classCollaborationWatch) $scope.classCollaborationWatch(); // remove watch
 
            if(($scope.textedit.current.Text != '' || ($scope.textedit.current.Text == '' && $scope.textedit.current.Old && $scope.textedit.current.Old != '')) && 
                !self.isSameContentHTML($scope.textedit.current.Text,$scope.textedit.current.Old) ){
              if(callback) callback('<doc id="'+$scope.textedit.docID+'"></doc>'+$scope.textedit.current.Text);
            }else{
              if($scope.taskStatus && $scope.taskStatus.Answer == '<doc id="'+$scope.textedit.docID+'"></doc>#.°.#'){
                // unchanged, delete it now
                var action = {"action":"saveUserTaskStatus", "ID":task.ID,
                              "status":'',
                              "answer":'', // reset #.°.#,
                              "classid":self.currentClass.ID};
                //if(self.currentTaskPartners) action.partners = self.currentTaskPartners;
                self.apiPost("ajax",action).then(function(){
                  if($scope.taskStatus) {
                    $scope.taskStatus.Answer = action.answer;
                    $scope.taskStatus.Status = action.status;
                  }
                });
              }
              if(callback) callback(null);
            }

            // mark seen last changes
            if(self.currentClass && $scope.classCollaboration){
              self.setLastOpenTime("classdoc",self.currentClass.ID+'-'+$scope.classCollaboration.ID);
              $timeout(function(){
                self.keepAliveCallback();
              },500);
            }
          };

          window.addEventListener("message", $scope.postMessage, false);

          $scope.textedit.caption = caption; // btn label for invites
          $scope.textedit.editable = readonly ? false : true; 
          $scope.textedit.annotateonly = annotateonly;
          $scope.textedit.task = task;        

          if(task) {
            $scope.t = task;
            $scope.taskStatus = self.getUserTaskStatus(task,$scope.student);
          }

          $scope.textedit.docID = "doc-"+($scope.student ? $scope.student.ID : self.user.ID) + "-"+($scope.textedit.task ? $scope.textedit.task.ID : 0)+'-'+new Date().getTime();
          // <doc id=""></doc> 
          $scope.textedit.foundIDFromText = false;
          if(text && text != ""){
            var regex = /<doc id="([^"]+)"><\/doc>/;
            var found = text.match(regex);
            if(found && found.length == 2){
              $scope.textedit.docID = found[1];
              text = text.replace(regex,""); // remove it      
              $scope.textedit.foundIDFromText = true;    
            }
          }
          if(collaborateDocID) 
            $scope.textedit.docID = collaborateDocID; // collaborateDocID overrules docID from content

          // current values
          $scope.textedit.current.Text = text;
          $scope.textedit.current.Old = text;

          $scope.textedit.title = (caption ? caption : "Dokument") + ($scope.classCollaboration ? " - "+self.currentClass.Name : '');

          $scope.taskDescriptionWidth = self.getTaskDescriptionWidth(task,'(max-width: 1400px)',self.sidePanelRight);


          $scope.editClassDocument = function(ev){
            self.editClassDocument($scope.classCollaboration,ev);
          };

          $scope.startEditing = function(invited){
            $scope.refreshTextEditorUrl(); // load editor now
            if(self.currentClass && $scope.classCollaboration){
              $timeout(function(){
                self.setLastOpenTime("classdoc",self.currentClass.ID+'-'+$scope.classCollaboration.ID);
              },500);
            }

            if(self.currentClass && !invited && !collaborateDocID && !$scope.textedit.foundIDFromText && task && task.Type != 'collection' && $scope.student.ID == self.user.ID){
              // save docID now, so we do not loose it, even if the task is not saved at all
              var action = {"action":"saveUserTaskStatus", "ID":task.ID,
                            "status":'w',
                            "answer":'<doc id="'+$scope.textedit.docID+'"></doc>#.°.#', //#.°.# so it is no empty doc,
                            "classid":self.currentClass.ID};
              //if(self.currentTaskPartners) action.partners = self.currentTaskPartners;
              self.apiPost("ajax",action).then(function(){
                if($scope.taskStatus) {
                  $scope.taskStatus.Answer = action.answer;
                  $scope.taskStatus.Status = action.status;
                }
              });

            }

            // students will auto-invite selected task Partners
            // when teacher opens the doc, we wont invite the students
            if(self.currentClass && !invited && !$scope.classCollaboration && self.currentTaskPartners && self.user.Teacher != 1){
              var colleagues = self.currentTaskPartners.split(",").map(Number);
              for(var i=0; i < colleagues.length; i++){
                $scope.inviteUser(colleagues[i]);
              }
            }

            // watch changes to the classCollaboration, like the document becomes read-only by teacher
            $scope.classCollaborationWatch = $scope.$watch(function(){
              return $scope.classCollaboration ? 
              ($scope.classCollaboration.deleted ? '1':'0')+
              ($scope.classCollaboration.DataJSON && 
               $scope.classCollaboration.DataJSON.Editable ? '1':'0') : null;
            },function(){ 
                if($scope.classCollaboration && $scope.classCollaboration.deleted){
                  $scope.classCollaborationWatch(); // remove watch
                  $scope.classCollaborationWatch = null;
                  $timeout(function(){$scope.cancel();},0);
                } 
                if($scope.classCollaboration && $scope.classCollaboration.DataJSON){
                  var n = $scope.classCollaboration.DataJSON.Editable || 
                          (self.user.Teacher == 1 && $scope.classCollaboration.Code && 
                           $scope.classCollaboration.Code != '');
                  if($scope.textedit.editable != n){
                    $scope.textedit.editable = n;
                    $scope.refreshTextEditorUrl();
                  }
                }
            });
          }

          $scope.startEditing(); // load editor now
          /*
          if(collaborateDocID || $scope.textedit.foundIDFromText || !task){
            $scope.startEditing(); // load editor now
          }else{
            // check for open invites first
            self.keepAliveCallback().then(function(){
              var partners = self.currentTaskPartners ? self.currentTaskPartners.split(",").map(Number) : [];
              for(var i=0; i < self.collaborations.length; i++){
                if(self.collaborations[i].DataJSON && self.collaborations[i].DataJSON.task &&
                   self.collaborations[i].DataJSON.task == $scope.textedit.task.ID &&
                   partners.indexOf(self.collaborations[i].Owner) != -1){
                  // open the document now
                  $scope.textedit.docID = self.collaborations[i].DataJSON.id;
                  $scope.startEditing(true); // load editor now
                  return;
                }
              }
              // not found, use new document now
              $scope.startEditing(); // load editor now
            });
          }
          */

          $timeout(function(){
            self.currentTextEditor.dialogElement = $scope.dialogElement;
          },1)

          $scope.cancel = function() {                   
            // ask the editor for closing now
            $scope.requestClose(function(){
              $scope.textedit.onClose = null; // alread closed
              self.closeDialog($scope.dialogElement);
            });
          };
        }
      });

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.trimHTML = function(s){
      s = s.replace(/&nbsp;/g," ");
      // at the end
      var lastS = "";
      while(lastS != s){
        lastS = s;
        s = s.replace(/(<p>[ ]*(<br>)*[ ]*<\/p>)+$/,"");
        s = s.replace(/<span[^>]*>([ ]*)<\/span>/g,"$1");
        s = s.replace(/[ ]*(<br>)+[ ]*$/,"");
        s = s.replace(/[ ]+$/,"");
        s = s.replace(/<p>[ ]*<\/p>$/,"");
      }
      var lastS = "";
      while(lastS != s){
        lastS = s;
        s = s.replace(/^(<p>[ ]*(<br>)*[ ]*<\/p>)+/,"");
        s = s.replace(/<span[^>]*>([ ]*)<\/span>/g,"$1");
        s = s.replace(/^[ ]*(<br>)+[ ]*/,"");
        s = s.replace(/^[ ]+/,"");
        s = s.replace(/^<p>[ ]*<\/p>/,"");
      }
      return $.trim(s);
    };

    self.isEmptyHTMLText = function(s){
      if(s == "") return true;
      var regex = /<doc id="([^"]+)"><\/doc>/;
      s = s.replace(regex,"");
      if(s == "") return true;
      if(s == "<br>") return true;
      if(s == "<p></p>") return true;
      if(s == "<p><br></p>") return true;
      if(self.trimHTML(s) == "") return true;
      return false;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openStudentClassInfo = function(c,ev){
      self.showDialog({
        templateUrl: "studentClassInfo.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.it = c;
          $scope.self = self;

          $scope.removeFromClass = function(c){
            self.confirm($filter('trans')('REMOVEMEFROMCLASS',c.Name),$filter('trans')('DELETE'),ev).then(function(){
              self.apiPost("ajax",{"action":"removeMeFromClass", "classid":c.ID})
                .then(function(data) {
                  // change active class
                  for(var i=0; i < self.classList.length; i++){
                    if(self.classList[i].ID == c.ID){
                      self.classList.splice(i,1);
                      break;
                    }
                  }
                  if(self.classList.length > 0){
                    self.openClass(self.classList[0],ev);
                  }
                  self.keepAliveCallback();
                  self.closeDialog($scope.dialogElement);
                });
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTaskStudentRatingDialog = function(t,ev){
      var deferred = $q.defer();
      if(self.isClassSet('useTaskRatings')){
        self.showDialog({
          templateUrl: "studentTaskRatingDialog.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.setRating = function(value) {
              self.closeDialog($scope.dialogElement);
              // save rating now
              self.apiPost("ajax",{"action":"saveUserTaskRating", "ID":t.ID, "value":value, "classid":self.currentClass.ID});
              var status = self.getUserTaskStatus(t,self.user,true);
              status.Rating = value;
              deferred.resolve();
            };
          }
        });

      }else 
        $timeout(function(){deferred.resolve();},1);
      return deferred.promise;      
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getUserTaskStatusColleagues = function(task,user){
      var s = self.getUserTaskStatus(task,user,true);
      if(!s.ColleaguesIDs || s.ColleaguesIDs == ''){
        var partners = self.getPredefinedTaskUserPartners(task,user);
        if(partners) return partners.join(",");            
      }
      return s.ColleaguesIDs ? s.ColleaguesIDs : '';
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTaskButtonWindow = function(t,ev,scope){
      var deferred = $q.defer();
      if(t.isNew) delete t.isNew;

      self.currentTask = t;
      self.currentTaskAction = null; // reset

      if(self.currentTaskResultDialog){
        self.closeDialog(self.currentTaskResultDialog);
        self.currentTaskResultDialog = null;
      }
      if(self.currentTaskDialog){
        self.closeDialog(self.currentTaskDialog);
        self.currentTaskDialog = null;
        if(self.lastOpenTask && self.lastOpenTask.ID == t.ID){
          self.lastOpenTask = null;
        }
      }

      self.track('taskopened',t);
      self.showDialog({
        state:"modal",
        templateUrl: "openTaskButtonWindow.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving:function(){
          self.currentTaskDialog = null;
          self.currentTask = null;
          deferred.resolve();
          self.track('taskclosed',t);
          $timeout(function(){ self.lastOpenTask = null; },100);          
        },
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          self.currentTask = t;
          $scope.self = self;
          $scope.isStudent = self.user.Teacher == "0";
          if(self.lastOpenTask)
            $scope.backToTask = self.lastOpenTask;
          self.lastOpenTask = t; // current task
          $scope.goToLastTask = function(){
            $scope.cancel(null,function(){
              // closed now, open last task
              $timeout(function(){ 
                self.findAndShowTask($scope.backToTask,false);
                self.openTaskButtonWindow($scope.backToTask,ev,scope); 
              },200);
              
            });
          };
          $scope.taskStatus = scope.taskStatus ? scope.taskStatus : self.getUserTaskStatus(t,self.user,true);

          $scope.fromCalendar = scope.fromCalendar;
          $scope.fromClassCalendar = scope.fromClassCalendar;
          $scope.fromFolder = scope.fromFolder;
          $scope.fromClassFolder = scope.fromClassFolder;
          $scope.fromChat = scope.fromChat;
          $scope.fromResults = scope.fromResults;
          $scope.fromJournal = scope.fromJournal;
          $scope.fromOpenTasks = scope.fromOpenTasks;
          $scope.isFromCorrection = scope.isFromCorrection;
          
          $scope.mt = scope.mt;
          $scope.it = scope.it;
          $scope.t = t;
          if($scope.t){
            $scope.topic = self.getTopicFromTask(t);
            if($scope.topic)
              $scope.mt = self.getMainTopicByID($scope.topic.MainTopic);
          }

          $scope.currentTaskAnswer = $scope.taskStatus.Answer ? $scope.taskStatus.Answer : (t.Answer ? t.Answer : "");
          $scope.currentTaskAnswerChanged = false;
          if(t.Type == "collection") {
            $scope.currentTaskAnswer = "";
            self.addCollectionRecorderScope($scope);
          }
          if(t.ResultType == "file"){
            // check for zip file and fetch list of files inside zip if .list file exists
            if(!$scope.zipItems) $scope.zipItems = [];
            // if no .list, just add the current answer
            if($scope.currentTaskAnswer && $scope.currentTaskAnswer != '')
              $scope.zipItems.push($scope.currentTaskAnswer);
          }


          setTimeout(function(){
            self.currentTaskDialog = $scope.dialogElement;

            $('.md-dialog-container').last().on("click",function(event){
              if(self.currentTaskAction) return;
              if(event.target == this){
                // clicked outside on background
                // close if possible now
                self.closeDialog($scope.dialogElement);
              }
            });
          },100);


          self.checkHasTeacherNotes("task",t);

          $scope.askPartners = function(t,ev,callback){
            var now = self.currentTaskPartners;
            self.askTaskUserPartners(t,ev,self.currentTaskPartners).then(function(partners){
              self.currentTaskPartners = partners.join(",");
              self.currentTaskPartnerStudents = [];
              for(var i=0; i < partners.length; i++){
                var s = self.users[partners[i]];
                if(s) self.currentTaskPartnerStudents.push(s);
              }
              if(self.currentTaskPartners != now) $scope.currentTaskAnswerChanged = true;
              if(callback) callback();
            });
          };

          $scope.editAnswer = function(ev,showSolutionsNow){
            var typeText = t.ResultType.charAt(0).toUpperCase() + t.ResultType.slice(1);
            if(!t.ResultType || t.ResultType == "" || t.ResultType == "none"){
              self.track('openEditTaskStatus',t);
            }else{
              self.track('openTaskEdit'+typeText+'Input',t);              
            }

            if($scope.taskStatus && $scope.taskStatus.FeedbackStatus == 'c'){
              // already closed, only show a non-editable version now
              if(t.ResultType == "annotation" || t.ResultType == "drawing"){
                self.showImageEditor(t.DataJSON.annotationImage,t.Name,true,t,self.user,ev);
              }else
              if(t.ResultType == "audionotes" || t.ResultType == "videonotes"){
                var currentNotes = $scope.currentTaskAnswer && $scope.currentTaskAnswer != '' ? JSON.parse($scope.currentTaskAnswer) : []; 
                self.showMediaNotesEditor(t.ResultType == "audionotes" ? t.DataJSON.audio : t.DataJSON.video,t,currentNotes,false,true,t.DataJSON.onlyEdit,false,ev);
              }else
              if(t.ResultType == "textnotes"){
                self.showTextEditor(t.Name,$scope.currentTaskAnswer,t,null,false,false, null, function(){}, null, true, false, ev);
              }else
                self.showTaskResultMedia(t.ResultType,$scope.taskStatus,null,self.user,false,ev);
              return;
            }

            var beforeEditNow = function(){
              var ask = [];
              if(self.collaborations)
                for(var i=0; i < self.collaborations.length; i++){
                  if(self.collaborations[i].DataJSON && self.collaborations[i].DataJSON.task &&
                     self.collaborations[i].DataJSON.task == t.ID &&
                     self.collaborations[i].deleted != true){
                    var u = self.users[self.collaborations[i].Owner];
                    if(u){
                      ask.push({u:u,c:self.collaborations[i]});
                    }
                  }
                }
              if(ask.length > 0){
                askForCollaborations(ask);
                return;
              }
              editNow();
            };

            var askForCollaborations = function(invites){
              var ask = invites.pop();
              self.confirm($filter('trans')('ASKACCEPTCOLLABORATIONINVITEFROM',ask.u.Name),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                // open invite now
                ask.c.open(ev);
              },function(){
                if(invites.length > 0){
                  askForCollaborations(invites);
                }else
                  editNow();
              });
            };

            var editNow = function(){
              self.currentTaskPartners = self.getUserTaskStatusColleagues(t,self.user);
              self.currentTaskPartnerStudents = [];

              if(self.currentTaskPartners != ""){
                var p = self.currentTaskPartners.split(",").map(Number);
                for(var i=0; i < p.length; i++){
                  var s = self.users[p[i]];
                  if(s) self.currentTaskPartnerStudents.push(s);
                }
              }

              $scope.currentTaskAnswer = $scope.taskStatus.Answer ? $scope.taskStatus.Answer : (t.Answer ? t.Answer : "");
              $scope.currentTaskAnswerChanged = false;

              var displayEditAnswer = function(){
                if(t.ResultType == "annotation" || t.ResultType == "drawing"){
                  // SHOW EDITOR NOW
                  self.showImageEditor(t.DataJSON.annotationImage,t.Name,false,t,self.user,ev).then(function(data){
                    var isEmpty = (!data.lastJson || data.lastJson == "{}") && data.json.match(/\{"version":"[^"]+","objects":\[\]\}/);
                    self.track('closeTaskEdit'+typeText+'Input',t);
                    
                    if(!isEmpty && data.json && data.lastJson != data.json){
                      // ask if teacher feedback was given already
                      if(data.feedback && data.feedback != '' && data.feedback != '{}' && t.CheckType == "teacher"){
                        self.confirm($filter('trans')('HANDINANNOTATIONAGAIN'),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                          $scope.currentTaskAnswerChanged = true;
                          $scope.currentTaskAnswer = t.DataJSON.annotationImage;
                          $scope.saveAnswer();
                        });

                      }else{
                        $scope.currentTaskAnswerChanged = true;
                        $scope.currentTaskAnswer = t.DataJSON.annotationImage;
                        $scope.saveAnswer();
                      }
                    }
                  });
                  return;
                }

                if(t.ResultType == "audionotes" || t.ResultType == "videonotes"){
                  var currentNotes = $scope.currentTaskAnswer && $scope.currentTaskAnswer != '' ? JSON.parse($scope.currentTaskAnswer) : []; 
                  self.showMediaNotesEditor(t.ResultType == "audionotes" ? t.DataJSON.audio : t.DataJSON.video,t,currentNotes,false,false,t.DataJSON.onlyEdit,false,ev).then(function(result){
                    self.track('closeTaskEdit'+typeText+'Input',t);
                    if(result.notes.length == 0 && (!$scope.currentTaskAnswer || $scope.currentTaskAnswer == ''))
                      $scope.currentTaskAnswer = '[]';
                    if($scope.currentTaskAnswer != JSON.stringify(result.notes)){
                      $scope.currentTaskAnswer = JSON.stringify(result.notes);
                      $scope.currentTaskAnswerChanged = true;
                      $scope.saveAnswer();
                    }
                  });
                  return;
                }

                if(t.ResultType == "textnotes"){
                  var regex = /<doc id="([^"]+)"><\/doc>/;
                  var oldText = $scope.currentTaskAnswer;
                  var removedDoc = false;
      
                  if((!oldText || self.isEmptyHTMLText(oldText)) &&
                     t.DataJSON.text && t.DataJSON.text != ""){
                    // remove an existing doc id  
                    oldText = t.DataJSON.text.replace(regex,"");
                    removedDoc = true;
                  }

                  self.showTextEditor(t.Name,oldText,t,null,(t.Social == 'pair' || t.Social == 'group'), (t.Groups && t.Groups != ''), null,function(text){
                    self.track('closeTaskEdit'+typeText+'Input',t);
                    if(text !== null){
                      var cleaned = removedDoc ? text.replace(regex,"") : text;
                      $scope.currentTaskAnswer = text;
                      $scope.currentTaskAnswerChanged = oldText != cleaned;
                      $scope.saveAnswer(ev);
                    }
                  },null,false,true,ev);

                  return;
                }

                if(t.ResultType == "annotation"){
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != "")
                     self.addToRecentFiles({'isUpload': false, 'type': 'image', 'url': $scope.currentTaskAnswer});
                }
                if(t.ResultType == "drawing"){
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != "")
                     self.addToRecentFiles({'isUpload': false, 'type': 'image', 'url': $scope.currentTaskAnswer});
                }
                if(t.ResultType == "image"){
                  self.addImageRecorderScope($scope);
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != "")
                     self.addToRecentFiles({'isUpload': false, 'type': t.ResultType, 'url': $scope.currentTaskAnswer});
                }
                if(t.ResultType == "audio"){
                  self.addAudioRecorderScope($scope);
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != ""){
                    var audio = new Audio();
                    audio.src = $scope.currentTaskAnswer;
                    $(audio).on("loadedmetadata", function(){
                      var audioDuration = Math.ceil(audio.duration.toString());
                      self.addToRecentFiles({"isUpload": false, "type": "audio", "url": audio.src, "duration": audioDuration});
                    });
                  }
                }
                if(t.ResultType == "video"){
                  self.addVideoRecorderScope($scope);
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != "")
                     self.addToRecentFiles({'isUpload': false, 'type': t.ResultType, 'url': $scope.currentTaskAnswer});
                }
                if(t.ResultType == "file"){
                  self.addFileRecorderScope($scope);
                  if(self.user.Teacher == 0 && $scope.currentTaskAnswer && $scope.currentTaskAnswer != "")
                     self.addToRecentFiles({'isUpload': false, 'type': t.ResultType, 'url': $scope.currentTaskAnswer, 'name': $scope.fileName});
                }
                if(t.ResultType == "link"){
                  /* Weblink */
                  var oldLink = $scope.currentTaskAnswer;
                  self.takeUserMedia('link',$scope.currentTaskAnswer,function(results){
                    if(results !== null && results[0].URL !== null){
                      $scope.currentTaskAnswer = results[0].URL;
                      $scope.currentTaskAnswerChanged = oldLink != results[0].URL;
                      if($scope.currentTaskAnswerChanged) $scope.saveAnswer(ev, true); // force, no ask
                    }
                  },{dialogMode: 2});
                  return;
                }

                if(t.ResultType == "text"){
                  var regex = /<doc id="([^"]+)"><\/doc>/;
                  var oldText = $scope.currentTaskAnswer;
                  var removedDoc = false;
                  if((!oldText || self.isEmptyHTMLText(oldText)) &&
                     t.DataJSON.textTemplate && t.DataJSON.textTemplate != ""){
                    // remove an existing doc id  
                    oldText = t.DataJSON.textTemplate.replace(regex,"");
                    removedDoc = true;
                  }

                  self.showTextEditor(t.Name,oldText,t,null,(t.Social == 'pair' || t.Social == 'group'),(t.Groups && t.Groups != ''), null,function(text){
                    self.track('closeTaskEdit'+typeText+'Input',t);
                    if(text !== null){
                      var cleaned = removedDoc ? text.replace(regex,"") : text;
                      $scope.currentTaskAnswer = text;
                      $scope.currentTaskAnswerChanged = oldText != cleaned;
                      $scope.saveAnswer(ev);
                    }
                  },null,false,false,ev);
                  return;
                }

                if(!t.ResultType || t.ResultType == "" || t.ResultType == "none"){
                  $scope.currentTaskAnswerChanged = true;
                  $scope.saveAnswer(ev);
                }else{
                  self.currentTaskAction = t.ResultType;
                }
              };

              if(self.currentTaskPartners == "" && (t.Social == 'pair' || t.Social == 'group')){
                $scope.askPartners(t,ev,displayEditAnswer);
              } else
                displayEditAnswer();

            };

            self.currentTaskPartners = self.getUserTaskStatusColleagues(t,self.user);
            // self.currentTaskPartners == "" &&
            if((t.Social == 'pair' || t.Social == 'group')){
              // check for changes now, maybe another student just started a group work
              self.keepAliveCallback().then(function(){
                beforeEditNow();
              });
            }else 
              beforeEditNow();
          };

          $scope.resetAnswer = function(ev){

            // clear / reset status

            var d = $mdDialog.confirm()
              .title($filter('trans')('AREYOUSURE'))
              .content('Deine Eingaben zu dieser Aufgabe werden gelöscht.')
              .targetEvent(ev)
              .cancel('abbrechen')
              .ok('zurücksetzen');
            d._options.skipHide = true; // keep other dialog open

            // reset for other partners too?
            /*
            var cn = $scope.taskStatus.ColleaguesIDs && $scope.taskStatus.ColleaguesIDs != "" ?
                     $scope.taskStatus.ColleaguesIDs.split(',') : [];

            var names = [];
            for(var i=0; i < cn.length; i++)
              for(var z=0; z < self.currentClass.students.length; z++)
                if(self.currentClass.students[z].ID == cn[i]) names.push(self.currentClass.students[z].Name);

            var d2 = $mdDialog.confirm()
              .title("Für ganze Gruppe zurücksetzen?")
              .content('Diese Aufgabe wurde mit '+names.join(", ")+' erstellt. Soll die Aufgabe für alle zurückgesetzt werden oder nur für dich?')
              .targetEvent(ev)
              .cancel('nur für mich')
              .ok('ganze Gruppe');
            d2._options.skipHide = true; // keep other dialog open
            */

            function resetNow(kind){
              // without feedback
              var action = {"action":"saveUserTaskStatus", "ID":t.ID, "status":"","answer":"", "classid":self.currentClass.ID};
              if(kind == "group" || kind == "self"){
                action.partners = self.getUserTaskStatusColleagues(t,self.user);
                action.type = kind;
              }

              self.apiPost("ajax",action)
               .then(function(data) {
                 $scope.taskStatus.Answer = "";
                 $scope.taskStatus.Status = "";
                 $scope.taskStatus.ColleaguesIDs = "";
                 self.hasShownTaskSolution[t.ID] = false;
                 self.keepAliveCallback();
                 self.track('resetTask',t);
               });
            }

            function askGroup(){
              if(t.Social == 'pair' || t.Social == 'group')
                resetNow('group'); else resetNow();
            }

            if($scope.taskStatus.Answer && $scope.taskStatus.Answer != "")
              $mdDialog.show(d).then(askGroup); else askGroup();

            self.currentTaskPartners = "";
            self.currentTaskAction = null;
            $scope.currentTaskAnswer = "";
            $scope.currentTaskAnswerChanged = false;
            if($scope.zipItems) $scope.zipItems = [];
          };

          $scope.saveAnswer = function(ev,force){
            if(t.Type == "collection") {
              $scope.currentTaskAnswer = $scope.taskStatus.Answer;
            }
            if(force) $scope.answerNotChanged = false;
            var overrideCheck = self.getUserTaskChecksDeep(t,self.user,self.currentClass);

            var saveNow = function(){
              if($scope.answerNotChanged) return;

              var confirmStatusNow = function(){
                if(!t.ResultType || t.ResultType == "" || t.ResultType == "none" || t.CheckType == "none"){
                  checkSolutionNow("OK");
                  return;
                }
                if($scope.currentTaskAnswer == ""){
                  checkSolutionNow("");
                  return;
                }
                if(force){
                  checkSolutionNow("OK");
                  return;
                }

                if(!(overrideCheck == 2 || overrideCheck == 3) && (t.CheckType == 'self' || overrideCheck == 1)){
                  // self check
                  self.confirm('<div style="text-align:center;font-weight:bold">'+$filter('trans')('ASKIFDONE')+'</div>',
                               '<i class="fa fa-fw fa-check"></i> '+$filter('trans')('DONE'),ev,
                               '<i class="fa fa-fw fa-pause" style="margin-top:-2px;color:#ccc;font-size:120%"></i> '+$filter('trans')('LATER'), 
                               true).then(function(){
                    checkSolutionNow("OK");
                  },function(){
                    checkSolutionNow("w");
                  });
                }else{
                  self.confirm('<div style="text-align:center;font-weight:bold">'+$filter('trans')('ASKTOSUBMIT')+'</div>',
                               '<i class="fa fa-fw fa-check"></i> '+$filter('trans')('SUBMIT'),ev,
                               '<i class="fa fa-fw fa-pause" style="margin-top:-2px;color:#ccc;font-size:120%"></i> '+$filter('trans')('NOTDONEYET'), 
                               true).then(function(){
                    checkSolutionNow("OK");
                  },function(){
                    checkSolutionNow("w");
                  });
                }
              };

              var checkSolutionNow = function(status){
                var hasSolution = false;
                if(t.DataJSON && t.DataJSON.hints)
                  for(var h = 0; h < t.DataJSON.hints.length; h++){
                    if(t.DataJSON.hints[h].visible == "2") {
                      hasSolution = true;
                      break;
                    }
                  }

                if(overrideCheck == 3) hasSolution = false;

                if(status == "OK" && hasSolution){
                  self.showUserTaskSolution(t).then(function(){
                    // saveNow
                    saveStatusNow(status);
                    self.hasShownTaskSolution[t.ID] = true;  
                  },function(){
                    saveStatusNow("w");
                    // open work again, if it is an editor       
                    self.hasShownTaskSolution[t.ID] = true;    
                    if(t.ResultType && t.ResultType != 'none')
                      $scope.editAnswer(ev,true);
                  });
                } else saveStatusNow(status);
              };

              var saveStatusNow = function(status, forceJournal){
                // ask for status now, is done or not?

                // if task is important = -1 now, reset to 0
                if($scope.taskStatus && $scope.taskStatus.Important == "-1") self.setUserTaskImportant(t,"0");

                // if this is a peer check question, student cannot directly set OK
                if(status == "OK" && (t.CheckType == 'peer')) status = "pw";

                if(overrideCheck >= 2){
                  if(status == "OK" && (t.Type != 'test' && t.Type != 'survey')) status = "?";
                }
                // normal case
                if(overrideCheck != 1){
                  // if this is a manual check question, student cannot directly set OK
                  if(status == "OK" && (t.CheckType == 'teacher')) status = "?";

                  // was rejected before so hand in again
                  if(status == "OK" && ($scope.taskStatus.Status == "x" && ($scope.taskStatus.FeedbackStatus && $scope.taskStatus.FeedbackStatus != '' ))) status = "?";

                  // was rejected before and adjusted again before another feedback was given
                  if(status == "OK" && ($scope.taskStatus.FeedbackStatus == "w" || $scope.taskStatus.FeedbackStatus == "wasx") && $scope.taskStatus.Status == "?") status = "?";
                }

                // after uploading files
                self.track('saveTaskStatus',{ID:t.ID, status:status,"answer":$scope.currentTaskAnswer,"partners":self.currentTaskPartners ?
                                         self.currentTaskPartners : '',"classid":self.currentClass.ID});
                var action = {"action":"saveUserTaskStatus", "ID":t.ID,
                              "noerror":1,
                              "status":status,
                              "answer":$scope.currentTaskAnswer,
                              "partners":self.currentTaskPartners ?
                                         self.currentTaskPartners : '',
                              "classid":self.currentClass.ID};
                if(forceJournal) action.forceJournal = 1;

                self.showLoadingIndicator(null,function(done){
                  self.apiPost("ajax",action).then(function(){
                    waitingForSave = false;
                    self.currentTaskAction = null;
                    $scope.taskStatus.Updated = new Date();
                    $scope.taskStatus.Status = status;
                    $scope.taskStatus.Answer = $scope.currentTaskAnswer;
                    $scope.taskStatus.ColleaguesIDs =
                      self.currentTaskPartners ? self.currentTaskPartners : '';

                    $timeout(function(){
                      if(status == "?"){
                        if(!t.ResultType || t.ResultType == "" || t.ResultType == "none"){
                          self.alert($filter('trans')('STATUSCHECKHINT'),ev).then(function(){
                            self.openTaskStudentRatingDialog(t,ev);
                          });
                        }else{
                          self.alertAndDisable("TEACHERCHECK", $filter('trans')('STATUSWAITCHECKHINT'),ev).then(function(){
                            self.openTaskStudentRatingDialog(t,ev);
                          });
                        }
                      }

                      if(status == "pw") {
                        self.openTaskStudentRatingDialog(t,ev).then(function(){
                          self.alert($filter('trans')('STATUSWAITPEERHINT'),ev).then(function(){
                            if(t.Type != "collection")
                              self.openPeerFeedbackList(t,ev);
                          });
                        });
                      }

                      if(status == "OK"){
                        self.openTaskStudentRatingDialog(t,ev);
                      }
                    },200);

                    self.keepAliveCallback();
                    done();
                  },function(){
                    self.confirm("Server Fehler. Erneut versuchen?","Senden",null).then(function(){
                      saveStatusNow(status, forceJournal);                
                    });
                  });
                });

              }; 


              if(t.ResultType == "file"){
                if($scope.multipleAnswers.length == 0){
                  $scope.currentTaskAnswer = ""; // empty
                  confirmStatusNow();
                }else
                if($scope.multipleAnswers.length == 1){
                  $scope.currentTaskAnswer = $scope.multipleAnswers[0].url;
                  confirmStatusNow();
                }else{
                  // more then one item in list
                  var json = [];
                  for(var i=0; i < $scope.multipleAnswers.length; i++){
                    var url = $scope.multipleAnswers[i].url;
                    var filename = url.replace("https://learningview.org/uploads/","");
                    json.push({'file':filename});
                  }
                  var jsonString = JSON.stringify(json);
                  var fileListBlob = new Blob([jsonString], { type: "application/json" });

                  self.uploadFile(fileListBlob, t.Name+".zip", self.getMediaID(),'ziplist',null,function(filename){
                    $scope.currentTaskAnswer = filename;
                    $timeout(function(){ confirmStatusNow(); },500);
                  });                  
                }
              }else
              if(t.ResultType == "audio"){
                // upload audio now
                if(!$scope.audioURL || $scope.audioURL == "") $scope.audioURL = $scope.currentTaskAnswer;
                if($scope.audioURL.indexOf("blob:") == -1 && $scope.audioURL.indexOf("://learningview.org/") > 0){
                  confirmStatusNow();
                }else {
                  self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL, $scope.audioFilename, self.getMediaID(),'record',null,function(filename){
                    $scope.currentTaskAnswer = filename;
                    $timeout(function(){ confirmStatusNow(); },500);
                  });
                }
              }else
              if(t.ResultType == "video"){
                // upload video now
                if(!$scope.videoURL || $scope.videoURL == "") $scope.videoURL = $scope.currentTaskAnswer;
                if($scope.videoURL.indexOf("blob:") == -1 && $scope.videoURL.indexOf("://learningview.org/") > 0){
                  confirmStatusNow();
                }else
                  self.uploadFile($scope.videoURL.indexOf("blob:") == 0 ? $scope.videoBlob : $scope.videoURL,
                    $scope.videoFilename, self.getMediaID(),'video',null,function(filename){
                    $scope.currentTaskAnswer = filename;
                    $timeout(function(){ confirmStatusNow(); },500);
                  });
              }else
                confirmStatusNow();
            }


            saveNow();

            //1010
            for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
              if(self.dropHandler[i].dialog == $scope.dialogElement) {
                self.dropHandler.splice(i, 1);
              }
            }
          };

          /* Task Notes */

          $scope.editTaskNote = function(){
            if($scope.taskStatus.Note && $scope.taskStatus.Note != '' && $scope.taskStatus.Note[0] == '¶'){
              self.alert('<div style="font-size: 120%;">'+$scope.taskStatus.Note.slice(1)+"\n\n<small style='color:#999'>"+$filter('trans')('TASKNOTEADDEDBYTEACHER')+"</small></div>");
              return;
            }

            $scope.taskNote = {ID:t.ID, Icon: "", Note:""}; // make copy here
            $scope.taskNoteType = self.lastEditTaskNoteType;

            self.track('openTaskEditNote',{ID:t.ID,"Note":$scope.taskStatus.Note ? $scope.taskStatus.Note : ''});

            if($scope.taskStatus.Note && $scope.taskStatus.Note != ''){
              $scope.taskNote.Note = $scope.taskStatus.Note.replace('¶','');
              if($scope.taskNote.Note.indexOf('<i class=') === 0){
                var m = $scope.taskStatus.Note.match(/"([^"]*)"/);
                $scope.taskNote.Icon = m[1];
                $scope.taskNote.Note = "";
                $scope.taskNoteType = "icon";
              }else{
                $scope.taskNoteType = "text";
              }
            }
            self.currentTaskAction = 'note';
            $scope.taskNote.getContent = function(){
              var content = "";
              if($scope.taskNoteType == 'text') content = $scope.taskNote.Note ? $scope.taskNote.Note : "";
              if($scope.taskNoteType == 'icon') content = $scope.taskNote.Icon && $scope.taskNote.Icon != "" ? '<i class="'+$scope.taskNote.Icon+'"></i>' : '';
              return content;
            };
          };

          $scope.saveTaskNote = function(){
            var content = $scope.taskNote.getContent();
            self.track('saveTaskNote',{ID:t.ID,"Note":content});
            self.apiPost("ajax",{"action":"updateTaskNote", "student":self.user.ID, "ID":t.ID, "Note":content, "classid":self.currentClass.ID})
             .then(function(data) {
               $scope.taskStatus.Note = content;
               self.lastEditTaskNoteType = $scope.taskNoteType;
               self.keepAliveCallback();
               self.currentTaskAction = null;
             });
          };

          $scope.selectNoteIcon = function(icon){
            $scope.taskNote.Icon = icon == $scope.taskNote.Icon ? '' : icon;
          };

          $scope.askCancelEdit = function(ev){
            if(self.currentTaskAction && $scope.currentTaskAnswerChanged){
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.currentTaskAction = null;
              });
            }else self.currentTaskAction = null;

            //1010
            for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
              if(self.dropHandler[i].dialog == $scope.dialogElement) {
                self.dropHandler.splice(i, 1);
              }
            }
            self.track('cancelEditTaskStatus',t);
          };
          $scope.askCancelJournalEdit = function(ev){
            if(self.currentTaskAction == 'journal' &&
              !self.isEmptyHTMLText($scope.Text.input) != "" ){
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.currentTaskAction = null;
              });
            }else self.currentTaskAction = null;
          };
          $scope.askCancelNoteEdit = function(ev){
            if(self.currentTaskAction == 'note' &&
               $scope.taskNote.getContent() != $scope.taskStatus.Note){
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.currentTaskAction = null;
              });
            }else self.currentTaskAction = null;
            self.track('cancelEditTaskNote',t);
          };

          $scope.cancel = function(ev,callback) {
            if((self.currentTaskAction == 'journal' &&
               !self.isEmptyHTMLText($scope.Text.input)) ||
               (self.currentTaskAction == 'note' && $scope.taskNote.getContent() != $scope.taskStatus.Note) ||
               (self.currentTaskAction && $scope.currentTaskAnswerChanged)){
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.closeDialog($scope.dialogElement);
                if(callback) callback();
              });
            } else {
              self.closeDialog($scope.dialogElement);
              if(callback) callback();
            }
          };
        }
      });

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTaskButtonWindowPreview = function(t,ev){
      // teacher preview button menu when editing a task
      self.showDialog({
        templateUrl: "openTaskButtonWindow.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.isStudent = true;
          $scope.isPreview = true;
          $scope.t = t;
          if($scope.t){
            $scope.topic = self.getTopicFromTask(t);
            if($scope.topic)
              $scope.mt = self.getMainTopicByID($scope.topic.MainTopic);
            $scope.taskStatus = {};
          }
          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getAccessTokenParameterInClass = function(){
      var r = "";
      if(self.currentClass){
        for(var i=0; i < self.currentClass.teachers.length; i++){
          if(self.currentClass.teachers[i].AID)
            r += (r != '' ? ',':'')+self.currentClass.teachers[i].AID;
        }
      }
      if(r == ""){
        if(self.user.Teacher == 1) r = self.user.AID; // teacher self case
      }
      return r;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openOfficeDocumentPreview = function(t,ev){
      var onMessage = null;
      self.showDialog({
        templateUrl: "officewebiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          if(onMessage) window.removeEventListener("message",onMessage);
          self.track('closePopupView',null);
        },        
        controller: function ($scope, $mdDialog) {
          var url = $.trim(t.DataJSON.URL);

          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.DataJSON.name ? t.DataJSON.name : (t.Name ? t.Name : (t.name ? t.name : '')));
          $scope.url = null;
          $scope.html = null;
          $scope.pdfURL = null; 
          var parts = url.split("/");
          parts = parts[parts.length-1].split("?");
          parts = parts[0].split(".");
          $scope.fileType = parts[parts.length-1].toLowerCase();
          if($scope.fileType == "php"){
            // try for last parameter openZIP.php for example
            $scope.fileType = url.split("=").pop().split(".").pop();
          }

          if (!url.match(/^[a-zA-Z]+:\/\//)) url = 'https://' + url;
          if($scope.fileType == "docx" || $scope.fileType == "pptx" || $scope.fileType == "xlsx"){
            // MS Office Preview, but we dont want to send files to MS
            // $scope.url = "http://view.officeapps.live.com/op/view.aspx?wdPrint=0&src=" + encodeURIComponent(url);
            $scope.pdfURL = "https://learningview.org/api/ajax.php?action=toPDF&url=" + encodeURIComponent(url);
            $.getJSON($scope.pdfURL+"&generate=1",function(data){
              if(data && !data.error){
                $timeout(function(){
                  $scope.url = "https://learningview.org/pdfviewer/web/viewer.html?file="+encodeURIComponent($scope.pdfURL);
                },0);
              }
            });            
          }else
          if($scope.fileType == "pdf"){
            $scope.caption = t.DataJSON.text ? t.DataJSON.text : t.DataJSON.name;
            $scope.url = "https://learningview.org/pdfviewer/web/viewer.html?file="+encodeURIComponent(url);
          }else
          if($scope.fileType == "zip"){
            $scope.caption = t.DataJSON.text ? t.DataJSON.text : t.DataJSON.name;
            $scope.url = "https://learningview.org/api/openZIP.php?file="+encodeURIComponent(url);
          }else{
            $scope.url = url;
          }

          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;

          onMessage = function(event){
            // from zip folder
            if(event.data && event.data.indexOf && event.data.indexOf("DOWNLOADFILE|") === 0){
              var data = event.data.substring(("DOWNLOADFILE|").length);
              // '/api/openZIP.php?file=&f=kitten-4794761_1280.webp'
              var parts = data.split("=");
              var file = parts[parts.length-1];
              var parts = file.split("/");
              self.downloadFile(data,parts[parts.length-1]);
              return;
            }
            if(event.data && event.data.indexOf && event.data.indexOf("OPENLINK|") === 0){
              var data = event.data.substring(("OPENLINK|").length);
              self.openWeblink({DataJSON:{URL:data}},null,'auto');
              return;
            }
            if(event.data && event.data.indexOf && event.data.indexOf("OPENHTML|") === 0){
              var data = event.data.substring(("OPENHTML|").length);
              self.openHTMLViewFromURL(data);
              return;
            }
          };

          window.addEventListener("message", onMessage, false);

          $scope.download = function(){
            var parts = url.split("/");
            var last = parts[parts.length-1];
            var parts = last.split("?");
            self.downloadFile(url,parts[0]);
          };
          $scope.print = function(){
            if(typeof cordova != "undefined"){
              var u = $scope.pdfURL ? $scope.pdfURL : url;
              var parts = url.split("/");
              var last = parts[parts.length-1];
              var parts = last.split("?");
              self.downloadFile(u,parts[0]+".pdf",false,'application/pdf',true); // doPrint
            }else{
              var frame = $('#webiframe').get(0);
              if(frame && frame.contentWindow){
                frame.contentWindow.postMessage("PRINT","*");
              }
            }
          };

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.storeInteractiveTaskResultWillChange = function(t,a,force){
      if(a && self.user.Teacher == 0){
        var ts = self.getUserTaskStatus(t,self.user,true);
        var action = {"action":"saveUserTaskStatus", "ID":t.ID,
                      "status":a.status,
                      "answer":a.answer,
                      "partners":a.partners ? a.partners : (self.currentTaskPartners ? self.currentTaskPartners : ""),
                      "classid":self.currentClass.ID};

        if(force) action.forceJournal = 1;
        if(a.duration) action.duration = a.duration;

        var overrideCheck = self.getUserTaskChecksDeep(t,self.user,self.currentClass);
        if(overrideCheck != 1){
          if(action.status == "OK" && (ts.Status == "x" && (ts.FeedbackStatus && ts.FeedbackStatus != '' ))) action.status = "?";

          if(action.status == "OK" && (ts.FeedbackStatus == "w" || ts.FeedbackStatus ==  "wasx") && ts.Status == "?") action.status = "?";
        }
        if(overrideCheck >= 2 && t.Type != 'test' && t.Type != 'survey') action.status = "?";

        if(force || (ts.Status != 'OK')){
          // was not ok already and value is not smaller 
          if(ts.Status != action.status || ts.Answer != action.answer){
            return action;
          }                          
        }
      }  
      return false;  
    };

    self.storeInteractiveTaskResult = function(t,a,force){
      var deferred = $q.defer();
      var action = self.storeInteractiveTaskResultWillChange(t,a,force);
      if(action){
        self.track('saveTaskStatus',{ID:t.ID, status:action.status,"answer":action.answer,
                                     "partners":action.partners ? action.partners : '',
                                     "classid":self.currentClass.ID});
        self.apiPost("ajax",action).then(function(){
          var ts = self.getUserTaskStatus(t,self.user,true);
          ts.Status = action.status;
          ts.Answer = action.answer;
          ts.Updated = new Date();
          self.keepAliveCallback();
          deferred.resolve();
        });        
      }else{
        if(a && self.user.Teacher == 0){
          self.track('saveTaskStatus',{ID:t.ID, status:a.status,"answer":a.answer,
                                       "partners":a.partners ? a.partners : '',
                                       "classid":self.currentClass.ID});
        }
        deferred.resolve();
      }
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openHTMLViewFromURL = function(url){
      try{
        var xhr = new XMLHttpRequest();
        xhr.open('GET', url, true);
        xhr.responseType = "text";
        xhr.onload = function() {
          if (xhr.status >= 200 && xhr.status < 300) {
            var htmlString = xhr.responseText || xhr.response;
            var htmlString = htmlString.replace(/^\uFEFF/, '').trimStart();
            if (!/^<!doctype\s+/i.test(htmlString)) {
              htmlString = '<!DOCTYPE html>\n' + htmlString;
            }              
            self.openHTMLView({ DataJSON: { URL: htmlString, BaseURL: url } });
          }
        };
        // Handle errors
        xhr.onerror = function(){
          self.alert("Fehler beim Laden der HTML-Datei. Status: " + xhr.status);
        };
        xhr.send();
      }catch(e){
        self.alert("Fehler beim Laden der HTML-Datei.");
      } 
    };
    
    self.openHTMLView = function(t,ev){
      var onMessage = null;
      var storeResultOnClose = null;
      var startTime = (new Date()).getTime();

      var url = $.trim(t.DataJSON.URL);

      var openNow = function(){
        self.showDialog({
          state:"one",
          templateUrl: "webiframe.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          onRemoving: function (event, removePromise) {
            if(onMessage) window.removeEventListener("message",onMessage);
            if(self.currentTask)
              self.storeInteractiveTaskResult(self.currentTask,storeResultOnClose);
            self.track('closePopupView',null);
          },
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            var url = $.trim(t.DataJSON.URL);
            $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));
            $scope.url = null;
            $scope.html = null;
            $scope.baseUrl = t.DataJSON.BaseURL ? $.trim(t.DataJSON.BaseURL) : "";
            if(url.length > 0 && url[0] == "<"){
              // html embed code
              $scope.html = url;
              $scope.iframeOnly = false;
              if(url.match(/^\s*<iframe\b[^>]*>(?:<\/iframe>)?\s*$/i)){
                $scope.iframeOnly = true;
                $scope.html = $sce.trustAsHtml(url);
              }
            }else{
              if (!url.match(/^[a-zA-Z]+:\/\//)) url = 'http://' + url;
              $scope.url = (url);
            }
            $scope.self = self;
            $scope.smallScreen = self.isSmallScreen;

            onMessage = function(event){
              // xAPI score
              if(event.data && event.data.result && event.data.result.score){
                var score = 100; // 100%
                if(event.data.result.score.scaled){
                  score = Math.round(event.data.result.score.scaled * 100);
                }else{
                  if(event.data.result.score.raw && event.data.result.score.max){
                    score = Math.round(event.data.result.score.raw / event.data.result.score.max * 100);
                  } 
                }
                if(self.user && self.user.Teacher == '0'){
                  var status = (score == 100) ? "OK" : "FAIL";
                  storeResultOnClose = {status:status, answer:score+"%", duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                }
              }
              // LearningApps.org
              if(event.data && event.data.split){
                var a = event.data.split("|");
                if(a[0] == "AppSolved" && parseInt(a[a.length-1])<= 2){
                  if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp'){
                    var status = "OK";
                    storeResultOnClose = {status:status, answer:"", duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                  }
                }
                if(a[0] == "AppCollection" && parseInt(a[a.length-1])<= 2){
                  var complete = parseInt(a[a.length-2]);
                  if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp' && complete > 0){
                    var status = (complete == 100) ? "OK" : "FAIL";
                    storeResultOnClose = {status:status, answer:complete+"%|"+$scope.uid, duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                  }
                }
              }

              if(event.data && event.data.indexOf && event.data.indexOf("ANSWER|") === 0){
                if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp'){
                  var status = "w";
                  var data = event.data.substring(("ANSWER|").length);
                  if(!storeResultOnClose)
                      storeResultOnClose = {};

                  storeResultOnClose.answer = data.indexOf("%|") > 0 ? data : '100%|'+data;
                  storeResultOnClose.status = storeResultOnClose.status != 'OK' ? status : storeResultOnClose.status;
                  storeResultOnClose.duration = Math.round(((new Date()).getTime()-startTime)/1000);
                }                
              }
              if(event.data && event.data.indexOf && event.data.indexOf("DOWNLOADFILE|") === 0){
                var data = event.data.substring(("DOWNLOADFILE|").length);
                var parts = data.split("/");
                self.downloadFile(data,parts[parts.length-1]);
                return;
              }

            };

            window.addEventListener("message", onMessage, false);
            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };

      if(self.openHTMLViewLoading) return; // still loading one
      self.openHTMLViewLoading = true;
      self.showLoadingIndicator(ev,function(done){
        if(url.length > 0 && url[0] == '\u003c') {
          self.openHTMLViewLoading = false;
          done();
          openNow();
          return;
        }
        $.getJSON("https://learningview.org/api/xframe.php?url="+encodeURIComponent(url),function(data){
          self.openHTMLViewLoading = false;
          done();
          if(data && data.error && t.Type != 'learningapp'){
            self.openWeblink(t,ev,false); // open external if not possible in popup
          }else{
            openNow();
          }
        },function(){
          // error 
          self.openHTMLViewLoading = false;
          done();
          openNow();
        });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openInteractive = function(t,s,ev){
      self.track('openTaskLearningApp',t);
      self.currentTaskPartners = "";
      if(self.user.Teacher == 0 && (t.Social == 'pair' || t.Social == 'group')){
        var status = self.getUserTaskStatus(t, s, true);
        self.currentTaskPartners = self.getUserTaskStatusColleagues(t,s);
        self.askTaskUserPartners(t,ev,self.currentTaskPartners).then(function(partners){
          self.currentTaskPartners = partners.join(",");
          self.openWeblink(t,ev,true,s);
        });
      }else{
        self.openWeblink(t,ev,true,s);
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openLearningApp = function(t,student,gallery,ev){
      if(!t.DataJSON) return;
      var url = t.DataJSON.URL;
      if(!url || url == "") return;
      var onMessage = null;
      var wasCompleted = false;
      var storeResultOnClose = null;
      var startTime = (new Date()).getTime();
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          if(onMessage) window.removeEventListener("message",onMessage);
          if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          self.storeInteractiveTaskResult(t,storeResultOnClose);
          self.track('closePopupView',null);
        },
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));

          var regex = /[?&]([^=#]+)=([^&#]*)/g,
              params = {}, match, appID = 0, appGUID = '';
          while(match = regex.exec(url)) {
            params[match[1]] = match[2];
          }

          if(params.app) appID = params.app;
          if(params.id) appGUID = params.id;
          if(params.v) appGUID = params.v;
          delete params.app;
          delete params.id;
          delete params.v;
          if(!appID && appGUID == "") {
            var pa = url.toLowerCase().match(/learningapps.org\/(?:view)?(\d+)/);
            if(pa && pa.length > 1) appID = pa[1];
          }

          onMessage = function(event){
            if(event.data && event.data.split){
              var a = event.data.split("|");
              if(a[0] == "AppSolved" && parseInt(a[a.length-1])<= 2){
                if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp'){
                  var status = "OK";
                  storeResultOnClose = {status:status, answer:"", duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                  wasCompleted = true;
                  $timeout(function(){
                    $scope.storeResultOnClose = storeResultOnClose;
                  },0);
                }
              }
              if(a[0] == "AppCollection" && parseInt(a[a.length-1])<= 2){
                var complete = parseInt(a[a.length-2]);
                if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp' && complete > 0){
                  var status = (complete == 100) ? "OK" : "FAIL";
                  storeResultOnClose = {status:status, answer:complete+"%|"+$scope.uid, duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                  wasCompleted = true;
                  $timeout(function(){
                    $scope.storeResultOnClose = storeResultOnClose;
                  },0);
                }
              }
            }
          };

          window.addEventListener("message", onMessage, false);

          var addons = "";
          for(var k in params){
            addons += '&'+k+'='+encodeURIComponent(params[k]);
          }

          $scope.url = "";
          $scope.student = student;
          $scope.updateURL = function(){
            $scope.uname = $scope.student ? $scope.student.Name+" "+$scope.student.Surname : self.user.Name + " "+ self.user.Surname;
            $scope.uid = $scope.student ? $scope.student.UID : self.user.UID;
            $scope.url = (appID ? "https://learningapps.org/watch?app="+appID+"&"+($scope.student ? 'student='+$scope.uid : 'user='+$scope.uid)+"&name="+encodeURIComponent($scope.uname)+"&fullscreen=1"+addons
                                : "https://learningapps.org/watch?v="+appGUID+"&"+($scope.student ? 'student='+$scope.uid : 'user='+$scope.uid)+"&name="+encodeURIComponent($scope.uname)+"&fullscreen=1"+addons)+
                          "&access="+self.getAccessTokenParameterInClass();
          };
          $scope.updateURL();
          $scope.t = t;

          self.addGalleryRecorderScope($scope,gallery); // will call updateURL on changeing student

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openEduloWidget = function(t,student,gallery,ev){
      if(!t.DataJSON) return;
      var url = t.DataJSON.URL;
      if(!url || url == "") return;
      var onMessage = null;
      var wasCompleted = false;
      var storeResultOnClose = null;
      var startTime = (new Date()).getTime();
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          if(onMessage) window.removeEventListener("message", onMessage);
          if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          self.storeInteractiveTaskResult(t,storeResultOnClose);
          self.track('closePopupView',null);
        },
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));

          onMessage = function(event){
            var a = event.data;
            if(event.data && event.data.indexOf && event.data.indexOf("DOWNLOADFILE|") === 0){
              var data = event.data.substring(("DOWNLOADFILE|").length);
              self.downloadFile(data,t.Name+($scope.student ? '_'+$scope.student.Name+'_'+$scope.student.Surname : '')+".pdf");
              return;
            }
            if(a && a.edulo == 1){
              if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp'){
                var status = (Math.round(a.correct) == 100) ? "OK" : "FAIL";
                storeResultOnClose = {status:status, answer:Math.round(a.correct)+"%|"+$scope.uid, duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                wasCompleted = true;
                $timeout(function(){
                  $scope.storeResultOnClose = storeResultOnClose;
                },0);
              }
            }
          };

          window.addEventListener("message", onMessage, false);

          $scope.url = "";
          $scope.student = student;

          $scope.updateURL = function(){
            $scope.uid = $scope.student && $scope.student.UID ? $scope.student.UID : self.user.UID;            
            if(t.Social == "pair" || t.Social == "group"){
              var taskStatus = self.getUserTaskStatus(t,$scope.student ? $scope.student : self.user,true);
              if(taskStatus.Answer && taskStatus.Answer.indexOf("|") > 0){
                var parts = taskStatus.Answer.split("|");
                $scope.uid = parts[parts.length-1];
              }
            }
            $scope.uname = $scope.student ? $scope.student.Name+" "+$scope.student.Surname : self.user.Name + " "+ self.user.Surname;
            $scope.url = url+(url.indexOf("?") > 0 ? '&':'?')+
                         ($scope.student ? 'student='+$scope.uid : 'user='+$scope.uid)+
                         "&access="+self.getAccessTokenParameterInClass()+"&name="+encodeURIComponent($scope.uname);
          };
          $scope.updateURL();
          $scope.t = t;

          self.addGalleryRecorderScope($scope,gallery); // will call updateURL on changeing student

          $scope.ok = function() {
            // save now on close
            var f = $('#webiframe').get(0);
            if(f) {
              f.contentWindow.postMessage("check","*");
              $timeout(function(){
                self.closeDialog($scope.dialogElement);     
              },100);
              return;
            }              
            self.closeDialog($scope.dialogElement);            
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openWordwallWidget = function(t,student,gallery,ev){
      if(!t.DataJSON) return;
      var url = t.DataJSON.URL;
      if(!url || url == "") return;
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          self.track('closePopupView',null);
        },
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));

          $scope.fetchEmbedURL = function(){
            $scope.openApp = null;
            $http({
                  method  : 'GET',
                  url     : 'https://wordwall.net/api/oembed',
                  timeout : 3000,
                  params  : {"url":url,"format":"json"}  // Query Parameters (GET)
            }).then(function(result, status, headers, config) {
                var data = result.data;
                var matches = data.html.match(/src="([^"]*)"/);
                if(matches && matches[1]){
                  $scope.url = matches[1];
                }else{
                  $window.alert("Error fetching embed URL from wordwall.net");
                }
            },function(data, status, headers, config) {
                $window.alert("Error fetching embed URL from wordwall.net");
            });
          };

          $scope.url = "";
          $scope.t = t;

          $scope.fetchEmbedURL();

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);            
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openZebisWidget = function(t,student,gallery,ev){
      if(!t.DataJSON) return;
      var url = t.DataJSON.URL;
      if(!url || url == "") return;
      var onMessage = null;
      var wasCompleted = false;
      var startTime = (new Date()).getTime();
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          if(onMessage) window.removeEventListener("message", onMessage);
          if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          self.storeInteractiveTaskResult(t,storeResultOnClose);
          self.track('closePopupView',null);
        },
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));

          onMessage = function(event){
            var a = event.data;
            if(a.indexOf && a.indexOf("ChapterSolved") === 0){
              var percent = Math.round(a.replace("ChapterSolved ",""));

              if(self.user && self.user.Teacher == '0' && t.Type == 'learningapp'){
                var status = (percent == 100) ? "OK" : "FAIL";
                storeResultOnClose = {status:status, answer:percent+"%|"+$scope.uid, duration:Math.round(((new Date()).getTime()-startTime)/1000)};
                wasCompleted = true;
                $timeout(function(){
                  $scope.storeResultOnClose = storeResultOnClose;
                },0);
              }
            }
          };

          window.addEventListener("message", onMessage, false);

          var embedURL = url.replace("https://zebis.digital/viewer/start","https://zeb.is");
          embedURL = embedURL.replace("https://zebis.digital/start","https://zeb.is");

          $scope.url = "";
          $scope.student = student;
          $scope.updateURL = function(){
            $scope.uid = $scope.student && $scope.student.UID ? $scope.student.UID : self.user.UID;            
            if(t.Social == "pair" || t.Social == "group"){
              var taskStatus = self.getUserTaskStatus(t,$scope.student ? $scope.student : self.user,true);
              if(taskStatus.Answer && taskStatus.Answer.indexOf("|") > 0){
                var parts = taskStatus.Answer.split("|");
                $scope.uid = parts[parts.length-1];
              }
            }
            $scope.url = embedURL+(embedURL.indexOf("?") > 0 ? '&':'?')+"mode=LearningView&"+
                         ($scope.student ? 'student='+$scope.uid : 'user='+$scope.uid)+
                         "&access="+self.getAccessTokenParameterInClass();
          };
          $scope.updateURL();
          $scope.t = t;
          self.addGalleryRecorderScope($scope,gallery); // will call updateURL on changeing student

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openYouTube = function(t,ev){
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          self.track('closePopupView',null);
        },
        controller: function ($scope, $mdDialog) {
          var url = t.DataJSON.URL;
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.caption = t.DataJSON.text ? t.DataJSON.text : (t.Name ? t.Name : (t.name ? t.name : ''));

          var regex = /[?&]([^=#]+)=([^&#]*)/g,
              params = {}, match, videoID = 0;
          while(match = regex.exec(url)) {
            params[match[1]] = match[2];
          }

          if(params.v) videoID = params.v;
          delete params.v;
          if(params.t) {
            var matches = url.match(/(\?|&)t=(?:(\d+)h)?(?:(\d+)m)?(\d+)s/i);
            if(matches){
              var s = 0;
              s += matches[2] == undefined ? 0 : (Number(matches[2])*60*60);
              s += matches[3] == undefined ? 0 : (Number(matches[3])*60);
              s += matches[4] == undefined ? 0 : (Number(matches[4]));
              params.start = s;
            }else params.start = params.t;
            delete params.t;
          }
          if(!videoID) {
            // https://youtu.be/l2izJvv0yxo?si=egerg
            // https://www.youtube.com/shorts/Ll8ixJbw9EU
            // https://www.youtube.com/live/jwt9OYFrxEk
            var parts = url.split("/");
            videoID = parts[parts.length-1];
            parts = videoID.split("?");
            videoID = parts[0];
          }

          var addons = "";
          for(var k in params){
            addons += '&'+k+'='+params[k];
          }

          $scope.url = ("https://learningview.org/youtube.php?id="+videoID+addons);
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.isPDFURL = function(url){
      return !!(url.toLowerCase().match(/https:.*?\.pdf$/));
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.openWeblink = function(t,ev,asPopup,student,gallery){
      var url = t.DataJSON.URL; // there might also be a t.DataJSON.source = "la" or "edulo" in the future
      if(!url) return;
      if(url == "") return;
      if(typeof asPopup == "undefined") asPopup = true;

      if(t.DataJSON.URL && t.DataJSON.URL.length > 0 && t.DataJSON.URL[0] == "<") asPopup = true; // embed code
      if(t.Type == "learningapp") asPopup = true; // embed code
      if(url.toLowerCase().match(/^https:\/\/learningview\.org\/[mg][0-9]+/)) asPopup = true; // internal material code

      var extension = "";
      extension = url.toLowerCase().split("?")[0].split(".").pop();
      if(extension == "php"){
        // openZIP php case
        extension = url.toLowerCase().split("=").pop().split(".").pop();
      }

      if(extension == "html" && url.toLowerCase().match(/^https:\/\/learningview\.org\/uploads\//)){
        self.openHTMLViewFromURL(url);
        ev.stopPropagation();
        return;
      }

      if(extension == "pages" || extension == "key" || extension == "numbers"){
        url = url + (url.indexOf("?") > 0 ? "&_download=1" : "?_download=1");
        var filename = url.split("?")[0].split("/").pop();
        self.downloadFile(url,filename);
        ev.stopPropagation();
        return;
      }

      if(asPopup === 'auto'){
        asPopup = false;
        // files that we can open in popup, we open in popup
        var filesToOpenInPopup = ["zip","docx","xlsx","pptx","png","jpg","jpeg","gif","pdf","m4v",'mp4','mp3','m4a'];
        var urlfile = url.split("?")[0].toLowerCase();
        if(filesToOpenInPopup.indexOf(extension) != -1) asPopup = true;
        if(url.indexOf("https://forms.gle/") != -1) asPopup = true; // open google forms in popup
        if((url.toLowerCase().match(/^https?:\/\/(www\.)?youtube\.com/) || url.toLowerCase().match(/\/\/youtu\.be/)) &&
           !url.toLowerCase().match(/channel/) && !url.toLowerCase().match(/\/c\//)){
          asPopup = true;
        }
      }
      self.track('openWebLink',{URL:url, asPopup:asPopup});
      if(asPopup){
        //url = url.replace(/\\/g,'/');
        //if (!url.match(/^[a-zA-Z]+:\/\//)) url = 'http://' + url;
        if(extension == "png" || extension == "jpg" || extension == "jpeg" || extension == "gif"){
          self.showTaskMedia("image",t.DataJSON,ev,true);
        }else
        if(extension == "mp4"){
          self.showTaskMedia("video",t.DataJSON,ev,true);
        }else
        if(extension == "m4a" || extension == "mp3"){
          self.showTaskMedia("audio",t.DataJSON,ev,true);
        }else
        if(url.toLowerCase().match(/^https:\/\/learningview\.org\/m[0-9]+/)){
          // internal material link
          var taskid = parseInt(url.replace("https://learningview.org/m",""));
          var task = null;
          var scope = {};

          var openTaskFound = function(task){
            self.showLoadingIndicator(null,function(done){
              self.findAndShowTask(task,false);
              self.openTaskButtonWindow(task,null,scope);
              //self.openResultButtonWindow(task,null,null,this)
              $timeout(function(){
                done();
              },10);
            });                  
          };

          if(self.user.Teacher == "1"){
            if(self.currentClass){
              task = self.findTaskInClass(self.currentClass,taskid);
              if(!task){
                var openClassAndFindTask = function(c){
                  self.confirm("Das verlinkte Material im Kurs <b>"+c.Name+"</b> gefunden. Soll in den Kurs gewechselt werden?").then(function(){
                    self.openClass(c,null,true,true);
                    self.lastOpenTask = null;
                    openTaskFound(task);
                  });
                };

                for(var i=0; i < self.classList.length; i++){
                  task = self.findTaskInClass(self.classList[i],taskid);
                  if(task){
                    openClassAndFindTask(self.classList[i]);
                    return;
                  }
                }
                self.alert("Das verlinkte Material ist in diesem Kurs nicht verteilt.");
                return;
              }
              scope.t = task;
            }else{
              task = self.getTaskByID(taskid);
              if(!task){
                self.alert("Das verlinkte Material wurde nicht gefunden.");
                return;
              }
              scope.t = task.task;
              scope.mt = task.mainTopic;
              task = task.task;
            }
          }else{
            if(!self.currentClass) return; // requires a class to search task in
            task = self.findTaskInClass(self.currentClass,taskid);
            if(!task){
              var openClassAndFindTask = function(c){
                self.confirm("Das verlinkte Material im Kurs <b>"+c.Name+"</b> gefunden. Soll in den Kurs gewechselt werden?").then(function(){
                  self.openClass(c,null,true,true);                  
                  self.lastOpenTask = null;
                  openTaskFound(task);
                });
              };

              for(var i=0; i < self.classList.length; i++){
                task = self.findTaskInClass(self.classList[i],taskid);
                if(task){
                  openClassAndFindTask(self.classList[i]);
                  return;
                }
              }
              self.alert("Das verlinkte Material ist in diesem Kurs nicht verteilt.");
              return;
            }
            scope.t = task;
          }
          if(!task) return;
          openTaskFound(task); // up
        }else
        if(url.toLowerCase().match(/^https:\/\/learningview\.org\/g[0-9]+/)){
          // internal learninggoal link
          var goalid = parseInt(url.replace("https://learningview.org/g",""));
          var goal = null;
          var topic = null;
          var mt = null;
          var scope = {};

          var openGoalFound = function(task){
            self.showLoadingIndicator(ev,function(done){
              if(self.user.Teacher == "0") self.closeDialog();
              self.findAndShowLearningGoal(goal,false);
              $timeout(function(){
                done();
              },10);
            });
          };

          if(self.user.Teacher == "1"){
            if(self.currentClass){
              goal = self.findGoalInClass(self.currentClass,goalid);
              if(!goal){
                var openClassAndFindGoal = function(c){
                  self.confirm("Das verlinkte Material im Kurs <b>"+c.Name+"</b> gefunden. Soll in den Kurs gewechselt werden?").then(function(){
                    self.openClass(c,null,true,true);
                    self.lastOpenTask = null;
                    openGoalFound(goal);
                  });
                };

                for(var i=0; i < self.classList.length; i++){
                  goal = self.findGoalInClass(self.classList[i],goalid);
                  if(goal){
                    openClassAndFindGoal(self.classList[i]);
                    return;
                  }
                }
                self.alert("Das verlinkte Material ist in diesem Kurs nicht verteilt.");
                return;
              }
            }else{
              goal = self.getGoalByID(goalid);
              if(!goal){
                self.alert("Das verlinkte Material wurde nicht gefunden.");
                return;
              }
              goal = goal.goal;
              topic = goal.topic;
              mt = goal.mainTopic;
            }
                      }else{
            if(!self.currentClass) return; // requires a class to search goal in
            goal = self.findGoalInClass(self.currentClass,goalid);
            if(!goal){
              var openClassAndFindGoal = function(c){
                self.confirm("Das verlinkte Material im Kurs <b>"+c.Name+"</b> gefunden. Soll in den Kurs gewechselt werden?").then(function(){
                  self.openClass(c,null,true,true);
                  self.lastOpenTask = null;
                  openGoalFound(goal);
                });
              };
              for(var i=0; i < self.classList.length; i++){
                goal = self.findGoalInClass(self.classList[i],goalid);
                if(goal){
                  openClassAndFindGoal(self.classList[i]);
                  return;
                }
              }
              self.alert("Das verlinkte Material ist in diesem Kurs nicht verteilt.");
              return;
            }
          }
          if(!goal) return;
          openGoalFound(goal); // up
        }else
        if((url.toLowerCase().match(/^https?:\/\/(www\.)?youtube\.com/) || url.toLowerCase().match(/\/\/youtu\.be/)) &&
           !url.toLowerCase().match(/channel/) && !url.toLowerCase().match(/\/c\//)){
          self.openYouTube(t,ev); 
        }else
        if(url.toLowerCase().match(/^https?:\/\/learningapps\.org/) && !url.toLowerCase().match(/^https?:\/\/learningapps.org\/?$/)){
          self.openLearningApp(t,student,gallery,ev);
        }else
        if(url.toLowerCase().match(/^https?:\/\/content\.edulo\.com/)){
          self.openEduloWidget(t,student,gallery,ev);
        }else
        if(url.toLowerCase().match(/^https?:\/\/wordwall\.net\/(.*)?resource\//)){
          self.openWordwallWidget(t,student,gallery,ev);
        }else
        if(url.toLowerCase().match(/^https?:\/\/zebis\.digital\/viewer\//) ||
           url.toLowerCase().match(/^https?:\/\/zebis\.digital\/start\//) ||
           url.toLowerCase().match(/^https?:\/\/zeb\.is\//) ){
          /*
          self.alert("Durch ein kürzliches Update von Zebis.digital steht die Einbindung in LearningView derzeit leider nicht zur Verfügung. Das Team von Zebis arbeitet bereits an einer Lösung. Die Aufgabe wird nun in einem externen Browser geöffnet.").then(function(){
            self.tryCloseLastWindow();
            window.lastOpenWindow = window.open(url,self.getNewWindowName());            
          });
          */
          self.openZebisWidget(t,student,gallery,ev);
        }else
        if(extension == "zip" ||
           extension == "pdf" ||
           extension == "docx" ||
           extension == "xlsx" ||
           extension == "pptx"){
          self.openOfficeDocumentPreview(t,ev);
        }else{
          if(!asPopup){
            self.tryCloseLastWindow();
            if(window.electron && url.indexOf("://learningview.org/uploads/") > 0){
              window.downloadElectronSaveAs(url,t.DataJSON && t.DataJSON.name ? t.DataJSON.name : null);
            }else{
              if (!url.match(/^[a-zA-Z]+:\/\//)) url = 'http://' + url;
              window.lastOpenWindow = window.open(url,self.getNewWindowName());
            }
          }else{
            self.openHTMLView(t,ev);
          }
        }
      }else{
        // if user selected asPopuo == false on request
        self.tryCloseLastWindow();
        if(window.electron && url.indexOf("://learningview.org/uploads/") > 0){
          window.downloadElectronSaveAs(url,t.DataJSON && t.DataJSON.name ? t.DataJSON.name : null);
        }else{
          if (!url.match(/^[a-zA-Z]+:\/\//)) url = 'http://' + url;
          window.lastOpenWindow = window.open(url,self.getNewWindowName());
        }
      }
    };

    self.needUpdateJQueryStuff = false;
    self.updateJQueryDelay = null;
    self.updateJQueryStuff = function(){
      if(!self.needUpdateJQueryStuff) return;
      function findParentWith_attribute (a,p){
        if(p.attr(a)){
          return p;
        }
        if(p.parent().length > 0){
          var r = findParentWith_attribute(a,p.parent());
          if(r) return r;
        }
        return null;
      }

      if(self.updateJQueryDelay) return; // already performing
      self.needUpdateJQueryStuff = false;
      self.updateJQueryDelay = setTimeout(function(){
        self.updateJQueryDelay = null;
        if(self.refreshMathJax && window.MathJax){
          // perform only once until next trustHTML calls it again
            try{
              MathJax.typesetPromise().then(function(){
                self.refreshMathJax = false;
              });
            }catch(e){}          
        }

        $('.imageZoomBox img').each(function(i,element){
          createImageZoomBox($(element),true);
        });

        if(inlineAudioEditorElement && !document.body.contains(inlineAudioEditorElement)){
          stopInlineAudioEditorPlayer();
        }

        setupInlineAudioEditorPlayback();

        $('.inlineAudio').each(function(i,element){
          createInlineAudioPlayer($(element));
        });

        $('.popup').each(function(x,p){
          $(p).off("click").on("click",function(e){ e.stopPropagation(); });
        });

        $('.nw-checklist').each(function(i,element){
          var ct = null;
          var cg = null;
          var parent = findParentWith_attribute("taskid",$(element));
          if(parent){
            ct = {ID: parent.attr("taskid"), user:parent.attr("userid")};
          }else{
            parent = findParentWith_attribute("goalid",$(element));
            if(parent){
              cg = {ID: parent.attr("goalid"), user:parent.attr("userid")};
            }else return; // no parent
          }

          // there might be multiple checklists in the same task, so go to parent and fetch all checklists from there
          var now = [];

          // self.user.Teacher == "0" ? self.user : self.currentTaskStudent
          var status = ct ? self.getUserTaskStatus(ct, {ID:ct.user},true) : self.getUserLearningGoalStatus(cg,{ID:cg.user},true);
          if(status && status.Checklist && status.Checklist != '')
            now = status.Checklist;

          var checklists = $('.nw-checklist',parent);
          var allchecks = [];
          checklists.each(function(i,element){
            $('li',element).each(function(z,r){
              allchecks.push(r); // add the element to the list of all checks
            });
          });

          var applyCheckList = function(i,r){
            var checked = false;
            if(now.length > i) checked = now[i] == "1";
            if(checked) $(r).addClass("checked"); else $(r).removeClass("checked");

            // student can change the checkmarks
            if(self.user.Teacher == "0" && 
              ((ct && ct.user == self.user.ID) || (cg && cg.user == self.user.ID)))
              $(r).off().on("click",function(event){
                event.stopPropagation();
                if($(this).hasClass("checked"))
                  $(this).removeClass("checked"); else
                  $(this).addClass("checked");
                // save now
                // collect status of all items
                var s = "";
                $(allchecks).each(function(z,r){
                  if($(r).hasClass("checked")) s += '1'; else s+= '0';
                });
                status.Checklist = s;
                if(ct){
                  self.track('checklistChange',{task:ct.ID, checks:s});
                  self.apiPost("ajax",{"action":"saveUserTaskChecklistStatus",// "noindicator":true,
                                       "ID":ct.ID, "status":s});
                }
                if(cg){
                  self.track('checklistChange',{goal:cg.ID, checks:s});
                  self.apiPost("ajax",{"action":"saveLearningGoalChecklistStatus",// "noindicator":true,
                                       "ID":cg.ID, "status":s});
                }
              });

            if(self.user.Teacher == "1" && ct && self.currentClass){
              $(r).off().on("click",function(event){
                event.stopPropagation();
                // open list of student status 
                if(ct.user == self.user.ID){
                  self.showTeacherStudentTaskChecklistContextMenu(ct,parseInt(i),allchecks,function(student,status){
                    self.apiPost("ajax",{"action":"saveStudentTaskChecklistStatus",// "noindicator":true,
                                         "student": student.ID, 
                                         "task":ct.ID, "status":status});

                  },event);                  
                }else{
                  if($(this).hasClass("checked"))
                    $(this).removeClass("checked"); else
                    $(this).addClass("checked");

                  // collect status of all items
                  var s = "";
                  $(allchecks).each(function(z,r){
                    if($(r).hasClass("checked")) s += '1'; else s+= '0';
                  });
                  status.Checklist = s;
                  self.apiPost("ajax",{"action":"saveStudentTaskChecklistStatus",// "noindicator":true,
                                       "student": ct.user, // self.currentTaskStudent.ID,
                                       "task":ct.ID, "status":s});
                }
              });
            }

            if(self.user.Teacher == "1" && cg && self.currentClass){
              $(r).off().on("click",function(event){
                event.stopPropagation();
                // open list of student status 
                if(cg.user == self.user.ID){
                  self.showTeacherStudentGoalChecklistContextMenu(cg,parseInt(i),allchecks,function(student,status){
                    self.apiPost("ajax",{"action":"saveStudentLearningGoalChecklistStatus",// "noindicator":true,
                                         "student": student.ID, 
                                         "learningGoal":cg.ID, "status":status});

                  },event);                  
                }else{
                  if($(this).hasClass("checked"))
                    $(this).removeClass("checked"); else
                    $(this).addClass("checked");

                  // collect status of all items
                  var s = "";
                  $(allchecks).each(function(z,r){
                    if($(r).hasClass("checked")) s += '1'; else s+= '0';
                  });
                  status.Checklist = s;
                  self.apiPost("ajax",{"action":"saveStudentLearningGoalChecklistStatus",// "noindicator":true,
                                       "student": cg.user, 
                                       "learningGoal":cg.ID, "status":s});
                }
              });
            }
            if(self.user.Teacher == "1" && !self.currentClass){
              $(r).off().on("click",function(event){
                event.stopPropagation();
                self.alert($filter('trans')('CHECKLISTCLICKINMATERIALS'));
              });
            }
          };
          $(allchecks).each(function(i,r){
            applyCheckList(i,r);
          });
        });

      },0);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.toggleNotelistLarge = function(){
      var n = self.currentNotelist;
      self.currentNotelist = null;
      if($('#sidePanelRight').hasClass("maximized")){
        $('#sidePanelRight').removeClass("maximized");
        $('#sidePanelRightButtons').removeClass("maximized");
        self.isNotelistEnlarged = false;
      }else{
        $('#sidePanelRight').addClass("maximized");
        $('#sidePanelRightButtons').addClass("maximized");
        self.track("notelist_maximized",{ID:n.ID, name:n.Name, color:n.Color ? n.Color : 0});
        self.isNotelistEnlarged = true;
      }
      $timeout(function(){ self.currentNotelist = n; },10);
    };

    self.getStudentNotelistContent = function(student){
      if(!student || !self.currentClass || !self.users[student.ID]) return null;
      if(!self.users[student.ID].classContent)
          self.users[student.ID].classContent = {};
      if(!self.users[student.ID].classContent[self.currentClass.ID])
          self.users[student.ID].classContent[self.currentClass.ID] = {};
      if(!self.users[student.ID].classContent[self.currentClass.ID].notelists)
          self.users[student.ID].classContent[self.currentClass.ID].notelists = [];
      return self.users[student.ID].classContent[self.currentClass.ID];
    };

    self.getCurrentNotelists = function(){
      if(self.teacherNotelistStudent){
        var c = self.getStudentNotelistContent(self.teacherNotelistStudent);
        return c && c.notelists ? c.notelists : [];
      }
      if(!self.currentClass) return [];
      if(!self.classContent[self.currentClass.ID]) self.classContent[self.currentClass.ID] = {};
      if(!self.classContent[self.currentClass.ID].notelists)
          self.classContent[self.currentClass.ID].notelists = [];
      return self.classContent[self.currentClass.ID].notelists;
    };

    self.sortNotelists = function(notelists){
      if(!notelists) return;
      notelists.sort(function(a,b){
        if(a.OrderIndex == b.OrderIndex){
          return a.ID > b.ID ? 1 : -1;
        }
        return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
      });
      for(var i=0; i < notelists.length; i++){
        if(!notelists[i].items) notelists[i].items = [];
        notelists[i].items.sort(function(a,b){
          if(a.OrderIndex == b.OrderIndex){
            return a.ID > b.ID ? 1 : -1;
          }
          return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
        });
      }
    };

    self.loadTeacherStudentNotelists = function(student){
      if(!student || !self.currentClass) return $q.when([]);
      var content = self.getStudentNotelistContent(student);
      if(!content) return $q.reject();
      return self.apiPost("ajax",{
        "action":"getUserNotelists",
        "student":student.ID,
        "classid":self.currentClass.ID,
        "noindicator":true,
        "noerror":true
      }).then(function(data){
        if(!data || data.result != "OK") return $q.reject(data);
        content.notelists = data && data.lists ? data.lists : [];
        self.sortNotelists(content.notelists);
        return content.notelists;
      });
    };

    self.changeNotelist = function(list,track){
      if(!list) return;
      var maxOrderIndex = 0;
      var before = self.currentNotelist;
      self.currentNotelist = null;

      var notelists = self.getCurrentNotelists();

      for(var i=0; i < notelists.length; i++){
        maxOrderIndex = Math.max(maxOrderIndex,notelists[i].OrderIndex)
        if(notelists[i].ID == list.ID){
          self.currentNotelist = notelists[i]; 
        }
      }
      self.currentNotelistEdit = false;
      self.deleteNotelistAsk = null;
      self.deleteNotelistItemAsk = null;
      self.currentNotelistItemSelected = null;
      self.currentNotelistTargets = null;
      if(!self.currentNotelist) return;

      if(!self.teacherNotelistStudent){
        self.userViewData["nl_"+self.currentClass.ID] = self.currentNotelist.ID;
        self.updateUserViewData();
      }

      if(!self.teacherNotelistStudent)
        self.currentNotelist.OrderIndex = maxOrderIndex+1;      

      notelists.sort(function(a,b){
        if(a.OrderIndex == b.OrderIndex){
          return a.ID > b.ID ? 1 : -1;
        }
        return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
      });
      var ids = [];
      for(var i=0; i < notelists.length; i++){
        ids.push(notelists[i].ID);
        if(!self.teacherNotelistStudent)
          notelists[i].OrderIndex = i;
      }

      if(!self.teacherNotelistStudent)
        self.apiPost("ajax",{"action":"saveNotelistOrder", "order":ids});
      if(track)
        self.track("notelist_changed",{now:self.currentNotelist.ID, name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0, before:before ? before.ID : 0});
    }
    
    self.getCurrentNotelistColor = function(){
      self.userViewData["nl_"+self.currentClass.ID]
    };

    self.toggleNotelist = function(ev){
      if(self.sidePanelRight && self.currentNotelist){
        self.closeNotelist();
      }else{
        self.openNotelist(ev);
      }
    };

    self.openNotelist = function(ev){
      $('body').addClass("sidePanRight large").append($('#sidePanelRight'));
      if(!self.currentNotelist){

        self.changeNotelist({ID:self.userViewData["nl_"+self.currentClass.ID] ? self.userViewData["nl_"+self.currentClass.ID] : 0});

        // not found, create dummy list for now
        if(!self.currentNotelist){
          if(self.getCurrentNotelists() && 
             self.getCurrentNotelists().length > 0){
            self.changeNotelist(self.getCurrentNotelists()[0]);
          }else{
            // create a first list
            self.createNotelist();
            return;
          }
        }

      }
      $timeout(function(){
        self.sidePanelRight = true;
        self.track("notelist_opened",{now:self.currentNotelist.ID, name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0});
        $timeout(function(){$('#closeNotelistBtn').focus();},100);
      },0);
    };

    self.closeNotelist = function(){
      $('body').removeClass("sidePanRight");
      $timeout(function(){
        if(self.currentNotelist)
          self.track("notelist_closed",{ID:self.currentNotelist.ID, name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0});
        self.currentNotelist = null;
        self.sidePanelRight = false;
        $('#sidePanelRight').removeClass("maximized");
        $('#sidePanelRightButtons').removeClass("maximized");
        $timeout(function(){
          $('#openNotelistBtn').focus();
        },10);
      },0);
    };

    self.createNotelistItem = function(newText,newColor,list){
      var deferred = $q.defer();
      if(self.teacherNotelistStudent) return deferred.promise;
      if(!newText || newText === '') return deferred.promise;
      var maxID = 0;
      if(!list) list = self.currentNotelist;
      for(var i=0; i < list.items.length; i++)
        maxID = Math.max(maxID,list.items[i].ID);
      var item = {ID:maxID+1,Text:newText};
      list.items.push(item);
      var p = {"action":"createNotelistItem", "ID":list.ID, "Text":item.Text};
      if(newColor) {
        p.Color = newColor;
        item.Color = newColor;
      }
      if(self.currentTask) {
        p.Task = self.currentTask.ID;
        item.Task = self.currentTask.ID;
      }
      self.apiPost("ajax",p).then(function(data){
        self.track("notelist_addnote",{ID:data.ID, text:item.Text, color:item.Color ? item.Color : 0, checked: item.Checked != 1 ? 0 : 1, task:item.Task ? item.Task : 0});
        if(data.ID) item.ID = data.ID;
        var found = false;
        for(var i=0; i < list.items.length; i++){
          if(list.items[i].ID == item.ID){
            found = true;
            break;
          }
        }
        if(!found)
          list.items.push(item);
        deferred.resolve(item);
      });
      return deferred.promise;
    };

    self.deleteNotelist = function(list){
      if(self.teacherNotelistStudent) return;
      if(self.deleteNotelistAsk == list.ID && self.deleteNotelistAskClickable){
        var notelists = self.getCurrentNotelists();
        for(var i=0; i < notelists.length; i++){
          if(notelists[i].ID == list.ID){
            notelists.splice(i,1);
            break;
          }
        }
        // delete it now on server 
        self.apiPost("ajax",{"action":"deleteNotelist", "ID":list.ID});
        self.track("notelist_delete",{ID:list.ID, name:list.Name, color:list.Color ? list.Color : 0});
        if(list.ID == self.currentNotelist.ID){
          if(self.getCurrentNotelists() && 
             self.getCurrentNotelists().length > 0){
            self.changeNotelist(self.getCurrentNotelists()[0],true);
          }else{
            // create a first list
            self.createNotelist();
          }          
        }
      }else{
        self.deleteNotelistAsk = list.ID;
        self.deleteNotelistAskClickable = false;
        $timeout(function(){ self.deleteNotelistAskClickable = true; },300);
      }
    };

    self.startNotelistEdit = function(){
      self.deleteNotelistAsk = null;
      self.deleteNotelistItemAsk = null;
      if(self.teacherNotelistStudent) return;
      self.currentNotelistEdit = true;
    };

    self.selectNotelistItemForEdit = function(item){
      self.saveNotelistItemTextBlur = false;
      if(self.teacherNotelistStudent) return;
      self.currentNotelistItemSelected = item;
    };

    self.toggleNotelistItemCheck = function(item){
      if(self.teacherNotelistStudent) return;
      item.Checked = item.Checked == 1 ? 0 : 1;
      self.saveNotelistItem(item);
    };

    self.deleteNotelistItem = function(item){
      if(self.teacherNotelistStudent) return;
      var deleteNow = function(pos){
        self.currentNotelist.items.splice(pos,1);
        // delete it now on server 
        self.apiPost("ajax",{"action":"deleteNotelistItem", "ID":item.ID}).then(function(){
          // delete again, if there was a data update in between 
          self.track("notelist_deletenote",{ID:item.ID, text:item.Text, color:item.Color ? item.Color : 0, checked: item.Checked != 1 ? 0 : 1, task:item.Task ? item.Task : 0});
          for(var i=0; i < self.currentNotelist.items.length; i++){
            if(self.currentNotelist.items[i].ID == item.ID){
              self.currentNotelist.items.splice(i,1);
              return;
            }
          }    
        });
      };

      for(var i=0; i < self.currentNotelist.items.length; i++){
        if(self.currentNotelist.items[i].ID == item.ID){
          if(item.Text == '')
            deleteNow(i);
          else
            if(self.deleteNotelistItemAsk == item.ID && self.deleteNotelistItemAskClickable){
              deleteNow(i);
            }else{
              self.deleteNotelistItemAsk = item.ID;
              self.deleteNotelistItemAskClickable = false;
              $timeout(function(){ self.deleteNotelistItemAskClickable = true; },300);
            }
          break;
        }
      }
    };

    self.saveNotelist = function(list){
      if(self.teacherNotelistStudent) return;
      var p = {"action":"saveNotelist", "ID":list.ID, "name":list.Name};
      if(list.Color) p.color = list.Color;
      self.apiPost("ajax",p);
      self.track("notelist_save",{ID:list.ID, name:list.Name, color:list.Color ? list.Color : 0});
    };

    self.saveNotelistItemTextBlur = false;
    self.saveNotelistItemText = function(item,newText){
      if(self.teacherNotelistStudent) return;
      $timeout(function(){ 
        if(self.saveNotelistItemTextBlur) 
           self.currentNotelistItemSelected = null;
      },500);
      self.saveNotelistItemTextBlur = true;
      if(item.Text == newText) return; // same value
      item.Text = newText;
      self.saveNotelistItem(item);
    }
    self.saveNotelistItem = function(item){
      if(self.teacherNotelistStudent) return;
      var n = JSON.parse(angular.toJson(item));
      self.apiPost("ajax",{"action":"saveNotelistItem", "ID":item.ID, "Text":item.Text, "Color":item.Color, "Checked":item.Checked != 1 ? 0 : 1}).then(function(){
        for(var k in n) item[k] = n[k];
        self.track("notelist_savenote",{ID:item.ID, text:item.Text, color:item.Color ? item.Color : 0, checked: item.Checked != 1 ? 0 : 1, task:item.Task ? item.Task : 0});
      });
    };

    self.moveNotelistItemTo = function(item,list){
      if(self.teacherNotelistStudent) return;
      self.track("notelist_movenote",{ID:item.ID, text:item.Text, color:item.Color ? item.Color : 0,task:item.Task ? item.Task : 0, checked: item.Checked != 1 ? 0 : 1, to:list.ID});
      self.createNotelistItem(item.Text,item.Color ? item.Color : '',list).then(function(newItem){
        if(item.Checked != newItem.Checked){
          newItem.Checked = item.Checked;
          self.saveNotelistItem(newItem);
        }
      });
      self.deleteNotelistItemAsk = item.ID;
      self.deleteNotelistItemAskClickable = true;
      self.deleteNotelistItem(item);
    };

    self.isTextEditorOpenAndEditable = function(){
      if(self.hasDialogOpen('textEditor.html')){
        if(self.currentTextEditor && self.currentTextEditor.editable &&
           self.currentTextEditor.annotateonly != true) return true;
      }
      return false;
    }

    self.sendTextNotesToTextEditor = function(){      
      var s = "";
      for(var i=0; i < self.currentNotelist.items.length; i++){
        s += self.currentNotelist.items[i].Text+"\n";
      }
      var frame = $('.textEditorFrame').get(0);
      if(frame){
        frame.contentWindow.postMessage("ADDTEXT|"+s,"*");
        self.track("notelist_sendtotexteditor",{ID:self.currentNotelist.ID, name:self.currentNotelist.Name, content:s});
      }
    };

    self.createNotelist = function(){
      if(self.teacherNotelistStudent) return;
      var n = 2;
      var dname = $filter('trans')('DEFAULTNOTELISTNAME');
      var name = dname;
      var exists = true;
      while(exists){
        exists = false;
        if(self.currentClass && self.classContent[self.currentClass.ID].notelists)
          for(var i=0; i < self.classContent[self.currentClass.ID].notelists.length; i++){
            if(self.classContent[self.currentClass.ID].notelists[i].Name == name){
              exists = true;
              break;
            }
          }
        if(exists){
          name = dname + ' ' + n;
          n++;
        }
      }  
      if(self.user.ID == -1){
        // fake it
        if(!self.classContent[self.currentClass.ID].notelists)
            self.classContent[self.currentClass.ID].notelists = [];
        var list = {ID:-(self.classContent[self.currentClass.ID].notelists.length+1),Name:name,items:[]};
        self.classContent[self.currentClass.ID].notelists.push(list);
        self.changeNotelist(list);
        self.currentNotelistEdit = true;
        if(!self.sidePanelRight){
          self.sidePanelRight = true;
          self.track("notelist_opened",{now:self.currentNotelist.ID, name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0});
        }
        return;
      }    
      self.apiPost("ajax",{"action":"createNotelist", "classid":self.currentClass.ID, "name":name})
        .then(function(data) {
          self.track("notelist_create",{ID:data.ID, name:name});
          self.keepAliveCallback().then(function(){
            self.changeNotelist(data);
            self.currentNotelistEdit = true;
            if(!self.sidePanelRight){
              self.sidePanelRight = true;
              self.track("notelist_opened",{now:self.currentNotelist.ID, name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0});
            }
          });
        });
    };


    self.updateNotelistItemOrder = function(){
      if(self.teacherNotelistStudent) return;
      if(!self.currentNotelist || self.currentNotelist.items.length == 0) return;
      var t = "";
      for(var i=0; i < self.currentNotelist.items.length; i++){
        t += (i > 0 ? ',' : '')+ self.currentNotelist.items[i].ID;
        self.currentNotelist.items[i].OrderIndex = (i+1);
      }
      self.apiPost("ajax",{"action":"updateNotelistItemOrder", "ID":self.currentNotelist.ID,"order": t});
      self.track("notelist_reordernotes",{ID:self.currentNotelist.ID,name:self.currentNotelist.Name, color:self.currentNotelist.Color ? self.currentNotelist.Color : 0, order:t});

    };

    // saveNotelist ID name

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getLearningGoalNumber = function(it,t){
      for(var i=0; i < t.goals.length; i++){
        if(t.goals[i].ID == it.ID) return (i+1);
      }
      return 1;
    };

    self.getLearningGoalNumberTooltip = function(it){
      var totalTime = 0;
      var totalTasks = 0;
      if(it.tasks){
        for(var i=0; i < it.tasks.length; i++){
          if(it.tasks[i].Time && it.tasks[i].Time != "0"){
            totalTime += parseInt(it.tasks[i].Time);
          }
          totalTasks++;
        }
      }
      return totalTasks+" " +$filter('trans')('TASKS')+
             (totalTime > 0 ?
              " ("+totalTime + " " +$filter('trans')('MINUTESSHORT')+")" : '');
    };

    self.getTopicNumber = function(it,mt){
      for(var i=0; i < mt.topics.length; i++){
        if(mt.topics[i].ID == it.ID) return (i+1);
      }
      return 1;
    }
    self.formatFileName = function(s){
      // replace escape characters from the name
      return unescape(s);
    };

    self.parseJSON = function(s){
      return JSON.parse(s);
    }
    self.splitAnswerType = function(s){
      if(!s || s.length == 0) return [""];
      var pos = s.indexOf(";");
      var parts = [];
      var p2 = s.split(";");
      parts[0] = p2[0];
      parts[1] = s.substring(pos+1);
      return parts;
    }

    self.escapeAttr = function (value) {
      return String(value)
        .replace(/&/g, "&amp;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#039;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;");
    };
    self.escapeJSString = function(s) {
      return String(s || "")
        .replace(/\\/g, "\\\\")
        .replace(/'/g, "\\'")
        .replace(/"/g, "\\&quot;")
        .replace(/\n/g, "\\n")
        .replace(/\r/g, "\\r")
        .replace(/</g, "\\x3C")
        .replace(/>/g, "\\x3E");
    };

    self.trustAsHTML = function (s, returns, linkify, disableSanitize){
      if(!s) return "";
      s = s.replace('¶',''); // for task notes
      s = s.replace('#.°.#',''); // for empty text content
      if(returns){
        s = s.replace(/<\/p>\n/g,"</p>");
        s = s.replace(/<br>\n/g,"<br>");
        s = s.replace(/\n/g,"<br>");
        s = s.replace(/<p><\/p>$/,"");
      }
      if(!disableSanitize){
//        t = DOMPurify.sanitize(t, {ALLOWED_TAGS: [], ALLOWED_ATTR:[], KEEP_CONTENT: true});
        s = window.DOMPurify ? DOMPurify.sanitize(s, {ADD_TAGS: ['q-image','q-imagecaption']}) : s;
      }

      // linkify
      if(linkify){
        s = " "+s;
        // prevent links including &nbsp; chars
        s = s.replace(/<a[^>]*?href="([^"]+)"[^>]*>(.*?)<\/a>/ig, function(match, p1, p2){
          p1 = p1.replace(/&nbsp;/g," ");
          var url = String(p1 || "").replace(/&nbsp;/g, " ").trim();
          if (!/^(https?|ftp):\/\//i.test(url)) url = "";
          if (!url) return p2;
          var classes = match.match(/class="(.*?)"/i);
          var className = "weblink";
          if(classes && classes.length == 2){
            className = classes[1]; // copy from source
          }
          return '<span class="'+self.escapeAttr(className)+'" onclick="event.stopPropagation();mc.openWeblink({DataJSON:{URL:\''+ self.escapeJSString(url) +'\'}},null,\'auto\')">'+p2+'</span>';
        });

        s = s.replace(/([^'"=?])(\b(https?|ftp):\/\/[-A-Z0-9+&@#\/%?=~_|!:,.;]*[-A-Z0-9+&@#\/%=~_|])/gim,function(match, p1, p2){
          p2 = p2.replace(/&nbsp;/g," ");
          return p1 + ' <span class="weblink" onclick="event.stopPropagation();mc.openWeblink({DataJSON:{URL:\''+ self.escapeJSString(p2)+'\'}},null,\'auto\')">'+p2+'</span>';
        });

        // add ?? ... ?? hints
        s = s.replace(/\?\?([^?]+?)\?\?/gim,function(match, p1, p2){
          function escapeHtml(unsafe) {
              return unsafe
                   .replace(/&/g, "&amp;")
                   .replace(/</g, "&lt;")
                   .replace(/>/g, "&gt;")
                   .replace(/"/g, "&quot;")
                   .replace(/'/g, "&#039;");
          };
          return '<i class="popup" text="'+escapeHtml(p1)+'"></i>';
        });
      }
      self.needUpdateJQueryStuff = true;
      self.refreshMathJax = true;

      return $sce.trustAsHtml($.trim(s));
    };

    self.bindHTML = function(scope,name,value,returns, linkify, disableSanitize){
      var reload = false;
      if(typeof scope["bindHTML_"+name] !== 'undefined'){
        if(scope["bindHTML_"+name+"_value"] != value){
          reload = true;
        }
      }else{
        reload = true;
      }    
      if(reload){
        scope["bindHTML_"+name] = self.trustAsHTML(value, returns, linkify, disableSanitize);
        scope["bindHTML_"+name+"_value"] = value;
      }  
      // refresh now once
      self.needUpdateJQueryStuff = true;
      self.refreshMathJax = true;
      return scope["bindHTML_"+name];
    }

    // let intervall check if update required
    self.updateJQueryStuffInterval = setInterval(self.updateJQueryStuff,100);

    self.getStarsHTML = function(n){
      var s = "";
      for(var i=0; i < n; i++)
        s += '<div class="star"><i class="fa fa-fw fa-star"></i></div>';
      return s;
    };
    self.hasMarkedHTMLText = function(s){
      return !!s.match(/style="[^"]*background-color/);
    };
    self.filterMarkedHTMLText = function(s){
      // removes all parts without color marking
      var r = document.createElement("div");
      var d = document.createElement("div");
      d.innerHTML = s;
      var spans = $(d).find("*");
      var d2 = null;
      var lastParent = null;
      spans.each(function( index ) {
        var col = $(this).css('background-color').toLowerCase();
        if(col != '' && col != 'rgb(255, 255, 255)' && col != '#ffffff'){
          if(lastParent != this.parentNode){
            lastParent = this.parentNode;
            d2 = document.createElement("div");
            d2.appendChild(this);
            r.appendChild(d2);
          }else{
            var space = document.createElement("span");
            space.innerHTML = " ... ";
            space.style.display = "inline-block";
            space.style.margin = "0em 0.2em";
            d2.appendChild(space);
            d2.appendChild(this);
          }
        }
      });
      return r.innerHTML;
    };

    self.filterArray = function(a){
      // a = {Date:d.date,DataJSON:{Coaching:1}}
      return function( item ) {
        for(var k in a){
          if(typeof(a[k]) == "object"){
            for(var k2 in a[k]){
              if(a[k][k2] === null) {
                if(!(typeof item[k] === 'undefined' || typeof item[k][k2] === 'undefined' || item[k][k2] === null)) return false;
              }else
                if(item[k][k2] != a[k][k2]) return false;
            }
          }else{
            if(a[k] === null) {
              if(!(typeof item[k] === 'undefined' || item[k] === null)) return false;
            }else
              if(item[k] != a[k]) return false;
          }
        }
        return true;
      };
    };

    self.lastAlertDialog = null;

    self.alertAndDisable = function (ref, msg,ev,closeLastOpen){
      var deferred = $q.defer();
      // skip if disabled 
      if(self.userViewData && self.userViewData["hide_"+ref] == 1){
        deferred.resolve();
        return deferred.promise;
      }

      if(msg.indexOf("<") < 0) msg = '<div style="max-width:500px">'+msg+'</div>';
      if(self.lastAlertDialog && closeLastOpen){
        self.lastAlertDialog = null;
        self.closeDialog(self.lastAlertDialog);
      }
      self.showDialog({
        template:
            '<md-dialog style="min-width:300px;max-width:90%">' +
            '  <md-content style="padding:24px" ng-bind-html="msg"></md-content>' +
            '  <md-content style="padding-left:24px"><md-checkbox ng-model="donotshowagain">'+$filter('trans')('DONOTSHOWAGAIN')+'</md-checkbox></md-content>' +
            '  <md-dialog-actions>' +
            '    <md-button md-autofocus="true" ng-click="ok()">' +
            '      OK' +
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>',
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          self.lastAlertDialog = null;
          deferred.resolve();
        },
        controller: function ($scope, $mdDialog) {
          $scope.msg = self.trustAsHTML(msg,true,true);
          setTimeout(function(){
            self.lastAlertDialog = $scope.dialogElement;
          },100);          
          
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
            if($scope.donotshowagain){
              self.userViewData["hide_"+ref] = 1;
              self.updateUserViewData();
            }
          };
        }
      });
      return deferred.promise;
    };

    self.alert = function (msg,ev,closeLastOpen, allowDisable){
      var deferred = $q.defer();

      if(msg.indexOf("<") < 0) msg = '<div style="max-width:500px">'+msg+'</div>';
      if(self.lastAlertDialog && closeLastOpen){
        self.lastAlertDialog = null;
        self.closeDialog(self.lastAlertDialog);
      }
      self.showDialog({
        template:
            '<md-dialog style="min-width:300px;max-width:90%">' +
            '  <md-content style="padding:24px" ng-bind-html="msg"></md-content>' +
            '  <md-dialog-actions>' +
            '    <md-button md-autofocus="true" ng-click="ok()">' +
            '      OK' +
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>',
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          self.lastAlertDialog = null;
          deferred.resolve();
        },
        controller: function ($scope, $mdDialog) {
          $scope.msg = self.trustAsHTML(msg,true,true);
          setTimeout(function(){
            self.lastAlertDialog = $scope.dialogElement;
          },100);          
          
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.errorToastCounter = 0;
    self.errorToastContents = [];
    self.errorToast = function(message,error) {
      var first = self.errorToastContents.length == 0;
      var found = false;
      for(var i = 0; i < self.errorToastContents.length; i++){
        if(self.errorToastContents[i].text == message){
          if(error) self.errorToastContents[i].errors.push(error); else self.errorToastContents[i].count++;
          found = true;
          break;
        }
      }
      if(!found){
        var e = {text:message,errors:[], count:1};
        if(error) e.errors.push(error);        
        self.errorToastContents.push(e);
      }

      if(first)
        $mdToast.show({
          template: `
            <md-toast class="error-toast">
              <span class="md-toast-text" ng-repeat="m in messages track by $index">
               {{m.text}} (<span ng-if="m.errors.length > 0" ng-repeat="e in m.errors track by $index">{{e}} </span><span ng-if="m.errors.length == 0">{{m.count}}</span>)
              </span>
              <md-button class="md-toast-close" aria-label="close" ng-click="closeToast()"><i class="fa fa-fw fa-times"></i></md-button>
            </md-toast>
          `,
          controller: function($scope, $mdToast) {
            self.errorToastCounter++;
            $scope.messages = self.errorToastContents;
            $scope.closeToast = function() {
              $mdToast.hide();
              self.errorToastContents = [];
            };
          },
          hideDelay: 0, // stay until manually closed
          position: 'top right'
        });
    };

    self.confirmAndHide = function (ref, msg,oklabel,ev,cancellabel,defaultOK){
      var deferred = $q.defer();
      // skip if hidden in current session 
      if(self["hide_"+ref] == -1){
        deferred.reject();
        return deferred.promise;
      }
      if(self["hide_"+ref] == 1){
        deferred.resolve();
        return deferred.promise;
      }

      if(msg.indexOf("<") < 0) msg = '<div style="max-width:500px">'+msg+'</div>';
      self.showDialog({
        template:
            '<md-dialog style="min-width:300px;max-width:90%;width: 400px;">' +
            '  <md-content style="padding:24px" ng-bind-html="msg"></md-content>' +
            '  <md-content style="padding-left:24px"><md-checkbox ng-model="donotaskagain">'+$filter('trans')('DONOTASKAGAINTODAY')+'</md-checkbox></md-content>' +
            '  <md-dialog-actions>' +
            '    <md-button ng-click="cancel()">' +
                  (cancellabel ? cancellabel : $filter('trans')('CANCEL'))+
            '    </md-button>' +
            '    <md-button md-autofocus="true" class="md-primary" ng-click="ok()">' +
                  (oklabel ? oklabel : $filter('trans')('OK'))+
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>',
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          if(!deferred.isDone) {
            if(defaultOK) deferred.resolve(); else deferred.reject();
          }
        },
        controller: function ($scope, $mdDialog) {
          $scope.msg = self.trustAsHTML(msg,true,true);
          $scope.ok = function() {
            if($scope.donotaskagain){
              self["hide_"+ref] = 1;
            }
            deferred.resolve();
            deferred.isDone = true;
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            if($scope.donotaskagain){
              self["hide_"+ref] = -1;
            }
            deferred.reject();
            self.closeDialog($scope.dialogElement);
          };
        }
      });

      return deferred.promise;
    };

    self.confirm = function (msg,oklabel,ev,cancellabel,defaultOK){
      var deferred = $q.defer();

      if(msg.indexOf("<") < 0) msg = '<div style="max-width:500px">'+msg+'</div>';
      self.showDialog({
        template:
            '<md-dialog style="min-width:300px;max-width:90%;width: 400px;">' +
            '  <md-content style="padding:24px" ng-bind-html="msg"></md-content>' +
            '  <md-dialog-actions>' +
            '    <md-button ng-click="cancel()">' +
                  (cancellabel ? cancellabel : $filter('trans')('CANCEL'))+
            '    </md-button>' +
            '    <md-button md-autofocus="true" class="md-primary" ng-click="ok()">' +
                  (oklabel ? oklabel : $filter('trans')('OK'))+
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>',
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: true,
        onRemoving: function (event, removePromise) {
          if(!deferred.isDone) {
            if(defaultOK) deferred.resolve(); else deferred.reject();
          }
        },
        controller: function ($scope, $mdDialog) {
          $scope.msg = self.trustAsHTML(msg,true,true);
          $scope.ok = function() {
            deferred.resolve();
            deferred.isDone = true;
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            deferred.reject();
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.prompt = function (msg,oklabel,inputlabel,inputvalue,ev,cancellabel){
      var deferred = $q.defer();

      if(msg.indexOf("<") < 0) msg = '<div style="max-width:500px">'+msg+'</div>';
      self.showDialog({
        template:
            '<md-dialog style="min-width:300px;max-width:90%">' +
            '  <md-content style="padding:24px;padding-bottom:0" ng-bind-html="msg"></md-content>' +
            '  <md-input-container style="margin:22px;width:auto">' +
            '    <label>'+inputlabel+'</label>' +
            '    <input md-autofocus="true" ng-model="textinput" type="text"/>' +
            '  </md-input-container>' +
            '  <md-dialog-actions>' +
            '    <md-button ng-click="cancel()">' +
                  (cancellabel ? cancellabel : $filter('trans')('CANCEL'))+
            '    </md-button>' +
            '    <md-button ng-disabled="!textinput || textinput == \'\'" class="md-primary" ng-click="ok()">' +
                  (oklabel ? oklabel : $filter('trans')('OK'))+
            '    </md-button>' +
            '  </md-dialog-actions>' +
            '</md-dialog>',
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.msg = self.trustAsHTML(msg,true,true);
          $scope.textinput = inputvalue ? inputvalue : "";
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve($scope.textinput);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.reject();
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.pickColor = function(currentColor){
      var deferred = $q.defer();

      var normalizeHexColor = function(value){
        if(value === undefined || value === null) return "";
        var hex = $.trim(String(value));
        if(hex === "") return "";
        if(hex.charAt(0) !== "#") hex = "#" + hex;
        if(/^#([0-9a-fA-F]{3})$/.test(hex)){
          hex = "#" +
            hex.charAt(1) + hex.charAt(1) +
            hex.charAt(2) + hex.charAt(2) +
            hex.charAt(3) + hex.charAt(3);
        }
        if(/^#([0-9a-fA-F]{6})$/.test(hex)) return hex.toLowerCase();
        return "";
      };

      var rgbToHex = function(r,g,b){
        var toHex = function(n){
          var x = parseInt(n,10);
          if(!isFinite(x)) x = 0;
          if(x < 0) x = 0;
          if(x > 255) x = 255;
          var h = x.toString(16);
          return h.length < 2 ? "0"+h : h;
        };
        return "#" + toHex(r) + toHex(g) + toHex(b);
      };

      var initialColor = normalizeHexColor(currentColor);
      if(!initialColor) initialColor = "#03a9f4";

      self.showDialog({
        templateUrl: "pickColorDialog.html",
        skipHide: true,
        clickOutsideToClose: true,
        escapeToClose: true,
        onRemoving: function () {
          if(!deferred.isDone) deferred.reject();
        },
        controller: function ($scope, $timeout) {
          $scope.hexInput = initialColor;
          $scope.selectedColor = initialColor;
          $scope.gradientCursor = {x:130, y:75};
          $scope.gradientSize = {width:260, height:150};

          $scope.getGradientCursorStyle = function(){
            return {
              left: $scope.gradientCursor.x + "px",
              top: $scope.gradientCursor.y + "px"
            };
          };

          $scope.isHexValid = function(){
            return normalizeHexColor($scope.hexInput) !== "";
          };

          $scope.onHexInputChange = function(){
            var normalized = normalizeHexColor($scope.hexInput);
            if(normalized){
              $scope.selectedColor = normalized;
              $scope.hexInput = normalized;
              setCursorFromHex(normalized);
            }
          };

          var hexToRgb = function(hex){
            var normalized = normalizeHexColor(hex);
            if(!normalized) return null;
            return {
              r: parseInt(normalized.substr(1,2),16),
              g: parseInt(normalized.substr(3,2),16),
              b: parseInt(normalized.substr(5,2),16)
            };
          };

          var gradientCanvas = null;
          var gradientCtx = null;
          var drawGradient = function(){
            if(!gradientCanvas) return;
            var w = gradientCanvas.width;
            var h = gradientCanvas.height;
            var ctx = gradientCanvas.getContext("2d");
            if(!ctx) return;
            gradientCtx = ctx;

            // base hue strip
            var hue = ctx.createLinearGradient(0, 0, w, 0);
            hue.addColorStop(0.00, "#ff0000");
            hue.addColorStop(0.17, "#ffff00");
            hue.addColorStop(0.33, "#00ff00");
            hue.addColorStop(0.50, "#00ffff");
            hue.addColorStop(0.67, "#0000ff");
            hue.addColorStop(0.83, "#ff00ff");
            hue.addColorStop(1.00, "#ff0000");
            ctx.fillStyle = hue;
            ctx.fillRect(0, 0, w, h);

            // top-to-bottom brightness modulation
            var light = ctx.createLinearGradient(0, 0, 0, h * 0.5);
            light.addColorStop(0, "rgba(255,255,255,0.9)");
            light.addColorStop(1, "rgba(255,255,255,0)");
            ctx.fillStyle = light;
            ctx.fillRect(0, 0, w, h);

            var dark = ctx.createLinearGradient(0, h * 0.4, 0, h);
            dark.addColorStop(0, "rgba(0,0,0,0)");
            dark.addColorStop(1, "rgba(0,0,0,0.9)");
            ctx.fillStyle = dark;
            ctx.fillRect(0, 0, w, h);
          };

          var setCursorFromHex = function(hex){
            if(!gradientCanvas || !gradientCtx) return;
            var rgb = hexToRgb(hex);
            if(!rgb) return;

            var w = gradientCanvas.width;
            var h = gradientCanvas.height;
            if(!w || !h) return;

            var image = gradientCtx.getImageData(0, 0, w, h).data;
            var bestX = 0;
            var bestY = 0;
            var bestDist = Number.POSITIVE_INFINITY;

            for(var y = 0; y < h; y++){
              for(var x = 0; x < w; x++){
                var idx = (y * w + x) * 4;
                var dr = image[idx] - rgb.r;
                var dg = image[idx + 1] - rgb.g;
                var db = image[idx + 2] - rgb.b;
                var dist = dr*dr + dg*dg + db*db;
                if(dist < bestDist){
                  bestDist = dist;
                  bestX = x;
                  bestY = y;
                  if(dist === 0) break;
                }
              }
              if(bestDist === 0) break;
            }

            var rect = gradientCanvas.getBoundingClientRect();
            var displayW = rect && rect.width ? rect.width : w;
            var displayH = rect && rect.height ? rect.height : h;
            var cursorX = (bestX / Math.max(1, w - 1)) * displayW;
            var cursorY = (bestY / Math.max(1, h - 1)) * displayH;

            if(cursorX < 0) cursorX = 0;
            if(cursorY < 0) cursorY = 0;
            if(cursorX > displayW) cursorX = displayW;
            if(cursorY > displayH) cursorY = displayH;

            $scope.gradientCursor.x = cursorX;
            $scope.gradientCursor.y = cursorY;
          };

          $scope.selectColorFromGradient = function(ev){
            if(!gradientCanvas || !gradientCtx) return;
            var rect = gradientCanvas.getBoundingClientRect();
            if(!rect || rect.width <= 0 || rect.height <= 0) return;

            var x = ev.clientX - rect.left;
            var y = ev.clientY - rect.top;
            if(x < 0) x = 0;
            if(y < 0) y = 0;
            if(x > rect.width - 1) x = rect.width - 1;
            if(y > rect.height - 1) y = rect.height - 1;

            $scope.gradientCursor.x = x;
            $scope.gradientCursor.y = y;

            var sampleX = Math.round((x / rect.width) * (gradientCanvas.width - 1));
            var sampleY = Math.round((y / rect.height) * (gradientCanvas.height - 1));
            var pixel = gradientCtx.getImageData(sampleX, sampleY, 1, 1).data;
            var hex = rgbToHex(pixel[0], pixel[1], pixel[2]);
            $scope.selectedColor = hex;
            $scope.hexInput = hex;
            $scope.$applyAsync();
          };

          $scope.confirm = function(){
            var normalized = normalizeHexColor($scope.hexInput);
            if(!normalized) return;
            deferred.isDone = true;
            deferred.resolve(normalized);
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function(){
            deferred.isDone = true;
            deferred.reject();
            self.closeDialog($scope.dialogElement);
          };

          $timeout(function(){
            var root = $scope.dialogElement && $scope.dialogElement[0] ? $scope.dialogElement[0] : document;
            gradientCanvas = root.querySelector(".pickColorCanvas");
            if(!gradientCanvas) return;
            drawGradient();
            setCursorFromHex($scope.selectedColor);
            $scope.$applyAsync();
          },0);
        }
      });

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showClassMainTopicFilterDialog = function(filterSettings,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classMainTopicFilterDialog.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        state:"modalTop",
        onRemoving: function (event, removePromise) {
          deferred.resolve();
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          if(filterSettings)
            $scope.$watch('self.currentClassResultMainTopicFilter', function() {
              filterSettings.WHERETOPICS = self.currentClassResultMainTopicFilter;
            });          
          
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.resetUserTasksFilters = function(goal){
      delete (self.userViewData["tlf_"+self.currentTopic.ID]);
      delete (self.userViewData["gsf_"+goal.ID]);
      self.updateUserViewData();
    };
    self.displayItemLevel = function(value){
      if(value == 1.5) return "1/2";
      if(value == 2.5) return "2/3";
      if(value == 3.5) return "3/4";
      if(value == 4.5) return "4/5";
      return value;
    }
    self.setUserLevelFilter = function(value){
      var n = self.userViewData["tlf_"+self.currentTopic.ID] ? parseInt(self.userViewData["tlf_"+self.currentTopic.ID]) : 0;
      if((n & value) === value) {
        n = n & ~value;
      }else{
        n = n | value; 
      }
      self.userViewData["tlf_"+self.currentTopic.ID] = n;
      self.updateUserViewData();
    };
    self.getUserLevelFilter = function(topic){
      if(!topic) topic = self.currentTopic; 
      return self.userViewData["tlf_"+topic.ID] ? self.userViewData["tlf_"+topic.ID] : 0;
    };

    self.isUserLevelInFilter = function(topic, n){
      var level = self.getUserLevelFilter(topic); // aktive Filter-Bitmaske
      var num = parseFloat((n + "").replace(",", "."));
      if(!isFinite(num) || num <= 0) return false;

      var p = [0,1,2,4,8,16,32];

      var low = Math.floor(num);   // z.B. 3
      var high = Math.ceil(num);   // z.B. 4

      var taskMask = 0;
      if(low >= 1 && low <= 5) taskMask |= p[low];
      if(high >= 1 && high <= 5) taskMask |= p[high];

      // Treffer, wenn irgendein Bit übereinstimmt
      return (level & taskMask) !== 0;
    };

    self.coutUserLevelFiltered = function(topic,goal){
      var f = self.getUserLevelFilter(topic);
      if(f == 0) return 0;
      var r = 0;
      for(var z=0; z < goal.tasks.length; z++){
        if(goal.tasks[z].Level && goal.tasks[z].Level != "0" &&
          !self.isUserLevelInFilter(topic,goal.tasks[z].Level)){
          r++;
        }
      }        
      return r;
    };

    self.getUserTaskLevelsInTopic = function(){
      var r = [];
      for(var i=0; i < self.learningGoalsList.length; i++){
        for(var z=0; z < self.learningGoalsList[i].tasks.length; z++){
          if(self.learningGoalsList[i].tasks[z].Level && self.learningGoalsList[i].tasks[z].Level != 0){
            if(self.learningGoalsList[i].tasks[z].Level == 1.5){
              if(r.indexOf("1") == -1) r.push("1");
              if(r.indexOf("2") == -1) r.push("2");
            }else
            if(self.learningGoalsList[i].tasks[z].Level == 2.5){
              if(r.indexOf("2") == -1) r.push("2");
              if(r.indexOf("3") == -1) r.push("3");
            }else
            if(self.learningGoalsList[i].tasks[z].Level == 3.5){
              if(r.indexOf("3") == -1) r.push("3");
              if(r.indexOf("4") == -1) r.push("4");
            }else
            if(self.learningGoalsList[i].tasks[z].Level == 4.5){
              if(r.indexOf("4") == -1) r.push("4");
              if(r.indexOf("5") == -1) r.push("5");
            }else
            if(r.indexOf(self.learningGoalsList[i].tasks[z].Level) == -1)
               r.push(self.learningGoalsList[i].tasks[z].Level);
          }
        }        
      }
      return r;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getUserLearningGoalFilterStickers = function(topic, goal){
      if(!self.learningGoalStickerFilter) self.learningGoalStickerFilter = {};
      if(!self.learningGoalStickerFilter[goal.ID]) self.learningGoalStickerFilter[goal.ID] = [];
      var stickers = self.learningGoalStickerFilter[goal.ID];
      while(stickers.length > 0) stickers.pop(); // clear first

      var f = self.getUserLevelFilter(topic);

      for(var i=0; i < goal.tasks.length; i++){
        if(f != 0 && goal.tasks[i].Level && 
          !self.isUserLevelInFilter(topic,goal.tasks[i].Level)) continue; // skip

        var s = self.getUserTaskStatus(goal.tasks[i],self.user,true);
        if(s.Note && s.Note.indexOf("<i class") != -1){
          // icon sticker
          var n = s.Note.replace('¶','');
          if(stickers.indexOf(n) == -1) stickers.push(n);
        }
      }
      return stickers.length > 0 ? stickers : null;
    };

    self.countUserSickerFiltered = function(topic,goal){
      var r = 0;
      var sticker = self.getUserStickerFilter(goal);
      if(!sticker) return 0;

      var f = self.getUserLevelFilter(topic);
      var found = 0;
      for(var i=0; i < goal.tasks.length; i++){
        if(f != 0 && goal.tasks[i].Level && 
          !self.isUserLevelInFilter(topic,goal.tasks[i].Level)) {
          continue;       
        }
        var s = self.getUserTaskStatus(goal.tasks[i],self.user,true);
        if(!s.Note || s.Note == '' || s.Note.replace('¶','') != sticker) {
          r++;
        }else{
          found++;
        }
      }        
      if(goal.tasks.length == r || !found){
        // all filtered, reset filters
        delete (self.userViewData["gsf_"+goal.ID]);
        self.updateUserViewData();
        return 0;
      }
      return r;
    };

    self.getUserStickerFilter = function(goal){
      return self.userViewData["gsf_"+goal.ID] ? self.userViewData["gsf_"+goal.ID] : null;
    };

    self.setUserStickerFilter = function(goal, sticker){
      self.userViewData["gsf_"+goal.ID] = sticker;
      self.updateUserViewData()
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showStudentGoalResultMenu = function(g,student,ev,hideJournal){
//      var visible = self.isUserLearningGoalVisibleDeep(self.currentMainTopic,
//                        self.currentTopic,g,student);
//      if(!visible) return;
      if(!self.hasClassReviewPermission(self.currentClass)) return; // do nothing

      var position = $mdPanel.newPanelPosition()
          .absolute().relativeTo(ev.target)
          .addPanelPosition('align-start', 'below')
          .addPanelPosition('align-start', 'center')
          .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.FADE);
//
      var config = {
        attachTo: angular.element(document.body),
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        templateUrl: "showStudentGoalResultMenu.html",
        controller: function ($scope, $mdPanel, mdPanelRef) {
          $scope.self = self;
          $scope.g = g;
          $scope.s = student;
          $scope.userStatus = self.getUserLearningGoalStatus(g,student,true);
          $scope.showJournal = !hideJournal;
          $scope.close = function(){
            mdPanelRef.close();
          };
        },
        position: position,
        animation: panelAnimation,
        openFrom: ev,
        closeTo: null,
        skipHide:true,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true,
        zIndex: 200
      };

      self.showPanel(config);
    };

    self.showClassCorrections = function(ev){
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "classCorrections.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.$mdDialog = $mdDialog;
            $scope.smallScreen = self.isSmallScreen;
            self.feedbackIsRecording = false;

            self.currentCorrectionListLimit = Math.round($(window).height() / 140);

            $scope.filterSettings = {
              WHAT: self.selectedClassCorrectionFilter,
              WHERE: "all",
              WHERETOPICS: self.currentClassResultMainTopicFilter.slice(0), // copy
              isCorrections: true
            };

            if($scope.filterSettings.WHERETOPICS &&
               $scope.filterSettings.WHERETOPICS.length > 0){
               $scope.filterSettings.WHERE = "maintopics";
            }

            $scope.$watch('filterSettings', function() {
              // store changed time to global settings

              if($scope.filterSettings.WHERETOPICS &&
                 $scope.filterSettings.WHERETOPICS.length == 0 &&
                 $scope.filterSettings.WHERE == 'maintopics'){
                $scope.filterSettings.WHERE = 'all';
                self.currentClassResultMainTopicFilter = [];
                self.selectedClassActivityPlace = $scope.filterSettings.WHERE;
              }

              if($scope.filterSettings.WHERETOPICS &&
                 $scope.filterSettings.WHERETOPICS.length > 0){
                $scope.filterSettings.WHERE = 'maintopics';
                self.currentClassResultMainTopicFilter = $scope.filterSettings.WHERETOPICS;
                self.selectedClassActivityPlace = $scope.filterSettings.WHERE;
              }
              self.selectedClassCorrectionFilter = $scope.filterSettings.WHAT;
              self.updateClassCorrectionFilter();
            },true);

            if(self.currentClassResultMainTopicFilter &&
               self.currentClassResultMainTopicFilter.length > 0){
               self.selectedClassActivityPlace = "maintopics";
            }

            $scope.showMoreCorrectionItems= function(){
              var now = self.currentClass.hasFilteredCorrections;
              self.correctionSearchTerm = '';
              $scope.filterSettings.WHAT = 'all';
              self.selectedClassCorrectionFilter = $scope.filterSettings.WHAT;
              self.updateClassCorrectionFilter();
              if(now > self.currentClass.hasFilteredCorrections) return;
              if($scope.filterSettings.WHERE != "all"){
                $scope.filterSettings.WHERE = "all";
                $scope.filterSettings.WHERETOPICS = [];
                self.currentClassResultMainTopicFilter = [];
                self.selectedClassActivityPlace = "all";

                //1007
                self.chooseFilterMainTopicList(null);
                self.updateUserClassViewData(self.currentClass.ID);

                self.updateClassCorrectionFilter();
              }

              self.updateClassesStatus();
              self.updateNewActivityBadge();
              self.updateNewFolderItemsBadge();
            };

            $scope.showCorrectionFilterPanel = function(scope,ev){
              var parent = $scope;

              var position = $mdPanel.newPanelPosition()
                  .absolute().relativeTo(ev.target)
                  .addPanelPosition('align-start', 'below')
                  .addPanelPosition('align-start', 'center')
                  .addPanelPosition('align-start', 'above');

              var panelAnimation = $mdPanel.newPanelAnimation()
                  .openFrom(ev)
                  .withAnimation($mdPanel.animation.SCALE);

              var config = {
                attachTo: angular.element(document.body),
                onDomAdded: function(e){
                  var menu = e[1];
                  self.limitPanelToViewport(menu._panelEl);
                  var container = menu._panelContainer.get(0);
                  container.addEventListener("click", function (e) {
                    if (e.target === container) {
                      menu.close();
                    }
                  });          
                },
                templateUrl: "classcorrectionFilterMenuPanel.html",
                controller: function ($scope, $mdPanel, mdPanelRef) {
                  $scope.self = self;
                  $scope.filterSettings = parent.filterSettings;
                  $scope.close = function(){ mdPanelRef.close(); };
                },
                position: position,
                animation: panelAnimation,
                openFrom: ev,
                clickOutsideToClose: true,
                escapeToClose: true,
                focusOnOpen: true,
                zIndex: 200
              };

              self.showPanel(config);
            };


            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };


    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // editing classes
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editingClass = null;

    self.changeAvatarImage = function(student){
      if(self.user.Teacher == 0 && parseInt(student.Avatar) < 0){
        self.alert($filter('trans')('CHANGEAVATARLOCKED'));
        return;
      }
      self.takeUserMedia("avatar",self.getAvatarImage(student.ID),function(results){
        self.apiPost("ajax",{"action":"updateAvatarImage", "ID":student.ID,"salt":student.Salt, "image":results[0].URL})
          .then(function(data) {
            if(data.Avatar) {
              student.Avatar = data.Avatar;
              self.users[student.ID].Avatar = data.Avatar;
            }
            self.keepAliveCallback();
          });
      }, {dialogMode: 2, student:student});
    };

    self.changeClassImage = function(c){
      self.takeUserMedia("image",c.Image != '0' ? self.getClassImage(c) :null,function(results){
        self.apiPost("ajax",{"action":"updateClassImage", "ID":c.ID, "image":results[0].URL})
          .then(function(data) {
            c.Image = (c.Image ? c.Image : 0) + 1;
          });
      }, {dialogMode: 0});
    };

    self.getAvatarImage = function(id,name){
      var s = self.users[id];
      var cache = (s && s.Avatar ? s.Avatar : false );
      return "https://learningview.org/img.php?t=a&id="+id+"&name="+encodeURIComponent(name ? name : (s && s.Name ? s.Name : ''))+(cache ? "&cache="+cache : "");
    };

    self.getClassImage = function(c){
      var cache = (c && c.Image ? c.Image : false );
      return "https://learningview.org/img.php?t=c&id="+c.ID+"&name="+encodeURIComponent(c && c.Name ? c.Name : '')+(cache ? "&cache="+cache : "");
    };

    self.startCreateAvatar = function(scope,ev){  
      var wasSaved = false;    
      var thisScope = null;
      var postMessage = function(e){
        if(e.data && e.data.indexOf && e.data.indexOf("AVATARSAVED|") === 0){
          var url = "https://learningview.org/svgavatars/ready-avatars/"+e.data.replace("AVATARSAVED|","");
          wasSaved = true;
          self.closeDialog(thisScope.dialogElement);
          self.showLoadingIndicator(ev,function(done){
            thisScope = null;
            scope.$parent.$parent.imageURL = url;
            scope.$parent.$parent.save();
            done();
          })
        }
      };
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          window.removeEventListener("message",postMessage);
        },

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          window.addEventListener("message",postMessage);
          $scope.url = ("https://learningview.org/svgavatars");
          $scope.self = self;
          thisScope = $scope;
          $scope.ok = function() {
            if(!wasSaved){
              self.confirm($filter('trans')('ASKCANCELAVATAR'),$filter('trans')('CANCEL'),null,$filter('trans')('BACK')).then(function(){
                self.closeDialog($scope.dialogElement);

              });
            } else
              self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.loginWithOAuthInterval = null;

    self.loginWithMicrosoft = function(ev){
      self.apiPost("loginPending",{"getCode":1}).then(function(data) {
        var code = data.code;
        var url = "https://learningview.org/loginWithMS.php?fromApp=1&code="+encodeURIComponent(code);
        self.openWeblink({DataJSON:{URL:url}},ev,false);
        // check if login worked
        var counter = 0;
        if(self.loginWithOAuthInterval) clearInterval(self.loginWithOAuthInterval);
        self.loginWithOAuthInterval = setInterval(function(){
          // check every 2,5 seconds
          self.apiPost("loginPending",{"check":code}).then(function(data) {
            if(data.user) {
              self.loginUser(data.user);
              clearInterval(self.loginWithOAuthInterval);
              self.loginWithOAuthInterval = null;
            }
            if(counter > 1000){
              clearInterval(self.loginWithOAuthInterval);
              self.loginWithOAuthInterval = null;            
            }
            counter++;
          },function(data){
            self.alert("Verbindung fehlgeschlagen.");
            clearInterval(self.loginWithOAuthInterval);
            self.loginWithOAuthInterval = null;
          });
        },2500);
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.askCountryAndState = function(){
      if(self.user && self.user.Teacher == 1 &&
        (!self.user.Country  || self.user.Country == "")){

        var dn = new Date();
        var d = new Date().fromMysqlFormat(self.user.Created);
        // less than 1 days ago?
        if(Math.abs(d.getTime() - dn.getTime()) < (1000 * 3600 * 24)*1 ) return true;

        // ask for country now
        self.showDialog({
          templateUrl: "askCountryAndState.html",
          targetEvent: null,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.Country = "";
            $scope.State = self.user.State ? self.user.State : "";

            $scope.isValid = function(){
              if(!$scope.Country || $scope.Country == "") return false;
              if($scope.Country == "LI") $scope.State = "LI-LI";
              if($scope.Country != "OTH" && (!$scope.State || $scope.State == "")) return false;
              return true;
            };

            $scope.save = function (){
              if(!$scope.isValid()) return;
              self.apiPost("ajax",{"action":"changeUserSetting", "param":"Country", "value": $scope.Country}).then(function(data) {
                if($scope.State && $scope.State != "")
                  self.apiPost("ajax",{"action":"changeUserSetting", "param":"State", "value": $scope.State}).then(function(data) {

                  });
              });
              self.closeDialog($scope.dialogElement);
            };

            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };

          }
        });
        return false;
      }
      return true;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.askSchoolManaged = function(){
      if(self.user && self.user.Teacher == 1 &&
        (self.user.SchoolManaged == "-1")) {
        // ask for school now
        self.showDialog({
          templateUrl: "askSchoolManaged.html",
          targetEvent: null,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.selectedSchool = null;

            self.apiPost("ajax",{"action":"getSchools"}).then(function(data) {
              $scope.schools = data.schools;
              for(var i=0; i < $scope.schools.length; i++){
                if($scope.schools[i].ID == -(parseInt(self.user.SchoolManaged))){
                  $scope.selectedSchool = $scope.schools[i].ID;
                }
              }
            });

            $scope.selectSchool = function (){
              if($scope.selectedSchool > 0)
              self.apiPost("ajax",{"action":"getSchoolAdmins", "id":$scope.selectedSchool}).then(function(data) {
                $scope.admins = data.admins;
              });
            };

            $scope.save = function (){
              self.apiPost("ajax",{"action":"changeUserSetting", "param":"SchoolManaged", "value":$scope.selectedSchool}).then(function(data) {
                self.user.SchoolManaged = $scope.selectedSchool;
              });
              self.closeDialog($scope.dialogElement);
            };

            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };

          }
        });
        return false;
      }
      if(self.user && self.user.Teacher == 1 &&
        (self.user.SchoolManaged && parseInt(self.user.SchoolManaged) < -1)) {
        // asked for a specific school
        self.apiPost("ajax",{"action":"getSchoolInvited"}).then(function(data) {
          self.askSchoolManagedInvited(data);
        });
        return false;
      }
      return true;
    };

    self.askSchoolManagedInvited = function(data){
      if(self.user && self.user.Teacher == 1) {
        self.showDialog({
          templateUrl: "askSchoolManagedInvited.html",
          targetEvent: null,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.school = data;
            $scope.admins = data.admins;

            $scope.save = function (){
              self.apiPost("ajax",{"action":"changeUserSetting", "param":"SchoolManaged", "value":$scope.school.ID}).then(function(data) {
                self.user.SchoolManaged = $scope.school.ID;
              });
              self.closeDialog($scope.dialogElement);
            };
            $scope.deny = function (){
              self.apiPost("ajax",{"action":"changeUserSetting", "param":"SchoolManaged", "value":0}).then(function(data) {
                self.user.SchoolManaged = 0;
              });
              self.closeDialog($scope.dialogElement);
            };

            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };

          }
        });
        return false;
      }
      return true;
    };
    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.changeUserSetting = function(p, v){
      self.apiPost("ajax",{"action":"changeUserSetting", "param":p, "value":v}).then(function(){
        self.user[p] = v;
        self.changeClassNameOrder();
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.changeClassNotificationsSettings = function(ev){
      self.showDialog({
        templateUrl: "changeClassNotificationsSettings.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.settings = null;
          self.apiPost("ajax",{"action":"getClassNotificationSettings", "classid":self.editingClass.ID}).then(function(data) {
            $scope.settings = data.settings;
            $scope.getTime = data.settings.get.from == "06:00" && data.settings.get.to == "18:00";
            $scope.sendTime = data.settings.send.from == "06:00" && data.settings.send.to == "18:00";
          });

          $scope.save = function (){
            // clean $scope.settings from all default settings now

            self.apiPost("ajax",{"action":"setClassNotificationSettings", "classid":self.editingClass.ID, "value": angular.toJson($scope.settings) }).then(function(data) {
              self.closeDialog($scope.dialogElement);
            });
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };

        }
      });

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassSettings = function(c){
      c.SettingsJSON = JSON.parse(c.Settings);

      for(var i=0; i < self.classList.length; i++){
        if(self.classList[i].ID == c.ID){
          if(self.classList[i].Settings != c.Settings){
            // settings have changed, reset journal mappings too 
            for(var z=0; z < self.classList[i].students.length; z++){
              if(self.users[self.classList[i].students[z].ID])
                self.users[self.classList[i].students[z].ID].hasMappedJournalItems = false;
            }
          }
          break;
        }
      }
    };   
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassToolSettings = function(c){
      if(!self.classToolSettings) self.classToolSettings = {};
      if(!self.classToolSettings[c.ID]) self.classToolSettings[c.ID] = {};

      var cts = self.classToolSettings[c.ID];
      for(var k in c.toolSettings){
        if(k == "Data"){
          var json = JSON.parse(c.toolSettings[k]);
          var classToolSettingLists = ["timers","groups","picks","docs","coaching"];

          for(var i=0; i < classToolSettingLists.length; i++)
            self.updateContentDeep(json,cts,[classToolSettingLists[i]]);

          for(var n in json){
            // skip lists
            if(classToolSettingLists.indexOf(n) != -1) continue;

            var old = cts[n];
            cts[n] = json[n];

            if(old != json[n] && n.indexOf("plugins_") != -1){
              for(var i=0; i < self.plugins.plugins.length; i++){
                if(n == "plugins_"+self.plugins.plugins[i].name){
                  if(self.plugins.plugins[i].dataChanged){
                    self.plugins.plugins[i].dataChanged("class", json[n], old);
                  }
                }
              }
            }
          }

          self.refreshClassToolSettings(c.ID);
        }
      }    
      // called on each refresh
      self.updateClassTabButtons(c.ID);
    };    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassTabButtons = function(classid){
      // order all tab buttons
      if(!self.tabButtons[classid]) return;
      var order = [];
      if(self.userClassViewData && self.userClassViewData[classid] && self.userClassViewData[classid]["classDocumentsOrder"]){
        order = self.userClassViewData[classid]["classDocumentsOrder"].split(",").map(Number);
      }

      self.tabButtons[classid].sort(function(a,b){
        // sort all timers to the front, newst on top of stack
        if(a.classCollaboration){
          if(b.classCollaboration){
            var p1 = order.indexOf(a.classCollaboration.ID);
            var p2 = order.indexOf(b.classCollaboration.ID);
            if(p1 == -1 && p2 != -1) return -1;
            if(p2 == -1 && p1 != -1) return 1;
            if(p1 == p2){ return b.ID - a.ID; }
            return p1-p2;
          }
          return 1;
        }
        if(b.classCollaboration){
          return -1;
        }
        return b.ID - a.ID;
      });      
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendClassToolSettings = function(classid){
      if(!self.classToolSettings) return;
      if(!self.classToolSettings[classid]) return;
      self.apiPost("ajax",{"action":"updateClassToolSettings", "noerror":1, "ID":classid,
                           "data":angular.toJson(self.classToolSettings[classid])}).then(function(){
      });
      self.refreshClassToolSettings(classid);
      self.updateClassTabButtons(classid);
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.setupTimerButton = function(t,classid){
      var config = {
        timer:t.ID,
        icon:"fa fa-fw fa-clock-o fa-spin", //  : "fa fa-fw fa-pause"
        click:function(button,ev){
          if(t.userTimer)
            self.showUserLargeTimer(t,btn,ev); else
            self.showClassToolsLargeTimer(t,btn,self.user.Teacher == 1,ev);
        },
        remove:function(){
          self.confirm($filter('trans')('ASKDELETETIMER',t.n),$filter('trans')('REMOVE'),null).then(function(){
            if(t.userTimer){
              if(!self.userClassViewData[classid]) self.userClassViewData[classid] = {};
              if(!self.userClassViewData[classid]["userTimers"]) self.userClassViewData[classid]["userTimers"] = [];

              for(var i=0; i < self.userClassViewData[classid]["userTimers"].length; i++){
                if(self.userClassViewData[classid]["userTimers"][i].ID == t.ID){
                  self.userClassViewData[classid]["userTimers"].splice(i,1);
                  self.updateUserClassViewData(classid); 
                  return;
                }
              }
            }else{
              if(self.classToolSettings[classid] && self.classToolSettings[classid].timers){
                for(var i=0; i < self.classToolSettings[classid].timers.length; i++){
                  if(self.classToolSettings[classid].timers[i].ID == t.ID){
                    self.classToolSettings[classid].timers.splice(i,1);
                    self.sendClassToolSettings(classid);
                    return;
                  }
                }
              }              
            }
          });
        }
      };
      // remove the delete button for class timers 
      if(self.user.Teacher == 0 && !t.userTimer) delete config.remove;

      var btn = self.addTabButton(classid,config);
      btn.refresh = function(){
        // check if still exists and remove self if not
        var found = false;
        if(t.userTimer){
          if(!self.userClassViewData[classid]) self.userClassViewData[classid] = {};
          if(!self.userClassViewData[classid]["userTimers"]) self.userClassViewData[classid]["userTimers"] = [];

          for(var i=0; i < self.userClassViewData[classid]["userTimers"].length; i++){
            if(self.userClassViewData[classid]["userTimers"][i].ID == t.ID){
              found = true; break;
            }
          }
        }else{
          if(self.classToolSettings[classid] && self.classToolSettings[classid].timers)
            for(var i=0; i < self.classToolSettings[classid].timers.length; i++){
              if(self.classToolSettings[classid].timers[i].ID == t.ID){
                found = true; break;
              }
            }            
        }
        if(!found){
          if(btn.interval){
            $interval.cancel(btn.interval);
            btn.interval = null;
          }
          for(var z=0; z < self.tabButtons[classid].length; z++){
            if(self.tabButtons[classid][z].timer == t.ID){
              self.removeTabButton(classid,self.tabButtons[classid][z]);
            }
          }
          return;
        }
        // update every second
        var totalDiff = moment(t.end).diff(moment().add(self.serverTimeSecondsDelta,"seconds"),"minutes");
        if(!t.running && t.pause){
          totalDiff = moment(t.end).diff(moment(t.pause),"minutes");
        }
        if(totalDiff < -5) btn.done = true; // wa already done 5 min ago, no ring anymore
        if(t.running){
          btn.minutes = Math.max(0,moment(t.end).diff(moment().add(self.serverTimeSecondsDelta,"seconds"),"minutes"));
          btn.seconds = Math.max(0,moment(t.end).diff(moment().add(self.serverTimeSecondsDelta,"seconds"),"seconds")) % 60;
        }
        if(!t.running && t.pause){
          btn.minutes = Math.max(0,moment(t.end).diff(moment(t.pause),"minutes"));
          btn.seconds = Math.max(0,moment(t.end).diff(moment(t.pause),"seconds")) % 60;
        }
        if(!t.running && !t.pause){
          btn.minutes = Math.max(0,moment(t.end).diff(moment(t.start),"minutes"));
          btn.seconds = Math.max(0,moment(t.end).diff(moment(t.start),"seconds")) % 60;
        }
        if(moment(t.end).date() != moment().add(self.serverTimeSecondsDelta,"seconds").date() && totalDiff < 0){
          // a timer form yesterday or longer, delete it now
          if(t.userTimer){
            if(self.userClassViewData[classid] && self.userClassViewData[classid]["userTimers"])
              for(var i=0; i < self.userClassViewData[classid]["userTimers"].length; i++){
                if(self.userClassViewData[classid]["userTimers"][i].ID == t.ID){
                  self.userClassViewData[classid]["userTimers"].splice(i,1);
                  self.updateUserClassViewData(classid);
                  console.log("Removing old timer.");
                  return;
                }
              }
          }else{
            if(self.classToolSettings[classid] && self.classToolSettings[classid].timers)
              for(var i=0; i < self.classToolSettings[classid].timers.length; i++){
                if(self.classToolSettings[classid].timers[i].ID == t.ID){
                  self.classToolSettings[classid].timers.splice(i,1);
                  self.sendClassToolSettings(classid);
                  console.log("Removing old timer.");
                  return;
                }
              }            
          }
        }

        var delta = (btn.minutes*60 + btn.seconds);
        btn.percent = 100 - Math.round(delta / (t.n*60) * 100);
        if(t.running)
          btn.icon = "fa fa-fw fa-clock-o "+(btn.minutes == 0 && btn.seconds == 0 ? '' : "fa-spin");
        else
          btn.icon = "fa fa-fw fa-pause";

        if(btn.minutes == 0){
          btn.text = "Timer: "+ btn.seconds+" "+$filter('trans')('SECONDS');
        }else{
          if(t.n > 2){
            if(btn.seconds > 0) { btn.minutes++; btn.seconds = 0; }
          }
          btn.text = "Timer: "+ btn.minutes+" "+$filter('trans')('MINUTESSHORT');
        }
        if(btn.minutes == 0 && btn.seconds == 0){
          btn.text = "Timer: FERTIG";
          if(!btn.done){
            btn.done = true;
            if(self.currentClass && classid == self.currentClass.ID){
              if(t.audio && self.currentClass && classid == self.currentClass.ID){
                var sndFinish = new Audio("https://learningview.org/app/sounds/finish.mp3");
                sndFinish.play();
              }
              // open timer now
              config.click(btn,null);
            }
          }
        } else btn.done = false;
      };

      btn.interval = $interval(btn.refresh,1000);
      btn.refresh();
      self.updateClassTabButtons(classid);
      return btn;
    };

    self.refreshClassToolSettings = function(classid){
      // called only on new settings available, update view

      // check for new timers in data
      if(!self.tabButtons) self.tabButtons = {};
      if(!self.tabButtons[classid]) self.tabButtons[classid] = [];

      if(self.classToolSettings[classid].timers){
        for(var i=0; i < self.classToolSettings[classid].timers.length; i++){
          var found = null;
          for(var z=0; z < self.tabButtons[classid].length; z++){
            if(self.tabButtons[classid][z].timer == self.classToolSettings[classid].timers[i].ID){
              found = self.tabButtons[classid][z];
              break;
            }
          }
          if(!found && (self.classToolSettings[classid].timers[i].n > 2 || self.user.Teacher == 1)){
            var t = self.classToolSettings[classid].timers[i];
            var btn = self.setupTimerButton(t,classid);
            // if less then 2 min, show now directly
            if(t.n <= 2 && self.user.Teacher == 1 && !btn.done && self.currentClass && classid == self.currentClass.ID)
              self.showClassToolsLargeTimer(t,btn,self.user.Teacher == 1,null);
          }
        }
      }

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.permissionsOrder = function(a){
      if(a.Permissions == "Owner") return 0;
      return parseInt(a.Permissions);
    };

    self.editClass = function(it){
      self.lastClassOnReset = it;
      self.editingClass = {};
      self.editingClass.ID = it.ID;
      self.editingClass.Name = it.Name;
      self.editingClass.GUID = it.GUID;
      self.editingClass.Owner = it.Owner;
      self.editingClass.AllowUserTasks = it.AllowUserTasks;
      self.editingClass.Description = it.Description;
      self.editingClass.Image = it.Image;
      self.editingClass.teachers = it.teachers;
      self.editingClass.groups = it.groups;
      self.editingClass.studentCount = it.students.length;
      self.editingClass.students = [];
      self.editingClass.Settings = it.Settings;
      var c = 0;
      for(var i=0; i < self.classList.length; i++){
        if(self.classList[i].Archived == '1') continue;
        if(self.classList[i].ID == it.ID){
          self.currentClassTabIndex = c;
          break;
        }
        c++;
      }
      for(var i=0; i < it.students.length;i++){
        self.editingClass.students.push({
          'ID':it.students[i].ID,
          'Salt':it.students[i].Salt,
          'InitPassword':it.students[i].InitPassword,
          "lastActivity":it.students[i].lastActivity,
          'Email':it.students[i].Email,
          'Name':it.students[i].Name,
          'Surname':it.students[i].Surname,
          'Science':it.students[i].Science,
          'classCount':it.students[i].classes.length,
          'newName':it.students[i].Name,
          'newSurname':it.students[i].Surname,
          'canSave':false
        });
      }
      self.changeClassNameOrder();
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.addStudent = function(scope,ev){
      scope.newStudentName = $.trim(scope.newStudentName);
      scope.newStudentSurname = $.trim(scope.newStudentSurname);
      if(scope.newStudentName == ""){
        setTimeout(function(){$('.newStudentName').focus();},50);
        return;
      }
      if(scope.newStudentSurname == ""){
        setTimeout(function(){$('.newStudentSurname').focus();},50);
        return;
      }

      scope.newStudentName = scope.newStudentName[0].toUpperCase() + scope.newStudentName.slice(1);
      if(scope.newStudentSurname.indexOf(" ") == -1)
        scope.newStudentSurname = scope.newStudentSurname[0].toUpperCase() + scope.newStudentSurname.slice(1);

      var askShort = true;
      if(scope.newStudentSurname.length == 1 || 
        (scope.newStudentSurname.length == 2 && scope.newStudentSurname[1] == ".")){
        askShort = false;
      }else{
        var d = self.getLocalStorage("askdShortSurname");
        if(d) {
          function sameDay(d1, d2) {
            return d1.getFullYear() === d2.getFullYear() &&
              d1.getMonth() === d2.getMonth() &&
              d1.getDate() === d2.getDate();
          }
          var n = new Date();
          n.setTime(d);
          if(sameDay(new Date(),n)){
            askShort = false;
          }            
        };        
      }

      var saveUser = function(){
        var s = {'ID':'0','Name':scope.newStudentName,'Surname':scope.newStudentSurname};

        self.apiPost("ajax",{"action":"updateStudentClassData", "ID":self.editingClass.ID, "student":angular.toJson(s)})
          .then(function(data) {
            self.updateUser(data.student);
            data.student.canSave = false;
            data.student.newName = data.student.Name;
            data.student.newSurname = data.student.Surname;
            self.editingClass.students.push(data.student);            
            self.getClasses(true);
            scope.newStudentName = "";
            scope.newStudentSurname = "";

            setTimeout(function(){$('.newStudentName').focus();},50);
          });
      };

      if(askShort){
        self.showDialog({
          templateUrl: "askShortSurname.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.before = scope.newStudentName + " " + scope.newStudentSurname;
            var parts = scope.newStudentSurname.split(" ");
            for(var pp = 0; pp < parts.length; pp++){
              parts[pp] = parts[pp][0];
            }
            $scope.shortVersion = parts.join("")+ ".";

            $scope.after = scope.newStudentName + " " + $scope.shortVersion;
            $scope.save = function(answer){
              self.closeDialog($scope.dialogElement);
              if(answer == true){
                scope.newStudentSurname = $scope.shortVersion;
              }else{
                self.setLocalStorage("askdShortSurname",new Date().getTime());                              
              }
              saveUser();
            };
            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      } else saveUser();
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveStudent = function(it){
      if(it.ID == 0 && it.newName == "" && it.newSurname == "") return; // don't save clean users
      if($.trim(it.newName) == "" || $.trim(it.newSurname) == "") return; // missing data
      // apply now
      it.Name = it.newName;
      it.Surname = it.newSurname;
      self.apiPost("ajax",{"action":"updateStudentClassData", "ID":self.editingClass.ID, "student":angular.toJson(it)})
        .then(function(data) {
          it.ID = data.ID;
          it.canSave = false;
          self.getClasses(true);
        });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.selectStudentColorInClass = function(s, ev){
      var deferred = $q.defer();

      var position = $mdPanel.newPanelPosition()
          .absolute().relativeTo(ev.target)
          .addPanelPosition('align-start', 'below')
          .addPanelPosition('align-start', 'center')
          .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.SCALE);

      var panel = self.showPanel({
        attachTo: angular.element(document.body),
        templateUrl: "selectStudentColorInClass.html",
        position: position,
        openFrom: ev,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true,
        animation: panelAnimation,
        zIndex: 81,
        panelClass: 'studentMenuPanel',
        controller: function (mdPanelRef, $scope, $mdPanel) {
          $scope.self = self;
          $scope.s = s;
          $scope.select = function(color){
            self.setStudentColorInClass(s,self.currentClass,color);
            mdPanelRef.close();
            deferred.resolve();
          };
        }
      });
      return deferred.promise;
    };
    self.setStudentColorInClass = function(student,c,color){
      self.apiPost("ajax",{"action":"setStudentColorInClass", "ID":student.ID, "classid":c.ID, "color":color})
        .then(function(data) {
          self.getClasses(true);
        });
    };
    self.getUserBorderColor = function(user){
      if(!self.currentClass) return "";
      //if(self.user.Teacher == 0 && user.ID != self.user.ID) return "";
      if(self.users[user.ID]){
        if(self.users[user.ID].colors && self.users[user.ID].colors[self.currentClass.ID]){
          return self.users[user.ID].colors[self.currentClass.ID];
        }
      }
      return "";
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.deleteStudent = function(it,ev){
      if(it.ID == 0){
        self.editingClass.students.splice(self.editingClass.students.indexOf(it),1);
        return;
      }
      self.confirm($filter('trans')('REMOVESTUDENT',it.Name),$filter('trans')('REMOVE'),ev).then(function(){
        if(!it.classCount && it.classes) it.classCount = it.classes.length;
        if((!it.classCount || it.classCount == 1) && it.InitPassword != ""){
          self.confirm($filter('trans')('DELETESTUDENT',it.Name),'<span style="color:red">'+$filter('trans')('DELETE')+'</span>',ev,$filter('trans')('KEEP')).then(function(){
            self.apiPost("ajax",{"action":"removeStudentFromClass","noerror":1, "ID":it.ID, "delete":1, "classid":self.editingClass.ID})
              .then(function(data) {
                self.getClasses(true);
              });
          },function(){
            self.apiPost("ajax",{"action":"removeStudentFromClass","noerror":1, "ID":it.ID, "classid":self.editingClass.ID})
            .then(function(data) {
              self.getClasses(true);
            });
          });
        }else{
          self.apiPost("ajax",{"action":"removeStudentFromClass","noerror":1, "ID":it.ID, "classid":self.editingClass.ID})
          .then(function(data) {
            self.getClasses(true);
          });
        }
      });

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openAddStudentsFromList = function(ev){
      self.showLoadingIndicator(ev,function(done){

        self.showDialog({
          templateUrl: "addStudentFromList.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.names = "";
            $scope.step = 0;
            $scope.accounts = null;            
            $scope.anserMakeShortSurnames = null;
            $scope.changeNameOrder = false;
            $scope.hasEmails = false;

            $scope.splitNames = function(s,makeShortSurnames){
              $scope.hasEmails = false;
              var names = [];
              var list = s.split("\n");
              var removeEmpty = function(a){
                for(var i=0; i < a.length; i++){
                  if($.trim(a[i]) == "") {
                    a.splice(i,1);
                    i--;
                  }else{
                    a[i] = $.trim(a[i]);
                  }
                }
              }
              for(var i=0; i < list.length; i++){
                var p = $.trim(list[i].replace('"',""));
                // remove , or ; at the end
                p = p.replace(/[,;\t ]+$/,"");
                if(p != ""){
                  var pl = p.split(",");
                  removeEmpty(pl);
                  if(pl.length == 1){
                    // no , found
                    var pl2 = p.split(" ");
                    removeEmpty(pl2);
                    if(pl2.length >= 2) {
                      pl = pl2; 
                    }
                    else {
                      var pl2 = p.split("\t");
                      removeEmpty(pl2);
                      if(pl2.length >= 2) pl = pl2;
                    }
                  }
                  var email = null;
                  if(pl.length > 2){
                    for(var z=0; z < pl.length; z++){
                      if(pl[z].indexOf("@") > 0){
                        // email found
                        email = $.trim(pl[z]);
                        $scope.hasEmails = true;
                        pl.splice(z,1);
                        break;
                      }
                    }
                    if($scope.changeNameOrder){
                      if(pl.length > 2){
                        // Names like: von Arx
                        var lastName = [];
                        while(pl.length > 1){
                          lastName.push(pl.shift());
                        }
                        pl.unshift(lastName.join(" "));                      
                      }                      
                    }else{
                      if(pl.length > 2){
                        // Names like: von Arx
                        var lastName = [];
                        while(pl.length > 1){
                          lastName.unshift(pl.pop());
                        }
                        pl.push(lastName.join(" "));                      
                      }                      
                    }
                  }

                  if(pl.length > 1){
                     if($scope.changeNameOrder){
                       var tmp = pl[0];
                       pl[0] = pl[1];
                       pl[1] = tmp;
                     }
                     pl[0] =  pl[0][0].toUpperCase() + pl[0].slice(1);
                     if(pl[1].indexOf(" ") == -1)
                       pl[1] =  pl[1][0].toUpperCase() + pl[1].slice(1);

                    if(makeShortSurnames){
                      var parts = pl[1].split(" ");
                      for(var pp = 0; pp < parts.length; pp++){
                        parts[pp] = parts[pp][0];
                      }
                      pl[1] = parts.join("")+ ".";
                    }

                    names.push({'ID':0,'Name':pl[0],'Surname':pl[1], 'Email':email});
                  }
                }
              }
              return names;
            };

            $scope.preview = function(makeShortSurnames){
              if($scope.anserMakeShortSurnames !== null) makeShortSurnames = $scope.anserMakeShortSurnames;
              $scope.accounts = $scope.splitNames($scope.names,makeShortSurnames === true);
              if($scope.accounts.length == 0) return;

              if(makeShortSurnames !== true && makeShortSurnames !== false)
                for(var i=0; i < $scope.accounts.length; i++){
                  var it = $scope.accounts[i];

                  var askShort = true;
                  if(it.Surname.length == 1 || 
                    (it.Surname.length == 2 && it.Surname[1] == ".")){
                    askShort = false;
                  }
                  if(askShort){
                    var parent = $scope;
                    self.showDialog({
                      templateUrl: "askShortSurname.html",
                      targetEvent: ev,
                      skipHide:true, // keep other dialog open
                      clickOutsideToClose: true,
                      controller: function ($scope, $mdDialog) {
                        $scope.self = self;
                        $scope.before = it.Name + " " + it.Surname;
                        var parts = it.Surname.split(" ");
                        for(var pp = 0; pp < parts.length; pp++){
                          parts[pp] = parts[pp][0];
                        }
                        $scope.shortVersion = parts.join("")+ ".";
                        $scope.after = it.Name + " " + $scope.shortVersion;
                        $scope.save = function(answer){
                          self.closeDialog($scope.dialogElement);
                          parent.anserMakeShortSurnames = !!answer;
                          if(answer == true){
                            parent.preview(); // make short
                          }else{
                            parent.preview(); // make not short
                          }
                        };
                        $scope.cancel = function() {
                          self.closeDialog($scope.dialogElement);
                        };
                      }
                    });
                    return; // stop for now
                  }                
                }            
              $scope.step = 1;
            };

            $scope.save = function (){
              var waitFor = 0;

              // process now
              for(var i=0; i < $scope.accounts.length; i++){
                waitFor++;
                var it = $scope.accounts[i];
                self.apiPost("ajax",{"action":"updateStudentClassData", "ID":self.editingClass.ID, "student":angular.toJson(it)}).then(function(data) {
                  waitFor--;
                  if(waitFor == 0) self.getClasses(true);
                });
              }
              self.closeDialog($scope.dialogElement);
            };

            $scope.paste = function(){
              readTextFromClipboard(function(clip){
                $scope.names = clip;
              });
            };

            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };

          }
        });

        done();
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.openAddStudentsFromOtherClasses = function(ev){
      self.showLoadingIndicator(ev,function(done){

        self.showDialog({
          templateUrl: "addStudentFromOtherClasses.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.selection = [];
            for(var i=0; i < self.classListCurrent.length; i++){
              if(self.classListCurrent[i].ID != self.editingClass.ID) {
                $scope.selectedClass = self.classListCurrent[i];
                break;
              }
            }

            $scope.matchSearch = function(searchterm,c){
              var isName = self.matchSearchTerm(searchterm,[c.Name]);
              if(isName) return true;
              var searchArray = [];
              for(var i=0; i < c.students.length; i++){
                searchArray.push(c.students[i].Name);
                searchArray.push(c.students[i].Surname);
                searchArray.push(c.students[i].Email);
              }
              return self.matchSearchTerm(searchterm,searchArray);
            };

            $scope.matchSearchStudent = function(searchterm,s){
              return self.matchSearchTerm(searchterm,[s.Name,s.Surname,s.Email]);              
            };

            $scope.openFirstSearchClass = function(searchterm){
              $scope.selectedClass = null;
              for(var i=0; i < self.classListCurrent.length; i++){
                if(self.classListCurrent[i].ID != self.editingClass.ID) {
                  if($scope.matchSearch(searchterm,self.classListCurrent[i])){
                    $scope.selectedClass = self.classListCurrent[i];
                    return;
                  }
                }
              }
            }

            $scope.disabled = [];

            for(var i=0; i < self.editingClass.students.length; i++){
              $scope.disabled.push(self.editingClass.students[i].ID);
              $scope.selection.push(self.editingClass.students[i].ID);
            }

            $scope.toggleSelect = function(s){
              var p = $scope.selection.indexOf(s.ID);
              if(p == -1)
                $scope.selection.push(s.ID); else
                $scope.selection.splice(p,1);
            };

            $scope.selectAll = function(c){
              for(var i=0; i < c.students.length; i++){
                if($scope.selection.indexOf(c.students[i].ID) == -1)
                   $scope.selection.push(c.students[i].ID);
              }
            };

            $scope.selectNone = function(c){
              for(var i=0; i < c.students.length; i++){
                var p = $scope.selection.indexOf(c.students[i].ID);
                var d = $scope.disabled.indexOf(c.students[i].ID);
                if(p != -1 && d == -1) $scope.selection.splice(p,1);
              }
            };

            $scope.countStudentsToAdd = function(){
              var c = 0;
              for(var i=0; i < $scope.selection.length; i++){
                var dis = false;
                for(var z=0; z < $scope.disabled.length; z++){
                  if($scope.selection[i] == $scope.disabled[z]){
                    dis = true;
                    break;
                  }
                }
                if(dis) continue;
                c++;
              }
              return c;
            };

            $scope.save = function() {
              // remove existing ones
              for(var i=0; i < $scope.selection.length; i++){
                for(var z=0; z < $scope.disabled.length; z++){
                  if($scope.selection[i] == $scope.disabled[z]){
                    $scope.selection.splice(i,1);
                    i--;
                    break;
                  }
                }
              }
              // save and add students to this class
              self.apiPost("ajax",{"action":"addUsersToClass", "classid":self.editingClass.ID,
                                   "students":$scope.selection.join(",")}).then(function(data){
                self.getClasses(true);
              });

              self.closeDialog($scope.dialogElement);
            };
            $scope.move = function() {
              self.confirm($filter('trans')('ASKMOVESTUDENTSTOCLASS',$scope.countStudentsToAdd()),$filter('trans')('MOVE'),ev).then(function(){
                // remove existing ones
                for(var i=0; i < $scope.selection.length; i++){
                  for(var z=0; z < $scope.disabled.length; z++){
                    if($scope.selection[i] == $scope.disabled[z]){
                      $scope.selection.splice(i,1);
                      i--;
                      break;
                    }
                  }
                }
                // save and add students to this class
                self.apiPost("ajax",{"action":"addUsersToClass", "classid":self.editingClass.ID, "move":1,
                                     "students":$scope.selection.join(",")}).then(function(data){
                  self.getClasses(true);
                });

                self.closeDialog($scope.dialogElement);
              });
            };
            $scope.cancel = function (){
              self.closeDialog($scope.dialogElement);
            };
          }
        });
        done();
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.copyStudentInviteToClassLink = function(ev){
      self.apiPost("ajax",{"action":"requestAddClassStudentLink", "ID":self.editingClass.ID}).then(function(data) {
        if(data.link){
          copyTextToClipboard(data.link);
          self.alert($filter('trans')('ADDSTUDENTLINKCOPYED'),ev);    
        }
      });
    };            
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTeacher = function(ev){
      self.showDialog({
        templateUrl: "addteachertoclass.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.link = "";
          $scope.error = "";
          $scope.data = {Permissions:1};
          $scope.invites = [];

          $scope.refreshLink = function(){
            self.apiPost("ajax",{"action":"requestAddClassTeacherLink", "ID":self.editingClass.ID, "Permissions":$scope.data.Permissions}).then(function(data) {
              if(data.link){
                $scope.link = data.link;
              }
            });
          };
          $scope.refreshLink();

          $scope.updateInviteList = function(){
            var emails = $scope.data.email ? $scope.data.email.toLowerCase().split(";") : [];
            $scope.invites = [];
            for(var i=0; i < emails.length; i++){
              $scope.invites.push({Email:emails[i]});
            }
          }

          $scope.$watchCollection('invites', function (newVal, oldVal) {
            var emails = [];
            for(var i=0; i < $scope.invites.length; i++){
              emails.push($scope.invites[i].Email);
            }
            $scope.data.email = emails.join(";");
          });

          self.addTeacherGroupsScope($scope);

          $scope.copy = function(){
            if($scope.link && $scope.link != ''){
              copyTextToClipboard($scope.link);
              self.closeDialog($scope.dialogElement);
              self.alert($filter('trans')('ADDTEACHERLINKCOPYED'),null);                
            }
          };

          $scope.ok = function() {
            $scope.data.email = $.trim($scope.data.email);
            if($scope.data.email == "") { return; }

            var successCount = 0;
            var successCountTry = 0;
            var mails = $scope.data.email.split(";");

            var done = function(){
              self.getClasses(true);
              if(mails.length == 0){
                self.closeDialog($scope.dialogElement);
                if(!self.notShowTeacherShareIntro){
                  self.notShowTeacherShareIntro = true;
                  self.openTeacherShareIntro(ev);
                }
              }else{
                addOne();
              }
            };

            var addOne = function (){
              var e = "";
              while(mails.length > 0 && e == ""){
                e = $.trim(mails.pop());
              }
              if(e == "") { done(); return; }
              successCountTry++;

              self.apiPost("ajax",{"action":"addClassTeacher","noerror":1, "ID":self.editingClass.ID, "Email":e, "Permissions":$scope.data.Permissions})
              .then(function(data) {
                self.editingClass.teachers = data.teachers;
                done();
              },function(data, status, headers, config) {
                if(data.error == "USER_NOT_FOUND")
                  self.alert($filter('trans')('SHAREUSERNOTFOUND',e));
                else if(data.error == "NO_TEACHER")
                  self.alert($filter('trans')('SHAREUSERNOTEACHER',e));
                else $scope.error = data.error;
              });
            };

            addOne();

          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.deleteClass = function(ev){
      self.removeClass(self.editingClass,ev).then(function(){
        if(self.lastClassOnReset && self.lastClassOnReset.ID == self.editingClass.ID)
          self.lastClassOnReset = null;
        self.editingClass = null;
        self.currentTeacherNavigation = "";
        $timeout(function(){self.currentTeacherNavigation = "Classes";},1);
      })
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.deleteTeacher = function(it,ev){
      self.confirm($filter('trans')('REMOVETEACHER',it.Name),$filter('trans')('REMOVE'),ev).then(function(){
        self.apiPost("ajax",{"action":"removeTeacherFromClass", "ID":it.ID, "classid":self.editingClass.ID})
          .then(function(data) {
            self.editingClass.teachers.splice(self.editingClass.teachers.indexOf(it),1);
            self.getClasses(true);
          });
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasClassChangePermission = function(it,e){
      if(!self.user || self.user.Teacher == "0") return false;
      if(it){
        if(it.Owner == self.user.ID) return true;
        for(var i=0; i < it.teachers.length; i++){
          if(it.teachers[i].ID == self.user.ID){
            if(it.teachers[i].Permissions == 1) return true;
            return false;
          }
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasClassReviewPermission = function(it){
      if(!self.user || self.user.Teacher == "0") return false;
      if(it){
        if(it.Owner == self.user.ID) return true;
        for(var i=0; i < it.teachers.length; i++){
          if(it.teachers[i].ID == self.user.ID){
            if(it.teachers[i].Permissions == 1) return true;
            if(it.teachers[i].Permissions == 2) return true;
            return false;
          }
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkUsePermission = function(it){
      if(self.user.Teacher == "0") return false;
      if(it && it.Owner == self.user.ID) return true;
      if(it && it.Permission) return it.Permission == "1" || it.Permission == "2";
      if(it && !it.Permission && it.shareSettings){
        for(var i=0; i < it.shareSettings.length; i++){
          if(it.shareSettings[i].User == self.user.ID) return it.shareSettings[i].Permission == "1" || it.shareSettings[i].Permission == "2";
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkChangePermission = function(it){
      if(self.user.Teacher == "0") return false;
      if(it && it.Owner == self.user.ID) return true;
      if(it && it.Permission) return it.Permission == "2";
      if(it && !it.Permission && it.shareSettings){
        for(var i=0; i < it.shareSettings.length; i++){
          if(it.shareSettings[i].User == self.user.ID) return it.shareSettings[i].Permission == "2";
        }
      }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasMaxPermission = function(it,permission){
      if(it.Owner != self.user.ID && it.Permission) return it.Permission >= permission;
      if(it.shareSettings){
        for(var i=0; i < it.shareSettings.length; i++){
          if(it.shareSettings[i].User != self.user.ID) continue;
          if(it.shareSettings[i].Permission >= permission) return true;
        }
      }
      return false;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.showPermissionInfo = function(it,ev){
      if(it.Permissions == 'Owner') self.alert($filter('trans')('PERMISSIONSOWNERHINT'),ev);
      if(it.Permissions == '1') self.alert($filter('trans')('PERMISSIONSFULLHINT'),ev);
      if(it.Permissions == '2') self.alert($filter('trans')('PERMISSIONSREADHINT'),ev);
      if(it.Permissions == '3') self.alert($filter('trans')('PERMISSIONSVIEWHINT'),ev);
    };

    self.changeClassTeacherPermissions = function(it,ev){
      var p = it.Permissions;
      var send = function(){
        self.apiPost("ajax",{"action":"changeClassTeacherPermissions", "ID":it.ID, "classid":self.editingClass.ID, "permissions":p})
          .then(function(data) {
            self.getClasses(true);
          });
      };

      if(p == "Owner"){
        self.confirm($filter('trans')('CHANGECLASSOWNER',it.Name),$filter('trans')('OK'),ev).then(function(){
          send();
        },function(){
          self.keepAliveCallback();
        });
      }else send();

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkEmail = function(email,outputAt, showInvalid){
      var $output = outputAt ? $(outputAt) : null;
      if($output && $output.length) $output.empty();
      $.getJSON("https://learningview.org/api/checkEmail.php?email="+encodeURIComponent(email),function(data){
        if(!$output || !$output.length) return;
        $output.empty();

        if(showInvalid && (data.error == "ATSIGNMISSMATCH" || data.error == "NODOTINDOMAIN")){
          $output.append(document.createTextNode("Du hast noch keine gültige Emailadresse angegeben."));
          $output.append(document.createElement("br"));
          $output.append(document.createTextNode("Bitte prüfe sie noch einmal."));
          return;
        }

        if(data.error == "DOMAINNOTFOUND"){
          var domain = (data && typeof data.domain == "string") ? data.domain : "";
          $output.append(document.createTextNode("Die Adresse "));
          $output.append($("<b></b>").text(domain));
          $output.append(document.createTextNode(" scheint es nicht zu geben."));
          $output.append(document.createElement("br"));
          $output.append(document.createTextNode("Diese Emailadresse wird eventuell nicht funktionieren."));
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.codeinputerror = null;
    self.addUserClass = function(guid,ev,withoutAsking){
      self.codeinputerror = null;
      if(guid == "" || guid.length < 8) return;

      self.apiPost("ajax",{"action":"requestAddClassUser","noerror":1, "GUID":guid})
        .then(function(data) {
          // ask for confirmation now
          var doNow = function(){
            self.apiPost("ajax",{"action":"addClassUser","noerror":1, "GUID":guid})
              .then(function(data) {
                self.keepAliveCallback().then(function(){
                  for(var i=0; i < self.classList.length; i++){
                    if(self.classList[i].GUID == guid.toLowerCase()) {
                      self.openClass(self.classList[i]);
                      self.classcodeinput = '';
                    }
                  }

                });
              },function(data, status, headers, config) {
                self.codeinputerror = data.error;
                if(data.error == "NOTALLOWEDBYSCHOOL")
                  self.alert($filter('trans')('ADDCLASSNOTALLOWEDBYSCHOOL'));
              });

          };

          $mdMenu.hide();
          if(withoutAsking && data.Outsider != 1){
            doNow();
          }else
            self.confirm($filter('trans')('CONFIRMADDCLASS',data.Name,data.Teacher)).then(function(){ 
              if(data.Outsider == 1){
                self.confirm('<span style="color:red">'+$filter('trans')('CONFIRMADDCLASSOUTSIDER')+'</span>').then(function(){
                  doNow();
                });
              }else
                doNow();
            });

        },function(data, status, headers, config) {
          if(data.error == 'CODENOTFOUND') {
            self.codeinputerror = "Der eingegebene Code passt zu keinem Kurs.<br><br>Bitte versuche es erneut.";
          }else
            self.codeinputerror = data.error;
        });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.refreshClassCode = function(ev){
      self.showDialog({
        templateUrl: "refreshClassCode.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.smallScreen = self.isSmallScreen;
          $scope.showFullscreen = function(ev){
            self.showDialog({
              templateUrl: "fullscreenClassCode.html",
              targetEvent: ev,
              skipHide:true, // keep other dialog open
              clickOutsideToClose: true,
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.cancel = function() {
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          };
          $scope.change = function() {
            self.apiPost("ajax",{"action":"refreshClassGUID","ID":self.editingClass.ID })
             .then(function(data) {
               self.editingClass.GUID = data.GUID;
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.editClassSettings = function(ev){
      self.showDialog({
        templateUrl: "editClassSettings.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.newName = self.editingClass.Name;
          $scope.AllowUserTasks = self.editingClass.AllowUserTasks;
          $scope.smallScreen = self.isSmallScreen;
          // default is on
          var defaults = self.getClassSettingDefaults();
          $scope.Settings = defaults;

          if(self.editingClass.Settings && self.editingClass.Settings != ""){
            $scope.Settings = JSON.parse(self.editingClass.Settings);
            for(var k in defaults){
              if(typeof $scope.Settings[k] == "undefined") $scope.Settings[k] = defaults[k];
            }
          }

          $scope.save = function() {
            if($.trim($scope.newName) == ""){
              $('#classNameInput').focus();
              return;
            }

            self.apiPost("ajax",{"action":"updateClass",
                                 "Description":self.editingClass.Description,
                                 "Settings":angular.toJson($scope.Settings),
                                 "ID":self.editingClass.ID, "Name":$scope.newName,
                                 "AllowUserTasks":$scope.AllowUserTasks})
             .then(function(data) {
               self.getClasses().then(function(){
                 var newClass = null;
                 for(var i=0; i < self.classList.length; i++){
                   if(self.editingClass.ID == self.classList[i].ID) {
                     newClass = self.classList[i];
                   }
                 }
                 self.editClass(newClass);
               });
             });

            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.createClass = function(ev){
      self.showDialog({
        templateUrl: "createclass.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.Name = "";
          $scope.isNew = 1;
          $scope.Description = "";
          $scope.save = function() {
            // try save now
            if($scope.Name == "") { $('#inputName').focus(); return;}

            self.apiPost("ajax",{"action":"createClass", "Name":$scope.Name, "Description":$scope.Description })
             .then(function(data) {
               self.closeDialog($scope.dialogElement);
               self.getClasses().then(function(){
                 if(data.newclass){
                   self.classList.push();
                   var newClass = null;
                   for(var i=0; i < self.classList.length; i++){
                     if(data.newclass.ID == self.classList[i].ID) {
                       newClass = self.classList[i];
                     }
                   }
                   self.editClass(newClass);
                   self.currentTeacherNavigation = "";
                   $timeout(function(){
                     self.currentTeacherNavigation = "Classes";
                     if(self.classList.length < 2 && !self.notShowTeacherClassIntro){
                       self.notShowTeacherClassIntro = true;
                       self.openTeacherClassIntro(ev);
                     }else{
                       if(!self.notShowTeacherClassIntro2){
                         self.notShowTeacherClassIntro2 = true;
                         self.openTeacherClassIntro2(ev);
                       }
                     }
                   },1);
                 }
               });
             });
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeClass = function(it,ev){
      var deferred = $q.defer();
      var ownClass = it.Owner == self.user.ID;

      var deleteNow = function(){
        self.apiPost("ajax",{"action":"removeClass", "ID":it.ID})
         .then(function(data) {
           self.classList.splice(self.classList.indexOf(it),1);               
           self.updateClassesOrder();
           self.keepAliveCallback(null,true);
           deferred.resolve();
         });
      }

      self.confirm(ownClass ? $filter('trans')('DELETECLASSHINT',it.Name):$filter('trans')('REMOVECLASSHINT',it.Name),ownClass ? $filter('trans')('DELETE') : $filter('trans')('REMOVE'),ev).then(function(){
        if(ownClass){
          var canDelete = [];
          for(var i=0; i < it.students.length; i++){
            var s = it.students[i];
            if(!s.classCount && s.classes) s.classCount = s.classes.length;
            if((!s.classCount || s.classCount == 1) && s.InitPassword != ""){
              // can delete this student
              canDelete.push(s);
            }
          }
          if(canDelete.length > 0){
            self.confirm($filter('trans')('DELETESTUDENTSINCLASS',canDelete.length),'<span style="color:red">'+$filter('trans')('DELETE')+'</span>',ev,$filter('trans')('KEEP')).then(function(){
              self.showLoadingIndicator(ev,function(done){
                for(var i=0; i < canDelete.length; i++)
                  self.apiPost("ajax",{"action":"removeStudentFromClass", "ID":canDelete[i].ID, "delete":1, "classid":it.ID});
                $timeout(function(){ done(); deleteNow(); },1000);
              });
            },function(){
              deleteNow();
            });
          }else deleteNow();
        }else deleteNow();
      });

      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    
    self.showStudentProgress = function(s,ev){
      self.showDialog({
        templateUrl: "studentProgress.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.s = s;
          $scope.smallScreen = self.isSmallScreen;

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };


    self.showClassProgress = function(calendarDate,ev){
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "classProgress.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open
          state:"one",
          clickOutsideToClose: true,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            // reset modes
            self.currentClassToggleCheckMode = false;
            self.currentClassToggleRejectMode = false;
            self.currentClassToggleVisibilityMode = false;
            self.currentClassToggleNoteMode = false;
            self.currentClassToggleCloseMode = false;
            self.currentClassToggleImportantMode = false;
            self.currentClassToggleResetMode = false;

            self.currentClassProgressCalendarMode = 0; // reset

            $scope.currentClassProgressCalendarWeeks = [];
            var progressCalendarAutoRefreshPromise = null;
            var progressCalendarSignatureUnwatch = null;

            var getCurrentProgressFilter = function(){
              if(self.userClassViewData &&
                 self.userClassViewData[self.currentClass.ID] &&
                 self.userClassViewData[self.currentClass.ID].filterMainTopics &&
                 self.userClassViewData[self.currentClass.ID].filterMainTopics.length > 0){
                return self.userClassViewData[self.currentClass.ID].filterMainTopics;
              }
              return null;
            };

            var parseStudentCalendarLine = function(line){
              var text = String(line || "");
              var checked = false;
              if(text != "" && text[0] == "✓"){
                checked = true;
                text = text.slice(1);
              }
              if(text != "" && text[0] == "¶") text = text.slice(1);
              return {text:text, checked:checked, color:null};
            };

            var getClassCalendarNoteEntries = function(date, student){
              var entries = [];
              var classNotes = self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].classCalendarNotes ?
                               self.classContent[self.currentClass.ID].classCalendarNotes : [];
              for(var i=0; i < classNotes.length; i++){
                var item = classNotes[i];
                if(!item || item.Date != date) continue;
                if(item.DataJSON && item.DataJSON.Coaching === 1) continue;
                if(!item.DataJSON || !item.DataJSON.Text || item.DataJSON.Text == "") continue;
                entries.push({
                  id: item.ID,
                  text: item.DataJSON.Text,
                  checked: self.getClassCalendarNoteItemChecked(item,student),
                  color: item.DataJSON.Color ? item.DataJSON.Color : null
                });
              }
              entries.sort(function(a,b){
                return (a.id > b.id ? 1 : -1);
              });
              return entries;
            };

            var getStudentCalendarNoteEntries = function(studentID, date){
              var entries = [];
              if(self.users[studentID] && self.users[studentID].calendarNotes && self.users[studentID].calendarNotes[self.currentClass.ID]){
                for(var y=0; y < self.users[studentID].calendarNotes[self.currentClass.ID].length; y++){
                  var calendarItem = self.users[studentID].calendarNotes[self.currentClass.ID][y];
                  if(calendarItem && calendarItem.Date == date &&
                     calendarItem.DataJSON && calendarItem.DataJSON.text && calendarItem.DataJSON.text != ''){
                    var lines = calendarItem.DataJSON.text.split("\n");
                    for(var z=0; z < lines.length; z++){
                      entries.push(parseStudentCalendarLine(lines[z]));
                    }
                    break;
                  }
                }
              }
              return entries;
            };

            var getMergedCalendarNoteEntries = function(date, student){
              var entries = [];
              var classEntries = getClassCalendarNoteEntries(date,student);
              for(var i=0; i < classEntries.length; i++){
                if(self.user.Teacher == 1 && classEntries[i].checked && classEntries[i].checked.Owner != classEntries[i].checked.User)
                  classEntries[i].green = true;
                entries.push(classEntries[i]);
              } 
              var studentEntries = getStudentCalendarNoteEntries(student.ID,date);
              for(var z=0; z < studentEntries.length; z++) entries.push(studentEntries[z]);
              return entries;
            };

            var scheduleProgressCalendarAutoRefresh = function(){
              if(!self.currentClassProgressCalendarMode) return;
              if(progressCalendarAutoRefreshPromise) $timeout.cancel(progressCalendarAutoRefreshPromise);
              progressCalendarAutoRefreshPromise = $timeout(function(){
                progressCalendarAutoRefreshPromise = null;
                if(self.currentClassProgressCalendarMode){
                  $scope.changeClassProgressCalendarMode(self.currentClassProgressCalendarMode,true);
                }
              },150);
            };

            var getProgressCalendarDataSignature = function(){
              if(!self.currentClass || !self.currentClassProgressCalendarMode) return "off:"+self.currentClassProgressCalendarMode;

              var classid = self.currentClass.ID;
              var weeks = $scope.currentClassProgressCalendarWeeks ? $scope.currentClassProgressCalendarWeeks : [];
              var students = self.currentClass.students ? self.currentClass.students : [];
              var classCalendarByDate = self.classContent[classid] && self.classContent[classid].classCalendarByDate ?
                                        self.classContent[classid].classCalendarByDate : {};
              var classCalendarNotes = self.classContent[classid] && self.classContent[classid].classCalendarNotes ?
                                       self.classContent[classid].classCalendarNotes : [];
              var filter = getCurrentProgressFilter();
              var filterKey = filter ? filter.join(",") : "";
              var signature = ["m:"+self.currentClassProgressCalendarMode, "c:"+classid, "f:"+filterKey, "w:"+weeks.length];

              // Build note lookups once per student to avoid repeated linear scans.
              var notesByStudentDate = {};
              for(var s=0; s < students.length; s++){
                var sid = students[s].ID;
                notesByStudentDate[sid] = {};
                if(self.users[sid] && self.users[sid].calendarNotes && self.users[sid].calendarNotes[classid]){
                  for(var n=0; n < self.users[sid].calendarNotes[classid].length; n++){
                    var note = self.users[sid].calendarNotes[classid][n];
                    if(note && note.DataJSON && note.DataJSON.text && note.DataJSON.text != ""){
                      notesByStudentDate[sid][note.Date] = note.DataJSON.text;
                    }
                  }
                }
              }

              for(var w=0; w < weeks.length; w++){
                var week = weeks[w];
                if(!week || !week.days) continue;
                signature.push("wk:"+week.ID);
                for(var d=0; d < week.days.length; d++){
                  var day = week.days[d];
                  if(!day || !day.date) continue;
                  var date = day.date;
                  var classItems = classCalendarByDate[date] ? classCalendarByDate[date] : [];
                  signature.push("d:"+date, "ct:"+classItems.length);
                  for(var ci=0; ci < classItems.length; ci++){
                    var cItem = classItems[ci];
                    signature.push("c:"+cItem.ID+":"+cItem.Task+":"+(cItem.OrderIndex || "")+":"+(cItem.Time || cItem.Time === 0 ? cItem.Time : ""));
                  }
                  for(var cn=0; cn < classCalendarNotes.length; cn++){
                    var classNote = classCalendarNotes[cn];
                    if(!classNote || classNote.Date != date) continue;
                    if(classNote.DataJSON && classNote.DataJSON.Coaching === 1) continue;
                    signature.push("cn:"+
                                   classNote.ID+":"+
                                   (classNote.DataJSON && classNote.DataJSON.Text ? classNote.DataJSON.Text : "")+":"+
                                   (classNote.DataJSON && classNote.DataJSON.Color ? classNote.DataJSON.Color : "")+":"+
                                   (classNote.Checked ? JSON.stringify(classNote.Checked) : ""));
                  }

                  for(var si=0; si < students.length; si++){
                    var studentID = students[si].ID;
                    var userByDate = self.users[studentID] &&
                                     self.users[studentID].calendarsByDate &&
                                     self.users[studentID].calendarsByDate[classid] ?
                                     self.users[studentID].calendarsByDate[classid] : null;
                    var studentItems = userByDate && userByDate[date] ? userByDate[date] : [];
                    signature.push("s:"+studentID+":"+studentItems.length);
                    for(var ti=0; ti < studentItems.length; ti++){
                      var sItem = studentItems[ti];
                      signature.push("t:"+sItem.ID+":"+sItem.Task+":"+(sItem.OrderIndex || "")+":"+(sItem.Time || sItem.Time === 0 ? sItem.Time : ""));
                    }
                    signature.push("n:"+studentID+":"+(notesByStudentDate[studentID][date] ? notesByStudentDate[studentID][date] : ""));
                  }
                }
              }

              return signature.join("|");
            };

            $scope.changeClassProgressCalendarMode = function(v,noAnimation){
              $scope.currentDate = moment().startOf('isoWeek');
              var filter = getCurrentProgressFilter();

              self.currentClassProgressCalendarMode = v;
              $scope.currentClassProgressCalendarWeeks = [];
              $scope.currentClassProgressCalendarWeeks.unshift({ID:2});
              $scope.currentClassProgressCalendarWeeks.unshift({ID:1});
              for(var i=0; i < v; i++)
                $scope.currentClassProgressCalendarWeeks.unshift({ID:-i});

              for(var i=0; i < $scope.currentClassProgressCalendarWeeks.length; i++){
                $scope.currentClassProgressCalendarWeeks[i].days = [];
                var d = $scope.currentDate.diff(moment().startOf('isoWeek').subtract('days', 7*$scope.currentClassProgressCalendarWeeks[i].ID), 'weeks');
                if(d < -1) $scope.currentClassProgressCalendarWeeks[i].label = $filter('trans')('WEEKSAGO',-d);
                if(d == -1) $scope.currentClassProgressCalendarWeeks[i].label = $filter('trans')('LASTWEEK');
                if(d == 0) $scope.currentClassProgressCalendarWeeks[i].label = $filter('trans')('THISWEEK');
                if(d == 1) $scope.currentClassProgressCalendarWeeks[i].label = $filter('trans')('NEXTWEEK');
                if(d > 1) $scope.currentClassProgressCalendarWeeks[i].label = $filter('trans')('WEEKSAHEAD',d);

                for(var z=0; z < 7; z++){
                  var days = 0+z+($scope.currentClassProgressCalendarWeeks[i].ID*7);
                  var d = {ID:z};
                  d.isToday = moment($scope.currentDate).add(days,'days').format("YYYY-MM-DD") == moment().format("YYYY-MM-DD");
                  d.day = moment($scope.currentDate).add(days,'days').format("dddd");
                  d.date = moment($scope.currentDate).add(days,'days').format("YYYY-MM-DD");
                  d.dateLabel = moment($scope.currentDate).add(days,'days').format("DD.MM.YYYY");
                  d.tasks = [];
                  // add all tasks from class calendar
                  if(self.classContent[self.currentClass.ID].classCalendarByDate[d.date])
                    for(var x=0; x < self.classContent[self.currentClass.ID].classCalendarByDate[d.date].length; x++){
                      var tt = self.getTaskByID(self.classContent[self.currentClass.ID].classCalendarByDate[d.date][x].Task);
                      if(tt){
                        if(!filter || filter.indexOf(tt.mainTopic.ID) != -1)
                          d.tasks.push(tt.task);
                      }
                    }

                  d.studentTasks = {};
                  d.studentCalendarLines = {};
                  d.hasStudentCalendarNotes = false;
                  d.maxStudentTasks = 0;
                  // add all students tasks from personal calendars
                  for(var s=0; s < self.currentClass.students.length; s++){
                    var student = self.currentClass.students[s];
                    var sid = student.ID;
                    d.studentTasks[sid] = [];
                    d.studentCalendarLines[sid] = getMergedCalendarNoteEntries(d.date, student);

                    if(self.users[sid] && 
                       self.users[sid].calendarsByDate && 
                       self.users[sid].calendarsByDate[self.currentClass.ID] &&
                       self.users[sid].calendarsByDate[self.currentClass.ID][d.date])
                      for(var x=0; x < self.users[sid].calendarsByDate[self.currentClass.ID][d.date].length; x++){
                        var tt = self.getTaskByID(self.users[sid].calendarsByDate[self.currentClass.ID][d.date][x].Task);
                        if(tt){
                          if(!filter || filter.indexOf(tt.mainTopic.ID) != -1)
                            d.studentTasks[sid].push(tt.task);
                        }
                      }

                    if(d.studentCalendarLines[sid].length > 0) d.hasStudentCalendarNotes = true;

                    d.maxStudentTasks = Math.max(d.maxStudentTasks, d.studentTasks[sid].length);
                  }

                  $scope.currentClassProgressCalendarWeeks[i].days.push(d);
                }
              }
              if(!noAnimation)
                self.runUpMainClassProgressList();
            };

            progressCalendarSignatureUnwatch = $scope.$watch(getProgressCalendarDataSignature, function(nv,ov){
              if(!self.currentClassProgressCalendarMode) return;
              if(typeof ov === "undefined") return;
              if(nv == ov) return;
              scheduleProgressCalendarAutoRefresh();
            });

            $scope.$on("$destroy", function(){
              if(progressCalendarAutoRefreshPromise) $timeout.cancel(progressCalendarAutoRefreshPromise);
              if(progressCalendarSignatureUnwatch) progressCalendarSignatureUnwatch();
            });

            if(calendarDate) {
              var d = moment(calendarDate).startOf('isoWeek').diff(moment().startOf('isoWeek'), 'weeks');
              $scope.changeClassProgressCalendarMode(d >= 0 ? 1 : -d+1);
            }

            self.progressMainTopic = self.currentMainTopic;
            self.progressTopic = self.currentTopic;
            $scope.smallScreen = self.isSmallScreen;
            $scope.waitForDownload = false;

            if(!self.progressTopic) self.runUpMainClassProgressList(); else self.runUpClassProgressList(self.currentTopic);

            var openClassProgressClass = function(it,ev){
              if(!it) return;
              if(self.currentClass && self.currentClass.ID == it.ID) return;
              var oldprogressMainTopic = self.progressMainTopic;
              var oldprogressTopic = self.progressTopic;
              var oldcurrentClassProgressCalendarMode = self.currentClassProgressCalendarMode;
              self.closeDialog($scope.dialogElement);
              self.openClass(it,ev);
              $timeout(function(){
                self.showClassProgress(false,ev);
                $timeout(function(){
                  self.progressMainTopic = null;
                  self.progressTopic = null;
                  self.currentClassProgressCalendarMode = oldcurrentClassProgressCalendarMode;

                  if(oldprogressMainTopic && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].mainTopics){
                    for(var i = 0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
                      if(self.classContent[self.currentClass.ID].mainTopics[i].ID == oldprogressMainTopic.ID){
                        self.progressMainTopic = self.classContent[self.currentClass.ID].mainTopics[i];
                        for(var z = 0; z < self.progressMainTopic.topics.length; z++){
                          if(self.progressMainTopic.topics[z].ID == oldprogressTopic.ID){
                            self.progressTopic = self.progressMainTopic.topics[z];
                            break;
                          }
                        }
                        break;
                      }
                    }
                  }
                  if(!self.progressTopic) self.runUpMainClassProgressList(); else self.runUpClassProgressList(self.currentTopic);
                },250);
              },0);
            };
            $scope.openClassProgressClass = openClassProgressClass;

            $scope.openMainTopicSelect = function(ev){

              var position = $mdPanel.newPanelPosition()
                  .absolute().relativeTo(ev.target)
                  .addPanelPosition('align-start', 'below')
                  .addPanelPosition('align-start', 'center')
                  .addPanelPosition('align-start', 'above');

              var panelAnimation = $mdPanel.newPanelAnimation()
                  .openFrom(ev)
                  .withAnimation($mdPanel.animation.SCALE);

              var config = {
                attachTo: angular.element(document.body),
                onDomAdded: function(e){
                  var menu = e[1];
                  self.limitPanelToViewport(menu._panelEl);
                  var container = menu._panelContainer.get(0);
                  container.addEventListener("click", function (e) {
                    if (e.target === container) {
                      menu.close();
                    }
                  });          
                },
                templateUrl: "progressMainTopicSelectPanel.html",
                controller: function ($scope, $mdPanel, mdPanelRef) {
                  $scope.self = self;
                  $scope.openClassProgressClass = function(it,ev){
                    mdPanelRef.close();
                    openClassProgressClass(it,ev);
                  };
                  $scope.select = function(mt,t){
                    mdPanelRef.close();
                    self.setCurrentTopic(mt,t);
                    self.progressMainTopic = self.currentMainTopic;
                    self.progressTopic = self.currentTopic;
                    self.runUpClassProgressList(self.currentTopic);
                  };
                },
                position: position,
                animation: panelAnimation,
                openFrom: ev,
                clickOutsideToClose: true,
                escapeToClose: true,
                focusOnOpen: true,
                zIndex: 200
              };

              self.showPanel(config);
            };

            $scope.exportClassResultsData = function(type, filter, maintopic, topic, ev){
              $scope.waitForDownload = true;
              var url = "https://learningview.org/api/exportProgress.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID+"&type="+type;
              if(type == "files")
                 url = "https://learningview.org/api/exportUploads.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID;

              if(maintopic) url += '&maintopic='+maintopic.ID;
              if(topic) url += '&topic='+topic.ID;

              if(filter && filter.length > 0){
                url += '&filter='+filter.join(",");
              }
              var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
              function checkDownload(){
                if(document.cookie.indexOf("fileDownload=true") > -1) {
                  var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                  document.cookie = cookieData;
                  setTimeout(function(){ frame.remove();},1000);
                  $scope.waitForDownload = false;
                }else
                  $timeout(checkDownload,100);
              }
              var desc = "";
              if(maintopic) desc += "_"+maintopic.Name;
              if(topic) desc += "_"+topic.Name;
              var filename = self.currentClass.Name+desc;
              filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
              var filename = window.cleanFilename("LearningViewExport_"+filename+"_"+moment().format('YYYY_MM_DD'))+(type == "files" ? ".zip" : ".xlsx");
              if(window.electron){
                window.downloadElectronSaveAs(url,filename,function(){
                  $timeout(function(){$scope.waitForDownload = false;},0);
                });
              }else
              if(typeof cordova != "undefined"){
                self.downloadFile(url,filename,true);
                $timeout(function(){$scope.waitForDownload = false;},500);
              }else{
                $('body').append(frame);
                checkDownload();
              }
            };

            $scope.ok = function() {
              self.closeDialog($scope.dialogElement);
            };

            done();
          }
        });
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.switchUserTo = function(u){
      self.apiPost("loginUser",{"salt":u.salt,"uid":u.userid,"noerror":1, "device":self.getDeviceName()})
       .then(function(data) {
         self.loginUser(data.user);
       },function(data){
         if(data.error == "error_loginDataOutdated"){
           self.alert("Die Anmeldedaten sind veraltet. Bitte melde dich erneut an.");
           self.deleteSwitchUser(u.userid);
         }else
         if(data.error == "error_loginFailedRetryLater"){
           self.alert("Zu viele Anmeldeversuche. Probiere es in 15 Minuten noch einmal.");
         }else
         if(data.error == "error_loginFailed"){
           self.alert("Anmeldung fehlgeschlagen.");
         } else
           self.alert("Verbindung fehlgeschlagen.");
       });
    };

    self.askDeleteSwitchUser = function(u){
      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETESWITCHUSER')+'</span>',$filter('trans')('OK'),null).then(function(){
        self.deleteSwitchUser(u);
      });
    };

    self.deleteSwitchUser = function(u){
      var users = [];
      if(self.getLocalStorage("switchUsers") != null){
        users = JSON.parse(self.getLocalStorage("switchUsers"));
      }
      for(var i=0; i < users.length; i++){
        if(users[i].userid == u){
          users.splice(i,1);
          break;
        }
      }
      self.setLocalStorage("switchUsers",angular.toJson(users));
      self.switchUsers = JSON.parse(self.getLocalStorage("switchUsers"));
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.loginUser = function(u){
      if(self.studentSignup && u.Teacher == 1){
        self.waitForFirstLogin = false; 
        // account exists for this email as teacher but tried to signup as student
        self.confirm($filter('trans')('ASKINVITEDASSTUDENTREGISTERWITHOUTEMAILINSTEAD'),$filter('trans')('CREATE'),null).then(function(){
        self.apiPost("registerUser",{"email":u.Email,"createstudent":1, "name":u.Name,"surname":u.Surname, "device":self.getDeviceName()})
         .then(function(data) {
           self.loginUser(data.user);
           self.closeDialog($scope.dialogElement);
          });             
        });
/*
        self.confirm('<span style="color:red;font-weight:bold">'+$filter('trans')('CONFIRMINVITEDASSTUDENTBUTTEACHER')+'</span>',$filter('trans')('CONTINUE'),null,$filter('trans')('BACK')).then(function(){
          self.studentSignup = false;
          self.loginUser(u);
        },function(){
          self.waitForFirstLogin = false; 

        });
*/        
        return;
      }
      if(self.teacherSignup && u.Teacher == 0){
        self.confirm('<span style="color:red;font-weight:bold">'+$filter('trans')('CONFIRMINVITEDASTEACHERBUTSTUDENT')+'</span>',$filter('trans')('CONTINUE'),null,$filter('trans')('BACK')).then(function(){
          self.studentSignup = false;
          self.loginUser(u);
        },function(){
          self.waitForFirstLogin = false; 
        });
        return;
      }
      self.userViewData = {}; // reset data now
      self.applyUserFontHEXP();
      self.lastUpdateTime = 0;
      self.user = u;
      self.updateUser(u);

      if(self.loginWithOAuthInterval) clearInterval(self.loginWithOAuthInterval);

      if(!self.user.ClassNameSorting) self.user.ClassNameSorting = "Name";

      self.initLoadingDone = false;
      window.__lvInitErrorAlertShown = false;
      if(self.keepSignedInAfterRestart && u.debug != 1){
        var p = {Salt:u.Salt, ID:u.ID,name:u.Name,surname:u.Surname, teacher:u.Teacher};
        self.setLocalStorage("user", JSON.stringify(p));
      }else{
        self.setLocalStorage("user",null);
      }
      self.currentTeacherNavigation = "";
      var ad = self.getLocalStorage("selectedClassActivityTimeDate");
      if(ad) {
        self.selectedClassActivityTimeDate = moment(new Date(ad)).startOf('day').toDate();
      }
      var ad = self.getLocalStorage("selectedClassActivityTimeHour");
      if(ad) {
        self.selectedClassActivityTimeHour = parseInt(ad);
      }
      var ad = self.getLocalStorage("selectedClassActivityTimeMinute");
      if(ad) {
        self.selectedClassActivityTimeMinute = parseInt(ad);
      }
      self.setClassActivityTimeDate();

      if(self.getLocalStorage("GCMToken") !== null)
        self.apiPost("ajax",{"action":"setPushToken","type":'gcm', "token":self.getLocalStorage("GCMToken")});
      if(self.getLocalStorage("APNSToken") !== null)
        self.apiPost("ajax",{"action":"setPushToken","type":'apns', "token":self.getLocalStorage("APNSToken")});

      self.keepAliveCallback(true).then(function(){
        self.initLoadingDone = true;
        $timeout(function(){
          self.checkSurveys(true);
        },1000);
        self.track('login',{ID:u.ID, version:self.userViewData && self.userViewData["appVersion"] ? self.userViewData["appVersion"]:'', from: window.electron ? 'app': ((typeof cordova == "undefined") ? 'browser' : 'app'),"userAgent": navigator && navigator.userAgent ? navigator.userAgent : '' });

        if(u.Teacher == "0"){
          self.selectedClassActivityTime = 'ever';
          if(self.classList.length > 0){
            if(self.user.lastOpenClass && self.user.lastOpenClass != '0'){
              for(var i=0; i < self.classList.length; i++)
                if(self.classList[i].Archived != "1" &&
                   self.classList[i].ID == self.user.lastOpenClass){
                  self.openClass(self.classList[i],null,false,true);
                  break;
                }
            }
            if(!self.currentClass) {
              for(var i=0; i < self.classList.length; i++)
                if(self.classList[i].Archived != "1"){
                  self.lastClassOnReset = self.classList[i];
                  self.openClass(self.classList[i],null,false,true);
                  break;
                }
            }
          }
        }
        if(u.Teacher == "1"){
          self.filterCurrentClassOnly = true;
          self.currentTeacherNavigation = "Classes";
          self.manageClassView = true;

          if(self.classList.length > 0){
            if(self.user.lastOpenClass){
              for(var i=0; i < self.classList.length; i++)
                if(self.classList[i].Archived == "0" && self.classList[i].ID == self.user.lastOpenClass){
                  if(self.userContent.mainTopics.length > 0) {
                    self.openClass(self.classList[i],null,false,true);
                    self.currentTeacherNavigation = "Teach";
                    self.manageClassView = false;
                  }else{
                    self.lastClassOnReset = self.classList[i];
                  }
                  break;
                }
            }
            if(!self.currentClass) {
              for(var i=0; i < self.classList.length; i++)
                if(self.classList[i].Archived != "1"){
                  self.lastClassOnReset = self.classList[i];
                  self.openClass(self.classList[i],null,false,true);
                  self.editClass(self.currentClass);
                  break;
                }
            }
          }
          /*
          if(self.currentClass && self.user.Teacher == "1")
            self.apiPost("ajax",{"action":"getClassStudentClasses","ID":self.currentClass.ID}).then(function(result){
              self.currentClassStudentClasses = result.classes;
            });
          */
        }

        if(self.user.Teacher == "1") {
          var check = true;
          if(check) check = self.askSchoolManaged();
          if(check) check = self.askCountryAndState();
        }

        if(self.user.Teacher == "0") self.updateStudentClassesStatus();
        if(self.user.Teacher == "1") self.updateClassesStatus();
        if(self.user.Teacher == "1") self.loadMaterialFilter();

        self.updateRubrics();
        self.updateRubricsStatus();
        self.updateNewTaskBadges();
        self.updateNewActivityBadge();
        self.updateNewFolderItemsBadge();
        self.updateChatRooms(self.chatRooms);

        if(self.getSessionStorage("inviteLinkUsed")){
          var content = JSON.parse(self.getSessionStorage("inviteLinkUsed"));
          if(content.type == "school")
            $timeout(function() {
              if(self.schoolSignupData && self.user.Teacher == "1"){
                if(self.schoolSignupData.useDomain){
                  var d = self.user.Email.split("@").pop();
                  if(self.schoolSignupData.Domain.toLowerCase() == d.toLowerCase()){
                    self.askSchoolManagedInvited(self.schoolSignupData);
                  }else{
                    self.alert($filter('trans')('SCHOOLINVITENOMATCHINGDOMAIN',self.schoolSignupData.Domain));
                  }
                } else
                  self.askSchoolManagedInvited(self.schoolSignupData);
              }
            },500);          

          if(content.type == "teacher")
            $timeout(function() {
              if(self.user.Teacher == "1"){
                self.apiPost("ajax",{"action":"addClassTeacherByCode","ID":content.id,"code":content.code}).then(function(data) {
                  if(self.currentTeacherNavigation != 'Classes') {
                    self.openEditClasses();
                  }
                  self.keepAliveCallback().then(function(){
                    for(var i=0; i < self.classListCurrent.length; i++){
                      if(self.classListCurrent[i].ID == content.id){
                        self.selectEditClass(self.classListCurrent[i]);
                        break;
                      }
                    }
                  });
                },function(data, status, headers, config) {
                  self.alert("Error: "+data.error);
                });
              }
            },500);        

          if(content.type == "student")
            $timeout(function() {
              if(self.user.Teacher == "0" && self.studentSignupData){
                self.addUserClass(self.studentSignupData.GUID,null,true);
              }
            },500);          

          if(content.type == "mainTopic")
            $timeout(function() {
              if(self.user.Teacher == "1"){
                self.apiPost("ajax",{"action":"addMainTopicShareByCode","ID":content.id,"code":content.code}).then(function(data) {
                  self.openMaterials(null);
                });
              }
            },500);          

          self.setSessionStorage("inviteLinkUsed",null); // remove now
        }

        if(self.getSessionStorage("shareLinkUsed")){
          var content = JSON.parse(self.getSessionStorage("shareLinkUsed"));
          $timeout(function() {
            if(self.user.Teacher == "1"){
              if(content.type == 1){
                var mainTopic = self.getUserContentByID("maintopic",content.id);
                if(mainTopic){
                  self.findAndShowMainTopic(mainTopic,true);
                }else{
                  // ask for a copy of this material
                  self.apiPost("ajax",{"action":"requestShareMainTopic", "id":content.id, "hash":content.hash})
                   .then(function(data) {
                     if(data.item){
                       self.previewSharedContent("MainTopic",data.item,content.hash);
                     }
                   });
                }
              }
              if(content.type == 2){
                var topic = self.getUserContentByID("topic",content.id);
                if(topic){
                  self.findAndShowTopic(topic.topic ? topic.topic : topic,true);
                }else{
                  // ask for a copy of this material
                  self.apiPost("ajax",{"action":"requestShareTopic", "id":content.id, "hash":content.hash})
                   .then(function(data) {
                     if(data.item){
                       self.previewSharedContent("Topic",data.item,content.hash);
                     }
                   });
                }
              }
              if(content.type == 3){
                var goal = self.getUserContentByID("goal",content.id);
                if(goal){
                  self.findAndShowLearningGoal(goal.goal ? goal.goal : goal,true);
                }else{
                  // ask for a copy of this material
                  self.apiPost("ajax",{"action":"requestShareLearningGoal", "id":content.id, "hash":content.hash})
                   .then(function(data) {
                     if(data.item){
                       self.previewSharedContent("LearningGoal",data.item,content.hash);
                     }
                   });
                }
              }
              if(content.type == 4){
                var task = self.getUserContentByID("task",content.id);
                if(task) {
                  self.findAndShowTask(task.task ? task.task : task,true);
                }else{
                  // ask for a copy of this material
                  self.apiPost("ajax",{"action":"requestShareTask", "id":content.id, "hash":content.hash})
                   .then(function(data) {
                     if(data.item){
                       self.previewSharedContent("Task",data.item,content.hash);
                     }
                   });
                }
              }
            }
            if(self.user.Teacher == "0"){
              if(content.type == 1){
                var mainTopic = self.getMainTopicByID(content.id);
                if(mainTopic){
                  self.openClass(mainTopic.currentClass);
                  $timeout(function() {
                    self.findAndShowMainTopic(mainTopic);
                  },200);
                }else{
                  self.alert($filter('trans')('NOTFOUNDINMYLEARNINGVIEW'));                  
                }
              }
              if(content.type == 2){
                var topic = self.getTopicByID(content.id);
                if(topic){
                  self.openClass(topic.currentClass);
                  $timeout(function() {
                    self.findAndShowTopic(topic.topic ? topic.topic : topic);
                  },200);
                }else{
                  self.alert($filter('trans')('NOTFOUNDINMYLEARNINGVIEW'));                  
                }
              }
              if(content.type == 3){
                var goal = self.getGoalByID(content.id);
                if(goal){
                  self.openClass(goal.currentClass);
                  $timeout(function() {
                    self.findAndShowLearningGoal(goal.goal ? goal.goal : goal);
                  },200);
                }else{
                  self.alert($filter('trans')('NOTFOUNDINMYLEARNINGVIEW'));                  
                }
              }
              if(content.type == 4){
                var task = self.getTaskByID(content.id);
                if(task) {
                  self.openClass(task.currentClass);
                  $timeout(function() {
                    self.findAndShowTask(task.task ? task.task : task);
                  },200);
                }else{
                  self.alert($filter('trans')('NOTFOUNDINMYLEARNINGVIEW'));                  
                }
              }
            }
          },500);
          self.setSessionStorage("shareLinkUsed",null); // remove now
        }
        var setFirstFocusAfterLogin = true;
        // maybe not so good
        if(self.user.Teacher == "1" && self.userContent && self.userContent.mainTopics && self.userContent.mainTopics.length == 0) {
          if(self.getLocalStorage("openTeacherIntro") != 1){
            self.setLocalStorage("openTeacherIntro",1); 
            self.openTeacherIntro();
            setFirstFocusAfterLogin = false;
          } 
        }
        if(self.user.Teacher == "0" && self.user.ID != '-1' &&
          (self.users[self.user.ID].journal.length == 0)) {
          if(self.getLocalStorage("openStudentIntro") != 1){
            self.setLocalStorage("openStudentIntro",1); 
            self.openStudentIntro();
            setFirstFocusAfterLogin = false;
          } 
        }
        // set first focus after login
        if(setFirstFocusAfterLogin){
          $timeout(function(){
            if(self.user.Teacher == "0"){
              $('#selectClassBtn').focus();
            }          
            if(self.user.Teacher == "1"){
              $('.mainNavBar').focus();
            }                      
          },200);
        }

        // load plugins
        requireJavascript("https://learningview.org/plugins/advent.js?v4");

        if(self.user.Science == 1 || self.user.Science == 10 || self.user.Science == 20){
          requireJavascript("https://learningview.org/plugins/assistent.js?r="+Math.random());
        }

        if(self.user.ID != -1)
          if(self.user.Science == 50 || self.user.Science == 51){
            requireJavascript("https://ml4ed-apps.epfl.ch/ml4ed_learningview/log.js?r="+Math.random());
          }

        if(self.user.ID == -1 || self.user.Science == 50 || self.user.Science == 51 || self.user.Science == 52){
          requireJavascript("https://learningview.org/plugins/SRL.js?r="+Math.random());
        }

      });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.waitForFirstLogin = true;
    self.relogin = function(relogin){
      if(!self.keepSignedInAfterRestart){
        self.waitForFirstLogin = false;
        return;
      }
      if (self.getLocalStorage("user") !== null) {
        // auto login with salt
        var p = JSON.parse(self.getLocalStorage("user"));

        if(self.getSessionStorage("inviteLinkUsed") || self.getSessionStorage("shareLinkUsed")){
          var users = [];
          if(self.getLocalStorage("switchUsers") != null){
            users = JSON.parse(self.getLocalStorage("switchUsers"));
          }
          var isThere = false;
          for(var i=0; i < users.length; i++){
            if(users[i].userid == p.ID){
              isThere = true;
              break;
            }
          }

          if(!isThere){
            users.push({"userid":p.ID,"salt":p.Salt,
                        "name":p.name,"surname":p.surname,
                        "teacher":p.teacher,
                        "lastUsed":new Date().getTime()});
            self.setLocalStorage("switchUsers",angular.toJson(users));
          }

          if(users.length > 0){
            // show select user screen
            self.waitForFirstLogin = false;
            return;
          }
        }else
        if(p.teacher == 0){
          var hasTeacher = false;
          var users = [];
          if(self.getLocalStorage("switchUsers") != null){
            users = JSON.parse(self.getLocalStorage("switchUsers"));
          }
          for(var i=0; i < users.length; i++){
            if(users[i].teacher == 1){
              hasTeacher = true;
              break;
            }
          }
          if(hasTeacher){
            // show select user screen
            self.waitForFirstLogin = false;
            return;            
          }
        }
        if(p.ID != -1){
          self.apiPost("loginUser",{uid:p.ID, salt:p.Salt,"noerror":1, "device":self.getDeviceName()})
           .then(function(data) {
             self.loginUser(data.user);
           },function(result){
             if(result && result.error == "error_loginDataOutdated"){
               // logout now
               //self.logout();
               self.waitForFirstLogin = false;
               return;
             }
             self.waitForFirstLogin = false;
             self.retryLogin();
           });
        }else{
          self.waitForFirstLogin = false;
        }
      } else self.waitForFirstLogin = false;
    };

    self.retryLogin = function() {
      self.waitForFirstLogin = false;
      setTimeout(function(){
        self.relogin();
      },2000);
    };

    self.showLatestNews = function(ev){
      self.apiPost("ajax",{"action":"getAllNews"})
       .then(function(data) {
         self.showDialog({
           templateUrl: "latestNews.html",
           targetEvent: ev,
           skipHide:true, // keep other dialog open
           clickOutsideToClose: true,
           controller: function ($scope, $mdDialog) {
             $scope.self = self;
             $scope.news = data.news;
             $scope.news.sort(function(a,b){
               var ob = parseInt(a.ID); // reverse order
               var oa = parseInt(b.ID);
               return oa < ob ? -1 : (oa > ob ? 1 : (a.ID < b.ID ? -1 : (a.ID > b.ID ? 1 : 0)));
             });

             $scope.untilNow = self.userViewData["latestNews"];
             if(!$scope.untilNow || $scope.untilNow == "") $scope.untilNow = 0;
             self.newsCounter = 0;
             var maxID = 0;
             $scope.currentIndex = -1;
             for(var i=0; i < data.news.length; i++){
               maxID = Math.max(maxID,data.news[i].ID);
               if(data.news[i].ID >= $scope.untilNow) $scope.currentIndex++;
             }
             if($scope.currentIndex > 5) $scope.currentIndex = 5;
             self.userViewData["latestNews"] = maxID;
             self.updateUserViewData();

             $scope.ok = function(){
               self.closeDialog($scope.dialogElement);
             };
           }
         });
       });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Plugin-System
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.plugins = {plugins:[]};
    if(!jQuery.fn.insertAt) // helper function for plugins
      jQuery.fn.insertAt = function(index, element) {
        var lastIndex = this.children().length;
        if (index < 0) {
          index = Math.max(0, lastIndex + 1 + index);
        }
        this.append(element);
        if (index < lastIndex) {
          this.children().eq(index).before(this.children().last());
        }
        return this;
      };

    self.plugins.initPlugin = function(options,callback){
      if(!options.name) {
        console.log("Plugin needs a name!");
        return;
      }
      self.plugins.plugins.push(options);

      var doCallback = function(){
        if(callback) {
          $injector.invoke(callback,$scope,
            {$scope:$scope, $injector:$injector, $timeout:$timeout, $interval:$interval, $location:$location,
               $mdDialog:$mdDialog, $mdMenu:$mdMenu, $mdPanel:$mdPanel,$mdToast:$mdToast, $filter:$filter,
               $mdUtil:$mdUtil, $window:$window, $sce:$sce, $log:$log, $q:$q, $animate:$animate,
               $mdMedia:$mdMedia, $http:$http, $mdSidenav:$mdSidenav, $mdBottomSheet:$mdBottomSheet,
               $templateCache:$templateCache
             });
        }
      };

      var getTemplates = function(){
        if(options.templates){
          $.ajax({url:'https://learningview.org/plugins/'+options.templates, type:'GET'})
           .done(function(data){ $compile(data);})
           .always(doCallback);
        }else{
          doCallback();
        }
      };

      var getTranslations = function(){
        if(options.translations){
          var i18n = "";
          var lang = "";
          if(options.translations[app.currentLanguage]){
            lang = app.currentLanguage;
          }else{
            lang = Object.keys(options.translations)[0];
          }
          i18n = options.translations[lang];
          $.getJSON("https://learningview.org/plugins/"+i18n+"?r="+Math.random(),function(data){
            if(app.translations[lang]){
              for(var key in data){
                app.translations[lang][key] = data[key];
              }
            }else{
              app.translations[lang] = data;
            }
            getTemplates();
          }).error(function(){
            getTemplates();
          });
        }else{
          getTemplates();
        }
      };
      // load css and html templates if exist for this plugin
      if(options.css)
        loadCSS('https://learningview.org/plugins/'+options.css);

      options.self = self;
      options.scope = $scope;
      options.log = console.log;
      options.injectInTemplate = function(template, searchReplace, insertCode){
        var s = $templateCache.get(template);
        if(!s) return false;
        s = s.replace(searchReplace,insertCode);
        $templateCache.put(template,s);
        $timeout(function(){
          // $compile
          self.templateRefresh = true;
        },0);
        $timeout(function(){
          self.templateRefresh = false;
        },10);
      };
      options.saveData = function(type, data){
        if(type == "user"){
          self.userViewData["plugins_"+options.name] = data;
          self.updateUserViewData();
        }
        if(type == "userclass"){
          if(!self.currentClass) return false;
          if(!self.userClassViewData) self.userClassViewData = {};
          if(!self.userClassViewData[self.currentClass.ID])
              self.userClassViewData[self.currentClass.ID] = {};
          self.userClassViewData[self.currentClass.ID]["plugins_"+options.name] = data;
          self.updateUserClassViewData(self.currentClass.ID);
        }
        if(type == "class"){
          if(!self.currentClass) return false;
          if(!self.classToolSettings) self.classToolSettings = {};
          if(!self.classToolSettings[self.currentClass.ID])
              self.classToolSettings[self.currentClass.ID] = {};
          self.classToolSettings[self.currentClass.ID]["plugins_"+options.name] = data;
          self.sendClassToolSettings(self.currentClass.ID);
          return true;
        }
      };
      options.loadData = function(type){
        if(type == "user"){
          if(!self.userViewData) return null;
          if(!self.userViewData["plugins_"+options.name]) return null;
          return self.userViewData["plugins_"+options.name];
        }
        if(type == "userclass"){
          if(!self.currentClass) return null;
          if(!self.userClassViewData) return null;
          if(!self.userClassViewData[self.currentClass.ID]) return null;
          if(!self.userClassViewData[self.currentClass.ID]["plugins_"+options.name]) return null;
          return self.userClassViewData[self.currentClass.ID]["plugins_"+options.name];
        }
        if(type == "class"){
          if(!self.currentClass) return null;
          if(!self.classToolSettings) return null;
          if(!self.classToolSettings[self.currentClass.ID]) return null;
          if(!self.classToolSettings[self.currentClass.ID]["plugins_"+options.name]) return null;
          return self.classToolSettings[self.currentClass.ID]["plugins_"+options.name];
        }
      };
      getTranslations(); // fetch files if required
      console.log("Plugin init: " +options.name);
    };
    window.initPlugin = self.plugins.initPlugin; // expose to global scope for plugin files to call
    ///////////////////////////////////////////////////////////////////////////////////////////////////


    self.keepAliveIntervalWorking = false;
    self.lastUpdateTime = 0;
    self.updateWaitCount = 0;
    self.informNewVersion = false;
    self.informNewVersionCounter = 0;
    self.knownShareUsers = [];
    self.knownOwners = [];


    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateKnownShareUsers = function(){
      self.knownShareUsers = [];
      self.knownOwners = [];
      if(self.userContent && self.userContent.mainTopics){
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          var ownerFound = false;
          for(var x=0; x < self.knownOwners.length; x++){
            if(self.knownOwners[x].User == self.userContent.mainTopics[i].Owner){
              ownerFound = true;
              break;
            }
          }  
          if(!ownerFound){
            var u = self.userContent.mainTopics[i].Owner;
            if(self.users && self.users[u]){
              self.knownOwners.push({User:u,Name:self.users[u].Name,Surname:self.users[u].Surname});
            }
          }

          if(self.userContent.mainTopics[i].shareSettings)
          for(var z=0; z < self.userContent.mainTopics[i].shareSettings.length; z++){
            var s = self.userContent.mainTopics[i].shareSettings[z];
            var found = false;
            for(var x=0; x < self.knownShareUsers.length; x++){
              if(self.knownShareUsers[x].User == s.User){
                found = true;
                break;
              }
            }  
            if(found) continue;
            self.knownShareUsers.push(s);
          }
        }
        self.knownShareUsersCount = Object.keys(self.knownShareUsers).length;
        self.knownOwnersCount = Object.keys(self.knownOwners).length;
      }
    };

    self.updateChatRooms = function(rooms){
      self.chatRooms = rooms;
      var old = self.chatRoomNews;
      self.chatRoomNews = 0;
      var showRoom = null;
      var now = (new Date()).getTime();

      for(var i=0; i < self.chatRooms.length; i++){
        if(self.currentOpenChat && self.chatRooms[i].ID == self.currentOpenChat.ID){
          self.currentOpenChat = self.chatRooms[i];
        }

        self.chatRooms[i].mute = false;
        if(!self.chatRooms[i].users) continue; // no users in room ?!

        for(var z = 0; z < self.chatRooms[i].users.length; z++){
          if(self.chatRooms[i].users[z].User == self.user.ID){
            if(self.chatRooms[i].users[z].mute){
              var d = (new Date().fromMysqlFormat(self.chatRooms[i].users[z].mute)).getTime();
              var hours = Math.abs(d - now) / 3600000;
              if(hours > 100) self.chatRooms[i].mute = 9999;
              if(hours < 73) self.chatRooms[i].mute = 72;
              if(hours < 25) self.chatRooms[i].mute = 24;
              if(hours < 9) self.chatRooms[i].mute = 8;
              if(hours < 1) self.chatRooms[i].mute = 1;
            }
            break;
          }
        }
        if(self.chatRooms[i].mute) continue; // skip muted room 
        
        // TODO: skip counter if users in chat room are no longer in class?
        // how to make this efficient here?

        var n = parseInt(self.chatRooms[i].new);
        self.chatRoomNews += n;
        if(!showRoom && n > 0) showRoom = self.chatRooms[i];
      }

      if(showRoom && self.user.Teacher == "0" &&
        (!self.capture || !self.capture.recording) &&
        !self.currentOpenChat && self.currentClass &&
         self.currentClass.ID == showRoom.Class && self.chatRoomNews > old){

        if(!self.chatRoomClosed || self.chatRoomClosed < now - 1000*60*3){
          self.openChatRooms(showRoom,null,null);
        }
      }

      if(self.chatRoomNews > old){
        if(self.chatRoomRingSound &&
         (!self.chatRoomRingPlayed || self.chatRoomRingPlayed < new Date().getTime() - 5000)){
          self.chatRoomRingPlayed = new Date().getTime();
          var ringSound = new Audio("https://learningview.org/app/sounds/ring.mp3");
          ringSound.play();
        }
      }
    };

    self.hasShareSetting = function(mt,share){
      if(!mt.shareSettings) return false;
      if(!share) return false;
      if(share.User == self.user.ID){
        return mt.shareSettings.length == 1;
      }
      for(var i=0; i < mt.shareSettings.length; i++){
        if(mt.shareSettings[i].User == share.User) return true;
      }

      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.currentAppVersion = null;
    self.processKeepaliveData = function (result, deferred){
      if(!self.user) return;
      if(!self.userViewData) self.userViewData = {};

      var oldLatestNews = self.userViewData["latestNews"];
      if(result.userViewData && result.userViewData != ""){
        try{
          self.loadUserViewData(JSON.parse(result.userViewData));
        }catch(e){
          console.error("Invalid userViewData JSON in keepalive:", e);
        }
      }

      if(oldLatestNews == self.userViewData["latestNews"])
        if(result.lastestNews) self.newsCounter = result.lastestNews;

      if(self.lastUpdateTime == 0) self.userViewData["appVersion"] = result.appVersion;

      var version = self.userViewData["appVersion"];
      if(!self.currentAppVersion) self.currentAppVersion = result.appVersion;
      if(version != result.appVersion || (self.currentAppVersion && self.currentAppVersion != result.appVersion)){
        // new version available, reload
        console.log("Now",version);
        console.log("Server",result.appVersion);
        self.informNewVersion = true;
        self.informNewVersionCounter = 1;
        self.userViewData["appVersion"] = result.appVersion;
      }

      if(self.informNewVersionCounter) self.informNewVersionCounter--;
      if(self.informNewVersion && self.informNewVersionCounter == 0 && !self.informNewVersionShowing){
        self.informNewVersionShowing = true;
        self.confirm('<span style="color:red;font-weight:bold">'+$filter('trans')('NEWVERSIONRELOAD')+'</span>',$filter('trans')('OK'),null).then(function(){
          window.location.reload();
        },function(){
          self.informNewVersionShowing = false;
        });
        self.informNewVersionCounter = 5;
      }

      console.log("Connected to Server ",result.server);

      self.lastUpdateTime = result.lastUpdateTime;
      self.serverTimeSecondsDelta = moment(self.lastUpdateTime).diff(moment(),"seconds");
      console.log("Last update time",self.lastUpdateTime);
      matchTimeZones(self.lastUpdateTime);

      // read new data from server and update local content

      // personal library of teacher
      if(result.mainTopics && self.user.Teacher == "1"){
        self.updateMyContent(result);
        console.log("updating user library data done");
      }

      self.trashCount = 0;
      if(result.trash){
        self.trashCount = parseInt(result.trash);
      }

      if(result.collaborations){
        self.updateCollaborations(result.collaborations);
      }

      // skill sets
      if(result.skills){
        self.updateSkillSets(result.skills);
      }

      // student user tasks
      if(result.usertaskdata){
        // will only update user tasks
        self.updateUser({ID:self.user.ID, usertaskdata:result.usertaskdata});
        console.log("updating user tasks data done");
      }

      // chat rooms
      if(result.chats){
        self.updateChatRooms(result.chats);
      }
      // teacher shares
      if(result.shares){
        self.openSharesToAccept = result.shares;
        if(self.openSharesToAccept.length > 0){
          // show first share dialog
          if(!self.autoOpendShares){
            self.acceptSharedContents();
          }
        }
      }

      // teacher classes
      if(result.classes){
        console.log("updating class data");
        self.updateClassList(result.classes);
        self.updateClassesStatus(result.classes);
        console.log("updating class data done");
      }

      // student classes
      if(result.userclasses){
        console.log("updating class data");
        var hadClass = self.currentClass != null;
        self.updateClassList(result.userclasses);
        if(hadClass && self.currentClass == null && self.classList.length > 0) {
          self.currentClass = self.classList[0];
          self.openClass(self.currentClass);
        }
        self.updateStudentClassesStatus();
        console.log("updating class data done");
      }

      if(self.classList.length <= 1)
         self.filterCurrentClassOnly = true;

      self.updateKnownShareUsers();
      self.changeClassNameOrder();

      if(result.journal && result.journal.length > 0){
        console.log("updating journal");
        // journal of current user
        self.updateUser({ID:self.user.ID, journal:result.journal}); // will only update journal
        $timeout(function() {
          self.getRecentNewJournalItems(false);
          self.showNewJournalItems(true);
        }, 0);
      }

      if(self.user.Teacher == 0) self.showCalendarDot = self.hasOpenCalendarTasksToday();

      self.shareSettings = result.shareSettings ? result.shareSettings : [];

      self.checkSurveys();

      deferred.resolve();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.allowedImageFileTypes = ['gif','png' ,'jpg','jpeg','heic','tif','tiff','svg','pdf','webp'];
    self.allowedAudioFileTypes = ['m4a','mp3','ogg','flac','wav','aiff','wma','3ga','aac'];
    self.allowedVideoFileTypes = ['mp4','m4v','mov','mpeg','mpg','avi','webp','webm','wmv','3gp'];
    self.allowedOtherFileTypes = ['pdf','doc','docx','ppt','pptx','ppsx','xls','xlsx',
                                 'zip','rar','odt','odp','ods','odb', 'txt','rtf', 'md',
                                 'pages','key','numbers','html'];
                                 // 'seb','itmz','rtd', 'sb2','sb3','epub','xml','stl','3mf','psd', 'ggb','hex','xmind','mtv','mtf','aup3' 
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkTypeFromFileName = function(fileName) {
      var re = /(?:\.([^.]+))?$/;
      var ext = re.exec(fileName.toLowerCase())[1];

      if(!ext)
        return null;

      if(ext == "pdf") return "file";

      if(self.allowedImageFileTypes.indexOf(ext) != -1)
        return "image";
      if(self.allowedAudioFileTypes.indexOf(ext) != -1)
        return "audio";
      if(self.allowedVideoFileTypes.indexOf(ext) != -1)
        return "video";
      if(self.allowedOtherFileTypes.indexOf(ext) != -1)
        return "file";

      return null;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkFileType = function(file,type,additionalFileTypes){
      var re = /(?:\.([^.]+))?$/;
      var ext = re.exec(file.name.toLowerCase())[1];
      if(!ext) {
        self.alert($filter('trans')('ONLYSOMEFILESALLOWED'));
        return false;
      }
      if(file.size && file.size > 1024*1024*500){
        self.alert($filter('trans')('ONLYSMALLERFILESALLOWED'));
        return false;
      }

      if(additionalFileTypes && additionalFileTypes.indexOf(ext) != -1) return true;

      if(type == "file" &&
        self.allowedImageFileTypes.indexOf(ext) == -1 &&
        self.allowedAudioFileTypes.indexOf(ext) == -1 &&
        self.allowedVideoFileTypes.indexOf(ext) == -1 &&
        self.allowedOtherFileTypes.indexOf(ext) == -1){
        return false;
      }
      if(type == "image" && self.allowedImageFileTypes.indexOf(ext) == -1){
        self.alert($filter('trans')('ONLYSOMEIMAGESALLOWED',self.allowedImageFileTypes.join(", ")));
        return false;
      }
      if(type == "audio" && self.allowedAudioFileTypes.indexOf(ext) == -1){
        self.alert($filter('trans')('ONLYSOMEAUDIOSALLOWED',self.allowedAudioFileTypes.join(", ")));
        return false;
      }
      if(type == "video" && self.allowedVideoFileTypes.indexOf(ext) == -1){
        self.alert($filter('trans')('ONLYSOMEVIDEOSALLOWED',self.allowedVideoFileTypes.join(", ")));
        return false;
      }
      return true;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendLastActive = function(){
      if(self.user == null) return;
      self.apiPost("ajax",{"action":"sendactive","noerror":1,"debug":self.user.debug == 1 ? 1 : 0})
    }

    self.keepAliveRequest = [];

    self.keepAliveCallback = function(firstRun,showLoadingIndicator){
      var deferred = $q.defer();
      if(self.user == null) return deferred.promise; // no polling yet
      if(!self.initLoadingDone && !firstRun) return deferred.promise; // wait for first data
      self.updateWaitCount++;
      if(self.updateWaitCount < 10){
        if(self.keepAliveIntervalWorking) return deferred.promise; // skip this one
        if(isWaitingAction) return deferred.promise; // no polling if we just change something with save timeout
      }else{
        console.log("Forcing keepalive after 10 wait fails. Maybe connection was lost.");
      }

      self.updateWaitCount = 0;
      self.keepAliveIntervalWorking = true;

      if(!self.userViewData) self.userViewData = {};
      var latestNews = self.userViewData["latestNews"];

      var currentClasses = [];
      var currentMainTopics = [];
      var archivedMainTopics = [];

      if(self.classList)
        for(var i=0; i < self.classList.length; i++)
          currentClasses.push(self.classList[i].ID);

      if(self.userContent && self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++)
          currentMainTopics.push(self.userContent.mainTopics[i].ID);
      if(self.userContent && self.userContent.archivedMainTopics)
        for(var i=0; i < self.userContent.archivedMainTopics.length; i++)
          archivedMainTopics.push(self.userContent.archivedMainTopics[i].ID);

      var actions = {"action":"keepalive",
                     "noerror":1,
                     "data":Math.random(),
                     "lastUpdateTime":self.lastUpdateTime,
                     "latestNews":latestNews ? latestNews : 0,
                     "currentClasses":currentClasses.join(","),
                     "currentMainTopics":currentMainTopics.join(","),
                     "archivedMainTopics":archivedMainTopics.join(",")
      };
      if(showLoadingIndicator) actions.indicator = true;

      $('#loadingActionText').text("sammle Daten ...");

      self.apiPost("ajax",actions).then(function(result){
        $('#loadingActionText').text("verarbeite Daten ...");
        $timeout(function(){
          // data before
          var counters = {};
          for(var i=0; i < self.classList.length; i++){
            counters[self.classList[i].ID] = {};
            counters[self.classList[i].ID].feedbackCounter = self.classList[i].feedbackCounter;
            counters[self.classList[i].ID].noteTasksCounter = self.classList[i].noteTasksCounter;
            counters[self.classList[i].ID].chatCounter = self.classList[i].chatCounter;
          }
          var isUpdateData = self.lastUpdateTime != 0;

          // process
          self.processKeepaliveData(result,deferred);
          self.updateKnownMainTopicTags();

          // data after, create desktop notifications for changes
          // TODO: Respect ClassesNotificationSettings here too?
          if(isUpdateData) 
          for(var i=0; i < self.classList.length; i++){
            if(self.user.Teacher == 0){
              // student notifications
              if((!counters[self.classList[i].ID] || counters[self.classList[i].ID].feedbackCounter < self.classList[i].feedbackCounter) && self.classList[i].feedbackCounter > 0)
                if(!(self.classList[i].notifications && self.classList[i].notifications.get.feedback === false))
                  addLocalNotification("Neue offene Aufgabe in: "+self.classList[i].Name,self.classList[i].feedbackCounter+" offene Aufgaben in "+self.classList[i].Name+".");
              if((!counters[self.classList[i].ID] || counters[self.classList[i].ID].noteTasksCounter < self.classList[i].noteTasksCounter) && self.classList[i].noteTasksCounter > 0)
                if(!(self.classList[i].notifications && self.classList[i].notifications.get.note === false))
                  addLocalNotification("Neuer Sticker bei Aufgabe in: "+self.classList[i].Name,self.classList[i].noteTasksCounter+" Sticker für Aufgaben in "+self.classList[i].Name+".");
              if((!counters[self.classList[i].ID] || counters[self.classList[i].ID].chatCounter < self.classList[i].chatCounter) && self.classList[i].chatCounter > 0)
                if(!(self.classList[i].notifications && self.classList[i].notifications.get.chat === false))
                  addLocalNotification("Neue Chat Nachricht in: "+self.classList[i].Name,self.classList[i].chatCounter+" ungelesene Chat-Nachricht(en) in "+self.classList[i].Name+".");
            }
            if(self.user.Teacher == 1){
              // teacher notifications
              if((!counters[self.classList[i].ID] || counters[self.classList[i].ID].feedbackCounter < self.classList[i].feedbackCounter) && self.classList[i].feedbackCounter > 0)
                if(!(self.classList[i].notifications && self.classList[i].notifications.get.question === false && self.classList[i].notifications.get.correction === false))
                  addLocalNotification("Neue Korrektur/Frage in: "+self.classList[i].Name,self.classList[i].feedbackCounter+" offene Korrekturen / Fragen in "+self.classList[i].Name+".");
              if((!counters[self.classList[i].ID] || counters[self.classList[i].ID].chatCounter < self.classList[i].chatCounter) && self.classList[i].chatCounter > 0)
                if(!(self.classList[i].notifications && self.classList[i].notifications.get.chat === false))
                  addLocalNotification("Neue Chat Nachricht in: "+self.classList[i].Name,self.classList[i].chatCounter+" ungelesene Chat-Nachricht(en) in "+self.classList[i].Name+".");
            }

          }
        },250);
        self.keepAliveIntervalWorking = false;

      },function(result){
        $('#loadingActionText').text("verbinde zum Server ...");
        self.keepAliveIntervalWorking = false;
        if(result.error == "error_loginDataOutdated"){
          // logout now
          self.logout();
          return;
        }
        if(result.error == "error_reload"){
          window.location.reload();
          return;
        } 
      });
      return deferred.promise;
    };

    self.keepAliveInterval = setInterval(self.keepAliveCallback,20000+Math.round(2000-Math.random()*4000));  // 10 sec

    self.activeAliveInterval = setInterval(self.sendLastActive,30000+Math.round(2000-Math.random()*4000));  // 28-32 sec

    self.currentUserPoll = setInterval(function(){
      var u = self.getLocalStorage("user");
      if(u){
        try{
          u = JSON.parse(u);
        }catch(e){
          u = {ID:0};
          localStorage.removeItem("user");
        }
        if(self.user && u.ID != self.user.ID){
          // login from other browser window
          window.location.reload();
        }
      }
    },1000);

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.timeFromNow = function(t){
      var m = moment(t);
      return m.fromNow() + " - "+m.format("H:mm [Uhr], D. MMMM");
    };
    self.shortTimeFromNow = function(t){
      var m = moment(t);
      return m.fromNow();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.timeFromNowPrivacy = function(t){
      var m = moment(t);
      if(m.hour() < 7 || m.hour() > 17){
        var today = new Date();
        today.setHours(0, 0, 0, 0);
        var from = new Date(t);
        from.setHours(0, 0, 0, 0)
        return moment(from).from(today)+ " - "+m.format("D. MMMM");
      }
      return m.fromNow() + " - "+m.format("H:mm [Uhr], D. MMMM");
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.shortDate = function(t,withYear,withweekday){
      var m = moment(t);
      var showYear = withYear || (m.year() != moment().year());
      return (withweekday ? m.format('dddd')+', ' : '') + m.format(showYear ? "DD.MM.YYYY" : "DD.MM.");
    };
    self.shortDateTime = function(t,withYear){
      var m = moment(t);
      var showYear = withYear || (m.year() != moment().year());
      return m.format((showYear ? "DD.MM.YYYY" : "DD.MM.")+ " H:mm [Uhr]").replace(" 0:00 Uhr","").replace(" 23:59 Uhr","");
    };
    self.shortDateTimePrivacy = function(t,withYear){
      var m = moment(t);
      var showYear = withYear || (m.year() != moment().year());
      if(m.hour() < 7 || m.hour() > 17 || showYear){
        var today = new Date();
        today.setHours(0, 0, 0, 0);
        var from = new Date(t);
        from.setHours(0, 0, 0, 0)
        return moment(from).format((showYear ? "DD.MM.YYYY" : "DD.MM."));
      }
      return m.format( "DD.MM., H:mm [Uhr]");
    };
    self.shortTime = function(t){
      var m = moment(t);
      return m.format("H:mm [Uhr]");
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.durationTime = function(t) {
      //0:00 format
      var s = parseInt(t % 60);
      var m = parseInt((t / 60) % 60);

      if (s < 10) {s = "0"+s;}
      // if (m < 10) {m = "0"+m;}

      formatedDuration = m + ':' + s ;

      return formatedDuration;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.mapJournalItem = function(item){
      if(!item.DataJSON) return item;
      if(item.DataJSON.Peer && !item.DataJSON.PeerStudent) {
        var student = self.users[item.DataJSON.Peer];
        if(student) {
          item.DataJSON.PeerStudent = student;
        }else{
          // Student / teacher is no longer there
          item.DataJSON.PeerStudent = {Name:$filter('trans')('UNKNOWNUSERNAME'),Surname:""};
        }
      }


      if(item.DataJSON.folder && !item.DataJSON.Folder) {
        var folder = self.findClassFolder(item.DataJSON.folder,true);
        if(folder) {
          item.DataJSON.Folder = folder;
          item.DataJSON.Class = self.findClassByID(folder.Class);            
        }else{
          // Folder is no longer there
          item.notexists = true;
          return {notexists:true};
        }
      }
      if(item.DataJSON.folder && item.DataJSON.Class){
        if(self.isClassSet('useFolders', item.DataJSON.Class) === false){
          item.notexists = true;
          return {notexists:true};
        }else{
          item.notexists = false;
        }
      }

      if(item.DataJSON.taskid && !item.DataJSON.Task) {
        var task = self.getTaskByID(item.DataJSON.taskid);
        if(task) {
          item.DataJSON.MainTopic = task.mainTopic;
          item.DataJSON.Topic = task.topic;
          item.DataJSON.LearningGoal = task.goal;
          item.DataJSON.Task = task.task;
          item.DataJSON.Class = task.currentClass;
        }else{
          // Task is no longer there
          item.notexists = true;
          return {notexists:true};
        }
      }

      if(item.DataJSON.goalid && !item.DataJSON.LearningGoal) {
        var goal = self.getGoalByID(item.DataJSON.goalid);
        if(goal) {
          item.DataJSON.MainTopic = goal.mainTopic;
          item.DataJSON.Topic = goal.topic;
          item.DataJSON.LearningGoal = goal.goal;
          item.DataJSON.Class = goal.currentClass;
        }else{
          // Goal is no longer there
          item.notexists = true;
          return {notexists:true};
        }
      }
      return item;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.setJournalRead = function(onlyCurrentClass, numItems){
      // sets all items isNew to 0
      var n = 0;
      var ids = [];
      if(!numItems || numItems > self.users[self.user.ID].journal.length)
        numItems = self.users[self.user.ID].journal.length;
      for(var i=0; i < numItems; i++){
        if(self.users[self.user.ID].journal[i].isNew == 1 &&
          (!onlyCurrentClass || (onlyCurrentClass && self.users[self.user.ID].journal[i].Class == self.currentClass.ID))) {
          ids.push(self.users[self.user.ID].journal[i].ID);
        }
      }
      if(ids.length > 0)
      self.apiPost("ajax",{"action":"setJournalRead","ids":ids.join(",")})
       .then(function(data) {
         for(var i=0; i < self.users[self.user.ID].journal.length; i++){
           if(ids.indexOf(self.users[self.user.ID].journal[i].ID) != -1)
             self.users[self.user.ID].journal[i].isNew = 0;
         }
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.manageUserUploads = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "manageUserUploads.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        escapeToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.files = [];

          $scope.openFile = function(f,ev){
            self.openWeblink({DataJSON:f});
          };

          $scope.removeFile = function(f,ev){
            self.confirm('<span style="color:red;font-weight:bold">'+$filter('trans')('CONFIRMDELETEFILE',f.Filename)+'</span>',$filter('trans')('DELETE'),ev).then(function(){
              self.apiPost("ajax",{"action":"manageUserUploads", "do":"delete", "ID":f.ID}).then(function(data) {
                self.alert($filter('trans')('CONFIRMDELETEDFILE',f.Filename));
                $scope.refresh();
              });
            });
          };

          $scope.refresh = function() {
            self.apiPost("ajax",{"action":"manageUserUploads","do":"list"}).then(function(data) {
              $scope.files = data.files;
              $scope.files.sort(function(a,b){
                return a.Created < b.Created ? 1 : (a.Created > b.Created ? -1 : 0);
              });
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.reject("cancel");
          };

          $scope.refresh();
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // deprecated Juli 2022 - we do not write into logs anymore
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.writeJournalItem = function(ev,attachtotype,attachto,toclass,selectedStudents){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "writejournalitem.html",
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.Text = {input:""};
          $scope.isCordova = !(typeof cordova == "undefined");
          $scope.towholeclass = toclass ? true : false;
          if(toclass){
            $scope.toSomeStudents = selectedStudents && selectedStudents.length > 0 ? selectedStudents.length+"/"+toclass.students.length : false;
          }
          $scope.attachtotype = attachtotype;
          $scope.attachto = attachto;

          $scope.attachment = null;

          $scope.removeAttachment = function(){
            $scope.attachment = null;
          };

          $scope.uploadFileSubmit = function(e,type){
            e = e && e.target && !e.files ? e.target : e;
            if(e.files.length == 0) return;
            if(!self.checkFileType(e.files[0],type)) return;
            var filename = e.files[0].name;
            e.files[0].myType = type;
            self.uploadFileInput(e,function(result){
              var d = {};
              d.URL = result;
              d.Media = type ? type : "file";
              d.Name = filename;
              $scope.attachment = d;
            });
            $(e).val('');
          };

          $scope.takeMedia = function(type, name = ''){
            var dM = 0;
            if(type == 'audio' || type == 'video') dM = 1;

            self.takeUserMedia(type,null,function(results){
              var d = {};
              var result = results[0];
              d.URL = result.URL;
              d.Name = result.Name;
              d.Media = result.Type;
              $scope.attachment = d;
            }, {dialogMode:dM});
          };

          $scope.save = function() {
            // try save now
            if(self.trimHTML($scope.Text.input) == "" && !$scope.attachment) {
              $('#inputText').focus();
              return;
            }
            var d = $scope.attachment ? $scope.attachment : {};
            d.Text = self.trimHTML($scope.Text.input);
            if($scope.attachtotype == "topic") d.topicid = $scope.attachto.ID;
            if($scope.attachtotype == "goal") d.goalid = $scope.attachto.ID;
            if($scope.attachtotype == "task") d.taskid = $scope.attachto.ID;
            if(toclass){
              self.apiPost("ajax",{"action":"saveClassJournalItem", "students": selectedStudents ? selectedStudents.join(",") : '*', "Text":(angular.toJson(d)), "Type":'teacherentry', "classid":toclass.ID})
              .then(function(data) {
                self.keepAliveCallback();
                self.closeDialog($scope.dialogElement);
                deferred.resolve();
              });
            }else{
              self.apiPost("ajax",{"action":"saveJournalItem", "Text":(angular.toJson(d)), "Type":(self.currentStudent == null ? 'user':'teacher')+'entry', "userid":(self.currentStudent == null ? self.user.ID:self.currentStudent.ID), "teacherid":self.user.ID, "classid":self.currentClass ? self.currentClass.ID : 0 })
              .then(function(data) {
                // update filter if not 'ever'
                self.selectedClassActivityTime = 'ever';
                self.keepAliveCallback();
                self.closeDialog($scope.dialogElement);
                deferred.resolve();
                if(data.item)
                  self.updateUser({ID:self.currentStudent == null ? self.user.ID:self.currentStudent.ID, journal:[data.item]});
                if(self.user.ID == "-1"){
                  data.item = {};
                  data.item.ID = Math.random();
                  data.item.Type = (self.currentStudent == null ? 'user':'teacher')+'entry';
                  data.item.Data = angular.toJson(d);
                  self.updateUser({ID:self.currentStudent == null ? self.user.ID:self.currentStudent.ID, journal:[data.item]});
                }
              });
            }
          };

          $scope.cancel = function() {
            if(!self.isEmptyHTMLText($scope.Text.input)){
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.closeDialog($scope.dialogElement);
                deferred.reject("cancel");
              });
            }else{
              self.closeDialog($scope.dialogElement);
              deferred.reject("cancel");
            }
          };

        }
      });
      return deferred.promise;
    };

