    self.setCurrentClassFilter = function(){
      self.filterTaskListColor = null;
      self.filterNoteListNote = null;
      self.filterNoteListColor = null;

      self.getRecentNewJournalItems(self.filterCurrentClassOnly);

      $timeout(function(){
        self.setLocalStorage("chatClassOnly",self.filterCurrentClassOnly ? 1 : 0);
        self.updateChatRooms(self.chatRooms);
        if(self.user.Teacher == 0) self.showCalendarDot = self.hasOpenCalendarTasksToday();
      },10);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.logout = function(switchUser){
      var p = {"action":"logout", "noerror":1, "switchUser":switchUser ? 1 : 0};

      if(self.getLocalStorage("GCMToken") !== null) p.pushToken = self.getLocalStorage("GCMToken");
      if(self.getLocalStorage("APNSToken") !== null) p.pushToken = self.getLocalStorage("APNSToken");
      var waitForLogout = true;

      self.apiPost("ajax",p).then(function(){ waitForLogout = false;}, function(){ waitForLogout = false;});

      if(switchUser){
        // add user to switch list
        var users = [];
        if(self.getLocalStorage("switchUsers") != null){
          users = JSON.parse(self.getLocalStorage("switchUsers"));
        }
        var isThere = false;
        for(var i=0; i < users.length; i++){
          if(users[i].userid == self.user.ID){
            users[i].salt = self.user.Salt;
            users[i].name = self.user.Name;
            users[i].surname = self.user.Surname;
            users[i].teacher = self.user.Teacher;
            isThere = true;
            break;
          }
        }
        if(!isThere){
          var n = self.getLocalStorage("user");
          if(n && JSON.parse(n).ID == self.user.ID){
            users.push({"userid":self.user.ID,"salt":self.user.Salt,
                        "name":self.user.Name,"surname":self.user.Surname,
                        "teacher":self.user.Teacher,
                        "lastUsed":new Date().getTime()});
          }
        }
        self.setLocalStorage("switchUsers",angular.toJson(users));
      }else{
        // full logout, remove from switch list if exists there
        self.deleteSwitchUser(self.user.ID);
      }
      var waitForLogoutFunc = function(){
        if(!waitForLogout){
          self.setLocalStorage("userid",null);
          self.setLocalStorage("salt",null);
          self.setLocalStorage("user",null);
          self.setLocalStorage("openTeacherIntro",null); 
          self.setLocalStorage("openStudentIntro",null); 
          self.initLoadingDone = false;
          //user = null; // global user
          //self.user = null;
          $mdDialog.hide();
          window.location.reload(true);
        }else
          $timeout(waitForLogoutFunc,100);
      };
      waitForLogoutFunc();
    };

    self.getUserName = function(s){
      var r = s.Email;
      r = r.replace("@learningview.org","");
      r = s.Name + " ("+r+")";
      return r;
    };

    self.showDeviceLogin = function(ev){
      var poll = null;
      self.showDialog({
        templateUrl: "showDeviceLogin.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          self.fetchDeviceCode = false;
          if(poll)
            $interval.cancel(poll);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.r = Math.random();
          $scope.value = null;
          var run = function(isNew){
            var p = {"action":"loginLiveCode","noindicator":"1"};
            if(isNew) p.new = 1;
            self.apiPost("ajax",p).then(function(result){
              $scope.r = Math.random();
              if(result.status == "1"){
                $scope.value = null;
                self.alert($filter('trans')('LOGINWITHOTHERDEVICEDONE'),ev);
                $scope.cancel();
              }else{
                $scope.value = result.code;
              }
            });
          };
          run(true);
          poll = $interval(function(){run(false);},3000);
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    self.usersettingsClick = function(ev){
      var postMessage = function(e){
        if(e.data == "LOGOUT|"+self.user.ID){
          // logout now
          self.logout();
        }
      };

      self.showDialog({
        templateUrl: "usersettings.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        onRemoving: function (event, removePromise) {
          if(postMessage)
            window.removeEventListener("message",postMessage);
          postMessage = null;
          self.changeAppZoom(self.appZoom);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.user = JSON.parse(angular.toJson(self.user));
          $scope.zoom = self.appZoom;
          $scope.hexpOptions = [
            {"value":0, "label":"normal"},
            {"value":10, "label":"weit"},
            {"value":20, "label":"weiter"},
            {"value":30, "label":"sehr weit"}
          ];
          $scope.currentHEXP = self.getUserFontHEXP();
          $scope.setZoom = function(v){
            self.changeAppZoom(v);
            $scope.zoom = self.appZoom;
          };
          $scope.setHEXP = function(value){
            self.setUserFontHEXP(value);
            $scope.currentHEXP = self.getUserFontHEXP();
          };

          window.addEventListener("message",postMessage);

          $scope.changeUsername = function(){
            if($.trim($scope.user.Name) == "") return;
            if($.trim($scope.user.Surname) == "") return;

            self.apiPost("ajax",{"action":"changeUsername", "newName":$scope.user.Name, "newSurname":$scope.user.Surname})
             .then(function(data){
               self.user.Name = $scope.user.Name;
               self.user.Surname = $scope.user.Surname;
               $scope.editUsername = false;
               $scope.editUserSurname = false;
             });
          };

          $scope.changeEmail = function(ev){
            self.showDialog({
              templateUrl: "changeEmail.html",
              targetEvent: ev,
              skipHide:true, // keep other dialog open
              clickOutsideToClose: false,
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.user = JSON.parse(angular.toJson(self.user));
                $scope.newEmail = "";
                $scope.changeEmail = function(){
                  $scope.error = "";
                  if(!$scope.newEmail || $scope.newEmail == "" || $scope.newEmail.indexOf("@") == -1){
                    $scope.error = "Es muss eine Emailadresse eingegeben werden!";
                    return;
                  }
                  self.apiPost("ajax",{"action":"changeEmail", "newEmail":$scope.newEmail})
                   .then(function(data){
                     self.track('changeEmailAddress',{old:self.user.Email, new:$scope.newEmail});
                     self.user.Email = $scope.newEmail;
                     self.closeDialog($scope.dialogElement);
                   },function(data){
                     if(data.error == "NOVALIDEMAIL"){
                       $scope.error = "Bitte eine gültige Emailadrese eingeben.";
                     }else
                     if(data.error == "EMAILALREADYUSED"){
                       $scope.error = "Emailadresse wird bereits verwendet.";
                     }else{
                       $scope.error = data.error;
                     }
                   });
                };                
                $scope.cancel = function (){
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          };

          $scope.changePassword = function(ev){
            self.showDialog({
              templateUrl: "changePassword.html",
              targetEvent: ev,
              skipHide:true, // keep other dialog open
              clickOutsideToClose: false,
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.user = JSON.parse(angular.toJson(self.user));
                $scope.oldPass = $scope.user.InitPassword ? $scope.user.InitPassword : "";
                $scope.newPass = "";
                $scope.changePassword = function(){
                  $scope.error = "";
                  if($scope.newPass.length < 5){
                    $scope.error = "Passwort sollte mindestens 5 Zeichen haben!";
                    return;
                  }
                  if($scope.oldPass == ""){
                    $scope.error = "Altes Passwort muss eingegeben werden!";
                    return;
                  }
                  if($scope.newPass != $scope.newPass2){
                    $scope.error = "Passwörter sind nicht gleich!";
                    return;
                  }
                  // wait for complete
                  isWaitingAction = true;
                  self.apiPost("ajax",{"action":"changePassword",
                      "oldPassword":$scope.oldPass, "newPassword":$scope.newPass})
                   .then(function(data){
                     isWaitingAction = false;
                     self.loginUser(data.user);
                     self.closeDialog($scope.dialogElement);
                   },function(data){
                     isWaitingAction = false;
                     if(data.error == "WRONGCHARACTERCOUNT")
                       $scope.error = "Passwörter müssen 5 bis 20 Zeichen haben.";
                     if(data.error == "OLDPASSWORDINCORRECT")
                       $scope.error = "Altes Passwort ist nicht korrekt .";
                   });
                };                
                $scope.cancel = function (){
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          };

          $scope.setup2FA = function(ev){
            self.apiPost("ajax",{"action":"2FARegisterCode"})
             .then(function(data){
              var parent = $scope;
              self.showDialog({
                templateUrl: "setup2FA.html",
                targetEvent: ev,
                skipHide:true, // keep other dialog open
                clickOutsideToClose: false,
                controller: function ($scope, $mdDialog) {
                  $scope.self = self;
                  $scope.step = 1;
                  $scope.activate2FASecret = data.secret;
                  $scope.activate2FAQRCode = data.qrcode;
                  $scope.activate2FACode = "";
                  $scope.check = function(){
                    $scope.activate2FACode = $scope.activate2FACode.replace(/[^0-9]/g,"");
                    self.apiPost("ajax",{"action":"2FAActivateCode", "secret":$scope.activate2FASecret, "code":$scope.activate2FACode})
                     .then(function(data){
                       parent.user.use2FA = true;
                       $scope.step++;
                       //self.alert($filter('trans')('ACTIVATED2FA'));
                     },function(e){
                       if(e.error == "WRONG_CODE"){
                         $scope.activate2FACode = "";
                         self.alert($filter('trans')('WRONG2FACODE'));
                       }else
                         self.alert(e.error);
                     });            
                  };                  
                  $scope.cancel = function (){
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });
             });
          };

          $scope.deactivate2FA = function(ev){
            self.confirm($filter('trans')('ASKDEACTIVATE2FA'),$filter('trans')('REMOVE'),ev).then(function(){
              self.apiPost("ajax",{"action":"2FADeactivate"})
               .then(function(data){
                $scope.user.use2FA = false;
               });            
            });            
          };


          $scope.logout = function() {
            // try logout now
            self.logout();
          };
          $scope.switchUser = function() {
            // try switchUser now
            self.logout(true);
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };

        }

      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getFilenameFromURL = function(url){
      if(!url || !url.split) return "";
      var parts = url.split("/");
      var last = parts[parts.length-1];
      parts = last.split("?");
      if(parts[0].indexOf("_") > 0){
        parts[0] = parts[0].replace(/_[0-9a-f]{13}\./,".",parts[0]);
      }
      return parts[0];
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Chat rooms
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.currentOpenChat = null;
    self.currentChatMessages = [];
    self.currentChatRoomListLimit = -10; // last 10
    self.lastOpenChat = null;
    self.hasChatRoomInClass = function(c){
      if(!c) return false;
      for(var i=0; i < self.chatRooms.length; i++){
        if(self.chatRooms[i].Class == c.ID) return true;
      }
      return false;
    };
    self.countNewChatsInClass = function(c){
      var count = 0;
      for(var i=0; i< self.chatRooms.length; i++){
        if(self.chatRooms[i].Class == c.ID && !self.chatRooms[i].mute) {
          count += self.chatRooms[i].new;
        }
      }
      return count;
    };

    self.openStudentOneOnOneChat = function(s,ev){
      // opens a 1:1 chat with selected student
      self.openChatRooms(null,s,ev);

    };

    self.openChatRooms = function(room, targetStudent, ev){
      if(self.currentOpenChatDialog){
        self.currentOpenChatDialog.close();
        return;
      }
      self.track('chatroomsopened',null);
      self.showDialog({
        state:"one",
        templateUrl: "chatRoomDialog.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onShowing:function(){
        },
        onRemoving: function (event, removePromise) {
          self.currentOpenChat = null;
          self.currentOpenChatDialog = null;
          if(self.currentOpenChatPoll)
            $interval.cancel(self.currentOpenChatPoll);
          self.currentOpenChatPoll = null;
          self.chatRoomClosed = new Date().getTime();
          self.track('chatroomsclosed',null);
        },
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.state = {};
          $scope.currentChatRoomLastScroll = 0;
          self.currentOpenChatDialog = $scope;
                    
          $scope.hasOtherChats = function(room){
            if(self.user.Teacher == 1) return true; // can always start new chats
            if(self.currentClass && self.currentClass.teachers.length > 1) return true;
            for(var i=0; i < self.chatRooms.length; i++){
              if(self.chatRooms[i].Class != self.currentClass.ID) continue;
              if(self.chatRooms[i].ID == room.ID) continue;
              return true; // at least one more room than this one
            }
            return false;
          };
          $scope.togglePlayRingSound = function(){
            self.chatRoomRingSound = !self.chatRoomRingSound;
            if(!self.chatRoomRingSound)
              self.userViewData["U"+self.user.ID+"_ringChat"] = null; else
              self.userViewData["U"+self.user.ID+"_ringChat"] = 1;
            self.updateUserViewData();
          };

          $scope.unmuteChatroom = function(room){
            self.apiPost("ajax",{"action":"muteChatRoomMessages",
                                 "room":room.ID,
                                 "duration":-1}).then(function(data) {
              self.keepAliveCallback();
            });
          };
          $scope.muteChatroom = function(room,duration){
            self.apiPost("ajax",{"action":"muteChatRoomMessages",
                                 "room":room.ID,
                                 "duration":duration}).then(function(data) {
              self.keepAliveCallback();
            });
          };

          $scope.isBlocked = function(room,student){
            if(room.users){
              var now = (new Date()).getTime();
              for(var i=0; i < room.users.length; i++){
                if(room.users[i].User == student.ID){
                  if(room.users[i].block){
                    var d = (new Date().fromMysqlFormat(room.users[i].block)).getTime();
                    var hours = Math.ceil((d - now) / 3600000);
                    if(hours <= 0) return false;
                    return hours < 100 ? hours+'h' : $filter('trans')('MUTEFOREVER');
                  }
                  return false;
                }
              }
            }
            return false;
          };

          $scope.blockStatusClicked = function($mdOpenMenu,ev,scope){
            // teacher class status list menu opened
            if($scope.isStatusMenuOpen) $mdMenu.cancel("closed");
            scope.isStatusMenuOpen = false;
            
            self.showLoadingIndicator(ev,function(done){
              scope.isStatusMenuOpen = true;
              $timeout(function(){
                $mdOpenMenu(ev);
                done();
                $scope.isStatusMenuOpen = true;
              },10);
            });
          };

          $scope.blockChatroom = function(room,student,duration){
            if(student == "*"){
              var done = 0;
              for(var i=0; i < self.currentClass.students.length; i++)
                self.apiPost("ajax",{"action":"blockChatRoomMessages",
                                     "room":room.ID,
                                     "student":self.currentClass.students[i].ID,
                                     "duration":duration}).then(function(data) {
                  done++;
                  if(done == self.currentClass.students.length) self.keepAliveCallback();
                });
            }else{            
              self.apiPost("ajax",{"action":"blockChatRoomMessages",
                                   "room":room.ID,
                                   "student":student.ID,
                                   "duration":duration}).then(function(data) {
                self.keepAliveCallback();
              });
            }
          };

          $scope.updateChatRoomLastScroll = function(){
            $scope.noScrollToBottom = true;
            if($scope.currentChatRoomLastScroll)
              $timeout.cancel($scope.currentChatRoomLastScroll);
            $scope.currentChatRoomLastScroll =
              $timeout(function(){
                $scope.noScrollToBottom = false;
              },10000); // delay for 10 sec
          };
          $scope.resetChatRoomLastScroll = function(){
            $scope.noScrollToBottom = false;
            if($scope.currentChatRoomLastScroll)
              $timeout.cancel($scope.currentChatRoomLastScroll);
          };

          $scope.createNewChat = function(){
            $scope.newChat = {title:"",write:'all', visibility : "0", limitContent: "0",
                   type:self.user.Teacher == "1" ? "class":"private",users:[]};
            $scope.newChat.class = self.currentClass.ID;
            if(self.user.Teacher != '1')
              $scope.newChat.title = "@ "+self.user.Name + " " + self.user.Surname;
            $scope.state.showAddChat = true;
          };

          $scope.selected = [];

          var chatUpdateTime = null;
          $scope.refreshMessages = function(){
            self.apiPost("ajax",{"action":"getOpenChatMessages","noindicator":"1",
                                 "ID":self.currentOpenChat ? self.currentOpenChat.ID : '',
                                 "lastUpdateTime":chatUpdateTime ? chatUpdateTime : 0}).then(function(data) {
              if(data.deleted == 1){
                $scope.closeChatRoom();
                self.alert("Der Chat wurde gelöscht.");
                return;
              }
              self.updateChatMessages(data.messages);
              self.currentOpenChatLastReads = data.lastUsersUpdateTime;
              chatUpdateTime = data.lastUpdateTime;
            });
          };

          $scope.closeChatRoom = function(ev){
            $scope.resetChatRoomLastScroll();
            $scope.state.showAddChat = false;
            $scope.state.adjustsettings = false;
            $scope.state.addUserToRoom = false;
            self.currentOpenChat = null;
            if(self.currentOpenChatPoll)
              $interval.cancel(self.currentOpenChatPoll);
            self.currentOpenChatPoll = null;

            //1010
            for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
              if(self.dropHandler[i].dialog == $scope.dialogElement) {
                self.dropHandler.splice(i, 1);
              }
            }
          };

          $scope.openChatRoom = function(room,ev){
            $scope.currentTaskAnswer = ""; // used for record scope
            self.addAudioRecorderScope($scope, null, true);
            $scope.removeUploadFileButton = true;

            $scope.resetChatRoomLastScroll();
            self.currentOpenChat = null;
            self.showLoadingIndicator(ev,function(done){
              self.apiPost("ajax",{"action":"getChatRoomMessages", room:room.ID})
               .then(function(data) {
                 $scope.chatClass = self.currentClass;
                 for(var i=0; i < self.classList.length; i++){
                   if(self.classList[i].ID == room.Class){
                     $scope.chatClass = self.classList[i];
                     break;
                   }
                 }
                 self.currentChatMessages = [];
                 self.currentChatRoomListLimit = -10;
                 self.updateChatMessages(data.messages);
                 done();
                 self.currentOpenChat = room;
                 self.lastOpenChat = room;
                 self.chatRoomNews -= parseInt(room.new);
                 self.currentOpenChat.new = 0;
                 $scope.selected = [];
                 if(self.currentOpenChatPoll)
                   $interval.cancel(self.currentOpenChatPoll);
                 self.currentOpenChatPoll = $interval($scope.refreshMessages,3000);
                 $scope.refreshMessages();
               });
            });
          };

          self.addChatMessageScope($scope);

          $scope.openOneOnOneChat = function(user,ev){
            if(!self.currentClass) return; // needs a class to continue
            var room = $scope.findOneOnOneChat(user);
            if(room){
              // open room now
              self.showLoadingIndicator(ev,function(done){
                $scope.openChatRoom(room,ev);
                done();
              });
            }else{
              if($scope.creatingNewChatNow) return; // wait for now
              self.showLoadingIndicator(ev,function(done){
                // create and open room
                if(self.user.Teacher == 1 && !self.hasClassReviewPermission(self.currentClass)){
                  self.alert("Kein Chat vorhanden.");
                  return;
                }
                var old = $scope.newChat;
                $scope.creatingNewChatNow = true;
                $scope.newChat = {type:'private', write:'all', visibility:1, limitContent:0, class:self.currentClass.ID,title:"Privater Chat", users:[self.user.ID,user.ID]};
                $scope.createChat(ev).then(function(r){
                  if(r) $scope.openChatRoom(r,ev);
                  done();
                  $scope.creatingNewChatNow = false;
                });
                $scope.newChat = old;
              });
            }
          };

          $scope.isOneOnOneChat = function(room){
            if(!room) return false;
            if(!room.users) return false;
            if(room.users.length != 2) return false;
            if(room.isPrivate == 0) return false;
            if(room.Title != "Privater Chat") return false;
            return true;
            /*
            var foundUser = false;
            var foundSelf = false;
            for(var i=0; i < room.users.length; i++){
              if(foundUser && room.users[i].User != self.user.ID) return false; // not a 1:1 with us
              if(room.users[i].User == self.user.ID) foundSelf = true;
              if(room.users[i].User != self.user.ID) foundUser = room.users[i].User;
            }
            if(foundUser && foundSelf){
              if(self.user.Teacher == 1 && self.currentClass && self.currentClass.teachers){
                for(var i=0; i < self.currentClass.teachers.length; i++){
                  if(self.currentClass.teachers[i].ID == foundUser) return false;
                }
              }
              var oneRoom = $scope.findOneOnOneChat({ID:foundUser});
              if(oneRoom && room.ID == oneRoom.ID) return true;
            }
            return false;
            */
          };
          $scope.findOneOnOneChat = function(user){
            if(!user) return null;
            if(!self.currentClass) return null;
            for(var i=0; i< self.chatRooms.length; i++){
              if(!self.chatRooms[i].users) continue;
              if(self.chatRooms[i].isPrivate == 0) continue;
              if(self.chatRooms[i].Title != "Privater Chat") continue;

              if(self.chatRooms[i].Class == self.currentClass.ID && self.chatRooms[i].users.length == 2) {
                var foundUser = false;
                var foundSelf = false;
                for(var z=0; z < self.chatRooms[i].users.length; z++){
                  if(self.chatRooms[i].users[z].User == user.ID) foundUser = true;
                  if(self.chatRooms[i].users[z].User == self.user.ID) foundSelf = true;
                }
                if(foundUser && foundSelf) return self.chatRooms[i];
              }
            }
            return null;
          };

          $scope.roomHasStudent = function(room,student){
            if(!room || !student) return false;
            if(!room.users) return false;
            for(var i=0; i < room.users.length; i++)
              if(room.users[i].User == student.ID) return true;
            return false;
          };

          $scope.countChatRoomsInClass = function(){
            var c = 0;
            if(self.currentClass)
            for(var i=0; i< self.chatRooms.length; i++){
              if(self.chatRooms[i].Class == self.currentClass.ID) c++;
            }
            return c;
          };

          $scope.selectCurrentUsers = function(){
            $scope.selected = [];
            for(var i=0; i< self.currentOpenChat.users.length; i++){
              $scope.selected.push(self.currentOpenChat.users[i].User);
            }
          };
          $scope.selectAdditionalChatUsers = function(ev){
            if(self.currentOpenChat){
              var outerScope = $scope;
              self.showDialog({
                templateUrl: "classStudentSelection.html",
                targetEvent: ev,
                skipHide:true, // keep other dialog open
                clickOutsideToClose: true,
                controller: function ($scope, $mdDialog) {
                  $scope.self = self;
                  $scope.c = null;
                  for(var i=0; i < self.classList.length; i++){
                    if(self.classList[i].ID == self.currentOpenChat.Class){
                      $scope.c = self.classList[i];
                    }
                  }

                  $scope.selection = [];
                  for(var i=0; i< self.currentOpenChat.users.length; i++){
                    $scope.selection.push(self.currentOpenChat.users[i].User);
                  }

                  $scope.disabled = [];
                  $scope.smallScreen = self.isSmallScreen;

                  self.addContentVisibilityScope($scope);

                  $scope.save = function() {
                    var keep = [];
                    for(var i=0; i < outerScope.selected.length; i++){
                      var found = false;
                      for(var s=0; s < $scope.c.students.length; s++){
                        if($scope.c.students[s].ID == outerScope.selected[i]) {
                          found = true;
                          break;
                        }
                      }
                      if(!found) keep.push(outerScope.selected[i]);
                    }
                    outerScope.selected = $scope.selection;
                    for(var i=0; i < keep.length; i++)
                      outerScope.selected.push(keep[i]);
                    self.closeDialog($scope.dialogElement);
                  };

                  $scope.cancel = function (){
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });
            }            
          }
          $scope.selectNewChatUsers = function(ev){
           var outerScope = $scope;
           self.showDialog({
              templateUrl: "classStudentSelection.html",
              targetEvent: ev,
              skipHide:true, // keep other dialog open
              clickOutsideToClose: true,
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.c = null;
                for(var i=0; i < self.classList.length; i++){
                  if(self.classList[i].ID == outerScope.newChat.class){
                    $scope.c = self.classList[i];
                  }
                }

                $scope.selection = [];
                $scope.disabled = [];
                $scope.smallScreen = self.isSmallScreen;

                for(var i=0; i< outerScope.newChat.users.length; i++){
                  $scope.selection.push(outerScope.newChat.users[i]);
                }

                self.addContentVisibilityScope($scope);

                $scope.save = function() {
                  var keep = [];
                  for(var i=0; i < outerScope.newChat.users.length; i++){
                    var found = false;
                    for(var s=0; s < $scope.c.students.length; s++){
                      if($scope.c.students[s].ID == outerScope.newChat.users[i]) {
                        found = true;
                        break;
                      }
                    }
                    if(!found) keep.push(outerScope.newChat.users[i]);
                  }
                  outerScope.newChat.users = $scope.selection;
                  for(var i=0; i < keep.length; i++)
                    outerScope.newChat.users.push(keep[i]);
                  self.closeDialog($scope.dialogElement);
                };

                $scope.cancel = function (){
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          };

          $scope.setUsersOfRoom = function(){
            self.apiPost("ajax",{"action":"setUsersOfChatRoom", users:$scope.selected.join(","), room:self.currentOpenChat.ID})
             .then(function(data) {
               $scope.state.sendingAddChat = false;
               $scope.state.addUserToRoom = false;
               $scope.selected = [];
               self.currentOpenChat.users = data.users;
               var stillInChat = false;
               for(var i=0; i < self.currentOpenChat.users.length; i++){
                 if(self.currentOpenChat.users[i].ID == self.user.ID){
                   stillInChat = true;break;
                 }
               }
               if(!stillInChat){
                 // close an remove chatroom
                 for(var i=0; i< self.chatRooms.length; i++){
                   if(self.chatRooms[i].ID == self.currentOpenChat.ID) {
                     self.chatRooms.splice(i,1); break;
                   }
                 }
                 $scope.closeChatRoom();
               }
               self.keepAliveCallback();
              },function(data){

              });
          };

          $scope.createChat = function(ev){
            var deferred = $q.defer();
            if($scope.state.sendingAddChat) return; // already creating one
            $scope.state.sendingAddChat = true;
            self.apiPost("ajax",{"action":$scope.newChat.type == 'class' ?
                                 "createClassChatRoom" : "createPrivateChatRoom",
                                  write:$scope.newChat.write == "all" ? '1':'0',
                                  limitContent:$scope.newChat.limitContent ? $scope.newChat.limitContent : '0',
                                  visibility:$scope.newChat.visibility,
                                  classid:$scope.newChat.class, title:$scope.newChat.title,
                                  users:$scope.newChat.users.join(",")})
             .then(function(data) {
               $scope.state.sendingAddChat = false;
               if(data.result == "OK"){
                 self.keepAliveCallback().then(function(){
                   $scope.state.showAddChat = false;
                   for(var i=0; i < self.chatRooms.length; i++){
                     if(self.chatRooms[i].ID == data.room){
                       self.chatRooms[i].new = 0;
                       deferred.resolve(self.chatRooms[i]);                       
                       break;
                     }
                   }
                 });
               }
             },function(data){
               $scope.state.sendingAddChat = false;
               self.alert("Erstellung fehlgeschlagen: "+data.error);
               deferred.resolve(null);                       
             });
            return deferred.promise;
          };

          $scope.deleteChat = function(ev){
            self.confirm($filter('trans')(self.currentOpenChat.isPrivate == '0' ?
              'DELETECLASSCHATASK':'DELETECHATASK'),$filter('trans')('DELETE'),ev).then(function(){
              self.apiPost("ajax",{"action":"deleteChatRoom", room:self.currentOpenChat.ID})
               .then(function(data) {
                 $scope.closeChatRoom();
                 self.updateChatRooms(data.chats);
                 self.keepAliveCallback();
               });
            });
          };

          $scope.openEditChat = function(ev){
            $scope.editChat = {};
            $scope.editChat.title = self.currentOpenChat.Title;
            $scope.editChat.type = self.currentOpenChat.isPrivate == "0" ? 'class' : 'private';
            $scope.editChat.write = self.currentOpenChat.canWrite == "1" ? 'all':'teachers';
            $scope.editChat.visibility = self.currentOpenChat.Visibility;
            $scope.editChat.limitContent = self.currentOpenChat.limitContent;
            $scope.state.adjustsettings = true;
          };

          $scope.saveSettings = function(ev){
            $scope.state.sendingSettings = true;
            self.apiPost("ajax",{"action":"editChatRoom",
                room:self.currentOpenChat.ID,
                write:$scope.editChat.write == "all" ? '1':'0',
                limitContent:$scope.editChat.limitContent ?  $scope.editChat.limitContent : '0',
                visibility:$scope.editChat.visibility,
                title:$scope.editChat.title})
             .then(function(data) {
               $scope.state.sendingSettings = false;
               $scope.state.adjustsettings = false;
               self.updateChatRooms(data.chats);
             },function(data){
               $scope.state.sendingSettings = false;
               self.alert("Fehlgeschlagen: "+data.error);
             });
          }

          $scope.scrollToMessage = function(m){
            var found = null;
            for(var i=0; i < self.currentChatMessages.length; i++){
              if(self.currentChatMessages[i].ID == m.ID){
                found = self.currentChatMessages.length-1-i;
              }
            }
            if(found && self.currentChatRoomListLimit > -found) {
              self.currentChatRoomListLimit = -found-3;
              $timeout(function(){
                $scope.scrollToMessage(m);
              },100);
              return;
            }
            // scroll to the message #$($("li").get().reverse()).each(function()
            $($('#chatMessagePanel .chatMessageWrapper').get().reverse()).each(function(i,e){
              var c = self.currentChatMessages[self.currentChatMessages.length-1-i];
              if(c.ID == m.ID){
                // found
                $(e).get(0).scrollIntoView({ behavior: "smooth", block: "start" }, 50); 
              }
            });
          }

          $scope.sendMessage = function(callback){
            $scope.state.message = $.trim($scope.state.message);
            $scope.state.message = $scope.state.message.replace(/[\n]\s*[\n]\s*([\n]\s*)+/g,"\n\n\n");
            if(!$scope.state.message || $scope.state.message == "") return;
            $scope.noScrollToBottom = false;
            $scope.state.sendingMessage = true;
            var currentChat = self.currentOpenChat;
            var p = {"action":"sendChatMessage",
                room:self.currentOpenChat.ID, message:$scope.state.message};
            if($scope.state.reply) p.data = JSON.stringify({reply:{ID:$scope.state.reply.ID, 
                                                                   Message:$scope.state.reply.Message,
                                                                   User:$scope.state.reply.User}});
            self.apiPost("ajax",p).then(function(data) {
               self.track("addChatItem",{"ID":self.currentOpenChat.ID,"content":$scope.state.message});
               $scope.state.sendingMessage = false;
               $scope.state.message = "";
               $scope.state.reply = null;
               $scope.state.isRecording = false;
               if(data.message) self.updateChatMessages([data.message]);
               // fetch messages again after 1,2 s
               $timeout(function(){
                 if(self.currentOpenChat != currentChat){
                   var nowCurrentChat = self.currentOpenChat;
                   self.currentOpenChat = currentChat;
                   $scope.refreshMessages();
                   self.currentOpenChat = nowCurrentChat;
                 }
               },1200);
               if(callback) callback();
             }, function(e){
               // failed to send
               $scope.state.sendingMessage = false;
               if($scope.state.isRecording){
                 $scope.state.isRecording = false;
                 $scope.state.message = "";
               }
               if(e && e.error == "BLOCKED") self.alert("Du kannst in diesem Chat derzeit nichts schreiben.");
             });
          };

          $scope.close = function(){
            self.closeDialog($scope.dialogElement);
          };

          if(room){
            for(var i=0; i < self.chatRooms.length; i++)
              if(self.chatRooms[i].ID == room.ID){
                $scope.openChatRoom(self.chatRooms[i],{});
                break;
              }
          }
          if(!room && targetStudent) $scope.openOneOnOneChat(targetStudent,ev);
/*
          if(!room && self.user.Teacher == 0)
            for(var i=0; i < self.chatRooms.length; i++){
              if(self.chatRooms[i].Class != self.currentClass.ID) continue;
              var others = $scope.hasOtherChats(self.chatRooms[i]);
              if(!others){
                // open it now as it is the only option for this student
                $scope.openChatRoom(self.chatRooms[i],ev);
                break;
              }
            }
*/
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.exportMaterialData = function(ev){
      self.showDialog({
        templateUrl: "exportMaterialSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.waitForDownload = false;
          $scope.selected = {};
          for(var i=0; i < self.userContent.mainTopics.length; i++){
            var mt = self.userContent.mainTopics[i];
            $scope.selected[mt.ID] = (!self.filterColor || self.filterColor == mt.Color || self.filterColor == '#03a9f4' && mt.Color == '') && (!self.filterShare || (self.hasShareSetting(mt,self.filterShare) )) && (!self.filterOwner || self.filterOwner.User == mt.Owner);
          }

          $scope.hideDetails = false;
          $scope.outputList = false; // excel mode

          $scope.selectAll = function(){
            for(var i=0; i < self.userContent.mainTopics.length; i++){
              var mt = self.userContent.mainTopics[i];
              $scope.selected[mt.ID] = true;
            }
          };
          $scope.unselectAll = function(){
            for(var i=0; i < self.userContent.mainTopics.length; i++){
              var mt = self.userContent.mainTopics[i];
              $scope.selected[mt.ID] = false;
            }
          };
          $scope.ok = function(){
            self.closeDialog($scope.dialogElement);
          };
          $scope.download = function(){
            $scope.waitForDownload = true;
            self.closeDialog($scope.dialogElement);
            // hideDetails=1
            // selected=123,456,643
            var url = "https://learningview.org/api/exportMaterials"+($scope.outputList ? 'List':'')+".php?user="+self.user.ID+"&code="+self.user.Salt;
            var selIDs = [];
            for(var i=0; i < self.userContent.mainTopics.length; i++)
              if($scope.selected[self.userContent.mainTopics[i].ID])
                selIDs.push(self.userContent.mainTopics[i].ID);
            if(selIDs.length > 0){
              url = url + "&selected="+ selIDs.join(",");
            }
            if($scope.hideDetails){
              url = url + "&hideDetails=1";
            }
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = window.cleanFilename("LearningViewExport_Materialien_"+moment().format('YYYY_MM_DD'))+($scope.outputList ? ".xlsx":".zip");
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editClassFolderItemTags = function(it,folder,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classfolderitemtags.html",
        skipHide:true, // keep other dialog open
        targetEvent : ev ? ev : null,
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.existingTags = [];
          $scope.tags = [];
          $scope.selected = null;
          // make a list of all existing tags in this folder to select from
          for(var z=0; z < folder.items.length; z++){
            var et = folder.items[z].Tags;
            var list = et && et != '' ? et.split("|") : [];
            for(var i=0; i < list.length; i++){
              var tag = list[i].split("☐");
              var found = false;
              for(var c=0; c < $scope.existingTags.length; c++){
                if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
                  found = true;
                  break;
                }
              }
              if(!found)
                $scope.existingTags.push({text:tag[0],color:tag[1]});
            }
          }
          if(folder.Tags && folder.Tags != ''){
            var list = folder.Tags.split("|");
            for(var i=0; i < list.length; i++){
              var tag = list[i].split("☐");
              var found = false;
              for(var c=0; c < $scope.existingTags.length; c++){
                if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
                  found = true;
                  break;
                }
              }
              if(!found)
                $scope.existingTags.push({text:tag[0],color:tag[1]});
            }
          }
          $scope.existingTags.sort(function(a, b) {
            return a.text.localeCompare(b.text);
          });

          var list = it && it.Tags && it.Tags != '' ? it.Tags.split("|") : [];
          for(var i=0; i < list.length; i++){
            var tag = list[i].split("☐");
            $scope.tags.push({text:tag[0],color:tag[1]});
          }

          $scope.hasTag = function(e){
            for(var i=0; i < $scope.tags.length; i++){
              if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return true;
            }            
            return false;
          };

          $scope.hasExistingTagsLeft = function(){
            var c = 0;
            for(var z=0; z < $scope.existingTags.length; z++){
              if($scope.hasTag($scope.existingTags[z])) c++;
            }
            return (c < $scope.existingTags.length);
          };
          
          $scope.append = function(e){
            var n = {color:e.color,text:e.text};
            for(var i=0; i < $scope.tags.length; i++){
              if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return;
            }
            $scope.tags.push(n);
          };
          $scope.add = function(){
            var n = {color:0,text:''};
            if($scope.tags.length > 0){
              n.color = $scope.tags[$scope.tags.length-1].color;
            }
            $scope.tags.push(n);
            $scope.selected = n;
            setTimeout(function(){
              $('.tagListEditor input').focus();
            },10);
          };
          $scope.remove = function(t){
            if($scope.selected == t) $scope.selected = null;
            $scope.tags.splice($scope.tags.indexOf(t),1); 
          }

          $scope.save = function() {
            var tags = [];
            for(var i=0; i < $scope.tags.length; i++){
              if($.trim($scope.tags[i].text) === "") continue;
              tags.push($scope.tags[i].text+"☐"+$scope.tags[i].color);
            }
            $scope.it.Tags = tags.join("|");

            self.closeDialog($scope.dialogElement);

            self.saveClassFolderItemTags($scope.it);

            deferred.resolve($scope.it.Tags);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;      
    };

    self.editClassFolderTags = function(it,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classfolderitemtags.html",
        skipHide:true, // keep other dialog open
        targetEvent : ev ? ev : null,
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.existingTags = [];
          $scope.tags = [];
          $scope.selected = null;

          // make a list of all existing tags in this folder to select from
          for(var z=0; z < self.classContent[self.currentClass.ID].folders.length; z++){
            var folder = self.classContent[self.currentClass.ID].folders[z];
            var et = folder.Tags;
            var list = et && et != '' ? et.split("|") : [];
            for(var i=0; i < list.length; i++){
              var tag = list[i].split("☐");
              var found = false;
              for(var c=0; c < $scope.existingTags.length; c++){
                if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
                  found = true;
                  break;
                }
              }
              if(!found)
                $scope.existingTags.push({text:tag[0],color:tag[1]});
            }
          }

          for(var x=0; x < self.currentClass.students.length; x++){
            if(self.users[self.currentClass.students[x].ID] &&
               self.users[self.currentClass.students[x].ID].classContent &&
               self.users[self.currentClass.students[x].ID].classContent[self.currentClass.ID] &&
               self.users[self.currentClass.students[x].ID].classContent[self.currentClass.ID].folders){
              for(var z=0; z < self.users[self.currentClass.students[x].ID].classContent[self.currentClass.ID].folders.length; z++){
                var folder = self.users[self.currentClass.students[x].ID].classContent[self.currentClass.ID].folders[z];
                var et = folder.Tags;
                var list = et && et != '' ? et.split("|") : [];
                for(var i=0; i < list.length; i++){
                  var tag = list[i].split("☐");
                  var found = false;
                  for(var c=0; c < $scope.existingTags.length; c++){
                    if($scope.existingTags[c].text == tag[0] && $scope.existingTags[c].color == tag[1]){
                      found = true;
                      break;
                    }
                  }
                  if(!found)
                    $scope.existingTags.push({text:tag[0],color:tag[1]});
                }

              }
            }
          }

          $scope.existingTags.sort(function(a, b) {
            return a.text.localeCompare(b.text);
          });

          var list = it && it.Tags && it.Tags != '' ? it.Tags.split("|") : [];
          for(var i=0; i < list.length; i++){
            var tag = list[i].split("☐");
            $scope.tags.push({text:tag[0],color:tag[1]});
          }

          $scope.hasTag = function(e){
            for(var i=0; i < $scope.tags.length; i++){
              if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return true;
            }            
            return false;
          };

          $scope.hasExistingTagsLeft = function(){
            var c = 0;
            for(var z=0; z < $scope.existingTags.length; z++){
              if($scope.hasTag($scope.existingTags[z])) c++;
            }
            return (c < $scope.existingTags.length);
          };
          
          $scope.append = function(e){
            var n = {color:e.color,text:e.text};
            for(var i=0; i < $scope.tags.length; i++){
              if($scope.tags[i].text == e.text && $scope.tags[i].color == e.color) return;
            }
            $scope.tags.push(n);
          };
          $scope.add = function(){
            var n = {color:0,text:''};
            if($scope.tags.length > 0){
              n.color = $scope.tags[$scope.tags.length-1].color;
            }
            $scope.tags.push(n);
            $scope.selected = n;
            setTimeout(function(){
              $('.tagListEditor input').focus();
            },10);
          };
          $scope.remove = function(t){
            if($scope.selected == t) $scope.selected = null;
            $scope.tags.splice($scope.tags.indexOf(t),1); 
          }

          $scope.save = function() {
            var tags = [];
            for(var i=0; i < $scope.tags.length; i++){
              if($.trim($scope.tags[i].text) === "") continue;
              tags.push($scope.tags[i].text+"☐"+$scope.tags[i].color);
            }
            $scope.it.Tags = tags.join("|");

            self.closeDialog($scope.dialogElement);

            deferred.resolve($scope.it.Tags);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateClassFolder = function(ev){
      self.confirm($filter('trans')('ASKDUPLICATEFOLDER'),$filter('trans')('COPY'),null).then(function(){
        self.showLoadingIndicator(ev,function(done){
          self.apiPost("ajax",{"action":"duplicateClassFolder","ID":self.currentClassFolder.ID}).then(function(data) {
            done();
            self.alert($filter('trans')('CLASSFOLDERDUPLICATEDHINT',data.folder.Name),ev);
            self.keepAliveCallback();
          });
        });
      });
    };

    self.publishClassFolder = function(ev){
      self.showDialog({
        templateUrl: "publishclassfolder.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.folder = self.currentClassFolder;
          $scope.working = false;
          $scope.shareLink = "";
          if($scope.folder.GUID && $scope.folder.GUID != '')
            $scope.shareLink = "https://learningview.org/share/p"+$scope.folder.ID+'/'+$scope.folder.GUID;

          $scope.copy = function(){
            copyTextToClipboard($scope.shareLink);
            self.alert($filter('trans')('COPYEDLINKTOCLIPBOARD'),null);
          };
          $scope.publish = function() {
            $scope.working = true;
            self.apiPost("ajax",{"action":"publishClassFolder","ID":$scope.folder.ID}).then(function(data) {
              self.currentClassFolder.GUID = data["GUID"];
              $scope.shareLink = "https://learningview.org/share/p"+$scope.folder.ID+'/'+$scope.folder.GUID;
              $scope.working = false;
            });
          };
          $scope.unpublish = function() {
            $scope.working = true;
            self.apiPost("ajax",{"action":"unpublishClassFolder","ID":$scope.folder.ID}).then(function(data) {
              self.currentClassFolder.GUID = "";
              $scope.shareLink = "";
              $scope.working = false;
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.exportClassFolder = function(ev){
      $scope.waitForDownload = true;
      var url = "https://learningview.org/api/exportClassFolder.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID+"&folderid="+self.currentClassFolder.ID;
      if(self.currentClassResultStudentFilter && self.currentClassResultStudentFilter.length > 0){
        url += '&filter='+self.currentClassResultStudentFilter.join(",");
      }
      var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
      function checkDownload(){
        if(document.cookie.indexOf("fileDownload=true") > -1) {
          var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
          document.cookie = cookieData;
          setTimeout(function(){ frame.remove();},1000);
          $scope.waitForDownload = false;
        }else
          $timeout(checkDownload,100);
      }
      var filename = "LearningViewExport_"+self.currentClass.Name+"_";
      if(self.currentClassFolder.Share == 0 || self.currentClassFolder.Share == 3){
        filename += self.users[self.currentClassFolder.Owner].Name+"_"+self.users[self.currentClassFolder.Owner].Surname+"_";
      }
      filename += self.currentClassFolder.Name+".zip";
      if(window.electron){
        window.downloadElectronSaveAs(url,filename,function(){
          $timeout(function(){$scope.waitForDownload = false;},0);
        });
      }else
      if(typeof cordova != "undefined"){
        self.downloadFile(url,filename,true);
        $timeout(function(){$scope.waitForDownload = false;},500);
      }else{
        $('body').append(frame);
        checkDownload();
      }
    };

    self.hasClassFoldersWithSameName = function(folder,student){
      if(self.currentClass && folder && (folder.Share == 0 || folder.Share == 3)){
        for(var i=0; i < self.currentClass.students.length; i++){
          if(self.users[self.currentClass.students[i].ID] &&
             self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID] &&
             self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders){
            for(var z=0; z < self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders.length; z++){
              if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[z].ID == folder.ID) continue; // skip self
              if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[z].Name == folder.Name) return true;
            }
          }
        }
      }
      return false;
    };

    self.duplicateClassFolderItemToClass = function(folder,folderitem){
      // && self.hasClassFoldersWithSameName(self.currentClassFolder)
      // select target folders for each student
      self.showDialog({
        templateUrl: "selectStudentsClassFoldersTarget.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        escapeToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.c = self.currentClass;
          $scope.selectionUserFolders = {};
          $scope.selectionClassFolders = {};

          $scope.selection = [];
          $scope.disabled = [];
          
          for(var i=0; i < self.currentClass.students.length; i++){
            if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders.length == 0){
              $scope.disabled.push(self.currentClass.students[i].ID);
            }else{
              // find matching folder
              $scope.selectionUserFolders[self.currentClass.students[i].ID] = self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[0];
              for(var z=0; z < self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders.length; z++){
                if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[z].ID == folder.ID){
                  // own folder, disable self
                  $scope.disabled.push(self.currentClass.students[i].ID);
                }
                if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[z].Name == folder.Name){
                  $scope.selectionUserFolders[self.currentClass.students[i].ID] = self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[z];
                  break;
                }                
              }
            }
          }          

          self.addContentVisibilityScope($scope);

          $scope.duplicate = function(){
            // do it now
            var duplicateNow = function(ownership){
              self.closeDialog($scope.dialogElement);
              self.showLoadingIndicator(null,function(done){
                var total = 0;
                var max = 0;
                for(var k in $scope.selectionUserFolders){
                  if($scope.selectionUserFolders[k] && $scope.selection.indexOf(parseInt(k)) != -1){
                    // target selected
                    total++; 
                    max++;
                    var p = {"action":"duplicateClassFolderItemToTarget", "ID":folderitem.ID, "ownership":ownership ? k : 0,
                             "target":$scope.selectionUserFolders[k].ID};
                    self.apiPost("ajax",p).then(function(){
                      total--;
                      if(total == 0) {
                        self.keepAliveCallback();
                        self.alert($filter('trans')('HINTRESULTDUPLICATEFOLDERITEMTOCLASSFOLDERS',max));
                        done();
                      }
                    });
                  }
                }
                if(max == 0)
                  self.alert($filter('trans')('HINTRESULTDUPLICATEFOLDERITEMTOCLASSFOLDERS',max));
              });              
            };

            self.confirm($filter('trans')('ASKDUPLICATEFOLDERITEMOWNERSHIP'),$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
              duplicateNow(true);
            },function(){
              duplicateNow(false);
            });
          };

          $scope.cancel = function(){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

