    self.editStudentGroups = function(c,ev){
      self.showDialog({
        templateUrl: "editStudentGroups.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.c = c;
          $scope.selection = [];
          $scope.disabled = [];

          self.addContentVisibilityScope($scope);

          $scope.saveGroup = function(){
            if(!$scope.editFavoriteGroup) return;
            self.apiPost("ajax",{"action":"updateClassUserGroup", "classid":c.ID,
                                 "ID":$scope.editFavoriteGroup.ID,
                                 "name":$scope.editFavoriteGroup.Name,
                                 "users":$scope.selection.join(",")})
             .then(function(data) {
                if(data.groups && c) c.groups = data.groups;
              });
          };
          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countClassTaskStatus = function(c,task,status){
      var count = 0;
      var tt = self.getTaskByID(task.ID);
      for(var i=0; i < c.students.length; i++){
        if(self.currentClassResultStudentFilter &&
           self.currentClassResultStudentFilter.length > 0){
          // filter is used, skip not in list
          if(self.currentClassResultStudentFilter.indexOf(c.students[i].ID) == -1) continue;
        }
        if(!self.isUserTaskVisibleDeep(tt.mainTopic,tt.topic,task,c.students[i])) continue;
        var s = self.getUserTaskStatus(task,c.students[i],true);
        if(s.Status == status) count++;
      }
      return count;
    }
    self.countClassTaskTeacherStatus = function(c,task,status){
      var count = 0;
      var tt = self.getTaskByID(task.ID);
      for(var i=0; i < c.students.length; i++){
        if(self.currentClassResultStudentFilter &&
           self.currentClassResultStudentFilter.length > 0){
          // filter is used, skip not in list
          if(self.currentClassResultStudentFilter.indexOf(c.students[i].ID) == -1) continue;
        }
        if(!self.isUserTaskVisibleDeep(tt.mainTopic,tt.topic,task,c.students[i])) continue;
        var s = self.getUserTaskStatus(task,c.students[i],true);
        if(s.FeedbackStatus == status) count++;
      }
      return count;
    }
    self.countClassGoalStatus = function(c,goal,status){
      var count = 0;
      var gg = self.getGoalByID(goal.ID);;
      for(var i=0; i < c.students.length; i++){
        if(self.currentClassResultStudentFilter &&
           self.currentClassResultStudentFilter.length > 0){
          // filter is used, skip not in list
          if(self.currentClassResultStudentFilter.indexOf(c.students[i].ID) == -1) continue;
        }
        if(!self.isUserLearningGoalVisibleDeep(gg.mainTopic,gg.topic,goal,c.students[i])) continue;
        var s = self.getUserLearningGoalStatus(goal,c.students[i],true);
        if(s.Status == status) count++;
      }
      return count;
    }

    self.countClassGoalTeacherStatus = function(c,goal,status){
      // green or lightgreen
      var count = 0;
      var gg = self.getGoalByID(goal.ID);;
      for(var i=0; i < c.students.length; i++){
        if(self.currentClassResultStudentFilter &&
           self.currentClassResultStudentFilter.length > 0){
          // filter is used, skip not in list
          if(self.currentClassResultStudentFilter.indexOf(c.students[i].ID) == -1) continue;
        }
        if(!self.isUserLearningGoalVisibleDeep(gg.mainTopic,gg.topic,goal,c.students[i])) continue;
        var s = self.getUserLearningGoalStatus(goal,c.students[i],true);
        if(s.Teacher == status) count++;
      }
      return count;
    }

    self.getAllClassGoalTeacherStatusKinds = function(){
      return [
        'green','lightgreen','yellow',
        'starGold3','starGold2','starGold',
        'bar1','bar2','bar3','bar4','bar5','starSilver',
        'plant1','plant2','plant3','plant4','plant5','starBronze',
        'greenEmpty','greenEx','greenMinus','greenPlus',
        'yellowEmpty','yellowMinus',
        'redEmpty','red','redMinus','redPlus',
        'yellowEx','yellowPlus',
        'smilie1','smilie2','smilie3','smilie4','smilie5','smilie6'
      ];
    };

    self.getClassGoalTeacherStatusKinds = function(c,goal){
      if(!c || !goal) return [];
      var order = self.getAllClassGoalTeacherStatusKinds();
      var orderedKeys = [];
      for(var i=0; i < c.students.length; i++){
        var s = self.getUserLearningGoalStatus(goal,c.students[i],false);
        var status = s && s.Teacher ? s.Teacher.trim() : "";
        if(status == "") continue;
        if(orderedKeys.indexOf(status) == -1){
          orderedKeys.push(status);
        }
      }
      var result = [];
      var seen = {};
      for(var j = 0; j < order.length; j++){
        var statusName = order[j];
        if(orderedKeys.indexOf(statusName) > -1){
          result.push(statusName);
          seen[statusName] = true;
        }
      }
      for(var k = 0; k < orderedKeys.length; k++){
        if(!seen[orderedKeys[k]]){
          result.push(orderedKeys[k]);
          seen[orderedKeys[k]] = true;
        }
      }
      return result;
    };

