    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openContentFollow = function(type,target,data){
      if(type == "MainTopic"){
        return self.findAndShowMainTopic(data.mainTopic,true);
      }
      if(type == "Topic"){
        return self.findAndShowTopic(data.topic,true);
      }
      if(type == "LearningGoal"){
        return self.findAndShowLearningGoal(data.goal,true);
      }
      if(type == "Task"){
        return self.findAndShowTask(data.task,true);
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.acceptShareContentOpen = false;
    self.lastShareToAccecpt = null;

    self.acceptSharedContents = function(){
      if(self.dialogStack.length > 0) return; // ask later
      if(self.acceptShareContentOpen) return;
      if(self.currentTeacherNavigation != "Prep") return;

      self.autoOpendShares = true; // once shown now
      if(self.openSharesToAccept.length == 1)
        self.acceptSharedContent(self.openSharesToAccept[0]);
      if(self.openSharesToAccept.length > 1){
        self.previewAllShares();
      }
    };

    self.acceptSharedContent = function(it,noShare){
      self.acceptShareContentOpen = true; 

      // show dialog 
      if(it.Type == "MainTopic"){
        self.apiPost("ajax",{"action":"requestShareMainTopic", "id":it.MainTopic.ID, "hash":it.MainTopic.Hash})
         .then(function(data) {
           if(data.item){
             self.previewSharedContent("MainTopic",data.item,it.MainTopic.Hash,noShare ? null : it);
           }
         });
      }
      if(it.Type == "Topic"){
        self.apiPost("ajax",{"action":"requestShareTopic", "id":it.Topic.ID, "hash":it.Topic.Hash})
         .then(function(data) {
           if(data.item){
             self.previewSharedContent("Topic",data.item,it.Topic.Hash,noShare ? null : it);
           }
         });
      }
      if(it.Type == "LearningGoal"){
        self.apiPost("ajax",{"action":"requestShareLearningGoal", "id":it.LearningGoal.ID, "hash":it.LearningGoal.Hash})
         .then(function(data) {
           if(data.item){
             self.previewSharedContent("LearningGoal",data.item,it.LearningGoal.Hash,noShare ? null : it);
           }
         });        
      }
      if(it.Type == "Task"){
        self.apiPost("ajax",{"action":"requestShareTask", "id":it.Task.ID, "hash":it.Task.Hash})
        .then(function(data) {
         if(data.item){
           self.previewSharedContent("Task",data.item,it.Task.Hash,noShare ? null : it);
         }
        });
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.archiveMainTopic = function(it,ev){
      self.confirm($filter('trans')('HIDEMAINTOPICASK',it.Name),$filter('trans')('HIDE'),ev).then(function(){
        self.apiPost("ajax",{"action":"archiveMainTopic", "ID":it.ID})
         .then(function(data) {
           for(var i=0; i < self.userContent.mainTopics.length; i++){
             if(self.userContent.mainTopics[i].ID == it.ID){
               self.userContent.mainTopics.splice(i,1);
               break;
             }
           }
           $mdDialog.hide();
           self.keepAliveCallback();
         },function(data, status, headers, config) {
           self.alert("Error: "+data.error);
         });
      });
    };

    self.unarchiveMainTopic = function(it,ev){
      self.confirm($filter('trans')('RESTOREHIDDENMAINTOPICASK',it.Name),$filter('trans')('UNHIDE'),ev).then(function(){
        self.apiPost("ajax",{"action":"unarchiveMainTopic", "ID":it.ID})
         .then(function(data) {
           $mdDialog.hide();
           self.keepAliveCallback();
         },function(data, status, headers, config) {
           self.alert("Error: "+data.error);
         });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getShareInitals = function(shares){
      var names = [];
      for(var i=0; i < shares.length; i++){
        var initals = (shares[i].Name == "" ? shares[i].Email[0] : shares[i].Name[0])+(shares[i].Surname.length > 0 ? shares[i].Surname[0]: "");
        names.push(initals.toUpperCase());
        if(i > 4) {names.push("..."); break;}
      }
      return names.join(", ");
    };

    self.openShareSettings = function(mainTopic,ev){
      self.showDialog({
        templateUrl: "shareSettingsDialog.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.mainTopic = mainTopic;
          $scope.invites = JSON.parse(angular.toJson(mainTopic ?  mainTopic.shareSettings : self.shareSettings));
          $scope.invites.sort(function(a,b){
            if(mainTopic){
              if(mainTopic.Owner == a.User) return -1;
              if(mainTopic.Owner == b.User) return 1;
            }
            var p1 = parseInt(a.Permission);
            var p2 = parseInt(b.Permission);
            if(p1 !== p2) return p2-p1;
            return a.Email.localeCompare(b.Email);
//            return a.Created < b.Created ? 1 : (a.Created > b.Created ? -1 : 0);
          });

          self.addTeacherGroupsScope($scope);

          $scope.linkPermission = self.userViewData["invitePermission"] && self.userViewData["invitePermission"] == 1 ? 1 : 2;

          $scope.refreshLink = function(){
            if(mainTopic)
              self.apiPost("ajax",{"action":"requestInviteMainTopicShareLink", noerror:1, "ID":mainTopic.ID, "Permissions":$scope.linkPermission}).then(function(data) {
                if(data.link){
                  $scope.link = data.link;
                }
              });
          };
          $scope.refreshLink();

          $scope.copyLink = function(){
            if($scope.link && $scope.link != ''){
              copyTextToClipboard($scope.link);
              self.closeDialog($scope.dialogElement);
              self.alert($filter('trans')('INVITEMAINTOPICSHARELINKCOPYED'),null);
            }
          };

          $scope.addNewInviteItem = function(){
            var p = self.userViewData["invitePermission"] && self.userViewData["invitePermission"] == 1 ? 1 : 2;
            $scope.invites.push({"Email":"","Permission":p});
          };
          $scope.removeAll = function(){
            for(var i=0; i < $scope.invites.length; i++){
              var item = $scope.invites[i];
              if(mainTopic && (!self.checkChangePermission(mainTopic) || mainTopic.Owner == item.User || item.User == self.user.ID))
                continue;
              $scope.removeInviteItem(item);
              i--;
            }
          };
          $scope.removeInviteItem = function(item){
            $scope.invites.splice($scope.invites.indexOf(item),1);
          };
          $scope.setInviteItemPermission = function(item,permission){
            item.Permission = permission;
            if(self.userViewData["invitePermission"] != permission){
              self.userViewData["invitePermission"] = permission;
              self.updateUserViewData();              
            }
          };
          $scope.askSwitchOwner = function(item,ev){
            if(mainTopic.Owner != self.user.ID) return; // not mine 
            if(item.User == mainTopic.Owner) return; // already self
            if(!item.Email || item.Email == "" ) return; // no target
            self.confirm($filter('trans')('ASKTRANSFERMAINTOPIC', $scope.mainTopic.Name,item.Email),$filter('trans')('MOVE')).then(function(){
              self.apiPost("ajax",{"action":"transferMainTopic", "ID":$scope.mainTopic.ID, "email":item.Email})
               .then(function(data) {
                 self.closeDialog($scope.dialogElement);
                 self.keepAliveCallback();
               },function(data, status, headers, config) {
                if(data.error == "USER_NOT_FOUND")
                  self.alert($filter('trans')('SHAREUSERNOTFOUND',item.Email));
                else if(data.error == "NO_TEACHER")
                  self.alert($filter('trans')('SHAREUSERNOTEACHER',item.Email));
                else $scope.error = data.error;
               });
            });
          };
          $scope.updateInvites = function(){
            if($scope.invites.length == 0){
              $scope.addNewInviteItem();
              return;
            }
            if($scope.invites[$scope.invites.length-1].Email != ""){
              $scope.addNewInviteItem();
            }
            // try to split emails
            for(var i = 0; i < $scope.invites.length; i++){
              if($scope.invites[i].Email != ''){
                var parts = $scope.invites[i].Email.split(";");
                if(parts.length > 1){
                  $scope.invites[i].Email = parts[0];
                  var p = i;
                  for(var z = 1; z < parts.length; z++)
                    if($.trim(parts[z]) != ""){
                      $scope.invites.splice(p,0,{"Email":parts[z],"Permission":$scope.invites[i].Permission});
                      p++;
                    }
                }
              }
            }
          };
          $scope.updateInvites();

          $scope.askApplyNow = function(){
            self.confirm($filter('trans')('APPLYSHARESETTINGSNOW'),$filter('trans')('APPLYNOW'),ev,$filter('trans')('NOTAPPLY')).then(function(){
              $scope.save(true);
            },function(){
              $scope.save();
            });
          };

          $scope.save = function(applyNow){
            var a = {};
            if(mainTopic){
              a = {"action":"updateMainTopicShareSettings","data":angular.toJson($scope.invites),"mainTopic":mainTopic.ID};
            }else{
              a = {"action":"updateUserShareSettings","data":angular.toJson($scope.invites)};
              if(applyNow) a.apply = "now";
            }
            self.apiPost("ajax",a)
             .then(function(data) {
               self.closeDialog($scope.dialogElement);
               if(data.missingEmails && data.missingEmails.length > 0){
                 for(var i=0; i < data.missingEmails.length; i++)
                   self.alert($filter('trans')('SHAREMISSINGEMAILACCOUNT',data.missingEmails[i]));
               }
               self.keepAliveCallback();
             },function(data, status, headers, config) {
               self.alert("Speichern fehlgeschlagen: "+data.error);
             });

          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editMySchoolShares = function(share,ev){
      var myShare = share && share.User && share.User.Share ? JSON.parse(share.User.Share) : {};
      self.showDialog({
        templateUrl: "editMySchoolSharesDialog.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.shareAll = share && share.shareAll == 1 ? true : false;
          $scope.mainTopics = [];
          for(var i=0; i < self.userContent.mainTopics.length; i++){
            if(self.userContent.mainTopics[i].Owner != self.user.ID) continue;
            var mt = {};
            mt.ID = self.userContent.mainTopics[i].ID;
            mt.Name = self.userContent.mainTopics[i].Name;
            mt.Color = self.userContent.mainTopics[i].Color;
            mt.topics = [];
            for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
              var t = {};
              t.ID = self.userContent.mainTopics[i].topics[z].ID;
              t.Name = self.userContent.mainTopics[i].topics[z].Name;              
              t.goals = [];
              for(var x=0; x < self.userContent.mainTopics[i].topics[z].goals.length; x++){
                var g = {};
                g.ID = self.userContent.mainTopics[i].topics[z].goals[x].ID;
                g.Name = self.userContent.mainTopics[i].topics[z].goals[x].Name;              
                g.tasks = [];
                t.goals.push(g);
              }
              mt.topics.push(t);
            }
            $scope.mainTopics.push(mt);
          }


          $scope.propagateUsedMainTopic = function(mt,noUpdate){
            for(var z=0; z < mt.topics.length; z++){
              mt.topics[z].Used = mt.Used;
              for(var x=0; x < mt.topics[z].goals.length; x++){
                mt.topics[z].goals[x].Used = mt.Used;
              }
            }
            if(!noUpdate) $scope.updateUsed();
          };
          $scope.propagateUsedTopic = function(t,noUpdate){
            for(var x=0; x < t.goals.length; x++){
              t.goals[x].Used = t.Used;
            }
            if(!noUpdate) $scope.updateUsed();
          };

          $scope.updateUsed = function(){
            for(var i=0; i < $scope.mainTopics.length; i++){
              if($scope.mainTopics[i].topics.length == 0) continue;
              $scope.mainTopics[i].Used = false;
              $scope.mainTopics[i].partialUsed = false;
              var allUsed2 = true;
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                if($scope.mainTopics[i].topics[z].goals.length == 0) continue;
                $scope.mainTopics[i].topics[z].Used = false;
                $scope.mainTopics[i].topics[z].partialUsed = false;
                var allUsed = true;
                for(var x=0; x < $scope.mainTopics[i].topics[z].goals.length; x++){
                  if($scope.mainTopics[i].topics[z].goals[x].Used){
                    $scope.mainTopics[i].topics[z].partialUsed = true;
                  } else allUsed = false;
                }
                if(allUsed){
                  $scope.mainTopics[i].topics[z].partialUsed = false;
                  $scope.mainTopics[i].topics[z].Used = true;
                }
                if($scope.mainTopics[i].topics[z].Used || 
                   $scope.mainTopics[i].topics[z].partialUsed){
                  $scope.mainTopics[i].partialUsed = true;
                } 
                if(!$scope.mainTopics[i].topics[z].Used) allUsed2 = false;
              }
              if(allUsed2){
                $scope.mainTopics[i].partialUsed = false;
                $scope.mainTopics[i].Used = true;
              }
            }
          };

          // read existing shares
          if(myShare && myShare.mainTopics)
          for(var i=0; i < myShare.mainTopics.length; i++){
            if(myShare.mainTopics[i].shared == 1){
              for(var z=0; z < $scope.mainTopics.length; z++){
                if($scope.mainTopics[z].ID == myShare.mainTopics[i].ID){
                  $scope.mainTopics[z].Used = true;
                  $scope.propagateUsedMainTopic($scope.mainTopics[z],true);
                  break;
                }
              }
            }else
            for(var z=0; z < myShare.mainTopics[i].topics.length; z++){
              if(myShare.mainTopics[i].topics[z].shared == 1){
                for(var w=0; w < $scope.mainTopics.length; w++){
                  for(var x=0; x < $scope.mainTopics[w].topics.length; x++){
                    if($scope.mainTopics[w].topics[x].ID == myShare.mainTopics[i].topics[z].ID){
                      $scope.mainTopics[w].topics[x].Used = true;
                      $scope.propagateUsedTopic($scope.mainTopics[w].topics[x],true);
                      break;
                    }
                  }
                }
              }else
              for(var x=0; x < myShare.mainTopics[i].topics[z].goals.length; x++){
                if(myShare.mainTopics[i].topics[z].goals[x].shared == 1){
                  for(var w=0; w < $scope.mainTopics.length; w++){
                    for(var t=0; t < $scope.mainTopics[w].topics.length; t++){
                      for(var g=0; g < $scope.mainTopics[w].topics[t].goals.length; g++){
                        if($scope.mainTopics[w].topics[t].goals[g].ID == myShare.mainTopics[i].topics[z].goals[x].ID){
                          $scope.mainTopics[w].topics[t].goals[g].Used = true;
                          break;
                        }
                      }
                    }
                  }
                }
              }
            }
          }
          $scope.updateUsed();

          $scope.save = function() {
            var shares = {"mainTopics":[]};
            for(var i=0; i < $scope.mainTopics.length; i++){
              if(!$scope.mainTopics[i].Used && !$scope.mainTopics[i].partialUsed) continue;
              var mt = {};
              mt.ID = $scope.mainTopics[i].ID;
              mt.topics = [];
              mt.shared = $scope.mainTopics[i].Used ? 1 : 0;
              if(mt.shared == 0)
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                if(!$scope.mainTopics[i].topics[z].Used && !$scope.mainTopics[i].topics[z].partialUsed) continue;
                var t = {};
                t.ID = $scope.mainTopics[i].topics[z].ID;
                t.goals = [];
                t.shared = $scope.mainTopics[i].topics[z].Used ? 1 : 0;
                if(t.shared == 0)
                for(var x=0; x < $scope.mainTopics[i].topics[z].goals.length; x++){
                  if(!$scope.mainTopics[i].topics[z].goals[x].Used) continue;
                  var g = {};
                  g.ID = $scope.mainTopics[i].topics[z].goals[x].ID;
                  g.shared = 1;
                  t.goals.push(g);
                }
                mt.topics.push(t);
              }
              shares["mainTopics"].push(mt);
            }            
            self.apiPost("ajax",{"action":"updateSchoolShare", "shareAll":$scope.shareAll ? 1 : 0, "data":angular.toJson(shares)}).then(function(data) {
              self.closeDialog($scope.dialogElement);
              self.closeDialog(); // also close parent so it can update
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });      
    };

    self.openSchoolShares = function(ev){
      if(!self.userViewData["IntroSS"]){
        self.userViewData["IntroSS"] = 1;
        self.updateUserViewData();
        self.openTeacherSchoolSharesIntro().then(function(){
          self.openSchoolShares(ev);
        });
        return;
      }

      self.showDialog({
        templateUrl: "schoolSharesDialog.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.shares = [];
          $scope.shareAll = 0;
          $scope.ownShare = null;
          $scope.loadingShares = true;
          self.showLoadingIndicator(null,function(done){ 
            self.apiPost("ajax",{"action":"getSchoolShares"}).then(function(data) {
              $scope.shares = data.shares;
              var sortFunction = function(a,b){
                if(a.OrderIndex == b.OrderIndex){
                  return a.ID > b.ID ? 1 : -1;
                }
                return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;              
              }
              $scope.ownShare = null;
              for(var i=0; i < $scope.shares.length; i++){
                if(!self.users[$scope.shares[i].User.ID]){
                  $scope.shares[i].User.ID = parseInt($scope.shares[i].User.ID);
                  self.users[$scope.shares[i].User.ID] = $scope.shares[i].User;
                }
                if($scope.shares[i].User.ID == self.user.ID) $scope.ownShare = $scope.shares[i];
                $scope.shares[i].mainTopics.sort(sortFunction);
                for(var mt = 0; mt < $scope.shares[i].mainTopics.length; mt++){
                  if(!$scope.shares[i].mainTopics[mt].topics) continue;
                  $scope.shares[i].mainTopics[mt].topics.sort(sortFunction);
                  for(var t = 0; t < $scope.shares[i].mainTopics[mt].topics.length; t++){
                    if(!$scope.shares[i].mainTopics[mt].topics[t].goals) continue;
                    $scope.shares[i].mainTopics[mt].topics[t].goals.sort(sortFunction);
                  }
                }
              }
              // sort alphabetical 
              $scope.shares.sort(function(a,b){
                if(a.User.Surname == b.User.Surname){
                  return a.User.Name.localeCompare(b.User.Name);
                }
                return a.User.Surname.localeCompare(b.User.Surname);
              });
              // find self and place on first
              var p = $scope.shares.indexOf($scope.ownShare);
              if(p != -1){
                $scope.shares.splice(p,1);
                $scope.shares.unshift($scope.ownShare);
              }

              $scope.loadingShares = false;
              done();
            },function(data, status, headers, config) {
              self.alert("Error: "+data.error);
            });
          });

          $scope.filterSearch = function(s){
            if(!self.schoolSharesSearchTerm || self.schoolSharesSearchTerm == "") return true;
            if(angular.toJson(s).toLowerCase().indexOf(self.schoolSharesSearchTerm.toLowerCase()) != -1) return true;
            return false;
          }

          $scope.openSharedContent = function(type,it){
            var t = {};
            t.Type = type;
            if(type == "MainTopic") t.MainTopic = it;
            if(type == "Topic") t.Topic = it;
            if(type == "LearningGoal") t.LearningGoal = it;
            if(type == "Task") t.Task = it;
            self.showLoadingIndicator(null,function(done){ 
              self.acceptSharedContent(t,true);
              done();              
            });
          };

          $scope.saveMyShares = function() {
            self.apiPost("ajax",{"action":"addSchoolShare","data":angular.toJson($scope.mainTopics),"shareAll":$scope.shareAll})
             .then(function(data) {
              self.closeDialog($scope.dialogElement);
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.reorderMainTopics = function(ev){
      self.showDialog({
        templateUrl: "reorderMainTopicsPanel.html",
        skipHide:true, // keep other dialog open
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.mainTopics = [];
          var preventD = function(e) { e.preventDefault(); };

          $scope.listSortOptions = {
            longTouch:false,
            accept: function (sourceItemHandleScope, destSortableScope) {
              return sourceItemHandleScope.itemScope.sortableScope.$parent.$id ==
                     destSortableScope.$parent.$id;
            },
            dragStart : function(obj){
              $(document).on('touchstart', preventD);
            },
            dragEnd : function(obj){
              $(document).off('touchstart', preventD);
            },
            orderChanged: function (obj) {
              $scope.changed = true;
              var items = obj.source.sortableScope.modelValue;
              var item = obj.source.itemScope.modelValue;
              item.OrderIndex = 0;
              var m = 0;
              for(var i=0; i < items.length; i++){
                if(m < parseInt(items[i]["OrderIndex"]))
                   m = parseInt(items[i]["OrderIndex"]);
                if(item.ID == items[i]["ID"]){
                  if(i < items.length-1) item.OrderIndex = parseInt(items[i+1]["OrderIndex"]);
                }
              }
              if(item.OrderIndex == 0) item.OrderIndex = m+1;
              return true;
            },
            clone:false
          };

          function addMainTopic(list,mainTopic){
            var mt = {
                org:mainTopic,
                'ID':mainTopic.ID,
                'Owner':mainTopic.Owner,
                'Name':mainTopic.Name,
                'Description':mainTopic.Description,
                'Color':mainTopic.Color,
                "Permission":mainTopic.Permission,
                "shareSettings":mainTopic.shareSettings,
                "OrderIndex":parseInt(mainTopic.OrderIndex),
                "topics":[],"changed":false};
            list.push(mt);
          };

          for(var i=0; i < self.userContent.mainTopics.length; i++){
            addMainTopic($scope.mainTopics,
             JSON.parse(angular.toJson(self.userContent.mainTopics[i])),true);
          }

          $scope.save = function() {
            var t = "";
            for(var i=0; i < $scope.mainTopics.length; i++){
              t += (i > 0 ? ',' : '')+ $scope.mainTopics[i].ID;
            }
            self.apiPost("ajax",{"action":"updateMainTopicsOrder", "order": t})
             .then(function(){
               self.keepAliveCallback();
               self.closeDialog($scope.dialogElement);
             });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.moveContent = function(inputtype, it, ev){
      var getSharedMainTopic = function(){
        if(inputtype == "MainTopic"){
          return it;
        }
        if(inputtype == "Topic"){
          return self.getMainTopicFromTopic(it);
        }
        if(inputtype == "LearningGoal"){
          var goalRef = self.getGoalByID(it.ID);
          return goalRef ? goalRef.mainTopic : null;
        }
        if(inputtype == "Task"){
          var taskRef = self.getTaskByID(it.ID);
          return taskRef ? taskRef.mainTopic : null;
        }
        if(inputtype == "Tasks" && it && it.length > 0){
          var firstTaskRef = self.getTaskByID(it[0].ID);
          return firstTaskRef ? firstTaskRef.mainTopic : null;
        }
        return null;
      };

      var openMoveTargetDialog = function(){
        self.selectMoveTarget("move",inputtype == "Tasks" ? "Task" : inputtype, inputtype == "Tasks" ? it[0] : it, ev, function(target,item,type,position,follow,isLocal){
        if(inputtype == "Tasks"){
          var t = 0;
          var next = function(){
            var task = it.shift();
            var a = {"action":"moveContent","target":target, "data":task["ID"], "type":"Task", "position":position+t};
            self.apiPost("ajax",a).then(function(data) {
              t++;
              if(it.length == 0){
                self.keepAliveCallback().then(function(){
                  if(follow){
                    self.openContentFollow("Task", target, data);
                  }
                  $mdDialog.hide();
                });
              }else next();        
            });  
          }
          next();
        }else{
          var a = {"action":"moveContent","target":target, "data":item, "type":type, "position":position};
          if(!isLocal && self.currentClass) a.inclass = self.currentClass.ID;
          self.apiPost("ajax",a)
           .then(function(data) {
             self.keepAliveCallback().then(function(){
               if(follow){
                 if(isLocal)
                   self.openMaterials(ev).then(function(){
                     self.openContentFollow(type,target,data);
                   }); else
                   self.openContentFollow(type,target,data);
               }
               $mdDialog.hide();
             });
           },function(data, status, headers, config) {
             self.alert("Speichern fehlgeschlagen: "+data.error);
           });          
        }
        });
      };

      var sharedMainTopic = getSharedMainTopic();
      if(sharedMainTopic && sharedMainTopic.shareSettings && sharedMainTopic.shareSettings.length > 1){
        self.confirmAndHide('ASKMOVESHAREDCONTENT',$filter('trans')('MOVESHAREDHINT'),$filter('trans')('MOVE'),ev).then(function(){
          openMoveTargetDialog();
        });
      }else{
        openMoveTargetDialog();
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.lastFollowContent = true;
    self.lastSelectMoveTarget = {};

    self.selectMoveTarget = function(mode, type, it, ev, callback){
      it = Object.assign({},it); // make a copy first
      self.showDialog({
        templateUrl: "movecontentpanel.html",
        skipHide:true, // keep other dialog open
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.mode = mode;
          $scope.followContent = self.lastFollowContent;
          $scope.it = it;
          $scope.type = type;
          $scope.selected = {};
          $scope.selected.type = type;
          $scope.selected.MainTopic = null;
          $scope.selected.Topic = null;
          $scope.selected.LearningGoal = null;
          $scope.mainTopics = [];

          // map the current item to move or copy 
          var mts = self.currentClass ?
                    self.classContent[self.currentClass.ID].mainTopics :
                    self.userContent.mainTopics;

          for(var i=0; i < mts.length; i++){
            var mt = mts[i];
            for(var z=0; z < mts[i].topics.length; z++){
              var t = mts[i].topics[z];
              for(var x=0; x < mts[i].topics[z].goals.length; x++){
                var g = mts[i].topics[z].goals[x];
                if(it.LearningGoal == mts[i].topics[z].goals[x].ID){
                  it.Task = {ID:it.ID, Name:it.Name, Description:it.Description};
                  it.LearningGoal = {ID:g.ID, Name:g.Name, Description:g.Description};
                  it.Topic = {ID:t.ID, Name:t.Name, Description:t.Description,Image:t.Image};
                  it.MainTopic = {ID:mt.ID, Name:mt.Name,
                                  Description:mt.Description,Color:mt.Color};
                }
              }
              if(it.Topic == mts[i].topics[z].ID){
                if(!it.LearningGoal)
                  it.LearningGoal = {ID:it.ID, Name:it.Name, Description:it.Description};
                it.Topic = {ID:t.ID, Name:t.Name, Description:t.Description,Image:t.Image};
                it.MainTopic = {ID:mt.ID, Name:mt.Name,
                                Description:mt.Description,Color:mt.Color};
              }
            }
            if(it.MainTopic == mts[i].ID){
              if(!it.Topic)
                it.Topic = {ID:it.ID, Name:it.Name, Description:it.Description,
                            Image:it.Image};
              it.MainTopic = {ID:mt.ID, Name:mt.Name,
                              Description:mt.Description,Color:mt.Color};
            }
          }

          $scope.preselectDropDowns = function(changed){
            var lastMoveSelectionJson = self.getLocalStorage("lastMoveSelection");
            var lastMoveSelection = lastMoveSelectionJson ? JSON.parse(lastMoveSelectionJson) : {};


            if(changed == "MainTopic"){

              if(!lastMoveSelection[$scope.selected.MainTopic.ID]) lastMoveSelection[$scope.selected.MainTopic.ID] = {};
              var preSelectTopicID = 0;

              if(lastMoveSelection[$scope.selected.MainTopic.ID].topic){
                var topic = parseInt(lastMoveSelection[$scope.selected.MainTopic.ID].topic);
                for(var i=0; i < $scope.selected.MainTopic.topics.length; i++){
                  if($scope.selected.MainTopic.topics[i].ID == topic){
                    preSelectTopicID = i;
                    break;
                  }
                }
              }
              $scope.selected.Topic = $scope.selected.MainTopic.topics[preSelectTopicID] ? $scope.selected.MainTopic.topics[preSelectTopicID] : null;
              $scope.selected.LearningGoal = null;

              if($scope.selected.type == "Task" && $scope.selected.Topic){
                var preSelectLearningGoalID = 0;
                if(lastMoveSelection[$scope.selected.MainTopic.ID].topics && 
                   lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID] &&
                   lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID].goal){
                  var goal = parseInt(lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID].goal);
                  for(var i=0; i < $scope.selected.Topic.goals.length; i++){
                    if($scope.selected.Topic.goals[i].ID == goal){
                      preSelectLearningGoalID = i;
                      break;
                    }
                  }
                }
                $scope.selected.LearningGoal = $scope.selected.Topic.goals[preSelectLearningGoalID] ? $scope.selected.Topic.goals[preSelectLearningGoalID] : null;              
              }
            }

            if(changed == "Topic" && $scope.selected.MainTopic){
              if(!lastMoveSelection[$scope.selected.MainTopic.ID]) lastMoveSelection[$scope.selected.MainTopic.ID] = {};
              if(!lastMoveSelection[$scope.selected.MainTopic.ID].topics) lastMoveSelection[$scope.selected.MainTopic.ID].topics = {};
              if(!lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID]) lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID] = {};

              $scope.selected.LearningGoal = null;

              if($scope.selected.type == "Task"){
                var preSelectLearningGoalID = 0;
                if(lastMoveSelection[$scope.selected.MainTopic.ID].topics && lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID].goal){
                  var goal = parseInt(lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID].goal);
                  for(var i=0; i < $scope.selected.Topic.goals.length; i++){
                    if($scope.selected.Topic.goals[i].ID == goal){
                      preSelectLearningGoalID = i;
                      break;
                    }
                  }
                }
                $scope.selected.LearningGoal = $scope.selected.Topic.goals[preSelectLearningGoalID] ? $scope.selected.Topic.goals[preSelectLearningGoalID] : null;              
              }

              if($scope.selected.MainTopic && $scope.selected.Topic)
                lastMoveSelection[$scope.selected.MainTopic.ID].topic = $scope.selected.Topic.ID;
            }
            if(changed == "LearningGoal"){
              if(!lastMoveSelection[$scope.selected.MainTopic.ID]) lastMoveSelection[$scope.selected.MainTopic.ID] = {};
              if(!lastMoveSelection[$scope.selected.MainTopic.ID].topics) lastMoveSelection[$scope.selected.MainTopic.ID].topics = {};
              if(!lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID]) lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID] = {};

              if($scope.selected.MainTopic && $scope.selected.Topic && $scope.selected.LearningGoal)
                lastMoveSelection[$scope.selected.MainTopic.ID].topics[$scope.selected.Topic.ID].goal = $scope.selected.LearningGoal.ID;
            }

            self.setLocalStorage("lastMoveSelection", JSON.stringify(lastMoveSelection));
          };

          var preventD = function(e) { e.preventDefault(); };

          $scope.listSortOptions = {
            longTouch:false,
            accept: function (sourceItemHandleScope, destSortableScope) {
              return sourceItemHandleScope.itemScope.sortableScope.$parent.$id ==
                     destSortableScope.$parent.$id;
            },
            dragStart : function(obj){
              $(document).on('touchstart', preventD);
            },
            dragEnd : function(obj){
              $(document).off('touchstart', preventD);
            },
            orderChanged: function (obj) {
              var items = obj.source.sortableScope.modelValue;
              var item = obj.source.itemScope.modelValue;
              item.OrderIndex = 0;
              var m = 0;
              for(var i=0; i < items.length; i++){
                if(m < parseInt(items[i]["OrderIndex"]))
                   m = parseInt(items[i]["OrderIndex"]);
                if(item.ID == items[i]["ID"]){
                  if(i < items.length-1) item.OrderIndex = parseInt(items[i+1]["OrderIndex"]);
                }
              }
              if(item.OrderIndex == 0) item.OrderIndex = m+1;
              return true;
            },
            clone:false
          };

          var placeholderUsed = false;
          function addMainTopic(list,mainTopic,isLocal){
            var needsCopy = mode == "copy" ? " "+$filter('trans')('ISCOPY') : ""; // add label

            var mt = {
                org:mainTopic,
                'ID':mainTopic.ID,
                'Owner':mainTopic.Owner,
                'Name':mainTopic.Name,
                'Description':mainTopic.Description,
                'Color':mainTopic.Color,
                "Permission":mainTopic.Permission,
                "shareSettings":mainTopic.shareSettings,
                "OrderIndex":parseInt(mainTopic.OrderIndex),
                "topics":[],"changed":false};
            if(isLocal) mt.isLocal = true;

            // hide current item when move
            if(!(type == "MainTopic" && mode == 'move' && it.ID == mt.ID))
              list.push(mt);
            if(type == "MainTopic" && it.ID == mt.ID && !placeholderUsed) {
              placeholderUsed = true;
              list.push({ ID:'new', "Name":it.Name + (it.Owner == self.user.ID ? needsCopy:''), "OrderIndex":parseInt(mt.OrderIndex)+1,topics:[]});
            }

            var placeholderTopicUsed = false;
            for(var z=0; z < mainTopic.topics.length; z++){
              var t = {org:mainTopic.topics[z],
                       'ID':mainTopic.topics[z].ID,
                       'Name':mainTopic.topics[z].Name,
                       'Description':mainTopic.topics[z].Description,
                       'OrderIndex':parseInt(mainTopic.topics[z].OrderIndex),
                       'changed':false, 'goals':[]};
              // hide current item when move
              if(!(type == "Topic" && mode == 'move' && it.ID == t.ID))
                mt.topics.push(t);
              if(type == "Topic" && it.ID == t.ID) {
                placeholderTopicUsed = true;
                mt.topics.push({ ID:'new', "Name":it.Name+needsCopy, "OrderIndex":parseInt(t.OrderIndex)+1,goals:[]});
              }

              var placeholderGoalUsed = false;
              for(var x=0; x < mainTopic.topics[z].goals.length; x++){
                var g = {org:mainTopic.topics[z].goals[x],
                        'ID':mainTopic.topics[z].goals[x].ID,
                        'Name':mainTopic.topics[z].goals[x].Name,
                        'Description':mainTopic.topics[z].goals[x].Description,
                        'OrderIndex':parseInt(mainTopic.topics[z].goals[x].OrderIndex),
                        'changed':false,'tasks':[]};
                // hide current item when move
                if(!(type == "LearningGoal" && mode == 'move' && it.ID == g.ID))
                  t.goals.push(g);
                if(type == "LearningGoal" && it.ID == g.ID) {
                  placeholderGoalUsed = true;
                  t.goals.push({ ID:'new', "Name":it.Name+needsCopy, "OrderIndex":parseInt(g.OrderIndex)+1,tasks:[]});
                }

                var placeholderTaskUsed = false;
                for(var y=0; y < mainTopic.topics[z].goals[x].tasks.length; y++){
                  var tt = {org:mainTopic.topics[z].goals[x].tasks[y],
                           'ID':mainTopic.topics[z].goals[x].tasks[y].ID,
                           'Name':mainTopic.topics[z].goals[x].tasks[y].Name,
                           'Description':mainTopic.topics[z].goals[x].tasks[y].Description,
                           'OrderIndex':parseInt(mainTopic.topics[z].goals[x].tasks[y].OrderIndex),
                           'changed':false};
                  // hide current item when move
                  if(!(type == "Task" && mode == 'move' && it.ID == tt.ID))
                    g.tasks.push(tt);
                  if(type == "Task" && it.ID == tt.ID) {
                    placeholderTaskUsed = true;
                    g.tasks.push({ ID:'new', org:it, "Name":it.Name+needsCopy, "OrderIndex":parseInt(tt.OrderIndex)+1});
                  }
                }
                if(type == 'Task'  && !placeholderTaskUsed)
                  g.tasks.push({ID:'new', org:it, "Name":it.Name, "OrderIndex":g.tasks.length > 0 ? g.tasks[g.tasks.length-1].OrderIndex+1 : 0});
              }
              if(type == 'LearningGoal' && !placeholderGoalUsed)
                t.goals.push({ID:'new', org:it, "Name":it.Name, "OrderIndex":t.goals.length > 0 ? t.goals[t.goals.length-1].OrderIndex+1 : 0, tasks:[]});
            }
            if(type == 'Topic' && !placeholderTopicUsed)
              mt.topics.push({ID:'new', org:it, "Name":it.Name, "OrderIndex":mt.topics.length > 0 ? mt.topics[mt.topics.length-1].OrderIndex+1 : 0, goals:[]});

          }
          var refreshDropDowns = function(){
            $scope.mainTopics = [];
            $scope.selected.MainTopic = null;
            $scope.selected.Topic = null;
            $scope.selected.LearningGoal = null;
            // copy content to scope variable to select from
            if(self.currentClass && self.hasClassChangePermission(self.currentClass)){
              for(var i=0; i < self.classContent[self.currentClass.ID].mainTopics.length; i++){
                addMainTopic($scope.mainTopics,
                   JSON.parse(angular.toJson(self.classContent[self.currentClass.ID].mainTopics[i])));
              }
              for(var i=0; i < self.userContent.mainTopics.length; i++){
                var isThere = false;
                for(var z=0; z < $scope.mainTopics.length; z++){
                  if($scope.mainTopics[z].ID == self.userContent.mainTopics[i].ID){
                    isThere = true; break;
                  }
                }
                if(!isThere)
                  addMainTopic($scope.mainTopics,
                   JSON.parse(angular.toJson(self.userContent.mainTopics[i])),true);
              }
            }else{
              for(var i=0; i < self.userContent.mainTopics.length; i++){
                addMainTopic($scope.mainTopics,
                   JSON.parse(angular.toJson(self.userContent.mainTopics[i])),true);
              }
            }

            if(!placeholderUsed){
              if(type == 'MainTopic') $scope.mainTopics.unshift({
                ID:'new', org:it, "Name":it.Name, "OrderIndex":0, topics:[]
              });
            }
          };
          refreshDropDowns();

          // preselect location based on current content
          if(type == "Topic") {
            var foundOn = false;
            for(var i=0; i < $scope.mainTopics.length; i++){
              if(it.MainTopic && $scope.mainTopics[i].ID == it.MainTopic.ID){
                $scope.selected.MainTopic = $scope.mainTopics[i];
                foundOn = true;
                break;
              }
            }
            // search again
            if(!foundOn)
            for(var i=0; i < $scope.mainTopics.length; i++){
              if(it.MainTopic &&
                 it.MainTopic.Name == $scope.mainTopics[i].Name &&
                 it.MainTopic.Description == $scope.mainTopics[i].Description
                ){
                $scope.selected.MainTopic = $scope.mainTopics[i];
                break;
              }
            }
          }

          if(type == "LearningGoal") {
            var foundOn = false;
            for(var i=0; i < $scope.mainTopics.length; i++){
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                if(it.Topic && $scope.mainTopics[i].topics[z].ID == it.Topic.ID){
                  $scope.selected.MainTopic = $scope.mainTopics[i];
                  $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                  foundOn = true;
                  break;
                }
              }
              if(foundOn) break;
            }
            // search again
            if(!foundOn)
            for(var i=0; i < $scope.mainTopics.length; i++){
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                if((it.Topic && $scope.mainTopics[i].topics[z].ID == it.Topic.ID) || (
                    it.MainTopic && it.Topic &&
                    it.MainTopic.Name == $scope.mainTopics[i].Name &&
                    it.MainTopic.Description == $scope.mainTopics[i].Description &&
                    it.Topic.Name == $scope.mainTopics[i].topics[z].Name &&
                    it.Topic.Description == $scope.mainTopics[i].topics[z].Description
                  )){
                  $scope.selected.MainTopic = $scope.mainTopics[i];
                  $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                  foundOn = true;
                  break;
                }
              }
              if(foundOn) break;
            }
          }

          if(type == "Task") {
            var foundOn = false;
            for(var i=0; i < $scope.mainTopics.length; i++){
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                for(var t=0; t < $scope.mainTopics[i].topics[z].goals.length; t++){
                  if(it.LearningGoal &&
                      $scope.mainTopics[i].topics[z].goals[t].ID == it.LearningGoal.ID){
                    $scope.selected.MainTopic = $scope.mainTopics[i];
                    $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                    $scope.selected.LearningGoal = $scope.mainTopics[i].topics[z].goals[t];
                    foundOn = true;
                    break;
                  }
                }
                if(foundOn) break;
              }
              if(foundOn) break;
            }
            // search again
            if(!foundOn)
            for(var i=0; i < $scope.mainTopics.length; i++){
              for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                for(var t=0; t < $scope.mainTopics[i].topics[z].goals.length; t++){
                  if( it.MainTopic && it.Topic && it.LearningGoal &&
                      it.MainTopic.Name == $scope.mainTopics[i].Name &&
                      it.MainTopic.Description == $scope.mainTopics[i].Description &&
                      it.Topic.Name == $scope.mainTopics[i].topics[z].Name &&
                      it.Topic.Description == $scope.mainTopics[i].topics[z].Description &&
                      it.LearningGoal.Name == $scope.mainTopics[i].topics[z].goals[t].Name &&
                      it.LearningGoal.Description == $scope.mainTopics[i].topics[z].goals[t].Description
                    ){
                    $scope.selected.MainTopic = $scope.mainTopics[i];
                    $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                    $scope.selected.LearningGoal = $scope.mainTopics[i].topics[z].goals[t];
                    foundOn = true;
                    break;
                  }
                }
                if(foundOn) break;
              }
              if(foundOn) break;
            }
          }

          // preselect location based on last target, when not following content last time
          if(!self.lastFollowContent){
            if(type == "Topic" && self.lastSelectMoveTarget.topic){
              for(var i=0; i < $scope.mainTopics.length; i++){
                if(it.MainTopic && $scope.mainTopics[i].ID == self.lastSelectMoveTarget.topic.mainTopic){
                  $scope.selected.MainTopic = $scope.mainTopics[i];
                  break;
                }
              }
            }
            if(type == "LearningGoal" && self.lastSelectMoveTarget.goal){
              for(var i=0; i < $scope.mainTopics.length; i++){
                for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                  if(it.Topic && $scope.mainTopics[i].topics[z].ID == self.lastSelectMoveTarget.goal.topic){
                    $scope.selected.MainTopic = $scope.mainTopics[i];
                    $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                  }
                }
              }
            }
            if(type == "Task" && self.lastSelectMoveTarget.task){
              var foundOn = false;
              for(var i=0; i < $scope.mainTopics.length; i++){
                for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                  for(var t=0; t < $scope.mainTopics[i].topics[z].goals.length; t++){
                    if(it.LearningGoal &&
                        $scope.mainTopics[i].topics[z].goals[t].ID == self.lastSelectMoveTarget.task.goal){
                      $scope.selected.MainTopic = $scope.mainTopics[i];
                      $scope.selected.Topic = $scope.mainTopics[i].topics[z];
                      $scope.selected.LearningGoal = $scope.mainTopics[i].topics[z].goals[t];
                      foundOn = true;
                      break;
                    }
                  }
                  if(foundOn) break;
                }
                if(foundOn) break;
              }
            }
          }
          
          // scroll to new item on open
          setTimeout(function(){
            var div = $(".targetItem");
            if(div.length > 0) div[0].scrollIntoView({
               behavior: "smooth", // or "auto" or "instant"
               block: "end" // "start" or "end"
            });
            setTimeout(function(){
              if(div.length > 0) div[0].scrollIntoView({
                 behavior: "smooth", // or "auto" or "instant"
                 block: "end" // "start" or "end"
              });
            },500);
          },300);

          $scope.createNew = function(type){
            $mdSelect.hide();
            self.openMaterials();
            if(type == "MainTopic"){
              self.createMainTopic(null,false).then(function(it){ ; // at the end
                // created
                refreshDropDowns();
                $scope.selected.MainTopic = null;
                $scope.selected.Topic = null;
                $scope.selected.LearningGoal = null;
                for(var i=0; i < $scope.mainTopics.length; i++){
                  if($scope.mainTopics[i].ID == it.ID){
                    $scope.selected.MainTopic = $scope.mainTopics[i];
                  }
                }
              });
            }
            if(type == "Topic"){
              var mt = $scope.selected.MainTopic;
              self.createTopic(mt,null).then(function(it){
                // created
                refreshDropDowns();
                $scope.selected.MainTopic = null;
                $scope.selected.Topic = null;
                $scope.selected.LearningGoal = null;
                for(var i=0; i < $scope.mainTopics.length; i++){
                  if($scope.mainTopics[i].ID == mt.ID){
                    $scope.selected.MainTopic = $scope.mainTopics[i];
                  }
                }
                for(var i=0; i < $scope.selected.MainTopic.topics.length; i++){
                  if($scope.selected.MainTopic.topics[i].ID == it.ID){
                    $scope.selected.Topic = $scope.selected.MainTopic.topics[i];
                  }
                }
              });;
            }
            if(type == "LearningGoal"){
              // ask for a Name
              self.prompt($filter('trans')('CREATELEARNINGGOAL')+":",
                          $filter('trans')('SAVE'),
                          $filter('trans')('NAME'),"").then(function(name){
                if(name && name != '')
                  var mt = $scope.selected.MainTopic;
                  var t = $scope.selected.Topic;
                  self.createLearningGoalWithTopic(name,t).then(function(it){
                    // created
                    refreshDropDowns();
                    $scope.selected.MainTopic = null;
                    $scope.selected.Topic = null;
                    $scope.selected.LearningGoal = null;
                    for(var i=0; i < $scope.mainTopics.length; i++){
                      if($scope.mainTopics[i].ID == mt.ID){
                        $scope.selected.MainTopic = $scope.mainTopics[i];
                      }
                    }
                    for(var i=0; i < $scope.selected.MainTopic.topics.length; i++){
                      if($scope.selected.MainTopic.topics[i].ID == t.ID){
                        $scope.selected.Topic = $scope.selected.MainTopic.topics[i];
                      }
                    }
                    for(var i=0; i < $scope.selected.Topic.goals.length; i++){
                      if($scope.selected.Topic.goals[i].ID == it.ID){
                        $scope.selected.LearningGoal = $scope.selected.Topic.goals[i];
                      }
                    }
                  });
              });
            }
          };

          $scope.ok = function() {
            self.lastFollowContent = $scope.followContent;
            var id = 0;
            var pos = 0;
            if(type == "MainTopic") {
              id = self.user.ID;
              for(var i=0; i < $scope.mainTopics.length; i++){
                if($scope.mainTopics[i].ID == 'new')
                  pos = parseInt($scope.mainTopics[i].OrderIndex);
              }
            }
            if(type == "Topic") {
              id = $scope.selected.MainTopic.ID;
              for(var i=0; i < $scope.selected.MainTopic.topics.length; i++){
                if($scope.selected.MainTopic.topics[i].ID == 'new')
                  pos = parseInt($scope.selected.MainTopic.topics[i].OrderIndex);
              }
              self.lastSelectMoveTarget.topic = {mainTopic: $scope.selected.MainTopic.ID};
            }
            if(type == "LearningGoal") {
              id = $scope.selected.Topic.ID;
              for(var i=0; i < $scope.selected.Topic.goals.length; i++){
                if($scope.selected.Topic.goals[i].ID == 'new')
                  pos = parseInt($scope.selected.Topic.goals[i].OrderIndex);
              }
              self.lastSelectMoveTarget.goal = {mainTopic: $scope.selected.MainTopic.ID,
                                                topic:$scope.selected.Topic.ID};
            }
            if(type == "Task") {
              id = $scope.selected.LearningGoal.ID;
              for(var i=0; i < $scope.selected.LearningGoal.tasks.length; i++){
                if($scope.selected.LearningGoal.tasks[i].ID == 'new')
                  pos = parseInt($scope.selected.LearningGoal.tasks[i].OrderIndex);
              }
              self.lastSelectMoveTarget.task = {mainTopic: $scope.selected.MainTopic.ID,
                                                topic:$scope.selected.Topic.ID,
                                                goal: $scope.selected.LearningGoal.ID};
            }
            self.closeDialog($scope.dialogElement);
            callback(id,it.ID,type,pos,self.lastFollowContent,
                     $scope.selected.MainTopic &&
                     $scope.selected.MainTopic.isLocal ? true : false);
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          }; 
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateMainTopic = function(it,ev){
      self.selectMoveTarget("copy","MainTopic", it,ev,
        function(target,item,type,position,follow,isLocal){

        var a = {"action":"copyMainTopic","mainTopic":it.ID,"position":position};
        var doNow = function(){
          self.apiPost("ajax",a).then(function(data) {
             self.keepAliveCallback().then(function(){
               if(follow){
                 self.openContentFollow("MainTopic",
                   data.mainTopic.ID,data).then(function(){                
                 });
               }
             });
           },function(data, status, headers, config) {
             self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
           });          
        }
        if(it.shareSettings && it.shareSettings.length > 1){
          self.confirm($filter('trans')('ASKDUPLICATESHARESETTINGS',it.shareSettings.length - 1),$filter('trans')('YES') ,ev, $filter('trans')('NO')).then(function(){
            a.useShareSettings = 1;
            doNow();
          },function(){
            a.useShareSettings = 0;
            doNow();
          });
        }else{
          doNow()
        }
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateTopic = function(it,mainTopic,ev){
      self.selectMoveTarget("copy","Topic", it,ev,
        function(target,item,type,position,follow,isLocal){
        var a = {"action":"copyTopic","topic":it.ID,"target":target,
                 "mainTopic":mainTopic.ID,"position":position};
        self.apiPost("ajax",a)
         .then(function(data) {
           self.keepAliveCallback().then(function(){
             if(follow){
               self.openContentFollow("Topic",
                 data.topic.ID,data).then(function(){

               });
             }
           });
         },function(data, status, headers, config) {
           self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
         });
       });
    };
