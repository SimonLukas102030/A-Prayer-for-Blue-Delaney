    self.text2SpeechLanguages = [
      { Name: "Thorsten (Deutsch)", Icon: "flag_de.png", Code: "de-0", Source: "LV"},
      { Name: "Kerstin (Deutsch)", Icon: "flag_de.png", Code: "de-21", Source: "LV"},
      { Name: "Cori (Englisch)", Icon: "flag_gb.png", Code: "en-22", Source: "LV"},
      { Name: "Amélie (Französisch)", Icon: "flag_fr.png", Code: "fr-23", Source: "LV"},
      { Name: "Paola (Italienisch)", Icon: "flag_it.png", Code: "it-24", Source: "LV" }
    ];

    self.currentTTSLanguage = self.getLocalStorage("lastTTSLanguage");
    // default voice
    if(!self.currentTTSLanguage || self.currentTTSLanguage == "") self.currentTTSLanguage = "de-0";

    self.getText2Speech = function (text, target) {
      var deferred = $q.defer();
      self.getServerText2Speech(text, target).then(deferred.resolve, deferred.reject);
      return deferred.promise;
    };

    self.getServerText2Speech = function(text,target){
      var data = {};
      data.t = "de";
      data.v = "1";
      if(self.currentTTSLanguage){
        var parts = self.currentTTSLanguage.split('-');
        data.t = parts[0];
        data.v = parts[1];
      }
      data.uid = self.user ? self.user.ID : 0;
      data.salt = self.user ? self.user.Salt : '';
      // remove all emojies and strip html style tags
      function cleanHtml(text) {
        const parser = new DOMParser();
        const doc = parser.parseFromString(text, "text/html");

        const allowedTags = ["UL","OL","LI","BR"];

        // Unerwünschte Tags komplett entfernen
        doc.querySelectorAll("script, style, iframe, noscript").forEach(function(el) {
          el.remove();
        });

        // Alle Elemente durchgehen
        var allElements = doc.body.querySelectorAll("*");
        for (var i = 0; i < allElements.length; i++) {
          var el = allElements[i];

          // Nicht erlaubte Tags "entpacken"
          if (allowedTags.indexOf(el.tagName) === -1) {
            var parent = el.parentNode;
            if (parent) {
              // Keep word boundaries when removing wrapper tags.
              parent.insertBefore(doc.createTextNode(" "), el);
              while (el.firstChild) {
                parent.insertBefore(el.firstChild, el);
              }
              parent.insertBefore(doc.createTextNode(" "), el);
              parent.removeChild(el);
            }
            continue;
          }

          // Alle Attribute entfernen
          var attrs = el.attributes;
          for (var j = attrs.length - 1; j >= 0; j--) {
            el.removeAttribute(attrs[j].name);
          }
        }        
        return doc.body.innerHTML;
      }
      data.s = cleanHtml(text.replace(/&nbsp;/g," ").replace(/\p{Extended_Pictographic}/gu, ' ').replace(/\s+/g,' '));

      data.e = "supersonic";
      
      var deferred = $q.defer();

      if(self.getServerText2SpeechFetching) return deferred.promise;

      self.getServerText2SpeechFetching = true;
      var r = $http({
        url: "https://learningview.org/api/text2speech.php",
        method: "POST",
        withCredentials : true,
        ignoreLoadingBar: true,
        useXDomain : true,
        headers: {'Content-Type': 'application/x-www-form-urlencoded'},
        transformRequest: function(obj) {
          var str = [];
          for(var p in obj)
            str.push(encodeURIComponent(p) + "=" + encodeURIComponent(obj[p]));
          return str.join("&");
        },
        data: data
      });

      r.then(function(response){
        self.getServerText2SpeechFetching = false;
        var data = response.data;
        if(data.result && data.result == "OK") {
          self.showTaskMedia("audio",{URL:data.url,text:$filter('trans')('READALOUD')},null,true,true);
          deferred.resolve();
        }else{
          deferred.reject(data);
        }
      },function(){
        // server error, no answer or no connection
        self.getServerText2SpeechFetching = false;
        console.log("text2speech failed.");
        deferred.reject({result:"FAILED", error:"CONNECTION_ERROR"});
      });

      return deferred.promise;
    };
