    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showPasteTextDialog = function(){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: 'pasteDialog.html',
        skipHide:true, // keep other dialog open
        targetEvent: null,
        clickOutsideToClose:false,
        controller: function ($scope, $mdDialog) {
          $scope.pasteText = "";
          $scope.paste = function() {
            deferred.resolve($scope.pasteText);
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addTextRecorderScope = function($scope){
      $scope.textedit = {};
      $scope.textedit.current = {Text:'', Old:''};
      $scope.textedit.users = [parseInt(self.user.ID)];
      $scope.textedit.invited = [];
      $scope.textedit.invitedIDs = {};
      $scope.textedit.title = "Dokumment";
      $scope.textedit.caption = "Dokument"; // for small button label
      $scope.textedit.task = null;
      $scope.textedit.docID = "";

      $scope.inviteUser = function(userid){ 
        userid = parseInt(userid);       
        if($scope.textedit.users.indexOf(userid) != -1) return; // we cannot invite a user which is already here
        // invite another user to this document
        // send a message to this user, add a tab button in lower left corner to join doc
        // invite is only valid for 2 min and will be removed after that time again

        var pos = $scope.textedit.invited.indexOf(userid);
        if(pos == -1) {
          var d = {id:$scope.textedit.docID, 
                   title:$scope.textedit.title, 
                   caption:$scope.textedit.caption, 
                   task:$scope.textedit.task ? $scope.textedit.task.ID : 0};
          $scope.textedit.invited.push(userid);     
          self.apiPost("ajax",{"action":"createCollaboration", "user":userid, 
                                        "classid":self.currentClass.ID, "noerror":1,
                                        "type":"doc", "data":JSON.stringify(d)}).then(function(data) {
            $scope.textedit.invitedIDs[userid] = data.collaboration;
            $timeout(function(){
              if($scope && $scope.textedit && 
                 $scope.textedit.invitedIDs[userid] == data.collaboration) 
                 $scope.textedit.invitedIDs[userid] = null;
              for(var i=0; i < $scope.textedit.invited.length; i++){
                if($scope.textedit.invited[i] == userid){
                  $scope.textedit.invited.splice(i,1);
                  break;
                }
              }
            },1000*60*2); // remove after 2 minutes
          });            
        }else{
          $scope.removeInvite(userid);
        }
      };

      $scope.removeInvite = function(userid){
        userid = parseInt(userid);       
        var pos = $scope.textedit.invited.indexOf(userid);
        if(pos == -1) return; // not found
        $scope.textedit.invited.splice(pos,1);
        var c = $scope.textedit.invitedIDs[userid];
        if(c)
          self.apiPost("ajax",{"action":"removeCollaboration", "ID":c, "noerror":1}).then(function(data) {
            if(c == $scope.textedit.invitedIDs[userid]) $scope.textedit.invitedIDs[userid] = null;
          });            
      };

      $scope.changeContentDelayTimer = null;


      $scope.requestClose = function(callback){
        $scope.requestCloseCallback = callback;
        // set empty if nothing is inside doc
        if(self.isEmptyHTMLText($scope.textedit.current.Text)) $scope.textedit.current.Text = "";

        // we close the editor and something has changed
        if($scope.textedit.onClose)
           $scope.textedit.onClose();

        $scope.postMessage("CLOSE");
        // remove all invites too 
        for(var i=0; i < $scope.textedit.invited.length; i++)
          $scope.removeInvite($scope.textedit.invited[i]);
      };

      $scope.hasChangedTextData = function(){
        if($scope.textedit && $scope.textedit.editable === false) return false;
        return !self.isSameContentHTML($scope.textedit.current.Text,$scope.textedit.current.Old);
      };

      $scope.postMessage = function(e){
        var frame = $('.textEditorFrame',$scope.dialogElement).get(0);
        if(e.source && frame.contentWindow != e.source) return; // ignore other frames
        if(e == "CLOSE"){
          // request close of iframe and save last changes
          if(frame && $scope.isReady){
            frame.contentWindow.postMessage("CLOSE","*");
          }else{
            if($scope.requestCloseCallback){
               var cc = $scope.requestCloseCallback;             
               $scope.requestCloseCallback = null; 
               cc();
            }
          }
        }
        if(e.data && e.data == "CLOSED"){
          // closed event send by iframe, now we can leave the page
          if($scope.requestCloseCallback){
             var cc = $scope.requestCloseCallback;             
             $scope.requestCloseCallback = null; 
             cc();
          }
        }        
        if(e.data && e.data.html){
          // we got HTML from iframe, store it
          if($scope.textedit.editable)
            $timeout(function(){ $scope.textedit.current.Text = e.data.html; },0);

          // mark classCollaboration document changed
          if(self.currentClass && $scope.classCollaboration){
            if(!self.isSameContentHTML($scope.textedit.current.Text,$scope.textedit.current.Old)){
              if($scope.changeContentDelayTimer) clearTimeout($scope.changeContentDelayTimer);
              $scope.changeContentDelayTimer = setTimeout(function(){
                self.setLastOpenTime("classdoc",self.currentClass.ID+'-'+$scope.classCollaboration.ID);
                // changed document, if it was a class doc, set last change time too
                self.apiPost("ajax",{"action":"setClassCollaborationChanged", 
                                              "ID":$scope.classCollaboration.ID, 
                                              "classid":$scope.classCollaboration.Class});            
                $scope.changeContentDelayTimer = null;             
              },1000);
            }
          }
        }
        if(e.data && e.data.users){
          // update current users in this document
          $timeout(function(){ 
            while($scope.textedit.users.length > 0) $scope.textedit.users.pop();
            for(var i=0; i < e.data.users.length; i++){
              $scope.textedit.users.push(parseInt(e.data.users[i].id));
              $scope.removeInvite(parseInt(e.data.users[i].id));
            }
          },0);
        }
        if(e.data == "READY"){
          // send in the current
          if(frame && frame.contentWindow && $scope.textedit.current.Text != "")
             frame.contentWindow.postMessage({loadHTML:$scope.textedit.current.Text },"*");
        }        
        if(e.data == "REQUESTIMAGE"){
          // take picture and send back
          $timeout(function(){
            self.takeUserMedia("image",null,function(results){
              var frame = $('.textEditorFrame',$scope.dialogElement).get(0);
              if(frame){
                frame.contentWindow.postMessage("ADD"+results[0].Type.toUpperCase()+"|"+results[0].URL,"*");
              }
            }, {dialogMode: 0});
          },10);
        }
        if(e.data == "REQUESTAUDIO"){
          // record audio and send back
          $timeout(function(){
            self.takeUserMedia("audio",null,function(results){
              var frame = $('.textEditorFrame',$scope.dialogElement).get(0);
              if(frame){
                frame.contentWindow.postMessage("ADD"+results[0].Type.toUpperCase()+"|"+results[0].URL,"*");
              }
            }, {dialogMode: 0});
          },10);
        }
        if(e.data == "REQUESTWEBLINK"){
          // record weblink and send back
          $timeout(function(){
            self.takeUserMedia("link",null,function(results){
              var frame = $('.textEditorFrame',$scope.dialogElement).get(0);
              if(frame){
                frame.contentWindow.postMessage("ADD"+results[0].Type.toUpperCase()+"|"+results[0].URL,"*");
              }
            }, {dialogMode: 1});
          },10);
        }
        if(e.data && e.data.indexOf && e.data.indexOf("UPLOADIMAGE|") === 0){
          // take picture and send back
          var dataURI = e.data.substring(("UPLOADIMAGE|").length);
          var byteString = atob(dataURI.split(',')[1]);
          var mimeString = dataURI.split(',')[0].split(':')[1].split(';')[0];
          var ab = new ArrayBuffer(byteString.length);
          var ia = new Uint8Array(ab);
          for (var i = 0; i < byteString.length; i++) {
              ia[i] = byteString.charCodeAt(i);
          }
          var blob = new Blob([ab], {type: mimeString});
          $timeout(function(){
            self.uploadFile(blob, $scope.textedit.title, self.getMediaID(),'image',null,function(result){
              var frame = $('.textEditorFrame',$scope.dialogElement).get(0);
              if(frame){
                frame.contentWindow.postMessage("ADDIMAGE|"+result,"*");
              }
            });
          },10);
        }
        if(e.data && e.data.indexOf && e.data.indexOf("DOWNLOADFILE|") === 0){
          var data = e.data.substring(("DOWNLOADFILE|").length);
          self.downloadFile(data,$scope.textedit.title+".pdf");
          return;
        }
        if(e.data && e.data.indexOf && e.data.indexOf("OPENLINK|") === 0){
          var data = e.data.substring(("OPENLINK|").length);
          self.openWeblink({DataJSON:{URL:data}},null,'auto');
          return;
        }
      };

      $scope.refreshTextEditorUrl = function(){
        // refreshes the URL to the editor based on the current state

        var username = self.user.Name + " "+self.user.Surname;
        if(self.user.Teacher == 1)
          username = (self.user.Name.length > 0 ?  self.user.Name[0]+'. ' : '') + self.user.Surname;
        $scope.textEditorURL = "https://learningview.org/textedit/?id="+encodeURIComponent($scope.textedit.docID)+
                                 "&user="+encodeURIComponent(self.user.ID)+
                                 "&username="+encodeURIComponent(username)+
                                 "&title="+encodeURIComponent($scope.textedit.title)+
                                 ($scope.textedit.editable === false ? "&readOnly=1":"")+
                                 ($scope.textedit.annotateonly === true ? "&annotateOnly=1":"")+
                                 "&readOnlyDoc="+($scope.classCollaboration &&  
                                                  $scope.classCollaboration.DataJSON && 
                                                  $scope.classCollaboration.DataJSON.Editable &&
                                                  $scope.classCollaboration.teacherOnly != 1 ? '0':'1')+
                                 ($scope.classCollaboration && 
                                  $scope.classCollaboration.Code ? 
                                 "&code="+$scope.classCollaboration.Code:"");            
      };

     
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addAnnotationRecorderScope = function($scope){
      $scope.annotationHistory = [];
      $scope.myAnnotationData = null;
      $scope.myLastAnnotationData = null;
      $scope.feedbackData = null;
      $scope.lastSaveTime = null;


      $scope.postMessage = function(e){
        var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
        if(e.source && frame.contentWindow != e.source) return; // ignore other frames

        var debounceMessage = function(e,time){
          var currentStudent = $scope.student ? $scope.student.ID : self.user.ID;
          setTimeout(function(){
            if(currentStudent != ($scope.student ? $scope.student.ID : self.user.ID)) return; 
            $scope.postMessage(e); 
          },time);
        };

        if($scope.isReady){
          // loaded now, do not wait for close anymore
          if($scope.waitToLoadEditorTimeout) clearTimeout($scope.waitToLoadEditorTimeout);
          $scope.waitToLoadEditorTimeout = null;
          $scope.waitToLoadEditor = false;
        }
        if(e == "CLOSE"){
          if(!$scope.isReady){
            if(!$scope.waitToLoadEditor){
              if($scope.waitToLoadEditorTimeout) clearTimeout($scope.waitToLoadEditorTimeout);
              $scope.waitToLoadEditorTimeout = setTimeout(function(){
                // 10 sec timeout for loading the editor now
                // tell every running fetch script we can apply data even if we cant ;-)
                $scope.isReady = true;

                setTimeout(function(){
                  if($scope.requestCloseCallback){
                     var cc = $scope.requestCloseCallback;             
                     $scope.requestCloseCallback = null; 
                     cc();
                  }
                },500);
              },1000);              
            }
            $scope.waitToLoadEditor = true;
          }
          if($scope.fetchingImageAnnotationFeedbackData ||
             $scope.fetchingImageAnnotationData ||
             !frame || !$scope.isReady || $scope.isStateLoading) {
            // still loading annotation data, wait for complete
            debounceMessage(e,200);
            return; // wait for now
          }
          // request close of iframe and save last changes
          if(frame && $scope.isReady){
            frame.contentWindow.postMessage("CLOSE","*");
          }
        }
        if(e && e.data == "CLOSED"){
          // closed event send by iframe, now we can leave the page
          if($scope.requestCloseCallback){
             var cc = $scope.requestCloseCallback;             
             $scope.requestCloseCallback = null; 
             cc();
          }
        }

        if(e && e.data == "STATEJSONLOADED"){
          $scope.isStateLoading = false;
          $scope.isStateLoaded = true;
        }

        if(e == "GOTANNOTATIONDATA"){
          if($scope.requestCloseCallback) return;
          if($scope.fetchingImageAnnotationData) return; // ignore while loading
          if($scope.isReady){
            var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
            if($scope.isStateLoading || $scope.isStateLoaded) return; // we already posted one, maybe there is a hanging debounce event, discard it if we already loading

            if(frame){
              $scope.isStateLoading = true;
              $scope.isStateLoaded = false;
              $scope.annotationDataChangedAndSaved = false;
              frame.contentWindow.postMessage("STATEJSON|"+($scope.myAnnotationData ? $scope.myAnnotationData :'{}'),"*");
              $scope.lastStateApplied = true;
              $scope.lastSaveTime = new Date().getTime();
            }
          }else{ 
            debounceMessage(e,500);
          }
          return;
        }
        if(e == "GOTFEEDBACKDATA"){
          if($scope.requestCloseCallback) return;
          if($scope.fetchingImageAnnotationFeedbackData) return; // ignore while loading
          if($scope.isReady){
            var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
            if(frame){
              frame.contentWindow.postMessage("FIXED"+(self.user.Teacher == "1" ? "UNDER" : "OVER")+"JSON|"+($scope.feedbackData ? $scope.feedbackData :'{}'),"*");
            }
          }else{ 
            debounceMessage(e,500);
          }
          return;
        }
        if(e.data == "READY"){
          console.log("Loaded image editor");
          $scope.isReady = true;
          $scope.lastStateApplied = false;
          var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
          if(frame) frame.focus();
          return;
        }
        if(e.data == "REQUESTCLIPBOARD"){
          var hadText = false;
          readTextFromClipboard(function(result){
            hadText = true;
            var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
            if(frame){
              frame.contentWindow.postMessage("ADDTEXT|"+result,"*");
            }
          });
          $timeout(function(){
            if(hadText) return;
            readImageFromClipboard(function(blob){
              $timeout(function(){
                self.uploadFile(blob,$scope.it && $scope.it.Name ? $scope.it.Name : ($scope.task ? $scope.task.Name : "Image"), 
                                self.getMediaID(),'image',null,function(result){
                  var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
                  if(frame){
                    frame.contentWindow.postMessage("ADDIMAGE|"+result,"*");
                  }
                });
              },10);
            });
          },100);
        }

        if(e.data && e.data.indexOf && e.data.indexOf("UPLOADIMAGE|") === 0){
          // take picture and send back
          var dataURI = e.data.substring(("UPLOADIMAGE|").length);
          var byteString = atob(dataURI.split(',')[1]);
          var mimeString = dataURI.split(',')[0].split(':')[1].split(';')[0];
          var ab = new ArrayBuffer(byteString.length);
          var ia = new Uint8Array(ab);
          for (var i = 0; i < byteString.length; i++) {
              ia[i] = byteString.charCodeAt(i);
          }
          var blob = new Blob([ab], {type: mimeString});
          $timeout(function(){
            self.uploadFile(blob,$scope.it && $scope.it.Name ? $scope.it.Name : ($scope.task ? $scope.task.Name : "Image"), 
                            self.getMediaID(),'image',null,function(result){
              var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
              if(frame){
                frame.contentWindow.postMessage("ADDIMAGE|"+result,"*");
              }
            });
          },10);
        }

        $scope.putIntoEditorIframe = function(results) {
          var frame = $('.imageeditoriframe',$scope.dialogElement).get(0);
          if(frame){
            frame.contentWindow.postMessage("ADD"+results[0].Type.toUpperCase()+"|"+results[0].URL,"*");
          }
        }

        if(e.data == "REQUESTIMAGE"){
          // take picture and send back
          $timeout(function(){
            self.takeUserMedia("image",null,$scope.putIntoEditorIframe, {dialogMode: 0});
          },10);
        }
        if(e.data && e.data.indexOf && e.data.indexOf("PRINT|") === 0){
          // print now
          var data = e.data.substring(("PRINT|").length);
          // image as datauri or blob
          self.printImage(data);
        }
        if(e.data == "REQUESTAUDIO"){
          // record audio and send back
          $timeout(function(){
            self.takeUserMedia("audio",null,$scope.putIntoEditorIframe, {dialogMode: 0});
          },10);
        }
        if(e.data == "REQUESTWEBLINK"){
          // record weblink and send back
          $timeout(function(){
            self.takeUserMedia("link",null,$scope.putIntoEditorIframe, {dialogMode: 1});
          },10);
        }
        if(e.data && e.data.indexOf && e.data.indexOf("DOWNLOADFILE|") === 0){
          var data = e.data.substring(("DOWNLOADFILE|").length);
          var m = $scope.annotationURL.toString().match(/.*\/(.+?)\./);
          if($scope.currentAnnotationHistory){
            m[1] += "_"+$scope.currentAnnotationHistory.Created.replace(/ /g,"_");
          }
          self.downloadFile(data,m && m.length > 1 ? (m[1].indexOf(".png") > 0 ? m[1] : m[1]+".png") : 'download.png');
          return;
        }
        if(e.data && e.data.indexOf && e.data.indexOf("OPENLINK|") === 0){
          var data = e.data.substring(("OPENLINK|").length);
          self.openWeblink({DataJSON:{URL:data}},null,'auto');
          return;
        }
        if(e.data == "ROTATELEFT"){
          // save now
          var now = new Date().getTime();
          if($scope.myAnnotationData != $scope.myLastAnnotationData){
            $scope.updateAnnotationData();
            $scope.lastSaveTime = now;
          }

          if($scope.imageURLOrg && $scope.imageURLOrg != "")
            self.rotateImage($scope.imageURLOrg,90).then(function(){
              $scope.setImage($scope.imageURLOrg,true);
            });
        }
        if(e.data == "ROTATERIGHT"){
          // save now
          var now = new Date().getTime();
          if($scope.myAnnotationData != $scope.myLastAnnotationData){
            $scope.updateAnnotationData();
            $scope.lastSaveTime = now;
          }

          if($scope.imageURLOrg && $scope.imageURLOrg != "")
            self.rotateImage($scope.imageURLOrg,-90).then(function(){
              $scope.setImage($scope.imageURLOrg,true);
            });
        }
        if(e.data && e.data.indexOf && e.data.indexOf("STATEJSON|") === 0){
          // do not apply while reloading
          if($scope.fetchingImageAnnotationFeedbackData ||
             $scope.fetchingImageAnnotationData ||
             $scope.isStateLoading) return; // discard this data if we still load data

          var data = e.data.substring(("STATEJSON|").length);
          $scope.myAnnotationData = data;
          if($scope.annotationLoadError){
            $scope.myLastAnnotationData = $scope.myAnnotationData;
            $scope.annotationLoadError = false;
          }

          var now = new Date().getTime();
          if(((now > $scope.lastSaveTime + 1000*60) || 
              ($scope.requestCloseCallback && $scope.lastStateApplied)) &&
             $scope.myAnnotationData != $scope.myLastAnnotationData){
            $scope.updateAnnotationData();
            $scope.lastSaveTime = now;
            $scope.lastStateApplied = true;
          }
          return;
        }
      };
      $scope.hasChangedAnnotationData = function(){
        if($scope.canEdit === false) return false;
        // empty image yet
        if($scope.myLastAnnotationData == null && 
           $scope.myAnnotationData == '{"version":"4.0.0-beta.11","objects":[]}') return false;
        return ($scope.myLastAnnotationData != $scope.myAnnotationData);
      };
      $scope.updateAnnotationData = function(){
        if(!$scope.isReady) return false; // editor not yet ready, so no change now
        if($scope.isStateLoading) return false;
        if($scope.hasChangedAnnotationData() == false) return false; // unchanged
        if(self.user.Teacher == "1"){
          // teacher feedback annotations
          if(self.hasClassReviewPermission(self.currentClass)){
            if($scope.student && $scope.student.ID != self.user.ID){
              // deal with $scope.students if exists and set for all students 
              if($scope.students){
                for(var i=0; i < $scope.students.length; i++){
                  if($scope.students[i] != '' && $scope.students[i] != $scope.student.ID){
                    // also set for this student
                    self.updateImageAnnotationFeedbackData({ID:$scope.students[i]},$scope.annotationURL,
                         $scope.myAnnotationData,$scope.imgWidth,$scope.imgHeight);
                  }
                }
              } 
              self.updateImageAnnotationFeedbackData($scope.student,$scope.annotationURL,
                   $scope.myAnnotationData,$scope.imgWidth,$scope.imgHeight);
            }          
            $scope.annotationDataChangedAndSaved = true;
          }
          return true;
        }else{
          if($scope.student && $scope.student.ID != self.user.ID){
            // peer feedback annotations

          }else{
            // own annotations
            var taskid = ($scope.it && $scope.it.TaskID ? $scope.it.TaskID:0);
            if(!taskid && $scope.taskStatus && $scope.taskStatus.TaskID) taskid = $scope.taskStatus.TaskID;
            // only apply for me, group works will update on userTaskStatus
            $scope.waitForAnnotationSave = true;
            self.updateImageAnnotationData(self.user, $scope.annotationURL, taskid, $scope.myAnnotationData,$scope.imgWidth,$scope.imgHeight).then(function(){
              // completed save
              $scope.waitForAnnotationSave = false;
              $scope.myLastAnnotationData = $scope.myAnnotationData; // update last now so we don't save again
            });
            $scope.annotationDataChangedAndSaved = true;
            return true;
          }
        }
        return false;
      };

      $scope.requestClose = function(callback){
        if($scope.requestCloseCallback) return; // skip now, a request is still pending
        if($scope.fetchingImageAnnotationData) return; // skip now, a request is still pending
        if($scope.fetchingImageAnnotationFeedbackData) return; // skip now, a request is still pending
        $scope.requestCloseCallback = function(){
          var waitingForSave = false;
          var waitForSaveDone = null;
          var waitForSave = function(){
            if($scope.waitForAnnotationSave){
              if(!waitingForSave){
                waitingForSave = true;
                self.showLoadingIndicator(null,function(done){
                  waitForSaveDone = done;
                });
              }
              setTimeout(waitForSave,100);
              return;
            }
            if(waitForSaveDone) waitForSaveDone();
            callback();
          }
          waitForSave();
        };
        $scope.currentAnnotationHistory = null;
        $scope.postMessage("CLOSE");
      };

      $scope.loadAnnotationHistory = function(historyItem){
        $scope.requestClose(function(){
          if(self.user.Teacher == "1"){
            if($scope.fetchingImageAnnotationFeedbackData) return; // already loading
            $scope.fetchingImageAnnotationFeedbackData = true;
          }else{
            if($scope.fetchingImageAnnotationData) return; // already loading
            $scope.fetchingImageAnnotationData = true;
          }
          var currentStudent = $scope.student ? $scope.student.ID : self.user.ID;
          $scope.isStateLoaded = false;
          self.getImageAnnotationData($scope.student ? $scope.student : self.user,$scope.annotationURL,($scope.it && $scope.it.TaskID ? $scope.it.TaskID:0),historyItem.ID).then(function(r){
            if(currentStudent != ($scope.student ? $scope.student.ID : self.user.ID)) return;
            $scope.currentAnnotationHistory = historyItem;
            if(self.user.Teacher == "1"){
              if(r && r.JSON)
                $scope.feedbackData = r.JSON; else
                $scope.feedbackData = "{}";
              $scope.fetchingImageAnnotationFeedbackData = false; 
              $scope.postMessage("GOTFEEDBACKDATA");
            }else{
              if(r && r.JSON){
                $scope.myAnnotationData = r.JSON;
                $scope.myLastAnnotationData = r.JSON;
              }else{
                $scope.myAnnotationData = "{}";
                $scope.myLastAnnotationData = "{}";
              }
              $scope.fetchingImageAnnotationData = false; 
              $scope.postMessage("GOTANNOTATIONDATA");
            }
          });
        });
      };

      $scope.loadAnnotationData = function(){
        var taskid = ($scope.it && $scope.it.TaskID ? $scope.it.TaskID:( $scope.t ? $scope.t.ID : 0));

        if(self.user.Teacher == 1){
          // reset first
          $scope.myAnnotationData = null;
          $scope.myLastAnnotationData = null;
          $scope.myLastAnnotationDataLoaded = null;
          $scope.annotationLoadError = false;
          $scope.isStateLoaded = false;

          $scope.fetchingImageAnnotationData = true; 
          var currentStudent = $scope.student.ID;
          self.getImageAnnotationFeedbackData($scope.student,$scope.annotationURL,taskid).then(function(r){
            if(currentStudent != $scope.student.ID) return;
            if(r && r.JSON === ""){
              self.alert("Achtung: Aufgrund eines technischen Problems konnten die bisherigen Daten nicht geladen werden. Bitte versuche es später noch einmal.");
              $scope.annotationLoadError = true;
              $scope.fetchingImageAnnotationData = false;
            }
            if(r && r.JSON){
              $scope.myAnnotationData = r.JSON;
              $scope.myLastAnnotationData = r.JSON;
              $scope.myLastAnnotationDataLoaded = r.JSON; // keep this until close
            }
            $scope.fetchingImageAnnotationData = false;
            $scope.postMessage("GOTANNOTATIONDATA");
          });
          $scope.fetchingImageAnnotationFeedbackData = true; 
          self.getImageAnnotationData($scope.student,$scope.annotationURL,taskid).then(function(r){
            if(currentStudent != $scope.student.ID) return;
            if(r && r.JSON === ""){
              self.alert("Achtung: Aufgrund eines technischen Problems konnten die bisherigen Daten nicht geladen werden. Bitte versuche es später noch einmal.");
              $scope.annotationLoadError = true;
              $scope.fetchingImageAnnotationFeedbackData = false;
            }
            $scope.feedbackData = "{}";
            if(r && r.JSON && !(r.JSON === '' || r.JSON === "{}")){
              $scope.feedbackData = r.JSON;
              $scope.fetchingImageAnnotationFeedbackData = false;
              $scope.postMessage("GOTFEEDBACKDATA");
            }else{
              // try to load default annotation for task if exists
              if($scope.t){
                self.getTaskImageAnnotationData(taskid,$scope.annotationURL).then(function(r){
                  if(currentStudent != $scope.student.ID) return;
                  if(r && r.JSON){
                    $scope.feedbackData = r.JSON;
                  }
                  $scope.fetchingImageAnnotationFeedbackData = false;
                  $scope.postMessage("GOTFEEDBACKDATA");
                });
              } else {
                $scope.fetchingImageAnnotationFeedbackData = false;
                $scope.postMessage("GOTFEEDBACKDATA");
              }                    
            }            
          });
        }else{
          // reset first
          $scope.myAnnotationData = null;
          $scope.annotationLoadError = false;
          $scope.myLastAnnotationData = null;
          $scope.myLastAnnotationDataLoaded = null;
          $scope.isStateLoaded = false;

          $scope.fetchingImageAnnotationData = true; 
          var currentStudent = $scope.student ? $scope.student.ID : self.user.ID;
          self.getImageAnnotationData($scope.student ? $scope.student : self.user,$scope.annotationURL,taskid).then(function(r){
            if(currentStudent != ($scope.student ? $scope.student.ID : self.user.ID)) return;
            if(r && r.JSON === ""){
              self.alert("Achtung: Aufgrund eines technischen Problems konnten die bisherigen Daten nicht geladen werden. Bitte versuche es später noch einmal.");
              $scope.annotationLoadError = true;
              $scope.fetchingImageAnnotationData = false;
            }
            if(r && r.JSON && !(r.JSON === '' || r.JSON === "{}")){
              // if not empty
              $scope.myAnnotationData = r.JSON;
              $scope.myLastAnnotationData = r.JSON;
              $scope.myLastAnnotationDataLoaded = r.JSON; // keep this until close
              $scope.fetchingImageAnnotationData = false;
              $scope.postMessage("GOTANNOTATIONDATA");
            }else{
              // if empty try to load default annotation for task if exists
              if($scope.t){
                self.getTaskImageAnnotationData(taskid,$scope.annotationURL).then(function(r){
                  if(currentStudent != ($scope.student ? $scope.student.ID : self.user.ID)) return;
                  if(r && r.JSON){
                    $scope.myAnnotationData = r.JSON;
                    $scope.myLastAnnotationData = r.JSON;
                    $scope.myLastAnnotationDataLoaded = r.JSON; // keep this until close
                  }
                  $scope.fetchingImageAnnotationData = false;
                  $scope.postMessage("GOTANNOTATIONDATA");
                });
              } else {
                $scope.fetchingImageAnnotationData = false;
                $scope.postMessage("GOTANNOTATIONDATA");
              }
            }
          });
          $scope.fetchingImageAnnotationFeedbackData = true; 
          self.getImageAnnotationFeedbackData($scope.student ? $scope.student : self.user,$scope.annotationURL,taskid).then(function(r){
            if(currentStudent != ($scope.student ? $scope.student.ID : self.user.ID)) return;
            if(r && r.JSON === ""){
              self.alert("Achtung: Aufgrund eines technischen Problems konnten die bisherigen Daten nicht geladen werden. Bitte versuche es später noch einmal.");
              $scope.annotationLoadError = true;
              $scope.fetchingImageAnnotationFeedbackData = false; 
            }
            if(r && r.JSON){ 
              $scope.feedbackData = r.JSON; 
            }
            $scope.fetchingImageAnnotationFeedbackData = false; 
            $scope.postMessage("GOTFEEDBACKDATA");
          });
        }
      };
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasMediaNotesInAnswer = function(answer){
      if(!answer || answer === '') return false;
      var a = JSON.parse(answer);
      if(a.length == 0) return false;
      if(a.length > 1) return true;
      if(a[0].pos) return false;
      return true;
    }

    self.showMediaNotesEditor = function(url, task, currentNotes, noPredefined, noEdit, onlyEditPredefined, noPlayTimestamp, ev){
      var deferred = $q.defer();
      self.currentMediaNotesEditor = null;
      self.showDialog({
        templateUrl: "medianoteseditor.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        targetEvent : ev ? ev : null,
        onRemoving: function (event, removePromise) {
          self.currentMediaNotesEditor = null;
        },
        controller: function ($scope, $mdDialog) {
          $scope.bindWavesurfer = true; // will be filled with scope
          $scope.bindVideplayer = true;
          $scope.self = self;
          $scope.URL = url;
          $scope.t = task;
          $scope.noEdit = noEdit;
          $scope.noPredefined = noPredefined;
          $scope.onlyEditPredefined = onlyEditPredefined == 1;
          $scope.pos = 0;
          $scope.newDescription = task.DataJSON.mediaDescription ? task.DataJSON.mediaDescription : '';
          $scope.taskStatus = self.getUserTaskStatus(task,$scope.student ? $scope.student : self.user);
          $scope.taskDescriptionWidth = self.getTaskDescriptionWidth(task,'(max-width: 1270px)',self.sidePanelRight);

          $scope.notes = [];          
          $scope.edit = null;

          self.currentMediaNotesEditor = $scope;

          if(currentNotes) 
            for(var i = 0; i < currentNotes.length; i++){
              if(currentNotes[i].pos || currentNotes[i].pos === 0) {
                $scope.pos = parseInt(currentNotes[i].pos);
                $timeout(function(){
                  $scope.seekNote({t:$scope.pos}, true);
                },100);
                continue; // do not add this note  
              }
              $scope.notes.push(JSON.parse(angular.toJson(currentNotes[i])));
            }

          if(!noPredefined && task.ResultType == 'audionotes' && task.DataJSON.audioNotes){
            for(var i = 0; i < task.DataJSON.audioNotes.length; i++){
              var n = JSON.parse(angular.toJson(task.DataJSON.audioNotes[i]));
              n.from = n.id;
              n.predefined = true;
              n.preText = n.text;
              var maxID = 0;
              var washere = false;
              for(var z=0; z < $scope.notes.length; z++){
                if($scope.notes[z].from == n.id) {
                  washere = true;
                  $scope.notes[z].preText = n.text;
                }
                maxID = Math.max($scope.notes[z].id,maxID);
              }
              n.id = maxID+1;
              if(!washere)
                $scope.notes.push(n);
            }
          }
          if(!noPredefined && task.ResultType == 'videonotes' && task.DataJSON.videoNotes){
            for(var i = 0; i < task.DataJSON.videoNotes.length; i++){
              var n = JSON.parse(angular.toJson(task.DataJSON.videoNotes[i]));
              n.from = n.id;
              n.predefined = true;
              n.preText = n.text;
              var maxID = 0;
              var washere = false;
              for(var z=0; z < $scope.notes.length; z++){
                if($scope.notes[z].from == n.id) {
                  washere = true;
                  $scope.notes[z].preText = n.text;
                }
                maxID = Math.max($scope.notes[z].id,maxID);
              }
              n.id = maxID+1;
              if(!washere)
                $scope.notes.push(n);
            }
          }

          // sort now
          $scope.notes.sort(function(a,b){
            return a.t < b.t ? -1 : (a.t > b.t ? 1 : (a.ID < b.ID ? -1 : 1));
          })

          $scope.hasChangedAnnotationData = function(){
            var desc = self.trimHTML($scope.newDescription ? $scope.newDescription : '');
            if(desc != task.DataJSON.mediaDescription && !(!desc && !task.DataJSON.mediaDescription)) return true;
            var now = [];
            for(var i=0; i < $scope.notes.length; i++){
              if($scope.notes[i].predefined) continue;
              if(!$scope.notes[i].text && !$scope.notes[i].pos) $scope.notes[i].text = '';
              var c = JSON.parse(angular.toJson($scope.notes[i]));
              delete(c.preText); // remove temp here
              now.push(c);
            }
            var time = $scope.getCurrentTime(true);
            if(!noPlayTimestamp && (time > 0 || (currentNotes && currentNotes.length > 0)))
              now.push({pos:time});
            if(!currentNotes && now.length > 0) return true;
            return angular.toJson(currentNotes) != angular.toJson(now);
          };

          $scope.getCurrentTime = function(inSeconds){
            var time = 0;
            if(task.ResultType == 'audionotes'){              
              time = $scope.wavesurfer.getTime(); // read time from player
            }
            if(task.ResultType == 'videonotes'){
              time = $scope.videoplayer.getTime();
            }
            return inSeconds ? parseInt(time) : secToMMSS(parseFloat(time));
          };

          $scope.editNote = function(n){
            $scope.edit = n;
          };
          $scope.changeNote = function(n){
            if(task.ResultType == 'audionotes'){              
              self.track('AN_changenote',{text:n.text,time:n.time, seconds:n.t, url:url});
            }
            if(task.ResultType == 'videonotes'){
              self.track('VN_changenote',{text:n.text,time:n.time, seconds:n.t, url:url});
            }
          }
          $scope.seekNote = function(n,noplay){
            // seek to n.time
            if(task.ResultType == 'audionotes'){              
              $scope.wavesurfer.seekTo(n.t,noplay);
            }
            if(task.ResultType == 'videonotes'){
              $scope.videoplayer.seekTo(n.t,noplay);
            }
          };

          $scope.createNote = function(){
            var time = 0;
            if(task.ResultType == 'audionotes'){              
              time = $scope.wavesurfer.getTime(); // read time from player
              if($scope.wavesurfer.playing) $scope.wavesurfer.playpause();
              self.track('AN_addnote',{text:"",time:secToMMSS(parseFloat(time)), seconds:time, url:url});
            }
            if(task.ResultType == 'videonotes'){
              time = $scope.videoplayer.getTime();
              if($scope.videoplayer.playing) $scope.videoplayer.playpause();
              self.track('VN_addnote',{text:"",time:secToMMSS(parseFloat(time)), seconds:time, url:url});
            }

            var maxID = 0;
            for(var i=0; i < $scope.notes.length; i++){
              //if($scope.notes[i].predefined) continue;
              if(typeof $scope.notes[i].id == "undefined") continue;
              maxID = Math.max($scope.notes[i].id,maxID);
            }
            var n = {id:maxID+1, t:time, text:"", time:secToMMSS(parseFloat(time))};
            $scope.notes.push(n);
            // always sort by time and id

            $scope.notes.sort(function(a,b){
              return a.t < b.t ? -1 : (a.t > b.t ? 1 : (a.ID < b.ID ? -1 : 1));
            })
            $scope.editNote(n);
          };

          $scope.deleteNote = function(n,ev){
            self.confirm($filter('trans')('ASKDELETENOTE'),$filter('trans')('DELETE'),ev).then(function(){
              for(var i=0; i < $scope.notes.length; i++)
                if($scope.notes[i] == n){
                  if(task.ResultType == 'audionotes'){        
                    self.track('AN_deletenote',{text:n.text,time:n.time, seconds:n.t, url:url});
                  }      
                  if(task.ResultType == 'videonotes'){
                    self.track('VN_deletenote',{text:n.text,time:n.time, seconds:n.t, url:url});
                  }
                  if(n.from){
                    n.text = n.preText;
                    n.predefined = true;
                  }else{
                    $scope.notes.splice(i,1);
                  }
                  return;
                }
            });
          };

          $scope.ok = function() {
            for(var i=0; i < $scope.notes.length; i++){
              delete($scope.notes[i].preText); // remove temp here
              if($scope.notes[i].predefined){
                $scope.notes.splice(i,1);
                i--;
                continue;
              }
              if(!$scope.notes[i].text) $scope.notes[i].text = '';
            }
            // add position now
            if(!noPlayTimestamp)
              $scope.notes.push({pos:$scope.getCurrentTime(true)});

            self.closeDialog($scope.dialogElement);
            deferred.resolve({notes:JSON.parse(angular.toJson($scope.notes)), description:self.trimHTML($scope.newDescription ? $scope.newDescription : '')});
          };
        }
      });              
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showTaskAudioNotesEditor = function(url, task, ev){
      if(!task.DataJSON.audioNotes) task.DataJSON.audioNotes = [];
      self.showMediaNotesEditor(url,task,task.DataJSON.audioNotes,true,false,false,true,ev).then(function(result){
        task.DataJSON.audioNotes = result.notes;
        if(result.description){
          task.DataJSON.mediaDescription = result.description;
        }else{
          if(task.DataJSON.mediaDescription) delete(task.DataJSON.mediaDescription);
        }
      });
    };
    self.showTaskVideoNotesEditor = function(url, task, ev){
      if(!task.DataJSON.videoNotes) task.DataJSON.videoNotes = [];
      self.showMediaNotesEditor(url,task,task.DataJSON.videoNotes,true,false,false,true,ev).then(function(result){
        task.DataJSON.videoNotes = result.notes;
        if(result.description){
          task.DataJSON.mediaDescription = result.description;
        }else{
          if(task.DataJSON.mediaDescription) delete(task.DataJSON.mediaDescription);
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showTaskAnnotationImageEditor = function(url, task, ev){
      // edit the default annotation for this image all students will see when start editing the image
      // on task Reset we also reset the user annotation and start from here again
      var deferred = $q.defer();
      var postMessage = null;
      if(!task || !task.ID){
        self.alert("Bitte die Aufgabe zunächst speichern, bevor die Bildvorlage zur Aufgabe bearbeitet werden kann.");
        return;
      }
      self.showDialog({
        state:"modal",
        templateUrl: "imageeditoriframe.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        targetEvent : ev ? ev : null,
        onRemoving: function (event, removePromise) {
          if(postMessage)
            window.removeEventListener("message",postMessage);
          postMessage = null;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.student = self.user;
          $scope.text = task.Name;
          $scope.annotationURL = url;
          $scope.imageURLOrg = url;

          $scope.t = task;

          $scope.taskDescriptionWidth = self.getTaskDescriptionWidth(task,'(max-width: 1270px)',self.sidePanelRight);
          // will use $scope.annotationURL
          self.addAnnotationRecorderScope($scope);

          postMessage = $scope.postMessage; // for remove of handler on close dialog
          window.addEventListener("message",postMessage);

          $scope.rotateImageRefresh = 0;
          $scope.lastURL = "";

          $scope.setImage = function(url,forcerefresh){
            if(forcerefresh) {
              $scope.lastURL = null;
              $scope.rotateImageRefresh++;
            }

            if($scope.lastURL != url) $scope.isReady = false;
            $scope.lastURL = url;
            $scope.myAnnotationData = null;
            $scope.myLastAnnotationData = null;
            $scope.myLastAnnotationDataLoaded = null;
            $scope.feedbackData = null;
            $scope.annotationHistory = [];

            $scope.imageURL = url && url != "" ? url+"?r="+Math.random() : "";
            $scope.imageURLOrg = url && url != "" ? url : "";
            var image = new Image();
            image.src = $scope.imageURL;
            image.crossOrigin = "Anonymous";
            image.onload = function(){
              $scope.imgWidth = image.width;
              $scope.imgHeight = image.height;
            };

            // load TaskAnnotation not personal user annotation
            self.getTaskImageAnnotationData(task.ID,$scope.annotationURL).then(function(r){
              if(r && r.JSON === ""){
                self.alert("Achtung: Aufgrund eines technischen Problems konnten die bisherigen Daten nicht geladen werden. Bitte versuche es später noch einmal.");                  
              }
              if(r && r.JSON){
                $scope.myAnnotationData = r.JSON;
                $scope.myLastAnnotationData = r.JSON;
                $scope.myLastAnnotationDataLoaded = r.JSON; // keep this until close
              }
              $scope.postMessage("GOTANNOTATIONDATA");
            });

            $scope.url = ("https://learningview.org/imageeditor/?showlocks=1&noedit=0&waitfordata=1&imagebutton=1&rotatebuttons=1&printbutton=1&audiobutton=1&weblinkbutton=1&image="+encodeURIComponent($scope.imageURL)+(forcerefresh ? '&r='+$scope.rotateImageRefresh:''));
          };

          $scope.setImage($scope.imageURLOrg);

          $scope.ok = function() {
            $scope.requestClose(function(){

              // Save task annotation not user annotation here

              if($scope.hasChangedAnnotationData() == true){
                self.updateTaskImageAnnotationData(task.ID,$scope.annotationURL,$scope.myAnnotationData,$scope.imgWidth,$scope.imgHeight);
              }

              self.closeDialog($scope.dialogElement);
              deferred.resolve({'json':$scope.myAnnotationData,
                                'lastJson':$scope.myLastAnnotationDataLoaded});
            });
          };
        }
      });
      return deferred.promise;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showImageEditor = function(url,text, noedit, task, student, ev){
      var deferred = $q.defer();
      var postMessage = null;

      self.showDialog({
        state:"modal",
        templateUrl: "imageeditoriframe.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        targetEvent : ev ? ev : null,
        onRemoving: function (event, removePromise) {
          if(postMessage)
            window.removeEventListener("message",postMessage);
          postMessage = null;
          self.track('IE_closed',task);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.student = student ? student : self.user;
          $scope.text = text;
          $scope.annotationURL = url;
          $scope.imageURLOrg = url;
          $scope.url = null;

          if(task){
            $scope.t = task;
            $scope.taskStatus = self.getUserTaskStatus(task,$scope.student);
            var partners = self.getUserTaskStatusColleagues(task,$scope.student);
            $scope.students = partners.split(",").map(Number);
          }
          if($scope.taskStatus && $scope.taskStatus.ColleaguesIDs && $scope.taskStatus.ColleaguesIDs != ''){
            $scope.students = $scope.taskStatus.ColleaguesIDs.split(",").map(Number);
          }

          $scope.taskDescriptionWidth = self.getTaskDescriptionWidth(task,'(max-width: 1270px)',self.sidePanelRight);
          // will use $scope.annotationURL
          self.addAnnotationRecorderScope($scope);

          postMessage = $scope.postMessage; // for remove of handler on close dialog
          window.addEventListener("message",postMessage);

          $scope.rotateImageRefresh = 0;
          $scope.lastURL = "";

          $scope.setImage = function(url,forcerefresh){
            var updateNow = function(){
              if(forcerefresh) {
                $scope.lastURL = null;
                $scope.rotateImageRefresh++;
              }

              if($scope.lastURL != url) $scope.isReady = false;
              $scope.lastURL = url;
              $scope.myAnnotationData = null;
              $scope.myLastAnnotationData = null;
              $scope.myLastAnnotationDataLoaded = null;
              $scope.feedbackData = null;
              $scope.annotationHistory = [];

              $scope.imageURL = url && url != "" ? url+"?r="+Math.random() : "";
              $scope.imageURLOrg = url && url != "" ? url : "";
              var image = new Image();
              image.crossOrigin = "Anonymous";
              image.onload = function(){
                $scope.imgWidth = image.width;
                $scope.imgHeight = image.height;
              };
              image.src = $scope.imageURLOrg;

              var rotateBtns = !noedit;
              if($scope.t){
                if($scope.t.ResultType == "annotation" || $scope.t.ResultType == "drawing") rotateBtns = false;
              }
              if(self.user.Teacher == 0 && $scope.student &&
                 $scope.student.ID != self.user.ID) rotateBtns = false;

              if(!noedit)
                self.getImageAnnotationHistoryData($scope.student ? $scope.student : self.user,$scope.annotationURL,($scope.it && $scope.it.TaskID ? $scope.it.TaskID:0)).then(function(r){
                  if(r && r.length > 1){
                    $scope.annotationHistory = r;
                  }
                });
              $scope.loadAnnotationData();
              $scope.canEdit = !noedit;
              $scope.url = ("https://learningview.org/imageeditor/?noedit="+(noedit ? 1:0)+"&waitfordata=1&imagebutton=1&rotatebuttons="+(rotateBtns ? "1":"0")+"&printbutton=1&audiobutton=1&weblinkbutton=1&image="+encodeURIComponent($scope.imageURL)+(forcerefresh ? '&r='+$scope.rotateImageRefresh:''));              
            }
            if($scope.url)
              $scope.requestClose(function(){
                updateNow();
              }); 
            else updateNow();
          };

          $scope.setImage($scope.imageURLOrg);

          $scope.ok = function() {
            $scope.requestClose(function(){
              if(!noedit && $scope.updateAnnotationData) $scope.updateAnnotationData();
              self.closeDialog($scope.dialogElement);
              deferred.resolve({'json':$scope.myAnnotationData,
                                'lastJson':$scope.myLastAnnotationDataLoaded,
                                'feedback':$scope.feedbackData});
            });
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.printElement = function(id){
      // experimental 
      var styles = document.getElementsByTagName("style");
      var css = ["https://learningview.org/app/main.css"];
      for (var i= 0; i < styles.length; i++) {
          var url = styles[i].getAttribute("data-href");
          if(url) css.push(url);
      }
      loadScript("https://cdnjs.cloudflare.com/ajax/libs/print-js/1.6.0/print.js",function(){
        printJS({printable:id, 
                 type:'html', 
                 css:css,scanStyles: false});
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    
    self.printImage = function(url){
      var url = String(url || "").replace(/&nbsp;/g, " ").trim();
      if (!/^(https?:\/\/|data:)/i.test(url)) url = "";
      if(url == "") return;
      var img = new Image();
      img.onload = function() {
        var htmlPage = '<!DOCTYPE html><html style="background:white !important;height:auto;"><head><meta name="viewport" content="width=device-width, initial-scale=1.0"></head><body style="background:white !important;display:flex;justify-content:center;align-items:center;min-height:99vh;"><img src="'+url+'" width="'+img.naturalWidth+'" height="'+img.naturalHeight+'" style="object-fit:contain;max-width:99vw;max-height:99vh;display:block;object-fit:contain;"></body></html>';
        self.printHTMLDialog(htmlPage);
      };
      img.src = url;
    };

    self.printHTML = function(html){
      var sanitizePrintableHTML = function(input){
        var value = String(input || "");
        if(window.DOMPurify){
          return DOMPurify.sanitize(value,{
            USE_PROFILES: {html: true},
            FORBID_TAGS: ['script','noscript','iframe','object','embed','base','meta','form','input','button','textarea','select'],
            ALLOW_DATA_ATTR: false,
            ALLOWED_URI_REGEXP: /^(?:(?:https?|blob):|data:image\/(?:png|gif|jpe?g|webp);base64,|[^a-z]|[a-z+.\-]+(?:[^a-z+.\-:]|$))/i
          });
        }
        // Fail-closed fallback if DOMPurify is unavailable: print as plain text.
        var escaped = $('<div></div>').text(value).html();
        return escaped.replace(/\r?\n/g,"<br>");
      };

      var safeHTML = sanitizePrintableHTML(html);
      var htmlPage = '<!DOCTYPE html><html style="background:white !important;"><head><meta name="viewport" content="width=device-width, initial-scale=1.0"><link rel="stylesheet" href="https://learningview.org/app/main.css"/></head><body style="background:white !important;overflow:auto !important;height:auto !important"><div style="max-width: 760px;margin:auto" class="HTMLcontent">'+safeHTML+'</div></body></html>';
      self.printHTMLDialog(htmlPage);
    };

    self.printHTMLDialog = function(htmlPage){
      if(typeof cordova != "undefined"){
        if(cordova.plugins && cordova.plugins.printer){
          cordova.plugins.printer.print(htmlPage,{name:"LearningView"},function(){
            // callback
          });
        }else{
          self.alert("Bitte aktualisiere deine Android / iOS App, um diese Funktion zu nutzen.");
        }
      }else{
        var proxyIframe = document.createElement('iframe');
        var body = document.getElementsByTagName('body')[0];
        body.appendChild(proxyIframe);
        proxyIframe.style.width = '100%';
        proxyIframe.style.height = '100%';
        proxyIframe.style.position = 'absolute';
        proxyIframe.style.left = '0px';
        proxyIframe.style.top = '0px';
        proxyIframe.style.zIndex = '1000';
        proxyIframe.style.background = 'white';
        proxyIframe.allowModal = true;

        var contentWindow = proxyIframe.contentWindow;
        var cleanedUp = false;
        var afterPrintHandler = null;
        var cleanup = function(){
          if(cleanedUp) return;
          cleanedUp = true;
          if(contentWindow){
            try{
              if(afterPrintHandler){
                contentWindow.removeEventListener("afterprint",afterPrintHandler);
              }
            }catch(e){}
          }
          $(proxyIframe).remove();
        };
        var printFallbackTimeout = setTimeout(cleanup,20000);
        proxyIframe.onload = function(){
          try{
            if(contentWindow){
              afterPrintHandler = function(){
                clearTimeout(printFallbackTimeout);
                cleanup();
              };
              contentWindow.addEventListener("afterprint",afterPrintHandler);
              setTimeout(function(){
                contentWindow.focus();
                contentWindow.print();                
              },100);
              return;
            }
          }catch(e){}
          clearTimeout(printFallbackTimeout);
          cleanup();
        };
        contentWindow.document.open();
        contentWindow.document.write(htmlPage);
        contentWindow.document.close();
      } 
    }
