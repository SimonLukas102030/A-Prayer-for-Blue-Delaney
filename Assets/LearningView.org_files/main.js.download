    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getiOSLibraryPermission = function(){
      if(typeof cordova != "undefined"){
        if(cordova.plugins && cordova.plugins.diagnostic){
          if(window.isIOSDevice){
            cordova.plugins.diagnostic.getCameraRollAuthorizationStatus(function(status){
                switch(status){
                    case cordova.plugins.diagnostic.permissionStatus.NOT_REQUESTED:
                        console.log("Permission not requested");
                        cordova.plugins.diagnostic.requestCameraRollAuthorization(function(){
                          console.log("Got Permission for Library.");
                        }, function(){
                          console.log("Got no Permission for Library.");
                        });
                        break;
                    case cordova.plugins.diagnostic.permissionStatus.DENIED_ALWAYS:
                        console.log("Library Permission denied");
                        break;
                    case cordova.plugins.diagnostic.permissionStatus.GRANTED:
                        console.log("Library Permission granted");
                        break;
                }
            }, function(error){
                console.error("Library Permission error occurred: "+error);
            });
          }
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////    
    self.requestMobileCameraPermissions = function(callback){
      if(window.androidVersion && window.cordova && cordova.plugins && cordova.plugins.permissions){
        // request permissions
        var permissions = cordova.plugins.permissions;
        var list = [
          permissions.CAMERA,
          permissions.READ_EXTERNAL_STORAGE,
          permissions.WRITE_EXTERNAL_STORAGE
        ];
        if(window.androidVersion >= 13)
          list = [
            permissions.CAMERA
//            permissions.READ_MEDIA_IMAGES,
//            permissions.READ_MEDIA_VIDEO
          ];

        permissions.checkPermission(list, function(status){
          if( !status.hasPermission ) {            
            permissions.requestPermissions(
              list,
              function(status) {
                if(status.hasPermission ) {
                  callback();
                }else{
                  self.alert($filter('trans')('NOCAMERAPERMISSION'));
                }
              }, function(){
                self.alert($filter('trans')('NOCAMERAPERMISSION'));
              });
          } else callback();      
        }, function(){
          self.alert($filter('trans')('NOCAMERAPERMISSION'));
        });
      }else if(window.cordova && cordova.plugins && cordova.plugins.diagnostic){
        cordova.plugins.diagnostic.getCameraAuthorizationStatus(function(status){
          if(status == cordova.plugins.diagnostic.permissionStatus.GRANTED || status === "granted"){
            callback();
          }else
          cordova.plugins.diagnostic.requestCameraAuthorization(function(status){
            if(status == cordova.plugins.diagnostic.permissionStatus.GRANTED || status === "granted"){
              callback();
            }else{
              self.alert($filter('trans')('NOCAMERAPERMISSION'));
            }
          });
        });

      } else {
        callback();
      } 
    };   
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.QRCodeLogin = function(result){
      var a = result.split("|");
      if(a[0] == "https://learningview.org/"){
        a.shift(); // remove it
      }

      if(a[0] == "LVCODE"){
        // since 2024
        self.apiPost("loginUser",{"v":2, "qrcode":a[1], "uid":a[2], "device":self.getDeviceName()}).then(function(data){
          if(data.user){
            if(data.request){
              // request custom password now, prevents login by teacher
              self.loginClick(null,data.user.Email);
            }else
              self.loginUser(data.user);
          }
        },function(data, status, headers, config) {
          if(data.error == "error_loginDataOutdated"){
            self.alert("Dieser Code ist nicht mehr gültig. Verwende alternativ deinen Benutzernamen/Passwort zur Anmeldung, oder frage deine Lehrperson nach einem neuen Code. Hinweis: Solltest du dein Passwort geändert haben, wird auch der Login-Code ungültig.");
          }else
           self.alert("Anmeldung fehlgeschlagen: "+data.error);
        });
      }else
      if(a[0] == "LVLIVECODE"){
        // since 2024
        self.apiPost("loginUser",{"v":2, "qrcode":a[1], "tid":a[2], "device":self.getDeviceName()}).then(function(data){
          if(data.user){
            self.loginUser(data.user);
          }
        },function(data, status, headers, config) {
          if(data.error == "error_loginDataOutdated"){

          }else
           self.alert("Anmeldung fehlgeschlagen: "+data.error);
        });
      }else
      if(a[0] == "LV"){
        self.apiPost("loginUser",{"qrcode":a[1], "uid":a[2], "device":self.getDeviceName()})
          .then(function(data) {
            self.loginUser(data.user);
          },function(data, status, headers, config) {
            if(data.error == "error_loginDataOutdated"){
              self.alert("Dieser Code ist nicht mehr gültig. Verwende alternativ deinen Benutzernamen/Passwort zur Anmeldung, oder frage deine Lehrperson nach einem neuen Code. Hinweis: Solltest du dein Passwort geändert haben, wird auch der Login-Code ungültig.");
            }else
             self.alert("Anmeldung fehlgeschlagen: "+data.error);
          });
      }else
      if(a[0] == "STUDENTVIEW"){
        self.apiPost("ajax",{"salt":a[1],"uid":a[2],"action":"studentView", "classid":a[3]})
          .then(function(data) {
            self.loginUser(data.user);
          },function(data, status, headers, config) {
            self.alert("Anmeldung fehlgeschlagen: "+data.error);
          });
      }else{
        if(result.toLowerCase().match(/https?:/)){
          self.confirm($filter('trans')('ASKOPENSCANNEDURLQRCODE'),$filter('trans')('OPEN')).then(function(){
            self.openWeblink({DataJSON:{URL:result}},null,false);
          });
        }else
          self.alter($filter('trans')('NOVALIDLOGINCODEHINT'));
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.scanQRCode = function(ev){
      var captureNow = function(){
        if(window.QrScanner){
          var scanNow = function(){
            // new version without plugin
            var scannerWindow = $('<div><video></video></div>');
            scannerWindow.css({"position":"absolute","display":"flex","justify-content":"center","align-items":"center",
                               "background":"black","width":"100%","height":"100%","top":"0","left":"0", "z-index":"100000"});
            var scannerWindowCancel = $('<button><i class="fa fa-fw fa-times"></i></button>');
            scannerWindowCancel.css({"position":"absolute","background":"black","padding":"0.5em","font-size":"2em",
                                     "border":"0","color":"white","top":"8px","right":"8px"});
            scannerWindow.append(scannerWindowCancel);
            $("body").append(scannerWindow);
            var currentActiveElement = document.activeElement;
            var qrScanner = new QrScanner(
                $("video",scannerWindow).get(0),
                function(result){
                  console.log(result);
                  qrScanner.destroy();
                  qrScanner = null;
                  scannerWindow.remove();
                  scannerWindow = null;
                  scannerWindowCancel.remove();
                  scannerWindowCancel = null;
                  if(result.data != "") self.QRCodeLogin(result.data);
                },{ preferredCamera:"environment", highlightScanRegion:true, highlightCodeOutline:true, alsoTryWithoutScanRegion:true }
            );
            scannerWindowCancel.on("click",function(){
              qrScanner.destroy();
              qrScanner = null;
              scannerWindow.remove();
              scannerWindow = null;
              scannerWindowCancel.remove();
              scannerWindowCancel = null;
              document.removeEventListener("keydown",escHandler);
              if(currentActiveElement){
                setTimeout(function(){
                  currentActiveElement.focus();
                  currentActiveElement = null;
                },100);
              }
            });
            setTimeout(function(){ qrScanner.start(); scannerWindowCancel.focus(); },100);
            var escHandler = function (event) {
              if (event.key === "Escape" || event.keyCode === 27) {
                event.preventDefault();
                scannerWindowCancel.trigger("click");
              }
            };            
            document.addEventListener("keydown",escHandler);
          };

          scanNow();
          return;
        }

        if(typeof cordova == "undefined"){
          // show scan iframe
          self.showDialog({
            templateUrl: "qrscan.html",
            targetEvent: ev,
            skipHide:true, // keep other dialog open

            clickOutsideToClose: false,
            escapeToClose: false,
            controller: function ($scope, $mdDialog) {
              $scope.scan = function() {
                self.closeDialog($scope.dialogElement);
              };
              $scope.cancel = function() {
                stopScanning();
                self.closeDialog($scope.dialogElement);
              };
            }
          });
        } else if(cordova.plugins.barcodeScanner) {
          cordova.plugins.barcodeScanner.scan(
            function (result) {
              if(result.cancelled) return;
              if(result.text != "") self.QRCodeLogin(result.text);
            },
            function (error) {
              self.alert("Scanning failed: " + error);
            },
            {
              //preferFrontCamera : true, // iOS and Android
              showFlipCameraButton : true, // iOS and Android
              showTorchButton : true, // iOS and Android
              //torchOn: true, // Android, launch with the torch switched on (if available)
              //saveHistory: true, // Android, save scan history (default false)
              //prompt : "Place a barcode inside the scan area", // Android
              resultDisplayDuration: 0, // Android, display scanned text for X ms. 0 suppresses it entirely, default 1500
              //formats : "QR_CODE,PDF_417", // default: all but PDF_417 and RSS_EXPANDED
              //orientation : "landscape", // Android only (portrait|landscape), default unset so it rotates with the device
              //disableAnimations : true, // iOS
              disableSuccessBeep: false // iOS and Android
            }
          );
        }
      };
      self.requestMobileCameraPermissions(captureNow);
    };
