    self.pickTasks = function(current, classid, student, callback){
      self.showDialog({
        templateUrl: "pickTasks.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = null;
          $scope.mainTopics = [];
          $scope.student = student ? student : self.user;
          $scope.pickTasksSearchTerm = "";
          $scope.showMyMaterials = false;

          $scope.hasPickTasksSearch = function(){
            return $.trim($scope.pickTasksSearchTerm || "") != "";
          };

          $scope.matchesPickTasksSearch = function(task){
            if(!$scope.hasPickTasksSearch()) return true;
            if(!task) return false;
            var searchTexts = [task.Name, task.Description];
            if(task.ParentGoal){
              searchTexts.push(task.ParentGoal.Name);
            }
            if(task.ParentTopic){
              searchTexts.push(task.ParentTopic.Name);
            }
            if(task.ParentMainTopic){
              searchTexts.push(task.ParentMainTopic.Name);
            }
            var safeTexts = [];
            for(var i=0; i < searchTexts.length; i++){
              if(searchTexts[i] === null || searchTexts[i] === undefined) continue;
              safeTexts.push(String(searchTexts[i]));
            }
            if(safeTexts.length == 0) return false;
            return self.matchSearchTerm($scope.pickTasksSearchTerm,safeTexts);
          };

          function addMainTopic(list,mainTopic){
            var mt = {
                org:mainTopic,
                'ID':mainTopic.ID,
                'Owner':mainTopic.Owner,
                'Name':mainTopic.Name,
                'Description':mainTopic.Description,
                'Color':mainTopic.Color,
                "Permission":mainTopic.Permission,
                "shareSettings":mainTopic.shareSettings,
                "OrderIndex":parseInt(mainTopic.OrderIndex),
                "topics":[],"changed":false};

            list.push(mt);

            for(var z=0; z < mainTopic.topics.length; z++){
              var t = {org:mainTopic.topics[z],
                       'ID':mainTopic.topics[z].ID,
                       'Name':mainTopic.topics[z].Name,
                       'Description':mainTopic.topics[z].Description,
                       'OrderIndex':parseInt(mainTopic.topics[z].OrderIndex),
                       'changed':false, 'goals':[]};
              mt.topics.push(t);
              mt.Clicked = true;

              for(var x=0; x < mainTopic.topics[z].goals.length; x++){
                var g = {org:mainTopic.topics[z].goals[x],
                        'ID':mainTopic.topics[z].goals[x].ID,
                        'Name':mainTopic.topics[z].goals[x].Name,
                        'Description':mainTopic.topics[z].goals[x].Description,
                        'OrderIndex':parseInt(mainTopic.topics[z].goals[x].OrderIndex),
                        'changed':false,'tasks':[]};
                g.ParentTopic = t;
                g.ParentMainTopic = mt;
                t.goals.push(g);

                for(var y=0; y < mainTopic.topics[z].goals[x].tasks.length; y++){
                  var tt = {org:mainTopic.topics[z].goals[x].tasks[y],
                           'ID':mainTopic.topics[z].goals[x].tasks[y].ID,
                           'Name':mainTopic.topics[z].goals[x].tasks[y].Name,
                           'Color':mainTopic.topics[z].goals[x].tasks[y].Color,
                           'Description':mainTopic.topics[z].goals[x].tasks[y].Description,
                           'OrderIndex':parseInt(mainTopic.topics[z].goals[x].tasks[y].OrderIndex),
                           'changed':false};
                  tt.ParentGoal = g;
                  tt.ParentTopic = t;
                  tt.ParentMainTopic = mt;
                  g.tasks.push(tt);
                  if(self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '')) {
                    mt.Clicked = true;
                    t.Clicked = true;
                    g.Clicked = true;
                  }

                  if(current && current.indexOf(tt.ID) != -1) {
                    mt.Clicked = true;
                    t.Clicked = true;
                    g.Clicked = true;
                    tt.Clicked = true;
                  }
                }
              }
            }
          };

          $scope.getSelectedTaskIDs = function(){
            var selected = [];
            for(var z=0; z < $scope.mainTopics.length; z++)
              for(var x=0; x < $scope.mainTopics[z].topics.length; x++)
                for(var y=0; y < $scope.mainTopics[z].topics[x].goals.length; y++)
                  for(var i=0; i < $scope.mainTopics[z].topics[x].goals[y].tasks.length; i++){
                    if($scope.mainTopics[z].topics[x].goals[y].tasks[i].Clicked === true){
                      selected.push($scope.mainTopics[z].topics[x].goals[y].tasks[i].ID);
                    }
                  }
            return selected;
          };

          $scope.getSelectedTaskEntries = function(){
            var selected = [];
            for(var z=0; z < $scope.mainTopics.length; z++)
              for(var x=0; x < $scope.mainTopics[z].topics.length; x++)
                for(var y=0; y < $scope.mainTopics[z].topics[x].goals.length; y++)
                  for(var i=0; i < $scope.mainTopics[z].topics[x].goals[y].tasks.length; i++){
                    if($scope.mainTopics[z].topics[x].goals[y].tasks[i].Clicked === true){
                      selected.push($scope.mainTopics[z].topics[x].goals[y].tasks[i]);
                    }
                  }
            return selected;
          };

          $scope.rebuildTaskTree = function(){
            var keepSelected = {};
            var selectedIDs = $scope.getSelectedTaskIDs();
            for(var i=0; i < selectedIDs.length; i++){
              keepSelected[selectedIDs[i]] = true;
            }

            $scope.mainTopics = [];
            var userMainTopics = (self.userContent && self.userContent.mainTopics) ? self.userContent.mainTopics : [];
            var classMainTopics = (classid != null && self.classContent[classid] && self.classContent[classid].mainTopics) ? self.classContent[classid].mainTopics : [];

            if(classid == null){
              for(var u=0; u < userMainTopics.length; u++){
                addMainTopic($scope.mainTopics,userMainTopics[u]);
              }
            }else if($scope.showMyMaterials){
              var existingMainTopicIDs = {};
              for(var um=0; um < userMainTopics.length; um++){
                addMainTopic($scope.mainTopics,userMainTopics[um]);
                existingMainTopicIDs[userMainTopics[um].ID] = true;
              }
              for(var cm=0; cm < classMainTopics.length; cm++){
                if(existingMainTopicIDs[classMainTopics[cm].ID]) continue;
                addMainTopic($scope.mainTopics,classMainTopics[cm]);
              }
            }else{
              for(var c=0; c < classMainTopics.length; c++){
                addMainTopic($scope.mainTopics,classMainTopics[c]);
              }
            }

            for(var z=0; z < $scope.mainTopics.length; z++)
              for(var x=0; x < $scope.mainTopics[z].topics.length; x++)
                for(var y=0; y < $scope.mainTopics[z].topics[x].goals.length; y++)
                  for(var t=0; t < $scope.mainTopics[z].topics[x].goals[y].tasks.length; t++){
                    if(keepSelected[$scope.mainTopics[z].topics[x].goals[y].tasks[t].ID]){
                      $scope.mainTopics[z].Clicked = true;
                      $scope.mainTopics[z].topics[x].Clicked = true;
                      $scope.mainTopics[z].topics[x].goals[y].Clicked = true;
                      $scope.mainTopics[z].topics[x].goals[y].tasks[t].Clicked = true;
                    }
                  }

          };

          $scope.toggleShowMyMaterials = function(){
            $scope.showMyMaterials = !$scope.showMyMaterials;
            $scope.rebuildTaskTree();
            if(self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '') || $scope.hasPickTasksSearch()){
              $scope.openAllOnFirstFilter();
            }
          };

          $scope.firstFilterSet = true;
          $scope.openAllOnFirstFilter = function(){
            var hasStatusFilter = self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '');
            var hasSearchFilter = $scope.hasPickTasksSearch();
            if(hasStatusFilter || hasSearchFilter){
              if($scope.firstFilterSet){
                $scope.firstFilterSet = false;
                for(var i=0; i < $scope.mainTopics.length; i++){
                  $scope.mainTopics[i].Clicked = true;
                  for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                    $scope.mainTopics[i].topics[z].Clicked = true;
                    for(var x=0; x < $scope.mainTopics[i].topics[z].goals.length; x++){
                      $scope.mainTopics[i].topics[z].goals[x].Clicked = true;
                    }
                  }
                }
              }
            }else{
              $scope.firstFilterSet = true;
              // close all now
              for(var i=0; i < $scope.mainTopics.length; i++){
                $scope.mainTopics[i].Clicked = false;
                for(var z=0; z < $scope.mainTopics[i].topics.length; z++){
                  $scope.mainTopics[i].topics[z].Clicked = false;
                  for(var x=0; x < $scope.mainTopics[i].topics[z].goals.length; x++){
                    $scope.mainTopics[i].topics[z].goals[x].Clicked = false;
                  }
                }
              }
            }
          };
          $scope.rebuildTaskTree();
          $scope.hasFilteredTasksMainTopic = function(mt){
            if(self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '') || $scope.hasPickTasksSearch()){
              for(var i=0; i < mt.topics.length; i++){
                if($scope.hasFilteredTasksTopic(mt.topics[i])) return true;
              }
              return false;
            }else return true;
          }
          $scope.hasFilteredTasksTopic = function(t){
            if(self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '') || $scope.hasPickTasksSearch()){
              for(var i=0; i < t.goals.length; i++){
                if($scope.hasFilteredTasksLearningGoal(t.goals[i])) return true;
              }
              return false;
            }else return true;
          }
          $scope.hasFilteredTasksLearningGoal = function(g){
            if(self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '') || $scope.hasPickTasksSearch()){
              for(var i=0; i < g.tasks.length; i++){
                if($scope.hasFilteredTasksTask(g.tasks[i])) return true;
              }
              return false;
            }else return true;            
          }
          $scope.hasFilteredTasksTask = function(t){
            var hasStatusFilter = self.filterTaskImportant || self.filterTaskListColor || (self.filterNoteListNote && self.filterNoteListNote != '');
            if(hasStatusFilter){
              var ts = self.getUserTaskStatus(t,$scope.student,true);
              var statusMatch = false;
              if(self.filterTaskListColor && t.Color == self.filterTaskListColor) statusMatch = true;
              if(self.filterNoteListNote && ts.Note == self.filterNoteListNote) statusMatch = true;
              if(self.filterNoteListNote && ts.Note == '¶'+self.filterNoteListNote) statusMatch = true;
              if(self.filterTaskImportant && (t.Important == 1 || ts.Important == 1 || ts.Important == 2)) statusMatch = true;
              if(!statusMatch) return false;
            }
            return $scope.matchesPickTasksSearch(t);
          }

          $scope.getVisibleTasksInGoal = function(g){
            var out = [];
            if(!g || !g.tasks) return out;
            for(var i=0; i < g.tasks.length; i++){
              if($scope.hasFilteredTasksTask(g.tasks[i])) out.push(g.tasks[i]);
            }
            return out;
          };

          $scope.areAllVisibleTasksSelectedInGoal = function(g){
            var visible = $scope.getVisibleTasksInGoal(g);
            if(visible.length == 0) return false;
            for(var i=0; i < visible.length; i++){
              if(visible[i].Clicked !== true) return false;
            }
            return true;
          };

          $scope.toggleSelectVisibleTasksInGoal = function(g,ev){
            if(ev){
              ev.preventDefault();
              ev.stopPropagation();
            }
            var visible = $scope.getVisibleTasksInGoal(g);
            if(visible.length == 0) return;
            var allSelected = true;
            for(var i=0; i < visible.length; i++){
              if(visible[i].Clicked !== true){
                allSelected = false;
                break;
              }
            }
            for(var z=0; z < visible.length; z++){
              visible[z].Clicked = allSelected ? false : true;              
            }
            if(!allSelected) g.Clicked = true;
          };

          $scope.countSelected = function(){
            return $scope.getSelectedTaskIDs().length;
          };

          $scope.getNotDistributedSelectedTasks = function(selectedEntries){
            var missing = [];
            if(classid == null || !selectedEntries || selectedEntries.length == 0) return missing;
            if(!self.classContent || !self.classContent[classid] || !self.classContent[classid].mainTopics) return selectedEntries;

            var inClassByTaskID = {};
            var classMainTopics = self.classContent[classid].mainTopics;
            for(var i=0; i < classMainTopics.length; i++){
              if(!classMainTopics[i].topics) continue;
              for(var z=0; z < classMainTopics[i].topics.length; z++){
                if(!classMainTopics[i].topics[z].goals) continue;
                for(var g=0; g < classMainTopics[i].topics[z].goals.length; g++){
                  if(!classMainTopics[i].topics[z].goals[g].tasks) continue;
                  for(var t=0; t < classMainTopics[i].topics[z].goals[g].tasks.length; t++){
                    inClassByTaskID[classMainTopics[i].topics[z].goals[g].tasks[t].ID] = true;
                  }
                }
              }
            }

            for(var s=0; s < selectedEntries.length; s++){
              if(!inClassByTaskID[selectedEntries[s].ID]){
                missing.push(selectedEntries[s]);
              }
            }

            return missing;
          };

          $scope.buildSetContentInUseChangesFromTasks = function(tasks){
            var changes = {"maintopics":[],"topics":[],"goals":[],"tasks":[]};
            var seenMainTopics = {};
            var seenTopics = {};
            var seenGoals = {};
            var seenTasks = {};

            for(var i=0; i < tasks.length; i++){
              var tt = tasks[i];
              if(!tt) continue;
              if(!seenTasks[tt.ID]){
                seenTasks[tt.ID] = true;
                changes.tasks.push({"ID":tt.ID, "used":"1"});
              }
              if(tt.ParentGoal && !seenGoals[tt.ParentGoal.ID]){
                seenGoals[tt.ParentGoal.ID] = true;
                changes.goals.push({"ID":tt.ParentGoal.ID, "used":"1"});
              }
              if(tt.ParentTopic && !seenTopics[tt.ParentTopic.ID]){
                seenTopics[tt.ParentTopic.ID] = true;
                changes.topics.push({"ID":tt.ParentTopic.ID, "used":"1"});
              }
              if(tt.ParentMainTopic && !seenMainTopics[tt.ParentMainTopic.ID]){
                seenMainTopics[tt.ParentMainTopic.ID] = true;
                changes.maintopics.push({"ID":tt.ParentMainTopic.ID, "used":"1"});
              }
            }

            return changes;
          };

          $scope.save = function() {
            var selectedEntries = $scope.getSelectedTaskEntries();
            var selected = [];
            for(var i=0; i < selectedEntries.length; i++){
              selected.push(selectedEntries[i].ID);
            }
            if(classid != null && self.currentClass && self.hasClassChangePermission(self.currentClass) && $scope.mainTopics.length == 0){
              // special case open select class content
              self.editClassContentUsed(self.currentClass);
              self.closeDialog($scope.dialogElement);
              return;
            }

            var shouldCheckDistribution = classid != null && self.currentClass && self.hasClassChangePermission(self.currentClass);
            var notDistributedTasks = shouldCheckDistribution ? $scope.getNotDistributedSelectedTasks(selectedEntries) : [];
            if(notDistributedTasks.length > 0){
              self.confirm($filter('trans')('ASKSETCONTENTUSEDINCLASS'),$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
                var changes = $scope.buildSetContentInUseChangesFromTasks(notDistributedTasks);
                self.closeDialog($scope.dialogElement);
                self.apiPost("ajax",{"action":"setClassesContentInUse","classid":classid,
                                     "changes":angular.toJson(changes)}).then(function(){
                  self.keepAliveCallback().then(function(){
                    if(callback) callback(selected);
                  });
                },function(){
                  if(callback) callback(selected);
                });
              });
              return;
            }

            if(callback) callback(selected);
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.pickRubricsSearchTerm = "";
    self.pickRubrics = function(current, single, callback, target){
      self.showLoadingIndicator(null,function(done){
        self.updateRubrics().then(function(){
          done();
          self.showDialog({
            templateUrl: "pickRubrics.html",
            skipHide:true, // keep other dialog open
            clickOutsideToClose: false,
            escapeToClose: false,
            controller: function ($scope, $mdDialog) {
              $scope.self = self;
              $scope.single = single;
              $scope.selected = [];
              $scope.searchTerm = self.pickRubricsSearchTerm;
              $scope.materialRubricTree = [];
              $scope.wasCreated = {};

              $scope.askToDuplicate = function(rubric, source, ev){
                var deferred = $q.defer();
                var askNow = function(){
                  self.confirm($filter('trans')('ASKCOPYRUBRICFORTASK'),$filter('trans')('COPY'),ev,$filter('trans')('CREATELINK')).then(function(){
                    var n = JSON.parse(angular.toJson(rubric));
                    n.ID = -1;
                    self.editRubric(n,ev).then(function(newRubric){
                      $scope.wasCreated[newRubric.ID] = true;
                      deferred.resolve(newRubric);
                    });

                  },function(){
                    // create link
                    deferred.resolve(rubric);
                  });
                };

                var shouldAskForDuplicate = function(targetContext){
                  if(!target) return false;
                  if(!source || !source.locations || !angular.isArray(source.locations) || source.locations.length == 0){
                    return false; // rubric currently not used anywhere
                  }

                  if(target.type == "goal"){
                    for(var i=0; i < source.locations.length; i++){
                      var loc = source.locations[i];
                      if(!loc) continue;
                      if(loc.type == "task") return true; // task != goal
                      if(loc.type == "goal" && loc.goalID != target.goal.ID) return true; // different goal
                    }
                    return false; // only same goal usages
                  }

                  if(target.type == "task"){
                    for(var z=0; z < source.locations.length; z++){
                      var locTask = source.locations[z];
                      if(!locTask) continue;
                      if(locTask.type == "goal") return true; // goal != task
                      if(locTask.type == "task" && locTask.taskID != target.task.ID) return true; // different task
                    }
                    return false; // only same task usages
                  }

                  return false;
                };

                if(shouldAskForDuplicate()){
                  askNow();
                }else{
                  deferred.resolve(rubric);
                }
                return deferred.promise;
              }

              $scope.hasSearchTerm = function(){
                return $.trim($scope.searchTerm || "") != "";
              };

              $scope.exportRubric = function(format, rubric, ev){
                var url = "https://learningview.org/api/exportRubric.php?user="+self.user.ID+"&code="+self.user.Salt+"&rubric="+encodeURIComponent(rubric.GUID)+"&format="+format;
                var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
                function checkDownload(){
                  if(document.cookie.indexOf("fileDownload=true") > -1) {
                    var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                    document.cookie = cookieData;
                    setTimeout(function(){ frame.remove();},1000);
                  }else{
                    $timeout(checkDownload,100);
                  }
                }
                var filename = rubric.Name;
                filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
                filename = window.cleanFilename('LearningView_'+filename+"_"+moment().format('YYYY_MM_DD'))+(format == "pdf" ? ".pdf" : ".xlsx");
                if(window.electron){
                  window.downloadElectronSaveAs(url,filename,function(){});
                }else if(typeof cordova != "undefined"){
                  self.downloadFile(url,filename,true);
                }else{
                  $('body').append(frame);
                  checkDownload();
                }
              };

              $scope.getKnownRubricByGUID = function(guid){
                if(!guid) return null;
                if(self.getRubricByGUIDmap[guid]) return self.getRubricByGUIDmap[guid];
                for(var i=0; i < self.rubrics.length; i++){
                  self.getRubricByGUIDmap[self.rubrics[i].GUID] = self.rubrics[i];
                  if(self.rubrics[i].GUID == guid) return self.rubrics[i];
                }
                return null;
              };

              $scope.collectMaterialRubricGUIDs = function(){
                var guids = [];
                var seen = {};
                var source = (self.userContent && self.userContent.mainTopics) ? self.userContent.mainTopics : [];

                var addGuid = function(guid){
                  var normalized = $.trim(String(guid || ""));
                  if(normalized == "" || seen[normalized]) return;
                  seen[normalized] = true;
                  guids.push(normalized);
                };

                for(var m=0; m < source.length; m++){
                  var mt = source[m];
                  if(!mt) continue;
                  if(!mt.topics || !angular.isArray(mt.topics)) continue;

                  for(var t=0; t < mt.topics.length; t++){
                    var topic = mt.topics[t];
                    if(!topic || !topic.goals || !angular.isArray(topic.goals)) continue;

                    for(var g=0; g < topic.goals.length; g++){
                      var goal = topic.goals[g];
                      if(goal && goal.Rubrics && goal.Rubrics != ""){
                        var refs = goal.Rubrics.split(",");
                        for(var r=0; r < refs.length; r++){
                          var raw = $.trim(refs[r]);
                          if(raw == "") continue;
                          var guid = self.getLearningGoalRubricGUID(raw);
                          if(guid) addGuid(guid);
                        }
                      }

                      if(!goal || !goal.tasks || !angular.isArray(goal.tasks)) continue;
                      for(var tt=0; tt < goal.tasks.length; tt++){
                        var task = goal.tasks[tt];
                        if(!task || !task.DataJSON || !task.DataJSON.hints || !angular.isArray(task.DataJSON.hints)) continue;
                        for(var h=0; h < task.DataJSON.hints.length; h++){
                          var hint = task.DataJSON.hints[h];
                          if(!hint || hint.type != "rubric" || !hint.rubric) continue;
                          addGuid(hint.rubric);
                        }
                      }
                    }
                  }
                }

                return guids;
              };

              $scope.preloadMissingRubricsFromMaterials = function(){
                var allGuids = $scope.collectMaterialRubricGUIDs();
                var missingGuids = [];
                for(var i=0; i < allGuids.length; i++){
                  if($scope.getKnownRubricByGUID(allGuids[i])) continue;
                  if(self.fetchRubricsGuidsMissing.indexOf(allGuids[i]) != -1) continue;
                  missingGuids.push(allGuids[i]);
                }

                if(missingGuids.length == 0){
                  return $q.when();
                }

                return self.apiPost("ajax",{"action":"getRubrics", "guids":missingGuids.join(",")}).then(function(result){
                  if(result && result.rubrics) self.updateRubricsData(result.rubrics);
                });
              };

              $scope.getLearningGoalRubricIDs = function(goal){
                var ids = [];
                if(!goal || !goal.Rubrics || goal.Rubrics == "") return ids;
                var seen = {};
                var refs = goal.Rubrics.split(",");
                for(var i=0; i < refs.length; i++){
                  var raw = $.trim(refs[i]);
                  if(raw == "") continue;
                  var guid = self.getLearningGoalRubricGUID(raw);
                  if(!guid) continue;
                  var rubric = $scope.getKnownRubricByGUID(guid);
                  if(!rubric) continue;
                  var rubricID = parseInt(rubric.ID,10);
                  if(isNaN(rubricID) || seen[rubricID]) continue;
                  seen[rubricID] = true;
                  ids.push(rubricID);
                }
                return ids;
              };

              $scope.getTaskRubricIDs = function(task){
                var ids = [];
                if(!task || !task.DataJSON || !task.DataJSON.hints || !angular.isArray(task.DataJSON.hints)) return ids;
                var seen = {};
                for(var i=0; i < task.DataJSON.hints.length; i++){
                  var hint = task.DataJSON.hints[i];
                  if(!hint || hint.type != "rubric" || !hint.rubric) continue;
                  var rubric = $scope.getKnownRubricByGUID(hint.rubric);
                  if(!rubric) continue;
                  var rubricID = parseInt(rubric.ID,10);
                  if(isNaN(rubricID) || seen[rubricID]) continue;
                  seen[rubricID] = true;
                  ids.push(rubricID);
                }
                return ids;
              };

              $scope.rubricUsageMatchesSearch = function(usage){
                self.pickRubricsSearchTerm = $scope.searchTerm;
                var search = $.trim(($scope.searchTerm || "").toLowerCase());
                if(search === "") return true;
                if(!usage) return false;
                var rubric = usage.rubric || {};
                var haystack = [
                  rubric.Name ? String(rubric.Name) : "",
                  rubric.Description ? String(rubric.Description) : "",
                  usage.mainTopicName ? String(usage.mainTopicName) : "",
                  usage.topicName ? String(usage.topicName) : "",
                  usage.goalName ? String(usage.goalName) : "",
                  usage.taskName ? String(usage.taskName) : "",
                  usage.contexts && usage.contexts.length ? usage.contexts.join(" ") : "",
                  usage.type == "goal" ? "learninggoal" : "task",
                  usage.type == "goal" ? "thema" : "aufgabe"
                ].join(" ").toLowerCase();
                return haystack.indexOf(search) != -1;
              };

              $scope.getRubricUsageTooltip = function(usage){
                if(!usage || !usage.contexts || !usage.contexts.length) return "";
                var contexts = [];
                for(var i=0; i < usage.contexts.length; i++){
                  var value = $.trim(String(usage.contexts[i] || ""));
                  if(value == "") continue;
                  contexts.push(value);
                }
                if(contexts.length == 0) return "";
                contexts.sort(function(a,b){
                  var an = a.toLowerCase();
                  var bn = b.toLowerCase();
                  if(an < bn) return -1;
                  if(an > bn) return 1;
                  return 0;
                });
                return contexts.join(" | ");
              };

              $scope.topicHasVisibleRubrics = function(topicNode){
                if(!topicNode || !topicNode.rubrics) return false;
                for(var i=0; i < topicNode.rubrics.length; i++){
                  if($scope.rubricUsageMatchesSearch(topicNode.rubrics[i])) return true;
                }
                return false;
              };

              $scope.mainTopicHasVisibleRubrics = function(mainTopicNode){
                if(!mainTopicNode) return false;
                if(mainTopicNode.rubrics && angular.isArray(mainTopicNode.rubrics)){
                  for(var r=0; r < mainTopicNode.rubrics.length; r++){
                    if($scope.rubricUsageMatchesSearch(mainTopicNode.rubrics[r])) return true;
                  }
                }
                for(var t=0; t < mainTopicNode.topics.length; t++){
                  if($scope.topicHasVisibleRubrics(mainTopicNode.topics[t])) return true;
                }
                return false;
              };

              $scope.refreshMaterialRubricTree = function(){
                var tree = [];
                var selectedLookup = {};
                var usedRubricIDs = {};
                for(var i=0; i < $scope.selected.length; i++){
                  selectedLookup[$scope.selected[i]] = true;
                }
                var source = (self.userContent && self.userContent.mainTopics) ? self.userContent.mainTopics : [];

                for(var m=0; m < source.length; m++){
                  var mt = source[m];
                  if(!mt) continue;

                  var mtNode = {
                    ID:mt.ID,
                    Name:mt.Name,
                    Color:mt.Color,
                    Clicked:false,
                    topics:[]
                  };

                  if(!mt.topics || !angular.isArray(mt.topics)) continue;
                  for(var t=0; t < mt.topics.length; t++){
                    var topic = mt.topics[t];
                    var topicNode = {
                      ID:topic.ID,
                      Name:topic.Name,
                      Clicked:false,
                      rubrics:[]
                    };
                    var topicRubricMap = {};

                    var addTopicRubricUsage = function(rubric, usageMeta){
                      if(!rubric) return;
                      var rubricID = parseInt(rubric.ID,10);
                      if(isNaN(rubricID)) return;
                      usedRubricIDs[rubricID] = true;

                      var usage = topicRubricMap[rubricID];
                      if(!usage){
                        usage = {
                          key:"topic_"+topic.ID+"_"+rubricID,
                          rubricID:rubricID,
                          rubric:rubric,
                          mainTopic:mt,
                          mainTopicName:mt.Name,
                          topicName:topic.Name,
                          contexts:[],
                          locations:[],
                          useCount:0,
                          fromGoal:null,
                          fromTask:null
                        };
                        topicRubricMap[rubricID] = usage;
                        topicNode.rubrics.push(usage);
                      }

                      usage.useCount++;
                      if(usageMeta){
                        if(usageMeta.context && usage.contexts.indexOf(usageMeta.context) == -1){
                          usage.contexts.push(usageMeta.context);
                        }
                        if(usageMeta.type == "goal" && usageMeta.fromGoal){
                          var goalLocKey = "goal_" + usageMeta.fromGoal;
                          var goalLocFound = false;
                          for(var gl=0; gl < usage.locations.length; gl++){
                            if(usage.locations[gl] && usage.locations[gl].key == goalLocKey){
                              goalLocFound = true;
                              break;
                            }
                          }
                          if(!goalLocFound){
                            usage.locations.push({key:goalLocKey, type:"goal", goalID:usageMeta.fromGoal});
                          }
                        }
                        if(usageMeta.type == "task" && usageMeta.fromTask){
                          var taskLocKey = "task_" + usageMeta.fromTask;
                          var taskLocFound = false;
                          for(var tl=0; tl < usage.locations.length; tl++){
                            if(usage.locations[tl] && usage.locations[tl].key == taskLocKey){
                              taskLocFound = true;
                              break;
                            }
                          }
                          if(!taskLocFound){
                            usage.locations.push({key:taskLocKey, type:"task", taskID:usageMeta.fromTask});
                          }
                        }
                        if(usageMeta.fromTask && !usage.fromTask){
                          usage.fromTask = usageMeta.fromTask;
                        }
                        if(!usage.fromTask && usageMeta.fromGoal && !usage.fromGoal){
                          usage.fromGoal = usageMeta.fromGoal;
                        }
                        if(usageMeta.goalName && !usage.goalName){
                          usage.goalName = usageMeta.goalName;
                        }
                        if(usageMeta.taskName && !usage.taskName){
                          usage.taskName = usageMeta.taskName;
                        }
                        if(usageMeta.type && !usage.type){
                          usage.type = usageMeta.type;
                        }
                      }

                      if(selectedLookup[rubricID]){
                        mtNode.Clicked = true;
                        topicNode.Clicked = true;
                      }
                    };

                    if(!topic.goals || !angular.isArray(topic.goals)) continue;
                    for(var g=0; g < topic.goals.length; g++){
                      var goal = topic.goals[g];
                      var goalRubricIDs = $scope.getLearningGoalRubricIDs(goal);
                      if(goalRubricIDs.length > 0){
                        for(var gr=0; gr < goalRubricIDs.length; gr++){
                          var goalRubric = self.getRubricByID(goalRubricIDs[gr]);
                          addTopicRubricUsage(goalRubric, {
                            type:"goal",
                            goalName:goal.Name,
                            fromGoal:goal.ID,
                            context:"Thema: " + (goal.Name ? goal.Name : "")
                          });
                        }
                      }

                      if(!goal.tasks || !angular.isArray(goal.tasks)) continue;
                      for(var tt=0; tt < goal.tasks.length; tt++){
                        var task = goal.tasks[tt];
                        var taskRubricIDs = $scope.getTaskRubricIDs(task);
                        if(taskRubricIDs.length > 0){
                          for(var tr=0; tr < taskRubricIDs.length; tr++){
                            var taskRubric = self.getRubricByID(taskRubricIDs[tr]);
                            addTopicRubricUsage(taskRubric, {
                              type:"task",
                              goalName:goal.Name,
                              taskName:task.Name,
                              fromTask:task.ID,
                              context:"Aufgabe: " + (task.Name ? task.Name : "")
                            });
                          }
                        }
                      }
                    }

                    if(topicNode.rubrics.length > 0){
                      topicNode.rubrics.sort(function(a,b){
                        var an = a.rubric && a.rubric.Name ? String(a.rubric.Name).toLowerCase() : "";
                        var bn = b.rubric && b.rubric.Name ? String(b.rubric.Name).toLowerCase() : "";
                        if(an < bn) return -1;
                        if(an > bn) return 1;
                        return 0;
                      });
                      mtNode.topics.push(topicNode);
                    }
                  }

                  if(mtNode.topics.length > 0){
                    mtNode.topics.sort(function(a,b){
                      var an = a && a.Name ? String(a.Name).toLowerCase() : "";
                      var bn = b && b.Name ? String(b.Name).toLowerCase() : "";
                      if(an < bn) return -1;
                      if(an > bn) return 1;
                      return 0;
                    });
                    tree.push(mtNode);
                  }
                }

                tree.sort(function(a,b){
                  var an = a && a.Name ? String(a.Name).toLowerCase() : "";
                  var bn = b && b.Name ? String(b.Name).toLowerCase() : "";
                  if(an < bn) return -1;
                  if(an > bn) return 1;
                  return 0;
                });

                // Add an extra virtual main-topic at the end for rubrics not used in any material.
                var additionalRubrics = [];
                for(var r=0; r < self.rubrics.length; r++){
                  var rubric = self.rubrics[r];
                  if(!rubric) continue;
                  var rubricID = parseInt(rubric.ID,10);
                  if(isNaN(rubricID)) continue;
                  if(usedRubricIDs[rubricID]) continue;
                  var usage = {
                    key:"additional_"+rubricID,
                    rubricID:rubricID,
                    rubric:rubric,
                    mainTopic:null,
                    mainTopicName:$filter('trans')('ADDITIONALRUBRICS'),
                    topicName:$filter('trans')('ADDITIONALRUBRICS'),
                    contexts:[],
                    useCount:0,
                    fromGoal:null,
                    fromTask:null
                  };
                  additionalRubrics.push(usage);
                }

                if(additionalRubrics.length > 0){
                  additionalRubrics.sort(function(a,b){
                    var an = a.rubric && a.rubric.Name ? String(a.rubric.Name).toLowerCase() : "";
                    var bn = b.rubric && b.rubric.Name ? String(b.rubric.Name).toLowerCase() : "";
                    if(an < bn) return -1;
                    if(an > bn) return 1;
                    return 0;
                  });
                  var additionalClicked = false;
                  for(var ar=0; ar < additionalRubrics.length; ar++){
                    if(selectedLookup[additionalRubrics[ar].rubricID]){
                      additionalClicked = true;
                      break;
                    }
                  }
                  tree.push({
                    ID:"__additional_rubrics_main_topic__",
                    Name:$filter('trans')('ADDITIONALRUBRICS'),
                    Color:"#607d8b",
                    Clicked:additionalClicked,
                    rubrics:additionalRubrics,
                    topics:[]
                  });
                }

                $scope.materialRubricTree = tree;
              };

              $scope.removeRubricFromMaterialRubricTree = function(rubricID){
                rubricID = parseInt(rubricID,10);
                if(isNaN(rubricID)) return;

                for(var m=$scope.materialRubricTree.length-1; m >= 0; m--){
                  var mt = $scope.materialRubricTree[m];
                  if(!mt) continue;

                  if(mt.rubrics && angular.isArray(mt.rubrics)){
                    for(var mr=mt.rubrics.length-1; mr >= 0; mr--){
                      if(parseInt(mt.rubrics[mr].rubricID,10) == rubricID){
                        mt.rubrics.splice(mr,1);
                      }
                    }
                  }

                  if(mt.topics && angular.isArray(mt.topics)){
                    for(var t=mt.topics.length-1; t >= 0; t--){
                      var topic = mt.topics[t];
                      if(!topic) continue;

                      if(topic.rubrics && angular.isArray(topic.rubrics)){
                        for(var tr=topic.rubrics.length-1; tr >= 0; tr--){
                          if(parseInt(topic.rubrics[tr].rubricID,10) == rubricID){
                            topic.rubrics.splice(tr,1);
                          }
                        }
                      }

                      if(!topic.rubrics || topic.rubrics.length == 0){
                        mt.topics.splice(t,1);
                      }
                    }
                  }

                  var hasMainRubrics = mt.rubrics && mt.rubrics.length > 0;
                  var hasTopics = mt.topics && mt.topics.length > 0;
                  if(!hasMainRubrics && !hasTopics){
                    $scope.materialRubricTree.splice(m,1);
                  }
                }

              };

              $scope.createRubric = function(ev){
                self.editRubric({
                  ID:-1,
                  "Name":"Neues Raster",
                  "Description":"",
                  Data:"{}",
                  DataJSON:{
                    width:500,
                    rowID:2,
                    colID:4,
                    cellID:8,
                    columns:[
                      {ID:1,inactive:1,span:0},
                      {ID:2,multi:1}],
                    rows:[
                      {ID:1,inactive:1,span:0,Align:"center",vAlign:"middle"},
                      {ID:2}],
                    cells:[
                      {ID:1,row:1,col:1,Text:""},
                      {ID:2,row:1,col:2,Text:"<b>Beschreibung</b>"},
                      {ID:5,row:2,col:1,Text:"Beschreibung"},
                      {ID:6,row:2,col:2,Text:""},
                    ]}},ev).then(function(r){
                  $scope.wasCreated[r.ID] = true;
                  $scope.select(r,true);
                });
              };

              $scope.duplicateRubric = function(r,ev){
                var n = JSON.parse(angular.toJson(r));
                n.ID = -1;
                n.Name = n.Name + " (Kopie)";
                self.editRubric(n,ev).then(function(newRubric){
                  $scope.wasCreated[newRubric.ID] = true;
                  $scope.select(newRubric,true);
                });
              };

              $scope.editRubric = function(r,ev){
                self.editRubric(r,ev).then(function(updatedRubric){
                  if(!single)
                    $scope.select(updatedRubric,true);
                });
              };

              $scope.canEditUsageRubric = function(usage){
                if(!usage || !usage.rubric) return false;
                if(parseInt(usage.rubric.Owner,10) == parseInt(self.user.ID,10)) return true;
                if(!usage.mainTopic) return false;
                return self.checkChangePermission(usage.mainTopic);
              };

              $scope.editRubricFromUsage = function(usage,ev){
                if(!usage || !usage.rubric) return;
                if(!$scope.canEditUsageRubric(usage)) return;
                var editContext = {};
                if(usage.fromTask) editContext.fromTask = usage.fromTask;
                else if(usage.fromGoal) editContext.fromGoal = usage.fromGoal;
                self.editRubric(usage.rubric,ev,editContext).then(function(updatedRubric){
                  if(!single)
                    $scope.select(updatedRubric,true);
                });
              };

              $scope.deleteRubric = function(r,ev){
                if(r.Owner == self.user.ID){
                  self.confirm('<div style="color:red;">'+$filter('trans')('ASKDELETERUBRIC')+'</div>','<i class="fa fa-fw fa-trash-o"></i> '+$filter('trans')('DELETE'),ev).then(function(){
                    self.apiPost("ajax",{"action":"updateRubric", "ID":r.ID, "Active":0}).then(function(data) {
                      self.removeRubricFromLocalData(r);
                      for(var s=0; s < $scope.selected.length; s++){
                        if($scope.selected[s] == r.ID){
                          $scope.selected.splice(s,1);
                          break;
                        }
                      }
                      self.updateRubricsData(data.rubrics);
                      $scope.removeRubricFromMaterialRubricTree(r.ID);
                    });
                  });
                }
              };

              if(current){
                for(var i=0; i < current.length; i++){
                  if(!self.getRubricByID(current[i])) continue;
                  $scope.selected.push(parseInt(current[i],10));
                }
              }

              $scope.preloadMissingRubricsFromMaterials().then(function(){
                $scope.refreshMaterialRubricTree();
              }, function(){
                $scope.refreshMaterialRubricTree();
              });

              $scope.isRubricListedInMaterialTree = function(rubricID){
                rubricID = parseInt(rubricID,10);
                if(isNaN(rubricID)) return false;
                for(var m=0; m < $scope.materialRubricTree.length; m++){
                  var mt = $scope.materialRubricTree[m];
                  if(!mt) continue;
                  if(mt.rubrics && angular.isArray(mt.rubrics)){
                    for(var mr=0; mr < mt.rubrics.length; mr++){
                      if(parseInt(mt.rubrics[mr].rubricID,10) == rubricID) return true;
                    }
                  }
                  if(mt.topics && angular.isArray(mt.topics)){
                    for(var t=0; t < mt.topics.length; t++){
                      var topic = mt.topics[t];
                      if(!topic || !topic.rubrics || !angular.isArray(topic.rubrics)) continue;
                      for(var tr=0; tr < topic.rubrics.length; tr++){
                        if(parseInt(topic.rubrics[tr].rubricID,10) == rubricID) return true;
                      }
                    }
                  }
                }
                return false;
              };

              $scope.select = function(rubric,onlyadd,ev) {
                if(!rubric) return;
                rubric.ID = parseInt(rubric.ID,10);                
                if($scope.selected.indexOf(rubric.ID) == -1){
                  var source = arguments.length > 3 ? arguments[3] : null; // source from tree click
                  $scope.askToDuplicate(rubric,source,ev).then(function(selectedRubric){
                    if(!selectedRubric) return;
                    selectedRubric.ID = parseInt(selectedRubric.ID,10);
                    if(isNaN(selectedRubric.ID)) return;
                    if($scope.selected.indexOf(selectedRubric.ID) != -1) return;
                    $scope.selected.push(selectedRubric.ID);
                    $scope.refreshMaterialRubricTree();
                    if(single){
                      $scope.save();
                    }
                  });
                }else if(!onlyadd){
                  var removeSelected = function(){
                    var index = $scope.selected.indexOf(rubric.ID);
                    if(index != -1) $scope.selected.splice(index,1);
                  };

                  var ownerID = parseInt(rubric.Owner,10);
                  var myID = parseInt(self.user.ID,10);
                  var isForeignRubric = !isNaN(ownerID) && !isNaN(myID) && ownerID != myID;
                  if(isForeignRubric){
                    self.confirm('<div style="color:red;">'+$filter('trans')('ASKREMOVEFOREIGNRUBRICFROMSELECTION')+'</div>', $filter('trans')('UNSELECT'), ev).then(function(){
                      removeSelected();
                    });
                  }else{
                    removeSelected();
                  }
                }
              };     

              $scope.save = function() {
                self.closeDialog($scope.dialogElement);
                if(callback) callback($scope.selected,$scope.wasCreated);
              };

              $scope.cancel = function() {
                self.closeDialog($scope.dialogElement);
              };
            }
          });

        });
      });
    };

    self.pickFlashcardsSearchTerm = "";
    self.pickFlashcards = function(current, single, callback){
      self.showLoadingIndicator(null,function(done){
        self.loadFlashCardData().then(function(){
          done();
          self.showDialog({
            templateUrl: "pickFlashcards.html",
            skipHide:true,
            clickOutsideToClose: false,
            escapeToClose: false,
            controller: function ($scope) {
              $scope.self = self;
              $scope.single = single;
              $scope.selected = [];
              $scope.searchTerm = self.pickFlashcardsSearchTerm;
              $scope.groupedSets = [];
              $scope.categoriesOpen = {};
              $scope.saving = false;

              $scope.hasSearchTerm = function(){
                return $.trim($scope.searchTerm || "") != "";
              };

              $scope.setMatchesSearch = function(set){
                self.pickFlashcardsSearchTerm = $scope.searchTerm;
                var search = $.trim(($scope.searchTerm || "").toLowerCase());
                if(search === "") return true;
                var name = (set && set.Set && set.Set.Name ? String(set.Set.Name) : "").toLowerCase();
                var category = (set && set.Set && set.Set.Category ? String(set.Set.Category) : "").toLowerCase();
                if(name.indexOf(search) !== -1) return true;
                return category.indexOf(search) !== -1;
              };

              function selectedMap(){
                var map = {};
                for(var i=0; i < $scope.selected.length; i++){
                  map[String($scope.selected[i])] = true;
                }
                return map;
              }

              function refreshGroupedSets(){
                var groups = {};
                var selectedLookup = selectedMap();
                for(var i=0; i < self.flashCardSets.length; i++){
                  var set = self.flashCardSets[i]; 
                  if(!set || !set.Set) continue;
                  var isOwner = !!set && !!set.Set && String(set.Set.Owner) == String(self.user.ID);
                  if(set.Active == -1 && !isOwner) continue;
                  if(set.Set.Active == 0) continue;
                  if(!$scope.setMatchesSearch(set)) continue;
                  var label = set.Set.Category ? set.Set.Category : $filter('trans')('FLASHCARDS_PICK_UNCATEGORIZED');
                  var key = label.toLowerCase();
                  if(!groups[key]) groups[key] = {key:key,label:label,sets:[]};
                  groups[key].sets.push(set);
                }
                var keys = Object.keys(groups).sort(function(a,b){
                  var al = groups[a].label.toLowerCase();
                  var bl = groups[b].label.toLowerCase();
                  if(al < bl) return -1;
                  if(al > bl) return 1;
                  return 0;
                });
                $scope.groupedSets = [];
                for(var k=0; k < keys.length; k++){
                  var group = groups[keys[k]];
                  group.sets.sort(function(a,b){
                    var an = a.Set.Name ? a.Set.Name.toLowerCase() : "";
                    var bn = b.Set.Name ? b.Set.Name.toLowerCase() : "";
                    if(an < bn) return -1;
                    if(an > bn) return 1;
                    return 0;
                  });
                  $scope.groupedSets.push(group);

                  var hasSelected = false;
                  for(var s=0; s < group.sets.length; s++){
                    if(selectedLookup[String(group.sets[s].Set.ID)]){
                      hasSelected = true;
                      break;
                    }
                  }
                  if($scope.categoriesOpen[group.key] === undefined){
                    $scope.categoriesOpen[group.key] = hasSelected ? true : false;
                  }
                }
              }

              $scope.toggleCategory = function(key){
                $scope.categoriesOpen[key] = !$scope.categoriesOpen[key];
              };
              $scope.isCategoryOpen = function(key){
                return !!$scope.categoriesOpen[key] || $scope.hasSearchTerm();
              };
              $scope.isSelected = function(set){
                return $scope.selected.indexOf(parseInt(set.Set.ID,10)) !== -1;
              };
              $scope.select = function(set, onlyAdd){
                if(!set || !set.Set) return;
                var id = parseInt(set.Set.ID,10);
                if(isNaN(id)) return;
                var idx = $scope.selected.indexOf(id);
                if(idx === -1){
                  $scope.selected.push(id);
                  if(single){
                    $scope.save();
                  }
                }else if(!onlyAdd){
                  $scope.selected.splice(idx,1);
                }
              };
              $scope.canEditSet = function(set){
                return !!set && !!set.Set && String(set.Set.Owner) == String(self.user.ID);
              };
              $scope.editSet = function(set, ev){
                self.openFlashCardSetEditorDialog({
                  set: set,
                  ev: ev,
                  knownSets: self.flashCardSets,
                  busyState: $scope,
                  busyKey: "saving"
                }).then(function(savedSet){
                  refreshGroupedSets();
                  if(savedSet) $scope.select(savedSet, true);
                }, function(){});
              };
              $scope.createSet = function(ev){
                self.openFlashCardSetEditorDialog({
                  createMode: true,
                  ev: ev,
                  knownSets: self.flashCardSets,
                  busyState: $scope,
                  busyKey: "saving"
                }).then(function(savedSet){
                  refreshGroupedSets();
                  if(savedSet) $scope.select(savedSet, true);
                }, function(){});
              };
              $scope.duplicateSet = function(set, ev){
                if(!set || !set.Set) return;
                self.openFlashCardSetEditorDialog({
                  createMode: true,
                  ev: ev,
                  knownSets: self.flashCardSets,
                  prefill: {
                    name: (set.Set.Name || "") + " " + $filter('trans')('FLASHCARDS_COPY_SUFFIX'),
                    category: set.Set.Category || "",
                    cards: set.Set.cards || []
                  },
                  busyState: $scope,
                  busyKey: "saving"
                }).then(function(savedSet){
                  refreshGroupedSets();
                  if(savedSet) $scope.select(savedSet, true);
                }, function(){});
              };
              $scope.deleteSet = function(set, ev){
                if(!set || !set.Set || $scope.saving) return;
                self.confirm('<div style="color:red;">'+$filter('trans')('FLASHCARDS_PICK_DELETE_CONFIRM')+'</div>', $filter('trans')('DELETE'), ev).then(function(){
                  $scope.saving = true;
                  var request;
                  if(String(set.Set.Owner) == String(self.user.ID)){
                    request = self.apiPost("ajax",{action:"updateFlashCardSet", noerror:1, ID:set.Set.ID, Active:0});
                  }else{
                    if(!set.Set.GUID || $.trim(set.Set.GUID) === ""){
                      $scope.saving = false;
                      self.alert($filter('trans')('FLASHCARDS_PICK_GUID_MISSING_REMOVE'));
                      return;
                    }
                    request = self.apiPost("ajax",{action:"updateUserFlashCardSet", noerror:1, ID:set.Set.ID, GUID:set.Set.GUID, Active:-1});
                  }
                  request.then(function(){
                    return self.loadFlashCardData();
                  }).then(function(){
                    var id = parseInt(set.Set.ID,10);
                    for(var i=0; i < $scope.selected.length; i++){
                      if($scope.selected[i] == id){
                        $scope.selected.splice(i,1);
                        break;
                      }
                    }
                    $scope.saving = false;
                    refreshGroupedSets();
                  }, function(err){
                    $scope.saving = false;
                    self.alert(err && err.error ? err.error : $filter('trans')('FLASHCARDS_PICK_DELETE_FAILED'));
                  });
                });
              };

              if(current && Array.isArray(current)){
                for(var i=0; i < current.length; i++){
                  var item = current[i];
                  var found = self.getFlashCardSetByID(item);
                  if(!found) found = self.getFlashCardSetByGUID(item);
                  if(!found || !found.Set) continue;
                  var id = parseInt(found.Set.ID,10);
                  if(isNaN(id)) continue;
                  if($scope.selected.indexOf(id) === -1) $scope.selected.push(id);
                }
              }

              refreshGroupedSets();

              $scope.save = function() {
                self.closeDialog($scope.dialogElement);
                if(callback) callback($scope.selected);
              };

              $scope.cancel = function() {
                self.closeDialog($scope.dialogElement);
              };
            }
          });
        });
      });
    };

    self.showItemInformation = function(type,it,ev){
      self.showDialog({
        templateUrl: "showItemInformation.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.type = type;
          $scope.it = it;
          $scope.owner = "";
          if(it.Owner && self.users[it.Owner]) 
            $scope.owner = self.users[it.Owner].Name + " " + self.users[it.Owner].Surname;
          $scope.changed = it.Changed ? it.Changed : 0;
          $scope.changedByTask = null;

          $scope.lastChangedByID = it.ChangedBy;
          if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
            $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;

          if(type == "maintopic"){
            for(var i=0; i < it.topics.length; i++){
              if(it.topics[i].Changed && $scope.changed < it.topics[i].Changed) {
                $scope.changed = it.topics[i].Changed;
                $scope.lastChangedByID = it.topics[i].ChangedBy;
                if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
                  $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;
              }
              for(var z=0; z < it.topics[i].goals.length; z++){
                if(it.topics[i].goals[z].Changed && $scope.changed < it.topics[i].goals[z].Changed){
                  $scope.changed = it.topics[i].goals[z].Changed;
                  $scope.lastChangedByID = it.topics[i].goals[z].ChangedBy;
                  if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
                    $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;
                } 
                for(var x=0; x < it.topics[i].goals[z].tasks.length; x++){
                  if(it.topics[i].goals[z].tasks[x].Changed && $scope.changed < it.topics[i].goals[z].tasks[x].Changed) {
                    $scope.changed = it.topics[i].goals[z].tasks[x].Changed;
                    $scope.changedByTask = it.topics[i].goals[z].tasks[x]; 
                  }
                }
              }
            }
          }
          if(type == "topic"){
            for(var z=0; z < it.goals.length; z++){
              if(it.goals[z].Changed && $scope.changed < it.goals[z].Changed) {
                $scope.changed = it.goals[z].Changed;
                $scope.lastChangedByID = it.goals[z].ChangedBy;
                if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
                  $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;
              }
              for(var x=0; x < it.goals[z].tasks.length; x++){
                if(it.goals[z].tasks[x].Changed && $scope.changed < it.goals[z].tasks[x].Changed) {
                  $scope.changed = it.goals[z].tasks[x].Changed;
                  $scope.changedByTask = it.goals[z].tasks[x];                    
                }
              }
            }
          }
          if(type == "goal"){
            for(var x=0; x < it.tasks.length; x++){
              if(it.tasks[x].Changed && $scope.changed < it.tasks[x].Changed) {
                $scope.changed = it.tasks[x].Changed;
                $scope.changedByTask = it.tasks[x];                    
              }
            }
          }
          if(type == "task"){
            $scope.changedByTask = it;
          }

          // fetch history of last changed task
          if($scope.changedByTask){
            // fetch history of task and update changed by
            $scope.lastChangedByID = $scope.changedByTask.ChangedBy;
            if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
              $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;

            self.apiPost("ajax",{"action":"getTaskHistory", "ID":$scope.changedByTask.ID})
              .then(function(data) {
                $scope.history = data.history;
                if($scope.history.length > 0){
                  if($scope.history[0].ChangedBy){
                    $scope.lastChangedByID = $scope.history[0].ChangedBy;
                    if($scope.lastChangedByID && self.users[$scope.lastChangedByID]) 
                      $scope.lastChangedByUser = self.users[$scope.lastChangedByID].Name + " " + self.users[$scope.lastChangedByID].Surname;
                  }                  
                }
                for(var i = 0; i < $scope.history.length; i++){
                  if(i == $scope.history.length-1) {
                    // last entry
                    $scope.history[i].ChangedBy = it.Owner;
                    if(it.Owner && self.users[it.Owner]) 
                      $scope.history[i].ChangedByUser = self.users[it.Owner].Name + " " + self.users[it.Owner].Surname;                    
                    continue;
                  }
                  $scope.history[i].ChangedBy = $scope.history[i+1].ChangedBy;
                  if($scope.history[i].ChangedBy && self.users[$scope.history[i].ChangedBy]) 
                    $scope.history[i].ChangedByUser = self.users[$scope.history[i].ChangedBy].Name + " " + self.users[$scope.history[i].ChangedBy].Surname;
                }
              });
          }

          $scope.openTaskHistory = function(h){
            // show editTask Panel with old data so we can save it again / override with current version
            var t = self.getTaskByID(h.ID);
            if(t){
              self.closeDialog($scope.dialogElement);
              h.DataJSON = JSON.parse(h.Data);
              self.editTask(h,t.goal,null);
            }
          };
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.createFolderLink = function(current, callback){
      self.showDialog({
        templateUrl: "createFolderLink.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.current = current ? JSON.parse(JSON.stringify(current)) : {};

          $scope.save = function() {
            var c = {Name:$scope.current.Name};
            if($scope.current && $scope.current.Share) c.Share = $scope.current.Share; else c.Share = 0;
            if($scope.current && $scope.current.Feedback) c.Feedback = $scope.current.Feedback; else c.Feedback = 0;
            if($scope.current && $scope.current.Icon) c.Icon = $scope.current.Icon;
            if($scope.current && $scope.current.Color) c.Color = $scope.current.Color;
            if(callback) callback(c);
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    //1010 dropHandler
    self.dropHandlerCounter = 0;
    self.dropHandler = [];

    self.dragFilePanel = false;

    window.addEventListener("dragenter", function(event) {
      if(self.dropHandler && self.dropHandler[0]) {
        self.dropHandlerCounter++;

        if(!self.dragFilePanel) {
          var isText = true;
          if(event.dataTransfer.types)
            for(var i=0; i < event.dataTransfer.types.length; i++){
              if(event.dataTransfer.types[i] != 'text/plain' && event.dataTransfer.types[i] != 'text/html') isText = false;
            }


          self.dragFilePanel = $('<div style="display:none;background:rgb(2,136,209);color:white;position:absolute;'+
                                 'z-index:9999997;top:0;left:0;right:0;bottom:0;"></div>'+
                                 '<div style="display:none;background:rgba(0,0,0,0.6);color:white;position:absolute;'+
                                 'z-index:9999999;top:0;left:0;right:0;bottom:0;"><div style="position:absolute;top:45%;left:0;right:0;text-align:center">' +
                                 (isText ? $filter('trans')('INSERT') : $filter('trans')('UPLOAD')) +
                                 ' ... <br><br><i class="fa fa-upload fa-4x"></i><br><br></div></div>');

          self.dragFilePanel.click(self.closeDragFilePanel);

          $("body").append(self.dragFilePanel);

          self.dragFilePanel.fadeIn();

          self.dropHandler[0].dialog.css("z-index", "9999998");
        }
      }
    });

    window.addEventListener("drop", function(event) {
        if(self.dropHandler && self.dropHandler[0]) {
          self.closeDragFilePanel();
          var isText = true;
          if(event.dataTransfer.types)
            for(var i=0; i < event.dataTransfer.types.length; i++){
              if(event.dataTransfer.types[i] != 'text/plain' && event.dataTransfer.types[i] != 'text/html') isText = false;
            }

          if(isText || (event.dataTransfer.types && event.dataTransfer.types[0] == 'text/plain')) {
            text = event.dataTransfer.getData("text");
            self.dropHandler[0].callback(null, text);
          }
          else {
            self.dropHandler[0].callback(event.dataTransfer.files || event.target.files);
          }
        }
    });

    window.addEventListener("dragleave", function() {
      self.dropHandlerCounter--;

      if(self.dropHandlerCounter <= 0) self.closeDragFilePanel();
    });

    self.closeDragFilePanel = function() {
      if(self.dragFilePanel) {
        self.dragFilePanel.fadeOut(400,function(){
          if(self.dropHandler && self.dropHandler[0]) {
            self.dropHandler[0].dialog.css("z-index", "");
          }

          if(self.dragFilePanel) self.dragFilePanel.remove();

          self.dragFilePanel = null;
        });
      }

      self.dropHandlerCounter = 0;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.takeUserMedia = function(type, currentValue, callback, settings){
      if(type == "text"){
        self.showTextEditor($filter('trans')('TEXTEDITOR'),currentValue,self.currentTask,null,(self.currentTask.Social == 'pair' || self.currentTask.Social == 'group'),(self.currentTask.Groups && self.currentTask.Groups != ''),null,function(text){
          if(text !== null) callback([{Text: text, Type:'text'}]);
        },null,false,false,null);
        return;
      }
      if(type == "textonly"){
        // without task description
        self.showTextEditor($filter('trans')('TEXTEDITOR'),currentValue,null,null,false,false,null,function(text){
          if(text !== null) callback([{Text: text, Type:'text'}]);
        },null,false,false,null);
        return;
      }
      if(type == "ref"){
        self.pickMaterial(currentValue,self.currentClass ? self.currentClass.ID : null,function(id,type){
          callback([{ID: id, Type: type}]);
        });
        return;
      }
      if(type == "folder"){
        self.createFolderLink(currentValue, function(folder){
          callback([{Folder: folder, Type:'folder'}]);
        });
        return;
      }
      // collect media of given type and return URL on success
      self.showDialog({
        templateUrl: "takeUserMedia.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        state:"modalTop",
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.type = type;

          //dialogMode: 0, 1 and 2
          // 0: direct save without preview
          // 1: with preview, clears data on replace, opens dialog 0 with append (default)
          // 2: with preview, without recentFiles, opens dialog 1 with choose, opens dialog 0 with replace or append
          //if you check 'settings.dialogMode' and it was '0' it would fail and would change dialogMode to 1
          $scope.dialogMode = settings ? typeof settings.dialogMode !== 'undefined' ? settings.dialogMode : 1 : 1;
          $scope.recordInParent = settings && settings.recordInParent ? settings.recordInParent : false;
          $scope.isNested = settings && settings.isNested ? settings.isNested : false;
          //allows the user to select multiple files in the explorer!
          $scope.allowMultiple = settings && settings.allowMultiple ? settings.allowMultiple : false;

          $scope.currentTaskAnswer = currentValue ? currentValue : "";

          if($scope.dialogMode != 0) $scope.currentTaskAnswerChanged = false;

          if(settings.student)
            $scope.avatarStudent = settings.student;
          if($scope.isNested && type == "avatar"){
            type = "image";
            $scope.type = type;
            $scope.isAvatar = true; 
            $scope.avatarStudent = settings.student;
          }

          if(type == "icon") self.addImageRecorderScope($scope);
          if(type == "avatar") self.addImageRecorderScope($scope); 
          if(type == "drawing") self.addFileRecorderScope($scope,["png","jpg","jpeg","pdf"]);
          if(type == "annotation") self.addFileRecorderScope($scope,["png","jpg","jpeg","pdf"]);
          if(type == "image") self.addImageRecorderScope($scope);
          if(type == "audio") self.addAudioRecorderScope($scope);
          if(type == "video") self.addVideoRecorderScope($scope);
          if(type == "file")  self.addFileRecorderScope($scope);
          if(type == "link"){
            $scope.hasLink = currentValue && currentValue != "";
            $scope.linkURL = currentValue;

            $scope.getLinkForUpload = function(){
              self.takeUserMedia("file",null,function(results){
                if(results && results[0].URL != '') {
                  var caption = results[0].Name;
                  var parts = caption.split(".");
                  parts.pop();
                  caption = parts.join(".");                  
                  $scope.linkURL = results[0].URL;
                  $timeout(function(){
                    $scope.save();
                  },10);
                }
              }, {dialogMode: 0});      
            };
          }
          if(type == "icon") {
            $scope.allowFull = settings && settings.allowFull ? settings.allowFull : false;
            $scope.isFull = false;
          }

          $scope.sendRecordInParent = function(){
            self.closeDialog($scope.dialogElement);
            callback("RECORDINPARENT");
          };

          $scope.sendIsNested = function(returnValue) {
            self.closeDialog($scope.dialogElement);
            callback(returnValue);
          }

          $scope.uploadIconFileSubmit = function(e){
            e = e && e.target && !e.files ? e.target : e;
            if(e.files.length == 0) return;
            if(!self.checkFileType(e.files[0],"image")) return;
            var filename = e.files[0].name;
            e.files[0].myType = "image";
            self.uploadFileInput(e,function(result){
              $scope.MainIconURL = result;
              self.customIconIsBlack($scope.MainIconURL,function(isBlack){
                $scope.isBlack = isBlack;
              });
            });
            $(e).val('');
          };

          //1009
          $scope.mergeRecentFilesLists = function(upldFiles, tempFiles){
            var array = [];
            var storedTempFilesURL = [];

            if(upldFiles) {
              for(var i = 0; i < upldFiles.length; i++){
                var addToArray = true;
                if(tempFiles) {
                  for(var ii = 0; ii < tempFiles.length; ii++) {
                    if(!tempFiles[ii].hide) {
                      if(upldFiles[i].url == tempFiles[ii].url) {
                          //don't allow dublicated url (mostly because the user viewed the uploaded File)
                          if(tempFiles[ii].time > upldFiles[i].time) {
                            addToArray = false;
                            array.push(tempFiles[ii]);
                          }
                          storedTempFilesURL.push(tempFiles[ii]);
                        break;
                      }
                    }
                  }
                }

                if(addToArray) {
                  array.push(upldFiles[i]);
                }
              }
            }

            if(tempFiles && tempFiles.length > 0 && storedTempFilesURL.length != tempFiles.length) {
              for(var i = 0; i < tempFiles.length; i++) {
                if(!tempFiles[i].hide) {
                  var addToArray = true;
                  for(var ii = 0; ii < storedTempFilesURL.length; ii++) {
                    if(tempFiles[i].url == storedTempFilesURL[ii].url) {
                      addToArray = false;
                      break;
                    }
                  }
                  if(addToArray) {
                    array.push(tempFiles[i]);
                  }
                }
              }
            }

            if(array && array.length > 0 && array[0].time) {
              array.sort(function(a, b) {
                if(a.time && b.time && a.time > b.time) return -1;
                if(a.time && b.time && a.time < b.time) return 1;
                return 0;
              });
            }

            return array;
          };

          // merge arrays for last used files here
          $scope.mergedRecentFilesList = [];
          if(type == "image" || type == "annotation" || type == "drawing")
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists(self.userViewData.recentFiles ? self.userViewData.recentFiles.imageUploads : null, self.tempRecentFiles ? self.tempRecentFiles.images : null);
          if(type == "audio")
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists(self.userViewData.recentFiles ? self.userViewData.recentFiles.audioUploads : null, self.tempRecentFiles ? self.tempRecentFiles.audios : null);
          if(type == "video")
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists(self.userViewData.recentFiles ? self.userViewData.recentFiles.videoUploads : null, self.tempRecentFiles ? self.tempRecentFiles.videos : null);
          if(type == "file"){
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists(self.userViewData.recentFiles ? self.userViewData.recentFiles.fileUploads : null, self.tempRecentFiles ? self.tempRecentFiles.files : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.userViewData.recentFiles ? self.userViewData.recentFiles.imageUploads : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.userViewData.recentFiles ? self.userViewData.recentFiles.audioUploads : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.userViewData.recentFiles ? self.userViewData.recentFiles.videoUploads : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.tempRecentFiles ? self.tempRecentFiles.images : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.tempRecentFiles ? self.tempRecentFiles.audios : null);
            $scope.mergedRecentFilesList = $scope.mergeRecentFilesLists($scope.mergedRecentFilesList, self.tempRecentFiles ? self.tempRecentFiles.videos : null);
          }

          $scope.save = function() {
            if($scope.allowMultiple && $scope.multipleAnswers && $scope.multipleAnswers.length > 1) {
              var resultArray = [];
              if($scope.multipleAnswers) {
                for(var i = 0; i < $scope.multipleAnswers.length; i++) {
                  var d = {};

                  d.URL = $scope.multipleAnswers[i].url;

                  if($scope.multipleAnswers[i].name)
                    d.Name = $scope.multipleAnswers[i].name;

                  if($scope.multipleAnswers[i].type)
                    d.Type = $scope.multipleAnswers[i].type;
                  else
                    d.Type = 'file';

                  d.Requested = type;

                  resultArray.push(d);
                }
              }
              callback(resultArray);
            } else
            if(type == "icon"){
              callback([{URL: $scope.MainIconURL, isFull:$scope.isFull, Type: "image",Requested:type}]);
              //close (war vorher hier)
            }else
            if(type == "link"){
              if($scope.linkURL.indexOf("http") == -1) $scope.linkURL = "https://"+$scope.linkURL;
              callback([{URL: $scope.linkURL, Type: "link", Requested:type}]);
              //close (war vorher hier)
            }else
            if(type == "audio"){
              // upload audio now
              if(!$scope.audioURL) $scope.audioURL = $scope.currentTaskAnswer;
              if($scope.audioURL.indexOf("blob:") == -1 && $scope.audioURL.indexOf("://learningview.org/") > 0){
                //close (war vorher hier)
                callback([{URL: $scope.audioURL, Type: "audio",Requested:type, Name: $scope.audioFilename}]);
              }else
                self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL,$scope.audioFilename, self.getMediaID(),'record',null,function(filename){
                  $scope.audioURL = filename;
                  $scope.currentTaskAnswer = filename;
                  //close (war vorher hier)
                  callback([{URL: $scope.audioURL, Type: "audio",Requested:type, Name: $scope.audioFilename}]);
                });
            }else
            if(type == "video"){
              // upload video now
              if(!$scope.videoURL) $scope.videoURL = $scope.currentTaskAnswer;
              if($scope.videoURL.indexOf("blob:") == -1 && $scope.videoURL.indexOf("://learningview.org/") > 0){
                //close (war vorher hier)
                callback([{URL: $scope.videoURL, Type: "video",Requested:type, Name: $scope.videoFilename}]);
              }else
                self.uploadFile($scope.videoURL.indexOf("blob:") == 0 ? $scope.videoBlob : $scope.videoURL, $scope.videoFilename, self.getMediaID(),'video',null,function(filename){
                  $scope.videoURL = filename;
                  $scope.currentTaskAnswer = filename;
                  //close (war vorher hier)
                  callback([{URL: $scope.videoURL, Type: "video",Requested:type, Name: $scope.videoFilename}]);
                });
            }else{
              //close (war vorher hier)
              if(type == 'file') {
                var t = self.checkTypeFromFileName($scope.currentTaskAnswer);
                callback([{URL: $scope.fileURL, Type: t, Requested:type, Name: $scope.fileName}]);
              }
              if(type == "image" || type == "annotation" || type == "drawing" || type == "avatar" || type == "icon") {
                callback([{URL: $scope.imageURL, Type: "image", Requested:type, Name: $scope.imageFilename}]);
              }
            }

            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function() {
            if(($scope.capture && $scope.capture.recording) || 
               ($scope.capture && $scope.capture.startRecording) || 
               ($scope.capture && $scope.capture.processing)) return; // no cancel now
            self.closeDialog($scope.dialogElement);
          };
        }
      });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Tasks
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.searchLearningApp = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "searchlearningapp.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.apps = [];
          $scope.categories = [];
          $scope.searchText = "";
          $scope.searchCategory = "";
          $scope.didSearch = false;
          $scope.openApp = null;

          $scope.fetchApps = function(){
            $scope.openApp = null;
            $http({
                  method  : 'GET',
                  url     : 'https://learningapps.org/api.php',
                  timeout : 10000,
                  params  : {"lang":"DE","from":"LearningView","search":$scope.searchText,"category":$scope.searchCategory, "user":self.user.UID, "access":self.user.AID},  // Query Parameters (GET)
                  transformResponse : function(data) {
                      // string -> XML document object
                      var xml = $.parseXML(data);
                      xml = xml.children.item(0); // root element;
                      var results = [];
                      for (var i = 0; i < xml.children.length; i++) {
                        var obj = {};
                        var item = xml.children.item(i);
                        for (var z = 0; z < item.attributes.length; z++){
                          var a = item.attributes.item(z);
                          obj[a.name] = a.value;
                        }
                        results.push(obj);
                      }
                      return results;
                  }
              }).then(function(result, status, headers, config) {
                  var data = result.data;
                  $scope.apps = data;
                  $scope.didSearch = true;
              },function(data, status, headers, config) {
                  $window.alert("Error");
              });
          };

          $scope.fetchCategories = function(){
            $http({
                  method  : 'GET',
                  url     : 'https://learningapps.org/api.php',
                  timeout : 10000,
                  params  : {"lang":"DE","getcategories":"1", "user":self.user.UID, "access":self.user.AID},  // Query Parameters (GET)
                  transformResponse : function(data) {
                      // string -> XML document object
                      var xml = $.parseXML(data);
                      xml = xml.children.item(0); // root element;
                      var results = [];
                      for (var i = 0; i < xml.children.length; i++) {
                        var obj = {};
                        var item = xml.children.item(i);
                        for (var z = 0; z < item.attributes.length; z++){
                          var a = item.attributes.item(z);
                          obj[a.name] = a.value;
                        }
                        results.push(obj);
                      }
                      return results;
                  }
              }).then(function(result, status, headers, config) {
                  var data = result.data;
                  data.unshift({id:"",name:"Alle Kategorien"});
                  $scope.categories = data;
              },function(data, status, headers, config) {
                  $window.alert("Error");
              });
          };

          $scope.fetchCategories();
          $scope.fetchApps();

          $scope.ok = function(a){
            deferred.resolve(a);
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function(s){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };


    self.searchEduloPage = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "searchedulo.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.bundles = [];
          $scope.categories = [];
          $scope.searchText = "";
          $scope.searchCategory = "All";
          $scope.didSearch = false;
          $scope.currentOpenBundle = null;

          $scope.fetchBundleByCode = function(code){
            $http({
                  method  : 'GET',
                  url     : 'https://content.edulo.com/api/getStoreBundles.php',
                  timeout : 10000,
                  params  : {"from":"LearningView","code":code, "user":self.user.UID, "access":self.user.AID},  // Query Parameters (GET)
              }).then(function(result, status, headers, config) {
                  if(result.data.result == "OK"){
                    $scope.bundles = [result.data.bundle];
                    $scope.didSearch = true;
                    if($scope.bundles.length > 0)
                       $scope.currentOpenBundle = $scope.bundles[0];
                  }else{
                    if(result.data.error == "PAIDBUNDLE")
                      self.alert("Es können derzeit nur kostenfreie Bücher auf diesem Weg gewählt werden.");
                    else
                      self.alert("Kein Buch zu diesem Code gefunden.");
                  }
              },function(data, status, headers, config) {
                  $window.alert("Error");
              });
          };

          $scope.fetchBundles = function(){
            $scope.currentOpenBundle = null;
            var searchString = "";
            var s = $.trim($scope.searchText).split(" ");
            var inBracket = false;
            for(var i=0; i < s.length; i++){
              if(s[i] === "") continue;

              if(s[i][0] == "(") inBracket = true;
              if(inBracket)
                searchString += (s[i][0] == "(" ? "+":"") + s[i]+ (s[i][0] == "(" ? "* ":" "); else
                searchString += '+'+s[i]+"* ";

              if(s[i][s[i].length-1] == ")") inBracket = false;
            }
            $http({
                  method  : 'GET',
                  url     : 'https://content.edulo.com/api/getStoreBundles.php',
                  timeout : 10000,
                  params  : {"from":"LearningView","level":"All","search":searchString,"subject":$scope.searchCategory, 
                             "user":self.user.UID, "access":self.user.AID},  // Query Parameters (GET)
              }).then(function(result, status, headers, config) {
                  $scope.bundles = result.data && result.data.bundles ? result.data.bundles : [];
                  // filter isFree
                  for(var i=0; i < $scope.bundles.length; i++){
                    if($scope.bundles[i].isFree != "1"){
                      $scope.bundles.splice(i,1);
                      i--;
                    }
                  }
                  $scope.didSearch = true;
              },function(data, status, headers, config) {
                  $window.alert("Error");
              });
          };

          $scope.fetchCategories = function(){
            $http({
                  method  : 'GET',
                  url     : 'https://content.edulo.com/api/getStoreBundles.php',
                  timeout : 10000,
                  params  : {"getSubjects":"1", "user":self.user.UID, "access":self.user.AID},  // Query Parameters (GET)
              }).then(function(result, status, headers, config) {
                  var subjects = result.data && result.data.subjects ? result.data.subjects : [];
                  subjects.unshift({ID:"All",Name:"Alle Fächer"});
                  $scope.categories = subjects;
              },function(data, status, headers, config) {
                  $window.alert("Error");
              });
          };

          $scope.fetchCategories();
          $scope.fetchBundles();
          $scope.openBundle = function(b){
            $scope.currentOpenBundle = b;
          };
          $scope.openWidget = function(w){
            $scope.currentOpenWidget = w;
          };
          $scope.ok = function(a){
            deferred.resolve(a);
            self.closeDialog($scope.dialogElement);
          };
          $scope.cancel = function(s){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.searchZebisPage = function(ev){
      var deferred = $q.defer();
      var onMessage = null;
      self.showDialog({
        templateUrl: "webiframe.html",
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        skipHide:true, // keep other dialog open
        onRemoving: function (event, removePromise) {
          if(onMessage) window.removeEventListener("message",onMessage);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          onMessage = function(event){
            var a = event.data;
            if(a && a.indexOf && a.indexOf("http") === 0){
              a = a.replace("?mode=LearningView","");
              deferred.resolve(a);
              $scope.ok();
            }
          };

          window.addEventListener("message", onMessage, false);
          $scope.url = "https://zebis.digital/tools/materialPicker?mode=LearningView&user="+self.user.UID+"&access="+self.user.AID;
          $scope.caption = "Zebis.digital";
          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };


    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getTaskTemplates = function(showEmpty){
      var templates = [];
      if(self.userViewData["TaskTemplates"]){
        var userTemplates = JSON.parse(self.userViewData["TaskTemplates"]);
        for(var k = 0; k < userTemplates.length; k++){
          if(!userTemplates[k] || userTemplates[k]["Name"] == '') continue;
          templates[parseInt(userTemplates[k].id)-1] = userTemplates[k];
        }           
      };
      // fill missings
      for(var i = 0; i < 16; i++){
        if(!templates[i]){
          templates[i] = { 
            id:i+1,
            Name:"",
            MainIcon:'fa fa-fw'
          }; 
        }
      }
      var addDefault = function(d){
        var found = false;
        for(var i=0; i < templates.length; i++){
          if(templates[i] && templates[i].default == d.default){
            for(var k in d){
              if(k == "id") continue;
              templates[i][k] = d[k];
            }
            found = true;
            break;
          }
        }
        if(!found){
          if(templates[d.id-1].Name === '') templates[d.id-1] = d;
        }
      }
      addDefault({ 
        id:1,
        default:1,
        Name:$filter('trans')('TYPEBOOKDESC'),
        MainIcon:'fa fa-book',
        changeTo:"book"
      });        
      addDefault({ 
        id:2,
        default:2,
        Name:$filter('trans')('TYPEWRITEDESC'),
        MainIcon:'fa fa-calendar-o fa-rotate-270',
        changeTo:"write"
      });        
      addDefault({ 
        id:3,
        default:3,
        Name:$filter('trans')('TYPESHEETDESC'),
        MainIcon:'fa fa-file-text',
        changeTo:"sheet"
      });        
      addDefault({ 
        id:4,
        default:4,
        Name:$filter('trans')('TYPEWEBLINKDESC'),
        MainIcon:'fa fa-globe',
        changeTo:"web"
      });        
      addDefault({ 
        id:5,
        default:5,
        Name:$filter('trans')('TYPETESTDESC'),
        MainIcon:'fa fa-graduation-cap',
        changeTo:"test"
      });        
      addDefault({ 
        id:6,
        default:6,
        Name:$filter('trans')('TYPESURVEYDESC'),
        MainIcon:'fa fa-question-circle',
        changeTo:"survey"
      }); 

      for(var i = 0; i < templates.length; i++){
        if(!showEmpty && templates[i].Name == ""){
          templates.splice(i,1);
          i--;
        }
      }
      return templates;
    }

    self.showTaskTextTemplate = function(t){
      // read only mode
      self.showTextEditor(t.Name,t.DataJSON.textTemplate,t,self.user,false,false,null,null,null,true,false);
    };

    self.editTaskTextTemplate = function(t){
      // remove existing doc id, so we can cancel the edit
      var regex = /<doc id="([^"]+)"><\/doc>/;
      var oldText = t.DataJSON.textTemplate ? t.DataJSON.textTemplate.replace(regex,"") : '';

      self.showTextEditor(t.Name,oldText,t,self.user,false,false,null,function(text){
        if(!text) return; // canceled
        var text = text.replace(regex,"");
        if(text == oldText) return; // nothing changed
        // save change to task now
        t.DataJSON.textTemplate = text;
        self.apiPost("ajax",{"action":"updateTask", "ID":t.ID,
                             "Data":angular.toJson(t.DataJSON)}).then(function(data) {
          self.keepAliveCallback();
        });
      },null,false,false);
    };

    self.showTasktNoteTemplate = function(t){
      // remove existing doc id, so we can cancel the edit

    };

    self.editTaskTextNoteTemplate = function(t){
      // remove existing doc id, so we can cancel the edit
      var regex = /<doc id="([^"]+)"><\/doc>/;
      var oldText = t.DataJSON.text ? t.DataJSON.text.replace(regex,"") : '';

      self.showTextEditor(t.Name,oldText,t,self.user,false,false,null,function(text){
        if(!text) return; // canceled
        var text = text.replace(regex,"");
        if(text == oldText) return; // nothing changed
        // save change to task now
        t.DataJSON.text = text;
        self.apiPost("ajax",{"action":"updateTask", "ID":t.ID,
                             "Data":angular.toJson(t.DataJSON)}).then(function(data) {
          self.keepAliveCallback();
        });
      },null,false,false);
    };

    self.showTaskNotesTemplate = function(t,ev){
      // read only mode
      if(t.ResultType == 'textnotes'){
        self.showTextEditor(t.Name,t.DataJSON.text,t,self.user,false,false,null,null,null,true,false);
      }else{
        // show audio or video
        var currentNotes = t.ResultType == "audionotes" ? t.DataJSON.audioNotes : t.DataJSON.videoNotes;
        self.showMediaNotesEditor(t.ResultType == "audionotes" ? t.DataJSON.audio : t.DataJSON.video,t,currentNotes,false,true,t.DataJSON.onlyEdit,true,ev).then(function(result){
        });
      }
    };

    self.editTaskNotesTemplate = function(t,ev){
      var currentNotes = t.ResultType == "audionotes" ? t.DataJSON.audioNotes : t.DataJSON.videoNotes;

      self.showMediaNotesEditor(t.ResultType == "audionotes" ? t.DataJSON.audio : t.DataJSON.video,t,currentNotes,true,false,false,true,ev).then(function(result){
        if(angular.toJson(currentNotes) != JSON.stringify(result.notes) || result.description != t.DataJSON.mediaDescription){
          if(result.description){
            t.DataJSON.mediaDescription = result.description;
          }else{
            if(t.DataJSON.mediaDescription) delete(t.DataJSON.mediaDescription);
          }
          if(t.ResultType == "audionotes"){
            t.DataJSON.audioNotes = result.notes;
          }
          if(t.ResultType == "videonotes"){
            t.DataJSON.videoNotes = result.notes;
          }
          self.apiPost("ajax",{"action":"updateTask", "ID":t.ID,
                               "Data":angular.toJson(t.DataJSON)}).then(function(data) {
            self.keepAliveCallback();
          });

        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.copiedScienceData = null;
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addEditTaskController = function($scope,$mdDialog){

      $scope.lastVersion = angular.toJson($scope.item);
      if($scope.item && $scope.item.MainIcon) self.updateLastUsedTaskIcons($scope.item.MainIcon);
      if($scope.item && $scope.item.Icon) self.updateLastUsedTaskIcons($scope.item.Icon);

      $scope.templates = self.getTaskTemplates();

      $scope.showSaveTaskTemplate = function(item,ev){
        self.showDialog({
          templateUrl: "saveTaskTemplate.html",
          skipHide:true, // keep other dialog open
          targetEvent: ev,
          clickOutsideToClose: true,
          onRemoving: function () {
            $scope.templates = self.getTaskTemplates();
          },
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.templates = self.getTaskTemplates(true);
            $scope.delete = function(index){
              self.confirm($filter('trans')('ASKDELETETASKTEMPLATE'),$filter('trans')('DELETE')).then(function(){
                var userTemplates = {};
                if(self.userViewData["TaskTemplates"]){
                  userTemplates = JSON.parse(self.userViewData["TaskTemplates"]);
                };
                delete userTemplates[index];
                self.userViewData["TaskTemplates"] = JSON.stringify(userTemplates);
                self.userViewData.hideTaskCreateSelect = false;
                self.updateUserViewData();
                $scope.templates = self.getTaskTemplates(true);
              });
            };

            $scope.saveTemplateOrder = function(){
              // order changed, save back
              var t = [];
              for(var i=0; i < $scope.templates.length; i++) {
                var c = JSON.parse(angular.toJson($scope.templates[i]));
                c.id = i+1;
                t.push(c);
              }
              self.userViewData["TaskTemplates"] = angular.toJson(t);
              self.updateUserViewData();
            };

            $scope.save = function(index) {
              var saveNow = function(){
                var t = [];
                for(var i=0; i < $scope.templates.length; i++) {
                  var c = JSON.parse(angular.toJson($scope.templates[i]));
                  c.id = i+1;
                  if(i == index){
                    var template = {};
                    template.Name = item.Name == "" ? 'Vorlage' : item.Name;
                    template.Description = item.Description;
                    template.MainIcon = item.MainIcon;
                    template.Data = item.Data;
                    template.Icon = item.Icon;
                    template.Color = item.Color;
                    template.Social = item.Social;
                    template.Level = item.Level;
                    template.Time = item.Time;
                    template.CheckType = item.CheckType;
                    template.ResultType = item.ResultType;
                    template.Data = item.Data;
                    template.changeTo = item.Type;
                    template.id = index+1;    
                    c = template;              
                  }
                  t.push(c);
                }
                self.userViewData["TaskTemplates"] = angular.toJson(t);
                self.userViewData.hideTaskCreateSelect = false;
                self.updateUserViewData();
                self.closeDialog($scope.dialogElement);
              };

              if($scope.templates[index].Name != ''){
                self.confirm($filter('trans')('ASKOVERRIDETEMPLTE'),$filter('trans')('REPLACE')).then(function(){
                  saveNow();
                });
              }else saveNow();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };

      $scope.showEditTaskTemplates = function(ev){
        self.showDialog({
          templateUrl: "editTaskTemplates.html",
          skipHide:true, // keep other dialog open
          targetEvent: ev,
          clickOutsideToClose: true,
          onRemoving: function () {
            $scope.templates = self.getTaskTemplates();
          },
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.templates = self.getTaskTemplates(true);
            $scope.delete = function(index){
              self.confirm($filter('trans')('ASKDELETETASKTEMPLATE'),$filter('trans')('DELETE')).then(function(){
                var userTemplates = {};
                if(self.userViewData["TaskTemplates"]){
                  userTemplates = JSON.parse(self.userViewData["TaskTemplates"]);
                };
                delete userTemplates[index];
                self.userViewData["TaskTemplates"] = JSON.stringify(userTemplates);
                self.userViewData.hideTaskCreateSelect = false;
                self.updateUserViewData();
                $scope.templates = self.getTaskTemplates(true);
              });
            };

            $scope.saveTemplateOrder = function(){
              // order changed, save back
              var t = [];
              for(var i=0; i < $scope.templates.length; i++) {
                var c = JSON.parse(angular.toJson($scope.templates[i]));
                c.id = i+1;
                t.push(c);
              }
              self.userViewData["TaskTemplates"] = angular.toJson(t);
              self.updateUserViewData();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };
      $scope.createFromTaskTemplate = function(template,ev){
        $scope.changeItemType(template.changeTo,ev); 
        for(var k in template){
          if(k == "default") continue; // skip this
          if(k == "changeTo") continue; // skip this
          $scope.item[k] = template[k];
          if(k == "Data") $scope.item["DataJSON"] = JSON.parse($scope.item["Data"]);
        }
      };

      $scope.addHintsFromFiles = function(multipleAnswers) {
        // check if we have a ng-wig as target 
        if(document.activeElement && $(document.activeElement).parent(".nw-editor").length == 1){
          // insert the content 
          for(var i = 0; i < multipleAnswers.length; i++) {
            var html = "";
            if(multipleAnswers[i].Type == "image"){
              html = '<br><img src="'+multipleAnswers[i].URL+'"><br>';
            }
            if(multipleAnswers[i].Type == "audio"){
              html = '<b class="fa fa-fw fa-volume-up inlineAudio" src="'+multipleAnswers[i].URL+'"></b> ';
            }
            if(multipleAnswers[i].Type == "video"){
              html = '<br><video controls controlslist="nodownload" class="inlineVideo" src="'+multipleAnswers[i].URL+'"></video><br>';
            }
            if(html != ""){
              pasteHtmlAtCaret(html);
              multipleAnswers.splice(i,1);
              i--;
            }
          }
        }
        for(var i = 0; i < multipleAnswers.length; i++) {
          if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];

          if(multipleAnswers[i].Text) {            
            $scope.item.DataJSON.hints.push({'type':'text','Text':multipleAnswers[i].Text});
          }
          else {
            var actualType = 'file';

            if(multipleAnswers[i].Type)
              actualType = multipleAnswers[i].Type;

            if(actualType == 'file' && multipleAnswers[i].Name)
              actualType = self.checkTypeFromFileName(multipleAnswers[i].Name);

            if(multipleAnswers[i].Requested && multipleAnswers[i].Requested == 'file') actualType = 'file';

            if(actualType != 'file')
              $scope.item.DataJSON.hints.push({'type':actualType,'URL':multipleAnswers[i].URL});
            else
              $scope.item.DataJSON.hints.push({'type': 'file','URL':multipleAnswers[i].URL, 'name':multipleAnswers[i].Name});
          }
        }
      }

      $scope.askDeleteQuestion = function(list,index,ev){
        self.confirm($filter('trans')('ASKDELETEQUESTION'),$filter('trans')('DELETE'),ev).then(function(){
          list.splice(index,1);
        });
      };

      $scope.close = function(ev) {
        if($scope.lastVersion != angular.toJson($scope.item)){
          // ask for save now
          self.confirm($filter('trans')('ASKTASKSAVE'),$filter('trans')('DISCARD'),ev,$filter('trans')('BACK')).then(function(){
            self.closeDialog($scope.dialogElement);
          });
        }else self.closeDialog($scope.dialogElement);
      };

      $scope.addCustomIcon = function(item,property,ev){
        // show image dialog and upload a small image to "addCustomIcon"
        self.takeUserMedia("icon",null,function(results){
          self.apiPost("ajax",{"action":"addCustomIcon", "image":results[0].URL})
            .then(function(data) {
              item[property] = data.icon + (results[0].isFull ? ' cifull':'');
              self.updateLastUsedTaskIcons(data.icon);
            });
        }, {dialogMode: 0, allowFull:property == "MainIcon"});
      };

      $scope.tryReadURLFromClipboard = function(){
        readTextFromClipboard(function(clip){
          var testUrl = clip.match(/(https?:[^\s]+)/);
          var url = testUrl && testUrl[1] ? testUrl[1] : "";
          url = url.replace(/['"]$/,""); // remove " at the end, if it was inside a src="" 
          if(url.length > 5 && url[url.length-1] == '"')
          if(!$scope.item.DataJSON.URL || $scope.item.DataJSON.URL == "") $scope.item.DataJSON.URL = url;
        });
      };

      $scope.changeItemType = function(type,ev){
        if($scope.item.Type == type) return;
        if($scope.isEdit){
          // ask confirm task type change
          if($scope.isEditAskedItemTypeChange)
            $scope.changeItemTypeNow(type); else
            self.confirm($filter('trans')('ASKCONFIRMTASKTYPECHANGE'),'<span style="color:red">'+$filter('trans')('CHANGE')+'</span>',ev).then(function(){
              $scope.isEditAskedItemTypeChange = true;
              $scope.changeItemTypeNow(type);
            });
        }else $scope.changeItemTypeNow(type);
      };

      $scope.checkForPopupURL = function(hint){
        var url = hint.URL;
        if((url.toLowerCase().match(/^https?:\/\/(www\.)?youtube\.com/) || url.toLowerCase().match(/\/\/youtu\.be/)) &&
           !url.toLowerCase().match(/channel/) && !url.toLowerCase().match(/\/c\//)){
          hint.popup = true;
          return;
        }
        // embed code case
        if(url.length > 0 && url[0] == '\u003c') {
          hint.popup = true;
          return;
        }

        $.getJSON("https://learningview.org/api/xframe.php?url="+encodeURIComponent(url),function(data){
          if(data && !data.error){
            hint.popup = true;
          }
          if(data && data.error){
            hint.popup = false;
          }
        });        
      };

      $scope.changeItemTypeNow = function(type){
        var old = $scope.item.Type;
        $scope.item.Type = type;
        if(old == type) return;

        delete $scope.item.MainIcon;

        // delete unused hints
        if($scope.item.DataJSON.hints)
        for(var i=0; i < $scope.item.DataJSON.hints.length; i++){
          if($scope.item.DataJSON.hints[i].type == "text" && $scope.item.DataJSON.hints[i].Text == ""){
            $scope.item.DataJSON.hints.splice(i,1);
            i--;
          }else
          if($scope.item.DataJSON.hints[i].type != "text" && $scope.item.DataJSON.hints[i].URL == ""){
            $scope.item.DataJSON.hints.splice(i,1);
            i--;
          }
        }
        if(type == "task"){
          $scope.item.MainIcon = "fa fa-cube";
        }
        if(type == "book"){
          $scope.item.MainIcon = "fa fa-book";
        }
        if(type == "write"){
          $scope.item.MainIcon = "fa fa-calendar-o fa-rotate-270";
        }
        if(type == "sheet"){
          $scope.item.MainIcon = "fa fa-file-text";
          /*
          $scope.item.ResultType = "annotation";
          $scope.item.DataJSON.annotationImage = "";
          self.takeUserMedia("annotation",$scope.item.DataJSON.annotationImage,
          function(result){
            $scope.item.DataJSON.annotationImage = result;
          },true);
          */
        }
        if(type == "web"){
          $scope.item.MainIcon = "fa fa-globe";
          if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
          var hasLink = false;
          for(var i=0; i < $scope.item.DataJSON.hints.length; i++){
            if($scope.item.DataJSON.hints[i].type == 'url') hasLink = true;
          }
          if(!hasLink)
            $scope.takeMedia("url");
        }

        if(type == "collection"){
          $scope.item.MainIcon = "fa fa-th";
          $scope.item.DataJSON.MaxItems = 0;
          $scope.item.DataJSON.MinItems = 1;
          $scope.item.DataJSON.Anonymous = '1';
          $scope.item.DataJSON.Public = '0';
          $scope.item.DataJSON.collectText = 1;
          $scope.item.DataJSON.collectImage = 1;
          $scope.item.DataJSON.collectAudio = 1;
          $scope.item.DataJSON.collectVideo = 1;
          $scope.item.DataJSON.collectFile = 1;
          $scope.item.DataJSON.collectLink = 1;
          $scope.item.ResultType = 'none';
          if($scope.item.Social == "input") $scope.item.Social = "single";
        }

        if(type == "learningapp"){
          $scope.item.MainIcon = "fa fa-lightbulb-o";
          $scope.item.DataJSON.source = $scope.item.DataJSON.source || 'la';
          if($scope.item.DataJSON.source == "la")              
            $scope.item.CheckType = 'self';
          $scope.tryReadURLFromClipboard();
        }

        if(type == "test"){
          $scope.item.MainIcon = "fa fa-graduation-cap";
          if($scope.item.Name == "") $scope.item.Name = $filter('trans')('TYPETEST');
          if(old == "survey"){
            // clean/change questions
            for(var i=0; i < $scope.item.DataJSON.questions.length; i++){
              if($scope.item.DataJSON.questions[i].type == "poll"){
                 $scope.item.DataJSON.questions[i].type = "mc";
              }else
              if($scope.item.DataJSON.questions[i].type == "input"){
                if(!$scope.item.DataJSON.questions[i].answers)
                  $scope.item.DataJSON.questions[i].answers = [{text:''}];
                 $scope.item.DataJSON.questions[i].mode = 'eq';
              }else{
                // all others
                $scope.item.DataJSON.questions[i].type = "mc";
              }
            }
          }else{
            $scope.item.DataJSON.questions = [];
          }
          $scope.item.DataJSON.repeatTime = 0;
          $scope.item.DataJSON.showSolution = 1;
          $scope.item.DataJSON.randomOrder = 0;
          $scope.item.DataJSON.randomAnswerOrder = 1;
          $scope.item.DataJSON.timeLimit = 0;
          $scope.item.Social='single';
          $scope.item.CheckType = 'self';
          $scope.item.Time = '0';
        }

        if(type == "survey"){
          $scope.item.MainIcon = "fa fa-question-circle";
          if($scope.item.Name == "") $scope.item.Name = $filter('trans')('TYPESURVEY');
          if(old == "test"){
            // clean/change questions
            for(var i=0; i < $scope.item.DataJSON.questions.length; i++){
              if($scope.item.DataJSON.questions[i].type == "mc")
                 $scope.item.DataJSON.questions[i].type = "poll";
            }
          }else{
            $scope.item.DataJSON.questions = [];
          }
          $scope.item.DataJSON.Anonymous = '1';
          $scope.item.DataJSON.Public = '1';
          $scope.item.DataJSON.Retake = '1';
          $scope.item.CheckType = 'self';
          if($scope.item.Social == "input") $scope.item.Social = "single";
        }
      };

      $scope.importTestMCQuestions = function(ev){
        var deferred = $q.defer();
        var parent = $scope;
        self.showDialog({
          templateUrl: "importTestMCQuestions.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.import = function() {
              if(!$scope.importData) return;
              var hasEmptyLine = true;
              var lines = $scope.importData.replace(/\r/g,"").split("\n\n\n");

              if(lines.length > 1)
                lines = $scope.importData.replace(/\r/g,"").replace(/\n\n/g,"\n").split("\n\n");
              else
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");

              var splitAt = "\n";
              if(lines.length == 1){
                splitAt = "";
                var hasSemi = false;
                var hasTab = false;
                var hasLine = false;
                lines = $scope.importData.replace(/\r/g,"").split("\n");
                for(var i=0; i < lines.length; i++){
                  var s = $.trim(lines[i]);
                  if(s === "") continue;
                  if(s.indexOf(";") != -1 && s.split(";").length > 1) hasSemi = true;
                  if(s.indexOf("\t") != -1 && s.split("\t").length > 1) hasTab = true;
                  if(s.indexOf("|") != -1 && s.split("|").length > 1) hasLine = true;
                }                
                if(hasSemi) splitAt = ";";
                if(hasLine) splitAt = "|";
                if(hasTab) splitAt = "\t";
              }

              if(splitAt == ""){
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");
                splitAt = "\n";
              }
              var added = 0;
              for(var i=0; i < lines.length; i++){
                var s = $.trim(lines[i]);
                if(s === "") continue;

                var parts = s.split(splitAt);
                while(parts.length > 0 && $.trim(parts[0]) == "") parts.shift();
                while(parts.length > 0 && $.trim(parts[parts.length-1]) == "") parts.pop();
                if(parts.length == 0) continue;

                var answers = [];
                for(var p = 1; p < parts.length; p++){
                  answers.push({'text':$.trim(parts[p]),'correct':p == 1});
                }
                if(answers.length == 0){
                  answers.push({'text':'','correct':true});
                  answers.push({'text':'','correct':false});
                  answers.push({'text':'','correct':false});
                  answers.push({'text':'','correct':false});
                }

                parent.item.DataJSON.questions.push({'type':'mc','q': $.trim(parts[0]),'correctIndex':'0', 'answers': answers});
                added++;
              }
              if(added == 0){
                self.alert($filter('trans')('IMPORTMCQUESTIONFORMAT'));
                return;                
              }

              self.closeDialog($scope.dialogElement);
              deferred.resolve();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
        return deferred.promise;
      };

      $scope.importTestInputs = function(ev){
        var deferred = $q.defer();
        var parent = $scope;
        self.showDialog({
          templateUrl: "importTestInputs.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.import = function() {
              if(!$scope.importData) return;
              var hasEmptyLine = true;
              var lines = $scope.importData.replace(/\r/g,"").split("\n\n\n");

              if(lines.length > 1)
                lines = $scope.importData.replace(/\r/g,"").replace(/\n\n/g,"\n").split("\n\n");
              else
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");

              var splitAt = "\n";
              if(lines.length == 1){
                splitAt = "";
                var hasSemi = false;
                var hasTab = false;
                var hasLine = false;
                lines = $scope.importData.replace(/\r/g,"").split("\n");
                for(var i=0; i < lines.length; i++){
                  var s = $.trim(lines[i]);
                  if(s === "") continue;
                  if(s.indexOf(";") != -1 && s.split(";").length > 1) hasSemi = true;
                  if(s.indexOf("\t") != -1 && s.split("\t").length > 1) hasTab = true;
                  if(s.indexOf("|") != -1 && s.split("|").length > 1) hasLine = true;
                }                
                if(hasSemi) splitAt = ";";
                if(hasLine) splitAt = "|";
                if(hasTab) splitAt = "\t";
              }

              if(splitAt == ""){
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");
                splitAt = "\n";
              }
              var added = 0;
              for(var i=0; i < lines.length; i++){
                var s = $.trim(lines[i]);
                if(s === "") continue;

                var parts = s.split(splitAt);
                while(parts.length > 0 && $.trim(parts[0]) == "") parts.shift();
                while(parts.length > 0 && $.trim(parts[parts.length-1]) == "") parts.pop();
                if(parts.length == 0) continue;

                var answers = [];
                for(var p = 1; p < parts.length; p++){
                  answers.push({'text':$.trim(parts[p])});
                }
                if(answers.length == 0){
                  answers.push({'text':''});
                }

                parent.item.DataJSON.questions.push({'type':'input','q': $.trim(parts[0]),'mode':'eq', 'answers': answers});
                added++;
              }
              if(added == 0){
                self.alert($filter('trans')('IMPORTMCQUESTIONFORMAT'));
                return;                
              }

              self.closeDialog($scope.dialogElement);
              deferred.resolve();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
        return deferred.promise;
      };

      $scope.importTestOrders = function(ev){
        var deferred = $q.defer();
        var parent = $scope;
        self.showDialog({
          templateUrl: "importTestOrders.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.import = function() {
              if(!$scope.importData) return;
              var hasEmptyLine = true;
              var lines = $scope.importData.replace(/\r/g,"").split("\n\n\n");

              if(lines.length > 1)
                lines = $scope.importData.replace(/\r/g,"").replace(/\n\n/g,"\n").split("\n\n");
              else
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");

              var splitAt = "\n";
              if(lines.length == 1){
                splitAt = "";
                var hasSemi = false;
                var hasTab = false;
                var hasLine = false;
                lines = $scope.importData.replace(/\r/g,"").split("\n");
                for(var i=0; i < lines.length; i++){
                  var s = $.trim(lines[i]);
                  if(s === "") continue;
                  if(s.indexOf(";") != -1 && s.split(";").length > 1) hasSemi = true;
                  if(s.indexOf("\t") != -1 && s.split("\t").length > 1) hasTab = true;
                  if(s.indexOf("|") != -1 && s.split("|").length > 1) hasLine = true;
                }                
                if(hasSemi) splitAt = ";";
                if(hasLine) splitAt = "|";
                if(hasTab) splitAt = "\t";
              }

              if(splitAt == ""){
                lines = $scope.importData.replace(/\r/g,"").split("\n\n");
                splitAt = "\n";
              }
              var added = 0;
              for(var i=0; i < lines.length; i++){
                var s = $.trim(lines[i]);
                if(s === "") continue;

                var parts = s.split(splitAt);
                while(parts.length > 0 && $.trim(parts[0]) == "") parts.shift();
                while(parts.length > 0 && $.trim(parts[parts.length-1]) == "") parts.pop();
                if(parts.length == 0) continue;

                var answers = [];
                for(var p = 1; p < parts.length; p++){
                  answers.push({'text':$.trim(parts[p])});
                }
                if(answers.length == 0){
                  answers.push({'text':''});
                }

                parent.item.DataJSON.questions.push({'type':'order','q': $.trim(parts[0]), 'answers': answers});
                added++;
              }
              if(added == 0){
                self.alert($filter('trans')('IMPORTMCQUESTIONFORMAT'));
                return;                
              }

              self.closeDialog($scope.dialogElement);
              deferred.resolve();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
        return deferred.promise;
      };

      $scope.importTestKnowQuestions = function(ev){
        var deferred = $q.defer();
        var parent = $scope;
        self.showDialog({
          templateUrl: "importTestKnowQuestions.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;

            $scope.import = function() {
              if(!$scope.importData) return;
              var lines = $scope.importData.split("\n");
              var hasSemi = false;
              var hasTab = false;
              var hasComma = false;
              var hasSpace = false;
              for(var i=0; i < lines.length; i++){
                var s = $.trim(lines[i]);
                if(s === "") continue;
                if(s.indexOf(";") != -1 && s.split(";").length == 2) hasSemi = true;
                if(s.indexOf("\t") != -1 && s.split("\t").length == 2) hasTab = true;
                if(s.indexOf(",") != -1 && s.split(",").length == 2) hasComma = true;
              }
              var splitAt = "";
              if(hasComma) splitAt = ",";
              if(hasTab) splitAt = "\t";
              if(hasSemi) splitAt = ";";
              if(splitAt == ""){
                self.alert($filter('trans')('IMPORTKNOWQUESTIONFORMAT'));
                return;
              }
              for(var i=0; i < lines.length; i++){
                var s = $.trim(lines[i]);
                if(s === "") continue;
                var parts = s.split(splitAt);
                if(parts.length == 2)
                  parent.item.DataJSON.questions.push({'type':'know','q': $.trim(parts[0]),'answer': $.trim(parts[1]) });
              }

              self.closeDialog($scope.dialogElement);
              deferred.resolve();
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
        return deferred.promise;
      };

      $scope.changeResultType = function(oldValue){
        if(oldValue == 'none' && $scope.item.ResultType != 'none'){
          if($scope.item.CheckType == 'self'){
            $scope.item.CheckType = "teacher";
          }
        }
        if($scope.item.ResultType == 'audionotes' || $scope.item.ResultType == 'videonotes'){
          if(typeof $scope.item.DataJSON.onlyEdit == "undefined"){
            $scope.item.DataJSON.onlyEdit = 0;
          }          
        }
      };

      $scope.takeTaskResultMedia = function(type,e){
        if(type == "annotation" || type == "drawing")
          self.takeUserMedia("image",$scope.item.DataJSON.annotationImage,
          function(results){
            $scope.item.DataJSON.annotationImage = results[0].URL;
          }, {dialogMode: 1});

        if(type == "videonotes")
          self.takeUserMedia("video",$scope.item.DataJSON.video,
          function(results){
            $scope.item.DataJSON.video = results[0].URL;
          }, {dialogMode: 1});

        if(type == "audionotes")
          self.takeUserMedia("audio",$scope.item.DataJSON.audio,
          function(results){
            $scope.item.DataJSON.audio = results[0].URL;
          }, {dialogMode: 1});

        if(type == "textnotes"){
          var regex = /<doc id="([^"]+)"><\/doc>/;
          // remove an existing doc id  
          var oldText = $scope.item.DataJSON.text ? $scope.item.DataJSON.text.replace(regex,"") : '';

          self.takeUserMedia("textonly",oldText,function(results){
            if(results !== null){
              if(self.isEmptyHTMLText(results[0].Text))
                delete $scope.item.DataJSON.text; else
                $scope.item.DataJSON.text = results[0].Text.replace(regex,"");
            }
          }, {dialogMode: 0});          
        }

        if(type == "texttemplate"){
          var regex = /<doc id="([^"]+)"><\/doc>/;
          // remove an existing doc id  
          var oldText = $scope.item.DataJSON.textTemplate ? $scope.item.DataJSON.textTemplate.replace(regex,"") : '';

          self.takeUserMedia("textonly",oldText,function(results){
            if(results !== null){
              if(self.isEmptyHTMLText(results[0].Text))
                delete $scope.item.DataJSON.textTemplate; else
                $scope.item.DataJSON.textTemplate = results[0].Text.replace(regex,"");
            }
          }, {dialogMode: 0});          
        }

        if(type == "annotationempty" ||
           type == "annotationempty2"||
           type == "annotationempty3"||
           type == "annotationempty4"){
          // make copy of empty image
          try {
            var xhr = new XMLHttpRequest();
            xhr.open("GET", "https://learningview.org/imageeditor/emptyPage"+(type == "annotationempty2" ? "2":(type == "annotationempty3" ? "3" : (type == "annotationempty4" ? "4" : "")))+".png?r="+Math.random());
            xhr.responseType = "blob";
            xhr.onerror = function() { };
            xhr.onload = function() {
              if (xhr.status === 200) {
                self.uploadFile(xhr.response,
                  "emptyPage.png", self.getMediaID(),'image',null,function(filename){
                  $scope.item.DataJSON.annotationImage = filename;
                });
              }
            };
            xhr.send();
          }catch(e){}
        }
      };

      $scope.openAttachment = function(hint, ev) {
        if(hint.type == 'file' || hint.type == 'url'){
          var t = self.checkTypeFromFileName(hint.URL);
          if(t == "image" || t == "audio" || t == "video"){
            self.showTaskMedia(t,hint,ev,true);
          }else
            self.openWeblink({DataJSON:hint,ID:$scope.item.ID},ev,'auto');
        }
        else
        if(hint.type == 'text'){
          if(hint.Collaborate == 1 && $scope.isEdit){
            self.confirm($filter('trans')('CLASSDOCUMENTATTASKCONFIRMCHANGE'),$filter('trans')('YES') ,ev, $filter('trans')('NO')).then(function(){
              $scope.takeMedia('text',null,hint);
            });
          }else
            $scope.takeMedia('text',null,hint);
        }
        else
        if(hint.type == 'folder')
          $scope.takeMedia('folder',null,hint);
        else
        if(hint.type == 'ref')
          $scope.takeMedia('ref',null,hint);
        else
        if(hint.type == "rubric") {
          var r = self.getRubricByGUID(hint.rubric); 
          if(r){
            r = JSON.parse(angular.toJson(r));
            if(hint.text && hint.text != '') r.Name = hint.text;
            self.showRubric(r, self.user, null, null, $scope.item, ev);
          } else {
            self.alert($filter('trans')('RUBRICWASNOTFOUND'));
          }
        }else
        if(hint.type == "flashcards"){
          self.loadFlashCardData().then(function(){
            var set = null;
            if(hint.ID) set = self.getFlashCardSetByID(hint.ID);
            if(!set && hint.flashcards) set = self.getFlashCardSetByGUID(hint.flashcards);
            if(!set || !set.Set){
              $scope.takeMedia('flashcards', null, hint);
              return;
            }

            var updateHintFromSavedSet = function(savedSet){
              if(!savedSet || !savedSet.Set) return;
              hint.ID = savedSet.Set.ID;
              hint.flashcards = savedSet.Set.GUID;
              if(!hint.text || $.trim(hint.text) === "") hint.text = savedSet.Set.Name;
            };

            if(set.Set.Owner == self.user.ID){
              self.openFlashCardSetEditorDialog({
                set: set, ev: ev, knownSets: self.flashCardSets
              }).then(function(savedSet){
                updateHintFromSavedSet(savedSet);
              }, function(){});
            }else{
              self.confirm($filter('trans')('FLASHCARDS_SET_COPY_CONFIRM'), $filter('trans')('FLASHCARDS_SET_COPY_ACTION'), ev, $filter('trans')('CANCEL')).then(function(){
                self.openFlashCardSetEditorDialog({
                  createMode: true, ev: ev, knownSets: self.flashCardSets,
                  prefill: {
                    name: (set.Set.Name || "") + " " + $filter('trans')('FLASHCARDS_COPY_SUFFIX'),
                    category: set.Set.Category || "",
                    cards: set.Set.cards || []
                  }
                }).then(function(savedSet){
                  updateHintFromSavedSet(savedSet);
                }, function(){});
              });
            }
          });
        }else
          self.showTaskMedia(hint.type,hint,ev,true);

        if(self.user.Teacher == 1 && hint.URL) {
          var attributes = {};
          attributes.isUpload = false;
          attributes.url = hint.URL;
          attributes.type = hint.type;

          if(hint.name && hint.name != '') attributes.name = hint.name;
          else attributes.name = self.getFilenameFromURL(hint.URL);

          if(hint.type == 'audio') {
            var audio = new Audio();
            audio.src = attributes.url;

            $(audio).on("loadedmetadata", function(){
                var audioDuration = Math.ceil(audio.duration.toString());
                attributes.duration = audioDuration;
                self.addToRecentFiles(attributes);
            });
          }
          else
            self.addToRecentFiles(attributes);
        }
        else
          void(0);
      }

      $scope.takeMedia = function(type,e, edit){
        if(edit){
          // attachments that can be changed / edited again
          if(type == "text"){
            var regex = /<doc id="([^"]+)"><\/doc>/;
            // remove an existing doc id  
            var oldText = edit.Text.replace(regex,"");

            self.takeUserMedia("textonly",oldText,function(results){
              edit.Text = results[0].Text;
            }, {dialogMode: 0});
          }

          if(type == "ref")
            self.takeUserMedia("ref",edit,function(results){
              if(results[0].Type == "task"){
                delete edit.goalid;
                edit.taskid = results[0].ID;
                edit.URL = "https://learningview.org/m"+results[0].ID;
              }
              if(results[0].Type == "goal"){
                delete edit.taskid;
                edit.goalid = results[0].ID;
                edit.URL = "https://learningview.org/g"+results[0].ID;
              }
            }, {dialogMode: 0});

          if(type == "folder")
            self.takeUserMedia("folder",edit,function(results){
              edit.ID = null; // reset
              var keys = ["ID","Share","Feedback","Name", "Color", "Icon"];
              for(var k in results[0].Folder) if(keys.indexOf(k) != -1) edit[k] = results[0].Folder[k];
            }, {dialogMode: 0, allowCreate:self.user.Teacher == 1});
          
          return;
        }

        // .text is used for button text, .Text for text content
        if(type == "text")
          self.takeUserMedia("textonly",null,$scope.addHintsFromFiles, {dialogMode: 0});
        if(type == "image")
          self.takeUserMedia("image",null,$scope.addHintsFromFiles, {dialogMode:0, allowMultiple: true});
        if(type == "file")
          self.takeUserMedia("file",null,$scope.addHintsFromFiles, {dialogMode:0, allowMultiple: true});
        if(type == "audio")
          self.takeUserMedia("audio",null,$scope.addHintsFromFiles, {dialogMode:1, allowMultiple: true});
        if(type == "video")
          self.takeUserMedia("video",null,$scope.addHintsFromFiles, {dialogMode:1, allowMultiple: true});

        if(type == "url"){
          if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
          $scope.item.DataJSON.hints.push({'type':'url','URL':""});
          // 
          readTextFromClipboard(function(clip){
            var testUrl = clip.match(/(https?:[^\s]+)/);
            var url = testUrl && testUrl[1] ? testUrl[1] : "";
            $scope.item.DataJSON.hints[$scope.item.DataJSON.hints.length-1].URL = url;
            $scope.checkForPopupURL($scope.item.DataJSON.hints[$scope.item.DataJSON.hints.length-1]);
          });
        }

        if(type == "ref"){
          self.takeUserMedia("ref",null,function(results){
            if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
            var edit = {type:"ref"};
            if(results[0].Type == "task"){
              edit.taskid = results[0].ID;
              edit.URL = "https://learningview.org/m"+results[0].ID;
            }
            if(results[0].Type == "goal"){
              edit.goalid = results[0].ID;
              edit.URL = "https://learningview.org/g"+results[0].ID;
            }
            $scope.item.DataJSON.hints.push(edit);
          }, {dialogMode: 0});
        }
        if(type == "folder"){
          self.takeUserMedia("folder",null,function(results){
            if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
            var edit = {type:"folder"};
            var keys = ["ID","Share","Feedback","Name", "Color", "Icon"];
            for(var k in results[0].Folder) if(keys.indexOf(k) != -1) edit[k] = results[0].Folder[k];
            $scope.item.DataJSON.hints.push(edit);
          }, {dialogMode: 0, allowCreate:self.user.Teacher == 1});
        }
        if(type == "rubric"){
          self.pickRubrics(null,true,function(results,wasCreated){
            var selectedRubric = self.getRubricByID(results[0]);
            if(!selectedRubric || !selectedRubric.GUID) return;
            if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
            var hint = {type:"rubric", rubric:selectedRubric.GUID, linked:1};
            // if rubric was selected from elsewhere, mark as link
            if(wasCreated){
              if(wasCreated[selectedRubric.ID]){
                delete(hint.linked); // no link
              }
            }
            $scope.item.DataJSON.hints.push(hint);
          },{type:"task", task:$scope.item});
        }
        if(type == "flashcards"){
          self.pickFlashcards(null, true, function(results){
            if(!results || !results[0]) return;
            var selectedSet = self.getFlashCardSetByID(results[0]);
            if(!selectedSet || !selectedSet.Set) return;
            if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
            $scope.item.DataJSON.hints.push({
              type:"flashcards",
              ID:selectedSet.Set.ID,
              flashcards:selectedSet.Set.GUID
            });
          });
        }
      };

      $scope.removeMediaHint = function(index){
        if(!$scope.item.DataJSON.hints) $scope.item.DataJSON.hints = [];
        $scope.item.DataJSON.hints.splice(index,1);
      };

      $scope.takeQuestionMedia = function(type,question,e){
        self.takeUserMedia(type,null,function(results){
          question.media = {'type':type,'URL':results[0].URL};
          if(type == 'audio'){
            question.media.AudioPlayLimit = '';
          }
        }, {dialogMode: 0});
      };

      $scope.takeAnswerMedia = function(type,answer,name){
        self.takeUserMedia(type,null,function(results){
          if(!name) name = "media";
          answer[name] = {'type':type,'URL':results[0].URL};
        }, {dialogMode: 0});
      };

      $scope.switchMultiSingle = function(q,skipCorrect){
        q.multi = !q.multi;
        if(skipCorrect) return;
        if(q.multi){
          for(var i=0; i < q.answers.length; i++)
            q.answers[i].correct = false;
          q.answers[q.correctIndex].correct = true;
        }else{
          var skipFirst = true;
          for(var i=0; i < q.answers.length; i++)
            if(q.answers[i].correct) {
              if(!skipFirst)
                q.answers[i].correct = false; else q.correctIndex = i;
              skipFirst = false;
            }
        }
      };

      $scope.moveQuestionUp = function(questions,index){
        if(index == 0) return; // already first place
        var n = questions[index];
        var p = questions[index-1];
        questions[index-1] = n;
        questions[index] = p;
      };

      $scope.duplicateQuestion = function(questions,index){
        var n = questions[index];
        questions.splice(index,0,JSON.parse(angular.toJson(n)));
      };

      $scope.searchLearningApp = function(ev){
        if(!$scope.item.DataJSON.source || $scope.item.DataJSON.source == "la")
          self.searchLearningApp(ev).then(function(url){
            $scope.item.DataJSON.URL = url;
          });
        if($scope.item.DataJSON.source == "edulo")
          self.searchEduloPage(ev).then(function(url){
            $scope.item.DataJSON.URL = url;
          });
        if($scope.item.DataJSON.source == "zebis"){
          if(self.isCordova){
            self.openWeblink({DataJSON:{URL:'https://zebis.digital/'}},ev,false);
          }else
            self.searchZebisPage(ev).then(function(url){
              $scope.item.DataJSON.URL = url;
            });
        }

      };

      $scope.openLearningApp = function(ev){
        self.openWeblink($scope.item,ev,true);
      };

      $scope.resetAnswers = function(q){
        for(var i=0; i < q.answers.length; i++) q.answers[i].correct = false;
        if(!q.multi) q.answers[q.correctIndex].correct = true;
      };

      $scope.setAnswers = function(q,a){
        for(var i=0; i < q.answers.length; i++) q.answers[i].correct = false;
        a.correct = true;
      };

      $scope.validateCheckType = function(changeIcon){
        // set public status for peer 
        // requires data to be shared between students to work
        if(!$scope.item.DataJSON.Public) $scope.item.DataJSON.Public = '0';

        if($scope.item.Social == 'input' || $scope.item.CheckType == 'peer'){
          $scope.item.DataJSON.Public = '1';
        }
        if($scope.item.Type == "survey" || $scope.item.Type == "collection"){
          // can be either Public 0 or 1 
          if($scope.item.CheckType == 'peer')
            $scope.item.DataJSON.Anonymous = '0';
        }
           

        if($scope.item.Social == 'input'){
          if(typeof $scope.item.DataJSON.Register == "undefined"){
            $scope.item.DataJSON.Register = 1;
          }
        }
        if($scope.item.CheckType == 'none'){
          if(!$scope.item.DataJSON.Repeat) $scope.item.DataJSON.Repeat = 0;
        }
        if($scope.item.Type == "learningapp"){
          if($scope.item.Social != 'single' && $scope.item.Social != 'pair' && $scope.item.Social != 'group'){
            $scope.item.Social = 'single';
          }
          if($scope.item.CheckType != 'self' && $scope.item.CheckType != 'teacher'){
            $scope.item.CheckType = 'self';
          }
          if($scope.item.DataJSON.source == 'la' || $scope.item.DataJSON.source == 'other'){
            $scope.item.CheckType = 'self';
          }
          if(changeIcon){
            if($scope.item.DataJSON.source == 'zebis' && $scope.item.MainIcon != "ci cb zebis"){
              $scope.oldIcon = $scope.item.MainIcon;
              $scope.item.MainIcon = "ci cb zebis";
            }
            if($scope.item.DataJSON.source != 'zebis' && $scope.item.MainIcon == "ci cb zebis"){
              if(!$scope.oldIcon) $scope.oldIcon = "fa fa-lightbulb-o";
              $scope.item.MainIcon = $scope.oldIcon;
            }
          }
        }

      };

      $scope.validate = function(){
        $scope.validateCheckType();

        if(self.isEmptyHTMLText($scope.item.Description))
          $scope.item.Description = "";

        if(!$scope.item.Name || $scope.item.Name == "") { $('#inputName').focus(); return false;}

        $scope.item.Description = self.trimHTML($scope.item.Description);
        if($scope.item.ResultType == "text"){
//          if($scope.item.DataJSON.textTemplate)
//             $scope.item.DataJSON.textTemplate = self.trimHTML($scope.item.DataJSON.textTemplate);
        }
        if($scope.item.ResultType == "audionotes"){
          if(!$scope.item.DataJSON.audio || $scope.item.DataJSON.audio === '') return false;
        }
        if($scope.item.ResultType == "videonotes"){
          if(!$scope.item.DataJSON.video || $scope.item.DataJSON.video === '') return false;
        }
        if($scope.item.ResultType == "textnotes"){
          if(!$scope.item.DataJSON.text || $scope.item.DataJSON.text === '') return false;
        }

        if($scope.item.Social == "input"){
          $scope.item.CheckType = 'none';
          $scope.item.ResultType = "none";
        }
        if($scope.item.Type == "test"){
          $scope.item.Social = "single";
        }
        if($scope.item.Type == "survey" || $scope.item.Type == "test"){
          $scope.item.CheckType = 'self';
          $scope.item.ResultType = "none";
        }
        if($scope.item.Type == "learningapp"){
          $scope.item.ResultType = 'none';
        }

        if($scope.item.Type == "collection"){
          $scope.item.ResultType = "none";
          if($scope.item.Social != 'single'){
            $scope.item.DataJSON.MinItems = 1;
            $scope.item.DataJSON.MaxItems = 0;
          }
          var hasNoMediaTypes = $scope.item.DataJSON.collectText != 1 &&
                                $scope.item.DataJSON.collectImage != 1 &&
                                $scope.item.DataJSON.collectAudio != 1 &&
                                $scope.item.DataJSON.collectVideo != 1 &&
                                $scope.item.DataJSON.collectFile != 1 &&
                                $scope.item.DataJSON.collectLink != 1;
          if(hasNoMediaTypes) return false;
        }

        if($scope.item.ResultType == "annotation" || $scope.item.ResultType == "drawing"){
          if(!$scope.item.DataJSON.annotationImage || $scope.item.DataJSON.annotationImage == "") return false;
        }

        if($scope.item.DataJSON.hints)
        for(var i=0; i < $scope.item.DataJSON.hints.length; i++){
          
          // replace old show attributes and place content in description
          /*
          if($scope.item.DataJSON.hints[i].show){
            var add = "";
            if($scope.item.DataJSON.hints[i].type == "image")
              add = '<img src="'+$scope.item.DataJSON.hints[i].URL+'"><br>'+($scope.item.DataJSON.hints[i].text && $scope.item.DataJSON.hints[i].text != '' ? $scope.item.DataJSON.hints[i].text+'<br>' : '');
            if($scope.item.DataJSON.hints[i].type == "audio")
              add = '<b class="fa fa-fw fa-volume-up inlineAudio" src="'+$scope.item.DataJSON.hints[i].URL+'"></b> '+($scope.item.DataJSON.hints[i].text && $scope.item.DataJSON.hints[i].text != '' ? $scope.item.DataJSON.hints[i].text : '')+'<br>';
            if($scope.item.DataJSON.hints[i].type == "video")
              add = '<video controls controlslist="nodownload" class="inlineVideo" src="'+$scope.item.DataJSON.hints[i].URL+'"></video>'+($scope.item.DataJSON.hints[i].text && $scope.item.DataJSON.hints[i].text != '' ? '<br>'+$scope.item.DataJSON.hints[i].text : '')+'<br>';

            if($scope.item.DataJSON.hints[i].show == "top"){
              $scope.item.Description = add + "<br>"+$scope.item.Description;
            }
            if($scope.item.DataJSON.hints[i].show == "bottom"){
              $scope.item.Description = $scope.item.Description + "<br>"+ add; 
            }
            delete($scope.item.DataJSON.hints[i].show);
          } 
          */

          if($scope.item.DataJSON.hints[i].type != "text" && $scope.item.DataJSON.hints[i].URL == ""){
            $scope.item.DataJSON.hints.splice(i,1);
            i--;
          }else
          if($scope.item.DataJSON.hints[i].type == "text" && $scope.item.DataJSON.hints[i].Text == ""){
            $scope.item.DataJSON.hints.splice(i,1);
            i--;
          }
        }

        // clean empty answers
        if($scope.item.Type == "test" || $scope.item.Type == "survey"){
          for(var i=0; i < $scope.item.DataJSON.questions.length; i++){
            if($scope.item.DataJSON.questions[i].answers){
              for(var z=0; z < $scope.item.DataJSON.questions[i].answers.length; z++){
                if($.trim($scope.item.DataJSON.questions[i].answers[z].text) == "" &&
                   !$scope.item.DataJSON.questions[i].answers[z].media &&
                    $scope.item.DataJSON.questions[i].answers.length > 1){
                  $scope.item.DataJSON.questions[i].answers.splice(z,1);
                  z--;
                  if($scope.item.DataJSON.questions[i].answers.length == 1 &&
                     $scope.item.DataJSON.questions[i].type != "input"){
                    $scope.item.DataJSON.questions[i].answers[0].correct = true;
                  }
                }
              }
            }
          }
        }

        return true;
      };
      // performe once on load
      $scope.validate();
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.createTask = function(it,ev){
      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "edittask.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.isNew = 1;
            $scope.allowTest = true;
            $scope.iconList = self.taskIconList;
            $scope.colorChoice = self.colorChoice;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;

            $scope.item = {};
            $scope.item.Name = "";
            $scope.item.Description = "";
            $scope.item.DataJSON = {};
            $scope.item.Icon = "";
            $scope.item.MainIcon = "fa fa-cube";
            var mt = self.getMainTopicFromTopic({ID:it.Topic});
            $scope.item.Color = mt ? mt.Color : self.colorChoice[0];
            $scope.item.Social = "single";
            $scope.item.Level = "0";
            $scope.item.Time = "0";
            $scope.item.CheckType = 'self';
            $scope.item.Type = "task";
            $scope.item.ResultType = "none";
            $scope.item.Important = "0";
            $scope.item.Public = "0";
            $scope.item.Science = "";

            //1010
            $timeout(function(){
              self.addDropHandler($scope, $scope.dialogElement, null, true, false, $scope.addHintsFromFiles);
            });

            // fetch defaults from last task in the same goal
            if(it.tasks && it.tasks.length > 0){
              $scope.item.Color = it.tasks[it.tasks.length-1].Color;
              $scope.item.MainIcon = it.tasks[it.tasks.length-1].MainIcon;
            }

            self.addEditTaskController($scope,$mdDialog);


            $scope.save = function(setvisibility) {
              // try save now
              if(!$scope.validate()) return;
              $scope.item.Public = $scope.item.DataJSON && $scope.item.DataJSON.Public ?
                                   $scope.item.DataJSON.Public : $scope.item.Public;

              self.replaceBase64Images($scope.item.Description).then(function(desc){        
                $scope.item.Description = desc;

                var a = {"action":"createTask", "ID":it.ID,
                         "Name":$scope.item.Name,
                         "Type":$scope.item.Type,
                         "Data":angular.toJson($scope.item.DataJSON),
                         "Public":$scope.item.Public,
                         "Icon":$scope.item.Icon ? $scope.item.Icon : "",
                         "MainIcon":$scope.item.MainIcon ? $scope.item.MainIcon : "",
                         "Social":$scope.item.Social,
                         "Level":$scope.item.Level,
                         "Time":$scope.item.Time,
                         "Important":$scope.item.Important,
                         "CheckType":$scope.item.CheckType,
                         "Color":$scope.item.Color,
                         "Description":$scope.item.Description,
                         "ResultType":$scope.item.ResultType,
                         "Science":$scope.item.Science};

                if(self.user.Teacher == 0) {
                  a.action = "createUserTask";
                  a.LearningGoal = it.ID;
                }

                if(self.currentClass) a.inclass = self.currentClass.ID;

                self.apiPost("ajax",a)
                 .then(function(data) {
                   // save teacher notes if exists
                   if($scope.item.teacherNotes && $scope.item.teacherNotes != "")
                     self.apiPost("ajax",{action:'saveTeacherNotes', type:'task', id:data.task.ID, text:$scope.item.teacherNotes});

                   // if this is the first task created
                   if(self.user.Teacher == 1){
                     var hasTasks = false;
                     for(var i=0; i < self.userContent.mainTopics.length; i++){
                       for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
                         for(var x=0; x < self.userContent.mainTopics[i].topics[z].goals.length; x++){
                           if(self.userContent.mainTopics[i].topics[z].goals[x].tasks.length > 0) hasTasks = true;
                           if(hasTasks) break;
                         }
                         if(hasTasks) break;
                       }
                       if(hasTasks) break;
                     }
                     if(!hasTasks){
                       self.setFirstTaskNotification = true;
                     }
                   }

                   data.task.DataJSON = data.task.Data != '' ? JSON.parse(data.task.Data) : {};
                   if(!it.tasks) it.tasks = [];
                   var isThere = false;
                   for(var i=0; i < it.tasks.length; i++){
                     if(it.tasks[i].ID == data.task.ID){
                       isThere = it.tasks[i];
                       break;
                     }
                   }
                   if(!isThere) { it.tasks.push(data.task); isThere = data.task; }

                   if(self.searchTerm && self.searchTerm != '')
                     self.addedAfterLastSearchTermChange.tasks.push(data.task.ID);

                   self.updateLastUsedTaskIcons(data.task.Icon);
                   self.updateLastUsedTaskIcons(data.task.MainIcon);

                   self.closeDialog($scope.dialogElement);
                   deferred.resolve();

                   // ask for publish in class?
                   if(setvisibility){
                     self.showClassesTaskVisibility(isThere,ev);
                   }

                   self.keepAliveCallback();
                 });
               });
            };

            $scope.cancel = function(ev) {
              $scope.close(ev);
            };
          }
        });

        $timeout(function(){
          done();
        },10);
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editTask = function(it,goal,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "edittask.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.isEdit = 1;
          $scope.allowTest = true;
          $scope.iconList = self.taskIconList;

          $scope.colorChoice = self.colorChoice;

          $scope.iconsLastUsed = self.lastUsedTaskIcons;
          $scope.item = JSON.parse(angular.toJson(it));

          // convert old media questions to new format
          if($scope.item.Type == "survey"){
            for(var i=0; i < $scope.item.DataJSON.questions.length; i++){
              if($scope.item.DataJSON.questions[i].type == 'image' ||
                 $scope.item.DataJSON.questions[i].type == 'audio' ||
                 $scope.item.DataJSON.questions[i].type == 'video' ||
                 $scope.item.DataJSON.questions[i].type == 'file'){
                var typnow = $scope.item.DataJSON.questions[i].type;
                $scope.item.DataJSON.questions[i]["m_"+typnow] = 1;
                $scope.item.DataJSON.questions[i].type = "media";
              }
            }
          }
          if($scope.item.Type == "test"){
            if(!$scope.item.DataJSON.timeLimit) $scope.item.DataJSON.timeLimit = 0;
          }
          if($scope.item.ResultType == 'audionotes' || $scope.item.ResultType == 'videonotes'){
            if(typeof $scope.item.DataJSON.onlyEdit == "undefined"){
              $scope.item.DataJSON.onlyEdit = 0;
            }          
          }

          $timeout(function(){
            self.addDropHandler($scope, $scope.dialogElement, null, true, false, $scope.addHintsFromFiles);
          });

          self.addEditTaskController($scope,$mdDialog);
          $scope.validate();

          $scope.save = function(setvisibility) {
            // try save now
            if(!$scope.validate()) return;
            if(!$scope.item.Public) $scope.item.Public = "0";
            $scope.item.Public = $scope.item.DataJSON && $scope.item.DataJSON.Public ?
                                 $scope.item.DataJSON.Public : $scope.item.Public;

            self.replaceBase64Images($scope.item.Description).then(function(desc){        
              $scope.item.Description = desc;

              var a = {"action":"updateTask", "ID":it.ID,
                       "Type":$scope.item.Type,
                       "Name":$scope.item.Name,
                       "Public":$scope.item.Public,
                       "Data":angular.toJson($scope.item.DataJSON),
                       "MainIcon":$scope.item.MainIcon ? $scope.item.MainIcon : "",
                       "Icon":$scope.item.Icon ? $scope.item.Icon : "",
                       "Social":$scope.item.Social,
                       "Level":$scope.item.Level,
                       "Time":$scope.item.Time,
                       "Important":$scope.item.Important,
                       "CheckType":$scope.item.CheckType,
                       "Color":$scope.item.Color,
                       "ResultType":$scope.item.ResultType,
                       "Science":$scope.item.Science,
                       "Description":$scope.item.Description};

              if(self.user.Teacher == 0) a.action = "updateUserTask";

              self.apiPost("ajax",a)
               .then(function(data) {
                 it.Name = $scope.item.Name;
                 it.Description = $scope.item.Description;
                 it.Type = $scope.item.Type;
                 it.DataJSON = $scope.item.DataJSON;
                 it.MainIcon = $scope.item.MainIcon;
                 it.Icon = $scope.item.Icon;
                 it.Color = $scope.item.Color;
                 it.Social = $scope.item.Social;
                 it.Level = $scope.item.Level;
                 it.Time = $scope.item.Time;
                 it.Important = $scope.item.Important;
                 it.CheckType = $scope.item.CheckType;
                 it.ResultType = $scope.item.ResultType;
                 it.Science = $scope.item.Science;
                 self.updateLastUsedTaskIcons(it.Icon);
                 self.updateLastUsedTaskIcons(it.MainIcon);
                 self.closeDialog($scope.dialogElement);
                 deferred.resolve();
                 // ask for publish in class?
                 if(setvisibility){
                   self.showClassesTaskVisibility(it,ev);
                 }
                 if(self.searchTerm && self.searchTerm != '')
                   self.addedAfterLastSearchTermChange.tasks.push(it.ID);

                 self.keepAliveCallback();
               });
             });
          };

          $scope.cancel = function(ev) {
            $scope.close(ev);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.createTaskSpacer = function(it,type,ev){
      self.apiPost("ajax",{"action":"createTask", "ID":it.ID, "Name":"SPACE-"+type, "Type":"space"})
       .then(function(data) {    
        self.keepAliveCallback();
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.lastEditTaskNoteType = "icon";

    self.checkTeacherTaskNote = function(note){
      return note && note[0] == '¶';
    };

    self.editTaskNote = function(it,user,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "edittasknote.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.user = user;
          // it is defined as {ID:a.ID, Note:userStatus.Note, ref:userStatus}
          $scope.task = {ID:it.ID, Icon: "", Note:""}; // make copy here
          $scope.type = self.lastEditTaskNoteType;
          if(it.Note && it.Note != ''){
            $scope.task.Note = it.Note.replace('¶','');
            if($scope.task.Note.indexOf('<i class=') === 0){
              var m = it.Note.match(/"([^"]*)"/);
              $scope.task.Icon = m[1];
              $scope.task.Note = "";
              $scope.type = "icon";
            }else{
              $scope.type = "text";
            }
          }
          self.track('openTaskEditNote',{ID:$scope.task.ID,"Note":it.Note ? it.Note : ''});

          $scope.save = function() {

            var content = "";
            if($scope.type == 'text') content = $scope.task.Note;
            if($scope.type == 'icon') content = $scope.task.Icon != "" ? '<i class="'+$scope.task.Icon+'"></i>' : '';
            self.track('saveTaskNote',{ID:$scope.task.ID,"Note":content});
            self.apiPost("ajax",{"action":"updateTaskNote", "student":user ? user.ID : self.user.ID, "ID":$scope.task.ID, "Note":(content != "" && self.user.Teacher == 1 ? '¶':'')+ content, "classid":self.currentClass.ID})
             .then(function(data) {
               it.Note = content;
               if(it.ref) it.ref.Note = content;
               self.lastEditTaskNoteType = $scope.type;
               self.closeDialog($scope.dialogElement);
               deferred.resolve();
               self.keepAliveCallback();
             });
          };

          $scope.selectIcon = function(icon){
            $scope.task.Icon = icon == $scope.task.Icon ? '' : icon;
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.currentClassSelectStudtensWithImportant = function(task){
      self.currentClassStudentSelection = [];
      for(var i=0; i < self.currentClass.students.length; i++){
        var student = self.currentClass.students[i];
        var status = self.getUserTaskStatus(task,student,true);
        if(status.Important == "1") self.currentClassStudentSelection.push(student.ID);
      }
    };

    self.setUserTaskImportant = function(it,value,scope){
      var action = {"action":"setUserTaskImportant", "ID":it.ID, "classid":self.currentClass.ID,
                    "important": value};
      self.apiPost("ajax",action).then(function(){
        if(scope && scope.taskStatus) scope.taskStatus.Important = value;
        var ts = self.getUserTaskStatus(it,self.user,true);
        ts.Important = value;
        self.updateStudentClassesStatus();
        self.track("setTaskImportant",{"ID":it.ID,"important":value});
      });
    };

    self.setUserTaskSearching = function(it,value,scope){
      var ts = self.getUserTaskStatus(it,self.user,true);
      var action = {"action":"saveUserTaskStatus", "ID":it.ID,
                    "status": value ? 's':'',
                    "classid":self.currentClass.ID};
      self.apiPost("ajax",action).then(function(){
        if(scope && scope.taskStatus) scope.taskStatus.Status = value ? 's':'';
        ts.Status = value ? 's':'';
        self.updateStudentClassesStatus();
        self.track("setTaskSearchPartner",{"ID":it.ID,"searching":value ? 1 : 0});
      });
    };

    self.setClassUserTaskImportant = function(student,task,value,ev,withoutAskColleagues){
      var status = self.getUserTaskStatus(task,student,true);
      var users = [student.ID];
      var partners = self.getUserTaskStatusColleagues(task,student);
      if(partners && partners != ""){
        var colleagues = partners.split(",").map(Number);
        for(var i=0; i < colleagues.length; i++) users.push(colleagues[i]);
      }

      var perform = function(){
        var count = users.length;
        var checkDone = function(){
          if(count == 0){
            if(value == 1 && ev && ev.currentTarget && ev.currentTarget.nodeName == "BUTTON"){
              $(ev.currentTarget).addClass('saved');
              $timeout(function(){ $(ev.currentTarget).removeClass('saved'); },2000);
            }
            self.keepAliveCallback();
          }
        }
        for(var i=0; i < users.length; i++){
          var status = self.getUserTaskStatus(task,{ID:users[i]},true);
          if(status.Status == "OK" && value == "1"){
            count++;
            // task was already completed by student, we have to set it back to "?"
            self.apiPost("ajax",{"action":"saveTeacherTaskStatus", "ID":task.ID, "user":users[i], "classid":self.currentClass.ID, "status":"?"})
             .then(function(data) {
               count--;
               checkDone();
            });

          }
          var action = {"action":"setUserTaskImportant",
                        "student":users[i],"classid":self.currentClass.ID,
                        "ID":task.ID,"important": value};
          self.apiPost("ajax",action).then(function(){
            status.Important = value;
            count--;
            checkDone();
            //self.updateStudentClassesStatus();
          });
        }
      };
      if(users.length > 1 && !withoutAskColleagues){
        self.confirm($filter('trans')('ASKSETPINFORALLCOLLEAGUES'),$filter('trans')('YES') ,ev, $filter('trans')('NO')).then(function(){
          perform();
        },function(){
          users = [student.ID]; // only for current user;
          perform();
        });
      } else perform();
    };

    self.askHideTaskFromOpenTaskList = function(student,task,reasonOnList, ev){
      var n = self.getUserTaskStatus(task,student ? student : self.user,true);
      if(n.Status == "x" && (!student || student.ID == self.user.ID)){

          return;
      }
      if(!student || student == self.user)
        if(n.Important == "1") return; // set by teacher

      self.confirm($filter('trans')('ASKHIDETASKFROMTASKLIST',task.Name),$filter('trans')('REMOVE'),ev).then(function(){
        var val = "-1";
        if(reasonOnList == "importantTask" && (n.Important == "1" || n.Important == "2")) val =  "0";

        if(!student || student == self.user){
          if(val == "-1" && n.Status == "?"){
            // also reset task status to w if it is ?
            var action = {"action":"saveUserTaskStatus", "ID":task.ID,"status":"w","classid":self.currentClass.ID};
            self.apiPost("ajax",action).then(function(){
              n.Status = "w";
              self.keepAliveCallback();
            });
          }
          self.setUserTaskImportant(task,val,ev);
        }else{
          if(val == "-1" && n.Status == "x"){
            // reset task too so we do not get it back on the list
            self.apiPost("ajax",{"action":"saveTeacherTaskStatus", "ID":task.ID, "user":student.ID, "classid":self.currentClass.ID, "status":"w"})
             .then(function(data) {
              n.Status = "w";
              self.keepAliveCallback();
            });
          }
          self.setClassUserTaskImportant(student,task,val,ev);
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countUserLearningGoalTaskDone = function(s,g){
      var count = 0;
      for(var i=0; i < g.tasks.length; i++){
        var status = self.getUserTaskStatus(g.tasks[i],s,true);
        if(status.Status && status.Status != "" && (status.Status != "w" || status.FeedbackStatus == 'OK')) count++;
      }
      return count;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countLearningGoalStatusInClassSelection = function(goal,c,selectedStudents,value){
      var count = 0;
      for(var i=0; i < c.students.length; i++){
        if(selectedStudents.indexOf(c.students[i].ID) >= 0){
          var status = self.getUserLearningGoalStatus(goal,c.students[i],true);
          if(status.Teacher == value || (value == "" && !status.Teacher)) count++;
        }
      }
      return count;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editLearningGoalStatusForClass = function(goal,c,selectedStudents,value,ev){
      var done = 0;
      for(var i=0; i < c.students.length; i++){
        if(selectedStudents.indexOf(c.students[i].ID) >= 0){
          var status = self.getUserLearningGoalStatus(goal,c.students[i],true);
          if(status.Teacher == value) continue;
          self.saveLearningGoalTeacherStatus(goal,c.students[i],value,status,true);
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countTaskStatusInClassSelection = function(task,c,selectedStudents,value){
      var count = 0;
      for(var i=0; i < c.students.length; i++){
        if(selectedStudents.indexOf(c.students[i].ID) >= 0){
          var status = self.getUserTaskStatus(task,c.students[i],true);
          if(status.Status == value || (value == '' && !status.Status)) count++;
        }
      }
      return count;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getClassStudentsWithTaskStatus = function(task,c,status){
      var students = [];
      for(var i=0; i < c.students.length; i++){
        var t = self.findTaskInClass(self.currentClass,task.ID,c.students[i]);
        if(!t) continue;
        var s = self.getUserTaskStatus(task,c.students[i],true);
        if(s.Status == status) students.push(c.students[i].ID);
      }      
      return students;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editTaskStatusForClass = function(task,c,selectedStudents,value,ev){
      var done = 0;
      for(var i=0; i < c.students.length; i++){
        if(selectedStudents.indexOf(c.students[i].ID) >= 0){
          var status = self.getUserTaskStatus(task,c.students[i],true);
          if(status.Status == value) continue;
          status.Status = value;

          self.apiPost("ajax",{"action":"saveTeacherTaskStatus", "ID":task.ID, "user":c.students[i].ID, "classid":self.currentClass.ID, "status":status.Status })
           .then(function(data) {
             done++;
             if(done == selectedStudents.length){
               self.updateClassesStatus();
               self.keepAliveCallback();
             }
          });
        }
      }
    };
    self.askDoneInputTask = function(task,ev){
      self.showDialog({
        templateUrl: "classStudentSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.selection = self.getClassStudentsWithTaskStatus (task,self.currentClass,task.DataJSON.Register == 1 ? 's':'');

          $scope.disabled = [];
          for(var i=0; i < c.students.length; i++){
            var cs = self.getUserTaskStatus(task,c.students[i],true);
            if(cs.Status == "OK") {
              $scope.disabled.push(c.students[i].ID);
              $scope.selection.push(c.students[i].ID);
            }
          }
          $scope.smallScreen = self.isSmallScreen;
          $scope.saveBtnText = $filter('trans')('INPUTDONE');

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            for(var i=0; i < c.students.length; i++){
              var cs = self.getUserTaskStatus(task,c.students[i],true);
              if(cs.Status == "OK") {
                var p = $scope.selection.indexOf(c.students[i].ID);
                if(p != -1) {
                  $scope.selection.splice(p,1);
                  i--;
                }
              }
            }

            self.editTaskStatusForClass(task,self.currentClass,$scope.selection,'OK',ev);
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
/*
      self.confirm($filter('trans')(task.DataJSON.Register == 1 ? 'ASKDONEINPUTREGISTEREDTASK' : 'ASKDONEINPUTTASK',students.length),$filter('trans')('DONE'),ev).then(function(){
        self.editTaskStatusForClass(task,self.currentClass,students,'OK',ev);
      });
*/      
    };    
