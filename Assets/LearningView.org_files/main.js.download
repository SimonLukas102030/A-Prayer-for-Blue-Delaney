    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateContentDeepNewWithMap = function(parent,current,next,onlyappenddata,discardOldChanges){
      if(!next || next.length == 0) return false;
      var changed = false;
      var list = next[0];
      next = next.slice(1);
      if(!current[list]) current[list] = [];

      function normalizeIdValue(id) {
        if (id === null || typeof id === "undefined") return null;
        var s = "" + id;
        if (s.match(/^\-?\d+$/)) return parseInt(s, 10);
        return s;
      }

      function normalizeItemId(item) {
        if (!item) return null;
        var normalized = normalizeIdValue(item.ID);
        if (normalized !== null) item.ID = normalized;
        return normalized;
      }

      function getIdKey(id) {
        var normalized = normalizeIdValue(id);
        if (normalized === null) return null;
        if (typeof normalized === "number") return "n:" + normalized;
        var s = "" + normalized;
        return "s:" + s;
      }

      function buildIdMap(items) {
        var map = {};
        if (!items) return map;
        for (var i = 0; i < items.length; i++) {
          var normalizedId = normalizeItemId(items[i]);
          var key = getIdKey(normalizedId);
          if (key !== null && typeof map[key] === "undefined") {
            map[key] = items[i];
          }
        }
        return map;
      }

      if(!onlyappenddata && !(list == "tasks" && self.user.ID == "-1")) {
        // find removed content (optimized with ID maps to avoid O(n^2))
        var parentIdMap = buildIdMap(parent[list]);
        for(var z = current[list].length - 1; z >= 0; z--){
          var currentItem = current[list][z];
          var currentNormalizedId = normalizeItemId(currentItem);
          var currentKey = getIdKey(currentNormalizedId);
          var found = (currentKey !== null && typeof parentIdMap[currentKey] !== "undefined");
          if(!found && currentItem && currentItem.ID != -1) { // keep -1 temp items
            current[list].splice(z,1); // remove it
          }
        }
      }

      var currentIdMap = buildIdMap(current[list]);

      if(parent[list])
        for(var i=0; i < parent[list].length; i++){
          var e = null;
          var parentNormalizedId = normalizeItemId(parent[list][i]);
          var parentKey = getIdKey(parentNormalizedId);
          if (parentKey !== null && typeof currentIdMap[parentKey] !== "undefined") {
            e = currentIdMap[parentKey];
          }
          if(!e){
            if(onlyappenddata) continue; // do nothing here
            e = parent[list][i];
            current[list].push(e);
            if (parentKey !== null && typeof currentIdMap[parentKey] === "undefined") {
              currentIdMap[parentKey] = e;
            }
          }

          // update data only
          // check if we already have a newer date and discard chage if so
          if(discardOldChanges && parent[list][i]["Changed"]){
            if(e["Changed"] && e["Changed"] > parent[list][i]["Changed"]) continue;
          }

          for(var k in parent[list][i]){
            if(next.length > 0 && k == next[0]){
              var hasChanged = self.updateContentDeep(parent[list][i],e,next,onlyappenddata);
              changed = changed || hasChanged;
              continue;
            }
            if(k == "shareSettings"){
              var hasChanged = self.updateContentDeep(parent[list][i],e,["shareSettings"],onlyappenddata);
              changed = changed || hasChanged;
              continue;
            }

            if(parent[list][i][k] && typeof(parent[list][i][k]) == "object") continue; // dont, update arrays

            if(onlyappenddata){
              if (typeof e[k] === "undefined"){
                changed = true;
                if(k == "Data"){
                  // special case for JSON data block
                  e["DataJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
                }
                if(k == "Skills"){
                  // special case for JSON data block
                  e["SkillsJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
                }
                e[k] = parent[list][i][k];
                if(k == "OrderIndex") e[k] = parseInt(e[k]);
              }
            }else{
              if(k == "Data"){
                // special case for JSON data block
                e["DataJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
              }
              if(k == "Skills"){
                // special case for JSON data block
                e["SkillsJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
              }
              changed = changed || (e[k] != parent[list][i][k]);
              e[k] = parent[list][i][k];
              if(k == "OrderIndex") e[k] = parseInt(e[k]);
            }
          }
        }
      // reorder by orderIndex if exists
      if(current[list].length > 0 && typeof(current[list][0].OrderIndex) != "undefined"){
        current[list].sort(function(a,b){
          var oa = parseInt(a.OrderIndex);
          var ob = parseInt(b.OrderIndex);
          return oa < ob ? -1 : (oa > ob ? 1 : (a.ID < b.ID ? -1 : (a.ID > b.ID ? 1 : 0)));
        });
      }

      return changed;
    }

    self.updateContentDeep = function(parent,current,next,onlyappenddata){
      if(!next || next.length == 0) return false;
      var changed = false;
      var list = next[0];
      next = next.slice(1);
      if(!current[list]) current[list] = [];

      if(!onlyappenddata && !(list == "tasks" && self.user.ID == "-1"))
        // find removed content
        for(var z=0; z < current[list].length; z++){
          var found = false;
          if(parent[list])
            for(var i=0; i < parent[list].length; i++){
              if(current[list][z].ID == parent[list][i].ID){
                found = true;
                break;
              }
            }
          if(!found && current[list][z].ID != -1) { // keep -1 temp items
            current[list].splice(z,1); // remove it
            z--;
          }
        }

      if(parent[list])
        for(var i=0; i < parent[list].length; i++){
          var e = null;
          for(var z=0; z < current[list].length; z++){
            // parseInts
            // ID may not be a single number but other data too, only parse to int if single number
            if((""+current[list][z].ID).match(/^\-?\d+$/) && (""+parent[list][i].ID).match(/^\-?\d+$/)){
              current[list][z].ID = parseInt(current[list][z].ID);
              parent[list][i].ID = parseInt(parent[list][i].ID);              
            }

            if(current[list][z].ID == parent[list][i].ID){
              e = current[list][z];
              break;
            }
          }
          if(!e){
            if(onlyappenddata) continue; // do nothing here
            e = parent[list][i];
            current[list].push(e);
          }

          // update data only
          for(var k in parent[list][i]){
            if(next.length > 0 && k == next[0]){
              var hasChanged = self.updateContentDeep(parent[list][i],e,next,onlyappenddata);
              changed = changed || hasChanged;
              continue;
            }
            if(k == "shareSettings"){
              var hasChanged = self.updateContentDeep(parent[list][i],e,["shareSettings"],onlyappenddata);
              changed = changed || hasChanged;
              continue;
            }

            if(parent[list][i][k] && typeof(parent[list][i][k]) == "object") continue; // dont, update arrays

            if(onlyappenddata){
              if (typeof e[k] === "undefined"){
                changed = true;
                if(k!= "Changed" && k!= "lastActivity" && e[k] != parent[list][i][k]){
                  console.log("update "+k+" from "+e[k]+" to "+ parent[list][i][k]);
                }
                if(k == "Data"){
                  // special case for JSON data block
                  e["DataJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
                }
                if(k == "Skills"){
                  // special case for JSON data block
                  e["SkillsJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
                }
                e[k] = parent[list][i][k];
              }
            }else{
              if(k!= "Changed" && k!= "lastActivity" && e[k] != parent[list][i][k])
                console.log("update "+k+" from "+e[k]+" to "+ parent[list][i][k]);
              if(k == "Data"){
                // special case for JSON data block
                e["DataJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
              }
              if(k == "Skills"){
                // special case for JSON data block
                e["SkillsJSON"] = parent[list][i][k] == '' ? {} : JSON.parse(parent[list][i][k]);
              }
              changed = changed || (e[k] != parent[list][i][k]);
              e[k] = parent[list][i][k];
            }
          }
        }
      // reorder by orderIndex if exists
      if(current[list].length > 0 && current[list][0].OrderIndex){
        current[list].sort(function(a,b){
          var oa = parseInt(a.OrderIndex);
          var ob = parseInt(b.OrderIndex);
          return oa < ob ? -1 : (oa > ob ? 1 : (a.ID < b.ID ? -1 : (a.ID > b.ID ? 1 : 0)));
        });
      }
      return changed;
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassTeachers = function(cs){
      for(var i=0; i < cs.teachers.length; i++){
        if(!self.users[cs.teachers[i].ID]) {
          self.users[cs.teachers[i].ID] = JSON.parse(JSON.stringify(cs.teachers[i]));
        } else {
          for(k in cs.teachers[i]){
            if(k != "Permissions")
              self.users[cs.teachers[i].ID][k] = cs.teachers[i][k];
          }
        }
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.changeClassNameOrder = function(){
      for(var i=0; i < self.classList.length; i++){
        if(!self.classList[i].students) continue;
        self.classList[i].students.sort(function(a,b){
          var r = a[self.user.ClassNameSorting].localeCompare(b[self.user.ClassNameSorting]);
          if(r == 0) {
            var sn = self.user.ClassNameSorting == "Surname" ? "Name" : "Surname";
            r = a[sn].localeCompare(b[sn]);
            if(r == 0) {
              r = parseInt(a.ID) - parseInt(b.ID);
            }
          }
          return r;
        });

        self.classList[i].teachers.sort(function(a,b){
          var x = self.permissionsOrder(a);
          var y = self.permissionsOrder(b);
          var r = x - y;
          if(r == 0) r = parseInt(a.ID)-parseInt(b.ID);
          return r;
        });
      }
      if(self.editingClass)
        self.editingClass.students.sort(function(a,b){
          var r = a[self.user.ClassNameSorting].localeCompare(b[self.user.ClassNameSorting]);
          if(r == 0) {
            var sn = self.user.ClassNameSorting == "Surname" ? "Name" : "Surname";
            r = a[sn].localeCompare(b[sn]);
            if(r == 0) {
              r = parseInt(a.ID) - parseInt(b.ID);
            }
          }
          return r;
        });
      if(self.currentClass)
        self.currentClass.students.sort(function(a,b){
          var r = a[self.user.ClassNameSorting].localeCompare(b[self.user.ClassNameSorting]);
          if(r == 0) {
            var sn = self.user.ClassNameSorting == "Surname" ? "Name" : "Surname";
            r = a[sn].localeCompare(b[sn]);
            if(r == 0) {
              r = parseInt(a.ID) - parseInt(b.ID);
            }
          }
          return r;
        });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassStudents = function(cs){

      for(var z=0; z < cs.students.length; z++){
        // read in for the current class
        if(cs.students[z].calendar){
          var cal = {};
          cal[cs.ID] = cs.students[z].calendar;
          self.updateUser({ID:cs.students[z].ID, calendars:cal});
        }
        delete cs.students[z].calendar; // remove from class object

        if(cs.students[z].calendarNotes){
          var cal = {};
          cal[cs.ID] = cs.students[z].calendarNotes;
          self.updateUser({ID:cs.students[z].ID, calendarNotes:cal});
        }
        delete cs.students[z].calendarNotes; // remove from class object

        if(cs.students[z].userTasks){
          var uts = {};
          uts[cs.ID] = cs.students[z].userTasks;
          self.updateUser({ID:cs.students[z].ID, userTasks:uts});
        }
        delete cs.students[z].userTasks; // remove from class object

        self.updateUser(cs.students[z]); // move results and journal into user objects

        if(!self.users[cs.students[z].ID].colors)
            self.users[cs.students[z].ID].colors = {};
        self.users[cs.students[z].ID].colors[cs.ID] = cs.students[z].Color;

        if(cs.students[z].folders){
          if(!self.users[cs.students[z].ID].classContent)
              self.users[cs.students[z].ID].classContent = {};
          var classContent = self.users[cs.students[z].ID].classContent;
          if(!classContent[cs.ID]) classContent[cs.ID] = {};
          if(!classContent[cs.ID].folders) classContent[cs.ID].folders = [];

          self.updateContentDeep(cs.students[z],classContent[cs.ID],["folders","items","contents"]);

        }
        delete cs.students[z].folders; // remove from student object

        if(cs.students[z].content){
          // class content, transfer all changes to user object
          if(!self.users[cs.students[z].ID].classContent)
              self.users[cs.students[z].ID].classContent = {};
          var classContent = self.users[cs.students[z].ID].classContent;
          if(!classContent[cs.ID]) classContent[cs.ID] = {};
          if(!classContent[cs.ID].tasks) classContent[cs.ID].tasks = {};
          if(!classContent[cs.ID].goals) classContent[cs.ID].goals = {};
          if(!classContent[cs.ID].topics) classContent[cs.ID].topics = {};
          if(!classContent[cs.ID].mainTopics) classContent[cs.ID].mainTopics = {};

          for(var i=0; i < cs.students[z].content.mainTopics.length; i++){
            var x = cs.students[z].content.mainTopics[i];
            if(!classContent[cs.ID].mainTopics[x.MainTopic])
                classContent[cs.ID].mainTopics[x.MainTopic] = {};
            for(var k in x)
              classContent[cs.ID].mainTopics[x.MainTopic][k] = x[k];
          }
          for(var i=0; i < cs.students[z].content.topics.length; i++){
            var x = cs.students[z].content.topics[i];
            if(!classContent[cs.ID].topics[x.Topic])
                classContent[cs.ID].topics[x.Topic] = {};
            for(var k in x)
              classContent[cs.ID].topics[x.Topic][k] = x[k];
          }
          for(var i=0; i < cs.students[z].content.goals.length; i++){
            var x = cs.students[z].content.goals[i];
            if(!classContent[cs.ID].goals[x.LearningGoal])
                classContent[cs.ID].goals[x.LearningGoal] = {};
            for(var k in x)
              classContent[cs.ID].goals[x.LearningGoal][k] = x[k];
          }
          for(var i=0; i < cs.students[z].content.tasks.length; i++){
            var x = cs.students[z].content.tasks[i];
            if(!classContent[cs.ID].tasks[x.Task])
                classContent[cs.ID].tasks[x.Task] = {};
            for(var k in x)
              classContent[cs.ID].tasks[x.Task][k] = x[k];
          }

          delete cs.students[z].content; // remove from student object
        }

        delete cs.students[z].taskStatus; // remove from class object
        delete cs.students[z].goalStatus; // remove from class object
        delete cs.students[z].journal; // remove from class object
        delete cs.students[z].usertaskdata; // remove from class object

      }
      // read all data from current students array so we not loose it
      for(var i=0; i < self.classList.length; i++){
        if(self.classList[i].ID == cs.ID){
          for(var z=0; z < cs.students.length; z++){
            for(var x=0; x < self.classList[i].students.length; x++){
              if(self.classList[i].students[x].ID == cs.students[z].ID){
                // found existing student in current data, transfer none
                // existing data
                for(k in self.classList[i].students[x]){
                  if(typeof(cs.students[z][k]) == "undefined"){
                    cs.students[z][k] = self.classList[i].students[x][k];
                  }
                }
                break;
              }
            }
          }
          break;
        }
      }

      // refresh current data if changed by server (other device, other teacher)
      if(self.editingClass && cs.ID == self.editingClass.ID){
        self.updateContentDeep(cs,self.editingClass,["groups"]);
        self.updateContentDeep(cs,self.editingClass,["students"]);
        self.updateContentDeep(cs,self.editingClass,["teachers"]);
        for(var i=0; i < self.editingClass.students.length; i++){
          if(!self.editingClass.students[i].canSave){
              self.editingClass.students[i].newName = self.editingClass.students[i].Name;
              self.editingClass.students[i].newSurname = self.editingClass.students[i].Surname;
            }
        }
      }
      /*
      if(self.currentClass && cs.ID == self.currentClass.ID){
        self.updateContentDeep(cs,self.currentClass,["groups"]);
        self.updateContentDeep(cs,self.currentClass,["students"]);
        self.updateContentDeep(cs,self.currentClass,["teachers"]);
      }
      */

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.classContent = {};

    self.updateClassFolders = function(cs){
      if(!self.classContent[cs.ID]) self.classContent[cs.ID] = {};
      var c = self.classContent[cs.ID];
      self.updateContentDeep(cs,c,["folders","items","contents"]);
    };

    self.updateClassContent = function(cs){
      if(!self.classContent[cs.ID]) self.classContent[cs.ID] = {};
      var c = self.classContent[cs.ID];
      // map own classContent too
      self.users[self.user.ID].classContent = self.classContent;

      // keep class currentInfo in classContent cache (single source of truth)
      var rawDescription = cs.Description ? cs.Description : "";
      if(!c.currentInfo){
        c.currentInfo = self.normalizeClassCurrentInfo({});
        c.currentInfoDescriptionRaw = "";
        c.currentInfoSaveVersion = 0;
      }
      if(c.currentInfoDescriptionRaw !== rawDescription){
        var descJSON = self.parseClassDescriptionJSON(rawDescription);
        var nextCurrentInfo = self.normalizeClassCurrentInfo(descJSON.currentInfo);
        self.syncClassCurrentInfoInPlace(c.currentInfo,nextCurrentInfo);
        self.applyClassCurrentInfoTextShadows(cs,c.currentInfo);
        c.currentInfoDescriptionRaw = rawDescription;
      }

      // reset mapping


      var changed = false;
      changed = self.updateContentDeep(cs,c,["mainTopics","topics","goals","tasks"]) || changed;

      if(self.userContent) {
        var userContentChanged = self.updateContentDeep(self.userContent,c,["mainTopics","topics","goals","tasks"],true);
        changed = changed || userContentChanged;
      }

      // reset task mapping inside class content now, auto rebuild with next status update
      c.classMainTopicMapped = {};
      c.classTopicMapped = {};
      c.classGoalMapped = {};
      c.classTasksMapped = {};

      // map all tasks in this class
      self.getTaskByIDmap = {};
      self.getGoalByIDmap = {};

      cs.taskMapped = {};
      cs.goalMapped = {};
      cs.topicMapped = {};
      cs.mainTopicMapped = {};

      if(c.mainTopics)
        for(var i=0; i < c.mainTopics.length; i++){
          cs.mainTopicMapped[c.mainTopics[i].ID] = c.mainTopics[i];
          var r = {};
          r.mainTopic = c.mainTopics[i];
          c.classMainTopicMapped[c.mainTopics[i].ID] = r;

          if(c.mainTopics[i].topics)
          for(var z=0; z < c.mainTopics[i].topics.length; z++){
            cs.topicMapped[c.mainTopics[i].topics[z].ID] = c.mainTopics[i].topics[z];
            var r = {};
            r.mainTopic = c.mainTopics[i];
            r.topic = c.mainTopics[i].topics[z];
            c.classTopicMapped[c.mainTopics[i].topics[z].ID] = r;

            if(c.mainTopics[i].topics[z].goals)
            for(var g=0; g < c.mainTopics[i].topics[z].goals.length; g++){
              cs.goalMapped[c.mainTopics[i].topics[z].goals[g].ID] = {
                goal:c.mainTopics[i].topics[z].goals[g],
                topic:c.mainTopics[i].topics[z],
                mainTopic:c.mainTopics[i]
              };
              var r = {};
              r.mainTopic = c.mainTopics[i];
              r.topic = c.mainTopics[i].topics[z];
              r.goal = c.mainTopics[i].topics[z].goals[g];
              c.classGoalMapped[c.mainTopics[i].topics[z].goals[g].ID] = r;

              if(c.mainTopics[i].topics[z].goals[g].tasks)
              for(var t=0; t < c.mainTopics[i].topics[z].goals[g].tasks.length; t++){
                cs.taskMapped[c.mainTopics[i].topics[z].goals[g].tasks[t].ID] = {
                  task:c.mainTopics[i].topics[z].goals[g].tasks[t],
                  goal:c.mainTopics[i].topics[z].goals[g],
                  topic:c.mainTopics[i].topics[z],
                  mainTopic:c.mainTopics[i]
                };
                var r = {};
                r.mainTopic = c.mainTopics[i];
                r.topic = c.mainTopics[i].topics[z];
                r.goal = c.mainTopics[i].topics[z].goals[g];
                r.task = c.mainTopics[i].topics[z].goals[g].tasks[t];
                c.classTasksMapped[c.mainTopics[i].topics[z].goals[g].tasks[t].ID] = r;
              }
            }
          }
        }

      // Remove tasks in "Aktuelles" task blocks that are no longer distributed in this class.
      // Only run when class content payload includes mainTopics in this update.
      if(cs.mainTopics && angular.isArray(cs.mainTopics)){
        self.removeClassCurrentInfoUnlinkedTasks(cs,true);
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.collaborations = [];

    self.updateCollaborations = function(r){
      function updateCollaboration(c,n){
        if(c){
          // update collaboration

          if(!self.tabButtons) self.tabButtons = {};
          if(!self.tabButtons[c.Class]) self.tabButtons[c.Class] = [];

          for(var i=0; i < self.tabButtons[c.Class].length; i++){
            if(!self.tabButtons[c.Class][i].collaboration) continue;
            if(self.tabButtons[c.Class][i].collaboration == c.ID){
              // found the button for this item
              if(!n) {
                c.deleted = true;
                self.removeTabButton(c.Class,self.tabButtons[c.Class][i]);
              }else{
                for(var k in n) c[k] = n[k];
                c["DataJSON"] = JSON.parse(c["JSON"]);
                self.tabButtons[c.Class][i].text = c.DataJSON.title;
              }
              break;
            }
          }

        }else{
          // new collaboration invite for text
          c = {};
          for(var k in n) c[k] = n[k];
          c["DataJSON"] = JSON.parse(c["JSON"]);
          if(c.Type == "doc" && !c.deleted){
            c.open = function(ev){
              // open the document now
              var task = null;
              if(c.DataJSON.task)
                task = self.findTaskInClass(self.currentClass,c.DataJSON.task);
              
              // task can be null here, if the current student does not see the task

              if(task && task.Groups && task.Groups != ''){
                self.currentTaskPartners = self.getUserTaskStatusColleagues(task,self.user);
              }
              self.showTextEditor(c.DataJSON.caption,'',task,null,true,task && task.Groups && task.Groups != '', // preventInvite others
                                  c.DataJSON.id,function(){
                // editor closed, only the owner will save it, do nothing now?
                // remove the button now
                // updateCollaboration(self.collaborations[i],null);                    
              },null,false,false,ev);              
            };

            var config = {
              bounce:true,
              collaboration:c.ID,
              text:c.DataJSON.title,
              icon:c.DataJSON.icon ? "fa-fw " + c.DataJSON.icon : "fa fa-fw fa-file-text-o", 
              click:function(button,ev){
                // open the document now
                for(var i=0; i < self.collaborations.length; i++){
                  if(self.collaborations[i].ID == button.collaboration){
                    self.collaborations[i].open(ev);
                    return;
                  }
                }
              },
              remove:function(){                                  
                updateCollaboration(c,null);
              }
            };
            self.addTabButton(c.Class,config);   
          }
          self.collaborations.push(c);       
        }
      }
      var now = self.collaborations;
      for(var i=0; i < r.length; i++){
        var found = false;
        for(var z=0; z < now.length; z++){
          if(now[z].ID == r[i].ID){
            found = true;
            updateCollaboration(now[z],r[i]);
            break;
          }
        }
        if(!found){
          updateCollaboration(null,r[i]);
        }
      }
      for(var z=0; z < now.length; z++){
        var found = false;
        for(var i=0; i < r.length; i++){
          if(now[z].ID == r[i].ID){
            found = true;
            break;
          }
        }
        if(!found){
          // remove the item now
          updateCollaboration(now[z],null);
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassCalendars = function(cs){
      if(!self.classContent[cs.ID]) self.classContent[cs.ID] = {};
      var c = self.classContent[cs.ID];
      self.updateContentDeep(cs,c,["classCalendar"]);      
      self.updateContentDeep(cs,c,["classCalendarNotes", "Checked"]);
      // create classCalendarByDate sub arrays 
      if(!c.classCalendarByDate) c.classCalendarByDate = {};
      if(!c.classCalendarByTask) c.classCalendarByTask = {};
      // empty the arrays
      for(var k in c.classCalendarByDate){
        while(c.classCalendarByDate[k].length > 0) c.classCalendarByDate[k].pop(); 
      }
      for(var k in c.classCalendarByTask){
        while(c.classCalendarByTask[k].length > 0) c.classCalendarByTask[k].pop(); 
      }
      for(var i=0; i < c.classCalendar.length; i++){
        if(!c.classCalendarByDate[c.classCalendar[i].Date]) c.classCalendarByDate[c.classCalendar[i].Date] = [];
        c.classCalendarByDate[c.classCalendar[i].Date].push(c.classCalendar[i]);
        if(c.classCalendar[i].Task){
          if(!c.classCalendarByTask[c.classCalendar[i].Task]) c.classCalendarByTask[c.classCalendar[i].Task] = [];
          c.classCalendarByTask[c.classCalendar[i].Task].push(c.classCalendar[i]);
        }
      }
      // sort them now
      for(var k in c.classCalendarByDate){
        c.classCalendarByDate[k].sort(function(a,b){
          if(a.OrderIndex == b.OrderIndex){
            return a.ID > b.ID ? 1 : -1;
          }
          return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
        });
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.fetchRubricsTimer = null;
    self.fetchRubricsGuids = [];
    self.fetchRubricsGuidsMissing = [];
    self.fetchRubricsGuidsFetching = [];
    self.fetchRubrics = function(guids){
      var deferred = $q.defer();
      var added = false;
      for(var i=0; i < guids.length; i++){
        if(self.fetchRubricsGuidsMissing.indexOf(guids[i]) != -1){
          continue;
        }
        if(self.fetchRubricsGuidsFetching.indexOf(guids[i]) != -1){
          continue;
        }
        if(self.fetchRubricsGuids.indexOf(guids[i]) == -1){
          self.fetchRubricsGuids.push(guids[i]);
          added = true;
        }
      }
      if(!added) return deferred.promise;
      // debounce timer
      if(self.fetchRubricsTimer){
        clearTimeout(self.fetchRubricsTimer);
        self.fetchRubricsTimer = null;
      }

      self.fetchRubricsTimer = setTimeout(function(){
        var now = self.fetchRubricsGuids.slice(0);
        self.fetchRubricsGuids = []; // clear again
        for(var i=0; i < now.length; i++)
          self.fetchRubricsGuidsFetching.push(now[i]);
        self.apiPost("ajax",{"action":"getRubrics", "guids":now.join(",")})
        .then(function(result) {
          if(result.rubrics)
            self.updateRubricsData(result.rubrics);
          for(var i=0; i < now.length; i++){
            var found = false;
            for(var z=0; z < self.rubrics.length; z++){
              if(self.rubrics[z].GUID == now[i]){
                found = true;
                break;
              }
            }
            if(!found){
              // mark as not found, no retry
              self.fetchRubricsGuidsMissing.push(now[i]);
            }
          }
          deferred.resolve();
        });
      },500);
      return deferred.promise;      
    }
    self.updateRubrics = function(){
      var deferred = $q.defer();
      self.apiPost("ajax",{"action":"getRubrics"}).then(function(result) {
        if(result.rubrics)
          self.updateRubricsData(result.rubrics);
        deferred.resolve();
      });
      return deferred.promise;      
    }

    self.updateRubricsData = function(s){
      if(!s) return; // empty data
      if(!self.rubrics) self.rubrics = [];
      for(var i = 0; i < s.length; i++){
        var active = parseInt(s[i]["Active"],10);
        if(!isNaN(active) && active === 0){
          self.removeRubricFromLocalData(s[i]);
          continue;
        }
        var found = false;
        s[i]["ID"] = parseInt(s[i]["ID"]);
        s[i]["DataJSON"] = JSON.parse(s[i]["Data"]);
        for(var z = 0; z < self.rubrics.length; z++){
          if(self.rubrics[z].ID == s[i].ID){
            for(var k in s[i]){
              self.rubrics[z][k] = s[i][k];
            }
            found = true;
            break;
          }
        }
        if(found) continue;
        self.rubrics.push(s[i]);
      }
      //self.updateContentDeep({rubrics:s},self,["rubrics"],false,true);
    };

    self.updateRubricsStatus = function(){
      var deferred = $q.defer();
      self.apiPost("ajax",{"action":"getRubricsStatus","noerror":1,"noindicator":1})
      .then(function(result) {
        if(self.user.Teacher == 0)
          self.updateUser({ID:self.user.ID, rubricStatus:result.rubricStatus});
        if(self.user.Teacher == 1){
          for(var k in result.rubricStatus){
            self.updateUser({ID:k, rubricStatus:result.rubricStatus[k]});
          }
        }
        deferred.resolve();            
      });
      return deferred.promise;      
    };

    self.skillSets = [];

    self.updateSkillSets = function(s){
      self.updateContentDeep({skillSets:s},self,["skillSets"]);
    };    

    self.fetchSkillSet = function(id){
      var deferred = $q.defer();
      for(var i=0; i < self.skillSets.length; i++){
        if(self.skillSets[i].ID == id){
          if(self.skillSets[i].DataJSON) {
            deferred.resolve(self.skillSets[i]);
            return deferred.promise;
          }
          break;
        }
      }
      self.apiPost("ajax",{"action":"getSkillSet", "ID":id})
       .then(function(data) {
          self.updateSkillSets([data.set]);
          for(var i=0; i < self.skillSets.length; i++){
            if(self.skillSets[i].ID == id){
              if(self.skillSets[i].DataJSON) {
                deferred.resolve(self.skillSets[i]);
              }
              break;
            }
          }
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.isRubricUsedInTasks = function(GUID){
      if(GUID == "") return false;
      var r = [];
      var found = false;
      var mainTopicSources = self.userContent.mainTopics;
      for(var si=0; si < mainTopicSources.length; si++){
        var mainTopics = mainTopicSources[si];
        if(!mainTopics || !angular.isArray(mainTopics)) continue;
        for(var m=0; m < mainTopics.length && !found; m++){
          var mt = mainTopics[m];
          if(!mt || !mt.topics || !angular.isArray(mt.topics)) continue;
          for(var t=0; t < mt.topics.length && !found; t++){
            var topic = mt.topics[t];
            if(!topic || !topic.goals || !angular.isArray(topic.goals)) continue;
            for(var g=0; g < topic.goals.length && !found; g++){
              var goal = topic.goals[g];
              if(!goal || !goal.tasks || !angular.isArray(goal.tasks)) continue;
              for(var x=0; x < goal.tasks.length && !found; x++){
                var task = goal.tasks[x];
                if(!task) continue;
                var dataJSON = task.DataJSON;
                if(!dataJSON || !dataJSON.hints) continue;
                if(typeof dataJSON == "string"){
                  try{
                    dataJSON = JSON.parse(dataJSON);
                  }catch(parseErr){
                    continue;
                  }
                }
                if(!dataJSON.hints || !angular.isArray(dataJSON.hints)) continue;

                for(var h=0; h < dataJSON.hints.length; h++){
                  var hint = dataJSON.hints[h];
                  if(!hint || hint.type != "rubric") continue;
                  var hintGUID = $.trim(String(hint.rubric || ""));
                  if(hintGUID == GUID){
                    found = true;
                    r.push(task);
                    break;
                  }
                }
              }
            }
          }
        }
      }
      return r;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////


    self.userContent = {};

    self.updateMyContent = function(r){
      if(!self.userContent) self.userContent = {};
      var c = self.userContent;

      if(r.archivedMainTopics)
        self.updateContentDeep(r,c,["archivedMainTopics","topics"]);

      self.updateContentDeep(r,c,["mainTopics","topics","goals","tasks"]);

      self.getTaskByIDmap = {};
      self.getGoalByIDmap = {};

      self.mainTopicColorChoice = [];
      if(self.userContent.mainTopics)
        for(var i=0; i < self.userContent.mainTopics.length; i++){
          if(self.userContent.mainTopics[i].shareSettings)
            for(var z=0; z < self.userContent.mainTopics[i].shareSettings.length; z++){
              var s = self.userContent.mainTopics[i].shareSettings[z];
              self.updateUser({ID:s.User,Name:s.Name,Surname:s.Surname,Email:s.Email});
            }

          if(self.mainTopicColorChoice.indexOf(self.userContent.mainTopics[i].Color) < 0)
            self.mainTopicColorChoice.push(self.userContent.mainTopics[i].Color);
        }

      var sortedColors = [];
      for(var x = 0; x < self.colorChoice.length; x++)
        if(self.mainTopicColorChoice.indexOf(self.colorChoice[x]) >= 0) sortedColors.push(self.colorChoice[x]);

      self.mainTopicColorChoice = sortedColors;

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.users = {};

    self.updateUser = function(s){
      s.ID = parseInt(s.ID);
      if(!self.users[s.ID]) self.users[s.ID] = {};
      var c = self.users[s.ID];
      if(s.ID) c.ID = s.ID; // also add the ID here for use later
      if(s.Name) c.Name = s.Name;
      if(s.Surname) c.Surname = s.Surname;
      if(s.Email) c.Email = s.Email;
      if(s.lastActivity) c.lastActivity = s.lastActivity;
      if(s.Salt) c.Salt = s.Salt;
      if(s.InitPassword) c.InitPassword = s.InitPassword;
      if(s.Avatar) c.Avatar = s.Avatar;

      if(!c.journal) c.journal = [];
      if(!c.journalTaskMapped) c.journalTaskMapped = {};
      if(!c.journalLearningGoalMapped) c.journalLearningGoalMapped = {};

      if(!c.userTasks) c.userTasks = {};

      if(!c.taskStatusMapped)     c.taskStatusMapped = {};
      if(!c.goalStatusMapped)     c.goalStatusMapped = {};
      if(!c.rubricStatusMapped)   c.rubricStatusMapped = {};

      if(!c.calendars) c.calendars = {};
      if(!c.calendarNotes) c.calendarNotes = {};

      if(s.calendars){
        // update all calendar items of this user
        if(!c.calendarsByDate) c.calendarsByDate = {};
        if(!c.calendarsByTask) c.calendarsByTask = {};

        for(var k in s.calendars){
          if(!c.calendars[k]) c.calendars[k] = [];
          if(!c.calendarsByDate[k]) c.calendarsByDate[k] = {};
          if(!c.calendarsByTask[k]) c.calendarsByTask[k] = {};
          self.updateContentDeep(s.calendars,c.calendars,[k]);
          c.calendars[k].sort(function(a,b){
            if(a.ID < b.ID) return 1;
            if(a.ID > b.ID) return -1;
            if(a.Date < b.Date) return 1;
            if(a.Date > b.Date) return -1;
            return 0;
          });
          // empty the arrays
          for(var x in c.calendarsByDate[k]){
            while(c.calendarsByDate[k][x].length > 0) c.calendarsByDate[k][x].pop(); 
          }
          for(var x in c.calendarsByTask[k]){
            while(c.calendarsByTask[k][x].length > 0) c.calendarsByTask[k][x].pop(); 
          }
          for(var i=0; i < c.calendars[k].length; i++){
            if(!c.calendarsByDate[k][c.calendars[k][i].Date]) c.calendarsByDate[k][c.calendars[k][i].Date] = [];
            c.calendarsByDate[k][c.calendars[k][i].Date].push(c.calendars[k][i]);
            if(c.calendars[k][i].Task){
              if(!c.calendarsByTask[k][c.calendars[k][i].Task]) c.calendarsByTask[k][c.calendars[k][i].Task] = [];
              c.calendarsByTask[k][c.calendars[k][i].Task].push(c.calendars[k][i]);
            }
          }
          // sort them now
          for(var x in c.calendarsByDate[k]){
            c.calendarsByDate[k][x].sort(function(a,b){
              if(a.OrderIndex == b.OrderIndex){
                return a.ID > b.ID ? 1 : -1;
              }
              return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
            });
          }
        }
      }
      if(s.calendarNotes){
        // update all calendar items of this user
        for(var k in s.calendarNotes){
          if(!c.calendarNotes[k]) c.calendarNotes[k] = [];
          self.updateContentDeep(s.calendarNotes,c.calendarNotes,[k]);
          c.calendarNotes[k].sort(function(a,b){
            if(a.ID < b.ID) return 1;
            if(a.ID > b.ID) return -1;
            if(a.Date < b.Date) return 1;
            if(a.Date > b.Date) return -1;
            return 0;
          });
        }
      }

      if(s.goalStatus)
        for(var i=0; i < s.goalStatus.length; i++){
          var goalid = s.goalStatus[i]["LearningGoalID"];
          if(!c.goalStatusMapped[goalid]) {
            c.goalStatusMapped[goalid] = {};
          }
          for(var k in s.goalStatus[i]){
            c.goalStatusMapped[goalid][k] = s.goalStatus[i][k];
          }
        }


      if(s.rubricStatus){
        // merge newer existing content
        /*
        if(c.rubricStatus)
          for(var i = c.rubricStatus.length-1; i >= 0; i--){
            s.rubricStatus.unshift(c.rubricStatus[i]);
          }
        */
        self.updateContentDeep(s,c,["rubricStatus"]);
        c.rubricStatus.sort(function(a,b){
          return (a.ID < b.ID ? 1 : (a.ID > b.ID ? -1 : 0));
        });

        // map rubricStatus latest entries to keys
        if(c.rubricStatusMapped){
          for(var k in c.rubricStatusMapped){
            for(var key in c.rubricStatusMapped[k]){
              c.rubricStatusMapped[k][key].student = null;
              c.rubricStatusMapped[k][key].teacher = null;
            }
          }
        }
        for(var i = 0; i < c.rubricStatus.length; i++){
          var rubricid = parseInt(c.rubricStatus[i].Rubric);
          if(!c.rubricStatusMapped[rubricid]) {
              c.rubricStatusMapped[rubricid] = {};
          }
          var key = c.rubricStatus[i].Row + "_"+c.rubricStatus[i].Col;
          if(!c.rubricStatusMapped[rubricid][key]){
              c.rubricStatusMapped[rubricid][key] = {teacher:null, student:null};
          }
          if(c.rubricStatusMapped[rubricid][key].teacher == null){
            if(c.rubricStatus[i].User != c.rubricStatus[i].Owner)
              c.rubricStatusMapped[rubricid][key].teacher = c.rubricStatus[i];
          }
          if(c.rubricStatusMapped[rubricid][key].student == null){
            if(c.rubricStatus[i].User == c.rubricStatus[i].Owner)
              c.rubricStatusMapped[rubricid][key].student = c.rubricStatus[i];
          }
        }
      }
      if(s.taskStatus)
        for(var i=0; i < s.taskStatus.length; i++){
          var taskid = s.taskStatus[i]["TaskID"];
          if(!c.taskStatusMapped[taskid]) {
            c.taskStatusMapped[taskid] = {};
          }
          for(var k in s.taskStatus[i]){
            c.taskStatusMapped[taskid][k] = s.taskStatus[i][k];
            if(k == "Feedback"){
              c.taskStatusMapped[taskid]["FeedbackJSON"] =
                c.taskStatusMapped[taskid][k] &&
                c.taskStatusMapped[taskid][k].indexOf("[") === 0 ? JSON.parse(c.taskStatusMapped[taskid][k]) :
               (c.taskStatusMapped[taskid][k] && c.taskStatusMapped[taskid][k] != '' ? [{"Message":c.taskStatusMapped[taskid][k],"User":self.user.ID,"Created":new Date()}] : []);
            }
          }
        }


      if(s.userTasks){
        // update all calendar items of this user
        for(var k in s.userTasks){
          if(!c.userTasks[k]) c.userTasks[k] = [];
          self.updateContentDeep(s.userTasks,c.userTasks,[k]);
        }
      }

      if(!c.journalMapped) c.journalMapped = {};

      if(s.journal && s.journal.length > 0){
        // this will take much compute power for teachers with many students and long journals,
        // do this lazzy
        for(var i=0; i < s.journal.length; i++){

          s.journal[i].Created = moment(s.journal[i].Created).toDate();
          if(!s.journal[i].DataJSON)
            s.journal[i].DataJSON = !s.journal[i].Data || s.journal[i].Data == '' ? {} : JSON.parse(s.journal[i].Data);

          // we should reuse old objects so bindings will keep alive, not delete and recrate them
          var oldItem = null;
          var oldItemMapped = null;
          if(c.journalMapped[s.journal[i].ID]){
            oldItem = c.journalMapped[s.journal[i].ID];
            c.journal.splice(c.journal.indexOf(oldItem),1); // remove old item from journal list of user
            if(c.journalTaskMapped && c.journalTaskMapped[s.journal[i].DataJSON.taskid]){
              oldItemMapped = c.journalTaskMapped[s.journal[i].DataJSON.taskid][s.journal[i].ID];
              delete c.journalTaskMapped[s.journal[i].DataJSON.taskid][s.journal[i].ID];
            }
            if(c.journalLearningGoalMapped && c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid]){
              oldItemMapped = c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid][s.journal[i].ID];
              delete c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid][s.journal[i].ID];
            }
          }
          if(s.journal[i].Active == 0) continue; // skip insert it

          if(s.journal[i].DataJSON && s.journal[i].DataJSON.taskid){
            if(!c.journalTaskMapped[s.journal[i].DataJSON.taskid])
                c.journalTaskMapped[s.journal[i].DataJSON.taskid] = {};
            if(oldItemMapped){
              for(k in s.journal[i]){
                oldItemMapped[k] = s.journal[i][k]; // update all data
              }
              c.journalTaskMapped[s.journal[i].DataJSON.taskid][s.journal[i].ID] = oldItemMapped;
            }else{
              c.journalTaskMapped[s.journal[i].DataJSON.taskid][s.journal[i].ID] = s.journal[i];
            }
          }
          if(s.journal[i].DataJSON && s.journal[i].DataJSON.goalid){
            if(!c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid])
                c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid] = {};
            if(oldItemMapped){
              for(k in s.journal[i]){
                oldItemMapped[k] = s.journal[i][k]; // update all data
              }
              c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid][s.journal[i].ID] = oldItemMapped;
            }else{
              c.journalLearningGoalMapped[s.journal[i].DataJSON.goalid][s.journal[i].ID] = s.journal[i];
            }
          }


          // Finaly add the item to the users journal list
          if(oldItem){
            for(k in s.journal[i]){
              oldItem[k] = s.journal[i][k]; // update all data
            }
            c.journal.push(oldItem);
            c.journalMapped[oldItem.ID] = oldItem;
          }else{
            c.journal.push(s.journal[i]);
            c.journalMapped[s.journal[i].ID] = s.journal[i];
          }
          self.users[s.ID].hasMappedJournalItems = false; // remap on next journal display
        }

        // order elements by Created desc
        c.journal.sort(function(a,b){
          return a.Created < b.Created ? 1 : (a.Created > b.Created ? -1 : 0);
        });

      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getUserLearningGoalStatusCSSClass = function(goal,user,teacher){
      var s = self.getUserLearningGoalStatus(goal,user);
      if(!s) return "";
      var ts = teacher ? s.Teacher : s.Status;
      if(ts == "red") return "statusColorRedBackground";
      if(ts == "yellow") return "statusColorYellowBackground";
      if(ts == "lightgreen") return "statusColorLightGreenBackground";
      if(ts == "green") return "statusColorGreenBackground";
      return "";
    };

    self.getUserLearningGoalStatus = function(goal, user, create){
      if(!goal) return null;
      if(!user) return null;

      if(self.users[user.ID] && self.users[user.ID].goalStatusMapped && self.users[user.ID].goalStatusMapped[goal.ID]){
        return self.users[user.ID].goalStatusMapped[goal.ID];
      }

      var s = {};
      s.Status = "";
      s.Teacher = "";
      s.LearningGoalID = goal.ID;
      s.LearningGoal = goal;
      s.TopicID = goal.Topic;

      if(create) self.users[user.ID].goalStatusMapped[goal.ID] = s;

      return s;
    };

    self.getUserRubricStatus = function(rubric, user){
      if(!rubric) return [];
      if(!user) return [];
      var status = [];
      if(self.users[user.ID] && self.users[user.ID].rubricStatus){
        for(var i=0; i < self.users[user.ID].rubricStatus.length; i++){
          if(self.users[user.ID].rubricStatus[i].Rubric == rubric.ID){
            status.push(self.users[user.ID].rubricStatus[i]);
          }
        }
      }
      // sort desc
      status.sort(function(a,b){
        return (a.ID < b.ID ? 1 : (a.ID > b.ID ? -1 : 0));
      });
      return status;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getUserTaskStatus = function (task, user, create){
      if(!user || !task || !task.ID) return {};

      if(self.users[user.ID] && self.users[user.ID].taskStatusMapped &&
         self.users[user.ID].taskStatusMapped[task.ID]){
        if(!self.users[user.ID].taskStatusMapped[task.ID].Task){
          var tt = self.getTaskByID(task.ID);
          if(tt) {
            self.users[user.ID].taskStatusMapped[task.ID].MainTopic = tt.mainTopic;
            self.users[user.ID].taskStatusMapped[task.ID].Topic = tt.topic;
            self.users[user.ID].taskStatusMapped[task.ID].LearningGoal = tt.goal;
            self.users[user.ID].taskStatusMapped[task.ID].Task = tt.task;
          }
        }
        return self.users[user.ID].taskStatusMapped[task.ID];
      }

      var s = {};
      s.Status = "";
      s.Answer = "";
      s.Feedback = "";
      s.FeedbackJSON = []; // empty list
      s.Note = "";
      s.ColleaguesIDs = "";
      s.TaskID = task.ID;
      s.Task = task;

      if(create) {
        if(!self.users[user.ID]) self.users[user.ID] = {};
        if(!self.users[user.ID].taskStatusMapped) self.users[user.ID].taskStatusMapped = {};
        self.users[user.ID].taskStatusMapped[task.ID] = s;
//        return self.getUserTaskStatus(task, user);
      }

      return s;
    };

    self.taskReadyToRepeat = function(t){
      if(!t.DataJSON.Repeat) return false;      
      var s = self.getUserTaskStatus(t,self.user,true);
      if(s.Status == "OK" && s.Updated){
        var journalData =
          self.getStudentFilteredJournal(self.user, {WHERE: "task", WHEREITEM:t});
        var n = new Date();  
        for(var i=0; i < journalData.length; i++){
          if(journalData[i].Type == "taskdone"){
            var parts = journalData[i].Updated.split(" ");
            var c = new Date().fromMysqlFormat(parts[0] + " 00:00:00");
            if(n.getTime() > c.getTime() + (1000 * 3600 * 24) * t.DataJSON.Repeat){
              return true;
            }
          }
        }
      }
      return false;
    };

    self.filterColleagues = function(ids){
      var parts = ids.split(",").map(Number);
      return function(item){
        return parts.indexOf(item.ID) >= 0;
      };
    };

    self.getClassStudentsTaskStatusHTML = function(students,task){
      var ok = 0;
      var x = 0;
      var d = 0;
      var n = 0;
      var sun = 0;
      var clouds = 0;
      var thunder = 0;
      var invis = 0;
      var visibleTo = 0;
      for(var i=0; i < students.length; i++){
        if(self.currentClassResultStudentFilter &&
           self.currentClassResultStudentFilter.length > 0){
          // filter is used, skip not in list
          if(self.currentClassResultStudentFilter.indexOf(students[i].ID) == -1) continue;
        }

        var visible = self.isUserTaskVisibleDeep (self.currentMainTopic,self.currentTopic, task,students[i]);
        if(visible) visibleTo++; else invis++;
        var stat = self.getUserTaskStatus(task,students[i],false);
        if(stat.Status == "") n++; else
        if(stat.Status == "OK") ok++; else
        if(stat.Status == "x" || stat.Status == "FAIL") x++; else
        if(stat.Status == "?") d++;
        if(stat.Rating == 1) sun++;
        if(stat.Rating == 2) clouds++;
        if(stat.Rating == 3) thunder++;
      }
      var r = [];
      r.push('<span style="color:green"><i class="fa fa-check" style="font-size: 80%"></i> '+ok+'/'+visibleTo+'</span>');
      if(x > 0)  r.push('<span style="color:red"><i class="fa fa-exclamation-triangle" style="font-size: 80%"></i> '+x+'</span>');
      if(d > 0)  r.push('<span style="color:orange"><i class="fa fa-comments" style="font-size: 80%"></i> '+d+'</span>');
      if(invis > 0)  r.push('<span style="color:gray"><i class="fa fa-eye-slash" style="font-size: 80%"></i> '+invis+'</span>');
      if(sun > 0 || clouds > 0 || thunder > 0) r.push(' '); // space
      if(sun > 0) r.push('<span><img src="https://learningview.org/app/sun.svg" style="position: relative;top: 2px;width:14px"> '+sun+'</span>');
      if(clouds > 0) r.push('<span><img src="https://learningview.org/app/clouds.svg" style="position: relative;top: 2px;width:14px"> '+clouds+'</span>');
      if(thunder > 0) r.push('<span><img src="https://learningview.org/app/thunder.svg" style="position: relative;top: 2px;width:14px"> '+thunder+'</span>');

      return r.join('&nbsp;&nbsp;');
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getTopicTaskCount = function(topic, unsolved){
      var t = 0;
      var level = self.getUserLevelFilter(topic);
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          //if(topic.goals[i].tasks[z].userTask == "1") continue;
          if(level != 0 && !self.isUserLevelInFilter(topic.goals[i],topic.goals[i].tasks[z].Level)) continue;
          if(unsolved){
            var s = self.getUserTaskStatus(topic.goals[i].tasks[z],self.user);
            if(s.Status == "OK") continue;
            if(s.Status == "?") continue;
          }
          t++;
        }
      }
      return t;
    };
    self.countTaskHintApproveRequests = function(task){
      if(!task || !task.DataJSON || !task.DataJSON.hints) return 0;
      var c = 0;
      for(var i=0; i < task.DataJSON.hints.length; i++){
        if(task.DataJSON.hints[i].visible == 3){
          c += self.countUserTaskHintAskApproved(i, task);
        }
      }
      return c;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getTopicRegisteredInputCount = function(topic){
      if(!self.currentClass) return 0; // only in class
      var t = 0;
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          if(topic.goals[i].tasks[z].Social == "input" && topic.goals[i].tasks[z].DataJSON.Register == 1)
            for(var s=0; s < self.currentClass.students.length; s++){
              var c = self.getUserTaskStatus(topic.goals[i].tasks[z],self.currentClass.students[s]);
              if(c.Status == "s") t++;
            }
        }
      }
      return t;
    };
    self.getTopicWaitingApproveCount = function(topic){
      if(!self.currentClass) return 0; // only in class
      var t = 0;
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          t += self.countTaskHintApproveRequests(topic.goals[i].tasks[z]);
        }
      }
      return t;
    };

    self.getTopicWaitingHintApproveNames = function(topic){
      if(!self.currentClass) return ''; // only in class
      var list = {};
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          if(self.countTaskHintApproveRequests(topic.goals[i].tasks[z])){
            // at least one
            list[topic.goals[i].tasks[z].ID] = {name:topic.goals[i].tasks[z].Name};
          }
        }
      }
      var out = "";
      for (var k in list){
        out += (out != '' ? '\n\n':'') + list[k].name;
      }      
      return out;
    };

    self.findFirstTopicWaitingHintApprove = function(topic){
      if(!self.currentClass) return 0; // only in class
      var t = 0;
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          if(self.countTaskHintApproveRequests(topic.goals[i].tasks[z])){
            // at least one
            // goto task now
            self.findAndShowTask(topic.goals[i].tasks[z],false);
            return; // done
          }
        }
      }
    };

    self.getTopicRegisteredInputNames = function(topic){
      if(!self.currentClass) return ''; // only in class
      var list = {};
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          if(topic.goals[i].tasks[z].Social == "input" && topic.goals[i].tasks[z].DataJSON.Register == 1)
            for(var s=0; s < self.currentClass.students.length; s++){
              var c = self.getUserTaskStatus(topic.goals[i].tasks[z],self.currentClass.students[s]);
              if(c.Status == "s") {
                if(!list[topic.goals[i].tasks[z].ID]) list[topic.goals[i].tasks[z].ID] = {name:topic.goals[i].tasks[z].Name, students:[]};
                list[topic.goals[i].tasks[z].ID].students.push(self.currentClass.students[s].Name);
              }
            }
        }
      }
      var out = "";
      for (var k in list){
        out += (out != '' ? '\n\n':'') + list[k].name+': \n'+list[k].students.join(", ");
      }
      
      return out;
    };
    self.findFirstTopicRegisteredInput = function(topic){
      if(!self.currentClass) return 0; // only in class
      var t = 0;
      for(var i=0; i < topic.goals.length; i++){
        if(topic.goals[i].tasks)
        for(var z=0; z < topic.goals[i].tasks.length; z++){
          if(topic.goals[i].tasks[z].Social == "input" && topic.goals[i].tasks[z].DataJSON.Register == 1)
            for(var s=0; s < self.currentClass.students.length; s++){
              var c = self.getUserTaskStatus(topic.goals[i].tasks[z],self.currentClass.students[s]);
              if(c.Status == "s") {
                // goto task now
                self.findAndShowTask(topic.goals[i].tasks[z],false);
                return; // done
              }
            }
        }
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.whenCallbacks = {};
    self.when = function(name,callback){
      if(!self.whenCallbacks[name]) self.whenCallbacks[name] = []; // list of callbacks
      var pos = self.whenCallbacks[name].indexOf(callback);
      if(pos == -1){
        // add it now
        self.whenCallbacks[name].push(callback);
      }
    };
    self.track = function(name,data){
      if(self.whenCallbacks[name]){
        for(var i=0; i < self.whenCallbacks[name].length; i++){
          self.whenCallbacks[name][i](data);
        }
      }
      var d = null;
      if(self.user && (self.user.Science >= 50) && self.currentClass && self.currentClass.ID == "78817") {
        d = {};
        for(var k in data){
          if(typeof(data[k]) == "object") continue; // skip
          if(typeof(data[k]) == "function") continue; // skip
          if(k == "TeacherName" || k == "TeacherSurname") continue; 
          if(k == "Data" && data["DataJSON"]) {
            // add subitems from data to item 
            for(var s in data["DataJSON"]) {
              if(typeof(data["DataJSON"][s]) == "object"){
                d[s] = angular.toJson(data["DataJSON"][s]);
                continue; // skip
              } 
              if(typeof(data["DataJSON"][s]) == "function") continue; // skip
              d[s] = data["DataJSON"][s];
            }
            continue;
          }
          d[k] = data[k];
        }
        if(!d.classid && self.currentClass) d.classid = self.currentClass.ID;
        var item = {'name':name,'data':d, "time":new Date().toMysqlFormat()};
        if(window.trackScienceData){
          // strip and copy data
          if(self.trackBufferBeforeLoad && self.trackBufferBeforeLoad.length > 0){
            for(var i=0; i < self.trackBufferBeforeLoad.length; i++){
              window.trackScienceData(self.user.ID, self.trackBufferBeforeLoad[i].name, self.trackBufferBeforeLoad[i].data);
            }
            self.trackBufferBeforeLoad = [];
          }
          window.trackScienceData(self.user.ID, name, d);
        }else{
          // not yet loaed
          if(self.user.Science >= 5){
            if(!self.trackBufferBeforeLoad) self.trackBufferBeforeLoad = [];
            self.trackBufferBeforeLoad.push(item);            
          }
        }
        /*
        if(!self.trackBuffer) self.trackBuffer = [];
        self.trackBuffer.push(JSON.stringify(item));
        if(!self.trackBufferLastSaved) self.trackBufferLastSaved = new Date();
        var lastSavedDiffSeconds = (new Date().getTime() - self.trackBufferLastSaved.getTime())/1000;
        if(self.trackBuffer.length > 20 || lastSavedDiffSeconds > 60 || name == "taskclosed" || name == "taskopened"){
          var all = '['+self.trackBuffer.join(",")+']';
          self.apiPost("scienceTrack",{user:self.user.ID, data:all});
          self.trackBufferLastSaved = new Date();
          self.trackBuffer = [];
        }        
        */
      }
      if(self.user && self.user.Science > 0){
        console.log("EVENT: "+name, d ? d : data);
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showAJAXLoadingIndicator = function(ev,f){

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.preventDoubleClick = function(){
      if(self.preventDoubleClickLast) return true;
      self.preventDoubleClickLast = true;
      $timeout(function(){
        delete self.preventDoubleClickLast;
      },300);
      return false;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.lastLoadingIndicatorTimeout = null;
    self.showLoadingIndicator = function(ev,func,timeout){
      if($('#loadingIndicator').length == 0){
        // create new Indicator
        $('#mainPanel').append($('<div id="loadingIndicator" style="display:none;position:absolute;top:50%;left:50%;margin-top:-20px;margin-left:-25px;width:50px;height:40px;z-index:999999"><div class="loader"><div class="bar1"></div><div class="bar2"></div><div class="bar3"></div><div class="bar4"></div><div class="bar5"></div><div class="bar6"></div></div></div>'));
      }

      if(ev && ev.currentTarget && ev.currentTarget.parentNode){
        $(ev.currentTarget.parentNode).append($('#loadingIndicator'));
      }else{
        $('#mainPanel').append($('#loadingIndicator'));
      }
      $('#loadingIndicator').show();
      if(self.lastLoadingIndicatorTimeout){
        $timeout.cancel(self.lastLoadingIndicatorTimeout);
        self.lastLoadingIndicatorTimeout = null;
      }
      $timeout(function(){
        // do processing task
        var done = function(){
          $timeout.cancel(to);
          self.lastLoadingIndicatorTimeout = $timeout(function(){
            $('#loadingIndicator').hide();
            $('#mainPanel').append($('#loadingIndicator'));
          },200);
        };

        var to = $timeout(done,timeout ? timeout : 1500);
        func(done);
      },150);

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.findStudentInClass = function(userid, c){
      if(!c) return null;
      for(var i=0; i < c.students.length; i++){
        if(c.students[i].ID == userid) return c.students[i];
      }
      return null;
    };

    self.showTeacherStudentContextMenu = function(student,ev){
      if(self.user.Teacher != 1) return; // menu only for teacher
      if(!student) return; 
      self.checkHasTeacherNotes("student",student);

      var r = ev.target.getBoundingClientRect();    
      
      var position = $mdPanel.newPanelPosition()
                      .absolute().relativeTo(ev.target)
                      .addPanelPosition('align-start', 'below')
                      .addPanelPosition('align-start', 'center')
                      .addPanelPosition('align-start', 'above');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.FADE);

      var config = {
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        attachTo: angular.element(document.body),
        controller: function($scope, $mdPanel, mdPanelRef){
            $scope.self = self;
            $scope.s = student;
            $scope.close = function(){
              mdPanelRef.close();
            };
        },
        panelClass: 'studentMenuPanel',
        templateUrl: "teacherUserMenuButtonContent.html",
        position: position,
        animation: panelAnimation,
        openFrom: ev,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true
      };
      self.showPanel(config);
    };

    self.showTeacherStudentNotelists = function(student,ev){
      if(self.user.Teacher != 1) return;
      if(!student || !self.currentClass) return;

      var previousState = null;
      var restored = false;
      var restoreState = function(){
        if(restored || !previousState) return;
        restored = true;
        self.teacherNotelistStudent = previousState.teacherNotelistStudent;
        self.currentNotelist = previousState.currentNotelist;
        self.currentNotelistEdit = previousState.currentNotelistEdit;
        self.deleteNotelistAsk = previousState.deleteNotelistAsk;
        self.deleteNotelistItemAsk = previousState.deleteNotelistItemAsk;
        self.currentNotelistItemSelected = previousState.currentNotelistItemSelected;
        self.currentNotelistTargets = previousState.currentNotelistTargets;
        self.currentNotelistChecks = previousState.currentNotelistChecks;
      };

      self.showDialog({
        state:"one",
        targetEvent: ev,
        templateUrl: "teacherStudentNotelists.html",
        skipHide:true,
        onRemoving: function(){
          restoreState();
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.s = student;
          $scope.notelistsLoading = false;
          $scope.notelistLoadError = false;
          $scope.notelistRequestID = 0;

          previousState = {
            teacherNotelistStudent: self.teacherNotelistStudent,
            currentNotelist: self.currentNotelist,
            currentNotelistEdit: self.currentNotelistEdit,
            deleteNotelistAsk: self.deleteNotelistAsk,
            deleteNotelistItemAsk: self.deleteNotelistItemAsk,
            currentNotelistItemSelected: self.currentNotelistItemSelected,
            currentNotelistTargets: self.currentNotelistTargets,
            currentNotelistChecks: self.currentNotelistChecks
          };

          $scope.openStudent = function(s) {
            $scope.s = s;
            $scope.notelistsLoading = true;
            $scope.notelistLoadError = false;
            var requestID = ++$scope.notelistRequestID;
            self.teacherNotelistStudent = s;
            self.currentNotelist = null;
            self.currentNotelistEdit = false;
            self.deleteNotelistAsk = null;
            self.deleteNotelistItemAsk = null;
            self.currentNotelistItemSelected = null;
            self.currentNotelistTargets = null;
            self.currentNotelistChecks = true;

            self.loadTeacherStudentNotelists(s).then(function(notelists){
              if(requestID != $scope.notelistRequestID) return;
              $scope.notelistsLoading = false;
              if(notelists && notelists.length > 0){
                self.changeNotelist(notelists[0]);
              }
            },function(){
              if(requestID != $scope.notelistRequestID) return;
              $scope.notelistsLoading = false;
              $scope.notelistLoadError = true;
            });
          };

          $scope.cancel = function (){
            restoreState();
            self.closeDialog($scope.dialogElement);
          };

          $scope.openStudent(student);
        }
      });
    };

    self.showTeacherStudentTaskChecklistContextMenu = function(task,index,allchecks,callback,ev){
      if(self.user.Teacher != 1) return; // menu only for teacher
      if(!self.currentClass) return; 
      if(!task) return; 

      var r = ev.target.getBoundingClientRect();    
      var position = $mdPanel.newPanelPosition()
                      .absolute().relativeTo(ev.target)
                      .addPanelPosition('align-start', 'center')
                      .addPanelPosition('align-start', 'below')
                      .addPanelPosition('align-start', 'above');
//          .absolute().relativeTo(ev.target)
//          .addPanelPosition('align-start', r.y > window.innerHeight - 320 ? 'above':'below');

      var panelAnimation = $mdPanel.newPanelAnimation()
          .openFrom(ev)
          .withAnimation($mdPanel.animation.FADE);

      var config = {
        onDomAdded: function(e){
          var menu = e[1];
          self.limitPanelToViewport(menu._panelEl);
          var container = menu._panelContainer.get(0);
          container.addEventListener("click", function (e) {
            if (e.target === container) {
              menu.close();
            }
          });          
        },
        attachTo: angular.element(document.body),
        controller: function($scope, $mdPanel, mdPanelRef){
            $scope.self = self;
            $scope.results = {};
            for(var i=0; i < self.currentClass.students.length; i++){
              var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
              var r = 0;
              if(status.Checklist && status.Checklist != ''){
                if(status.Checklist.length > index && status.Checklist[index] == 1) r = 1;
              }
              $scope.results[self.currentClass.students[i].ID] = r;
            }
            $scope.save = function(s,value){
              var status = self.getUserTaskStatus(task,s);
              var n = "";
              for(var i = 0; i < allchecks.length; i++){
                n += '0';
              }
              if(!status.Checklist || status.Checklist == ""){
                status.Checklist = n;
              }
              while(status.Checklist.length < allchecks.length) status.Checklist += '0';
              status.Checklist = status.Checklist.substring(0,index) + value + status.Checklist.substring(index+1);
              if(callback) callback(s,status.Checklist);
              $scope.results[s.ID] = value;
            };
            $scope.close = function(){
              mdPanelRef.close();
            };
        },
        panelClass: 'studentChecklistMenuPanel',
        templateUrl: "teacherUserChecklistContextMenu.html",
        position: position,
        openFrom: ev,
        animation:panelAnimation,
        clickOutsideToClose: true,
        escapeToClose: true,
        focusOnOpen: true
      };

      self.showPanel(config);
    };

