// desktop notifications for macOS and Windows
window.notificationList = [];
window.appHasNoFocus = false;
addLocalNotification = function(title,body){
  if(!window.appHasNoFocus) return;

  if(window.electron && !window.electron.remote && window.Notification){
    // new version without remote
    window.Notification(title,{body:body,requireInteraction:true});
    window.electron.ipcRenderer.send("notification");
  }

  if(window.electron && window.electron.remote && window.electron.remote.Notification){
    if (Notification.permission !== "denied") {
      Notification.requestPermission().then(function(result){
        if(Notification.permission === "granted"){
          // we can use desktop notifications

          var n = new electron.remote.Notification({ title: title, body: body, requireInteraction:true});
          n.show();
          window.notificationList.push(n);
          // dock badge and bounce on macOS
          if(window.electron.remote.app && window.electron.remote.app.dock){
            window.electron.remote.app.dock.setBadge(window.notificationList.length ? window.notificationList.length+"" : "");
            window.electron.remote.app.dock.bounce();
          }
        }
      });
    }
  }
}

function getSelectionText() {
  var text = "";
  var activeEl = document.activeElement;
  var activeElTagName = activeEl ? activeEl.tagName.toLowerCase() : null;
  if ( (activeElTagName == "textarea" || activeElTagName == "input") &&
        typeof activeEl.selectionStart == "number") {
    text = activeEl.value.slice(activeEl.selectionStart, activeEl.selectionEnd);
  } else if (window.getSelection) {
    text = window.getSelection().toString();
  }
  return text;
}
window.addEventListener('paste', function(event) {
  try{
    var paste = (event.clipboardData || window.clipboardData).getData("text");
    mc.track("paste",{text:paste});
  }catch(e){mc.track("paste",{});}
});
window.addEventListener('copy', function(event) {
  mc.track("copy",{text:getSelectionText()});    
});
window.addEventListener('cut', function(event) {
  mc.track("cut",{text:getSelectionText()});    
});

window.addEventListener('focus',function(){
  window.appHasNoFocus = false;
  // The tab has become visible so clear the now-stale Notification.

  // deprecated
  while(window.notificationList.length > 0){
    var n = window.notificationList.pop();
    n.close();
  }
  if(window.electron && window.electron.remote && window.electron.remote.app && window.electron.remote.app.dock){
    window.electron.remote.app.dock.setBadge("");
  }
});
window.addEventListener('blur',function(){
  window.appHasNoFocus = true;
});

if(window.isIOSDevice || window.isAndroidDevice){
  var isWebAudioUnlocked = false;
  var isHTMLAudioUnlocked = false;

  function unlockAudio() {
      if (isWebAudioUnlocked  && isHTMLAudioUnlocked) return;
      if(!window.globalAudioContextPlay){
        window.globalAudioContextPlay = createAudioContext(0);
        window.globalAudioContextRecord = createAudioContext(0);
      }
      // Unlock WebAudio - create short silent buffer and play it
      // This will allow us to play web audio at any time in the app
      var buffer = window.globalAudioContextPlay.createBuffer(1, 1, 44100); // 1/10th of a second of silence
      var source = window.globalAudioContextPlay.createBufferSource();
      source.buffer = buffer;
      source.connect(window.globalAudioContextPlay.destination);
      source.onended = function()
      {
          console.log("WebAudio unlocked!");
          isWebAudioUnlocked = true;
          if (isWebAudioUnlocked && isHTMLAudioUnlocked)
          {
              console.log("WebAudio unlocked and playable w/ mute toggled on!");
              window.removeEventListener("mousedown", unlockAudio);
          }
      };
      source.start();

      // Unlock HTML5 Audio - load a data url of short silence and play it
      // This will allow us to play web audio when the mute toggle is on
      var silenceDataURL = "data:audio/mp3;base64,";
      var tag = document.createElement("audio");
      tag.controls = false;
      tag.preload = "auto";
      tag.loop = false;
      tag.src = silenceDataURL;
      tag.onended = function()
      {
          console.log("HTMLAudio unlocked!");
          isHTMLAudioUnlocked = true;
          if (isWebAudioUnlocked && isHTMLAudioUnlocked)
          {
              console.log("WebAudio unlocked and playable w/ mute toggled on!");
              window.removeEventListener("mousedown", unlockAudio);
          }
      };
      var p = tag.play();
      if (p) p.then(function(){console.log("play success")}, function(reason){console.log("play failed", reason)});
  }

  window.addEventListener("mousedown", unlockAudio);
  /*
  $(window).one("click",function(){
    var silenceSound = new Audio("https://learningview.org/app/sounds/silent.wav");
    silenceSound.play();
    setTimeout(function(){
      silenceSound.pause();
      silenceSound.src = "";
    },10);
  });
  */
}

if("ontouchstart" in document.body)
  document.body.className += ' touch-device';

if (!Object.keys) {
  Object.keys = function (obj) {
    var keys = [], k;
    for (k in obj)
      if (Object.prototype.hasOwnProperty.call(obj, k)) keys.push(k);
    return keys;
  };
}

function matchTimeZones(serverTime){
  timeShiftFromServer = 0;
  var utc = new Date().toMysqlFormat();
  timeShiftFromServer = moment(serverTime).diff(utc);
}
var timeShiftFromServer = 0;
Date.prototype.toMysqlFormat = function() {
  var shifted = new Date(this);
  shifted.setTime(shifted.getTime()+timeShiftFromServer);
  function twoDigits(d) {
    if(0 <= d && d < 10) return "0" + d.toString();
    if(-10 < d && d < 0) return "-0" + (-1*d).toString();
    return d.toString();
  }

  return shifted.getUTCFullYear() + "-" + twoDigits(1 + shifted.getUTCMonth()) + "-" + twoDigits(shifted.getUTCDate()) + " " + twoDigits(shifted.getUTCHours()) + ":" + twoDigits(shifted.getUTCMinutes()) + ":" + twoDigits(shifted.getUTCSeconds());
};

Date.prototype.fromMysqlFormat = function(s) {
  if(s && typeof s.getMonth === 'function') return s; // already a date
  s = s + "";
  if(!s || s == "" || !s.replace) return new Date();
  return new Date(Date.parse(s.replace(/[-]/g, '/')));
};


function readTextFromClipboard (callback){
  try{
    if(typeof cordova != "undefined" &&
       cordova.plugins && cordova.plugins.clipboard){
      cordova.plugins.clipboard.paste(function (clip) {
        console.log("Read from clipboard.");
        callback(clip);
      });
      return;
    }
    if(window.electron){
      var clip = window.electron.clipboard.readText();
      console.log("Read from clipboard.");
      if(clip) callback(clip);
      return;
    }
    if (navigator.clipboard) {
      var tryToReadNow = function(){
        navigator.clipboard.readText().then(function(clip){
          console.log("Read from clipboard.");
          if(clip) callback(clip);
        }, function(e){});
      };
      // ask permissions if exist
      if(navigator.permissions){
        navigator.permissions.query({ name: 'clipboard-read' }).then(function(permission){
          if (permission.state === 'denied') {
            console.log('Not allowed to read clipboard.');
            return;
          }
          tryToReadNow();
       }, function(e){});
      }else{
        tryToReadNow();
      }
    }
  }catch(e){}
};

function readImageFromClipboard (callback){
  try{
    if(window.electron){
      var availableFormats = window.electron.clipboard.availableFormats("clipboard");
      for(var i=0; i < availableFormats.length; i++){
        if(availableFormats[i].indexOf("text/plain") != -1) return; // something else in clipboard
      }
      if (availableFormats.includes("image/png")){
        var img = window.electron.clipboard.readImage("clipboard").toPNG();
        var blob = new Blob([img], {type : 'image/png'});
        if(callback && blob) callback(blob);
      }
      return;
    }
    if (navigator.clipboard) {
      var tryToReadNow = function(){
        navigator.clipboard.read().then(function(items){
          for (var item of items) {
            for(var i=0; i < item.types.length; i++){
              if(item.types[i].indexOf("text/plain") != -1) return; // something else in clipboard
            }
          }
          for (var item of items) {
            if (!item.types.includes('image/png')) continue;
            item.getType('image/png').then(function(blob){
              if(callback && blob) callback(blob);
            })
          }
        }, function(e){});
      };
      // ask permissions if exist
      if(navigator.permissions){
        navigator.permissions.query({ name: 'clipboard-read' }).then(function(permission){
          if (permission.state === 'denied') {
            console.log('Not allowed to read clipboard.');
            return;
          }
          tryToReadNow();
       }, function(e){});
      }else{
        tryToReadNow();
      }
    }
  }catch(e){}
};

function copyTextToClipboard (text,type){
  function fallbackCopyTextToClipboard(text) {
    var textArea = document.createElement("textarea");
    textArea.value = text;

    // Avoid scrolling to bottom
    textArea.style.top = "0";
    textArea.style.left = "0";
    textArea.style.position = "fixed";

    document.body.appendChild(textArea);
    textArea.focus();
    textArea.select();

    try {
      var successful = document.execCommand('copy');
      if(successful) console.log("Copied to clipboard."); else
      alert('Error: Text could not be copied to clipboard.');
    } catch (err) {
      alert('Error: Text could not be copied to clipboard.');
    }
    document.body.removeChild(textArea);
  }
  if(typeof cordova != "undefined" &&
     cordova.plugins && cordova.plugins.clipboard){
    cordova.plugins.clipboard.copy(text);
    console.log("Copied to clipboard.");
    return;
  }
  //text = unescape(encodeURIComponent(text));
  if(type == "html"){
    var d = $('<div></div>');
    d.html(text);
    $("body").append(d);
    window.getSelection().removeAllRanges();
    let range = document.createRange();
    range.selectNode(d.get(0));
    window.getSelection().addRange(range);
    document.execCommand('copy');
    window.getSelection().removeAllRanges();
    d.remove();
    console.log("Copied to clipboard.");
  }else{
    if (!navigator.clipboard) {
      fallbackCopyTextToClipboard(text);
      return;
    }
    navigator.clipboard.writeText(text).then(function() {
      console.log("Copied to clipboard.");
    }, function(err) {
      fallbackCopyTextToClipboard(text);
    });
  }
};

function copyImageToClipboard (img){
  function fallbackCopyImageToClipboard(img) {
    function SelectText(element) {
      var doc = document;
      if (doc.body.createTextRange) {
        var range = document.body.createTextRange();
        range.moveToElementText(element);
        range.select();
      } else if (window.getSelection) {
        var selection = window.getSelection();
        var range = document.createRange();
        range.selectNodeContents(element);
        selection.removeAllRanges();
        selection.addRange(range);
      }
    }
    var d = $('<div style="position:absolute;left:-100000px;width:100px;"><img /></div>');
    $('body').append(d);
    $('img',d).get(0).src = img.src;
    d.attr("contenteditable", true);
    SelectText(d.get(0));
    //Execute copy Command
    //Note: This will ONLY work directly inside a click listenner
    document.execCommand('copy');
    //Unselect the content
    window.getSelection().removeAllRanges();
    //Make the container Div uneditable again
    d.remove();
    d = null;
  }

  try {
    if (!navigator.clipboard) {
      fallbackCopyImageToClipboard(img);
      return;
    }
    fetch(img.src).then(function (response) {
      var pngImageBlob = response.blob();
      navigator.clipboard.write([ new ClipboardItem({ 'image/png': pngImageBlob })]).then(function() {
        console.log("Copied to clipboard.");
      }, function(err) {
        fallbackCopyImageToClipboard(text);
      });
    });    
  } catch (error) {
    console.error(error);
    fallbackCopyImageToClipboard(img);
  }
}

function createImageZoomBox(element,wrap){
  if(element.attr("hasZoombox")) return; // already set
  var zoomScale = 1.0;
  if(wrap) element.wrap('<span style="position:relative"></span>');
  element.css({"user-select":"none"});
  element.attr("draggable","false");
  element.attr("hasZoombox","1");

  var zoom = null;
  var btn = null;

  function createOverlay(e){
    var w = element.get(0).naturalWidth;
    var h = element.get(0).naturalHeight;
    if(!zoom){
      zoom = $('<div style="position:fixed;user-select:none;top:0;left:0;overflow:auto;left:0;top:0;width:100%;height:100%; background: white;z-index:1001;text-align:center"><div style="display:inline-block;position:relative"><img class="largeImage" draggable="false" style="pointer-events:none" /><img class="largeImageOverlay" draggable="false" style="pointer-events:none;position:absolute;width:100%;height:100%;top:0;left:0"></div></div>');
      $(".largeImage",zoom).attr("src",element.attr("src"));
      var o = $(element).parent().find('.overlay');
      if(o && o.length > 0)
        $(".largeImageOverlay",zoom).attr("src",$(element).parent().find('.overlay').attr("src"));

      $("body").append(zoom);
      zoom.scrollTop(0);
      zoom.scrollLeft(0);
      $('.fa-times',btn).show();
      $('.fa-search-minus',btn).show();

      var px = element.offset().left;
      var py = element.offset().top;
      btn.css({position:"fixed", left:"auto", right:"1vw", top:"1vh"});
      zoom.append(btn);

    }

    var img = $("img",zoom);
    var w = element.get(0).naturalWidth*(zoomScale);
    var h = element.get(0).naturalHeight*(zoomScale);
    img.css("width",w+"px");
    img.css("height",h+"px");
    e.preventDefault();
    e.stopPropagation();
  };

  var zoomPanel = false;
  element.on("touchend",function(e){
    e.stopPropagation();
  });
  element.on("click",function(e){
    e.stopPropagation();
    if(!zoomPanel){
      btn = $('<div style="display: flex;pointer-events: auto;position:absolute;z-index: 100;padding:8px;background:rgba(255,255,255,0.5);border-radius:4px;box-shadow:0 0 10px rgba(0,0,0,0.2)"><i style="display:none;cursor:pointer;font-size:32px;margin-right:4px" class="fa fa-fw fa-search-minus"></i><i style="cursor:pointer;font-size:32px;margin-left:4px" class="fa fa-fw fa-search-plus"></i><i style="display:none;cursor:pointer;font-size:32px;margin-left:4px;color:red" class="fa fa-fw fa-times"></i></div>');
      element.parent().append(btn);
      var px = element.offset().left - element.parent().offset().left + element.parent().scrollLeft();
      var py = element.offset().top - element.parent().offset().top + element.parent().scrollTop();
      var clickX = e.offsetX;
      var clickY = e.offsetY;
      var keep1onZoom = false;
      if(element.get(0).naturalWidth > element.width()*1.1 ||
         element.get(0).naturalHeight > element.height()*1.1){
        keep1onZoom = true;
      }
      btn.css({top:(py-32+clickY)+"px", left:(px-32+clickX)+"px"});
      btn.on("click",function(e){e.stopPropagation();});
      btn.on("touchend",function(e){
        e.stopPropagation();
      });
      zoomScale = 1.0;
      $('.fa-search-minus',btn).on("click",function(e){
        if(zoomScale == 1.0) zoomScale = 0.6;
        zoomScale = zoomScale * 0.8;
        if(zoomScale < 0.1) zoomScale = 0.1;
        if(keep1onZoom){
          zoomScale = 1.0;
          keep1onZoom = false;
        }
        createOverlay(e);
      });
      $('.fa-search-plus',btn).on("click",function(e){
        if(zoomScale == 1.0) zoomScale = 1.4;
        zoomScale = zoomScale * 1.2;
        if(zoomScale > 8.0) zoomScale = 8.0;
        if(keep1onZoom){
          zoomScale = 1.0;
          keep1onZoom = false;
        }
        createOverlay(e);
      });
      $('.fa-times',btn).on("click",function(e){
        if(btn) btn.remove();
        btn = null;
        if(zoom) zoom.remove();
        zoom = null;
        zoomPanel = false;
      });
      zoomPanel = true;
      setTimeout(function(){
        $(document).one("click",function(){
          if(!zoom){
            if(btn) btn.remove();
            btn = null;
            zoomPanel = false;
          }
        });
      },100);
      e.stopPropagation();
      return;
    }else{
      if(btn) btn.remove();
      btn = null;
      zoomPanel = false;
      return;
    }
  });  
}

var inlineAudioPlayer = null;
var inlineAudioEditorPlayer = null;
var inlineAudioEditorElement = null;
var inlineAudioEditorPlaybackBound = false;

function stopInlineAudioEditorPlayer(){
  if(inlineAudioEditorPlayer){
    try{
      inlineAudioEditorPlayer.pause();
    }catch(e){}
    inlineAudioEditorPlayer = null;
    inlineAudioEditorElement = null;
  }
}

function stopInlineAudioViewerPlayer(){
  if(inlineAudioPlayer){
    try{
      inlineAudioPlayer.pause();
    }catch(e){}
    inlineAudioPlayer = null;
  }
  $('.inlineAudioPlayerWrapper i').each(function(i,e){
    e.className = "fa fa-fw fa-volume-up";
  });
  $('.inlineAudioPlayerProgress').css({width:0});
}

function setupInlineAudioEditorPlayback(){
  if(inlineAudioEditorPlaybackBound) return;
  inlineAudioEditorPlaybackBound = true;

  var toggleInlineAudioFromEditorElement = function(el,e){
    if(!el) return;
    var src = el.getAttribute("src");
    if(!src || src === "") return;
    if(e){
      e.preventDefault();
      e.stopPropagation();
    }

    if(inlineAudioEditorPlayer && inlineAudioEditorElement === el){
      if(!inlineAudioEditorPlayer.paused){
        stopInlineAudioEditorPlayer();
        return;
      }
    }

    stopInlineAudioEditorPlayer();
    stopInlineAudioViewerPlayer();

    inlineAudioEditorElement = el;
    inlineAudioEditorPlayer = new Audio(src);
    inlineAudioEditorPlayer.addEventListener("ended", function(){
      stopInlineAudioEditorPlayer();
    });
    var playPromise = inlineAudioEditorPlayer.play();
    if(playPromise && playPromise.catch){
      playPromise.catch(function(){
        stopInlineAudioEditorPlayer();
      });
    }
  };

  $(document).on("click.inlineAudioEditor", ".nw-editor .inlineAudio", function(e){
    toggleInlineAudioFromEditorElement(this,e);
  });

  $(document).on("keydown.inlineAudioEditor", ".nw-editor .inlineAudio", function(e){
    if(e.keyCode == 32 || e.keyCode == 13){
      toggleInlineAudioFromEditorElement(this,e);
    }else
    if(e.keyCode == 27){
      e.preventDefault();
      e.stopPropagation();
      stopInlineAudioEditorPlayer();
    }
  });
}

function createInlineAudioPlayer(element){
  if(element.attr("hasAudioPlayer")) return; // already set
  if ($(element).closest('.nw-editor').length) return; // not in editor

  element.wrap('<span class="inlineAudioPlayerWrapper" tabindex="0"></span>');
  element.parent().append('<i class="fa fa-fw fa-volume-up"></i>');
  element.parent().append('<div class="inlineAudioPlayerProgress"></div>');
  element.attr("hasAudioPlayer","1");
  var checkStillThere = function(){
    if(document.body.contains(element.get(0))){
      setTimeout(checkStillThere,500);
    }else{
      // removed already
      stopInlineAudioPlayer();
    }
  }
  var stopInlineAudioPlayer = function(){
    stopInlineAudioViewerPlayer();
  };

  var onClick = function(e){
    // play now
    e.stopPropagation();
    var icon = $('i',element.parent()).get(0);
    if(icon.className == "fa fa-fw fa-volume-up"){
      stopInlineAudioEditorPlayer();
      stopInlineAudioPlayer();
      icon.className = "fa fa-fw fa-pause";
      inlineAudioPlayer = new Audio(element.attr("src"));
      inlineAudioPlayer.play();
      var p = $('.inlineAudioPlayerProgress',element.parent());
      p.css({width:0});
      inlineAudioPlayer.addEventListener("timeupdate", function() {
        if (inlineAudioPlayer && inlineAudioPlayer.duration) {
          var percent = (inlineAudioPlayer.currentTime / inlineAudioPlayer.duration) * 100;
          p.css({width:percent + "%"});
        }
      });
      inlineAudioPlayer.addEventListener("ended", function() {
        stopInlineAudioPlayer();
      });
      checkStillThere();      
    }else{
      stopInlineAudioPlayer();
    }
  }
  var onKey = function(e){
    e.stopPropagation();
    if(e.keyCode == 27 && inlineAudioPlayer){
      onClick(e);
    }
    if(e.keyCode == 32 || e.keyCode == 13){
      onClick(e);
    }
  }
  $(element.parent()).on("click",onClick);
  $(element.parent()).on("keydown",onKey);
  $(element.parent()).on("touchend",function(e){ e.stopPropagation(); });
}

function createAudioContext (desiredSampleRate) {
  var AudioCtor = window.AudioContext || window.webkitAudioContext;

  desiredSampleRate = typeof desiredSampleRate === 'number' ? desiredSampleRate : 44100;

  var context = null;

  if (desiredSampleRate != 0 &&
      navigator.mediaDevices && navigator.mediaDevices.getSupportedConstraints &&
      navigator.mediaDevices.getSupportedConstraints().sampleRate) {
    context = new AudioCtor({sampleRate:desiredSampleRate});
  }else
    context = new AudioCtor();

  // Check if hack is necessary.
  if (desiredSampleRate != 0 && context.sampleRate !== desiredSampleRate) {
    var buffer = context.createBuffer(1, 1, desiredSampleRate);
    var dummy = context.createBufferSource();
    dummy.buffer = buffer;
    dummy.connect(context.destination);
    dummy.start(0);
    dummy.disconnect();
    dummy = null;

    context.close(); // dispose old context

    if (navigator.mediaDevices && navigator.mediaDevices.getSupportedConstraints &&
        navigator.mediaDevices.getSupportedConstraints().sampleRate) {
      context = new AudioCtor({sampleRate:desiredSampleRate});
    }else
      context = new AudioCtor();
  }
  return context;
}

window.cleanFilename = function(s){
  // Remove reserved characters: \ / : * ? " < > |
  var illegalRe = /[\\\/:\*\?"<>\|]/g;
  var sanitized = s.replace(illegalRe, '');
  sanitized = sanitized.replace(/[\. ]+$/, '');
  if (sanitized.length === 0) {
    sanitized = 'untitled';
  }
  return sanitized;
};

window.downloadElectronSaveAs = function(url,filename, callbackDone){
  function downloadNow(userChosenPath){
    if(!userChosenPath || userChosenPath == "") return;
    // patch file extensions!
    var up = userChosenPath.split(".");
    var op = filename.split("?")[0].split(".");
    if(up[up.length-1] != op[op.length-1])
      userChosenPath = userChosenPath + "."+op[op.length-1];

    var openOnce = false;
    window.electron.download(url,userChosenPath,function(progress,len){
      if(progress == len && !openOnce){
        openOnce = true;
        console.log("download of "+url+" to "+userChosenPath+" done.");
        setTimeout(function(){
          if(!window.electron.remote)
            window.electron.shell.openPath(userChosenPath); else
            window.electron.remote.shell.openItem(userChosenPath);
          if(callbackDone) callbackDone();
        },500);
      }
    });
  }
  if(!filename) filename = window.electron.path.basename(url);
  filename = filename.split("?")[0];
  filename = filename.replace(/["<>#%\{\}\|\\\^~\[\]`;\?:@=&]/g,"_");

  if(window.electron.remote){
    var toLocalPath = window.electron.path.resolve(window.electron.remote.app.getPath("downloads"),
                                                   filename);
    var userChosenPath = window.electron.remote.dialog.showSaveDialog({
        defaultPath: toLocalPath
    });
    if(typeof(userChosenPath) == "string"){
      downloadNow(userChosenPath);
    }else{
      userChosenPath.then(function(result){ downloadNow(result.filePath); })
    }
  }else{
    electron.ipcRenderer.invoke("getPath","downloads").then(function(d){
      electron.ipcRenderer.invoke("showSaveDialogSync",{defaultPath:window.electron.path.resolve(d,filename)}).then(function(path){
        downloadNow(path);
      });
    });
  }
};

if(window.electron && electron.remote){
  // will remove the auto-download system from nativefier and show save as dialog instead
  alert("Die aktuelle Version der LearningView-Desktop-App ist veraltet. Bitte lade eine aktuelle Version von https://learningview.org heruntern, um Probleme zu vermeiden.");
  window.electron.remote.session.defaultSession.removeAllListeners();
}
if(window.electron){
  // electron.appVersion check
  if(isMacDevice && electron.appVersion != '1.8')
    alert("Die Version "+electron.appVersion+" der LearningView-Desktop-App ist veraltet. Bitte lade eine aktuelle Version von https://learningview.org heruntern, um Probleme zu vermeiden.");
}

window.AudioContext =
      window.AudioContext ||
      window.webkitAudioContext ||
      window.mozAudioContext;

function requireJavascript(file,callback){
    var head=document.getElementsByTagName("head")[0];
    var script=document.createElement('script');
    script.src=file;
    script.crossorigin="anonymous";
    script.type='text/javascript';
    //real browsers
    script.onload=callback;
    //Internet explorer
    script.onreadystatechange = function() {
        if (this.readyState == 'complete') {
            callback();
        }
    }
    head.appendChild(script);
}

function shuffleArray(array) {
    for (var i = array.length - 1; i >= 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var temp = array[i];
        array[i] = array[j];
        array[j] = temp;
    }
    return array;
}

$(document).on('drop dragover', function (e) {
 e.preventDefault();
});      
///////////////////////////////////////////////////////////////////////////////////////////////////
function secToMMSS(s){
  var secs = Math.round(s);
  var mm = Math.floor(secs / 60);
  var ss = secs % 60;
  if(ss < 10) ss = '0'+ss;
  return mm+":"+ss;
}

function getBrowser(){
  var nVer = navigator.appVersion;
  var nAgt = navigator.userAgent;
  var browserName  = navigator.appName;
  var fullVersion  = ''+parseFloat(navigator.appVersion);
  var majorVersion = parseInt(navigator.appVersion,10);
  var nameOffset,verOffset,ix;

  // In Opera, the true version is after "Opera" or after "Version"
  if ((verOffset=nAgt.indexOf("Opera"))!=-1) {
   browserName = "Opera";
   fullVersion = nAgt.substring(verOffset+6);
   if ((verOffset=nAgt.indexOf("Version"))!=-1)
     fullVersion = nAgt.substring(verOffset+8);
  }
  // In MSIE, the true version is after "MSIE" in userAgent
  else if ((verOffset=nAgt.indexOf("MSIE"))!=-1) {
   browserName = "Microsoft Internet Explorer";
   fullVersion = nAgt.substring(verOffset+5);
  }
  // In Chrome, the true version is after "Chrome"
  else if ((verOffset=nAgt.indexOf("Chrome"))!=-1) {
   browserName = "Chrome";
   fullVersion = nAgt.substring(verOffset+7);
  }
  // In Safari, the true version is after "Safari" or after "Version"
  else if ((verOffset=nAgt.indexOf("Safari"))!=-1) {
   browserName = "Safari";
   fullVersion = nAgt.substring(verOffset+7);
   if ((verOffset=nAgt.indexOf("Version"))!=-1)
     fullVersion = nAgt.substring(verOffset+8);
  }
  // In Firefox, the true version is after "Firefox"
  else if ((verOffset=nAgt.indexOf("Firefox"))!=-1) {
   browserName = "Firefox";
   fullVersion = nAgt.substring(verOffset+8);
  }
  // In most other browsers, "name/version" is at the end of userAgent
  else if ( (nameOffset=nAgt.lastIndexOf(' ')+1) <
       (verOffset=nAgt.lastIndexOf('/')) )
  {
   browserName = nAgt.substring(nameOffset,verOffset);
   fullVersion = nAgt.substring(verOffset+1);
   if (browserName.toLowerCase()==browserName.toUpperCase()) {
    browserName = navigator.appName;
   }
  }
  // trim the fullVersion string at semicolon/space if present
  if ((ix=fullVersion.indexOf(";"))!=-1)
     fullVersion=fullVersion.substring(0,ix);
  if ((ix=fullVersion.indexOf(" "))!=-1)
     fullVersion=fullVersion.substring(0,ix);

  majorVersion = parseInt(''+fullVersion,10);
  if (isNaN(majorVersion)) {
   fullVersion  = ''+parseFloat(navigator.appVersion);
   majorVersion = parseInt(navigator.appVersion,10);
  }


  return browserName;
}
var isWaitingAction = false;

