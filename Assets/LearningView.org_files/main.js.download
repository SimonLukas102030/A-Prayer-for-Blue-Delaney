                  '<button style="cursor:pointer;border:1px solid #ddd; background:green;  width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'green\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#1ec11e;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#1ec11e\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#016c9c;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#016c9c\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#0babd2;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#0babd2\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#9c0115;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#9c0115\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:red;    width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'red\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#7e0bd2;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#7e0bd2\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#de21a2;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#de21a2\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#0909b1;width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#0909b1\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:blue;   width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'blue\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:orange; width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'orange\',$event)"></button>'+
                  '<button style="cursor:pointer;border:1px solid #ddd; background:#5C3317; width:2em;height:2em;" class="needsclick" '+
                  'ng-click="selectColor(\'#5C3317\',$event)"></button></div>',

        controller: function($scope,$timeout) {
          var s = this;
          $scope.fontcolor = ngWigLastColor;

          $scope.showColors = false;
          $scope.showColorSelect = function(e){
            if($scope.$parent.$parent.blendTimeout)
              $timeout.cancel($scope.$parent.$parent.blendTimeout);
            e = e || window.event;
            e.preventDefault();
            e.stopPropagation();
            $scope.showColors = !$scope.showColors;
            $(document).one("click",function(){
              $scope.showColors = false;
            });
          }
          $scope.selectColor = function(c,e){
            e = e || window.event;
            e.preventDefault();
            s.execCommand('foreColor',c);
            $scope.fontcolor = c;
            ngWigLastColor = c;
            $scope.showColors = false;
          };
        }
    });

angular.module('ngWig')
    .config(['ngWigToolbarProvider', function (ngWigToolbarProvider) {
       ngWigToolbarProvider.addCustomButton('copy', 'nw-copy-button');
    }])
    .component('nwCopyButton', {
        bindings: {
          editMode: '=',
          disabled: '=',
          content: '='
        },
        template: '<button class="needsclick nw-button copy" title="Kopieren" ng-click="$ctrl.click()">Copy</button>',
        controller: function($scope,$timeout,$filter) {
          var s = this;
          this.click = function(){
            var selectedText = '';

            // window.getSelection
            if (window.getSelection) {
                selectedText = window.getSelection().toString();
            }
            // document.getSelection
            else if (document.getSelection) {
                selectedText = document.getSelection().toString();
            }
            // document.selection
            else if (document.selection) {
                selectedText =
                document.selection.createRange().text;
            }
            if(selectedText == ""){
              // copy all
              selectedText = s.content;
            }
            copyTextToClipboard(selectedText);
            mc.alert($filter('trans')('COPYEDTEXTTOCLIPBOARD'),null);
          };
        }
    });

angular.module('ngWig')
    .config(['ngWigToolbarProvider', function (ngWigToolbarProvider) {
       ngWigToolbarProvider.addCustomButton('export', 'nw-export-button');
    }])
    .component('nwExportButton', {
        bindings: {
          editMode: '=',
          disabled: '=',
          content: '=',
          container: '=',
          filename: '='
        },
        template: '<button class="needsclick nw-button export" title="Exportieren" ng-click="$ctrl.click()">Export</button>',
        controller: function($scope,$timeout,$document) {
          var s = this;
          this.click = function(){
            var filename = s.filename;
            var doc = new jsPDF();
            var elementHandler = {
              '#ignorePDF': function (element, renderer) {
                return true;
              }
            };
            var source = s.container.get(0);
            doc.fromHTML(source, 15, 15, {
                  'width': 180,'elementHandlers': elementHandler
            },function(){
              if(typeof cordova != "undefined"){
                mc.downloadAndOpenFile(filename,doc.output('blob'),"application/pdf");
              }else{
                doc.save(filename);
              }              
            });

          };
        }
    });

angular.module('ngWig')
    .config(['ngWigToolbarProvider', function (ngWigToolbarProvider) {
       ngWigToolbarProvider.addCustomButton('addImage', 'nw-image-button');
    }])
    .component('nwImageButton', {
        bindings: {
          editMode: '=',
          disabled: '=',
          container: '=',
          content: '='
        },
        template: '<button class="needsclick nw-button addImage" title="Bild" ng-click="$ctrl.click()">Image</button>',
        controller: function($scope,$timeout,$document) {
          var s = this;
          this.click = function(){
            // save caret position
            var sel = null;
            var range = null;
            if (window.getSelection) {
              sel = window.getSelection();
              if (sel.getRangeAt && sel.rangeCount) {
                range = sel.getRangeAt(0);
              }
            }
            mc.takeUserMedia("image",null,function(results){
              var r = false;
              if(s.container[0] !== $document[0].activeElement){
                s.container.focus();
                // restore position
                if(range){
                  window.getSelection().removeAllRanges();
                  document.getSelection().addRange(range);
                }
              }
              var text = '<img src="'+results[0].URL+'"><br>';

              if(s.content != "" && s.content != "<br>" && 
                 s.content != "<p></p>" && s.content != "<p><br></p>") r = pasteHtmlAtCaret(text);
              if(!r)
                $timeout(function(){
                  if(s.content != "" && s.content != "<br>" && 
                     s.content != "<p></p>" && s.content != "<p><br></p>"){
                    s.content = s.content + (text);
                  }else{
                    s.content = (text);
                  }
                },1);

            }, {dialogMode:0}); // allowMultiple:true
          };
        }
    });

