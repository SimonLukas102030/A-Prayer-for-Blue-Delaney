    };
    */
    self.showMaintenanceHint = self.nextMaintenance && self.getLocalStorage("showMaintenanceHint"+self.nextMaintenance.id) != 2;
    self.hideMaintenanceHint = function(){
      self.showMaintenanceHint = false;
      self.nextMaintenance.displayCounter = self.getLocalStorage("showMaintenanceHint"+self.nextMaintenance.id);
      if(!self.nextMaintenance.displayCounter) self.nextMaintenance.displayCounter = 0;
      self.nextMaintenance.displayCounter++;
      self.setLocalStorage("showMaintenanceHint"+self.nextMaintenance.id,self.nextMaintenance.displayCounter);
    };


    self.updateLastUsedTaskIcons = function(icon){
      if(!icon || icon == "" || icon == "time") return;
      var p = self.lastUsedTaskIcons.indexOf(icon);
      if(p != -1) self.lastUsedTaskIcons.splice(p,1);
      self.lastUsedTaskIcons.unshift(icon);
      while(self.lastUsedTaskIcons.length > 10) { self.lastUsedTaskIcons.pop();}
      self.setLocalStorage("lastUsedTaskIcons",
        angular.toJson(self.lastUsedTaskIcons));
    };

    self.isSmallScreen = false;

    self.descriptionNeedsWindow = function(desc){
      if(desc.length > 200) return true;
      if(desc.indexOf("<img") >= 0) return true;
      if(desc.indexOf("</") >= 0) return true;
      return false;
    };

    $scope.$watch(function() { return $mdMedia('(max-width:'+Math.round(650*self.appZoom)+'px)'); }, function(v) {
      self.isSmallScreen = v;
    });

    self.showDebugLog = function(ev){
      self.showDialog({
        template:
          '<md-dialog style="width:960px;max-width:96vw;max-height:96vh;">' +
          '  <md-toolbar class="md-primary" layout="row" layout-align="space-between center">' +
          '    <div style="margin-left:16px">Debug Log</div>' +
          '    <div style="margin-right:8px">' +
          '      <md-button md-autofocus="true" class="md-icon-button" ng-click="close()" aria-label="close"><i class="fa fa-fw fa-times"></i></md-button>' +
          '    </div>' +
          '  </md-toolbar>' +
          '  <md-content style="padding:16px;overflow:auto">' +
          '    <div layout="row" layout-wrap layout-align="start center" style="gap:8px">' +
          '      <md-input-container flex style="margin:0;min-width:240px">' +
          '        <label>Suche in Log-Nachrichten</label>' +
          '        <input ng-model="searchTerm" ng-change="applyFilter()" placeholder="Suchbegriff eingeben...">' +
          '      </md-input-container>' +
          '      <md-button ng-click="clearSearch()" ng-disabled="!searchTerm" style="margin:0">Suche löschen</md-button>' +
          '    </div>' +
          '    <div style="color:#666;font-size:12px;margin:2px 0 10px 0">{{filteredEntries.length}} / {{entries.length}} Einträge</div>' +
          '    <div ng-if="filteredEntries.length == 0" style="color:#666;padding:12px;border:1px solid #eee;border-radius:6px">Keine Einträge für diesen Suchbegriff.</div>' +
          '    <div ng-repeat="entry in filteredEntries track by entry.id" style="border:1px solid #e7e7e7;border-radius:8px;margin-bottom:8px;overflow:hidden">' +
          '      <div layout="row" layout-align="start center" style="background:#fafafa;padding:8px 10px;cursor:pointer" ng-click="toggle(entry)">' +
          '        <span style="color:#999;font-size:12px;min-width:64px">#{{entry.index}}</span>' +
          '        <div style="font-family:monospace;font-size:12px;white-space:pre-wrap;word-break:break-word">{{entry.text}}</div>' +
          '      </div>' +
          '    </div>' +
          '  </md-content>' +
          '</md-dialog>',
        targetEvent: ev,
        skipHide: true,
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var lines = (window.__lvDebugLogStore || mc.debugLog || []).slice();

          $scope.entries = lines.map(function(line, idx){
            return {
              id: idx,
              index: idx + 1,
              text: String(line || ""),
            };
          });

          $scope.filteredEntries = $scope.entries.slice();
          $scope.searchTerm = "";

          $scope.applyFilter = function(){
            var term = String($scope.searchTerm || "").toLowerCase().trim();
            if(term === ""){
              $scope.filteredEntries = $scope.entries.slice();
              return;
            }
            $scope.filteredEntries = $scope.entries.filter(function(entry){
              return entry.text.toLowerCase().indexOf(term) !== -1;
            });
          };

          $scope.clearSearch = function(){
            $scope.searchTerm = "";
            $scope.applyFilter();
          };

          $scope.close = function(){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    }; 

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.apiPost = function (url, data, fileupload){
      // add credentials to every request because of drop out / offline
      if((!data || !data.uid) && self.user != null) {
        data.uid = self.user.ID;
        data.salt = self.user.Salt;
      }
      var isKeepAlive = data.action == "keepalive";

      var r = $http({
        url: "https://learningview.org/api/"+url+".php",
        method: "POST",
        withCredentials : true,
        ignoreLoadingBar: data.indicator ? false : (data.action == "keepalive"|| data.action == "sendactive" || data.action == "scienceTrack" || data.noindicator ? true : false),
        useXDomain : true,
        headers: fileupload ? { 'Content-Type': undefined } : {'Content-Type': 'application/x-www-form-urlencoded'},
        transformRequest: fileupload ? angular.identity : function(obj) {
          var str = [];
          for(var p in obj)
            str.push(encodeURIComponent(p) + "=" + encodeURIComponent(obj[p]));
          return str.join("&");
        },
        onProgress: function(event) {
          $('#loadingActionText').text("lade Daten: "+ Math.round((event.loaded/1024/1024)) + " MB");
        },
        data: data
      });

      var deferred = $q.defer();
      var noerror = data.noerror;

      r.then(function(response){
        var data = response.data;
        if(data.result && data.result == "FAILED" &&
          url == "ajax" && self.user && self.user.ID == "-1")
         data.result = "OK"; // special case for student view

        if(data.result && data.result == "FAILED") console.log(data.error);
        if(data.result == "OK"){
          if(!isKeepAlive && self.keepAliveIntervalWorking) {
            // wait until keepalive is finished until reporting back
            // this can prevent some race conditions when we add something while keepalive is removing again
            var tryAgain = function(tries){
              $timeout(function(){
                if(self.keepAliveIntervalWorking && tries < 50){
                  tryAgain(tries+1); 
                  return;
                }
                deferred.resolve(data);
              },100);
            };
            tryAgain(0);
          }else
            deferred.resolve(data);
        }else{
          deferred.reject(data);
          if(!noerror){
            self.errorToast("Server-Fehler",(data && data.error ? data.error : false));
          }
        }
      },function(error){
        // server error, no answer or no connection
        console.log(url+" failed.");
        if(!data.noerror){
          self.errorToast("Verbindungsfehler");
        }
        deferred.reject({result:"FAILED", error:"CONNECTION_ERROR"});
      });

      return deferred.promise;
    };
