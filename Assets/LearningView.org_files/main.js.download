        function(target,item,type,position,follow,isLocal){
        var a = {"action":"copyLearningGoal","goal":it.ID,"target":target,
                 "topic":topic.ID,"position":position};
        self.apiPost("ajax",a)
         .then(function(data) {
           self.keepAliveCallback().then(function(){
             if(follow){
               self.openContentFollow("LearningGoal",
                 target,data).then(function(){

               });
             }
           });
         },function(data, status, headers, config) {
           self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
         });
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateTask = function(it,goal,ev){
      self.selectMoveTarget("copy","Task", it,ev,
        function(target,item,type,position,follow,isLocal){
        var a = {"action":"copyTask","task":it.ID,"target":target,
                 "goal":goal.ID,"position":position};
        self.apiPost("ajax",a)
          .then(function(data) {
            self.keepAliveCallback().then(function(){
              if(follow){
               self.openContentFollow("Task",
                 target,data).then(function(){
                 // done and scrolled to, ask for open
                 self.confirm($filter('trans')('EDITDUPLICATE',data.task.Name),
                   $filter('trans')('EDIT'),null).then(function(){
                   var t = self.getTaskByID(data.task.ID);
                   self.editTask(t.task,null);
                 });
               });
              }
            });
          },function(data, status, headers, config) {
            self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
          });
      });
    };

    self.duplicateTasks = function(tasks,ev){
      self.selectMoveTarget("copy","Task", tasks[0], ev, function(target,item,type,position,follow,isLocal){
        var t = 0;
        var next = function(){
          var it = tasks.shift();
          self.apiPost("ajax",{"action":"copyTask","task":it.ID,"target":target,
                   "goal":it.LearningGoal,"position":position+t}).then(function(data) {
            t++;
            if(tasks.length == 0){
              self.keepAliveCallback().then(function(){
                if(follow){
                  self.openContentFollow("Task",target,data);
                }
              });
            }else next();        
          });  
        }
        next();
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.changeTasksAttributes = function(tasks,ev){
      self.showDialog({
        templateUrl: "changeTasksAttributesDialog.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        escapeToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;

          $scope.iconList = self.taskIconList;
          $scope.colorChoice = self.colorChoice;
          $scope.iconsLastUsed = self.lastUsedTaskIcons;

          $scope.item = {};
          $scope.item.Icon = null;
          $scope.item.MainIcon = null;
          $scope.item.Color = null;
          $scope.item.Level = null;
          $scope.item.Time = null;

          $scope.save = function(){
            // save now
            var done = 0;
            for(var t=0; t < tasks.length; t++){
              var it = tasks[t];
              var p = {"action":"updateTask", "ID":it.ID};
              var changes = 0;
              if($scope.item.Color !== null && it.Color != $scope.item.Color){
                p.Color = $scope.item.Color;
                changes++;
              }
              if($scope.item.Icon !== null && it.Icon != $scope.item.Icon){
                p.Icon = $scope.item.Icon;
                changes++;
              }
              if($scope.item.MainIcon !== null && it.MainIcon != $scope.item.MainIcon){
                p.MainIcon = $scope.item.MainIcon;
                changes++;
              }
              if($scope.item.Level !== null && it.Level != $scope.item.Level){
                p.Level = $scope.item.Level;
                changes++;
              }
              if($scope.item.Time !== null && it.Time != $scope.item.Time){
                p.Time = $scope.item.Time;
                changes++;
              }

              if(changes > 0){
                done++;
                self.apiPost("ajax",p).then(function(){
                  done--;
                  if(done == 0) self.keepAliveCallback();
                });                
              }
            }
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeLearningGoal = function(it,ev, force){
      self.confirm($filter('trans')('REMOVELEARNINGGOAL',it.Name)+(self.currentMainTopic.shareSettings && self.currentMainTopic.shareSettings.length > 1 ? " "+$filter('trans')('REMOVESHAREDHINT'):''),$filter('trans')('DELETE'),ev).then(function(){
        self.apiPost("ajax",{"action":"removeLearningGoal", "ID":it.ID})
         .then(function(data) {
           self.learningGoalsList.splice(self.learningGoalsList.indexOf(it),1);
           self.updateLearningGoalsOrder();
           $mdDialog.hide();
           self.keepAliveCallback();
         },function(data, status, headers, config) {
           self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
         });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showLearningGoalDescription = function(it,ev){
      self.alert('<div style="max-width:500px">'+it.Description+'</div>',ev);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeTask = function(it,goal,ev,force){
      self.confirm($filter('trans')('REMOVETASK',it.Name)+(self.currentMainTopic.shareSettings && self.currentMainTopic.shareSettings.length > 1 ?
          " "+$filter('trans')('REMOVESHAREDHINT'):''),$filter('trans')('DELETE'),ev).then(function(){
        self.apiPost("ajax",{"action":"removeTask", "ID":it.ID})
         .then(function(data) {
           goal.tasks.splice(goal.tasks.indexOf(it),1);
           $mdDialog.hide();
           self.keepAliveCallback();
         },function(data, status, headers, config) {
           self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
         });
      });
    };

    self.removeTasks = function(tasks,ev){
      self.confirm($filter('trans')('REMOVETASKS',tasks.length)+(self.currentMainTopic.shareSettings && self.currentMainTopic.shareSettings.length > 1 ?
          " "+$filter('trans')('REMOVESHAREDHINT'):''),$filter('trans')('DELETE'),ev).then(function(){
        var done = 0;
        for(var t=0; t < tasks.length; t++){
          var it = tasks[t];
          done++;
          self.apiPost("ajax",{"action":"removeTask", "ID":it.ID})
           .then(function(data) {
             done--;
             if(done == 0)
               self.keepAliveCallback();
           });
        }
        // clear selection
        while(tasks.length > 0) tasks.pop();
      });

    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasUserTaskInCalendar = function(student,it){
      if(self.users[student.ID] && self.users[student.ID].calendars)
        for(var key in self.users[student.ID].calendars){
          for(var z=0; z < self.users[student.ID].calendars[key].length; z++){
            if(self.users[student.ID].calendars[key][z].Task == it.ID) return true;
          }
        }
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.removeUserTask = function(student,task,ev,closeWindow){
      self.confirm($filter('trans')('REMOVEUSERTASK',task.Name),$filter('trans')('DELETE'),ev).then(function(){
        if(!student || student == self.user){
          self.setUserTaskImportant(task,"-1",ev);
        }else{
          self.setClassUserTaskImportant(student,task,"-1",ev);
        }
        self.apiPost("ajax",{"action":"removeUserTask", "ID":task.ID})
         .then(function(data) {
           if(closeWindow) $mdDialog.hide();
           self.keepAliveCallback();
         },function(data, status, headers, config) {
           self.alert("Speichern fehlgeschlagen: Stelle sicher, dass du an diesem Ort etwas schreiben/ändern darfst.");
         });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.capturePhoto = function(id,callback,ev) {
      if(navigator.camera){
        var options = {
            mQuality : 80,
            quality: 80,
            encodingType: navigator.camera.EncodingType.JPEG,
            cameraDirection:0,
            allowEdit:false,
            destinationType: navigator.camera.DestinationType.FILE_URI,
            correctOrientation: true,
            targetWidth:1600,targetHeight:1200
        };
        if(window.isIOSDevice) options.saveToPhotoAlbum = true;
        // also for android with new versions
        if(window.cordovaAppVersionNumber >= 204013) options.saveToPhotoAlbum = true;

        var captureNow = function(){
          var cleanupCamera = function(){
            try{
              navigator.camera.cleanup();
            }catch(e){
              console.log("camera cleanup failed", e);
            }
          };
          navigator.camera.getPicture(function(fileURI){
            // move file to data folder
            window.resolveLocalFileSystemURL(fileURI,function(fileEntry){
              window.resolveLocalFileSystemURL(cordova.file.dataDirectory,function(dirEntry){
                fileEntry.moveTo(dirEntry, id+".jpg", function(){
                  cleanupCamera(); // löscht das tmp File!
                  if(callback) callback(cordova.file.dataDirectory+id+".jpg",id+".jpg");
                }, function(error){
                  cleanupCamera();
                  self.alert("Fehler beim Speichern des Fotos: "+JSON.stringify(error));
                  $mdDialog.cancel();
                });
              }, function(error){
                cleanupCamera();
                self.alert("Fehler beim Öffnen des Zielordners: "+JSON.stringify(error));
                $mdDialog.cancel();
              });
            }, function(error){
              cleanupCamera();
              self.alert("Fehler beim Lesen des Fotos: "+JSON.stringify(error));
              $mdDialog.cancel();
            });

          }, function (m) {
            // not available or canceled by user
            if(m && m.toString().toLowerCase().indexOf("permission") >= 0)
              self.alert("Du musst in den App-Einstellungen LearningView die Verwendung der Kamera erlauben.");
            cleanupCamera();
            $mdDialog.cancel();
          },options);
        };

        self.requestMobileCameraPermissions(captureNow);

      }else{
        // inside browser

        if(navigator.mediaDevices === undefined)  navigator.mediaDevices = {};
        if(navigator.mediaDevices.getUserMedia === undefined) {
          navigator.mediaDevices.getUserMedia = function(constraints) {
            var getUserMedia = navigator.webkitGetUserMedia || navigator.mozGetUserMedia || navigator.msGetUserMedia;
            if (!getUserMedia)
              return Promise.reject(new Error('getUserMedia is not implemented in this browser')); else
              return new Promise(function(resolve, reject) {
                getUserMedia.call(navigator, constraints, resolve, reject);
              });
          }
        }

        navigator.mediaDevices.enumerateDevices().then(function(devices) {
          self.deviceCameras = [];
          devices.forEach(function(device) {
            if(typeof device === 'string' || device instanceof String){
              self.deviceCameras.push(device);
            }else
            if (device.kind === "videoinput") {
              self.deviceCameras.push(device.deviceId);
            }
          });
          // start now
          var constraints = {"video":true};
//          if(window.electron || getBrowser() == "Chrome" || getBrowser() == "Safari" || getBrowser() == "Mobile" || getBrowser() == "Netscape"){
//            constraints = {"video": { "minWidth": 640,  "maxWidth": 1920, "minHeight": 480, "maxHeight": 1080, "maxFrameRate": 30 }};//Chrome did not support the new constraints spec until 59 for video and 60 for audio
//          }else if(getBrowser() == "Firefox"){
          constraints = {video: {  width: { min: 640, ideal: 1920, max: 1920 },  height: { min: 480, ideal: 1080, max: 1080 }}}; //Firefox
//          }

          if(self.deviceCameras[self.currentCameraIndex] != "")
            constraints.video.deviceId = {exact: self.deviceCameras[self.currentCameraIndex]};

          if(self.failedCameraConstrained) {
            constraints = {video:true};
            self.useMinimalCamaeraConstrained = true; 
          }

          navigator.mediaDevices.getUserMedia(constraints).then(function(stream){
            // iOS once again ask for devices as only now we will have correct data ...
            navigator.mediaDevices.enumerateDevices().then(function(devices) {
              self.deviceCameras = [];
              devices.forEach(function(device) {
                if (device.kind === "videoinput") {
                  self.deviceCameras.push(device.deviceId);
                }
              });
            });
            self.failedCameraConstrained = false; // works now
            self.useMinimalCamaeraConstrained = false;
            var options = {};

            self.showDialog({
              templateUrl: "recordImageDialog.html",
              skipHide:true, // keep other dialog open
              clickOutsideToClose: false,
              targetEvent:ev,
              escapeToClose: false,
              onRemoving : function(){
                var tracks = stream.getTracks();
                for(var i=0; i < tracks.length; i++) tracks[i].stop();
              },
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.id = id;
                $scope.waitingForStream = true;
                $scope.canceled = false;
                $scope.dialogClosed = false;
                $scope.streamSetupTimeout = null;

                $scope.streamSetupTimeout = setTimeout(function(){
                  if($scope.canceled || $scope.dialogClosed) return;
                  var videoElement = $('#videoRecorderScreen').get(0);
                  if(!videoElement){
                    console.log("Photo video element missing");
                    $scope.cancel();
                    return;
                  }
                  var url = window.URL || window.webkitURL;
                  try{
                    videoElement.src = url ? url.createObjectURL(stream) : stream;
                  }catch(e){
                    videoElement.srcObject = stream; // new FireFox way?
                  }
                  videoElement.style.transform = self.mirrorCameraX == 1 && self.mirrorCameraY == 1 ? "scale(-1,-1)" : (
                                                 self.mirrorCameraX == 1 ? "scaleX(-1)" : (
                                                 self.mirrorCameraY == 1 ? "scaleY(-1)" : ''));
                  videoElement.play();

                  $timeout(function(){
                    if($scope.canceled || $scope.dialogClosed) return;
                    var tracks = stream.getTracks();
                    $scope.recordingDeviceLabels = [];
                    for(var i=0; i < tracks.length; i++) $scope.recordingDeviceLabels.push(tracks[i].label);
                    tracks = null;
                    $scope.waitingForStream = false;  
                  },0)
                },1000);

                $scope.flipCamera = function(){
                  self.currentCameraIndex++;
                  if(self.currentCameraIndex >= self.deviceCameras.length)
                    self.currentCameraIndex = 0;
                  $scope.cancel();
                  self.capturePhoto(id,callback,ev);
                };
                $scope.mirrorCamera = function(direction){
                  if(direction == "x"){
                    self.mirrorCameraX = self.mirrorCameraX ? 0 : 1;
                    var videoElement = $('#videoRecorderScreen').get(0);
                    videoElement.style.transform = self.mirrorCameraX == 1 && self.mirrorCameraY == 1 ? "scale(-1,-1)" : (
                                                   self.mirrorCameraX == 1 ? "scaleX(-1)" : (
                                                   self.mirrorCameraY == 1 ? "scaleY(-1)" : ''));
                    if(self.mirrorCameraX) self.userViewData["vmx"] = 1; else delete self.userViewData["vmx"];
                    self.updateUserViewData();
                  }
                  if(direction == "y"){
                    self.mirrorCameraY = self.mirrorCameraY ? 0 : 1;
                    var videoElement = $('#videoRecorderScreen').get(0);
                    videoElement.style.transform = self.mirrorCameraX == 1 && self.mirrorCameraY == 1 ? "scale(-1,-1)" : (
                                                   self.mirrorCameraX == 1 ? "scaleX(-1)" : (
                                                   self.mirrorCameraY == 1 ? "scaleY(-1)" : ''));
                    if(self.mirrorCameraY) self.userViewData["vmy"] = 1; else delete self.userViewData["vmy"];
                    self.updateUserViewData();
                  }
                };

                $scope.takeImage = function() {
                  if($scope.canceled || $scope.dialogClosed) return;
                  var video = $('#videoRecorderScreen').get(0);
                  if(!video || !video.videoWidth || !video.videoHeight){
                    self.alert("Die Kamera ist noch nicht bereit. Bitte kurz warten und erneut versuchen.");
                    return;
                  }
                  var canvas = document.createElement("CANVAS");
                  canvas.width = video.videoWidth;
                  canvas.height = video.videoHeight;

                  try{
                    var ctx = canvas.getContext("2d");
                    if(self.mirrorCameraX == 1 || self.mirrorCameraY == 1){
                      ctx.save();
                      ctx.scale(self.mirrorCameraX == 1 ? -1 : 1, 
                                self.mirrorCameraY == 1 ? -1 : 1);
                      ctx.drawImage(video, self.mirrorCameraX ? -canvas.width : 0, self.mirrorCameraY ? -canvas.height : 0);
                      ctx.restore();
                    }else{
                      ctx.drawImage(video, 0, 0);
                    }
      
                    var dataUri = canvas.toDataURL('image/jpeg');
                    var data = dataUri.split(',')[1];
                    var mimeType = dataUri.split(';')[0].slice(5)

                    var bytes = window.atob(data);
                    var buf = new ArrayBuffer(bytes.length);
                    var arr = new Uint8Array(buf);

                    for (var i = 0; i < bytes.length; i++) arr[i] = bytes.charCodeAt(i);

                    var blob = new Blob([ arr ], { type: mimeType });

                    var url = window.URL || window.webkitURL;
                    var imageURL = url.createObjectURL(blob);

                    if(callback) setTimeout(function(){ callback(imageURL,id+".jpg",blob);},1);
                  }catch(e){
                    console.log("Photo capture failed", e);
                    self.alert("Das Foto konnte nicht erstellt werden. Bitte versuche es erneut.");
                  }

                  $scope.cancel();
                };
                $scope.cancel = function() {
                  if($scope.dialogClosed) return;
                  if($scope.streamSetupTimeout)
                    clearTimeout($scope.streamSetupTimeout);
                  $scope.streamSetupTimeout = null;
                  $scope.canceled = true;
                  $scope.dialogClosed = true;
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          }).catch(function(error){
            if(error && error.name =="NotAllowedError"){
              self.alert("Dein Browser erlaubt derzeit keine Aufzeichnung von der Kamera. Es wurde keine Erlaubnis erteilt.");
            }else{
              if(!self.useMinimalCamaeraConstrained) {
                self.failedCameraConstrained = true;
                // retry
                self.capturePhoto(id,callback,ev);
                return;
              }
              self.alert("Dein Browser unterstützt keine Aufnahme von der Kamera, oder es wurde keine Webcam gefunden. Bitte verwende eine aktuelle Version von Chrome oder FireFox oder die LearningView App.");
            }
          });
        });
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.checkMicrophoneAuthorization = function(callback){
      if(typeof(cordova) != "undefined" && cordova.plugins && cordova.plugins.diagnostic){
        cordova.plugins.diagnostic.getMicrophoneAuthorizationStatus(function(status){
          if(status === cordova.plugins.diagnostic.permissionStatus.GRANTED || status === "granted"){
            console.log("Microphone use is authorized");
            callback(true);
          }else{
            cordova.plugins.diagnostic.requestMicrophoneAuthorization(function(status){
              if(status == cordova.plugins.diagnostic.permissionStatus.GRANTED || status === "granted"){
                self.checkMicrophoneAuthorization(callback);
              }else{
                self.alert($filter('trans')('NOMICPERMISSION'));
              }
            });
          }
        });
      }else{
        callback(true);
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.captureAudioProcessFile = function(id,savedFilePath,callback) {
      window.resolveLocalFileSystemURL(savedFilePath.indexOf("file://") == 0 ? savedFilePath : 'file://'+savedFilePath,function(fileEntry){
        window.resolveLocalFileSystemURL(cordova.file.dataDirectory,function(dirEntry){
          var newName = id+"_"+Math.random()+".m4a";
          fileEntry.moveTo(dirEntry, newName, function(){
            self.capture.playable = true;
            self.capture.recording = false;
            self.capture.processing = false;
            var now = new Date();
            self.capture.recordingDurationMS = now.getTime() - self.capture.recordingTimer.getTime();
            self.capture.recordingDuration = secToMMSS(Math.ceil((now.getTime() - self.capture.recordingTimer.getTime())/ 1000));

            if(callback) callback(cordova.file.dataDirectory+newName,id+".m4a");
          }, null);
        }, null);
      }, null);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.captureAudio = function(id,callback) {
      self.checkMicrophoneAuthorization(function(){
        self.capture.recordingTimer = null;

        self.capture.service = new AudioRecorderService();

        self.capture.processingTimeout = null;
        self.capture.clearProcessingWatchdog = function(){
          if(self.capture.processingTimeout){
            clearTimeout(self.capture.processingTimeout);
          }
          self.capture.processingTimeout = null;
        };
        self.capture.startProcessingWatchdog = function(){
          self.capture.clearProcessingWatchdog();
          self.capture.processingTimeout = setTimeout(function(){
            if(self.capture && self.capture.processing){
              self.capture.processing = false;
              self.capture.recording = false;
              self.alert("Die Audio-Verarbeitung hat zu lange gedauert. Bitte Aufnahme erneut versuchen.");
            }
          },15000);
        };

        self.capture.service.onGraphSetupWithInputStream = function(inputStreamNode) {
          self.capture.service.meterNodeRaw = self.capture.service.audioCtx.createScriptProcessor(2048, inputStreamNode.channelCount, inputStreamNode.channelCount);
          inputStreamNode.connect(self.capture.service.meterNodeRaw);
          self.capture.service.meterNodeRaw.connect(self.capture.service.audioCtx.destination);
          self.capture.service.meterNodeRaw.onaudioprocess = function(audioProcessingEvent) {
            // update the meter
            var inputBuffer = audioProcessingEvent.inputBuffer;
            var channelData = inputBuffer.getChannelData(0);
            var channelMaxes = 0.0;
            for (var sample = 0; sample < inputBuffer.length; sample++) {
              if (Math.abs(channelData[sample]) > channelMaxes) {
                channelMaxes = Math.abs(channelData[sample]);
              }
            }
            var db = channelMaxes === 0.0 ? 0 : ((Math.log(10) / Math.log(channelMaxes)) * -20);
            // db = 32db = 100%
            if(db > 32) db = 32;
            $('.audioMeter div').css({"width":Math.floor(db/32*100)+"%","background":typeof window.MediaRecorder !== 'undefined' ? 'green':'red'});

          };
        };

        self.capture.service.onComplete = function(recording){
          // callback with recording            
          $timeout(function(){
            if(self.capture.clearProcessingWatchdog) self.capture.clearProcessingWatchdog();
            self.capture.processing = false;
            if(!self.capture.service.canceled){
              self.capture.playable = true;
              if(callback) callback(recording.blobUrl, id+".wav",recording.blob);                
            }
          },0);

        };

        self.capture.service.onError = function(error){
          $timeout(function(){
            if(self.capture.clearProcessingWatchdog) self.capture.clearProcessingWatchdog();
            self.capture.processing = false;
            self.capture.recording = false;
            self.capture.playable = false;
            console.log('Audio recording error', error);
            self.alert("Die Audioaufnahme konnte nicht beendet werden. Bitte versuche es erneut.");
          },0);
        };

        self.capture.service.startRecording(function(){
          var finishAfterTime = function(){
            self.stopCaptureAudio(id);
          };
          self.capture.startRecording = false;
          self.capture.recording = true;
          self.capture.recordingTimer = new Date();
          self.capture.recordingTimeout = setTimeout(finishAfterTime,10*60*1000);
        },function(error){
          if(error && error.name =="NotAllowedError"){
            self.alert("Dein Browser erlaubt derzeit keine Aufzeichnung vom Microphone. Es wurde keine Erlaubnis erteilt.");
          }else
            self.alert("Dein Browser unterstützt keine Aufnahme, oder es wurde kein Microphone gefunden. Bitte verwende eine aktuelle Version von Chrome oder FireFox oder die LearningView App.");

          if(self.capture.clearProcessingWatchdog) self.capture.clearProcessingWatchdog();
          self.capture.processing = false;
          self.capture.recording = false;

          $mdDialog.cancel();
        });
      });
    };

    self.stopCaptureAudio = function(id,canceled) {
      // inside app
      if(!self.capture || !self.capture.recording) return;
      self.capture.recording = false;
      self.capture.processing = true;
      if(self.capture.startProcessingWatchdog) self.capture.startProcessingWatchdog();
      // will raise exception if called without succesful "start" recording
      // inside browser
      if(self.capture.service){
        if(self.capture.service.state === 'inactive'){
          if(self.capture.clearProcessingWatchdog) self.capture.clearProcessingWatchdog();
          self.capture.processing = false;
          return;
        }
        var now = new Date();
        self.capture.recordingDurationMS = now.getTime() - self.capture.recordingTimer.getTime();
        self.capture.recordingDuration = secToMMSS(Math.ceil((now.getTime() - self.capture.recordingTimer.getTime())/ 1000));
        self.capture.service.canceled = canceled;
        self.capture.service.stopRecording();
        if(self.capture.recordingTimeout)
          clearTimeout(self.capture.recordingTimeout);
        self.capture.recordingTimeout = null;
      }

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.currentCameraIndex = 0;
    self.deviceCameras = [];
    self.captureVideo = function(id,callback,ev) {
      // inside app
      if(navigator.device && navigator.device.capture && navigator.device.capture.captureVideo){
        var captureNow = function(){
          // capture callback
          var captureSuccess = function(mediaFiles) {
            var savedFilePath = mediaFiles[0].fullPath; // fullPath;
            // try move to
            window.resolveLocalFileSystemURL(savedFilePath.indexOf("file:/") == 0 ? savedFilePath : 'file:/'+savedFilePath,function(fileEntry){
              window.resolveLocalFileSystemURL(cordova.file.dataDirectory,function(dirEntry){
                fileEntry.moveTo(dirEntry, id+".mp4", function(){
                  if(callback) callback(cordova.file.dataDirectory+id+".mp4",id+".mp4");

                }, function(error){
                  self.alert("Fehler Kopieren: "+JSON.stringify(error));} );
              },  function(error){
                self.alert("Fehler Ordner öffnen: "+JSON.stringify(error));} );
            },  function(error){
              self.alert("Fehler Datei finden: "+JSON.stringify(error)+ " "+mediaFiles[0].fullPath);} );

          };

          // capture error callback
          var captureError = function(error) {
            if(error.code != 3) // canceld
              self.alert('Fehler bei der Aufnahme. Code: ' + JSON.stringify(error));
          };

          // start video capture
          var options = {
            //quality:0, // 0 for small files
            duration:600,
            limit:1
          };

          if(window.isIOSDevice) options.saveToPhotoAlbum = true;
          // also for android with new versions
          if(window.cordovaAppVersionNumber >= 204013) options.saveToPhotoAlbum = true;

          navigator.device.capture.captureVideo(captureSuccess, captureError, options);
        };

        self.requestMobileCameraPermissions(captureNow);

      }else{
        // inside browser

        if(navigator.mediaDevices === undefined)  navigator.mediaDevices = {};
        if(navigator.mediaDevices.getUserMedia === undefined) {
          navigator.mediaDevices.getUserMedia = function(constraints) {
            var getUserMedia = navigator.webkitGetUserMedia || navigator.mozGetUserMedia || navigator.msGetUserMedia;
            if (!getUserMedia)
              return Promise.reject(new Error('getUserMedia is not implemented in this browser')); else
              return new Promise(function(resolve, reject) {
                getUserMedia.call(navigator, constraints, resolve, reject);
              });
          }
        }

        self.deviceCameras = [];

        navigator.mediaDevices.enumerateDevices().then(function(devices) {
          self.deviceCameras = [];
          devices.forEach(function(device) {
            if (device.kind === "videoinput") {
              self.deviceCameras.push(device.deviceId);
            }
          });
          // start now
          var constraints = {};
          if(window.electron || getBrowser() == "Chrome" || getBrowser() == "Safari"|| getBrowser() == "Mobile" || getBrowser() == "Netscape"){
            constraints = {"audio": true, "video": {  "minWidth": 640,  "maxWidth": 640, "minHeight": 480,"maxHeight": 480 } };//Chrome did not support the new constraints spec until 59 for video and 60 for audio
          }else if(getBrowser() == "Firefox"){
            constraints = {"audio": true, "video": {  "width": { min: 640, ideal: 640, max: 640 },  
                                                      "height": { min: 480, ideal: 480, max: 480 } } }; //Firefox
          }else{
            $mdDialog.cancel();
            self.alert("Dein Browser unterstützt keine Aufnahme von Videos. Bitte verwende eine aktuelle Version von Chrome oder FireFox oder die LearningView App.");
            return;
          }
          if(self.deviceCameras[self.currentCameraIndex] != "")
            constraints.video.deviceId = {exact: self.deviceCameras[self.currentCameraIndex]};
          

          if(self.failedCameraConstrained) {
            constraints = {audio: true, video:true};
            self.useMinimalCamaeraConstrained = true; 
          }

          if (typeof MediaRecorder === 'undefined') {
            $mdDialog.cancel();
            self.alert("Dein Browser unterstützt keine Aufnahme von Videos. Bitte verwende eine aktuelle Version von Chrome oder FireFox oder die LearningView App.");
            return;
          }else{
            navigator.mediaDevices.getUserMedia(constraints).then(function(stream){
              // iOS once again ask for devices as only now we will have correct data ...
              navigator.mediaDevices.enumerateDevices().then(function(devices) {
                self.deviceCameras = [];
                devices.forEach(function(device) {
                  if (device.kind === "videoinput") {
                    self.deviceCameras.push(device.deviceId);
                  }
                });
              });
              self.failedCameraConstrained = false; // works now
              self.useMinimalCamaeraConstrained = false;

              self.showDialog({
                templateUrl: "recordVideoDialog.html",
                skipHide:true, // keep other dialog open
                clickOutsideToClose: false,
                targetEvent:ev,
                escapeToClose: false,
                onRemoving : function(){
                  var tracks = stream.getTracks();
                  for(var i=0; i < tracks.length; i++) tracks[i].stop();
                },
                controller: function ($scope, $mdDialog) {
                  $scope.self = self;
                  $scope.id = id;
                  $scope.chunks = [];
                  $scope.recording = false;
                  $scope.canceled = false;
                  $scope.dialogClosed = false;
                  $scope.stopWatchdog = null;

                  $scope.clearVideoTimers = function(){
                    if(self.capture.updateInterval)
                      clearInterval(self.capture.updateInterval);
                    self.capture.updateInterval = null;
                    if($scope.stopWatchdog)
                      clearTimeout($scope.stopWatchdog);
                    $scope.stopWatchdog = null;
                  };

                  $scope.scheduleStopWatchdog = function(){
                    if($scope.stopWatchdog)
                      clearTimeout($scope.stopWatchdog);
                    $scope.stopWatchdog = setTimeout(function(){
                      if($scope.canceled || $scope.dialogClosed) return;
                      console.log("Video recorder stop watchdog triggered");
                      $scope.recording = false;
                      self.alert("Die Videoaufnahme konnte nicht sauber beendet werden. Bitte versuche es erneut.");
                      $scope.cancel(true);
                    },15000);
                  };

                  setTimeout(function(){
                    if($scope.canceled || $scope.dialogClosed) return;
                    var captureStream = stream;
                    var options = {};

                    var videoElement = $('#videoRecorderScreen').get(0);
                    if(!videoElement){
                      console.log("Video element missing");
                      $scope.cancel(true);
                      return;
                    }
                    videoElement.onloadedmetadata = function() {
                      if(self.mirrorCameraX == 1 || self.mirrorCameraY == 1) {
                        var mirrorCanvas = document.createElement("canvas");
                        mirrorCanvas.width = videoElement.videoWidth;
                        mirrorCanvas.height = videoElement.videoHeight;
                        var ctx = mirrorCanvas.getContext("2d");
                        var canvasStream = mirrorCanvas.captureStream(30);
                        stream.getAudioTracks().forEach(function(track){ canvasStream.addTrack(track); });
                        captureStream = canvasStream;
                        var drawMirroredFrame = function() {
                          if($scope.canceled) return; // stop it
                          ctx.save();
                          ctx.scale(self.mirrorCameraX == 1 ? -1 : 1, 
                                    self.mirrorCameraY == 1 ? -1 : 1);
                          ctx.drawImage(videoElement, self.mirrorCameraX ? -mirrorCanvas.width : 0, self.mirrorCameraY ? -mirrorCanvas.height : 0);
                          ctx.restore();
                          requestAnimationFrame(drawMirroredFrame);
                        }
                        drawMirroredFrame();
                        setupMediaRecorder();
                      }
                    };                    
                    var url = window.URL || window.webkitURL;
                    try{
                      videoElement.src = url ? url.createObjectURL(stream) : stream;
                    }catch(e){
                      videoElement.srcObject = stream; // new FireFox way?
                    }

                    videoElement.style.transform = self.mirrorCameraX == 1 && self.mirrorCameraY == 1 ? "scale(-1,-1)" : (
                                                   self.mirrorCameraX == 1 ? "scaleX(-1)" : (
                                                   self.mirrorCameraY == 1 ? "scaleY(-1)" : ''));
                    videoElement.play();

                    $timeout(function(){
                      var tracks = stream.getTracks();
                      $scope.recordingDeviceLabels = [];
                      for(var i=0; i < tracks.length; i++) $scope.recordingDeviceLabels.push(tracks[i].label);
                      tracks = null;                      
                    },0)

                    var setupMediaRecorder = function(){
                      try{
                        if (typeof MediaRecorder.isTypeSupported == 'function'){
                          if (MediaRecorder.isTypeSupported('video/webm;codecs=h264'))
                            options = {mimeType: 'video/webm;codecs=h264'};
                          else if (MediaRecorder.isTypeSupported('video/webm;codecs=vp9,opus'))
                            options = {mimeType: 'video/webm;codecs=vp9,opus'};
                          else if (MediaRecorder.isTypeSupported('video/webm;codecs=vp8,opus'))
                            options = {mimeType: 'video/webm;codecs=vp8,opus'};
                          else if (MediaRecorder.isTypeSupported('video/webm;codecs=vp9'))
                            options = {mimeType: 'video/webm;codecs=vp9'};
                          else if (MediaRecorder.isTypeSupported('video/webm;codecs=vp8'))
                            options = {mimeType: 'video/webm;codecs=vp8'};

                          self.capture.video_recorder = new MediaRecorder(captureStream, options);
                        }else{
                          self.capture.video_recorder = new MediaRecorder(captureStream);
                        }
                      }catch(e){
                        console.log("Video recorder init failed", e);
                        self.alert("Die Videoaufnahme konnte nicht gestartet werden.");
                        $scope.cancel(true);
                        return;
                      }

                      self.capture.video_recorder.ondataavailable = function(e){
                        if(e && e.data && e.data.size > 0) $scope.chunks.push(e.data);
                      };
                      self.capture.video_recorder.onerror = function(e){
                        console.log("Video recorder error", e);
                        $scope.clearVideoTimers();
                        $scope.recording = false;
                        self.alert("Fehler bei der Videoaufnahme. Bitte versuche es erneut.");
                        $scope.cancel(true);
                      };
                      self.capture.video_recorder.onstart = function(){
                      };
                      self.capture.video_recorder.onpause = function(){
                      };
                      self.capture.video_recorder.onresume = function(){
                      };
                      self.capture.video_recorder.onwarning = function(e){
                        console.log("Record warning:",e);
                      };
                      self.capture.video_recorder.onstop = function(){
                        $scope.clearVideoTimers();
                        $scope.recording = false;
                        self.capture.video_recorder = null;
                        if($scope.canceled){
                          $scope.cancel(true);
                          return;
                        }
                        if(!$scope.canceled){
                          try{
                            var type = "video/webm";
                            for(var i=0; i < $scope.chunks.length; i++)
                              if($scope.chunks[i].type && $scope.chunks[i].type != ""){
                                type = $scope.chunks[i].type; break;
                              }
                            var blob = new Blob($scope.chunks, {type: type});
                            $scope.chunks = [];
                            var url = window.URL || window.webkitURL;
                            var videoURL = url.createObjectURL(blob);
                            var now = new Date();
                            if(self.capture.recordingTimer){
                              self.capture.recordingDurationMS = now.getTime() - self.capture.recordingTimer.getTime();
                              self.capture.recordingDuration = secToMMSS(Math.ceil((now.getTime() - self.capture.recordingTimer.getTime())/ 1000));
                            }

                            if(callback) callback(videoURL,id+".mp4",blob);
                          }catch(e){
                            console.log("Video finalize failed", e);
                            self.alert("Die Videoaufnahme konnte nicht verarbeitet werden.");
                          }
                        }
                        $scope.cancel(true);
                      };
                    };

                    if (self.mirrorCameraX != 1 && self.mirrorCameraY != 1) {
                      // start now otherwise wait for videoElement.onloadedmetadata
                      setupMediaRecorder();
                    }
                  },1000);

                  $scope.flipCamera = function(){
                    self.currentCameraIndex++;
                    if(self.currentCameraIndex >= self.deviceCameras.length)
                      self.currentCameraIndex = 0;
                    $scope.cancel();
                    self.captureVideo(id,callback,ev);
                  };
                 
                  $scope.mirrorCamera = function(direction){
                    if(direction == "x"){
                      self.mirrorCameraX = self.mirrorCameraX ? 0 : 1;
                      if(self.mirrorCameraX) self.userViewData["vmx"] = 1; else delete self.userViewData["vmx"];
                      self.updateUserViewData();
                    }
                    if(direction == "y"){
                      self.mirrorCameraY = self.mirrorCameraY ? 0 : 1;
                      if(self.mirrorCameraY) self.userViewData["vmy"] = 1; else delete self.userViewData["vmy"];
                      self.updateUserViewData();
                    }
                    $scope.cancel();
                    self.captureVideo(id,callback,ev);
                  };

                  $scope.record = function(){
                    if(!self.capture.video_recorder){
                      self.alert("Die Videoaufnahme ist noch nicht bereit. Bitte kurz warten.");
                      return;
                    }
                    $scope.recording = true;
                    try{
                      self.capture.video_recorder.start(250);
                      self.capture.recordingTimer = new Date();
                      self.capture.updateInterval = setInterval(function(){
                        $timeout(function(){
                          var now = new Date();
                          if(self.capture.recordingTimer){
                            self.capture.recordtime = secToMMSS((now.getTime() - self.capture.recordingTimer.getTime())/ 1000);
                          }
                        },0);
                      },500);
                    }catch(e){
                      $scope.recording = false;
                      console.log("Video start failed", e);
                      self.alert("Die Videoaufnahme konnte nicht gestartet werden.");
                      $scope.cancel(true);
                    }
                  };
                  $scope.stop = function(){
                    if(!self.capture.video_recorder){
                      $scope.recording = false;
                      return;
                    }
                    if(self.capture.video_recorder.state === "inactive"){
                      $scope.clearVideoTimers();
                      $scope.recording = false;
                      return;
                    }
                    try{
                      self.capture.video_recorder.stop();
                      $scope.scheduleStopWatchdog();
                    }catch(e){
                      console.log("Video stop failed", e);
                      self.alert("Die Videoaufnahme konnte nicht beendet werden.");
                      $scope.cancel(true);
                    }
                    $scope.recording = false;
                  };
                  $scope.pause = function(){
                    if(self.capture.video_recorder && self.capture.video_recorder.state === "recording"){
                      self.capture.video_recorder.pause();
                    }
                  };
                  $scope.resume = function(){
                    if(self.capture.video_recorder && self.capture.video_recorder.state === "paused"){
                      self.capture.video_recorder.resume();
                    }
                  };

                  $scope.cancel = function(skipStopRecorder) {
                    if($scope.dialogClosed) return;
                    $scope.clearVideoTimers();
                    $scope.recording = false;
                    $scope.canceled = true;
                    $scope.chunks = [];
                    if(!skipStopRecorder && self.capture.video_recorder && self.capture.video_recorder.state !== "inactive"){
                      try{
                        self.capture.video_recorder.stop();
                      }catch(e){
                        console.log("Video stop during cancel failed", e);
                      }
                    }
                    self.capture.video_recorder = null;
                    $scope.dialogClosed = true;
                    self.closeDialog($scope.dialogElement);
                  };
                }
              });
            }).catch(function(error){
              if(error && error.name =="NotAllowedError"){
                self.alert("Dein Browser erlaubt derzeit keine Aufzeichnung von Ton / Video. Es wurde keine Erlaubnis erteilt.");
              }else{
                if(!self.useMinimalCamaeraConstrained) {
                  self.failedCameraConstrained = true;
                  // retry
                  self.captureVideo(id,callback,ev);
                  return;
                }
                self.alert("Dein Browser unterstützt keine Aufnahme von Videos, oder es wurde keine Webcam gefunden. Bitte verwende eine aktuelle Version von Chrome oder FireFox oder die LearningView App.");
              }
            });
          }
        });
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getNewWindowName = function(){
      if(typeof(cordova) != "undefined" && cordova.InAppBrowser){
        return "_system";
      }      
      return "_blank"+Math.random();
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.tryCloseLastWindow = function(){
      if(typeof(cordova) != "undefined"){
        if(window.lastOpenWindow) {
          try{
          window.lastOpenWindow.close();
          }catch(e){}
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openURLNewWindow = function(url){
      if(typeof(cordova) != "undefined"){
        if(window.lastOpenWindow) {
          try{
          window.lastOpenWindow.close();
          }catch(e){}
        }
        window.lastOpenWindow = window.open(url,self.getNewWindowName(),'location=no');
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.handleUploadError = function(result,callback,onerror){
      if(result == "NOCONNECTION"){
        if(onerror) onerror();
        self.alert("Keine Internet-Verbindung zum Server oder Fehler bei der Übermittlung. Versuche es später noch einmal.");
      } else
      if(result == "TOOMANYPAGESTOCONVERTTOIMAGE"){
        if(onerror) onerror();
        self.alert("Das PDF konnte nicht als Bild konvertiert werden, da es zu viele Seiten enthält. Bitte verwende ein Bild oder ein kürzeres PDF.");
      }else
      if(result == "FILETOOLARGE"){
        if(onerror) onerror();        
        self.alert($filter('trans')('ONLYSMALLERFILESALLOWED'));
      } else
      if(result == "NOTALLOWEDFILETYPE"){
        if(onerror) onerror();
        self.alert("Diese Datei kann leider nicht hochgeladen werden.<br> Nur bestimmte Dokumente wie PDF, Word, Excel usw. sind erlaubt.");
      } else
      if(result.indexOf("https://") === 0){
        if(callback) callback(result);
      }else{
        if(onerror) onerror();
        self.alert(result);
      }
    };

    self.uploadFileInput = function(e,callback, index){
      if(!index) index = 0;

      e = e && e.target && !e.files ? e.target : e;
      if(e.files.length > 0 && e.files[index].name){
        // upload the file

        var uploadFileWithInput = function (input,callback, index) {
          if(input){
            var file = input.files[index];
            var ext = file.type;

            // Create a new FormData object.
            var formData = new FormData();
            var fileName = file.name;

            formData.append('file', file, fileName);
            formData.append('userid', self.user.ID);
            formData.append('salt', self.user.Salt);
            formData.append('id', fileName);

            if(file.myType == "image" && ext.indexOf("pdf") >= 0)
              formData.append('type', file.myType); else
              formData.append('type', 'file');

            if(input.appendToImage) formData.append('appendtoimage', input.appendToImage);

            self.sendUploadFile(formData,function(fileURL){
              $timeout(function(){
                if(fileURL.indexOf("https://") === 0){
                  var attributes = {};
                  attributes.isUpload = true;
                  attributes.url = fileURL;
                  if(file.name && file.name != '') attributes.name = file.name;

                  if(!file.myType) file.myType = 'file';
                  attributes.type = file.myType;

                  if(attributes.type == 'audio') {
                    //audio additionally needs duration inside recentFiles
                    var audio = new Audio();
                    audio.src = attributes.url;

                    $(audio).on("loadedmetadata", function(){
                      var audioDuration = Math.ceil(audio.duration.toString());
                      attributes.duration = audioDuration;
                      self.addToRecentFiles(attributes);
                    });
                  }

                  else {
                    self.addToRecentFiles(attributes);
                  }                    
                }
                if(callback) callback(fileURL);
              },0);              
            });
          }
        };

        uploadFileWithInput(e,function(result){
          self.handleUploadError(result,callback,function(){
            $(e).val(''); // reset on error
          })
        }, index);
      }
    };

    //////////////////////////////////////////////////////////////////////////////////////////////////

    self.createBlob = function(data, type) {
      var r;
      try {
        r = new $window.Blob([data], {type: type});
      }
      catch (e) {
        // TypeError old chrome and FF
        $window.BlobBuilder = $window.BlobBuilder ||
        $window.WebKitBlobBuilder ||
        $window.MozBlobBuilder ||
        $window.MSBlobBuilder;
        // consider to use crosswalk for android

        if (e.name === 'TypeError' && window.BlobBuilder) {
          var bb = new BlobBuilder();
          bb.append([data.buffer]);
          r = bb.getBlob(type);
        }
        else if (e.name == "InvalidStateError") {
          // InvalidStateError (tested on FF13 WinXP)
          r = new $window.Blob([data.buffer], {type: type});
        }
        else {
          throw e;
        }
      }

      return r;
    };

    self.addFileFromLocalURI = function(form, key, fileUri, filename) {
      var deferred = $q.defer();

      $window.resolveLocalFileSystemURL(fileUri, function (fileEntry) {
        fileEntry.file(function (file) {
          var reader = new FileReader();
          reader.onloadend = function (fileReadResult) {
            var data = new Uint8Array(fileReadResult.target.result);
            var blob = self.createBlob(data, file.type);
            form.append(key, blob, filename);
            deferred.resolve();
          };

          reader.onerror = function (fileReadResult) {
            deferred.reject(reader.error);
          };
          reader.readAsArrayBuffer(file);
        });
      });
      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.uploadFilePanel = null;

    self.sendUploadFile = function(formData,callback){
      // show panel now
      if(self.uploadFilePanel) self.uploadFilePanel.remove();
      self.uploadFilePanel = $(
        '<div style="display:none;background:rgb(2,136,209);color:white;position:absolute;z-index:9999999;top:0;left:0;width:100vw;height:100vh;">' +
          '<div style="position:absolute;top:35%;left:24px;right:24px;text-align:center">' +
            'Bitte warten ... <br><br><i class="fa fa-spinner fa-spin fa-3x"></i><br><br>' +
            '<span id="uploadFileProgress" style="font-size:24px;line-height:1.2"></span>' +
            '<div style="width:100%;max-width:200px;margin:16px auto 7px auto">' +
              '<div style="height:8px;background:rgb(1,105,160);border-radius:4px;overflow:hidden">' +
                '<div id="uploadFileProgressBar" style="height:8px;width:0%;background:white;border-radius:4px"></div>' +
              '</div>' +
              '<div style="display:flex;justify-content:space-between;gap:12px;margin-top:6px;font-size:12px;color:rgba(255,255,255,0.9)">' +
                '<span id="uploadFileSpeed">-- MB / s</span>' +
                '<span id="uploadFileEta">--</span>' +
              '</div>' +
            '</div><br>' +
            '<small id="uploadFileConverting" style="display:none">Die Datei muss noch konvertiert werden. Das ist abhängig von der Dateigrösse und kann mehrere Minuten dauern.</small>' +
            '<br><br><a href="#" id="uploadFileCancel" style="color:white;text-decoration:none;font-size:13px;padding:8px; background: rgb(0 106 160); border-radius: 4px;">Upload abbrechen</a>' +
          '</div>' +
        '</div>'
      );
      $("body").append(self.uploadFilePanel);
      self.uploadFilePanel.fadeIn();

      var offerRetry = function(){
        self.confirm("Keine Internet-Verbindung zum Server oder Fehler bei der Übermittlung. Möchtest du es jetzt erneut versuchen?","JA").then(function(){
          // retry now
          self.sendUploadFile(formData,callback);
        });
      }
      var informNoUpload = function(e){
        self.alert("Fehler bei der Übermittlung, die zu übermittelnden Daten konnten nicht gelesen werden.");
      }
      var informUploadTimeout = function(e){
        self.alert("Fehler bei der Übermittlung. Es konnte kein Upload gestartet werden.");
      }
      var formatUploadTime = function(seconds){
        if(!isFinite(seconds) || seconds < 0) return "--";
        seconds = Math.ceil(seconds);
        if(seconds < 60) return seconds+" s";
        var minutes = Math.floor(seconds / 60);
        var restSeconds = seconds % 60;
        if(minutes < 60) return minutes+" min "+(restSeconds < 10 ? "0" : "")+restSeconds+" s";
        var hours = Math.floor(minutes / 60);
        minutes = minutes % 60;
        return hours+" h "+(minutes < 10 ? "0" : "")+minutes+" min";
      }

      var timeout = function(){
        // 30 sec without progress, we call it an error
        if(request && request.abort){
          request.abort(); // cancel the request now
        }else{
          self.uploadFilePanel.fadeOut(400,function(){ self.uploadFilePanel.remove(); });
          if(uploadTimeout) clearTimeout(uploadTimeout);
          informUploadTimeout();
        }
      };

      var uploadTimeout = setTimeout(timeout,30*1000);
      var uploadProgressLastTime = null;
      var uploadProgressLastLoaded = 0;
      var uploadSpeed = 0;
      var uploadCanceled = false;
      
      var request = $.ajax({
        url: 'https://learningview.org/api/upload.php',
        type: 'POST',
        data: formData,
        cache: false,
        contentType: false,
        processData: false,
        // Custom XMLHttpRequest
        xhr: function() {
          var myXhr = $.ajaxSettings.xhr();
          if (myXhr) {
              myXhr.withCredentials = true; 
          }          
          if (myXhr.upload) { 
              // For handling the progress of the upload
              myXhr.upload.addEventListener('progress', function(e) {
                var now = new Date().getTime();
                if(uploadProgressLastTime === null) uploadProgressLastTime = now;

                if (e.lengthComputable) {
                  var p = Math.floor(e.loaded*100/e.total);
                  $('#uploadFileProgress').html(p+" %");
                  $('#uploadFileProgressBar').css('width', p+"%");

                  var secondsSinceLastProgress = (now - uploadProgressLastTime) / 1000;
                  if(secondsSinceLastProgress > 0.25 && e.loaded >= uploadProgressLastLoaded){
                    var instantUploadSpeed = (e.loaded - uploadProgressLastLoaded) / secondsSinceLastProgress;
                    uploadSpeed = uploadSpeed ? uploadSpeed * 0.7 + instantUploadSpeed * 0.3 : instantUploadSpeed;
                    uploadProgressLastTime = now;
                    uploadProgressLastLoaded = e.loaded;
                  }

                  if(uploadSpeed > 0){
                    $('#uploadFileSpeed').html((uploadSpeed / 1024 / 1024).toFixed(1)+" MB / s");
                    $('#uploadFileEta').html(formatUploadTime((e.total - e.loaded) / uploadSpeed));
                  }
                  if(p >= 99) $('#uploadFileConverting').fadeIn();
                }
                if(uploadTimeout){
                  clearTimeout(uploadTimeout);
                  uploadTimeout = setTimeout(timeout,30*1000); // reset timer on any progress made
                }
              } , false);
          }else{
            self.uploadFilePanel.fadeOut(400,function(){ self.uploadFilePanel.remove(); });
            if(uploadTimeout) clearTimeout(uploadTimeout);

            informNoUpload();       
          }
          return myXhr;
        },
        success: function(fileURL){
          self.uploadFilePanel.fadeOut(400,function(){ self.uploadFilePanel.remove(); });
          if(uploadTimeout) clearTimeout(uploadTimeout);

          if(callback) callback(fileURL);
        },
        error: function(){
          self.uploadFilePanel.fadeOut(400,function(){ self.uploadFilePanel.remove(); });
          if(uploadTimeout) clearTimeout(uploadTimeout);

          if(uploadCanceled) return;
          offerRetry();       
        }
      });
      $('#uploadFileCancel').on('click', function(e){
        e.preventDefault();
        var cancelConfirm = self.confirm("Möchtest du den Upload wirklich abbrechen?",$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
          uploadCanceled = true;
          if(request && request.abort) request.abort();
        });
        setTimeout(function(){
          $('.md-dialog-container').last().css('z-index','10000002');
          $('.md-dialog-container').last().find('md-dialog').css('z-index','10000003');
        },200);
      });
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.uploadFile = function (fileURI,filename,id,type,appendtoimage,callback) {

      var sendForm = function(fileURL){
        $timeout(function(){
          if(fileURL.indexOf("https://") === 0){
            var attributes = {};
            attributes.isUpload = true;
            attributes.url = fileURL;
            if(filename && filename != '') attributes.name = filename;

            if(!type) type = 'file';
            if(type == 'record') type = 'audio';
            attributes.type = type;

            if(type == 'audio') {
              //audio additionally needs duration inside recentFiles
              var audio = new Audio();
              audio.src = attributes.url;
              $(audio).on("loadedmetadata", function(){
                  var audioDuration = Math.ceil(audio.duration.toString());
                  attributes.duration = audioDuration;
                  self.addToRecentFiles(attributes);
              });
            } else {
              self.addToRecentFiles(attributes);
            }
          }
          self.handleUploadError(fileURL,callback);
        },0);
      };

      if(typeof(cordova) != "undefined" && !(fileURI instanceof Blob)){
        var formData = new FormData();
        self.addFileFromLocalURI(formData,'file',fileURI,filename ? filename : fileURI.substr(fileURI.lastIndexOf('/') + 1)).
        then(function(){
          formData.append('userid', self.user.ID);
          formData.append('salt', self.user.Salt);
          formData.append('id', id);
          formData.append('type', type);
          formData.append('cordova', fileURI);
          if(appendtoimage) formData.append('appendtoimage', appendtoimage);
          self.sendUploadFile(formData,sendForm);
        }); 

      }else{
        var formData = new FormData();
        formData.append('file', fileURI, filename ? filename : fileURI.substr(fileURI.lastIndexOf('/') + 1));
        formData.append('userid', self.user.ID);
        formData.append('salt', self.user.Salt);
        formData.append('id', id);
        formData.append('type', type);
        if(appendtoimage) formData.append('appendtoimage', appendtoimage);
        self.sendUploadFile(formData,sendForm);
      }
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showUserTrash = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "showUserTrashDialog.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.refresh = function(){
            // fetch items
            self.apiPost("ajax",{"action":"getUserTrashEntries"}).then(function(data) {
              $scope.items = data.items;
            });
          };

          $scope.restoreUserTrashEntry = function(item,ev) {
            self.apiPost("ajax",{"action":"restoreFromUserTrash", id:item.ID}).then(function(data) {
              self.alert($filter('trans')('RESTOREDFROMTRASH',item.Data.Name));
              self.keepAliveCallback();
              $scope.refresh();
            });
          };

          $scope.removeUserTrashEntry = function(item,ev) {
            self.confirm($filter('trans')('ASKREMOVEFROMTRASHCAN',item.Data.Name),'<span style="color:red">'+$filter('trans')('DELETE')+'</span>',ev).then(function(){
              self.apiPost("ajax",{"action":"removeUserTrashEntry", id:item.ID}).then(function(data) {
                $scope.refresh();
              });
            });
          };

          $scope.askEmptyTrash = function(ev) {
            self.confirm($filter('trans')('ASKEMPTYTRASHCAN'),'<span style="color:red">'+$filter('trans')('EMPTYTRASHCAN')+'</span>',ev).then(function(){
              self.apiPost("ajax",{"action":"clearUserTrashEntries"}).then(function(data) {
                $scope.items = [];
                self.closeDialog($scope.dialogElement);
              });
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };

          $scope.refresh();
        }
      });
      return deferred.promise;      
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showTranslationPanel = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "translationDialog.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.app = app;
          $scope.pageStart = 0;

          $scope.totalItems = Object.keys(app.translations['DE']).length;
          $scope.pages = [];
          $scope.perPage = 20;
          for(var i=0; i < Math.ceil($scope.totalItems / $scope.perPage); i++)
            $scope.pages.push(i);


          for(var lang in app.translations){
            app.fetchTranslation(lang);
          }

          self.translationLanguage = app.currentLanguage;


          $scope.saveTranslations = function(lang,key){
            var d = {};
            d[key] = app.translations[lang][key];

            self.apiPost("ajax",{"action":"saveTranslations", "lang":lang, "data":JSON.stringify(d)})
              .then(function(data) {
                console.log("translations saved.");
              });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.hasShownTaskSolution = [];
    self.hasTaskHintsVisible = function(t,taskStatus){
      if(!t || !t.DataJSON || !t.DataJSON.hints) return false;
      for(var i=0; i < t.DataJSON.hints.length; i++){
        if(!t.DataJSON.hints[i].visible && t.DataJSON.hints[i].visible != '0') return true;
        if(t.DataJSON.hints[i].visible == '0' && self.user.Teacher == '1') return true;
        if(t.DataJSON.hints[i].visible == '1') return true;
        if(t.DataJSON.hints[i].visible == '3') return true;
        if(t.DataJSON.hints[i].visible == '5') return true;
        if(t.DataJSON.hints[i].visible == '4') {
          if(self.user.Teacher == 1) return true;
          if(self.getUserTaskHintApproved(i, t, self.user) == 1) return true;
        }
        if(t.DataJSON.hints[i].visible == '2' &&
          ((self.user.Teacher == '1' || 
           ((self.getUserTaskChecksDeep(t,self.user,self.currentClass) != 3 || taskStatus.Status == 'OK') && 
           (taskStatus && (self.hasShownTaskSolution[t.ID] == true || taskStatus.Status == 'OK' || taskStatus.Status == 'x' || taskStatus.Status == '?' || taskStatus.Status == 're')))))) return true;

      }
      return false;
    };

    self.showUserTaskSolution = function(it){
      var deferred = $q.defer();
      self.track('openTaskSolution',it);

      self.showDialog({
        templateUrl: "showUserTaskSolution.html",
        skipHide:true, // keep other dialog open
        clickOutsideToClose: false,
        escapeToClose: false,
        onRemoving: function (event, removePromise) {
          self.track('closeTaskSolution',it);
        },        
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.t = it;

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.reject("cancel");
          };

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve();
          };
        }
      });
      return deferred.promise;

    };

    self.countSearchingPartners = function(it,excludeSelf){
      if(!self.currentClass) return 0;
      var c = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        if(excludeSelf && self.currentClass.students[i].ID == self.user.ID) continue;
        var t = self.findTaskInClass(self.currentClass,it.ID,self.currentClass.students[i]);
        if(!t) continue;
        var currentStatus = self.getUserTaskStatus(it,self.currentClass.students[i]);
        if(currentStatus.Status == 's') c++;
      }
      return c;
    }

    self.searchpartners = function(it,ev){
      var refreshStudentInterval = null;
      self.track('openSearchTaskPartners',it);
      self.showDialog({
        templateUrl: "searchpartners.html",
        skipHide:true, // keep other dialog open
        targetEvent: ev,
        clickOutsideToClose: true,
        onRemoving : function(){
          if(refreshStudentInterval) $interval.cancel(refreshStudentInterval);
          refreshStudentInterval = null;
          self.track('closeSearchTaskPartners',it);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.user = self.user;

          $scope.showSearchParnterHint = function(s,ev){
            self.alert($filter('trans')('SEARCHPARTNERHINT',s.Name),ev);
          };

          $scope.refreshStudents = function(){
            $scope.ownStatus = '';
            $scope.students = [];
            for(var i=0; i < self.currentClass.students.length; i++)
              $scope.students.push({student:self.currentClass.students[i]});

            for(var i=0; i < $scope.students.length; i++){
              $scope.students[i].currentStatus = self.getUserTaskStatus(it,$scope.students[i].student);
              if(!$scope.students[i].currentStatus || $scope.students[i].currentStatus.Status != 's'){
                $scope.students.splice(i,1);
                i--;
              }
            }

            $scope.ownStatus = self.getUserTaskStatus(it,self.user).Status;
          };

          $scope.ok = function() {
            self.closeDialog($scope.dialogElement);
          };

          $scope.setSearching = function(){
            self.showLoadingIndicator(null,function(done){
              var action = {"action":"saveUserTaskStatus", "ID":it.ID,
                            "status":$scope.searching ? 's':'',
                            "answer":'', "partners":'',
                            "classid":self.currentClass.ID};

              self.apiPost("ajax",action).then(function(data) {
                 var ts = self.getUserTaskStatus(it,self.user,true);
                 ts.Status = $scope.searching ? 's':'';
                 self.keepAliveCallback().then(function(){
                   $scope.refreshStudents();
                   done();
                 });
                 self.track("setTaskSearchPartner",{"ID":it.ID,"searching":ts.Status == 's' ? 1 : 0});
               },function(data){
                 self.alert("Speichern fehlgeschlagen: "+data.error);
               });
            });
          };

          $scope.refreshStudents();
          refreshStudentInterval = $interval($scope.refreshStudents,2000);

          $scope.searching = $scope.ownStatus == 's';

          // activate on first run
          /*
          if($scope.ownStatus == ''){
            self.confirm($filter('trans')('ASKSEARCHPARTNERNOW'),$filter('trans')('ASKSEARCHPARTNERREGISTER') ,ev, $filter('trans')('NO')).then(function(){
              $scope.searching = true;
              $scope.setSearching();              
            })
          }
          */
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.feedbackIsAudio = function(feedback){
      if(!feedback || feedback == "") return false;
      return feedback.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(m4a)/) ? true : false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addFeedbackController = function($scope) {
      $scope.addFeedbackFromFiles = function(results) {
        if(results[0].Type == "audio") {
          self.addAudioRecorderScope($scope, null, true);
          $scope.selectActivity({url:results[0].URL, name:results[0].name});
          $scope.isRecording = true;
        }
        else if(results[0].Type == "text") {
          $timeout(function(){
            $scope.changeToRecording(true);
            $scope.currentReview = results[0].Text;
          },0);
        }
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openPeerFeedbackList = function(it,ev){
      var deferred = $q.defer();
      var refreshInterval = null;
      self.track('openTaskPeerFeedbacks',it);
      self.showDialog({
        templateUrl: "peerFeedbackList.html",
        skipHide:true, // keep other dialog open
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        onRemoving: function (event, removePromise) {
          $interval.cancel(refreshInterval);
          self.track('closeTaskPeerFeedbacks',it);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.currentStudent = null;
          $scope.currentReview = "";
          $scope.currentStars = 0;

          $scope.studentStatus = [];
          $scope.studentGroups = {};
          $scope.hasStudents = false;

          self.addFeedbackController($scope);

          // we need to group results if the task was done by multiple users
          // we can click on the group to provide the whole group a feedback
          // the feedback is "individual" so it is not "group to group" 
          $scope.refresh = function(){
            for(var i=0; i < self.currentClass.students.length; i++){
              var us = self.getUserTaskStatus(it,self.currentClass.students[i]);
              $scope.studentStatus[self.currentClass.students[i].ID] = us.Status;
              $scope.studentGroups[self.currentClass.students[i].ID] = [self.currentClass.students[i].ID];            
              if(us.Status == "OK" || us.Status == "pw"){

                // group them
                if(us.ColleaguesIDs && us.ColleaguesIDs != ""){
                  var colleagues = us.ColleaguesIDs.split(",").map(Number);
                  colleagues.push(self.currentClass.students[i].ID);
                  colleagues.sort();
                  $scope.studentGroups[self.currentClass.students[i].ID] = colleagues;
                  // only show the group, if current student is first in studentGroups
                  if(colleagues.indexOf(self.user.ID) == -1)  $scope.hasStudents = true;
                }else{
                  if(self.currentClass.students[i].ID != self.user.ID) $scope.hasStudents = true;
                }
              }
            }            
          }
          $scope.refresh();
          refreshInterval = $interval($scope.refresh,1000);

          $scope.selectStudent = function(s){
            $scope.currentStudent = s;
            $scope.currentStudentStatus = self.getUserTaskStatus(it,s);
            $scope.refreshFeedback = false;
            $scope.currentStars = 0;
            $scope.currentReview = "";
            $scope.isRecording = false;
            $scope.currentTaskAnswer = '';

            //1010
            $timeout(function(){
              self.addDropHandler($scope, $scope.dialogElement, ["audio", "text"], false, true, $scope.addFeedbackFromFiles);
            });

            for(var i=0; i < self.users[self.user.ID].journal.length; i++){
              if(self.users[self.user.ID].journal[i].Type == "taskpeerfeedbacksend")
                if(self.users[self.user.ID].journal[i].DataJSON &&
                   self.users[self.user.ID].journal[i].DataJSON.taskid == it.ID){
                  if(self.users[self.user.ID].journal[i].DataJSON.Peer == s.ID){
                    // already send a feedback for this student, load data
                    $scope.currentStars = self.users[self.user.ID].journal[i].DataJSON.Stars;
                    $scope.currentReview = self.users[self.user.ID].journal[i].DataJSON.PeerFeedback;
                    $scope.refreshFeedback = true;

                    if($scope.currentReview.match(/.m4a$/)) {
                      $scope.currentTaskAnswer = $scope.currentReview;
                      $scope.isRecording = true;
                      self.addAudioRecorderScope($scope, null, true);
                    }
                    break;
                  }
                }
            }
          };

          $scope.unselectStudent = function(){
            $scope.currentStudent = null;
            //1010
            for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
              if(self.dropHandler[i].dialog == $scope.dialogElement) {
                self.dropHandler.splice(i, 1);
              }
            }
          };

          $scope.changeToRecording = function(notRecording){
            $scope.currentTaskAnswer = ""; // used for record scope
            self.addAudioRecorderScope($scope, null, true);
            $scope.isRecording = notRecording ? false : true;
            $scope.currentReview = '';
          }

          $scope.sendReview = function(ev){
            //self.api();
            if(!$scope.currentReview) $scope.currentReview = "";
            if(!$scope.currentStars) $scope.currentStars = 0;
              
            var saveNow = function(){
              self.track('sendTaskPeerFeedback',{ID:it.ID,student:$scope.currentStudent.ID,
                                   "feedback":$scope.currentReview,
                                   "stars":$scope.currentStars, 
                                   "classid":self.currentClass.ID});
              self.apiPost("ajax",{"action":"sendPeerFeedback", "ID":it.ID, 
                                   "student":$scope.currentStudent.ID,
                                   "feedback":$scope.currentReview, 
                                   "stars":$scope.currentStars, 
                                   "classid":self.currentClass.ID, 
                                   "refresh":$scope.refreshFeedback ? 1:0})
               .then(function(data) {
                 deferred.resolve();
                 self.keepAliveCallback();
                 self.closeDialog($scope.dialogElement);
               },function(data){
                 self.alert($filter('trans')('ERROROCCURRED',data.error));
               });
             };

            self.confirm($filter('trans')('PEERFEEDBACKREVIEWASKDONE'),$filter('trans')('PEERFEEDBACKREVIEWDONE'),ev).then(function(){
              // there needs to be an upload here first
              if($scope.isRecording){
                // upload audio now
                if($scope.audioURL.indexOf("blob:") == -1 &&
                   $scope.audioURL.indexOf("://learningview.org/") > 0){
                  $scope.currentReview = $scope.audioURL;
                  saveNow();
                }else
                  self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL,
                    $scope.audioFilename, self.getMediaID(),'record',null,function(filename){
                    $scope.currentReview = filename;
                    saveNow();
                  });
              } else
                saveNow();
            });
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.reject("cancel");
          };
        }
      });
      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getPredefinedTaskUserPartners = function(it, student){
      if(it.Groups && it.Groups != ''){
        var g = JSON.parse(it.Groups);
        var index = 0;
        if(g.groups){
          for(var i=0; i < g.groups.length; i++){
            var p = g.groups[i].indexOf(student ? student.ID : self.user.ID);
            if(p != -1){
              // found myself in this group, remove myself
              g.groups[i].splice(p,1);
              g.groups[i].index = i+1;
              return g.groups[i]; // do not ask in this case, just use the predefined group
            }
          }
        }
      }
      return false;
    };
    self.getPredefinedTaskUserPartnersGroupID = function(it, student){
      if(it.Groups && it.Groups != ''){
        var g = JSON.parse(it.Groups);
        if(g.groups){
          for(var i=0; i < g.groups.length; i++){
            var p = g.groups[i].indexOf(student ? student.ID : self.user.ID);
            if(p != -1){
              return i+1; 
            }
          }
        }
      }
      return 0;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.askTaskUserPartners = function(it, ev, current, user, noRestriction){
      var deferred = $q.defer();
      if(!current){
        var ts = self.getUserTaskStatus(it,self.user,true);
        current = ts.ColleaguesIDs;
      }
      if(!self.currentClass){
        deferred.resolve([]);
        return deferred.promise;
      }
      var studentCount = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        if(self.currentClass.students[i].ID == self.user.ID) continue;
        studentCount++;
      }
      if(studentCount == 0){
        deferred.resolve([]);
        return deferred.promise;
      }
      var groups = self.getPredefinedTaskUserPartners(it, user ? user : self.user);
      if(groups){
        deferred.resolve(groups);
        return deferred.promise; // do not ask in this case, just use the predefined group
      }

      self.track('openAskTaskPartners',it);
      self.showDialog({
        templateUrl: "askwhichpartners.html",
        skipHide:true, // keep other dialog open
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        onRemoving: function (event, removePromise) {
          self.track('closeAskTaskPartners',it);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = it;
          $scope.user = user ? user : self.user;
          $scope.students = [];
          $scope.noRestriction = noRestriction;
          for(var i=0; i < self.currentClass.students.length; i++)
            $scope.students.push({student:self.currentClass.students[i]});

          for(var i=0; i < $scope.students.length; i++){
            // mark those who cannot be selected
            var ts = self.getUserTaskStatus(it,$scope.students[i].student);
            $scope.students[i].currentStatus = ts;

            $scope.students[i].currentColleague = [];

            if(current && current != ""){
              $scope.students[i].currentColleagues = current.split(",").map(Number);
              $scope.students[i].currentColleague =
                $scope.students[i].currentColleagues.indexOf(self.user.ID);
            }
          }

          $scope.selected = [];
          var cn = current && current != "" ? current.split(',').map(Number) : [];
          for(var i=0; i < cn.length; i++){
            for(var z=0; z < $scope.students.length; z++)
              if($scope.students[z].student.ID == cn[i]) $scope.selected.push($scope.students[z]);
          }

          $scope.selectStudent = function(s){
            var ts = self.getUserTaskStatus(it,s.student);
            var p = [];
            if(current && current != "")
              p = current.split(",").map(Number);


            if(noRestriction || self.user.Teacher == 1 || !(p.indexOf(self.user.ID) == -1 && (ts.Status == "OK" || ts.Status == "?"))){
              $scope.selected.push(s);
            }else{
              // TODO: translate
              self.alert(s.student.Name + " hat die Aufgabe bereits erledigt und kann nicht gewählt werden.");
            }

          };

          $scope.save = function() {
            var partners = [];
            for(var i=0; i < $scope.selected.length; i++) partners.push($scope.selected[i].student.ID);

            self.closeDialog($scope.dialogElement);
            deferred.resolve(partners);
          };

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.reject("cancel");
          };
        }
      });

      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveTeacherTaskFeedbackStatusFindTask = function(t, student, status, ev){
      var id = 0;
      if(t.TaskID) id = t.TaskID; else
      if(t.taskid) id = t.taskid; else
      if(t.ID) id = t.ID; else
      return null;

      var t = self.getTaskByID(id);
      if(!t) return null;
      return self.saveTeacherTaskFeedbackStatus(t.task,student, status, ev);
    };
    self.saveTeacherTaskFeedbackStatus = function(t, user, status, ev){
      // only save FeedbackStatus
      var current = self.getUserTaskStatus(t,user);
      if(current && current.ColleaguesIDs) status.ColleaguesIDs = current.ColleaguesIDs;
      var partners = status.ColleaguesIDs && status.ColleaguesIDs != '' ? status.ColleaguesIDs.split(",").map(Number) : [];

      var saveNow = function(){
        var params = {"action":"saveTeacherTaskFeedbackStatus", "ID":t.ID, "user":user.ID,
                      "classid":self.currentClass.ID,
                      "status":status.FeedbackStatus, "partners":partners.join(",")};

        self.apiPost("ajax",params)
         .then(function(data) {
           if(partners.length > 0){
             for(var i=0; i < self.currentClass.students.length; i++){
               var s = self.currentClass.students[i];
               if(partners.indexOf(s.ID) >= 0){
                 var stat = self.getUserTaskStatus(t,s,true);
                 stat.FeedbackStatus = status.FeedbackStatus;
                 var others = partners.slice();
                 others.push(user.ID);
                 others.sort();
                 var p = others.indexOf(s.ID);
                 if(p != -1) others.splice(p,1);
                 stat.ColleaguesIDs = others.join(",");
               }
             }
           }

           var s = self.getUserTaskStatus(t,user,true);
           s.FeedbackStatus = status.FeedbackStatus;

           self.updateClassesStatus();

           self.keepAliveCallback();
         });
      };      

      saveNow();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveTeacherTaskStatusFindTask = function(t, student, status, ev){
      var id = 0;
      if(t.TaskID) id = t.TaskID; else
      if(t.taskid) id = t.taskid; else
      if(t.ID) id = t.ID; else
      return null;

      var t = self.getTaskByID(id);
      if(!t) return null;
      return self.saveTeacherTaskStatus(t.task,student, status, ev);
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveTeacherTaskStatus = function(t, user, status, ev, noKeepAlive){
      var deferred = $q.defer();
      var current = self.getUserTaskStatus(t,user);
      if(current && current.Feedback) status.Feedback = current.Feedback;
      if(current && current.ColleaguesIDs) status.ColleaguesIDs = current.ColleaguesIDs;
      var partners = status.ColleaguesIDs && status.ColleaguesIDs != '' ? status.ColleaguesIDs.split(",").map(Number): [];

      if(ev && ev.currentTarget && ev.currentTarget.nodeName == "BUTTON"){
        $(ev.currentTarget).addClass('saved');
        $timeout(function(){ $(ev.currentTarget).removeClass('saved'); },2000);
      }
/*
      var askForTrackTask = function(){
        var silent = false;
        // a task with self check is hand back, ask for track or not
        var overrideCheck = self.getUserTaskChecksDeep(t,user,self.currentClass);
        if(status.Status == "x" && t.CheckType != "teacher" && (overrideCheck != 2 && overrideCheck != 3)){
          // ask now 
          self.confirm('<div style="max-width:500px">'+$filter('trans')('ASKTRACKTASKREVOKED')+'</div>',
            $filter('trans')('YES'),ev,$filter('trans')('NO'),true).then(function(){ 
              saveNow(); 
            },function(){ 
              saveNow(true); 
            });                      
        }else
          saveNow(silent);
      };
*/
      var saveNow = function(){
        var params = {"action":"saveTeacherTaskStatus", "ID":t.ID, "user":user.ID,
                      "feedback":status.Feedback ? status.Feedback : "", "classid":self.currentClass.ID,
                      "status":status.Status, "partners":partners.join(",")};

        self.apiPost("ajax",params)
         .then(function(data) {
           if(partners.length > 0){
             for(var i=0; i < self.currentClass.students.length; i++){
               var s = self.currentClass.students[i];
               if(partners.indexOf(s.ID) >= 0){
                 var stat = self.getUserTaskStatus(t,s,true);
                 stat.Status = status.Status;
                 stat.Feedback = status.Feedback;
                 stat.FeedbackStatus = status.Status;
                 var others = partners.slice();
                 others.push(user.ID);
                 others.sort();
                 var p = others.indexOf(s.ID);
                 if(p != -1) others.splice(p,1);
                 stat.ColleaguesIDs = others.join(",");
                 if(status.Status == "") {
                   stat.Answer = "";
                   stat.FeedbackStatus = "";
                   stat.ColleaguesIDs = "";
                 }
               }
             }
           }

           var s = self.getUserTaskStatus(t,user,true);
           s.Status = status.Status;
           s.Feedback = status.Feedback;
           s.FeedbackStatus = status.Status;
           s.ColleaguesIDs = partners.join(",");
           if(status.Status == "") {
             s.Answer = "";
             s.FeedbackStatus = "";
             s.ColleaguesIDs = "";
           }

           self.updateClassesStatus();

           if(status.Status == "x"){
             // also add something to feedback if there is none yet
             //var lastFeedback = self.getLastTaskFeedback(t,user,null,true);
             //if(!lastFeedback || lastFeedback.User == user.ID) {
             self.apiPost("ajax",{"action":"addTaskStatusFeedback",
              "ID":t.ID,"user":user.ID,"classid":self.currentClass.ID, sys:1, 
              "message":'%%TASKREJECTED%%'}).then(function(data) {
                deferred.resolve();
                if(!noKeepAlive) self.keepAliveCallback();
             });
             //}
           } else{
             deferred.resolve();
             if(!noKeepAlive) self.keepAliveCallback();
           }

           // gallery case, auto go next, if not 
           if((status.Status == "OK" || status.Status == "x") && ev && ev.currentTarget){
            var sc = $(ev.currentTarget).scope();
            if(sc && sc.gallery && sc.gallery.length > 0 && !sc.isOpenResultButtonWindow){
              sc.fadeOutNow = true;
              $timeout(function(){
                if(sc.showNext){
                  // we can go next, do it now
                  sc.goNext(); 
                }else{
                  // no other user, close panel now
                  sc.cancel();
                }
                sc.fadeOutNow = false; 
              },750);
            }
            if(sc && sc.closeDialogAfterFeedback && !sc.isOpenResultButtonWindow){
              $timeout(function(){
                sc.cancel(); // close panel now
              },250);
            }
           }

         });
      };

      // clear / reset status
      if(status.Status == ""){
        var names = [];
        for(var i=0; i < partners.length; i++)
          for(var z=0; z < self.currentClass.students.length; z++)
            if(self.currentClass.students[z].ID == partners[i]) names.push(self.currentClass.students[z].Name);

        var d = $mdDialog.confirm()
          .title($filter('trans')('AREYOUSURE'))
          .content('Die Eingaben zu dieser Aufgabe werden gelöscht.')
          .targetEvent(ev)
          .cancel('abbrechen')
          .ok('zurücksetzen');
        d._options.skipHide = true; // keep other dialog open

        var d2 = $mdDialog.confirm()
          .title("Für ganze Gruppe zurücksetzen?")
          .content('Diese Aufgabe wurde mit '+names.join(", ")+' bearbeitet. Soll die Aufgabe für alle zurückgesetzt werden oder nur für '+user.Name+'?')
          .targetEvent(ev)
          .cancel('nur für '+user.Name)
          .ok('ganze Gruppe');
        d2._options.skipHide = true; // keep other dialog open

        function reset(kind){
          var action = {"action":"saveTeacherTaskStatus", "ID":t.ID,"feedback":status.Feedback ? status.Feedback : "",
            "user":user.ID, "status":"","answer":"", "classid":self.currentClass.ID};
          if(kind == "group" || kind == "self"){
            action.partners = status.ColleaguesIDs ? status.ColleaguesIDs : '';
            action.type = kind;
          }

          self.apiPost("ajax",action)
           .then(function(data) {
             status.Answer = "";
             status.Status = "";
             status.FeedbackStatus = "";
             status.ColleaguesIDs = "";
             deferred.resolve();
             if(!noKeepAlive) self.keepAliveCallback();
           });
        }

        function askGroup(){
          if((t.Social == 'pair' || t.Social == 'group') && names.length > 0)
            $mdDialog.show(d2).then(function(){ reset('group'); },
                                    function(){ reset('self'); }); else reset();
        }

        //if(status.Answer && status.Answer != "")
        if(status.skipAsk) 
          askGroup(); else
          $mdDialog.show(d).then(askGroup); // else askGroup();

      }else{
        if(!status.skipAsk && 
           (status.Status != null && status.Status != "" && status.Status != "x" && status.Status != "?" && status.Status != "w") &&
           (t.Social == 'pair' || t.Social == 'group') && (!status.ColleaguesIDs || status.ColleaguesIDs == "")){
          // select with whom we worked with
          var partners = self.getUserTaskStatusColleagues(t,user);
          self.askTaskUserPartners(t,ev,partners,user).then(function(selected){
            partners = selected;
            status.ColleaguesIDs = partners.join(",");
            saveNow();
          });
        }else
          saveNow();
      }
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getImageAnnotationData = function(user,url,taskid,history){
      var deferred = $q.defer();
      var p = {"action":"getImageAnnotation","user":user.ID, "url":url, "task":taskid};
      if(history) p.history = history;
      if(taskid) p.task = taskid;
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve(data.data);
       });
      return deferred.promise;
    };

    self.getImageAnnotationHistoryData = function(user,url,taskid){
      var deferred = $q.defer();
      var p = {"action":"getImageAnnotationHistory","user":user.ID, "url":url,"task":taskid};
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve(data.data);
       });
      return deferred.promise;
    };

    self.updateImageAnnotationData = function(user,url,taskid,json,width,height){
      var deferred = $q.defer();
      self.apiPost("ajax",{"action":"updateImageAnnotation", "user":user.ID, "noerror":1, "task":taskid, "url":url, "json":json,"width":width ? width : 0, "height":height ? height : 0})
       .then(function(data) {
         app.refreshAnnotationOverlays(url);            
         deferred.resolve();
       },function(error){
         self.alert("Fehler: Serververbindung fehlgeschlagen. Änderungen konnten nicht gespeichert werden.");
       });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getTaskImageAnnotationData = function(taskid,url){
      var deferred = $q.defer();
      var p = {"action":"getTaskImageAnnotation","ID":taskid, "url":url};
      self.apiPost("ajax",p)
       .then(function(data) {
         deferred.resolve(data.data);
       });
      return deferred.promise;
    };
