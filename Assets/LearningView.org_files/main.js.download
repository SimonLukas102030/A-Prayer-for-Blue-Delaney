            var value = self.getUserTaskChecks(it, c.students[i],c);
            $scope.values[c.students[i].ID] = value;
            var p = self.getUserLearningGoalChecks(g,c.students[i],c);
            if(!p)
              p = self.getUserTopicChecks(t,c.students[i],c);
            if(!p)
              p = self.getUserMainTopicChecks(mt,c.students[i],c);
            $scope.parentValues[c.students[i].ID] = p;             
