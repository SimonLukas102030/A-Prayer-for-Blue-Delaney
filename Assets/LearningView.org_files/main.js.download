                  }
                },1);
            });
          };
        }
    });

///////////////////////////////////////////////////////////////////////////////////////////////////
var app = null;
var user = null;
var preventNavigation = false;


(function(){

  app = angular.module('App',
    ['ngRoute', 'ngMaterial', 'ngMessages', 'ngCookies' ,'ui.sortable', 'angular-loading-bar', 'ngAnimate', 'monospaced.qrcode','ngWig','ErrorCatcher' ]);

/*
  app.config(['$compileProvider', function ($compileProvider) {
    $compileProvider.debugInfoEnabled(false);
    $compileProvider.commentDirectivesEnabled(false);
    $compileProvider.cssClassDirectivesEnabled(false);
  }]);
  app.config(function ($mdInkRippleProvider) {
    $mdInkRippleProvider.disableInkRipple();
  });
*/

  app.config(function ($mdInkRippleProvider) {
    $mdInkRippleProvider.disableInkRipple();
  });
  app.config(function ($mdGestureProvider) {
    if($mdGestureProvider && $mdGestureProvider.disableAll){
      $mdGestureProvider.disableAll();
    }
  });

  app.currentLanguage = "DE";

  app.translations = {};

  app.translations.DE = null;
  app.translations.EN = null;
  app.translations.FR = null;
  app.translations.IT = null;


  app.config(function($mdDateLocaleProvider) {
    $mdDateLocaleProvider.formatDate = function(date) {
       return date ? moment(date).format('DD.MM.YYYY') : '';
    };
    $mdDateLocaleProvider.firstDayOfWeek = 1;
    $mdDateLocaleProvider.months = ['Januar', 'Februar', 'März', 'April',
                                    'Mai', 'Juni', 'Juli', 'August', 'September',
                                    'Oktober', 'November','Dezember'];
    $mdDateLocaleProvider.shortMonths = ['Jan','Feb','Mrz','Apr','Mai','Jun','Jul',
                                         'Aug','Sep','Okt','Nov','Dez'];
    $mdDateLocaleProvider.shortMonths = $mdDateLocaleProvider.months;
    $mdDateLocaleProvider.days = ['Montag','Dienstag','Mittwoch','Donnerstag',
                                  'Freitag','Samstag','Sonntag'];
    $mdDateLocaleProvider.shortDays = ['So','Mo','Di','Mi','Do','Fr','Sa'];
  });

  app.config(function($mdThemingProvider){
    $mdThemingProvider.theme('default')
    //.backgroundPalette('grey', {
    //           'default': '200'
    //       })
    .primaryPalette('light-blue', {
     'default': '700', // by default use shade 500 from the pink palette for primary intentions
     'hue-1': '400', // use shade 100 for the <code>md-hue-1</code> class
     'hue-2': '800'  // use shade 700 for the <code>md-hue-2</code> class
    })
    .accentPalette('amber', {
     'default': 'A700', // by default use shade 500 from the pink palete for primary intentions
     'hue-1': 'A100', // use shade 100 for the <code>md-hue-1</code> class
     'hue-2': 'A200'  // use shade 700 for the <code>md-hue-2</code> class
    });
  });

  app.config(['$httpProvider',
    function($httpProvider) {
      $httpProvider.defaults.useXDomain = true;
      $httpProvider.defaults.withCredentials = true;
      delete $httpProvider.defaults.headers.common['X-Requested-With'];
    }
  ]);

  app.config(function($routeProvider, $locationProvider) {
    $routeProvider
    .when('/', {
      templateUrl: app.patchWKWebviewPath(store+'main.html?'+Math.random())
     }).otherwise({ redirectTo: '/' });

    $locationProvider.html5Mode(false);
  });

  app.directive('mdTooltip', function($timeout) {
    function isCoarsePointer() {
      return !!(
        window.matchMedia &&
        window.matchMedia('(pointer: coarse)').matches
      );
    }

    return {
      restrict: 'E',
      priority: 1, // do this first, before element gets detachted from DOM tree
      compile: function(tElement, tAttrs) {
        if (!isCoarsePointer()) return;

        return function(scope, element) {
          var triggers = [];

          var p1 = element.parent();
          if (p1 && p1.length) triggers.push(p1[0]);

          var p2 = p1 && p1.parent ? p1.parent() : null;
          if (p2 && p2.length) triggers.push(p2[0]);

          if (triggers.length == 0) return;

          function hideAllTooltips() {
            $timeout(function() {
              document.body.dispatchEvent(new Event('touchend', { bubbles: true }));
            }, 10, false);
          }

          triggers.forEach(function(el) {
            el.addEventListener('touchend', hideAllTooltips, true);
          });
          scope.$on('$destroy', function() {
            triggers.forEach(function(el) {
              el.removeEventListener('touchend', hideAllTooltips, true);
            });
          });          
        };
      }
    };
  });

  app.directive('onTouchStart', function() {
    return { restrict:'A', link: function(s, el, a) {
      el[0].addEventListener('touchstart', function(e) {
        s.$apply(function() { s.$eval(a.onTouchStart, {$event:e}); });
      }, {passive:false});
    }};
  });
  app.directive('onTouchMove', function() {
    return { restrict:'A', link: function(s, el, a) {
      el[0].addEventListener('touchmove', function(e) {
        s.$apply(function() { s.$eval(a.onTouchMove, {$event:e}); });
      }, {passive:false});
    }};
  });
  app.directive('onTouchEnd', function() {
    return { restrict:'A', link: function(s, el, a) {
      el[0].addEventListener('touchend', function(e) {
        s.$apply(function() { s.$eval(a.onTouchEnd, {$event:e}); });
      }, {passive:false});
    }};
  });

  app.directive('textContextMenu', function ($timeout) {
    return {
      restrict: 'A',
      link: function (scope, element, attrs) {
        var el = element[0];
        var touchStartTime;
        var touchMoved = false;
        var longPressThreshold = 400;
        var hadSelectionOnTouchStart = false;
        var wasHandled = false;
        
        function hasSelection() {
          var sel = window.getSelection && window.getSelection();
          return sel && sel.toString().length > 0;
        }
        
        function handleTouchStart(ev) {
          touchStartTime = Date.now();
          touchMoved = false;
          hadSelectionOnTouchStart = hasSelection();
          wasHandled = false;
        }
        
        function handleTouchMove(ev) {
          touchMoved = true;
        }
        
        function handleTouchEnd(ev) {
          // If there was a selection when touch started, skip menu logic
          if (hadSelectionOnTouchStart) {
            return;
          }
          if(ev.target && ev.target.nodeName == 'VIDEO') return; // no context-menu on video touch-end
          
          var touchDuration = Date.now() - touchStartTime;
          
          // If user moved finger, likely trying to select
          if (touchMoved) {
            return;
          }
          
          // Quick tap - open menu immediately
          if (touchDuration < longPressThreshold) {
            if (!hasSelection()) {
              scope.$applyAsync(function () {
                scope.$eval(attrs.textContextMenu, {$event: ev});
              });
              wasHandled = true; 
            }
            return;
          }
          
          // Long press - wait a bit to see if selection appears
          $timeout(function () {
            if (!hasSelection()) {
              scope.$eval(attrs.textContextMenu, {$event: ev});
            }
          }, 150);
        }
        
        function handleClick(ev) {
          // Don't open menu if there's a text selection
          if(ev.target && ev.target.nodeName == 'VIDEO') return; // no context-menu on video touch-end
          if (!hasSelection() && !wasHandled) {
            scope.$applyAsync(function () {
              scope.$eval(attrs.textContextMenu, {$event: ev});
            });
          }
        }
        
        function handleContextMenu(ev) {
          // Always allow contextmenu if there's a selection
          if (hasSelection()) {
            return; // Let iOS show its menu
          }
          // Prevent default iOS context menu when no selection
          ev.preventDefault();
        }
        
        if (window.isIPad) {
          // Handle touch events
          el.addEventListener('touchstart', handleTouchStart, {passive: true});
          el.addEventListener('touchmove', handleTouchMove, {passive: true});
          el.addEventListener('touchend', handleTouchEnd, {passive: true});
          
          // Also handle mouse clicks (trackpad/mouse on iOS)
          el.addEventListener('click', handleClick);
          
          el.addEventListener('contextmenu', handleContextMenu);
        } else {
          el.addEventListener('click', handleClick);
        }
        
        // Cleanup
        scope.$on('$destroy', function () {
          if (window.isIPad) {
            el.removeEventListener('touchstart', handleTouchStart);
            el.removeEventListener('touchmove', handleTouchMove);
            el.removeEventListener('touchend', handleTouchEnd);
            el.removeEventListener('click', handleClick);
            el.removeEventListener('contextmenu', handleContextMenu);
          } else {
            el.removeEventListener('click', handleClick);
          }
        });
      }
    };
  });

  app.directive('safeIframe', ['$sce', function($sce) {
    return {
      restrict: 'A',
      scope: {
        content: '=safeIframe',
        baseUrl: '=?safeIframeBaseUrl'
      },
      link: function(scope, element) {
        var sandboxTokens = [
          'allow-downloads',
          'allow-forms',
          'allow-modals',
          'allow-orientation-lock',
          'allow-pointer-lock',
          'allow-popups',
          'allow-popups-to-escape-sandbox',
          'allow-presentation',
          'allow-scripts',
          'allow-storage-access-by-user-activation',
          'allow-top-navigation',
          'allow-top-navigation-by-user-activation',
          'allow-top-navigation-to-custom-protocols'
        ];
        element.attr('sandbox', sandboxTokens.join(' '));

        var currentObjectUrl = null;
        var revokeCurrentObjectUrl = function(){
          if(currentObjectUrl){
            URL.revokeObjectURL(currentObjectUrl);
            currentObjectUrl = null;
          }
        };

        var applyBaseHref = function(html, baseUrl){
          if(!baseUrl) return html;
          if(/<base\b/i.test(html)) return html;
          var baseTag = '<base href="'+$('<div></div>').text(baseUrl).html()+'">';
          if(/<head\b[^>]*>/i.test(html)){
            return html.replace(/<head\b[^>]*>/i,function(match){
              return match + baseTag;
            });
          }
          if(/<html\b[^>]*>/i.test(html)){
            return html.replace(/<html\b[^>]*>/i,function(match){
              return match + '<head>' + baseTag + '</head>';
            });
          }
          return '<head>' + baseTag + '</head>' + html;
        };
        scope.$watch('content', function(newContent) {
          if (newContent) {
            revokeCurrentObjectUrl();
            var htmlToLoad = applyBaseHref(newContent, scope.baseUrl);
            var blob = new Blob([htmlToLoad], { 
                type: 'text/html; charset=utf-8' 
            });
            currentObjectUrl = URL.createObjectURL(blob);
            element.attr('src', currentObjectUrl);
          }
        });
        element.on('load', revokeCurrentObjectUrl);
        scope.$on('$destroy', revokeCurrentObjectUrl);
      }
    };
  }]);

