    self.setTaskImportantInClass = function(task,ev){
      // display a select dialog with all students to select all or some and the current important status

      if(task.Important == '1'){
        self.alert($filter('trans')('TASKISPINNEDTASKHINT'));
        return;
      }
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classTaskImportantSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.t = task;
          $scope.c = self.currentClass;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.required = [];
          $scope.smallScreen = self.isSmallScreen;

          for(var i=0; i < self.currentClass.students.length; i++){
            /* maybe resprect student filter here too?
            if(self.currentClassResultStudentFilter &&
               self.currentClassResultStudentFilter.length > 0){
              // filter is used, skip not in list
              if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) == -1) {
                $scope.disabled.push(self.currentClass.students[i].ID);
                continue;
              }
            }
            */
            var r = self.findTaskInClass(self.currentClass,task.ID,self.currentClass.students[i]);
            if(!r){
              $scope.disabled.push(self.currentClass.students[i].ID);
              continue;
            }else{
              //$scope.selection.push(self.currentClass.students[i].ID);
              var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
              if(status.Important == "1") {
                $scope.selection.push(self.currentClass.students[i].ID);
              }
            }
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // apply $scope.selection
            // leave disabled unchanged
            for(var i=0; i < $scope.disabled.length; i++){
              var status = self.getUserTaskStatus(task,{ID:$scope.disabled[i]},true);
              if(status.Important == "1") $scope.selection.push($scope.disabled[i]);
            }
            self.apiPost("ajax",{"action":"updateTaskImportantForClass",
                "classid":self.currentClass.ID, "students":$scope.selection.join(","), "ID":task.ID})
             .then(function(data) {
               self.keepAliveCallback().then(function(){
                /*
                 for(var i=0; i < $scope.selection.length; i++){
                   var status = self.getUserTaskStatus(task,{ID:$scope.selection[i]},true);
                   if(status.Status == "OK" && status.Important == "1"){
                     // task was already completed by student, we have to set it back to "?"
                     self.apiPost("ajax",{"action":"saveTeacherTaskStatus", "ID":task.ID, "user":$scope.selection[i], "classid":self.currentClass.ID, "status":"?"});
                   }
                 }
                 */
               })
             });

            self.closeDialog($scope.dialogElement);
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.setTasksImportantInClass = function(tasks,ev){
      // display a select dialog with all students to select all or some and the current important status
      var tasksFiltered = [];
      for(var i=0; i < tasks.length; i++){
        if(tasks[i].Important != '1'){
          tasksFiltered.push(tasks[i]);
        }
      }

      if(tasks.length > tasksFiltered.length && tasksFiltered.length == 0){
        self.alert($filter('trans')('TASKISPINNEDTASKHINT'));
        return;
      }
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classTaskImportantSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.t = {};
          $scope.c = self.currentClass;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.required = [];
          $scope.smallScreen = self.isSmallScreen;

          for(var i=0; i < self.currentClass.students.length; i++){
            var isAllSet = true;
            for(var t=0; t < tasksFiltered.length; t++){
              var task = tasksFiltered[t];
              //$scope.selection.push(self.currentClass.students[i].ID);
              var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
              isAllSet = isAllSet && status.Important == "1";
            }
            if(isAllSet) {
              $scope.selection.push(self.currentClass.students[i].ID);
            }
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // apply $scope.selection
            var done = 0;
            for(var t=0; t < tasksFiltered.length; t++){
              var task = tasksFiltered[t];
              done++;
              self.apiPost("ajax",{"action":"updateTaskImportantForClass",
                  "classid":self.currentClass.ID, "students":$scope.selection.join(","), "ID":task.ID})
               .then(function(data) {
                 done--;
                 if(done == 0)
                   self.keepAliveCallback();
               });
            }
            self.closeDialog($scope.dialogElement);
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };    
