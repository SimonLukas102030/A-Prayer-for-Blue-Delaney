      }

      self.showDialog({
        templateUrl: "classContentChecks.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = cc ? cc : self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.it = tasks[0];
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.values = {};
          $scope.parentValues = {};

          for(var i=0; i < c.students.length; i++){
            var it = tasks[0];
            var value = self.getUserTaskChecks(it, c.students[i],c);
            $scope.values[c.students[i].ID] = value;
            $scope.parentValues[c.students[i].ID] = 0;             
          }

          self.addContentChecksScope($scope);

          $scope.save = function() {
            // maybe currentClass has changed already, use current variable for sure
            var c = cc ? cc : self.currentClass;
            for(var t = 0; t < tasks.length; t++){
              self.updateUserTaskChecks(tasks[t],c,$scope.values);
            }
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.showClassTaskGroups = function(it,ev){
      var mt,t,g;
      var find = self.getTaskByID(it.ID);
      if(find && find.mainTopic){
        mt = find.mainTopic;
        t = find.topic;
        g = find.goal;
      }else{
        return;
      }

      self.showDialog({
        templateUrl: "classTaskGroups.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.it = it;
          $scope.students = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.task = it; // for status display
          $scope.setting = {};

          if(!self.toolCurrentSelectedStudents){
            self.toolCurrentSelectedStudents = [];
            if(self.currentClassResultStudentFilter &&
               self.currentClassResultStudentFilter.length > 0){
              classFilterUsed = true;
              for(var i=0; i < self.currentClass.students.length; i++){
                if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) >= 0)
                self.toolCurrentSelectedStudents.push(self.currentClass.students[i]);
              }
            }else{
              for(var i=0; i < self.currentClass.students.length; i++){
                self.toolCurrentSelectedStudents.push(self.currentClass.students[i]);
              }
            }
          }

          if(!g)
          for(var i=0; i < t.goals.length; i++){
            if(t.goals[i].ID == it.LearningGoal){
              g = t.goals[i];
            }
          }
          if(!g) return; // error case, parent goal not found

          $scope.isStudentDisabled = function(s){
            return !self.isUserMainTopicVisible(mt, s,c,true) ||
                   !self.isUserTopicVisible(t, s,c,true) ||
                   !self.isUserLearningGoalVisible(g, s,c,true) ||
                   !self.isUserTaskVisible(it, s,c,true);
          };

          $scope.students = [];
          for(var i=0; i < self.toolCurrentSelectedStudents.length; i++){
            var disabled = $scope.isStudentDisabled(self.toolCurrentSelectedStudents[i]);
            if(!disabled) $scope.students.push(self.toolCurrentSelectedStudents[i].ID);
          }
          // was still invisible for whole class, we use all students
          if($scope.students.length == 0){
            for(var i=0; i < self.toolCurrentSelectedStudents.length; i++){
              $scope.students.push(self.toolCurrentSelectedStudents[i].ID);
            }
          }

          $scope.setting.n = 2;
          $scope.setting.mode = 1;

          $scope.setMode = function(m){
            if(m == $scope.setting.mode) return;
            $scope.setting.mode = m;
            $scope.refresh();
          };

          $scope.loadGroup = function(data){
            if(data && data.groups){
              $scope.students = [];

              $scope.groups = JSON.parse(angular.toJson(data)); // make copy here
              $scope.setting.n = $scope.groups.n;
              $scope.oldGroups = $scope.groups && $scope.groups.old ? $scope.groups.old : null;

              // filter out students no longer in $scope.students
              var gs = $scope.groups.groups;
              for(var i = 0; i < gs.length; i++){
                var g = [];
                for(var z = 0; z < gs[i].length; z++){
                  var sid = gs[i][z];
                  for(var s=0; s < self.currentClass.students.length; s++){
                    if(self.currentClass.students[s].ID == sid){
                      $scope.students.push(self.currentClass.students[s].ID);
                      g.push(sid);
                      break;
                    }
                  }
                }
                gs[i] = g;
              }
              $scope.startSelect = false;
            }
          };

          $scope.groups = {"groups":[]};
          if(it.Groups && it.Groups != '') $scope.loadGroup(JSON.parse(it.Groups));

          $scope.showSelectGroupingStudents = function(ev){
            var selectedNow = $scope.students.slice(0);
            var disabledNow = [];
            for(var i=0; i < self.currentClass.students.length; i++){
              if($scope.isStudentDisabled(self.currentClass.students[i])){
                disabledNow.push(self.currentClass.students[i].ID);                
              }
            }

            self.showClassResultStudentFilter(ev,selectedNow,$filter('trans')('SAVE'),disabledNow).then(function(selection){
              var selectedNow = $scope.students.slice(0);
              $scope.students = [];
              for(var i=0; i < self.currentClass.students.length; i++){
                if(selection.indexOf(self.currentClass.students[i].ID) != -1)
                  $scope.students.push(self.currentClass.students[i].ID);
              }
              //$scope.setStudents();
              var selectedNew = $scope.students.slice(0);

              if($scope.groups.groups.length > 0){
                for(var i=0; i < selectedNow.length; i++){
                  var stillHere = false;
                  for(var z=0; z < selectedNew.length; z++){
                    if(selectedNow[i] == selectedNew[z]) {
                      stillHere = true;
                      break;
                    }
                  }
                  if(!stillHere){
                    // remove student now
                    for(var z=0; z < $scope.groups.groups.length; z++){
                      var p = $scope.groups.groups[z].indexOf(selectedNow[i]);
                      if(p != -1) $scope.groups.groups[z].splice(p,1);
                    }
                  }
                }
                for(var i=0; i < selectedNew.length; i++){
                  var isNew = true;
                  for(var z=0; z < selectedNow.length; z++){
                    if(selectedNew[i] == selectedNow[z]) {
                      isNew = false;
                      break;
                    }
                  }
                  if(isNew){
                    $scope.groups.groups[0].push(selectedNew[i]);
                  }
                }
                for(var i=0; i < $scope.groups.groups.length; i++){
                  if($scope.groups.groups[i].length == 0) {
                    $scope.groups.groups.splice(i,1);
                    i--;
                  }
                }
              }else
                $scope.refresh();
            });
          };

          $scope.saveGroups = function(ev){
            self.prompt($filter('trans')('TOOLSSAVEGROUP'),$filter('trans')('SAVE'),$filter('trans')('NAME'),"",ev).then(function(name){
              if($.trim(name) == "") return;
              if(!self.classToolSettings) self.classToolSettings = {};
              if(!self.classToolSettings[self.currentClass.ID])
                  self.classToolSettings[self.currentClass.ID] = {};
              if(!self.classToolSettings[self.currentClass.ID].groups)
                  self.classToolSettings[self.currentClass.ID].groups = [];

              for(var i=0; i < $scope.groups.groups.length; i++){
                // remove empty groups
                if($scope.groups.groups[i].length == 0) {
                  $scope.groups.groups.splice(i,1);
                  i--;
                  continue;
                }
              }

              var s = {groups:$scope.groups.groups,name:name,n:$scope.setting.n, 
                       ID:1, old:$scope.oldGroups ? $scope.oldGroups : null};
              for(var i=0; i < self.classToolSettings[self.currentClass.ID].groups.length; i++){
                var g = self.classToolSettings[self.currentClass.ID].groups[i];
                if(g.name == s.name){
                  self.classToolSettings[self.currentClass.ID].groups.splice(i,1);
                  i--;
                }
                s.ID = Math.max(g.ID+1,s.ID);
              }
              self.classToolSettings[self.currentClass.ID].groups.push(s);
              self.classToolSettings[self.currentClass.ID].groups.sort(function(a,b){
                return a.name.localeCompare(b.name);
              });
              self.sendClassToolSettings(self.currentClass.ID);
            });
          };


          $scope.hasDoubleName = function(s){
            for(var i=0; i < $scope.students.length; i++){
              if($scope.students[i] == s.ID) continue;
              if(self.users[$scope.students[i]] && self.users[$scope.students[i]].Name == s.Name) return true;
            }
            return false;
          };

          $scope.setGroupsOfSize = function(n){
            $scope.setting.n = n;
            var leftStudents = $scope.students.length % n;
            if(leftStudents > n/2) $scope.setting.mode = 1; else $scope.setting.mode = 2;
            $scope.startSelect = false;
            $scope.refresh();
          };
          $scope.setNGroups = function(n){
            $scope.setting.n = -n;
            $scope.setting.mode = 1; 
            $scope.startSelect = false;
            $scope.refresh();
          }
          

          $scope.refresh = function() {
            if($scope.oldGroups){
              // refresh but keep old groups, recreate old groups and puzzle again
              $scope.groups.groups = [];
              for(var i=0; i < $scope.oldGroups.length; i++){
                var g = $scope.oldGroups[i].g;
                var s = null;
                if(!$scope.groups.groups[g]) $scope.groups.groups[g] = [];
                for(var z=0; z < $scope.students.length; z++)
                  if($scope.students[z] == $scope.oldGroups[i].s){
                    s = $scope.students[z];
                    break;
                  }
                if(s){
                  $scope.groups.groups[g].push(s);
                }
              }              
              $scope.regroupPuzzle();
              return;
            }
            var students = [];
            for(var i=0; i < $scope.students.length; i++){
              students.push($scope.students[i]);
            }

            $scope.groups.groups = [];
            students = shuffleArray(students);

            var g = 0;

            var groupcount = $scope.setting.n < 0 ? Math.abs($scope.setting.n) : ($scope.setting.mode == 1 ? Math.ceil($scope.students.length / $scope.setting.n) : Math.floor($scope.students.length / $scope.setting.n));

            for (var i=0; i < groupcount; i++) $scope.groups.groups.push([]);
            while(students.length > 0){
              var s = students.pop();
              $scope.groups.groups[g].push(s);
              g++;
              if(g > $scope.groups.groups.length - 1) g = 0;
            }

            for(var i=0; i < $scope.groups.groups.length; i++){
              if($scope.groups.groups[i].length == 0) {
                $scope.groups.groups.splice(i,1);
                i--;
              }
            }
            for(var i=0; i < $scope.groups.groups.length; i++){
              $scope.groups.groups[i].sort(function(a,b){
                return self.users[a].Name.localeCompare(self.users[b].Name);
              });
            }

            //$scope.setting.n = $scope.groups.groups.length;
            $scope.groups.n = $scope.setting.n;
          };

          $scope.regroupPuzzle = function(){
            for(var i=0; i < $scope.groups.groups.length; i++){
              // remove empty groups
              if($scope.groups.groups[i].length == 0) {
                $scope.groups.groups.splice(i,1);
                i--;
                continue;
              }
            }
            if($scope.groups.groups.length == 0) return;
            $scope.autoSave();
            var newGroups = [];
            $scope.oldGroups = [];
            var n = Math.floor($scope.students.length / $scope.groups.groups.length);
            for(var i=0; i < n; i++){
              newGroups[i] = []; // we need so many groups
            }

            for(var i=0; i < $scope.groups.groups.length; i++){
              // remove empty groups
              if($scope.groups.groups[i].length == 0) {
                $scope.groups.groups.splice(i,1);
                i--;
                continue;
              }
              var notYetUsed = [];
              for(var z=0; z < n; z++) notYetUsed.push(z);
              for(var z=0; z < $scope.groups.groups[i].length; z++){
                var r = Math.floor(Math.random()*notYetUsed.length);
                newGroups[notYetUsed[r]].push($scope.groups.groups[i][z]);
                notYetUsed.splice(r,1); // remove it
                $scope.oldGroups.push({s:$scope.groups.groups[i][z],g:i});
                if(notYetUsed.length == 0){
                  // refill array to choose from
                  for(var x=0; x < n; x++) notYetUsed.push(x);
                }
              }
            }

            $scope.groups.groups = newGroups;

            for(var i=0; i < $scope.groups.groups.length; i++){
              $scope.groups.groups[i].sort(function(a,b){
                return self.users[a].Name.localeCompare(self.users[b].Name);
              });
            }

            $scope.setting.n = $scope.groups.groups.length;
          };

          $scope.getBackColor = function(s,index,dark){
            if(!s && $scope.oldGroups){
              return "#666"; // is a puzzle group already
            }
            if(s && $scope.oldGroups){
              for(var i=0; i < $scope.oldGroups.length; i++)
                if($scope.oldGroups[i].s == s) 
                  return dark ? self.getFolderColorDark(self.folderColors[$scope.oldGroups[i].g+1]) : self.folderColors[$scope.oldGroups[i].g+1];
            }else{
              return dark ? self.getFolderColorDark(self.folderColors[index+1]) : self.folderColors[index+1];
            }
          };

          $scope.save = function() {
            /* 
              Will use same structure as class tools groups
                {"groups":[["347","341","9","2"],
                          ["333194","359","152","360"],
                          ["348","8","13","346"],
                          ["146","145","10","343"],
                          ["342","344","340","349","345"]],
                "name":"P1","n":-4,"ID":3}
            */
            self.updateClassTaskGroups(it,self.currentClass,$scope.groups);
            self.closeDialog($scope.dialogElement);
          };
          $scope.reset = function() {
            self.updateClassTaskGroups(it,self.currentClass,null);
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };

          if(!it.Groups) {
            $scope.startSelect = true;
            if($scope.task.Social == 'pair'){
              $scope.setGroupsOfSize(2);
            }
          }
          //  $scope.refresh();

        }
      });
    };

    // visibility for class content
    self.updateUserMainTopicVisibility = function(it,c,hiddenFor){
      self.apiPost("ajax",{"action":"setClassesUserMainTopicVisibility","ID":it.ID, "classid":c.ID, "hidden":hiddenFor.join(",")}).then(self.keepAliveCallback);
    };
    self.updateUserTopicVisibility = function(it,c,hiddenFor){
      self.apiPost("ajax",{"action":"setClassesUserTopicVisibility","ID":it.ID, "classid":c.ID, "hidden":hiddenFor.join(",")}).then(self.keepAliveCallback);
    };
    self.updateUserLearningGoalVisibility = function(it,c,hiddenFor){
      self.apiPost("ajax",{"action":"setClassesUserLearningGoalVisibility","ID":it.ID, "classid":c.ID, "hidden":hiddenFor.join(",")}).then(self.keepAliveCallback);
    };
    self.updateUserTaskVisibility = function(it,c,hiddenFor){
      self.apiPost("ajax",{"action":"setClassesUserTaskVisibility","ID":it.ID, "classid":c.ID, "hidden":hiddenFor.join(",")}).then(self.keepAliveCallback);
    };

    // override checks for class content
    self.updateUserMainTopicChecks = function(it,c,values){
      self.apiPost("ajax",{"action":"setClassesUserMainTopicChecks","ID":it.ID, "classid":c.ID, "values":angular.toJson(values)}).then(self.keepAliveCallback);
    };
    self.updateUserTopicChecks = function(it,c,values){
      self.apiPost("ajax",{"action":"setClassesUserTopicChecks","ID":it.ID, "classid":c.ID, "values":angular.toJson(values)}).then(self.keepAliveCallback);
    };
    self.updateUserLearningGoalChecks = function(it,c,values){
      self.apiPost("ajax",{"action":"setClassesUserLearningGoalChecks","ID":it.ID, "classid":c.ID, "values":angular.toJson(values)}).then(self.keepAliveCallback);
    };
    self.updateUserTaskChecks = function(it,c,values){
      self.apiPost("ajax",{"action":"setClassesUserTaskChecks","ID":it.ID, "classid":c.ID, "values":angular.toJson(values)}).then(self.keepAliveCallback);
    };    

    self.updateUserTaskCheck = function(it,cc,student,value){
      var c = cc ? cc : self.currentClass;
      var values = [];
      for(var i=0; i < c.students.length; i++){
        var v = self.getUserTaskChecks(it, c.students[i],c);
        values[c.students[i].ID] = v;
        if(c.students[i].ID == student.ID) values[c.students[i].ID] = value;
      }
      self.updateUserTaskChecks(it,c,values);
    }

    // times for class content
    // set 0 to NULL value
    self.updateClassMainTopicTimes = function(it,c,vFrom,vTo){
      self.apiPost("ajax",{"action":"setClassesMainTopicTimes","ID":it.ID, "classid":c.ID, "vFrom":vFrom, "vTo":vTo}).then(function(){
        it.vFrom = vFrom;
        it.vTo = vTo;
        self.lastFromTime = vFrom || self.lastFromTime;
        self.lastToTime = vTo || self.lastToTime;
      }).then(self.keepAliveCallback);
    };
    self.updateClassTopicTimes = function(it,c,vFrom,vTo){
      self.apiPost("ajax",{"action":"setClassesTopicTimes","ID":it.ID, "classid":c.ID, "vFrom":vFrom, "vTo":vTo}).then(function(){
        it.vFrom = vFrom;
        it.vTo = vTo;
        self.lastFromTime = vFrom || self.lastFromTime;
        self.lastToTime = vTo || self.lastToTime;
      }).then(self.keepAliveCallback);
    };
    self.updateClassLearningGoalTimes = function(it,c,vFrom,vTo){
      self.apiPost("ajax",{"action":"setClassesLearningGoalTimes","ID":it.ID, "classid":c.ID, "vFrom":vFrom, "vTo":vTo}).then(function(){
