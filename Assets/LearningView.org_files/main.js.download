    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.setTasksNotesInClass = function(tasks,ev){
      if(tasks.length == 0) return;
      self.showDialog({
        templateUrl: "classTaskNoteSelection.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.c = c;
          $scope.it = tasks.length > 1 ? null : tasks[0];
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
/*
          for(var i=0; i < c.students.length; i++){
            $scope.selection.push(c.students[i].ID);
          }
*/
          self.addContentVisibilityScope($scope);

          $scope.hasNotesSelected = function(){
            var noteCount = 0;
            for(var z=0; z < $scope.selection.length; z++){
              for(var i=0; i < tasks.length; i++){
                var status = self.getUserTaskStatus(tasks[i],{ID:$scope.selection[z]});
                if(status.Note && status.Note != '') noteCount++;
              }
            }
            return noteCount;
          };

          $scope.removeNotes = function(){
            var noteCount = $scope.hasNotesSelected();
            self.confirm(noteCount+ " "+$filter('trans')('ASKDELETETASKNOTE'),$filter('trans')('DELETE')).then(function(){
              var count = 0;
              for(var z=0; z < $scope.selection.length; z++){
                for(var i=0; i < tasks.length; i++){
                  var ts = self.getUserTaskStatus(tasks[i],$scope.selection[z],true);
                  ts.Note = "";
                  count++;
                  self.apiPost("ajax",{"action":"updateTaskNote", "student":$scope.selection[z], "ID":tasks[i].ID, "Note":"", "classid":self.currentClass.ID})
                   .then(function(data) {
                      count--;
                      if(count == 0) {
                        // clear selection
                        $scope.selection = [];
                        self.keepAliveCallback();
                      }
                   });
                }
              }
            });
          };

          $scope.save = function(ev) {
            var parent = $scope;
            self.closeDialog($scope.dialogElement);

            self.showDialog({
              templateUrl: "edittasknote.html",
              targetEvent: ev,
              skipHide:true, // keep other dialog open

              clickOutsideToClose: false,
              escapeToClose: false,
              controller: function ($scope, $mdDialog) {
                $scope.self = self;
                $scope.user = user;
                // it is defined as {ID:a.ID, Note:userStatus.Note, ref:userStatus}
                $scope.task = {ID:tasks[0].ID, Icon: "", Note:""}; // make copy here
                $scope.type = self.lastEditTaskNoteType;

                $scope.save = function() {

                  var content = "";
                  if($scope.type == 'text') content = $scope.task.Note;
                  if($scope.type == 'icon') content = $scope.task.Icon != "" ? '<i class="'+$scope.task.Icon+'"></i>' : '';

                  self.lastEditTaskNoteType = $scope.type;
                  var count = 0;
                  var done = 0;
                  for(var t=0; t < tasks.length; t++){
                    var task = tasks[t];
                    done++;

                    for(var i = 0; i < parent.selection.length; i++){
                      var ts = self.getUserTaskStatus(task,parent.selection[i],true);
                      ts.Note = content;
                      count++;
                      self.apiPost("ajax",{"action":"updateTaskNote", "student":parent.selection[i], "ID":task.ID, "Note":(content != "" && self.user.Teacher == 1 ? '¶':'')+ content, "classid":self.currentClass.ID})
                       .then(function(data) {
                         count--;
                         if(count == 0) {
                           self.keepAliveCallback();
                           done--;
                           if(done == 0){

                           }
                         }
                       });
                    }
                  }
                  self.closeDialog($scope.dialogElement);
                };

                $scope.selectIcon = function(icon){
                  $scope.task.Icon = icon == $scope.task.Icon ? '' : icon;
                };

                $scope.cancel = function() {
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    }

    self.toggleUserTaskNote = function(student, task, c){      
      var ts = self.getUserTaskStatus(task,student,true);
      if(ts.Note && ts.Note != ""){
        self.confirm($filter('trans')('ASKDELETETASKNOTE'),$filter('trans')('DELETE')).then(function(){
          self.apiPost("ajax",{"action":"updateTaskNote", "student":student.ID, "ID":task.ID, "Note":"", "classid":self.currentClass.ID})
           .then(function(data) {
             ts.Note = content;
           });        
         });
      }else{
        self.editTaskNote({ID:task.ID, Note:ts.Note, ref:ts},student);
      }
    };

    self.addTaskNoteInClass = function(task,ev){
      // add a sticker to the whole class and inform teacher if there are already stickers
      var current = self.getClassTaskNoteMostUsed(task);
      var startDialog = function(){

        self.showDialog({
          templateUrl: "edittasknote.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.forClass = self.currentClass;
            $scope.task = {ID:task.ID, Icon: "", Note:""}; // make copy here
            $scope.type = self.lastEditTaskNoteType;
            if(current && current != ""){
              if(current.indexOf('<i class=') != -1){
                $scope.task.Icon = current.replace(/<i class="([^"]+)"><\/i>/,"$1");
                $scope.type = "icon";
              }else{
                $scope.task.Note = current;
                $scope.type = "text";
              }
            }

            $scope.selectedNow = [];
            for(var i=0; i < self.currentClass.students.length; i++)
              $scope.selectedNow.push(self.currentClass.students[i].ID);

            $scope.selectStudents = function(ev){
              self.showClassResultStudentFilter(ev,$scope.selectedNow).then(function(selection){
                $scope.selectedNow = selection;
              });
            };

            $scope.save = function() {
              var content = "";
              if($scope.type == 'text') content = $scope.task.Note;
              if($scope.type == 'icon') content = $scope.task.Icon != "" ? '<i class="'+$scope.task.Icon+'"></i>' : '';
              var allStudents = [];
              for(var i=0; i < self.currentClass.students.length; i++){
                if($scope.selectedNow.indexOf(self.currentClass.students[i].ID) == -1) continue;
                var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
                if(status.Note == content) continue; // skip existing ones
                allStudents.push(self.currentClass.students[i].ID);
              }
              self.apiPost("ajax",{"action":"updateTaskNoteForClass", "classid":self.currentClass.ID, "students":allStudents.join(","), "ID":$scope.task.ID, "Note":(content != "" ? '¶':'')+content})
               .then(function(data) {
                 self.lastEditTaskNoteType = $scope.type;
                 for(var i=0; i < self.currentClass.students.length; i++){
                   if($scope.selectedNow.indexOf(self.currentClass.students[i].ID) == -1) continue;
                   var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
                   status.Note = content;
                 }
                 self.closeDialog($scope.dialogElement);
               });
            };

            $scope.selectIcon = function(icon){
              $scope.task.Icon = icon == $scope.task.Icon ? '' : icon;
            };

            $scope.cancel = function() {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };

      var count = 0;
      var who = [];
      for(var i=0; i < self.currentClass.students.length; i++){
        //$scope.selection.push(self.currentClass.students[i].ID);
        var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
        if(status.Note && status.Note != "" && (!current || current == "" || status.Note != current)) {
          count++;
          who.push(self.currentClass.students[i].Name);
        }
      }

      if(count > 0)
        self.confirm($filter('trans')('ASKTASKNOTEOVERWRITECLASS',count < 6 ? who.join(", "): count),$filter('trans')('OVERWRITE'),ev).then(function(){
          startDialog();
        });
      if(count == 0) startDialog();
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getClassTaskNoteMostUsed = function(task){
      if(!self.currentClass) return "";
      var tt = self.getTaskByID(task.ID);
      if(!tt) return "";

      var used = {};
      var total = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
        if(status.Note && status.Note != "") {
          if(!used[status.Note]) used[status.Note] = 0;
          used[status.Note]++;
          total++;
        }
      }
      var visible = self.countUserTaskVisible(tt.mainTopic,tt.topic,tt.goal,tt.task,self.currentClass);

      if(total >= visible){
        // all students have a sticker
        var m = "";
        var v = 0;
        for(var k in used){
          if(used[k] > v){
            v = used[k];
            m = k;
          }
        }
        return m.replace('¶','');
      }
      return "";
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.isClassTaskImportedForAll = function(task){
      if(task.Important == "1") return true;
      if(!self.currentClass) return false;
      if(!self.currentClass.students || self.currentClass.students.length == 0) return false;
      for(var i=0; i < self.currentClass.students.length; i++){
        var status = self.getUserTaskStatus(task,self.currentClass.students[i],true);
        if(status.Important != 1) return false;
      }
      return true;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.copyUserTask = function(usertask,calendardate,ev){
      var deferred = $q.defer();
      var p = {"action":"createUserTask",
               "Name":usertask.Name,
               "Data":angular.toJson(usertask.DataJSON),
               "inclass":self.currentClass.ID,
               "Icon":usertask.Icon,
               "Time":usertask.Time,
               "Color":usertask.Color,
               "Important":usertask.Important,
               "Description":usertask.Description};
      if(usertask.LearningGoal) p.LearningGoal = usertask.LearningGoal;
      if(usertask.Owner != self.user.ID) p.student = usertask.Owner;

      self.apiPost("ajax",p).then(function(data) {
         if(calendardate){
           self.addTasksToUsersCalendar(self.users[usertask.Owner],[data.task.ID],calendardate);
         }
         deferred.resolve(data.task);
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.createUserTask = function(student,goal,calendardate,ev){
      if(student.Teacher == 1){
        self.alert($filter('trans')('ALLOWUSERTASKSETTING'));
        return;
      }
      var deferred = $q.defer();

      // calendar and open tasks case:
      if(goal == null){
        self.showDialog({
          templateUrl: "editusertask.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.student = student;
            $scope.isNew = 1;
            $scope.iconList = self.taskIconList;
            $scope.colorChoice = self.colorChoice;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.item = {};
            $scope.item.Name = "";
            $scope.item.Description = "";
            $scope.item.DataJSON = {};
            $scope.item.Time = 0;
            $scope.item.Icon = "";
            $scope.item.Type = "user";
            $scope.item.Important = "0";
            var mt = goal ? self.getMainTopicFromTopic({ID:goal.Topic}) : null;
            $scope.item.Color = mt ? mt.Color : self.colorChoice[0];
            $scope.item.DataJSON.Class = self.currentClass.ID;

            self.addEditTaskController($scope,$mdDialog);

            //1010
            $timeout(function(){
              self.addDropHandler($scope, $scope.dialogElement, null, true, false, $scope.addHintsFromFiles);
            });

            $scope.save = function() {
              // try save now
              if(!$scope.validate()) return;

              self.replaceBase64Images($scope.item.Description).then(function(desc){        
                $scope.item.Description = desc;

                var p = {"action":"createUserTask",
                         "Name":$scope.item.Name,
                         "Data":angular.toJson($scope.item.DataJSON),
                         "inclass":self.currentClass.ID,
                         "Icon":$scope.item.Icon,
                         "Time":$scope.item.Time,
                         "Color":$scope.item.Color,
                         "Important":$scope.item.Important,
                         "Description":$scope.item.Description};

                if(student.ID != self.user.ID) p.student = student.ID;
                if(goal) p.LearningGoal = goal.ID;

                self.apiPost("ajax",p).then(function(data) {
                   if(self.user.ID == "-1"){
                     data.task = $scope.item;
                     data.task.Changed = new Date();
                     data.task.Active = 1;
                     data.task.Type = "user";
                     data.task.ResultType = "";
                     data.task.LearningGoal = null;
                     data.task.userTask = 1;
                     data.task.OrderIndex = 99999;
                     data.task.Owner = self.user.ID;
                     data.task.ID = data.task.Changed.getTime();
                     self.updateLastUsedTaskIcons(data.task.Icon);
                     self.updateLastUsedTaskIcons(data.task.MainIcon);
                     self.closeDialog($scope.dialogElement);
                     deferred.resolve();
                   }else{
                     data.task.DataJSON = data.task.Data != '' ? JSON.parse(data.task.Data) : {};
                     self.updateLastUsedTaskIcons(data.task.Icon);
                     self.updateLastUsedTaskIcons(data.task.MainIcon);
                     self.closeDialog($scope.dialogElement);
                     if(calendardate){
                       self.addTasksToUsersCalendar(student,[data.task.ID],calendardate);
                     }
                     if(calendardate && self.user.Teacher == 1){
                        // ask to add it to other students too
                        self.confirmAndHide("COPYINTOCALENDARS",$filter('trans')('COPYCALENDARNOTEHINT')+"?",$filter('trans')('COPY'),ev).then(function(){
                          self.copyTasksIntoStudentsCalendars([data.task.ID],calendardate);
                        },function(){});
                     }
                     if(!calendardate && self.user.Teacher == 1){
                        // ask to add it to other students too
                        self.confirmAndHide("COPYTOOTHERS",$filter('trans')('COPYUSERTASKHINTTOOTHERS')+"?",$filter('trans')('COPY'),ev).then(function(){
                          self.copyUserTaskToOtherStudents(data.task,ev);
                        },function(){});
                     }

                     self.keepAliveIntervalWorking = false;
                     self.keepAliveCallback().then(function(){
                       deferred.resolve();
                       $timeout(function(){
                         var d = $('#userTask'+data.task.ID).get(0);
                         if(d) d.scrollIntoView({behavior: "smooth",
                                                 block: "start",
                                                 inline: "nearest"});
                       },10);
                     });
                   }
                 });
               });
            };

            $scope.cancel = function(ev) {
              $scope.close(ev);
            };
          }
        });
      }else{
        // create task inside LearningGoal in class
        self.createTask(goal,ev);
      }

      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editUserTask = function(it,goal,ev){
      var deferred = $q.defer();
      // calendar and open tasks case:
      if(goal == null){
        self.showDialog({
          templateUrl: "editusertask.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.isEdit = 1;
            $scope.allowTest = true;
            $scope.iconList = self.taskIconList;
            $scope.colorChoice = self.colorChoice;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.item = JSON.parse(angular.toJson(it));

            $scope.student = self.users[$scope.item.Owner];

            self.addEditTaskController($scope,$mdDialog);

            $scope.save = function() {
              // try save now
              if(!$scope.validate()) return;

              self.replaceBase64Images($scope.item.Description).then(function(desc){        
                $scope.item.Description = desc;                
                self.apiPost("ajax",{"action":"updateUserTask", "ID":it.ID,
                                     "Name":$scope.item.Name,
                                     "Data":angular.toJson($scope.item.DataJSON),
                                     "Icon":$scope.item.Icon,
                                     "Time":$scope.item.Time,
                                     "Color":$scope.item.Color,
                                     "Important":$scope.item.Important,
                                     "Description":$scope.item.Description})
                 .then(function(data) {
                   it.Name = $scope.item.Name;
                   it.Description = $scope.item.Description;
                   it.DataJSON = $scope.item.DataJSON;
                   it.Icon = $scope.item.Icon;
                   it.Color = $scope.item.Color;
                   it.Important = $scope.item.Important;

                   self.updateLastUsedTaskIcons(it.Icon);
                   self.closeDialog($scope.dialogElement);
                   deferred.resolve();
                   self.keepAliveCallback();
                 });
               });
            };

            $scope.cancel = function(ev) {
              $scope.close(ev);
            };
          }
        });
      }else{
        // create task inside LearningGoal in class
        self.editTask(it,goal,ev);
      }
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Task feedback
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countTaskFeedbacks = function(status, inClass){
      inClass = inClass || self.currentClass;
      var c = 0;
      if(status.FeedbackJSON && status.FeedbackJSON.length > 0){
        for(var i=0; i < status.FeedbackJSON.length; i++){
          if(status.FeedbackJSON[i].Deleted != "1" && 
           !(status.UserID == status.FeedbackJSON[i].User && status.FeedbackJSON[i].isSys == "1") && 
            (!inClass || status.FeedbackJSON[i].Class == inClass.ID)) c++; 
          else 
          if(status.FeedbackJSON[i].Deleted != "1" && 
             status.FeedbackJSON[i].isSys == "1" && 
             status.FeedbackJSON[i].Message.match(/%%.*ACCESS%%/)){
            c++;
          }
        }
      }
      return c;
    };

    self.lastFeedbackActionFromUser = function(lastFeedback,user, currentClass){
      if(lastFeedback && lastFeedback.emojis){
        if(!currentClass) currentClass = self.currentClass;
        var users = [];
        for(var k in lastFeedback.emojis){
          users = users.concat(lastFeedback.emojis[k]);
        }
        // check if one teacher gave a emoji to the last feedback item already
        for(var i=0; i < currentClass.teachers.length; i++){
          if(users.indexOf(currentClass.teachers[i].ID) != -1) return false;
        }
      }
      return lastFeedback && lastFeedback.User == user.ID;
    };

    self.getLastTaskFeedback = function(task,student,inClass,includeSys){
      inClass = inClass || self.currentClass;
      student = student ? student : self.user;
      var status = self.getUserTaskStatus(task, student, true);
      if(status.FeedbackJSON && status.FeedbackJSON.length > 0){
        // go backward from newst 
        for(var i=status.FeedbackJSON.length-1; i >= 0; i--)
          if(status.FeedbackJSON[i].Deleted != "1"  &&
            (!inClass || status.FeedbackJSON[i].Class == inClass.ID) &&
            (self.user.Teacher == 1 || status.FeedbackJSON[i].User != student.ID)) {
            if((includeSys && status.FeedbackJSON[i].User != student.ID) || 
//               (status.FeedbackJSON[i].isSys == '1' && status.FeedbackJSON[i].Message.match(/%%ASKACCESS%%/)) ||
               (status.FeedbackJSON[i].isSys != '1' && status.FeedbackJSON[i].Message != '%%RESOLVED%%') )
              return status.FeedbackJSON[i];

            // check for open askAcess
            if(status.FeedbackJSON[i].isSys == '1' && status.FeedbackJSON[i].Message.match(/%%ASKACCESS%%/)){
              var parts = status.FeedbackJSON[i].Message.split("|");
              var accepted = self.getUserTaskHintApproved(parts[2], {ID:parts[1]}, {ID:status.FeedbackJSON[i].User});
              if(accepted == -1 || accepted == -3){
                return status.FeedbackJSON[i];
              }
            }
          }
      }
      return null;
    };


    self.getTaskFeedbackType = function(feedback){
      var type = "text";
      var isURL = feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*/) ? true : false;
      var isAudio = feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(m4a)/) ? true : false;
      var isImage = feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(jpg|jpeg|png|gif)/) ? true : false;
      var isVideo= feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/uploads\/.*\.(mp4)/) ? true : false;
      var isTaskRef = feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/m[0-9]+/) ? true : false;
      var isRubricRef = feedback.Message.toLowerCase().match(/https:\/\/learningview\.org\/r[0-9a-zA-Z]{10}/) ? true : false;
      if(isURL) type = "file";
      if(isAudio) type = "audio";
      if(isImage) type = "image";
      if(isVideo) type = "video";
      if(isTaskRef) type = "ref";
      if(isRubricRef) type = "rubric";
      return type;
    };

    self.closeUserTask = function(task,student,ev){
      var deferred = $q.defer();
      self.confirm('<span style="color:red">'+$filter('trans')('ASKCLOSETASK')+'</span>',$filter('trans')('CLOSETASK'),null).then(function(){
        self.saveTeacherTaskFeedbackStatus(task,student,{FeedbackStatus:'c'});
        deferred.resolve();
      },function(){});
      return deferred.promise;
    };

    self.openTaskUserFeedback = function(task,student,ev){
      if(self.currentTaskFeedbackDialog){
        self.closeDialog(self.currentTaskFeedbackDialog);
        self.currentTaskFeedbackDialog = null;
        if(self.lastTaskFeedbackDialogStudent == student.ID) return;
      }

      self.showDialog({
        state:"one",
        templateUrl: "edittaskuserfeedback.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          self.currentTaskFeedbackDialog = null;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = task;
          $scope.student = student;
          $scope.status = self.getUserTaskStatus(task, student ? student : self.user, true);
          $scope.state = {};
          $scope.currentChatLastScroll = 0;
          $scope.currentChatListLimit = -10;
          $scope.userList = [];
          var partners = self.getUserTaskStatusColleagues(task,student);
          if(partners && partners != ""){
            $scope.userList = partners.split(",").map(Number);
          }
          $scope.userList.unshift($scope.student.ID);

          setTimeout(function(){
            self.currentTaskFeedbackDialog = $scope.dialogElement;
            self.lastTaskFeedbackDialogStudent = student.ID;
          },100);

          $scope.updateChatLastScroll = function(){
            $scope.noScrollToBottom = true;
            if($scope.currentChatLastScroll)
              $timeout.cancel($scope.currentChatLastScroll);
            $scope.currentChatLastScroll =
              $timeout(function(){
                $scope.noScrollToBottom = false;
              },10000); // delay for 10 sec
          };
          $scope.resetChatLastScroll = function(){
            $scope.noScrollToBottom = false;
            if($scope.currentChatLastScroll)
              $timeout.cancel($scope.currentChatLastScroll);
          };

          self.addChatMessageScope($scope);


          $scope.messageSeenByAll = function(m,task){
            // find isNew in matching journal items 
            for(var i=0; i < $scope.userList.length; i++){
              if(self.users[$scope.userList[i]] && 
                 self.users[$scope.userList[i]].journalTaskMapped[task.ID]){
                for(var z in self.users[$scope.userList[i]].journalTaskMapped[task.ID]){
                  if(self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].isNew == "1" && 
                     self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].DataJSON){
                    if(self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].DataJSON.feedback == m.Message &&
                       self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].Created.getTime() == new Date().fromMysqlFormat(m.Created).getTime()){
                      return false; // found a user 
                    }
                  }
                }
              }
            }
            return true; // or false
          }
          $scope.messageNotSeenBy = function(m,task){
            var users = [];
            for(var i=0; i < $scope.userList.length; i++){
              if(self.users[$scope.userList[i]] && 
                 self.users[$scope.userList[i]].journalTaskMapped[task.ID]){
                for(var z in self.users[$scope.userList[i]].journalTaskMapped[task.ID]){
                  if(self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].isNew == "1" && 
                     self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].DataJSON){
                    if(self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].DataJSON.feedback == m.Message &&
                       self.users[$scope.userList[i]].journalTaskMapped[task.ID][z].Created.getTime() == new Date().fromMysqlFormat(m.Created).getTime()){
                      users.push($scope.userList[i]);
                      break;
                    }
                  }
                }
              }
            }

            var names = [];
            // all missing reads in users now
            for(var i=0; i < users.length; i++)
              if(self.users[users[i]])
                names.push(self.users[users[i]].Name+(self.users[users[i]].Surname && self.users[users[i]].Surname.length > 0 ? " "+self.users[users[i]].Surname[0]+". " : ''));
            
            return names.join(", ");            
          }

          $scope.setResolved = function(){
            self.apiPost("ajax",{"action":"addTaskStatusFeedback",
                "ID":$scope.task.ID,"user":$scope.student.ID,"classid":self.currentClass.ID, 
                "message":'%%RESOLVED%%', sys:1})
             .then(function(data) {
               self.keepAliveIntervalWorking = false;
               self.keepAliveCallback();
               $scope.close();
             });
          };

          $scope.setAccessApproved = function(m,list){
            var parts = m.Message.split("|");
            var hintIndex = parts[2];
            var pos = list.indexOf(m);
            self.setUserTaskHintApproved($scope.task.ID,m.User,hintIndex,pos);
          };
          $scope.setAccessDeny = function(m,list){
            var parts = m.Message.split("|");
            var hintIndex = parts[2];
            var pos = list.indexOf(m);
            self.setUserTaskHintDeny($scope.task.ID,m.User,hintIndex,pos);
          };

          $scope.setClosed = function(){
            self.closeUserTask($scope.task,$scope.student).then(function(){
              $scope.close();
            });            
          };

          $scope.needsResolveButton = function(){
            // already closed
            if($scope.status.FeedbackStatus == 'c') return 0;
            //if($scope.status.Status == '?' &&  $scope.status.FeedbackStatus != 'w') return 3;
            // include sys messages, who wrote the last message?
            var last = self.getLastTaskFeedback(task,$scope.student,self.currentClass, true);
            if(last && last.User == $scope.student.ID && last.isSys != 1) return 1;
            if($scope.status.Status == 'x') return 2;
            return 0;
          };

          $scope.scrollToMessage = function(m){
            // scroll to the message #$($("li").get().reverse()).each(function()
            var list = [];
            for(var i=0; i < $scope.status.FeedbackJSON.length; i++){
              if($scope.status.FeedbackJSON[i].Class == self.currentClass.ID)
                list.push($scope.status.FeedbackJSON[i]);
            }
            $($('#feedbackChatMessagePanel .chatMessageWrapper').get().reverse()).each(function(i,e){
              var c = list[list.length-1-i];
              if(c.User == m.User && c.Created == m.Created && c.Message == m.Message){
                // found
                $(e).get(0).scrollIntoView({ behavior: "smooth", block: "start" }, 50); 
              }
            });
          }

          $scope.sendMessage = function(){
            $scope.state.message = $.trim($scope.state.message);
            $scope.state.message = $scope.state.message.replace(/[\n]\s*[\n]\s*([\n]\s*)+/g,"\n\n\n");
            if(!$scope.state.message || $scope.state.message == "") return;

            $scope.state.sendingMessage = true;
            $scope.noScrollToBottom = false;
            self.apiPost("ajax",{"action":"addTaskStatusFeedback",
                "ID":$scope.task.ID,"user":student.ID,"classid":self.currentClass.ID, 
                "reply":$scope.state.reply ? JSON.stringify({User:$scope.state.reply.User,
                                                             Created:$scope.state.reply.Created,
                                                             Message:$scope.state.reply.Message}) : '',
                "message":$scope.state.message})
             .then(function(data) {
               self.track("addTaskChatItem",{"ID":$scope.task.ID,"content":$scope.state.message});
               $scope.state.sendingMessage = false;
               $scope.state.message = "";
               $scope.state.reply = null;
               $scope.state.isRecording = false;
               self.keepAliveIntervalWorking = false;
               if($scope.status.Important == -1){
                 if(!student || student == self.user){
                   self.setUserTaskImportant(task,"0",null);
                 }else{
                   self.setClassUserTaskImportant(student,task,"0",null);
                 }
               }
               self.keepAliveCallback();
             });
          };

          $scope.close = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.customIcons = {};
    self.customIconsStyle = null;
    self.customIconIsBlack = function(url,callback){
      var iconImage = new Image();
      iconImage.src = url;
      iconImage.crossOrigin = "Anonymous";
      iconImage.onload = function() {
        var steps = Math.max(1,iconImage.width / 8);
        var canvas = document.createElement('canvas');
        canvas.width = iconImage.width;
        canvas.height = iconImage.height;
        var ctx = canvas.getContext('2d');
        ctx.drawImage(iconImage, 0, 0, iconImage.width, iconImage.height);
        var imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        var pixels = imageData.data;

        var isBlack = true;
        for (var i = 0; i < pixels.length; i += 4*steps) {
            var r = pixels[i];
            var g = pixels[i + 1];
            var b = pixels[i + 2];
            var a = pixels[i + 3];

            // Check if the pixel is not black
            if (a != 0 && (r > 50 || g > 50 || b > 50)) {
                isBlack = false;
                break;
            }
        }

        // Assuming your text color is white
        if(callback) callback(isBlack);
      };     
    };
    self.customIcon = function(iconString){
      if(iconString && iconString.indexOf && iconString.indexOf("ci") === 0){
        // ci cc ci-120-30 cifull
        var found = iconString.match(/ci-\d+-\d+/);
        if(!found) return iconString;
        var parts = found[0].split("-");
        var cbc  = parts[0].indexOf("cb") != 0 || parts[0].indexOf("cc") != 0;
        var user = parts[1];
        var icon = parts[2];
        if(!self.customIcons[user]) self.customIcons[user] = {};
        if(!self.customIcons[user][icon]) {
          // build custom css now
          var s = ''
          if(!self.customIconsStyle){
            self.customIconsStyle = document.createElement('style');
            document.head.append(self.customIconsStyle);
            self.customIconsStyle.textContent = "";
          }
          self.customIconsStyle.textContent += '.ci-'+user+'-'+icon+':before { background-image:url(\'https://learningview.org/customIcons/'+user+'/'+icon+'.png\') }';
          self.customIcons[user][icon] = 1;

          if(!cbc){
            self.customIconIsBlack('https://learningview.org/customIcons/'+user+'/'+icon+'.png',function(isBlack){
              if (isBlack) {
                self.customIconsStyle.textContent += '.taskListItem .ci-'+user+'-'+icon+':before, '+
                                                     '.tableCell .btn .ci-'+user+'-'+icon+':before, '+
                                                     '.userTable .btn .ci-'+user+'-'+icon+':before  { filter: invert(100%) }';
              }              
            });
          }
        }
      }
      return iconString;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    // Folders & Class Folders
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.classFolderFullscreen = true; // children start with fullscreen folder view
    self.folderColors =     ["#f3f3f3","#fce5cd","#fff2cc","#d9ead3","#cceef4","#c9daf8","#d9d2e9","#ead1dc","#f4cccc","#f4cce7"];
    self.folderColorsDark = ["#d9d9d9","#f9cb9c","#ffe599","#b6d7a8","#9ed5d8","#a4c2f4","#b4a7d6","#d5a6bd","#ea9999","#d396bf"];
    self.rubricColors =     ["#ffffff","#f3f3f3","#d9d9d9","#fff2cc","#ffe599","#d9ead3","#b9e2ab","#cceef4","#9de0ec","#c9daf8","#d9d2e9","#fce5cd","#f4cccc"];
    self.getFolderColorDark = function(c){
      var p = self.folderColors.indexOf(c);
      if(p == -1) p = 0;
      return self.folderColorsDark[p];
    };

    self.findClassFolder = function(id,allClasses){
      if(self.currentClass){
        if(self.classContent && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders)
          for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
            if(self.classContent[self.currentClass.ID].folders[i].ID == id)
              return self.classContent[self.currentClass.ID].folders[i];
          }
        for(var i=0; i < self.currentClass.students.length; i++){
          if(self.users[self.currentClass.students[i].ID] &&
             self.users[self.currentClass.students[i].ID].classContent &&
             self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID] &&
             self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders){
            for(var x=0; x < self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders.length; x++){
              if(self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[x].ID == id)
                return self.users[self.currentClass.students[i].ID].classContent[self.currentClass.ID].folders[x];
            }
          }
        }
      }
      if(allClasses){
        for(var z=0; z < self.classList.length; z++){
          if(self.classContent[self.classList[z].ID] && self.classContent[self.classList[z].ID].folders)
            for(var i=0; i < self.classContent[self.classList[z].ID].folders.length; i++){
              if(self.classContent[self.classList[z].ID].folders[i].ID == id)
                return self.classContent[self.classList[z].ID].folders[i];
            }
          for(var i=0; i < self.classList[z].students.length; i++){
            if(self.users[self.classList[z].students[i].ID] &&
               self.users[self.classList[z].students[i].ID].classContent &&
               self.users[self.classList[z].students[i].ID].classContent[self.classList[z].ID] &&
               self.users[self.classList[z].students[i].ID].classContent[self.classList[z].ID].folders){
              for(var x=0; x < self.users[self.classList[z].students[i].ID].classContent[self.classList[z].ID].folders.length; x++){
                if(self.users[self.classList[z].students[i].ID].classContent[self.classList[z].ID].folders[x].ID == id)
                  return self.users[self.classList[z].students[i].ID].classContent[self.classList[z].ID].folders[x];
              }
            }
          }
        }
      }
      return null;
    };
    self.searchInClassFolderItem = function(it){
      var searchterm = self.folderSearchTerm;
      if(!searchterm || searchterm == "") return true;

      var searchArray = [
        it.Title,
        it.DataJSON && it.DataJSON.Name ? it.DataJSON.Name : "",
        it.DataJSON && it.DataJSON.Description ? it.DataJSON.Description : "",
        it.Tags ? it.Tags : ""
      ];
      if(it.contents)
        for(var i=0; i < it.contents.length; i++){
          if(it.contents[i].DataJSON){
            if(it.contents[i].DataJSON.text)
              searchArray.push(it.contents[i].DataJSON.text);
            if(it.contents[i].DataJSON.Answer)
              searchArray.push(it.contents[i].DataJSON.Answer);
            if(it.contents[i].DataJSON.URL)
              searchArray.push(it.contents[i].DataJSON.URL);
          }
        }

      return self.matchSearchTerm(searchterm,searchArray);
/*
      searchterm = searchterm.toLowerCase();
      function check(s){
        return s.toLowerCase().indexOf(searchterm) != -1;
      }
      if(it.Title && check(it.Title)) return true;
      if(it.DataJSON && it.DataJSON.Name && check(it.DataJSON.Name)) return true;
      if(it.DataJSON && it.DataJSON.Description && check(it.DataJSON.Description)) return true;
      if(it.Tags && check(it.Tags)) return true;
      if(it.contents)
        for(var i=0; i < it.contents.length; i++){
          if(it.contents[i].DataJSON){
            if(it.contents[i].DataJSON.text && check(it.contents[i].DataJSON.text)) return true;
            if(it.contents[i].DataJSON.Answer && check(it.contents[i].DataJSON.Answer)) return true;
            if(it.contents[i].DataJSON.URL && check(it.contents[i].DataJSON.URL)) return true;
          }
        }
      return false;
*/      
    };
    self.findClassFolderItemByID = function(folder, itemid){
      for(var z=0; z < folder.items.length; z++){
        if(folder.items[z].ID == itemid)
          return folder.items[z];
      }
      return null;
    };

    self.countTaskFoldersByType = function(type){
      var c = 0;
      for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
        if(type == "personal" && (self.classContent[self.currentClass.ID].folders[i].Share == 0 || self.classContent[self.currentClass.ID].folders[i].Share == 3)) c++;
        if(type == "class" && (self.classContent[self.currentClass.ID].folders[i].Share == 1 || self.classContent[self.currentClass.ID].folders[i].Share == 2)) c++;
      }
      return c;
    };

    self.getStudentClassFoldersWithTask = function(student, folder, task){
      var r = [];
      var usedIDs = [];

      if(self.currentClass && self.classContent && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders)
        for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
          if(folder && folder.ID != self.classContent[self.currentClass.ID].folders[i].ID) continue;
          if(!self.classContent[self.currentClass.ID].folders[i].items) continue;
          for(var z=0; z < self.classContent[self.currentClass.ID].folders[i].items.length; z++){
            if(self.classContent[self.currentClass.ID].folders[i].items[z].Owner == student.ID &&
               self.classContent[self.currentClass.ID].folders[i].items[z].Task == task.ID){
              r.push(self.classContent[self.currentClass.ID].folders[i]);
              usedIDs.push(self.classContent[self.currentClass.ID].folders[i].ID);
            }
          }
        }
      if(self.currentClass &&
         self.users[student.ID] &&
         self.users[student.ID].classContent &&
         self.users[student.ID].classContent[self.currentClass.ID] &&
         self.users[student.ID].classContent[self.currentClass.ID].folders){
        for(var x=0; x < self.users[student.ID].classContent[self.currentClass.ID].folders.length; x++){
          if(folder && folder.ID != self.users[student.ID].classContent[self.currentClass.ID].folders[x].ID) continue;
          if(!self.users[student.ID].classContent[self.currentClass.ID].folders[x].items) continue;
          for(var z=0; z < self.users[student.ID].classContent[self.currentClass.ID].folders[x].items.length; z++){
            if(self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Owner == student.ID &&
               self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Task == task.ID){
              if(usedIDs.indexOf(self.users[student.ID].classContent[self.currentClass.ID].folders[x].ID) == -1)
                r.push(self.users[student.ID].classContent[self.currentClass.ID].folders[x]);
            }
          }
        }
      }
      return r;
    };

