              return;
            }
            event.preventDefault();
            if (dragElement) {
              //rollback all the changes.
              rollbackDragChanges();
              scope.sortableScope.$apply(function () {
                scope.callbacks.dragCancel(dragItemInfo.eventArgs());
              });
              dragItemInfo = null;
            }
            unBindEvents();
          };
          blurOthers = function(){
            if(document.activeElement) document.activeElement.blur();
          }
          /**
           * Binds the drag start events.
           */
          bindDrag = function () {
            if (hasTouch) {
              if (isLongTouch) {
                if (isIOS) {
                  element.bind('touchstart', longTouchStart);
                  element.bind('touchend', longTouchCancel);
                  addTouchMoveListener(element[0], longTouchMoveCancel, true);
                } else {
                  element.bind('contextmenu', dragListen);
                }
              } else {
                element.bind('touchstart', dragListen);
                addTouchMoveListener(element[0], angular.noop, true); // <- the bug fix just adds a no operation event handler function() {}, which is later removed in the unbindDrag function
              }
            }
            element.bind('mousedown', dragListen);
            element.bind('mousedown', blurOthers); 
            element[0].addEventListener('touchstart', blurOthers, {passive:true});
          };

          /**
           * Unbinds the drag start events.
           */
          unbindDrag = function () {
            element.unbind('touchstart', longTouchStart);
            element.unbind('touchend', longTouchCancel);
            removeTouchMoveListener(element[0], longTouchMoveCancel);
            element.unbind('contextmenu', dragListen);
            element.unbind('touchstart', dragListen);
            removeTouchMoveListener(element[0], angular.noop);
            element.unbind('mousedown', dragListen);
            element.unbind('mousedown', blurOthers); 
            element[0].removeEventListener('touchstart', blurOthers, false);
          };
          /**
           * starts a timer to detect long touch on iOS devices. If touch held for more than 500ms,
           * it would be considered as long touch.
           *
           * @param event - the event object.
           */
          longTouchStart = function(event) {
            if(event.originalEvent && event.originalEvent.touches && event.originalEvent.touches[0]){
              longTouchStartPosition = {x:event.originalEvent.touches[0].pageX, y:event.originalEvent.touches[0].pageY};
            }else
            if(event.originalEvent && event.originalEvent.changedTouches && event.originalEvent.changedTouches[0]){
              longTouchStartPosition = {x:event.originalEvent.changedTouches[0].pageX, y:event.originalEvent.changedTouches[0].pageY};
            }else
            if(event.touches && event.touches[0]){
              longTouchStartPosition = {x:event.touches[0].pageX, y:event.touches[0].pageY};
            }else
            if(event.changedTouches && event.changedTouches[0]){
              longTouchStartPosition = {x:event.changedTouches[0].pageX, y:event.changedTouches[0].pageY};
            }

            longTouchTimer = $timeout(function() {
              dragListen(event);
            }, 500);
          };
          /**
           * cancel the long touch and its timer.
           */
          longTouchMoveCancel = function(event) {
            var posNow = null;
            if(event.originalEvent && event.originalEvent.touches && event.originalEvent.touches[0]){
              posNow = {x:event.originalEvent.touches[0].pageX, y:event.originalEvent.touches[0].pageY};
            }else
            if(event.originalEvent && event.originalEvent.changedTouches && event.originalEvent.changedTouches[0]){
              posNow = {x:event.originalEvent.changedTouches[0].pageX, y:event.originalEvent.changedTouches[0].pageY};
            }else
            if(event.touches && event.touches[0]){
              posNow = {x:event.touches[0].pageX, y:event.touches[0].pageY};
            }else
            if(event.changedTouches && event.changedTouches[0]){
              posNow = {x:event.changedTouches[0].pageX, y:event.changedTouches[0].pageY};
            }
            if(posNow && longTouchStartPosition){
              var dx = Math.abs(longTouchStartPosition.x - posNow.x);
              var dy = Math.abs(longTouchStartPosition.y - posNow.y);
              if(dx < 5 && dy < 5) return; // not yet changed position enough
            }
            $timeout.cancel(longTouchTimer);
          };
          /**
           * cancel the long touch and its timer.
           */
          longTouchCancel = function() {
            $timeout.cancel(longTouchTimer);
          };
          //bind drag start events.
          //put in a watcher since this method is now depending on the longtouch option from sortable.sortOptions
          //bindDrag();
          //Cancel drag on escape press.
          escapeListen = function (event) {
            if (event.keyCode === 27) {
              dragCancel(event);
            }
          };
          angular.element($document[0].body).bind('keydown', escapeListen);
          /**
           * Binds the events based on the actions.
           */
          bindEvents = function () {
            addTouchMoveListener($document[0], dragMove, false);
            angular.element($document).bind('touchend', dragEnd);
            angular.element($document).bind('touchcancel', dragCancel);
            angular.element($document).bind('mousemove', dragMove);
            angular.element($document).bind('mouseup', dragEnd);
          };
          /**
           * Un binds the events for drag support.
           */
          unBindEvents = function () {
            angular.element($document).unbind('touchend', dragEnd);
            angular.element($document).unbind('touchcancel', dragCancel);
            removeTouchMoveListener($document[0], dragMove);
            angular.element($document).unbind('mouseup', dragEnd);
            angular.element($document).unbind('mousemove', dragMove);
          };
        }
      };
    }]);

// tell angualr to use the bugfixed version of asSortableItemHandle
angular.module('ui.sortable').decorator(
      "asSortableItemHandleDirective",
      function asSortableItemHandleDirectiveDecorator( $delegate ) {
        return( [ $delegate[ $delegate.length-1 ] ] );
      }
    );

///////////////////////////////////////////////////////////////////////////////////////////////////
/*! ngWig */
///////////////////////////////////////////////////////////////////////////////////////////////////
function cleanHTMLStyles(pasteContent){
  pasteContent = pasteContent.replace(/mso-[^;"]+?:[^;"]+;/g,'').replace(/mso-[^;"]+?:[^;"]+/g,'');
  pasteContent = pasteContent.replace(/ class="MsoNormal"/g,'').replace(/ lang="[^"]*"/g,'');
  // remove font styles 
  var changed = false;
  pasteContent = pasteContent.replace(/style="([^"]+?)"/igm,function(match, p1){
    p1 = p1.replace(/&quot;/ig,"'");
    p1 = p1.replace(/letter-spacing[^;"]+/ig,"");
    p1 = p1.replace(/font-size[^;"]+/ig,"");
    p1 = p1.replace(/font-family[^;"]+/ig,"");
    p1 = p1.replace(/font-weight[^;"]+/ig,"");
    p1 = p1.replace(/box-sizing[^;"]+/ig,"");
    p1 = p1.replace(/line-height[^;"]+/ig,"");
    p1 = p1.replace(/outline[^;"]+/g,"");
    p1 = p1.replace(/font-size[^;"]+/g,"");
    p1 = p1.replace(/font-variant-ligatures[^;"]+/g,"");
    p1 = p1.replace(/font-variant-caps[^;"]+/g,"");
    p1 = p1.replace(/letter-spacing[^;"]+/g,"");
    p1 = p1.replace(/orphans[^;"]+/g,"");
    p1 = p1.replace(/text-indent[^;"]+/g,"");
    p1 = p1.replace(/text-transform[^;"]+/g,"");
    p1 = p1.replace(/white-space[^;"]+/g,"");
    p1 = p1.replace(/caret-color[^;"]+/g,"");
    p1 = p1.replace(/widows[^;"]+/g,"");
    p1 = p1.replace(/word-spacing[^;"]+/g,"");
    p1 = p1.replace(/-webkit-text-stroke-width[^;"]+/g,"");
    p1 = p1.replace(/text-decoration-thickness[^;"]+/g,"");
    p1 = p1.replace(/text-decoration-style[^;"]+/g,"");
    p1 = p1.replace(/text-decoration-color[^;"]+/g,"");
    p1 = p1.replace(/text-decoration[^;"]+/g,"");
    p1 = p1.replace(/float[^;"]+/g,"");
    p1 = p1.replace(/display[^;"]+/g,"");
    p1 = p1.replace(/font-style:\s?normal;/g,"");
    p1 = p1.replace(/text-align:\s?start;/g,"");
    p1 = p1.replace(/background-color:\s?rgb\(255, 255, 255\);/ig,"");
    p1 = p1.replace(/background-color:\s?#ffffff;/ig,"");
    p1 = p1.replace(/color:\s?rgb\(0, 0, 0\);/ig,"");
    p1 = p1.replace(/color:\s?#000000;/ig,"");
    p1 = p1.replace(/color:\s?#0;/ig,"");
    p1 = p1.replace(/color:\s?rgba[^;"]+;/ig,"");
    var l1 = p1.length+1;
    while(p1.length < l1){
      l1 = p1.length;
      p1 = p1.replace(/;\s*;/g,";");
      p1 = p1.replace(/^\s*?;/,"");
    }
    
    p1 = $.trim(p1);
    if(p1 == "" || p1.match(/^[;\s]+$/)) {
      changed = true;
      return "";
    }
    return 'style="'+p1+'"';
  });
  if(changed){
    pasteContent = pasteContent.replace(/<span >/g,"<span>");
    pasteContent = pasteContent.replace(/<span>([^<>]*?)<\/span>/g,"$1");
  }

  return pasteContent;
}

angular.module('ngWig', ['ngwig-app-templates']);
angular.ngWig = {
  version: 1
};

angular.module('ngWig').directive("ngWigChange",function($parse) {
  return {
    require: 'ngModel',
    link: function(scope, elem, attrs, ngModel) {
      attrs.$observe('ngModel', function(value){ // Got ng-model bind path here
        scope.$watch(value,function(newValue){ // Watch given path for changes
          scope.$applyAsync($parse(attrs.ngWigChange));
        });
      });
    }
  };
});

angular.module('ngWig').component('ngWig', {
  bindings: {
    content: '=ngModel',
    label: '@?',
    options: '<?',
    onPaste: '&',
    onBlur: '&',
    onReturn: '&',
    buttons: '@',
    beforeExecCommand: '&',
    afterExecCommand: '&',
    placeholder: '@?',
    filename: '@?'
  },
  require: {
    ngModelController: 'ngModel'
  },
  templateUrl: 'ng-wig/views/ng-wig.html',
  controller: ["$scope", "$element", "$q", "$attrs", "$window", "$timeout", "$document", "ngWigToolbar", function ($scope, $element, $q, $attrs, $window, $timeout, $document, ngWigToolbar) {
    var _this = this;
    _this.filename = _this.filename ? _this.filename.replace(/["<>#%\{\}\|\\\^~\[\]`;\?:@=&]/g,'') : null;
    var $wig = angular.element($element[0].querySelector('.ng-wig'));
    var $container = angular.element($element[0].querySelector('.ng-wig-editable'));
    var $toolbar = angular.element($element[0].querySelector('.nw-toolbar'));
    var $label = angular.element($element[0].querySelector('.nw-label'));
    var dockedToolbarTarget = null;
    var dockDeactivateTimeout = null;
    var isToolbarInteraction = false;

    //TODO: clean-up this attrs solution
    this.container = $container;
    this.required = 'required' in $attrs;
    this.isSourceModeAllowed = 'sourceModeAllowed' in $attrs;
    this.isImageAllowed = 'imagesAllowed' in $attrs;
    this.editMode = false;
    this.isNoBlend = 'noBlend' in $attrs;
    this.isMinimal = 'minimalOptions' in $attrs;
    this.isNoTables = 'noTables' in $attrs;
    this.autoFocus = 'autoFocus' in $attrs;
    this.doTrim = 'doTrim' in $attrs;

    var getToolbarDockTarget = function(toolbarPosition) {
      if (!toolbarPosition) return null;
      var position = ("" + toolbarPosition).trim();
      if (!position || position === "top" || position === "bottom") return null;
      if (position.charAt(0) === "#") position = position.substring(1);
      return position ? document.getElementById(position) : null;
    };

    var setDockedToolbarInactive = function(isInactive) {
      if (!dockedToolbarTarget) return;
      $toolbar.css("opacity", isInactive ? "0.5" : "1");
      $toolbar.css("pointer-events", isInactive ? "none" : "");
      if (isInactive) {
        $toolbar.attr("inert","true");
      } else {
        $toolbar.removeAttr("inert");
      }
    };

    var clearDockDeactivateTimeout = function() {
      if (dockDeactivateTimeout) {
        clearTimeout(dockDeactivateTimeout);
        dockDeactivateTimeout = null;
      }
    };

    var scheduleDockedToolbarInactiveCheck = function(delayMs) {
      if (!dockedToolbarTarget) return;
      clearDockDeactivateTimeout();
      dockDeactivateTimeout = setTimeout(function() {
        dockDeactivateTimeout = null;
        var active = document.activeElement;
        var toolbarHasFocus = !!(active && ($toolbar[0] === active || $toolbar[0].contains(active)));
        var editorHasFocus = ($container.length && $container[0] === active);
        if (isToolbarInteraction || toolbarHasFocus || editorHasFocus) {
          setDockedToolbarInactive(false);
          return;
        }
        setDockedToolbarInactive(true);
      }, delayMs || 0);
    };

    var dockToolbarIntoTarget = function() {
      if (!dockedToolbarTarget || !$toolbar.length) return;
      var toolbarEl = $toolbar[0];
      var existingToolbar = dockedToolbarTarget.querySelector(".nw-toolbar");
      if (existingToolbar && existingToolbar !== toolbarEl) {
        existingToolbar.remove();
      }
      if (toolbarEl.parentNode !== dockedToolbarTarget) {
        dockedToolbarTarget.appendChild(toolbarEl);
      }
      $toolbar.css({
        "position":"relative",
        "top":"",
        "bottom":"",
        "left":"",
        "right":"",
        "box-shadow":"",
        "min-width":""
      });
    };

    var trimHTML = function(s){
      s = s.replace(/&nbsp;/g," ");
      // at the end
      var lastS = "";
      while(lastS != s){
        lastS = s;
        s = s.replace(/(<p>[ ]*(<br>)*[ ]*<\/p>)+$/,"");
        s = s.replace(/<span[^>]*>([ ]*)<\/span>/g,"$1");
        s = s.replace(/[ ]*(<br>)+[ ]*$/,"");
        s = s.replace(/[ ]+$/,"");
        s = s.replace(/<p>[ ]*<\/p>$/,"");
      }
      var lastS = "";
      while(lastS != s){
        lastS = s;
        s = s.replace(/^(<p>[ ]*(<br>)*[ ]*<\/p>)+/,"");
        s = s.replace(/<span[^>]*>([ ]*)<\/span>/g,"$1");
        s = s.replace(/^[ ]*(<br>)+[ ]*/,"");
        s = s.replace(/^[ ]+/,"");
        s = s.replace(/^<p>[ ]*<\/p>/,"");
      }
      return $.trim(s);
    };

    function enableElementResizeInDiv(id) {
      var editor = id.get(0);
      var resizing = false;
      var currentImage = null;
      var currentVideo = null;
      var currentCell = null;
      var resizeMouseMoveHandler = null;
      var resizeMouseUpHandler = null;
      var resizeTouchMoveHandler = null;
      var resizeTouchEndHandler = null;
      var resizeTouchCancelHandler = null;
      $('.resize-frame,.resizer,.cell-editor',editor).remove();

      var unbindGlobalImageResizeEvents = function(){
        if(resizeMouseMoveHandler){
          document.removeEventListener("mousemove", resizeMouseMoveHandler);
          resizeMouseMoveHandler = null;
        }
        if(resizeMouseUpHandler){
          document.removeEventListener("mouseup", resizeMouseUpHandler);
          resizeMouseUpHandler = null;
        }
        if(resizeTouchMoveHandler){
          document.removeEventListener("touchmove", resizeTouchMoveHandler, false);
          resizeTouchMoveHandler = null;
        }
        if(resizeTouchEndHandler){
          document.removeEventListener("touchend", resizeTouchEndHandler, false);
          resizeTouchEndHandler = null;
        }
        if(resizeTouchCancelHandler){
          document.removeEventListener("touchcancel", resizeTouchCancelHandler, false);
          resizeTouchCancelHandler = null;
        }
      };
      var bindGlobalImageResizeEvents = function(onMove, onUp, options){
        options = options || {};
        var useMouse = options.useMouse !== false;
        var useTouch = options.useTouch !== false;
        unbindGlobalImageResizeEvents();
        if(useMouse){
          resizeMouseMoveHandler = onMove;
          resizeMouseUpHandler = onUp;
          document.addEventListener("mousemove", resizeMouseMoveHandler);
          document.addEventListener("mouseup", resizeMouseUpHandler);
        }
        if(useTouch){
          resizeTouchMoveHandler = function(event){
            if(!event || !event.changedTouches || event.changedTouches.length === 0) return;
            var touch = event.changedTouches[0];
            onMove({
              pageX: touch.pageX,
              pageY: touch.pageY,
              preventDefault: function(){},
              stopPropagation: function(){}
            });
            if(event.cancelable) event.preventDefault();
          };
          resizeTouchEndHandler = function(event){
            onUp(event);
          };
          resizeTouchCancelHandler = function(event){
            onUp(event);
          };
          document.addEventListener("touchmove", resizeTouchMoveHandler, {passive:false});
          document.addEventListener("touchend", resizeTouchEndHandler, false);
          document.addEventListener("touchcancel", resizeTouchCancelHandler, false);
        }
      };

      var clickImage = function (img) {
        $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resizer,.resize-trash',editor).remove();
        currentImage = img;

        var imgHeight = img.offsetHeight;
        var imgWidth = img.offsetWidth;
        var imgPosition = { top: 0, left: 0 };

        var p = img;
        while (p){
          imgPosition.top += p.offsetTop;
          imgPosition.left += p.offsetLeft;
          if(p.parentNode == p) break;
          p = p.offsetParent;
          if($(p).hasClass("nw-editor-container")) break;
        }

        var editorScrollTop = editor.scrollTop;
        var editorScrollLeft = editor.scrollLeft;
        var top = imgPosition.top - editorScrollTop - 1;
        var left = imgPosition.left - editorScrollLeft - 1;

        resizing = false;
        var borders = $('<span class="resize-trash" style="cursor:pointer;position: absolute; top: '+(top + 10) + 'px; left: '+(left + 10) + 'px;padding:8px;background:white;color:#999"><i class="fa fa-fw fa-trash-o"></i></span>'+
                        '<span class="resize-frameWH" style="margin:10px; position: absolute; top: '+(top + imgHeight - 16) + 'px; left: '+(left + imgWidth - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: se-resize; z-index: 1;opacity:0.5"></span>'+
                        '<span class="resize-frameW" style="margin:10px; position: absolute; top: '+(top + imgHeight/2 - 16) + 'px; left: '+(left + imgWidth - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: e-resize; z-index: 1;opacity:0.5"></span>'+
                        '<span class="resize-frameH" style="margin:10px; position: absolute; top: '+(top + imgHeight - 16) + 'px; left: '+(left + imgWidth/2 - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: s-resize; z-index: 1;opacity:0.5"></span>'+

                        '<span class="resize-frameTWH" style="margin:10px; position: absolute; top: '+(top - 16) + 'px; left: '+(left - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: nw-resize; z-index: 1;opacity:0.5"></span>'+
                        '<span class="resize-frameTW" style="margin:10px; position: absolute; top: '+(top + imgHeight/2 - 16) + 'px; left: '+(left - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: w-resize; z-index: 1;opacity:0.5"></span>'+
                        '<span class="resize-frameTH" style="margin:10px; position: absolute; top: '+(top - 16) + 'px; left: '+(left + imgWidth/2 - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: n-resize; z-index: 1;opacity:0.5"></span>'+

                        '<span class="resize-frameCWH" style="margin:10px; position: absolute; top: '+(top - 16) + 'px; left: '+(left + imgWidth - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: ne-resize; z-index: 1;opacity:0.5"></span>'+
                        '<span class="resize-frameCHW" style="margin:10px; position: absolute; top: '+(top + imgHeight - 16) + 'px; left: '+(left - 16) + 'px; border: solid 3px #0088d1; width: 6px; height: 6px;cursor: sw-resize; z-index: 1;opacity:0.5"></span>'+

                        '<span class="resizer top-border" style="position:absolute;top:'+top+'px;left:'+left+'px;border:dashed 1px grey;width:'+imgWidth+'px;height:0px"></span>'+
                        '<span class="resizer left-border" style="position:absolute;top:'+top+'px;left:'+left+'px;border:dashed 1px grey;width:0px;height:'+imgHeight+'px"></span>'+
                        '<span class="resizer right-border" style="position:absolute;top:'+top+'px;left:'+(left + imgWidth)+'px;border:dashed 1px grey;width:0px;height:'+imgHeight+'px"></span>'+
                        '<span class="resizer bottom-border" style="position:absolute;top:'+(top + imgHeight)+'px;left:'+left+'px;border:dashed 1px grey;width:'+imgWidth+'px;height:0px"></span>');

        $(img).after(borders);

        var finishImageResize = function() {
          if (resizing) {
            currentImage.style.width = document.querySelector('.top-border').offsetWidth + 'px';
            currentImage.style.height = document.querySelector('.left-border').offsetHeight + 'px';
            refresh();
            currentImage.click();
            resizing = false;
          }
          unbindGlobalImageResizeEvents();
        };

        var moveImageResize = function(e) {
          if (currentImage && resizing) {
            var off = $(currentImage).offset();

            var width = e.pageX - off.left;
            var height = e.pageY - off.top;
            width = width < 1 ? 1 : width;
            height = height < 1 ? 1 : height;

            var orgWidth = currentImage.naturalWidth ? currentImage.naturalWidth : imgWidth;
            var orgHeight = currentImage.naturalHeight ? currentImage.naturalHeight : imgHeight;

            if(resizing == 1){
              // corner, keep aspect
              var s = width / orgWidth;
              height = Math.round(orgHeight*s);
            }
            if(resizing == -1){
              // corner, keep aspect
              var s = height / orgHeight;
              width = Math.round(orgWidth*s);
            }
            if(resizing == 2 || resizing == -2){
              height = imgHeight;
            }
            if(resizing == 3 || resizing == -3){
              width = imgWidth;
            }
            if(resizing == 4){
              // corner keep aspect but use both diffs
              var sw = width / orgWidth;
              var sh = height / orgHeight;
              if(sw > sh){
                height = Math.round(orgHeight*sw);
              }else{
                width = Math.round(orgWidth*sh);
              }
            }


            var top = imgPosition.top - editorScrollTop - 1;
            var left = imgPosition.left - editorScrollLeft - 1;

            $('.resize-trash',editor).css({
                top: (top +  10) + 'px',
                left: (left + 10) + "px"
            });
            $('.resize-frameWH',editor).css({
                top: (top + height - 16) + 'px',
                left: (left + width - 16) + "px"
            });
            $('.resize-frameW',editor).css({
                top: (top + height/2 - 16) + 'px',
                left: (left + width - 16) + "px"
            });
            $('.resize-frameH',editor).css({
                top: (top + height - 16) + 'px',
                left: (left + width/2 - 16) + "px"
            });

            $('.resize-frameTWH',editor).css({
                top: (top - 16) + 'px',
                left: (left - 16) + "px"
            });
            $('.resize-frameTW',editor).css({
                top: (top + height/2 - 16) + 'px',
                left: (left - 16) + "px"
            });
            $('.resize-frameTH',editor).css({
                top: (top - 16) + 'px',
                left: (left + width/2 - 16) + "px"
            });
            $('.resize-frameCWH',editor).css({
                top: (top - 16) + 'px',
                left: (left + width - 16) + "px"
            });
            $('.resize-frameCHW',editor).css({
                top: (top + height - 16) + 'px',
                left: (left - 16) + "px"
            });

            $('.top-border',editor).css({ width: width + "px" });
            $('.left-border',editor).css({ height: height + "px" });
            $('.right-border',editor).css({
                left: (left + width) + 'px',
                height: height + "px"
            });
            $('.bottom-border',editor).css({
                top: (top + height) + 'px',
                width: width + "px"
            });
          }
          return false;
        };

        var startImageResize = function(mode, e){
          resizing = mode;
          var isTouchStart = !!(e && (e.type === "touchstart" || e.lvFromTouch));
          bindGlobalImageResizeEvents(moveImageResize, finishImageResize, {
            useMouse: !isTouchStart,
            useTouch: isTouchStart
          });
          if(e){
            e.preventDefault();
            e.stopPropagation();
          }
          return false;
        };

        $('.resize-frameWH',editor).get(0).onmousedown = function(e) {
            return startImageResize(4, e);
        };
        $('.resize-frameW',editor).get(0).onmousedown = function(e) {
            return startImageResize(2, e);
        };
        $('.resize-frameH',editor).get(0).onmousedown = function(e) {
            return startImageResize(3, e);
        };
        $('.resize-frameTWH',editor).get(0).onmousedown = function(e) {
            return startImageResize(4, e);
        };
        $('.resize-frameTW',editor).get(0).onmousedown = function(e) {
            return startImageResize(-2, e);
        };
        $('.resize-frameTH',editor).get(0).onmousedown = function(e) {
            return startImageResize(-3, e);
        };
        $('.resize-frameCWH',editor).get(0).onmousedown = function(e) {
            return startImageResize(1, e);
        };
        $('.resize-frameCHW',editor).get(0).onmousedown = function(e) {
            return startImageResize(-1, e);
        };

        $('.resize-trash',editor).get(0).onclick = function(e) {
            unbindGlobalImageResizeEvents();
            resizing = false;
            $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resize-frameCWH,.resize-frameCHW,.resizer,.resize-trash',editor).remove();
            $(img).remove();
            e.stopPropagation();
        };

        var touchHandler = function(event) {
            if(resizing && resizeTouchMoveHandler){
              if(event && event.preventDefault) event.preventDefault();
              return;
            }
            var touch = event.originalEvent.changedTouches[0];

            var simulatedEvent = document.createEvent("MouseEvent");
                simulatedEvent.initMouseEvent({
                touchstart: "mousedown",
                touchmove: "mousemove",
                touchend: "mouseup"
            }[event.type], true, true, window, 1,
                touch.screenX, touch.screenY,
                touch.clientX, touch.clientY, false,
                false, false, false, 0, null);
            simulatedEvent.lvFromTouch = true;

            $(touch.target).get(0).dispatchEvent(simulatedEvent);
            //event.preventDefault();
        };

        $(editor).off("touchstart.ngWigResize touchmove.ngWigResize touchend.ngWigResize");
        $(editor).on("touchstart.ngWigResize touchmove.ngWigResize touchend.ngWigResize", touchHandler);

      };

      var clickVideo = function (video) {
        $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resizer,.resize-trash',editor).remove();
        currentVideo = video;

        var videoHeight = video.offsetHeight;
        var videoWidth = video.offsetWidth;
        var videoPosition = { top: 0, left: 0 };

        var p = video;
        while (p){
          videoPosition.top += p.offsetTop;
          videoPosition.left += p.offsetLeft;
          if(p.parentNode == p) break;
          p = p.offsetParent;
          if($(p).hasClass("nw-editor-container")) break;
        }

        var editorScrollTop = editor.scrollTop;
        var editorScrollLeft = editor.scrollLeft;
        var top = videoPosition.top - editorScrollTop - 1;
        var left = videoPosition.left - editorScrollLeft - 1;

        resizing = false;
        var borders = $('<span class="resize-trash" style="cursor:pointer;position: absolute; top: '+(top + 10) + 'px; left: '+(left + 10) + 'px;padding:8px;background:white;color:#999"><i class="fa fa-fw fa-trash-o"></i></span>');

        $(video).after(borders);

        $('.resize-trash',editor).get(0).onmousedown = function(e) {
            unbindGlobalImageResizeEvents();
            resizing = false;
            $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resize-frameCWH,.resize-frameCHW,.resizer,.resize-trash',editor).remove();
            $(video).remove();
            e.stopPropagation();
        };

        var touchHandler = function(event) {
            if(resizing && resizeTouchMoveHandler){
              if(event && event.preventDefault) event.preventDefault();
              return;
            }
            var touch = event.originalEvent.changedTouches[0];

            var simulatedEvent = document.createEvent("MouseEvent");
                simulatedEvent.initMouseEvent({
                touchstart: "mousedown",
                touchmove: "mousemove",
                touchend: "mouseup"
            }[event.type], true, true, window, 1,
                touch.screenX, touch.screenY,
                touch.clientX, touch.clientY, false,
                false, false, false, 0, null);
            simulatedEvent.lvFromTouch = true;

            $(touch.target).get(0).dispatchEvent(simulatedEvent);
            //event.preventDefault();
        };

        $(editor).off("touchstart.ngWigResize touchmove.ngWigResize touchend.ngWigResize");
        $(editor).on("touchstart.ngWigResize touchmove.ngWigResize touchend.ngWigResize", touchHandler);
      };

      var resetOtherCellWidthHeight = function(td){
        if(!td) return;
        if(!td.parentNode) return;
        var table = td.parentNode.parentNode;
        for(var i=0; i < table.childNodes.length; i++){
          for(var z=0; z < table.childNodes[i].childNodes.length; z++){
            if(table.childNodes[i].childNodes[z] == td){
              colElementIndex = z;
              rowElementIndex = i;
              break;
            }
          }
        }        
        for(var i=0; i < table.childNodes.length; i++){
          for(var z=0; z < table.childNodes[i].childNodes.length; z++){
            if(z == colElementIndex && td != table.childNodes[i].childNodes[z]){
              table.childNodes[i].childNodes[z].style.width = "";
            }
            if(i == rowElementIndex && td != table.childNodes[i].childNodes[z]){
              table.childNodes[i].childNodes[z].style.height = "";
            }
          }
        }        
      };

      var repositionCellToolbar = function(td){
        var tdPosition = { top: 0, left: 0 };

        var p = td;
        while (p){
          tdPosition.top += p.offsetTop;
          tdPosition.left += p.offsetLeft;
          if(p.parentNode == p) break;
          p = p.offsetParent;
          if($(p).hasClass("nw-editor-container")) break;
        }

        var editorScrollTop = editor.scrollTop;
        var editorScrollLeft = editor.scrollLeft;
        var top = tdPosition.top - editorScrollTop - 1 + currentCell.offsetHeight;
        var left = tdPosition.left - editorScrollLeft - 1; 

        $('.cell-editor').css({"top":(top+3)+'px',"left":(left+3)+'px'});
        $('.cell-editor .backgroundColor .fa').css("color",td.style.backgroundColor ? td.style.backgroundColor : "white");
      }
      var clickCell = function(td){
        $('.cell-editor,.cell-remove-col',editor).remove();
        currentCell = td;
        var table = currentCell.parentNode.parentNode;
        var colElementIndex = -1;
        var rowElementIndex = -1;
        for(var i=0; i < table.childNodes.length; i++){
          for(var z=0; z < table.childNodes[i].childNodes.length; z++){
            if(table.childNodes[i].childNodes[z] == td){
              colElementIndex = z;
              rowElementIndex = i;
              break;
            }
          }
        }

        var buttons = $('<div class="cell-editor">'+
                        '<div class="cell-editor-btn backgroundColor"><i class="fa fa-square" style="position:absolute;color:white;left:3px;top:1px;font-size:19px"></i></div>'+
                        '<div class="cell-editor-btn addColLeft"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:8px;top:4px;height:14px;width:6px;background:rgb(2,136,209)"></div><i style="font-size:8px;position:absolute;top:7px;left:2px;background:#f3f3f3" class="fa fa-arrow-left"></i></div>'+
                        '<div class="cell-editor-btn deleteCol"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:8px;top:4px;height:14px;width:6px;background:rgb(2,136,209)"></div><i style="font-size:6px;position:absolute;top:8.5px;left:8.5px;color:white" class="fa fa-times"></i></div>'+
                        '<div class="cell-editor-btn addColRight"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:8px;top:4px;height:14px;width:6px;background:rgb(2,136,209)"></div><i style="font-size:8px;position:absolute;top:7px;right:2px;background:#f3f3f3" class="fa fa-arrow-right"></i></div>'+
                        '<div class="cell-editor-btn addRowAbove" style="margin-left: 4px;"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:2px;top:9px;width:17px;height:5px;background:rgb(2,136,209)"></div><i style="font-size:8px;position:absolute;top:2px;left:8px;background:#f3f3f3" class="fa fa-arrow-up"></i></div>'+
                        '<div class="cell-editor-btn deleteRow"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:2px;top:9px;width:17px;height:5px;background:rgb(2,136,209)"></div><i style="font-size:6px;position:absolute;top:8.5px;left:8.5px;color:white" class="fa fa-times"></i></div>'+
                        '<div class="cell-editor-btn addRowBelow"><i class="fa fa-table" style="position:absolute;color:#999;left:2px;top:2px;font-size:19px"></i><div style="position:absolute;left:2px;top:9px;width:17px;height:5px;background:rgb(2,136,209)"></div><i style="font-size:8px;position:absolute;bottom:2px;left:8px;background:#f3f3f3" class="fa fa-arrow-down"></i></div>'+
                        '</div>');
        $(editor).append(buttons);

        repositionCellToolbar(td);
        
        var refreshColumWidth = function(){
          var hasPixelWidth = false;
          var hasPercentWidth = false;
          var maxWidth = [];
          var maxHeight = [];
          for(var i=0; i < table.childNodes.length; i++){
            for(var z=0; z < table.childNodes[i].childNodes.length; z++){
              if(table.childNodes[i].childNodes[z].style.width.indexOf("px") > 0) {
                hasPixelWidth = true;
              }
              if(table.childNodes[i].childNodes[z].style.width.indexOf("%") > 0) {
                hasPercentWidth = true;
              }              
            }
          }
          if(!hasPixelWidth && hasPercentWidth){
            for(var i=0; i < table.childNodes.length; i++){
              for(var z=0; z < table.childNodes[i].childNodes.length; z++){
                table.childNodes[i].childNodes[z].style.width = Math.round(100*100 / table.childNodes[i].childNodes.length)/100+"%";
              }
            }
          }
        };

        $('.backgroundColor',editor).on("click",function(event){
          var colors = ["transparent","#f3f3f3","#fce5cd","#fff2cc","#d9ead3","#cceef4","#c9daf8","#d9d2e9","#ead1dc","#f4cccc","#f4cce7"];
          var colorSelector = $('<div style="background:white;z-index:10;position:absolute;left:0;top:0;width:100%;height:100%;display:flex"></div>');
          for(var i=0; i < colors.length; i++){
            var b = $('<div style="width:20px;height:20px;background-color:'+colors[i]+'"></div>');
            b.on("click",function(event){
              if(this.style.backgroundColor == "transparent")
                currentCell.style.backgroundColor = ''; else            
                currentCell.style.backgroundColor = this.style.backgroundColor;
              event.stopPropagation();  
            })
            colorSelector.append(b);
          }
          $('.cell-editor').append(colorSelector);
          console.log(colorSelector);
          event.stopPropagation();
        });

        $('.deleteCol',editor).on("click",function(event){
          if($('.deleteCol',editor).hasClass("confirmNow")){
            console.log("delete column");
            for(var i=0; i < table.childNodes.length; i++){
              table.childNodes[i].childNodes[colElementIndex].remove();
              if(table.childNodes[i].childNodes.length == 0){
                if(table.nodeName == "TBODY") table = table.parentNode;
                table.remove();
                break;
              }
            }
            refreshColumWidth();
            $('.cell-editor .confirmNow',editor).removeClass("confirmNow");
          }else{
            $('.cell-editor .confirmNow',editor).removeClass("confirmNow");
            $('.deleteCol',editor).addClass("confirmNow");
            event.stopPropagation();
          }
        });
        $('.deleteRow',editor).on("click",function(event){
          if($('.deleteRow',editor).hasClass("confirmNow")){
            console.log("delete row");
            table.childNodes[rowElementIndex].remove();
            if(table.childNodes.length == 0){
              if(table.nodeName == "TBODY") table = table.parentNode;
              table.remove();
            }            
            refreshColumWidth();
            $('.cell-editor .confirmNow',editor).removeClass("confirmNow");
          }else{
            $('.cell-editor .confirmNow',editor).removeClass("confirmNow");
            $('.deleteRow',editor).addClass("confirmNow");
            event.stopPropagation();
          }
        });
        $('.addRowAbove',editor).on("click",function(){
          console.log("add row above");
          var tr = table.childNodes[rowElementIndex].cloneNode();
          for(var i=0; i < table.childNodes[rowElementIndex].childNodes.length; i++){
            tr.appendChild(table.childNodes[rowElementIndex].childNodes[i].cloneNode());
          }
          table.insertBefore(tr,table.childNodes[rowElementIndex]);
          refreshColumWidth();
        });
        $('.addRowBelow',editor).on("click",function(){
          console.log("add row below");
          var tr = table.childNodes[rowElementIndex].cloneNode();
          for(var i=0; i < table.childNodes[rowElementIndex].childNodes.length; i++){
            tr.appendChild(table.childNodes[rowElementIndex].childNodes[i].cloneNode());
          }
          if(rowElementIndex == table.childNodes.length)
            table.appendChild(tr); else
            table.insertBefore(tr,table.childNodes[rowElementIndex].nextSibling);
          refreshColumWidth();
        });
        $('.addColLeft',editor).on("click",function(){
          console.log("add column left");
          for(var i=0; i < table.childNodes.length; i++){
            var cell = currentCell.cloneNode();
            table.childNodes[i].insertBefore(cell, table.childNodes[i].childNodes[colElementIndex]);
          }
          refreshColumWidth();
        });
        $('.addColRight',editor).on("click",function(){
          console.log("add column right");
          for(var i=0; i < table.childNodes.length; i++){
            var cell = currentCell.cloneNode();
            if(colElementIndex == table.childNodes[i].childNodes.length)
              table.childNodes[i].appendChild(cell); else
              table.childNodes[i].insertBefore(cell, table.childNodes[i].childNodes[colElementIndex].nextSibling);
          }
          refreshColumWidth();
        })
      };

      var bindClickListener = function () {
        editor.querySelectorAll('img').forEach(function(img, i) {
          img.onclick = function(e){
            if (e.target === img) {
              clickImage(img);
              e.stopPropagation();
            }
          };
        });
        editor.querySelectorAll('video').forEach(function(vid, i) {
          vid.onclick = function(e){
            if (e.target === vid) {
              clickVideo(vid);
              e.stopPropagation();
            }
          };
        });

        editor.querySelectorAll('table').forEach(function(table, i) {
          if(table.resizeObserver){
            table.resizeObserver.disconnect();
            table.resizeObserver = null; 
          }
          var resizingCell = null; // Track active resizes

          // Track which cell is being resized
          table.onmousedown = function (e) {
              let cell = e.target.closest("td, th");
              if (!cell) return;
              resizingCell = cell;
          };

          table.resizeObserver = new ResizeObserver(function(entries) {
            resetOtherCellWidthHeight(resizingCell);
            $('.cell-editor',editor).remove();
          });
          var cells = table.querySelectorAll("td, th");
          cells.forEach(function(cell){ table.resizeObserver.observe(cell); });   
        });

        editor.querySelectorAll('td').forEach(function(td, i) {
          td.onclick = function(e) {
            if (e.target === td) {
              clickCell(td);
              e.stopPropagation();
            }
          };
        });
      };

      var refresh = function () {
        unbindGlobalImageResizeEvents();
        bindClickListener();
        $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resize-frameCWH,.resize-frameCHW,.resizer,.resize-trash',editor).remove();
        //$('.cell-editor',editor).remove();
      };
      var reset = function () {
        unbindGlobalImageResizeEvents();
        if (currentImage != null) {
          currentImage = null;
          resizing = false;
          $('.resize-frameWH,.resize-frameH,.resize-frameW,.resize-frameTWH,.resize-frameTH,.resize-frameTW,.resize-frameCWH,.resize-frameCHW,.resizer,.resize-trash',editor).remove();
        }
        if (currentCell != null) {
          currentCell = null;
          resizing = false;
          $('.cell-editor',editor).remove();
        }
        bindClickListener();
      };
      editor.addEventListener('scroll',  reset , false);
      editor.addEventListener('input',  reset , false);
      bindClickListener();
      return refresh;
    }

    var refreshElementClickHandlers = enableElementResizeInDiv($('#ng-wig-editable',$element));

    $toolbar.css("pointer-events","none");
    $toolbar.attr("inert","true");

    if(this.isNoBlend){
      $toolbar.css("opacity","1");
      $toolbar.css("pointer-events","");
      $label.css("opacity","0");
      $toolbar.removeAttr('inert');
    }
    $attrs.$observe('disabled', function (isDisabled) {
      _this.disabled = isDisabled;
      $container.attr('contenteditable', !isDisabled);
    });
    this.isEditorActive = function () {
      return $container[0] === $document[0].activeElement;
    };

    var focusEditorFromOuterClick = function(event) {
      if (_this.disabled || _this.editMode || !$container.length) return;

      var $target = $(event.target);
      if ($target.closest('.nw-toolbar').length) return;
      if ($target.closest('.nw-editor__src-container').length) return;
      //if ($target.closest('.ng-wig-editable').length) return;

      $container[0].focus();
    };

    if ($wig.length) {
      $wig.bind('click', focusEditorFromOuterClick);
      $scope.$on('$destroy', function () {
        $wig.unbind('click', focusEditorFromOuterClick);
      });
    }

    this.toggleEditMode = function () {
      _this.editMode = !_this.editMode;
      if ($window.getSelection().removeAllRanges) {
        $window.getSelection().removeAllRanges();
        refreshElementClickHandlers();
      }
      if(_this.editMode && !_this.isNoBlend){
        if($scope.blendTimeout) $timeout.cancel($scope.blendTimeout);
        $toolbar.css("opacity","1");
        $toolbar.css("pointer-events","");
        $toolbar.removeAttr('inert');
        $label.css("opacity","0");
      }
    };

    this.execCommand = function (command, options) {
      if($container[0] !== $document[0].activeElement){
        $container.focus();
      }
      if($scope.blendTimeout) $timeout.cancel($scope.blendTimeout);
      if (_this.editMode) return false;

      if (command != 'insertchecklist')
        if ($document[0].queryCommandSupported && !$document[0].queryCommandSupported(command)) {
          throw 'The command "' + command + '" is not supported';
        }

      if (command === 'createlink' || command === 'insertImage') {
        options = $window.prompt('Please enter the URL', 'http://');
        if (!options) {
          return;
        }
      }

      if (command != 'insertchecklist')
        _this.beforeExecCommand({ command: command, options: options });
      // use insertHtml for `createlink` command to account for IE/Edge purposes, in case there is no selection

      var selection = $document[0].getSelection().toString();
      if (command === 'insertchecklist'){
        var createdList = false;
        var sel = $document[0].getSelection();
        if(!(sel && sel.focusNode && sel.focusNode.parentElement.nodeName == "LI")){
          // create normal UL first
          _this.beforeExecCommand({ command: "insertunorderedlist", options: options });
          $document[0].execCommand("insertunorderedlist", false, options);
          createdList = true;
        }

        var sel = $document[0].getSelection();
        var ul = null;
        if(sel && sel.focusNode && sel.focusNode.nodeName == 'LI'){
          ul = sel.focusNode.parentElement;

        }else
        if(sel && sel.focusNode && sel.focusNode.parentElement.nodeName == "LI"){
          // we are already inside a list
          ul = sel.focusNode.parentElement.parentElement;
        }else
        if(sel && sel.focusNode && sel.focusNode.parentElement && 
           sel.focusNode.parentElement.parentElement && sel.focusNode.parentElement.parentElement.nodeName == "LI"){
          // we are already inside a list
          ul = sel.focusNode.parentElement.parentElement.parentElement;
        }
        if(ul){
          if(ul.className == "nw-checklist" && !createdList){
            _this.beforeExecCommand({ command: "insertunorderedlist", options: options });
            $document[0].execCommand("insertunorderedlist", false, options);
          }else{
            if(ul.nodeName == "OL"){
              var ul2 = document.createElement("ul");
              var li = ul.querySelectorAll('li');
              for(var i=0; i < li.length; i++) {
                ul2.appendChild(li[i]);
              }
              ul.parentNode.replaceChild(ul2,ul);
              ul = ul2;
            }
            ul.className = "nw-checklist";            
          }
        }
      } else
      if (command === 'createlink' && selection === '') {
        $document[0].execCommand('insertHtml', false, '<a href="' + options + '" target="_blank">' + options + '</a>');
      } else {
        $document[0].execCommand(command, false, options);
      }

      _this.afterExecCommand({ command: command, options: options });

      if(command == "removeFormat"){
        // try to remove selection
        var sel = $document[0].getSelection();
        if(sel){
          var range = sel.getRangeAt(0);
          if(range){
            var p = range.commonAncestorContainer;
            while(p && (p.nodeType == 3 || p.parentNode.children.length == 1)){
              if($container.find(p).length == 0) {p = $container.get(0); break; }
              p = p.parentNode;
            }
            if(p){
              range.selectNodeContents(p);
              var html = p.innerHTML;
              //remove code brakes and tabs
              html = html.replace(/\n/g, "");
              html = html.replace(/\t/g, "");

              //keep html brakes and tabs
              html = html.replace(/<\/td>/g, "\t");
              html = html.replace(/<\/table>/g, "\n");
              html = html.replace(/<\/tr>/g, "\n");
              html = html.replace(/<\/p>/g, "\n");
              html = html.replace(/<\/li>/g, "\n");
              html = html.replace(/<\/div>/g, "\n");
              html = html.replace(/<\/h>/g, "\n");
              html = html.replace(/<br>/g, "\n");
              html = html.replace(/<br( )*\/>/g, "\n");
              var span = document.createElement("span");
              span.innerHTML = html;
              var t = span.textContent;
              t = t.replace(/\n/g, "<br>");
              span.innerHTML = t;
              if(html != ""){
                range.deleteContents();
                range.insertNode(span);
                $(span).contents().unwrap();
              }
/*
              var text = range.toString();
              range.deleteContents();
              if(text && text != "")
                range.insertNode(document.createTextNode(text));
*/
            }
          }
        }
      }

      // added temporarily to pass the tests. For some reason $container[0] is undefined during testing.
      if ($container.length) {
        $container[0].focus();
      }
    };

    this.$onInit = function () {
      if($attrs.label) {
        $label.text(_this.label);
      }
      _this.buttons = 'bold,italic,underline,foreColor,'+
                      'superscript,subscript,strikethrough,removeFormat,list1,list2';

      if(!$attrs.noChecklist) {
         _this.buttons += ",list3";
      }

      _this.buttons += ',table,emojis';
      _this.buttons += ",copy,paste";
      _this.buttons += (_this.filename && _this.filename != '' ? ',export':'');

      if(_this.isMinimal){
        _this.buttons = 'bold,italic,underline,foreColor,'+
                        'strikethrough,removeFormat,list1,list2,table,emojis';
      }
      if('noLists' in $attrs) {
        _this.buttons = _this.buttons.replace("list1,list2,","");
      }
      if('noTables' in $attrs) {
        _this.buttons = _this.buttons.replace("table,","");
      }

      if('imagesAllowed' in $attrs) {
        _this.buttons = _this.buttons.replace("emojis","emojis,addImage,addAudio,addVideo");
      }

      _this.toolbarButtons = ngWigToolbar.getToolbarButtons(_this.buttons && string2array(_this.buttons));

      if('floatToolbar' in $attrs) {
        var applyFloatToolbarPosition = function(toolbarPosition) {
          dockedToolbarTarget = getToolbarDockTarget(toolbarPosition);
          if (dockedToolbarTarget) {
            dockToolbarIntoTarget();
            setDockedToolbarInactive(true);
            return;
          }

          var pos = "bottom";
          if(toolbarPosition == "bottom") pos = "top";
          if(toolbarPosition == "top") pos = "bottom";

          var otherPos = pos == "top" ? "bottom" : "top";
          var toolbarCss = {
            "position":"absolute",
            "box-shadow":"2px 2px 5px rgba(0, 0, 0, 0.2)",
            "min-width":"190px"
          };
          toolbarCss[pos] = "calc(100% + 8px)";
          toolbarCss[otherPos] = "";
          $toolbar.css(toolbarCss);

          requestAnimationFrame(function() {
            var parent = $toolbar.closest('md-dialog')[0];
            if (!parent) return;

            var toolbarRect = $toolbar[0].getBoundingClientRect();
            var parentRect = parent.getBoundingClientRect();

            var overflowRight = toolbarRect.right - parentRect.right;

            if (overflowRight > 0) {
              var currentLeft = parseFloat($toolbar.css("left")) || 0;
              $toolbar.css("left", currentLeft - overflowRight - 4);
            }
          });
        };

        if ('floatToolbarPosition' in $attrs) {
          $attrs.$observe('floatToolbarPosition', function(value) {
            applyFloatToolbarPosition(value);
          });
        } else {
          applyFloatToolbarPosition(null);
        }
      }

      var placeholder = Boolean(_this.placeholder);
      var firstContent = null;
      var nowContent = null;
      var wasChanged = false;
      _this.ngModelController.$render = function () {
        // content changed from outside, only do, if not edited yet
        if(!firstContent) {
          firstContent = _this.ngModelController.$viewValue;
          if(firstContent)
            $container.html(firstContent); else
            $container.html('');
        }
        if(wasChanged) return true; // skip write to container
        $('.resize-frame,.resizer',$element).remove();        
        nowContent = _this.ngModelController.$viewValue;
        return _this.ngModelController.$viewValue ? $container.html(_this.ngModelController.$viewValue) : placeholder ? $container.empty() : $container.html('<br>');
      };
      $scope.blendTimeout = null;
      $container.bind('focus', function () {
        if (dockedToolbarTarget) {
          clearDockDeactivateTimeout();
          dockToolbarIntoTarget();
          setDockedToolbarInactive(false);
          $label.css("opacity","0");
          return;
        }
        if(_this.isNoBlend) return;
        if($scope.blendTimeout) $timeout.cancel($scope.blendTimeout);
        blendTimeout = null;
        $toolbar.css("opacity","1");
        $toolbar.css("pointer-events","");
        $label.css("opacity","0");
        $toolbar.removeAttr('inert');
      });

      $scope.changeTimeout = null;

      if($attrs.onReturn)
        $container.bind('keyup', function (event) {
          if(event.keyCode == 13){
            $q.when(_this.onReturn({ $event: event}));
          }
        });

      function closestTag(node, tagName) {
        tagName = tagName.toUpperCase();

        while (node && node !== $container[0]) {
          if (node.nodeType === Node.ELEMENT_NODE && node.tagName === tagName) {
            return node;
          }
          node = node.parentNode;
        }

        return null;
      }

      // backspace for contenteditable=false elements inside text
      $container.bind('keydown', function (e) {
        // -------------------------
        // Backspace-Sonderfall
        // -------------------------
        if (e.key === 'Backspace') {
          var sel = window.getSelection();
          if (!sel.rangeCount) return;

          var range = sel.getRangeAt(0);
          var node = range.startContainer;

          // If caret is in a text node, check sibling before it
          if (node.nodeType === Node.TEXT_NODE) {
            var prev = node.previousSibling;

            if (prev && prev.matches && prev.matches('[contenteditable="false"]')) {
              prev.remove();
              e.preventDefault();
              return;
            }
          }
        }

        // -------------------------
        // Tab / Shift+Tab in Listen
        // -------------------------
        if (e.key === 'Tab') {
          // In rubric grid editor, Tab/Shift+Tab is handled by rubric cell navigation.
          if ($attrs.ignoreTabKeys !== undefined) {
            return;
          }
          var sel = window.getSelection();
          if (!sel.rangeCount) return;

          var range = sel.getRangeAt(0);
          var node = range.startContainer;

          // Falls Textnode, auf das Parent-Element gehen
          var el = node.nodeType === Node.TEXT_NODE ? node.parentNode : node;

          // Nächstes <li> nach oben suchen
          var li = closestTag(el, 'LI');
          if (!li) {
            // Nicht in einer Liste -> normales Tab-Verhalten beibehalten
            return;
          }

          e.preventDefault();

          // Fokus sicherstellen, damit execCommand auf den Editor wirkt
          $container[0].focus();

          if (e.shiftKey) {
            document.execCommand('outdent', false, null);
          } else {
            document.execCommand('indent', false, null);
          }

          // ngModel / Toolbar / Preview ggf. synchronisieren
          // je nach ng-wig-Setup:
          if (typeof scope !== 'undefined' && scope.$evalAsync) {
            scope.$evalAsync(function () {
              // Beispiel: falls du HTML zurück in dein Model schreibst
              // ngModel.$setViewValue($container.html());
            });
          }

          return;
        }
      });

      $container.bind('blur change focus click', function (event) { // keyup
        //view --> model
        refreshElementClickHandlers();
        if (placeholder && (!$container.html().length || $container.html() === "<br>")) $container.empty();
        var val = $container.html();
        if(_this.doTrim){
          var nval = trimHTML(val);
          if(nval != val){
            val = nval;
            $container.html(val);
          }
        }
        // clean styles
        val = cleanHTMLStyles(val);

        _this.ngModelController.$setViewValue(val);
        wasChanged = val != nowContent;
        nowContent = val;
        $scope.$applyAsync();
      });
      // order of binds is important here
      $container.bind('blur', function (event) {
        if (dockedToolbarTarget) {
          if($scope.changeTimeout) $timeout.cancel($scope.changeTimeout);
          scheduleDockedToolbarInactiveCheck(120);
          $label.css("opacity","1");
        } else
        if(!_this.isNoBlend) {
          if($scope.blendTimeout) $timeout.cancel($scope.blendTimeout);
          if($scope.changeTimeout) $timeout.cancel($scope.changeTimeout);
          $scope.blendTimeout = $timeout(function(){
            $toolbar.css("opacity","0");
            $toolbar.css("pointer-events","none");
            $label.css("opacity","1");
            $toolbar.attr("inert","true");
          },250);
        }
        if (!$attrs.onBlur) {
          return;
        }
        $('.resize-frame,.resizer',$element).remove();
        if(firstContent == nowContent) return;
        firstContent = nowContent;
        wasChanged = false;
        console.log("save ng-wig content.");
        $q.when(_this.onBlur({ $event: event}));
      });

      $container.bind('keyup', function (event) {
        if($scope.changeTimeout) $timeout.cancel($scope.changeTimeout);
        $scope.changeTimeout = $timeout(function(){
          if (placeholder && (!$container.html().length || $container.html() === "<br>")) $container.empty();
          var val = $container.html();
          if(_this.doTrim){
            var nval = trimHTML(val);
            if(nval != val){
              val = nval;
              $container.html(val);
            }
          }
          // clean styles
          val = cleanHTMLStyles(val);

          _this.ngModelController.$setViewValue(val);
          wasChanged = val != nowContent;
          nowContent = val;
          $scope.$applyAsync();

          if(firstContent == nowContent) return;
          firstContent = nowContent;
          wasChanged = false;
          console.log("save ng-wig content.");
          if ($attrs.onBlur) $q.when(_this.onBlur({ $event: event}));
        },5000);
      });

      if(_this.autoFocus){
        setTimeout(function(){
          $container.focus();
          var range = document.createRange();
          range.selectNodeContents($container.get(0));
          range.collapse(false);
          var sel = window.getSelection();
          sel.removeAllRanges();
          sel.addRange(range);
        },100);
      }

      if (dockedToolbarTarget) {
        $toolbar.on('mousedown', function() {
          isToolbarInteraction = true;
          clearDockDeactivateTimeout();
          setDockedToolbarInactive(false);
          setTimeout(function(){ isToolbarInteraction = false; }, 0);
        });
      }

      $scope.$on('$destroy', function () {
        clearDockDeactivateTimeout();
        $toolbar.off('mousedown');
        if (!dockedToolbarTarget) return;
        dockToolbarIntoTarget();
        setDockedToolbarInactive(true);
      });
    };

    $container.on('drop', function (event) {
      event = event || window.event;
      if (event.originalEvent) event = event.originalEvent;
      if (event.preventDefault) event.preventDefault();
      var dt = event.dataTransfer;
      if(dt.files && dt.files.length > 0){
        var files = dt.files;
        console.log('Dropped '+files.length+' files');
        for (var i=0; i < files.length; i++) {
          var reader = new FileReader();
          reader.onload = function (e) {
            if(e.target.result.substring(0,"data:text/plain;base64,".length) == "data:text/plain;base64,"){
              if($container[0] !== $document[0].activeElement){
                $container.focus();
              }
              pasteHtmlAtCaret(atob(e.target.result.substring("data:text/plain;base64,".length)));
            }
          };
          reader.readAsDataURL(files[i]);
        }
      } else
      if(dt.items && dt.items.length > 0){
        var items = dt.items;
        console.log('Dropped '+items.length+' items');
        for (var i=0; i < items.length; i++) {
          if ((items[i].kind == 'string') &&
              (items[i].type.match('^text/plain'))) {
            items[i].getAsString(function (s){
              if($container[0] !== $document[0].activeElement){
                $container.focus();
              }
              pasteHtmlAtCaret(s);
            });
          }
        }
      }
    });

    $container.on('paste', function (event) {
      var pasteContent = void 0;
      if (window.clipboardData && window.clipboardData.getData) {
        // IE
        pasteContent = window.clipboardData.getData('Text');
      } else {
        pasteContent = (event.originalEvent || event).clipboardData.getData('text/html');
        if(!pasteContent || pasteContent == ""){
          pasteContent = (event.originalEvent || event).clipboardData.getData('text/plain');
        }
      }

      event.preventDefault();

      if(pasteContent == "" && (event.originalEvent || event).clipboardData.items.length > 0){
        // try files too
        var e = (event.originalEvent || event);
        for(var i=0; i < e.clipboardData.items.length; i++){
          if(e.clipboardData.items[i].kind == "file" &&    
             e.clipboardData.items[i].type.indexOf("image/") === 0){
            var file = e.clipboardData.items[i].getAsFile();
            var reader = new FileReader();
            reader.onload = function (e) {
              var u = {files:[file]}
              mc.uploadFileInput(u,function(result){
                pasteContent = '<img src="'+result+'" />';
                if (!$attrs.onPaste) {
                  pasteHtmlAtCaret(pasteContent);
                  return;
                }

                $q.when(_this.onPaste({ $event: event, pasteContent: pasteContent })).then(function (pasteText) {
                  if($container[0] !== $document[0].activeElement){
                    $container.focus();
                  }
                  pasteHtmlAtCaret(pasteText);
                });
              });
            };
            reader.readAsDataURL(file);
            return;
          }
        }
        return;        
      }

      // pasteText clean?
      pasteContent = window.DOMPurify ? DOMPurify.sanitize(pasteContent) : pasteContent; // HtmlSanitizer.SanitizeHtml(pasteContent);
      pasteContent = cleanHTMLStyles(pasteContent);

      if(_this.isMinimal){
        var divElement = document.createElement('div');
        divElement.innerHTML = pasteContent;

        // loop through ALL DOM elements insidie the divElement
        var elements = divElement.getElementsByTagName("*");
        for (var i = 0; i < elements.length; i++) {
          elements[i].removeAttribute('style');
        }        
        pasteContent = divElement.innerHTML;
        // <p> to <br><br> 
        pasteContent = pasteContent.replace(/<p[^>]*>([\s\S]*?)<\/p>/gi, '$1<br><br>');
        pasteContent = pasteContent.replace(/(<br\s*\/?>)+$/i, '');
      }

      if(pasteContent.indexOf("</p>") > 0) pasteContent = pasteContent.replace(/\r?\n/g,' ');

      pasteContent = trimHTML(pasteContent);

      if(pasteContent.indexOf("<") === 0){
        // unwrap if possible
        for (var i = 0; i < 10; i++) {
          var $wrapper = $('<div>').html(pasteContent);
          // Prüfe ob das div genau EIN Kind-Element hat und sonst nichts
          var children = $wrapper.contents();
          if (children.length === 1 && children[0].nodeType === 1) {
            var tag = children[0].tagName.toLowerCase();
            if (tag === 'ul' || tag === 'ol') {
              break;
            }
            if (tag !== 'img' && tag !== 'a') {
              pasteContent = $(children[0]).html();
            } else {
              break;
            }
          } else {
            break;
          }
        }
      }

      if (!$attrs.onPaste) {
        if($container[0] !== $document[0].activeElement){
          $container.focus();
        }
        var s = $.trim($container[0].innerHTML);
        if(s == "<br>" || s == "<p></p>" || s == "<p><br></p>") {
          $container[0].innerHTML = ""; // clear empty <br>
        }
        pasteHtmlAtCaret(pasteContent);
        return;
      }

      $q.when(_this.onPaste({ $event: event, pasteContent: pasteContent })).then(function (pasteText) {
        if($container[0] !== $document[0].activeElement){
          $container.focus();
        }
        pasteHtmlAtCaret(pasteText);
      });
    });

  }]
});

function string2array(keysString) {
  return keysString.split(',').map(Function.prototype.call, String.prototype.trim);
}

function textToHTML (s){
  // parse and create html if spaces detected
  if(!s) return "";
  if(s.indexOf("</") >= 0){
    return s; // is already some sort of HTML
  }
  if(s.indexOf("  ") == -1 && s.indexOf("\n") == -1) return s; // nothing to change
  s = s.replace(/\a?\n/g,"<br>");
  s = s.replace(/&nbsp;/g," ");
  s = s.replace(/[ ]+/g,function(m){
    var l = m.length;
    var r = "";
    for(var i=0; i < l-1; i++) r += "&nbsp;";
    r += " ";
    return r;
  });
  return s;
}

function pasteHtmlAtCaret (html) {
  html = textToHTML(html);
  var sel, range;
  if (window.getSelection) {
    sel = window.getSelection();
    if (sel.getRangeAt && sel.rangeCount) {
      range = sel.getRangeAt(0);
      range.deleteContents();

      // Range.createContextualFragment() would be useful here but is
      // non-standard and not supported in all browsers (IE9, for one)
      var el = document.createElement("div");
      el.innerHTML = html;

      var frag = document.createDocumentFragment(),
          node,
          lastNode;
      while (node = el.firstChild) {
        lastNode = frag.appendChild(node);
      }
      range.insertNode(frag);

      // Preserve the selection
      if (lastNode) {
        range = range.cloneRange();
        range.setStartAfter(lastNode);
        range.collapse(true);
        sel.removeAllRanges();
        sel.addRange(range);
      }
      return true;
    }else{
      return false;
    }
  } else if (document.selection && document.selection.type != "Control") {
    // IE < 9
    document.selection.createRange().pasteHTML(html);
    return true;
  }else
    return false;
}

angular.module('ngWig').provider('ngWigToolbar', function () {
  var buttonLibrary = {
    list1: { title: 'Aufzählung', command: 'insertunorderedlist', styleClass: 'list-ul' },
    list2: { title: 'Nummerierte Liste', command: 'insertorderedlist', styleClass: 'list-ol' },
    list3: { title: 'Check-Liste', command: 'insertchecklist', styleClass: 'list-check' },

    strikethrough: { title: 'Durchgestrichen', command: 'strikethrough', styleClass: 'strikethrough' },
    subscript: { title: 'Tiefgestellt', command: 'subscript', styleClass: 'subscript' },
    superscript: { title: 'Hochgestellt', command: 'superscript', styleClass: 'superscript' },
    removeFormat: { title: 'Formatierung löschen', command: 'removeFormat', styleClass: 'removeFormat' },
    bold: { title: 'Fett', command: 'bold', styleClass: 'bold' },
    italic: { title: 'Kursiv', command: 'italic', styleClass: 'italic' },
    link: { title: 'Link', command: 'createlink', styleClass: 'link' },
    underline: { title: 'Unterstrichen', command: 'underline', styleClass: 'underline' }
  };

  var defaultButtonsList = ['bold', 'italic','underline','foreColor', 'list1', 'list2','list3']; // 'link'

  var isButtonActive = function isButtonActive() {
    var r = false;
    try{
      r = !!this.command && document.queryCommandState(this.command);
    }catch(e){}
    return r;
  };

  this.setButtons = function (buttons) {
    if (!angular.isArray(buttons)) {
      throw 'Argument "buttons" should be an array';
    }

    defaultButtonsList = buttons;
  };

  this.addStandardButton = function (name, title, command, styleClass) {
    if (!name || !title || !command) {
      throw 'Arguments "name", "title" and "command" are required';
    }

    styleClass = styleClass || '';
    buttonLibrary[name] = { title: title, command: command, styleClass: styleClass };
    defaultButtonsList.push(name);
  };

  this.addCustomButton = function (name, pluginName) {
    if (!name || !pluginName) {
      throw 'Arguments "name" and "pluginName" are required';
    }

    buttonLibrary[name] = { pluginName: pluginName, isComplex: true };
    //defaultButtonsList.push(name);
  };

  this.$get = function () {
    return {
      getToolbarButtons: function getToolbarButtons(list) {
        var toolbarButtons = [];
        (list || defaultButtonsList).forEach(function (buttonKey) {
          if (!buttonLibrary[buttonKey]) {
            throw 'There is no "' + buttonKey + '" in your library. Possible variants: ' + Object.keys(buttonLibrary);
          }

          var button = angular.copy(buttonLibrary[buttonKey]);
          button.isActive = isButtonActive;
          toolbarButtons.push(button);
        });
        return toolbarButtons;
      }
    };
  };
});

angular.module('ngWig').component('ngWigPlugin', {
  bindings: {
    plugin: '<',
    execCommand: '=',
    filename: '=',
    editMode: '=',
    disabled: '=',
    options: '<',
    content: '=',
    container: '='
  },
  controller: ["$scope", "$element", "$compile", function ($scope, $element, $compile) {
    var $ctrl = this;
    this.$onInit = function () {
      $element.replaceWith($compile('<' + $ctrl.plugin.pluginName + ' ' + 'plugin=' + '"$ctrl.plugin"' + 'exec-command=' + '"$ctrl.execCommand"' + 'filename=' + '"$ctrl.filename"' + 'edit-mode=' + '"$ctrl.editMode"' + 'data-disabled=' + '"$ctrl.disabled"' + 'options=' + '"$ctrl.options"' + 'content=' + '"$ctrl.content"' + 'container=' + '"$ctrl.container"' + '/>')($scope));
    };
  }]
});
angular.module('ngwig-app-templates', ['ng-wig/views/ng-wig.html']);

angular.module("ng-wig/views/ng-wig.html", []).run(["$templateCache", function ($templateCache) {
