    self.showShareRequest = function(mt,ev){
      self.alert('<div style="max-width:400px">'+$filter('trans')('ASKFOREDITINMATERIALS',self.users[mt.Owner] ? '<b>'+self.users[mt.Owner].Name+" "+self.users[mt.Owner].Surname+'</b>' : "",self.users[mt.Owner] ? self.users[mt.Owner].Name: "")+'</div>',ev);
