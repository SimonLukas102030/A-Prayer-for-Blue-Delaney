    self.getStudentClassFoldersWithRubric = function(student, folder, rubric, task){
      var r = [];
      var usedIDs = [];

      if(self.currentClass && self.classContent && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders)
        for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
          if(folder && folder.ID != self.classContent[self.currentClass.ID].folders[i].ID) continue;
          if(!self.classContent[self.currentClass.ID].folders[i].items) continue;
          for(var z=0; z < self.classContent[self.currentClass.ID].folders[i].items.length; z++){
            if(self.classContent[self.currentClass.ID].folders[i].items[z].Owner == student.ID &&
               self.classContent[self.currentClass.ID].folders[i].items[z].Rubric == rubric.ID &&
            ((!self.classContent[self.currentClass.ID].folders[i].items[z].DataJSON.taskid && !task) ||
              (task && self.classContent[self.currentClass.ID].folders[i].items[z].DataJSON.taskid == task.ID))){
              r.push(self.classContent[self.currentClass.ID].folders[i]);
              usedIDs.push(self.classContent[self.currentClass.ID].folders[i].ID);
            }
          }
        }
      if(self.currentClass &&
         self.users[student.ID] &&
         self.users[student.ID].classContent &&
         self.users[student.ID].classContent[self.currentClass.ID] &&
         self.users[student.ID].classContent[self.currentClass.ID].folders){
        for(var x=0; x < self.users[student.ID].classContent[self.currentClass.ID].folders.length; x++){
          if(folder && folder.ID != self.users[student.ID].classContent[self.currentClass.ID].folders[x].ID) continue;
          if(!self.users[student.ID].classContent[self.currentClass.ID].folders[x].items) continue;
          for(var z=0; z < self.users[student.ID].classContent[self.currentClass.ID].folders[x].items.length; z++){
            if(self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Owner == student.ID &&
               self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Rubric == rubric.ID &&
            ((!self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].DataJSON.taskid && !task) ||
              (task && self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].DataJSON.taskid == task.ID))){
              if(usedIDs.indexOf(self.users[student.ID].classContent[self.currentClass.ID].folders[x].ID) == -1)
                r.push(self.users[student.ID].classContent[self.currentClass.ID].folders[x]);
            }
          }
        }
      }
      return r;
    };

    self.getAllStudentClassFoldersWithLearningGoalCount = function(goal){
      var c = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        var r = self.getStudentClassFoldersWithLearningGoal(self.currentClass.students[i], null, goal);
        c += r.length;
      }

      return c;
    };

    self.getStudentClassFoldersWithLearningGoalCount = function(student, folder, goal){
      var r = self.getStudentClassFoldersWithLearningGoal(student, folder, goal);
      return r.length;
    };

    self.getAllStudentClassFoldersWithTaskCount = function(task,foldername){
      var c = 0;
      for(var i=0; i < self.currentClass.students.length; i++){
        var r = self.getStudentClassFoldersWithTask(self.currentClass.students[i], null, task);
        if(foldername){
          var found = false;
          for(var z=0; z < r.length; z++)
            if(r[z].Name == foldername){found = true; break;}
          if(!found) continue;
          c++;
        }else
          c += r.length;
      }

      return c;
    };

    self.findStudentClassFolderWithNameAndTask = function(student,foldername, task){
      if(self.users[student.ID] &&
         self.users[student.ID].classContent &&
         self.users[student.ID].classContent[self.currentClass.ID] &&
         self.users[student.ID].classContent[self.currentClass.ID].folders){
        for(var x=0; x < self.users[student.ID].classContent[self.currentClass.ID].folders.length; x++){
          if(self.users[student.ID].classContent[self.currentClass.ID].folders[x].Name != foldername) continue;
          if(!self.users[student.ID].classContent[self.currentClass.ID].folders[x].items) continue;
          for(var z=0; z < self.users[student.ID].classContent[self.currentClass.ID].folders[x].items.length; z++){
            if(self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Owner == student.ID &&
               self.users[student.ID].classContent[self.currentClass.ID].folders[x].items[z].Task == task.ID){
              return self.users[student.ID].classContent[self.currentClass.ID].folders[x];
            }
          }
        }
      }
      return null;
    };

    self.getStudentClassFoldersWithTaskCount = function(student, folder, task){
      var r = self.getStudentClassFoldersWithTask(student, folder, task);
      return r.length;
    };
    self.getStudentClassFoldersWithRubricCount = function(student, folder, rubric, task){
      var r = self.getStudentClassFoldersWithRubric(student, folder, rubric, task);
      return r.length;
    };

    self.findPersonalClassFolderByName = function(n){
      if(self.currentClass){
        if(!self.classContent || !self.classContent[self.currentClass.ID] || !self.classContent[self.currentClass.ID].folders) return null;
        for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
          if((self.classContent[self.currentClass.ID].folders[i].Share == 0 ||
              self.classContent[self.currentClass.ID].folders[i].Share == 3) && self.classContent[self.currentClass.ID].folders[i].Name == n)
            return self.classContent[self.currentClass.ID].folders[i];
        }
      }
      return null;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getStudentFolderFrameColor = function($scope,user){
      if($scope.selectedStudent && $scope.selectedStudent.ID == user.ID) return "#039AF4";
      var itemCount = 0;
      for(var i=0; i < self.currentClassFolder.items.length; i++){
        if(self.currentClassFolder.items[i].Owner == user.ID) itemCount++;
      }
      if(itemCount > 0) return '#92eab9';
      return '#fff';
    };
    self.isClassFolderHiddenFor = function(folder,student){
      if((","+folder.hiddenFor+",").indexOf(","+student.ID+",") != -1) return true; 
      return false;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.createClassFolder = function(withTarget,ev){
      if(self.user.Teacher == 0 && self.classContent[self.currentClass.ID] &&
        (!self.classContent[self.currentClass.ID].folders ||
          self.classContent[self.currentClass.ID].folders.length == 0)){
         if(!self.openStudentIntroFolders(withTarget,ev)) return;
      }
      if(self.user.Teacher == 1 && self.classContent[self.currentClass.ID] &&
        (!self.classContent[self.currentClass.ID].folders ||
          self.classContent[self.currentClass.ID].folders.length == 0)){
         if(!self.openTeacherIntroFolders(withTarget,ev)) return;
      }

      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclassfolder.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.folder = {};
            $scope.folder.Share = self.user.Teacher == 1 ? 2 : 0;
            $scope.folder.Feedback = "1";
            $scope.folder.Owner = self.user.ID;
            $scope.folder.Name = "";
            $scope.folder.vFrom = 0;
            $scope.folder.vTo = 0;
            $scope.folder.hiddenFor = "";
            $scope.folder.hiddenTeachers = "";
            $scope.folder.Color = "#eeeeee";
            $scope.folder.Icon = "fa fa-folder-o";
            $scope.isEdit = false;
            $scope.iconList = self.taskIconList;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.colorChoice = self.folderColors;

            $scope.save = function(ev) {
              if(!$scope.folder.Name || $scope.folder.Name == "") return;
              if($scope.folder.Share == 3 && $scope.folder.hiddenTeachers && $scope.folder.hiddenTeachers != ""){
                var parts = $scope.folder.hiddenTeachers.split(",").map(Number);
                if(parts.length == self.currentClass.teachers.length){
                  self.alert('<div style="max-width:500px">'+$filter('trans')('FOLDERREQUIRESTEACHER')+'</div>',ev);
                  return;
                }
              }
              var exists = self.findPersonalClassFolderByName($scope.folder.Name);
              if(exists){
                self.alert('<div style="max-width:500px">'+$filter('trans')('FOLDERNAMEUSED')+'</div>',ev);
                return;
              }
              self.apiPost("ajax",{"action":"createClassFolder", "ID":self.currentClass.ID,
                                   "Name":$scope.folder.Name,  "Icon":$scope.folder.Icon,
                                   "Color":$scope.folder.Color, "Share":$scope.folder.Share,
                                   "Feedback":$scope.folder.Feedback,
                                   "hiddenFor":$scope.folder.hiddenFor,
                                   "hiddenTeachers":$scope.folder.hiddenTeachers,
                                   "vFrom":$scope.folder.vFrom, "vTo":$scope.folder.vTo})
               .then(function(data) {
                  // we created a folder
                  self.keepAliveCallback().then(function(){
                    var f = self.findClassFolder(data.folder.ID);
                    if(withTarget){
                      if(withTarget.tasks)
                        self.sendLearningGoalToClassFolder(withTarget,f,self.user,ev); else
                        self.sendTaskToClassFolder(withTarget,f,self.user,ev);
                    }else{
                      self.openClassFolder(f);
                    }
                  });
                  self.closeDialog($scope.dialogElement);
                  self.track("createclassfolder",data.folder);
                  deferred.resolve(data.folder);
               });
            };

            // invert select for new student folders to start with only 1 student
            $scope.changeShareSetting = function() {
              if($scope.folder.Share == 3){
                if(!$scope.folder.hiddenFor || $scope.folder.hiddenFor == ""){
                  var list = [];
                  for(var i = 0; i < self.currentClass.students.length; i++)
                    if(self.user.ID != self.currentClass.students[i].ID) list.push(self.currentClass.students[i].ID);
                  $scope.folder.hiddenFor = list.join(",");
                }
              }
            };

            $scope.countStudentsVisible = function(){
              var r = self.currentClass.students.length;
              if($scope.folder.Share == 3){
                if($scope.folder.hiddenFor && $scope.folder.hiddenFor != ""){
                  var hiddenFor = $scope.folder.hiddenFor.split(',').map(Number);
                  for(var i=0; i < self.currentClass.students.length; i++){
                    if(hiddenFor.indexOf(self.currentClass.students[i].ID) != -1) r--;
                  }
                }
              }        
              return r;
            };

            $scope.isTeacherHidden = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === '') return false;
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++) if(n[i] == u.ID) return true;
              return false;
            };
            $scope.toggleHideTeacher = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === ""){
                $scope.folder.hiddenTeachers = u.ID;
                return;
              }
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++)
                if(n[i] == u.ID){
                  // is in, remove it
                  n.splice(i,1);
                  $scope.folder.hiddenTeachers = n.join(",");
                  return;
                }
              $scope.folder.hiddenTeachers += ','+u.ID;
            };

            $scope.cancel = function(ev) {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    
    self.createStudentClassFolders = function(ev){
      if(!self.openTeacherIntroStudentFolders(ev)) return;
 
      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclassfolder.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.createStudentClassFolders = true; // to show additional Description and remove some options
            $scope.folder = {};
            $scope.folder.Share = 0;
            $scope.folder.Feedback = "1";
            $scope.folder.Owner = self.user.ID;
            $scope.folder.Name = "";
            $scope.folder.Tags = "";
            $scope.folder.vFrom = 0;
            $scope.folder.vTo = 0;
            $scope.folder.hiddenFor = "";
            $scope.folder.hiddenTeachers = "";
            $scope.folder.Color = "#eeeeee";
            $scope.folder.Icon = "fa fa-folder-o";
            $scope.isEdit = false;
            $scope.iconList = self.taskIconList;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.colorChoice = self.folderColors;

            $scope.save = function(ev) {

              if(!$scope.folder.Name || $scope.folder.Name == "") return;
              self.apiPost("ajax",{"action":"createStudentClassFolders", "ID":self.currentClass.ID,
                                   "Name":$scope.folder.Name,  "Icon":$scope.folder.Icon,
                                   "Color":$scope.folder.Color, "Share":$scope.folder.Share,
                                   "Tags":$scope.folder.Tags,
                                   "Feedback":$scope.folder.Feedback,
                                   "hiddenFor":$scope.folder.hiddenFor,
                                   "hiddenTeachers":$scope.folder.hiddenTeachers,
                                   "vFrom":$scope.folder.vFrom, "vTo":$scope.folder.vTo})
               .then(function(data) {
                  // we created the folders
                  self.keepAliveCallback().then(function(){
                    self.closeDialog($scope.dialogElement);
                  });
               });
            };

            $scope.isTeacherHidden = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === '') return false;
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++) if(n[i] == u.ID) return true;
              return false;
            };
            $scope.toggleHideTeacher = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === ""){
                $scope.folder.hiddenTeachers = u.ID;
                return;
              }
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++)
                if(n[i] == u.ID){
                  // is in, remove it
                  n.splice(i,1);
                  $scope.folder.hiddenTeachers = n.join(",");
                  return;
                }
              $scope.folder.hiddenTeachers += ','+u.ID;
            };
            $scope.cancel = function(ev) {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editClassFolder = function(it,ev){
      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclassfolder.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.folder = JSON.parse(angular.toJson(it));
            $scope.iconList = self.taskIconList;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.colorChoice = self.folderColors;
            $scope.isEdit = true;
            $scope.save = function(ev) {
              if(!$scope.folder.Name || $scope.folder.Name == "") return;
              if($scope.folder.Share == 3 && $scope.folder.hiddenTeachers && $scope.folder.hiddenTeachers != ""){
                var parts = $scope.folder.hiddenTeachers.split(",").map(Number);
                if(parts.length == self.currentClass.teachers.length){
                  self.alert('<div style="max-width:500px">'+$filter('trans')('FOLDERREQUIRESTEACHER')+'</div>',ev);
                  return;
                }
              }

              var exists = self.findPersonalClassFolderByName($scope.folder.Name);
              if(exists && exists.ID != $scope.folder.ID){
                self.alert('<div style="max-width:500px">'+$filter('trans')('FOLDERNAMEUSED')+'</div>',ev);
                return;
              }

              var p = {"action":"updateClassFolder", "ID":$scope.folder.ID,
                       "Name":$scope.folder.Name,  "Icon":$scope.folder.Icon, 
                       "Color":$scope.folder.Color, "Share":$scope.folder.Share,
                       "Tags":$scope.folder.Tags,
                       "Feedback":$scope.folder.Share == 3 ? 1 : $scope.folder.Feedback,
                       "locked":$scope.folder.locked == 1 ? 1 : 0,
                       "hiddenFor":$scope.folder.hiddenFor,
                       "hiddenTeachers":$scope.folder.hiddenTeachers,
                       "vFrom":$scope.folder.vFrom, "vTo":$scope.folder.vTo};
              if(self.user.Teacher == 1) p.fixed = 1;
              self.apiPost("ajax",p)
               .then(function(data) {
                  // we created a folder
                  self.closeDialog($scope.dialogElement);
                  self.keepAliveCallback().then(function(){
                    if(self.user.Teacher == 1){
                      var f = self.findClassFolder(data.folder.ID);
                      self.openClassFolder(f,null,self.user.Teacher == 0,ev);
                    }
                    self.track("saveclassfolder",data.folder);
                    deferred.resolve(data.folder);
                  });
               });
            };

            // invert select for new student folders to start with only 1 student
            $scope.changeShareSetting = function() {
              if($scope.folder.Share == 3){
                if(!$scope.folder.hiddenFor || $scope.folder.hiddenFor == ""){
                  var list = [];
                  for(var i = 0; i < self.currentClass.students.length; i++)
                    if(self.user.ID != self.currentClass.students[i].ID) list.push(self.currentClass.students[i].ID);
                  $scope.folder.hiddenFor = list.join(",");
                }
              }
            };

            $scope.countStudentsVisible = function(){
              var r = self.currentClass.students.length;
              if($scope.folder.Share == 3){
                if($scope.folder.hiddenFor && $scope.folder.hiddenFor != ""){
                  var hiddenFor = $scope.folder.hiddenFor.split(',').map(Number);
                  for(var i=0; i < self.currentClass.students.length; i++){
                    if(hiddenFor.indexOf(self.currentClass.students[i].ID) != -1) r--;
                  }
                }
              }        
              return r;
            };

            $scope.isTeacherHidden = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === '') return false;
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++) if(n[i] == u.ID) return true;
              return false;
            };
            $scope.toggleHideTeacher = function(u){
              if(!$scope.folder.hiddenTeachers || $scope.folder.hiddenTeachers === ""){
                $scope.folder.hiddenTeachers = u.ID;
                return;
              }
              var n = $scope.folder.hiddenTeachers.split(',').map(Number);
              for(var i=0; i < n.length; i++)
                if(n[i] == u.ID){
                  // is in, remove it
                  n.splice(i,1);
                  $scope.folder.hiddenTeachers = n.join(",");
                  return;
                }
              $scope.folder.hiddenTeachers += ','+u.ID;
            };

            $scope.cancel = function(ev) {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.setClassFolderVisibility = function(it, ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "classContentVisibility.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open
        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          var c = self.currentClass;
          $scope.self = self;
          $scope.it = it;
          $scope.c = c;
          $scope.selection = [];
          $scope.disabled = [];
          $scope.smallScreen = self.isSmallScreen;
          $scope.isTeacher = self.user.Teacher == 1;
          $scope.hideTimes = !(it.Share == 1 || it.Share == 2);
          if(self.user.Teacher == 0) {
            $scope.disabled.push(self.user.ID);
            $scope.selection.push(self.user.ID);
            $scope.required = [];
            $scope.required.push(self.user.ID);
          }
          var hiddenFor = it.hiddenFor.split(",").map(Number);
          for(var z=0; z < c.students.length; z++){
            if(hiddenFor.indexOf(c.students[z].ID) == -1){
              $scope.selection.push(c.students[z].ID);
            }
          }

          self.addContentVisibilityScope($scope);

          $scope.save = function() {
            // apply $scope.selection to current folder visibility
            var hiddenFor = [];
            for(var i=0; i < c.students.length; i++){
              var isIn = false;
              for(var z=0; z < $scope.selection.length; z++){
                if($scope.selection[z] == c.students[i].ID) isIn = true;
              }
              if(!isIn) hiddenFor.push(c.students[i].ID);
            }
            // update data on it now
            it.hiddenFor = hiddenFor.join(",");
            if(it.vFrom != $scope.vFromDateTime || it.vTo != $scope.vToDateTime){
              if(!(!it.vFrom && !$scope.vFromDateTime && !it.vTo && !$scope.vToDateTime)){
                it.vFrom = $scope.vFromDateTime;
                it.vTo = $scope.vToDateTime;
                self.lastFromTime = it.vFrom || self.lastFromTime;
                self.lastToTime = it.vTo || self.lastToTime;
              }
            }
            self.closeDialog($scope.dialogElement);
            deferred.resolve($scope.selection);
          };

          $scope.cancel = function (){
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.selectClassFolderTarget = function(ev){
      var deferred = $q.defer();
      var c = 0;
      for(var i = 0; i < self.classList.length; i++){
        if(self.classList[i].Archived == 1) continue;
        if(self.classList[i].Active != 1) continue;
        if(self.user.Teacher == 1 && !self.hasClassChangePermission(self.classList[i])) continue;
        if(!self.classContent[self.classList[i].ID].folders || self.classContent[self.classList[i].ID].folders.length == 0) continue;
        c++;
      }
      if(c == 0){
        self.alert($filter('trans')('NOOTHERCLASSESWITHFOLDERS'));
        return deferred.promise;
      }
      self.showDialog({
        templateUrl: "selectClassFolderTarget.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.targetClass = null;
          $scope.targetFolder = null;
          var newest = "";
          
          if(self.lastSelectClassFolderTarget){
            for(var i=0; i < self.classList.length; i++){
              if(self.classContent[self.classList[i].ID].folders)
              for(var z=0; z < self.classContent[self.classList[i].ID].folders.length; z++){
                if(self.classContent[self.classList[i].ID].folders[z].ID == self.lastSelectClassFolderTarget){
                  $scope.targetClass = self.classList[i];
                  $scope.targetFolder = self.classContent[self.classList[i].ID].folders[z];
                  break;
                }
              }
            }
          }

          $scope.copy = function(ev) {
            if(!$scope.targetClass) return;
            if(!$scope.targetFolder) return;
            deferred.resolve($scope.targetFolder);
            self.lastSelectClassFolderTarget = $scope.targetFolder.ID;
            self.closeDialog($scope.dialogElement);
          };

          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.moveClassFolder = function(it,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "moveClassFolderTarget.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.targetClass = null;
          $scope.folder = it;
          var newest = "";
          for(var i=0; i < self.classList.length; i++){
            if(self.classList[i].ID == self.currentClass.ID) continue;
            if(self.lastMoveFolderTarget && self.lastMoveFolderTarget == self.classList[i].ID && self.hasClassChangePermission(self.classList[i])){
              $scope.targetClass = self.classList[i];
              break;
            }
            if(self.classList[i].Created > newest && self.hasClassChangePermission(self.classList[i])){
              $scope.targetClass = self.classList[i];
              newest = self.classList[i].Created;
            }
          }
          $scope.move = function() {
            if(!$scope.targetClass) return;
            self.apiPost("ajax",{"action":"moveClassFolder", "ID":it.ID, "target":$scope.targetClass.ID })
             .then(function(data) {
                self.lastMoveFolderTarget = $scope.targetClass.ID;
                // we moved a folder
                if(self.currentClassFolder && self.currentClassFolder.ID == it.ID){
                  self.closeClassFolder();
                }
                self.keepAliveCallback();
                deferred.resolve($scope.targetClass);
             });
          };

          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };

    self.deleteClassFolder = function(it){
      var deferred = $q.defer();
      var deleteNow = function(){
        self.apiPost("ajax",{"action":"removeClassFolder", "ID":it.ID })
         .then(function(data) {
            // we removed a folder
            if(self.currentClassFolder && self.currentClassFolder.ID == it.ID){
              self.closeClassFolder();
            }
            if(self.classContent && self.classContent[it.Class] && self.classContent[it.Class].folders){
              for(var i=0; i < self.classContent[it.Class].folders.length; i++)
                if(self.classContent[it.Class].folders[i].ID == it.ID){
                  self.classContent[it.Class].folders.splice(i,1);
                  break;
                }
            }
            self.keepAliveCallback();
            self.track("removeclassfolder",it);
            deferred.resolve();
         });
      };
      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDER',it.Name)+'</span>',$filter('trans')('DELETE'),null).then(function(){
        if(it.items.length > 0)
          self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERCONFIRM',it.items.length)+'</span>',$filter('trans')('DELETE'),null).then(function(){
            deleteNow();
          });
          else deleteNow();
      });
      return deferred.promise;
    };

    self.setClassFolderLocked = function(it,value){
      if(value == 1)
        self.confirm($filter('trans')('ASKLOCKCLASSFOLDER',it.Name),$filter('trans')('LOCK'),null).then(function(){
          self.apiPost("ajax",{"action":"lockClassFolder", "ID":it.ID}).then(function(data) {
            it.Locked = 1;
          });
        });
      if(value == 0)
        self.apiPost("ajax",{"action":"unlockClassFolder", "ID":it.ID}).then(function(data) {
          it.Locked = 0;
        });
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.addClassFolderItem = function(it,ev){
      var deferred = $q.defer();
      var createNow = function(ownership){
        var p = {"action":"addClassFolderItem", "ID":it.ID, "Type":"page", "Title":moment().format('DD.MM.YYYY'), "Content":''};
        if(ownership) p.student = it.Owner;
        self.showLoadingIndicator(ev,function(done){
          self.apiPost("ajax",p).then(function(data) {
            // we added a new folder item
            self.keepAliveCallback().then(function(){
              for(var i=0; i < it.items.length; i++){
                if(it.items[i].ID == data.item.ID){
                  self.openClassFolderItem(it.items[i],ev);
                  self.track("addclassfolderitem",it.items[i]);
                  self.addClassFolderItemContent(it.items[i],'text',0,ev);
                  deferred.resolve(it.items[i]);
                  break;
                }
              }
              done();
            });
          });
        });
      };

      if(self.user.Teacher == 1 && it.Share == 0){
        self.confirm($filter('trans')('ASKDUPLICATEFOLDERITEMOWNERSHIPUSER',self.users[it.Owner].Name),$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
          createNow(true);
        },function(){
          createNow(false);
        });
      }else 
        createNow(false);

      return deferred.promise;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.changeClassFolderItem = function(value,selectedStudent){
      if(!self.currentClassFolder) return;
      if(!self.currentClassFolderItem) return;
      var list = self.currentClassFolder.items;
      if(selectedStudent || (self.folderSearchTerm && self.folderSearchTerm != '')){
        list = [];
        for(var i=0; i < self.currentClassFolder.items.length; i++){

          if((selectedStudent && self.currentClassFolder.items[i].Owner == selectedStudent.ID) ||
             (self.folderSearchTerm && self.folderSearchTerm != '' && self.searchInClassFolderItem(self.currentClassFolder.items[i]))) {
            list.push(self.currentClassFolder.items[i]);
          }
        }
      }

      for(var i=0; i < list.length; i++){
        if(list[i].ID == self.currentClassFolderItem.ID){
          if(value > 0){
             while(value > 0){value--; i++;}
          }
          if(value < 0){
             while(value < 0){value++; i--;}
          }
          if(i >= 0 && i <= list.length-1){
            self.openClassFolderItem(list[i]);
          }else{
            // self.currentClassFolderItem = null; // back to page list
          }
          break;
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.countClassFolderItemOtherAuthorsContent = function(it){
      if(!it) return 0;

      var c = 0;
      for(var i=0; i < it.contents.length; i++){
        if(it.contents[i].Owner != it.Owner) c++;
      }
      return c;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveClassFolderItemTitle = function(it){
      // data has changed, save back to server
      self.apiPost("ajax",{"action":"updateClassFolderItem", "ID":it.ID, "Title":it.Title});
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveClassFolderItemTags = function(it){
      // data has changed, save back to server
      self.apiPost("ajax",{"action":"updateClassFolderItem", "ID":it.ID, "Tags":it.Tags}).then(function(){
        self.keepAliveCallback().then(function(){
          self.track("saveclassfolderitemtags",it);
          $timeout(function(){
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
            self.updateNewFolderItemsBadge();                      
          },1500);
          for(var i=0; i< self.currentClassFolder.items.length; i++){
            if(self.currentClassFolder.items[i].ID == it.ID){
              self.currentClassFolder.items[i].isNew = false;
              break;
            }
          }
        });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.saveClassFolderItemLocked = function(it){
      // data has changed, save back to server
      self.apiPost("ajax",{"action":"updateClassFolderItem", "ID":it.ID, "Locked":it.Locked});
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.pickEmoji = function(ev,callback){
      var openEmojiPicker = function(){
        var picker = null;
        if(self.currentEmojiPicker){
          self.closeDialog(self.currentEmojiPicker);
          self.currentEmojiPicker = false;
          return;
        }
        self.showDialog({
          template:
              '<md-dialog style="min-width:300px;max-width:90%">' +
              '  <md-button md-autofocus="true" aria-label="close" style="position:absolute;right:0;top:0;z-index:3;width: 28px; padding: 0;min-width: 1em;margin:0" ng-click="cancel()"><i class="fa fa-fw fa-times"></i></md-button>'+
              '  <md-content aria-label="Emoji" id="emojiPicker"></md-content>' +
              '</md-dialog>',
          skipHide:true, // keep other dialog open
          clickOutsideToClose: true,
          targetEvent: ev,
          onRemoving: function (event, removePromise) {
            if(picker) picker.remove();
            self.currentEmojiPicker = null;
          },
          controller: function ($scope, $mdDialog) {
            var pickerOptions = { 
              data:emoji_data, // will come from emoji_data.js
              i18n:emoji_de, 
              locale:"de", 
              theme:"light", 
              dynamicWidth:true,
              previewPosition:"none",
              categories : ["frequent", "people", "nature", "foods", "activity", "places", "objects", "symbols"],  
              exceptEmojis:[],
              perLine:8,
              emojiButtonSize: 50,
              emojiSize: 38,
              icons: 'solid',
              onEmojiSelect: function(e){ 
                console.log(e); 
                self.closeDialog($scope.dialogElement);
                if(callback) callback(e.native);
              }
            };
            $scope.cancel = function(){
              self.closeDialog($scope.dialogElement);              
            }
            setTimeout(function(){
              pickerOptions.parent = document.querySelector('#emojiPicker');
              $(pickerOptions.parent).html("");
              picker = new EmojiMart.Picker(pickerOptions);
              self.currentEmojiPicker = $scope.dialogElement;
            },100);
          }
        });                  
      };
      if(!window.hasEmojiPicker){
        loadScript("https://learningview.org/emojis/emoji_data.js",function(){
          loadScript("https://learningview.org/emojis/browser.js",function(){
            window.hasEmojiPicker = true;
            openEmojiPicker();
          });
        });
      } else {
        openEmojiPicker();
      }      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.classFolderItemContentClicked = function(it,content,item,ev){
      if(content.Type == "emoji"){
        // pick one emoji and highlight it
        if(ev.target.nodeName == "SPAN"){
          if($(ev.target).hasClass("selectedEmoji")){
            $(ev.target).removeClass("selectedEmoji");
          }else{
            $("span", $(ev.target).parent()).removeClass("selectedEmoji");
            $(ev.target).addClass("selectedEmoji");
          }
          content.DataJSON.text = self.trimHTML($(ev.target).parent().html());
          self.saveClassFolderItemContent(content);
          ev.stopPropagation();
        }
      }
      if(content.Type == "checklist"){
        item.checked = item.checked == 1 ? 0 : 1;
        self.saveClassFolderItemContent(content);
        ev.stopPropagation();
      }
    };

    self.addClassFolderItemContent = function(it,type,position,ev){
      if(position == -1) position = self.currentClassFolderItem.contents.length;
      var deferred = $q.defer();
      var json = {}; // create default data based on type
      if(type == "text"){
        json.text = "";
        self.showLoadingIndicator(null,function(done){
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            done();
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });
        }); 
        return deferred.promise;
      }
      if(type == "headline"){
        json.text = "<b>"+ $filter('trans')('HEADLINE') +"</b>";
        json.headline = true;
        json.size = "120%";
        self.lastSaveClassFolderItemContentHeadlineBackground
        if(self.lastSaveClassFolderItemContentHeadlineBackground){
          json.background = self.lastSaveClassFolderItemContentHeadlineBackground;
        }
        // json.color
        self.showLoadingIndicator(null,function(done){
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":"text", "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            done();
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });
        }); 
        return deferred.promise;
      }
      if(type == "checklist"){
        json.items = [{ID:1,text:"",checked:0},{ID:2,text:"",checked:0},{ID:3,text:"",checked:0}];
        self.showLoadingIndicator(null,function(done){
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            done();
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });
        }); 
        return deferred.promise;
      }
      if(type == "choice"){
        json.items = [{ID:1,text:"A"},{ID:2,text:"B"},{ID:3,text:"C"}];
        json.value = 1; // 1 is selected now
        self.showLoadingIndicator(null,function(done){
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            done();
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });
        }); 
        return deferred.promise;
      }
      if(type == "rubric"){
        // unused right now
        self.pickRubrics(null, true, function(results,wasCreated){
          json.rubric = self.getRubricByID(results[0]).GUID;
          json.linked = true;
          // if rubric was selected from elsewhere, mark as link
          if(wasCreated){
            if(wasCreated[self.getRubricByID(results[0]).ID]){
              delete(json.linked); // no link
            }
          }
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });          
        },{type:"folder",folder:it});
        return deferred.promise;
      }
      if(type == "tasks"){
        self.pickTasks(null, self.currentClass.ID, null, function(selected){
          //if(selected.length == 0) return;
          json.tasks = selected; // list of task ids
          self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            if(position == 0)
              it.contents.push(data.content); else
              it.contents.splice(position,0,data.content);
            self.classFolderItemContentSelect(it,data.content);
            self.track("addclassfolderitemcontent",data.content);
            deferred.resolve(data.content);
            self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          });          
        });
        return deferred.promise;
      }
      if(type == "emoji"){
        json.text = "";
        self.pickEmoji(ev,function(result){
          json.text = '<span>'+result+'</span>';
          self.showLoadingIndicator(null,function(done){
            var lastElement = null;
            if(position == 0) {
              if(it.contents.length > 0) lastElement = it.contents[it.contents.length-1];
            }else {
              lastElement = it.contents[position-1];
            }
            if(lastElement && lastElement.Type == type && (lastElement.Owner == self.user.ID || self.user.Teacher == 1)) {
              // append emoji on last emoji element, combine them
              lastElement.DataJSON.text = self.trimHTML(lastElement.DataJSON.text+" "+json.text);
              self.saveClassFolderItemContent(lastElement);
            }else{
              // add new element
              self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
                data.content.DataJSON = JSON.parse(data.content.Data);
                if(position == 0)
                  it.contents.push(data.content); else
                  it.contents.splice(position,0,data.content);
                self.classFolderItemContentSelect(it,data.content);
                self.track("addclassfolderitemcontent",data.content);
                done();
                deferred.resolve(data.content);
                self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
              });
            }                    
          });     
        });
        return deferred.promise;   
      }

      var dM = 0;
      if(type == 'audio' || type == 'video') dM = 1;

      self.currentTask = null; // reset if there is one now
      self.takeUserMedia(type,null,function(results){
        self.showLoadingIndicator(null,function(done){
          var total = 0;
          for(var i = 0; i < results.length; i++) {
            json.URL = results[i].URL;
            if(results[i].Type == "file"){
              json.URL = json.URL + "?filename="+encodeURIComponent(results[i].Name);
            }
            self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, "Type":results[i].Type, "Data":JSON.stringify(json)}).then(function(data) {
              total++;
              if(total == results.length){
                data.content.DataJSON = JSON.parse(data.content.Data);  
                if(position == 0)
                  it.contents.push(data.content); else
                  it.contents.splice(position,0,data.content);
                self.classFolderItemContentSelect(it,data.content);
                self.track("addclassfolderitemcontent",data.content);
                done();          
                deferred.resolve(data.content);
                self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
              }
            });
          }
        });
      }, {dialogMode:dM, allowMultiple:true});
      return deferred.promise;      
    };

    self.countClassFolderItemTextContentParts = function(content){
      if(content.DataJSON.text && content.DataJSON.text  != ''){
        var parts = content.DataJSON.text.replace(/<br><\/span><br>/g,"</span><br><br>").replace(/<\/table><br>/g,"</table><br><br>").replace(/<div><br><\/div>/g,"<br><br>").replace(/<p>\s*<\/p>/g,"<br><br>").replace(/<p><br><\/p>/g,"<br><br>").split("<br><br>");
        return parts.length;
      }
      return 1;
    };

    self.splitClassFolderItemTextContentParts = function(content,position){
      if(content.DataJSON.text && content.DataJSON.text  != ''){
        var parts = content.DataJSON.text.replace(/<br><\/span><br>/g,"</span><br><br>").replace(/<\/table><br>/g,"</table><br><br>").replace(/<div><br><\/div>/g,"<br><br>").replace(/<p>\s*<\/p>/g,"<br><br>").replace(/<p><br><\/p>/g,"<br><br>").split("<br><br>");
        var i = 1;
        if(parts.length <= 1) return;
        var addNextText = function(){
          var now = JSON.parse(angular.toJson(content.DataJSON));
          now.text = parts[i];
          var p = {"action":"addClassFolderItemContent", "ID":self.currentClassFolderItem.ID,
           "pos":position, "Type":"text", "Data":JSON.stringify(now)};
          if(content.Owner != self.user.ID) p.student = content.Owner;
          self.apiPost("ajax",p).then(function(data) {
            data.content.DataJSON = JSON.parse(data.content.Data);
            self.currentClassFolderItem.contents.push(data.content);
            i++;
            position++;
            if(i < parts.length){
              addNextText();              
            }else{
              self.keepAliveCallback();
            }
          });
        };
        addNextText();
        content.DataJSON.text = parts[0];
        content.newText = content.DataJSON.text;
        content.Data = angular.toJson(content.DataJSON);
        self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Data":content.Data}).then(function(){
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          self.track("saveclassfolderitemcontent",content);  
        });
      }      
    };

    self.saveClassFolderItemTextContent = function(content,ev){
      $timeout(function(){
        var old = content.DataJSON.text;
        content.DataJSON.text = self.trimHTML(content.newText);
        self.replaceBase64Images(content.DataJSON.text).then(function(desc){        
          if(old != desc) content.newText = desc;
          content.DataJSON.text = desc;
          if(content.DataJSON.text == old) return; // still the same
          self.saveClassFolderItemContent(content);
        }); 
      },0);
    };

    self.saveClassFolderItemChecklistContent = function(content,check,newText,ev){
      if(!content.saveChecklistDelay) content.saveChecklistDelay = [];
      if(content.saveChecklistDelay[check.ID])
        $timeout.cancel(content.saveChecklistDelay[check.ID]);

      content.saveChecklistDelay[check.ID] = $timeout(function(){
        if(check.text == newText) return;
        check.text = newText;
        content.Data = angular.toJson(content.DataJSON);
        var saved = content.Data;
        self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Data":content.Data}).then(function(){
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          self.track("saveclassfolderitemcontent",content);          
        });
        content.saveChecklistDelay[check.ID] = null;
      },500);
    };    
    self.saveClassFolderItemChecklistCheck = function(content,check,value,ev){
      check.checked = value;
      content.Data = angular.toJson(content.DataJSON);
      var saved = content.Data;
      self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Data":content.Data}).then(function(){
        self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
        self.track("saveclassfolderitemcontent",content);          
      });
    };    
    self.addClassFolderItemChecklistContent = function(content,ev){
      self.showLoadingIndicator(null,function(done){
        $timeout(function(){
          var maxID = 0;
          for(var i=0; i < content.DataJSON.items.length; i++){
            maxID = Math.max(maxID, content.DataJSON.items[i].ID);
          }
          content.DataJSON.items.push({ID:maxID+1, text:"", checked:0});
          self.saveClassFolderItemContent(content);
          $timeout(done,1000);
        },0);
      });
    };
    self.addClassFolderItemChoiceContent = function(content,ev){
      self.showLoadingIndicator(null,function(done){
        $timeout(function(){
          var maxID = 0;
          for(var i=0; i < content.DataJSON.items.length; i++){
            maxID = Math.max(maxID, content.DataJSON.items[i].ID);
          }
          content.DataJSON.items.push({ID:maxID+1, text:""});
          self.saveClassFolderItemContent(content);
          $timeout(done,1000);
        },0);
      });
    };
    self.saveClassFolderItemChoiceContent = function(content,check,newText,ev){
      if(!content.saveChoiceDelay) content.saveChoiceDelay = [];
      if(content.saveChoiceDelay[check.ID])
        $timeout.cancel(content.saveChoiceDelay[check.ID]);

      content.saveChoiceDelay[check.ID] = $timeout(function(){
        if(check.text == newText) return;
        check.text = newText;
        content.Data = angular.toJson(content.DataJSON);
        var saved = content.Data;
        self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Data":content.Data}).then(function(){
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
          self.track("saveclassfolderitemcontent",content);          
        });
        content.saveChoiceDelay[check.ID] = null;
      },500);
    };  
    self.getClassFolderItemChoiceColor = function(content,ev){
      if(content.DataJSON.items)
        for(var i=0; i < content.DataJSON.items.length; i++){
          if(content.DataJSON.items[i].ID == content.DataJSON.value){
            return content.DataJSON.items[i].background ? content.DataJSON.items[i].background : '';
          }
        }
      return '';
    };

    self.removeClassFolderItemChoiceContent = function(content,check,ev){
      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERITEMCHOICEITEM')+'</span>',$filter('trans')('DELETE'),null).then(function(){
        self.showLoadingIndicator(null,function(done){
          var pos = content.DataJSON.items.indexOf(check);
          if(pos != -1){
            content.DataJSON.items.splice(pos,1); 
            self.saveClassFolderItemContent(content);
          }
          $timeout(done,1000);
        });
      });
    };

    self.removeClassFolderItemChecklistContent = function(content,check,ev){
      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERITEMCHECKLISTITEM')+'</span>',$filter('trans')('DELETE'),null).then(function(){
        self.showLoadingIndicator(null,function(done){
          var pos = content.DataJSON.items.indexOf(check);
          if(pos != -1){
            content.DataJSON.items.splice(pos,1); 
            self.saveClassFolderItemContent(content);
          }
          $timeout(done,1000);
        });
      });
    };

    self.selectClassFolderItemTasksContent = function(content,ev){
      self.pickTasks(content.DataJSON.tasks, self.currentClass.ID, null, function(selected){
        //if(selected.length == 0) {
          // remove now
        //  self.removeClassFolderItemContent(self.currentClassFolderItem,content,ev);
        //  return;
        //}
        var existing = content.DataJSON.tasks || [];
        for(var i=0; i < existing.length; i++){
          if(selected.indexOf(existing[i]) == -1){
            existing.splice(i,1);
            i--;
          }
        }
        for(var i=0; i < selected.length; i++){
          if (existing.indexOf(selected[i]) == -1) {
              existing.push(selected[i]);
          }
        }
        content.DataJSON.tasks = existing; // list of task ids
        self.saveClassFolderItemContent(content);
      });
    };

    self.saveClassFolderItemContent = function(content){
      // data has changed, save back to server
      var id = self.currentClassFolder.ID;
      $timeout(function(){
        content.Data = angular.toJson(content.DataJSON);
        if(content.DataJSON.headline){
          self.lastSaveClassFolderItemContentHeadlineBackground = content.DataJSON.background;
        }
        var saved = content.Data;
        self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Data":content.Data}).then(function(){
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+id);
          self.track("saveclassfolderitemcontent",content);          
          self.keepAliveIntervalWorking = false;
          self.keepAliveCallback();
        });
      },0);
    };
    
    self.copyClassFolderItemContent = function(it,content,ev){
      self.currentClassFolderItemContentCopy = null;
      self.currentClassFolderItemCopy = null;
      $timeout(function(){
        self.currentClassFolderItemContentCopy = content;
        self.currentClassFolderItemCopy = it;
        // for bounce effect
      },10);
    };
    self.pasteClassFolderItemContent = function(it,position){
      if(!self.currentClassFolderItemContentCopy) return;
      if(position == -1) position = it.contents.length;
      self.showLoadingIndicator(null,function(done){
        self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":it.ID, "pos":position, 
                             "Type":self.currentClassFolderItemContentCopy.Type, "Data":self.currentClassFolderItemContentCopy.Data}).then(function(data) {
          data.content.DataJSON = JSON.parse(data.content.Data);
          if(position == 0)
            it.contents.push(data.content); else
            it.contents.splice(position,0,data.content);
          self.classFolderItemContentSelect(it,data.content);
          self.track("addclassfolderitemcontent",data.content);
          done();
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
        });
      }); 
    };

    self.changeClassFolderItemOwner = function(item,owner){
      item.Owner = owner;
      self.apiPost("ajax",{"action":"updateClassFolderItem", "ID":item.ID, "Owner":item.Owner}).then(function(){
        self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
        self.keepAliveIntervalWorking = false;
        self.keepAliveCallback();
      });
    };

    self.changeClassFolderItemContentOwner = function(content,owner){
      content.Owner = owner;
      self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Owner":content.Owner}).then(function(){
        self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
        self.keepAliveIntervalWorking = false;
        self.keepAliveCallback();
      });
    };

    self.removeClassFolderItemContent = function(it,content,ev){
      if(content.Type == "emoji"){
        // allow delete of selected subitem
        var parts = content.DataJSON.text.split("</span>");
        if(parts.length > 2 && content.DataJSON.text.indexOf("selectedEmoji") > 0) {
          self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERITEMCONTENTEMOJI')+'</span>',$filter('trans')('DELETE'),null).then(function(){
            content.DataJSON.text = self.trimHTML(content.DataJSON.text.replace(/<span class="selectedEmoji">[^<]*<\/span>/,""));
            self.saveClassFolderItemContent(content);
            ev.stopPropagation();
          });
          return; 
        }
      }

      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERITEMCONTENT')+'</span>',$filter('trans')('DELETE'),null).then(function(){
        self.showLoadingIndicator(null,function(done){
          self.apiPost("ajax",{"action":"updateClassFolderItemContent", "ID":content.ID, "Deleted":1}).then(function(data) {
            self.keepAliveCallback().then(function(){
              self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
              self.track("removeclassfolderitemcontent",content);
              done();
            });
          });
        });
      });
    };
    self.updateClassFolderItemContentsOrder = function(){
      // save new order after move
      var list = [];
      for(var i=0; i < self.currentClassFolderItem.contents.length; i++){
        list.push(self.currentClassFolderItem.contents[i].ID);
        self.currentClassFolderItem.contents[i].OrderIndex = i;
      }
      self.showLoadingIndicator(null,function(done){
        self.apiPost("ajax",{"action":"updateClassFolderItemContentOrder", "ID":self.currentClassFolderItem.ID, "order":list.join(",")})
         .then(function(data) {
           self.keepAliveCallback().then(function(){
             self.setLastOpenTime("folder",self.currentClass.ID+'-'+self.currentClassFolder.ID);
             self.track("reorderclassfolderitemcontent",self.currentClassFolderItem);
             done();
           });
         });
      });
    };

    self.isClassFolderItemContentEditable = function(it){
      if(!it) return false;
      if(it.Owner != self.user.ID && self.user.Teacher == 0 && self.currentClassFolder.Share == 2 && it.Locked != 0) return false;
      if(self.user.Teacher == 0 && self.currentClassFolder.Locked == 1) return false;
      if(self.user.Teacher == 1 || it.Owner == self.user.ID || self.currentClassFolderItem.Owner == self.user.ID) return true;
      return false;
    };

    self.classFolderItemContentSelect = function(it,content,ev){
      if(!it) return;
      // check if the current user is allowed to edit this item
      var selectable = self.isClassFolderItemContentEditable(it) || (content && content.Owner == self.user.ID);

      for(var i=0; i < it.contents.length; i++){
        if(it.contents[i].selected && (!content || it.contents[i].ID != content.ID)){
          // get unselected
          if(it.contents[i].Type == "text")
            self.saveClassFolderItemTextContent(it.contents[i]);
          it.contents[i].selected = null;
        }else
        if(!it.contents[i].selected && content && it.contents[i].ID == content.ID) {
          if(selectable){
            if(it.contents[i].DataJSON.text)
               it.contents[i].newText = it.contents[i].DataJSON.text; // make a copy now to edit
            it.contents[i].selected = true;            
          }
        }
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.classFolderContentNeedsAuthor = function(it,content){
      if(!it) return false;
      var hasOtherOwners = false;
      for(var i=0; i < it.contents.length; i++){
        if(it.contents[i].Owner != it.Owner) { hasOtherOwners = true; break;}
      }
      for(var i=0; i < it.contents.length; i++){
        if(it.contents[i] == content && i > 0 && it.contents[i-1].Owner != it.contents[i].Owner) return true;
        if(it.contents[i] == content && i == 0 && hasOtherOwners) return true;
      }      
      return false;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openClassFolderItem = function(it,ev){
      // delay open new item to make sure we save last changes
      if(self.currentClassFolderItem){
        self.classFolderItemContentSelect(self.currentClassFolderItem,null);

        if(!it) {
          self.track("resetclassfolderitem",self.currentClassFolderItem);
        }

        if(self.currentClassFolderItem.isNew){
          self.currentClassFolderItem.isNew = false;
          self.updateNewFolderItemsBadge();
        }
      }

      self.currentClassFolderItem = it;

      if(!it) return;

      self.lastClassFolderItems[self.currentClassFolder.ID] = it;

      if(it.isNew) {
        it.isNew = false;
        self.updateNewFolderItemsBadge();
      }
      self.track("openclassfolderitem",it);

      var retry = 0;
      var findElement = function(){
        if(retry > 10) return; // 1 sec waited
        var d = $("#folderitem_"+it.ID)[0];
        if(d) {
          d.scrollIntoView({
            behavior: "smooth", // or "auto" or "instant"
            block: "nearest" // or "end"
          });
        }
        if(!d) { retry++; setTimeout(findElement,100); }
      };
      setTimeout(findElement,1);        
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassFolderItemsOrder = function(){
      // save new order after move
      var list = [];
      for(var i=0; i < self.currentClassFolder.items.length; i++){
        list.push(self.currentClassFolder.items[i].ID);
        self.currentClassFolder.items[i].OrderIndex = i;
      }
      self.apiPost("ajax",{"action":"updateClassFolderItemOrder", "ID":self.currentClassFolder.ID, "order":list.join(",")})
       .then(function(data) {
          // we added a new folder item
          self.keepAliveCallback();
          self.track("reorderclassfolderitems",self.currentClassFolder);
       });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateClassFolderItem = function(it,ev){
      if(it.Type == 'task' || it.Type == 'goal'){
        self.alert($filter('trans')('CANNOTDUPLICATEFOLDERITEMTYPE')).then(function(){
          self.duplicateClassFolderItemToOther(it,ev);
        });
        return;
      }
      var duplicateNow = function(ownership){        
        var p = {"action":"duplicateClassFolderItem", "ID":it.ID, "ownership" : ownership ? self.currentClassFolder.Owner : 0};

        self.showLoadingIndicator(ev,function(done){
          self.apiPost("ajax",p).then(function(data) {
            // we added a new folder item
            self.keepAliveCallback().then(function(){
              for(var i=0; i < self.currentClassFolder.items.length; i++){
                if(self.currentClassFolder.items[i].ID == data.item.ID){
                  self.openClassFolderItem(self.currentClassFolder.items[i],ev);
                  break;
                }
              }
              done();
            });
            self.track("duplicateclassfolderitem",it);
          });
        })        
      }
//      self.confirm($filter('trans')('ASKDUPLICATEFOLDERITEM'),$filter('trans')('COPY'),null).then(function(){
        if(self.user.Teacher == 1 && self.currentClassFolder.Share == 0){
          self.confirm($filter('trans')('ASKDUPLICATEFOLDERITEMOWNERSHIPUSER',self.users[self.currentClassFolder.Owner].Name),$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
            duplicateNow(true);
          },function(){
            duplicateNow(false);
          });
        }else
          duplicateNow(false);
//      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.duplicateClassFolderItemToOther = function(it,ev){
      var duplicateNow = function(ownership,target){
        var p = {"action":"duplicateClassFolderItemToTarget", "ID":it.ID, 
                 "ownership":ownership ? target.Owner : 0, "target":target.ID};

        self.showLoadingIndicator(ev,function(done){
          self.apiPost("ajax",p).then(function(data) {
            // we added a new folder item
            self.keepAliveCallback().then(function(){
              for(var i=0; i < self.currentClassFolder.items.length; i++){
                if(self.currentClassFolder.items[i].ID == data.item.ID){
                  self.openClassFolderItem(self.currentClassFolder.items[i],ev);
                  break;
                }
              }
              done();
            });
            self.track("duplicateclassfolderitemto",{item:it.ID, target:target.ID});
          });
        })        
      }

      self.selectClassFolderTarget(ev).then(function(target){
        if(self.user.Teacher == 1 && target.Share == 0){
          self.confirm($filter('trans')('ASKDUPLICATEFOLDERITEMOWNERSHIPUSER',self.users[target.Owner].Name),$filter('trans')('YES'),null,$filter('trans')('NO')).then(function(){
            duplicateNow(true,target);
          },function(){
            duplicateNow(false,target);
          });
        }else
          duplicateNow(false,target);
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.deleteClassFolderItem = function(it,ev){
      var deferred = $q.defer();

      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETEFOLDERITEM')+'</span>',$filter('trans')('DELETE'),null).then(function(){
        self.apiPost("ajax",{"action":"removeClassFolderItem", "ID":it.ID })
         .then(function(data) {
            // we removed a folder item
            if(self.currentClassFolder){
              for(var i=0; i < self.currentClassFolder.items.length; i++){
                if(self.currentClassFolder.items[i].ID == it.ID){
                  if(i > 0){
                    self.openClassFolderItem(self.currentClassFolder.items[i-1]);
                  }else{
                    if(i < self.currentClassFolder.items.length-1)
                      self.openClassFolderItem(self.currentClassFolder.items[i+1]);
                    else
                      self.openClassFolderItem(null);
                  }
                }
              }
            }
            self.keepAliveCallback();
            self.track("deleteclassfolderitem",it);
            deferred.resolve();
         });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendLearningGoalToClassFolder = function(goal,folder,student,ev){
      if(self.user.ID == -1) return;
      self.openClassFolder(folder,student,self.user.Teacher == 0, ev).then(function(){
        // check if there is already a matching item
        var exists = null;
        for(var i=0; i < folder.items.length; i++){
          if(folder.items[i].Owner == student.ID && folder.items[i].Goal == goal.ID){
            exists = folder.items[i];
            break;
          }
        }

        var keysResult = ["Status","Teacher","Updated"];
        var keysGoal = ["ID","Name","Description"];

        if(!exists){
          $timeout(function(){            
            self.confirm($filter('trans')('ASKSENDLEARNINGGOALTOCLASSFOLDER',goal.Name,folder.Name),$filter('trans')('ADD'),ev).then(function(){
              // copy data from current task to the folder item for later use
              var data = {};
              for(var k in goal) if(keysGoal.indexOf(k) != -1) data[k] = goal[k];

              var now = {};
              var status = self.getUserLearningGoalStatus (goal, student ? student : self.user, true);
              for(var k in status) if(keysResult.indexOf(k) != -1) now[k] = status[k];

              data.Result = now;

              var p = {"action":"addClassFolderItem", "ID":folder.ID, "Title":moment().format('DD.MM.YYYY'), "Type":"goal", "Goal":goal.ID, "Content":JSON.stringify(data)};
              if(student && student.ID != self.user.ID) p.student = student.ID;

              self.apiPost("ajax",p).then(function(data) {
                // we added a new folder item, open it now
                self.keepAliveCallback().then(function(){
                  self.sendLearningGoalToClassFolder(goal,folder,student,ev);
                });
                self.track("addclassfolderitem",data.item);
              });
            });
          },500);
          return;
        }else{
          self.currentClassFolder = folder;
          self.openClassFolderItem(exists,ev);
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendRubricToClassFolder = function(rubric,folder,student,task,ev){
      if(self.user.ID == -1) return;
      self.openClassFolder(folder,student,self.user.Teacher == 0, ev).then(function(){
        // check if there is already a matching item
        var exists = null;
        for(var i=0; i < folder.items.length; i++){
          if(folder.items[i].Owner == student.ID && folder.items[i].Rubric == rubric.ID && folder.items[i].DataJSON && 
              ((!task && !folder.items[i].DataJSON.taskid) || (task && folder.items[i].DataJSON.taskid == task.ID))){
            exists = folder.items[i];
            break;
          }
        }

        var keysRubric = ["GUID","ID","Name","Description"];
        var keysTask = ["ID","Name","Description","Type","Data","MainIcon","Icon","Color","Social","Level","Time","ResultType","userTask"];

        if(!exists){
          $timeout(function(){            
            self.confirm($filter('trans')('ASKSENDRUBRICTOCLASSFOLDER',rubric.Name,folder.Name),$filter('trans')('ADD'),ev).then(function(){
              // copy data from current task to the folder item for later use
              var data = {};

              for(var k in rubric) if(keysRubric.indexOf(k) != -1) data[k] = rubric[k];

              if(task){
                data.taskid = task.ID;
                data.Task = {};
                for(var k in task) if(keysTask.indexOf(k) != -1) data.Task[k] = task[k];
              }

              var p = {"action":"addClassFolderItem", "ID":folder.ID, "Title":moment().format('DD.MM.YYYY'), "Type":"rubric", "Rubric":rubric.ID, "Content":JSON.stringify(data)};
              if(student && student.ID != self.user.ID) p.student = student.ID;

              self.apiPost("ajax",p).then(function(data) {
                // we added a new folder item, open it now
                self.keepAliveCallback().then(function(){
                  self.sendRubricToClassFolder(rubric,folder,student,task,ev);
                });
                self.track("addclassfolderitem",data.item);
              });
            });
          },500);
          return;
        }else{
          self.currentClassFolder = folder;
          self.openClassFolderItem(exists,ev);
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendTaskToPredefinedClassFolder = function(task,data,ev){
      if(self.user.ID == -1) return;
      var name = data.Name;
      var icon = data.Icon ? data.Icon : 'fa fa-folder-o';
      var color = data.Color ? data.Color : '#eeeeee';

      var exists = self.findPersonalClassFolderByName(name);
      if(!exists){
        self.apiPost("ajax",{"action":"createClassFolder", "ID":self.currentClass.ID,
                             "Name":name,  "Icon":icon, "Feedback":0,
                             "Color":color, "Share":0, "fixed": 1}) // has a fixed name, student cannot change it
         .then(function(data) {
            // we created a folder
            self.keepAliveCallback().then(function(){
              var f = self.findClassFolder(data.folder.ID);
              self.sendTaskToClassFolder(task,f,self.user,ev);
            });
         });
      }else{
        self.sendTaskToClassFolder(task,exists,self.user,ev);
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.sendTaskToClassFolder = function(task,folder,student,ev){
      if(self.user.ID == -1) return;
      self.openClassFolder(folder,student,self.user.Teacher == 0,ev).then(function(){
        // check if there is already a matching item
        var exists = null;
        for(var i=0; i < folder.items.length; i++){
          if(folder.items[i].Owner == student.ID && folder.items[i].Task == task.ID){
            exists = folder.items[i];
            break;
          }
        }

        var keysTask = ["ID","Name","Description","Type","Data","MainIcon","Icon","Color","Social","Level","Time","ResultType","userTask"];

        if(!exists){
          $timeout(function(){            
            self.confirm($filter('trans')('ASKSENDTASKTOCLASSFOLDER',task.Name,folder.Name),$filter('trans')('ADD'),ev).then(function(){
              // copy data from current task to the folder item for later use
              var data = {};
              for(var k in task) if(keysTask.indexOf(k) != -1) data[k] = task[k];

              var p = {"action":"addClassFolderItem", "ID":folder.ID, "Type":"task", "Title": moment().format('DD.MM.YYYY'), "Task":task.ID, "Content":JSON.stringify(data)};
              if(student && student.ID != self.user.ID) p.student = student.ID;

              self.apiPost("ajax",p).then(function(data) {
                // we added a new folder item
                self.keepAliveCallback().then(function(){
                  self.sendTaskToClassFolder(task,folder,student,ev);
                });
                self.track("addclassfolderitem",data.item);
              });
            });
          },500);
          return;
        }else{
          var keysResult = ["Answer"];
          var now = {};
          var status = self.getUserTaskStatus(task,student ? student : self.user,true);
          for(var k in status) if(keysResult.indexOf(k) != -1) now[k] = status[k];

          // check if there is already a result content item and if not, add it
          var hasResultContent = false;
          if(exists.contents){
            for(var i=0; i < exists.contents.length;i++){
              if(exists.contents[i].Type == "result"){ hasResultContent = true; break; }
            }
          }
          if(status.Answer && status.Answer != '' && !hasResultContent){
            var p = {"action":"addClassFolderItemContent", "ID":exists.ID, "pos":0, "Type":"result", "Data":JSON.stringify(now)};
            if(student && student.ID != self.user.ID) p.student = student.ID;

            self.apiPost("ajax",p).then(function(data) {
              data.content.DataJSON = JSON.parse(data.content.Data);
              exists.contents.unshift(data.content);
              self.keepAliveCallback();
              self.track("addclassfolderitemcontent",data.content);
            });
          }
          self.currentClassFolder = folder;
          self.openClassFolderItem(exists,ev);
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.lastClassFolderItems = {};
    self.openClassFolder = function (it,selectedStudent,allowSidepanel,ev){
      var deferred = $q.defer();
      self.folderSearchTerm = "";

      if(self.currentClassFolderItemDialog){
        self.closeDialog(self.currentClassFolderItemDialog);
        self.currentClassFolderItemDialog = null;
        self.currentClassFolder = null;
        self.currentClassFolderItem = null;
      }
      if(self.currentTaskResultDialog){
        self.closeDialog(self.currentTaskResultDialog);
        self.currentTaskResultDialog = null;
      }
      if(self.currentTaskDialog){
        self.closeDialog(self.currentTaskDialog);
        self.currentTaskDialog = null;
      }

      if(self.user.Teacher == 0) $timeout(self.openStudentIntroFolderContent,1000);

      if(!self.currentClass){
        self.alert('<div style="max-width:500px">'+$filter('trans')('CLASSFOLDERONLYINCLASS')+'</div>',ev);
        return deferred.promise;
      }
      if(!it){
        self.alert('<div style="max-width:500px">'+$filter('trans')('CLASSFOLDERNOTFOUND')+'</div>',ev);
        return deferred.promise;
      }
      if(it.Class != self.currentClass.ID){
        var found = false;
        var c = self.findClassByID(it.Class);
        if(c) self.openClass(c);
        if(!c) return deferred.promise;
      }
      // lookup the folder, if he still exists
      var found = false;
      if(self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID] &&
         self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent &&
         self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID] &&
         self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID] &&
         self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID].folders &&
         self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID].folders.length > 0){
        for(var i=0; i < self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID].folders.length; i++){
          if(self.users[self.users[it.Owner] ? self.users[it.Owner].ID : self.user.ID].classContent[self.currentClass.ID].folders[i].ID == it.ID){
            found = true;
            break;
          }
        }
      }
      if(!found){
        if(self.classContent && self.currentClass && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders){
          for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
            if(self.classContent[self.currentClass.ID].folders[i].ID == it.ID){
              found = true;
              break;
            }
          }
        }
      }

      if(!found){
        self.alert('<div style="max-width:500px">'+$filter('trans')('CLASSFOLDERNOTFOUND')+'</div>',ev);
        return deferred.promise;
      }


      self.showLoadingIndicator(ev,function(){
        self.updateNewFolderItemsBadge(true);
        if(it.isNew) {
          it.isNew = false;
          self.setLastOpenTime("folder",self.currentClass.ID+'-'+it.ID);
          self.updateNewFolderItemsBadge();
        }

        if(self.user.Teacher == 1){
          if(it.Share == 0 || it.Share == 3){
            self.userViewData["U"+self.user.ID+"_lastStudentFolder_"+self.currentClass.ID] = it.Name;
            self.updateUserViewData();
          }
          self.lastClassFolderName = it.Name;
        }

        self.currentClassFolder = it;
        self.currentClassFolderItem = null;
        self.track("openclassfolder",it);

        if(self.currentClassFolderDialog){
          self.closeDialog(self.currentClassFolderDialog);
          self.currentClassFolderDialog = null;
        }

        self.showDialog({
          templateUrl: self.user.Teacher == 1 ? "teacherclassfolder.html" : "studentclassfolder.html",
          targetEvent: ev,
          stayBack: true, // never get in front of other open windows
          clickOutsideToClose: false,
          escapeToClose: false,
          skipHide:true, // keep other dialog open
          onRemoving: function () {
            self.currentClassFolderDialog = null;
            self.track("closeclassfolder",it);
          },
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.selectedStudent = selectedStudent ? selectedStudent : null;

            setTimeout(function(){
              self.currentClassFolderDialog = $scope.dialogElement;
              self.addDropHandler($scope, $scope.dialogElement, null, true, false, function(resultArray) { addDroppedItem(resultArray, 0); });
              deferred.resolve(); // it is open now
              $timeout(function(){
                if(!self.currentClassFolderItem && !self.isSmallScreen && self.currentClassFolder.items.length > 0){
                  var openItem = self.currentClassFolder.items[0];
                  if(self.lastClassFolderItems[self.currentClassFolder.ID]) {
                    for(var i=0; i < self.currentClassFolder.items.length; i++){
                      if(self.currentClassFolder.items[i].ID == self.lastClassFolderItems[self.currentClassFolder.ID].ID){
                        openItem = self.currentClassFolder.items[i];
                        break;
                      }
                    }
                  }
                  self.openClassFolderItem(openItem,ev);
                }
              },10);
            },100);

            //Gesicherte Reihenfolge
            var addDroppedItem = function(resultArray, index) {
              $timeout(function(){
                var dropNow = function(){
                  var json = {};

                  var type = resultArray[index].Type;

                  if(type == 'text'){
                    json.text = resultArray[index].Text ? resultArray[index].Text : '';
                  }else{
                    json.URL = resultArray[index].URL;
                  }
                  if(type == "file"){
                    json.URL = json.URL + "?filename="+encodeURIComponent(resultArray[index].Name);
                  }

                  self.apiPost("ajax",{"action":"addClassFolderItemContent", "ID":self.currentClassFolderItem.ID,
                                       "Type":type, "Data":JSON.stringify(json)}).then(function(data) {
                    data.content.DataJSON = JSON.parse(data.content.Data);
                    self.currentClassFolderItem.contents.push(data.content);
                    self.classFolderItemContentSelect(self.currentClassFolderItem,data.content);
                    if(index == resultArray.length-1)
                      self.keepAliveCallback(); // last item, do callback now
                  });

                  if(index < resultArray.length-1) addDroppedItem(resultArray, index+1);
                };
                if(self.currentClassFolderItem){
                  dropNow();
                }else{
                  self.addClassFolderItem(it,ev).then(function(){
                    // self.currentClassFolderItem is now set
                    dropNow();
                  });
                }
              },0);
            }

            $scope.cancel = function() {
              self.closeClassFolder();
            };
          }
        });

      });

      return deferred.promise;
    };

    self.openStudentClassFolder = function(s, folderWithNewItems, ev){
      if(self.users[s.ID] && self.users[s.ID].classContent && self.users[s.ID].classContent[self.currentClass.ID] &&
         self.users[s.ID].classContent[self.currentClass.ID] && self.users[s.ID].classContent[self.currentClass.ID].folders &&
         self.users[s.ID].classContent[self.currentClass.ID].folders.length > 0){
        // pick the best match for opening students folder now
        var pick = null;

        var lastStudentFolderName = self.userViewData["U"+self.user.ID+"_lastStudentFolder_"+self.currentClass.ID];
        if(lastStudentFolderName){
          for(var i=0; i < self.users[s.ID].classContent[self.currentClass.ID].folders.length; i++){
            if(self.users[s.ID].classContent[self.currentClass.ID].folders[i].Name == lastStudentFolderName){
              pick = self.users[s.ID].classContent[self.currentClass.ID].folders[i];
              break;
            }
          }
        }
        if(!pick || (folderWithNewItems && pick.itemCounter == 0 && self.currentClass.studentFolderCounter > 0)){
          for(var i=0; i < self.users[s.ID].classContent[self.currentClass.ID].folders.length; i++){
            if(self.users[s.ID].classContent[self.currentClass.ID].folders[i].itemCounter > 0){
              pick = self.users[s.ID].classContent[self.currentClass.ID].folders[i];
              break;
            }
          }
        }
        if(!pick){
          // select first
          pick = self.users[s.ID].classContent[self.currentClass.ID].folders[0];
        }

        return self.openClassFolder(pick,null,false,ev);
      }
      if(self.classContent && self.currentClass && self.classContent[self.currentClass.ID] && self.classContent[self.currentClass.ID].folders){
        for(var i=0; i < self.classContent[self.currentClass.ID].folders.length; i++){
          if(self.classContent[self.currentClass.ID].folders[i].Name == self.lastClassFolderName){
            pick = self.classContent[self.currentClass.ID].folders[i];
            break;
          }
        }
        if(!pick){
          // select first
          pick = self.classContent[self.currentClass.ID].folders[0];
        }

        return self.openClassFolder(pick,null,false,ev);
      }

      return false;
    };

    self.closeClassFolder = function(){
      self.currentClassFolder = null;
      self.currentClassFolderItem = null;
      if(self.currentClassFolderItemDialog){
        self.closeDialog(self.currentClassFolderItemDialog);
        self.currentClassFolderItemDialog = null;        
      }
      if(self.currentClassFolderDialog){
        self.closeDialog(self.currentClassFolderDialog);
        self.currentClassFolderDialog = null;        
      }
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.updateClassNotelists = function(cs){
      if(!self.classContent[cs.ID]) self.classContent[cs.ID] = {};
      var c = self.classContent[cs.ID];
      self.updateContentDeep(cs,c,["notelists","items"]);
      // sort by order index
      for(var i=0; i < c.notelists.length; i++){
        c.notelists[i].items.sort(function(a,b){
          if(a.OrderIndex == b.OrderIndex){
            return a.ID > b.ID ? 1 : -1;
          }
          return parseInt(a.OrderIndex) > parseInt(b.OrderIndex) ? 1 : -1;
        });
      }
    }

    self.updateClassCollaborations = function(cs){
      if(!self.classContent[cs.ID]) self.classContent[cs.ID] = {};
      var c = self.classContent[cs.ID];
      self.updateContentDeep(cs,c,["collaborations"]);

      if(!self.tabButtons) self.tabButtons = {};
      if(!self.tabButtons[cs.ID]) self.tabButtons[cs.ID] = [];

      // remove 
      for(var i=0; i < self.tabButtons[cs.ID].length; i++){
        if(!self.tabButtons[cs.ID][i].classCollaboration) continue;
        var n = null;
        for(var z=0; z < c["collaborations"].length; z++){
          if(c["collaborations"][z] == self.tabButtons[cs.ID][i].classCollaboration){
            n = c["collaborations"][z];
            break;
          }
        }
        if(!n) {
          if(self.tabButtons[cs.ID][i].classCollaboration)
             self.tabButtons[cs.ID][i].classCollaboration.deleted = true;
          self.removeTabButton(cs.ID,self.tabButtons[cs.ID][i]);
        }
      }
      // add / update
      for(var z=0; z < c["collaborations"].length; z++){
        c["collaborations"][z]["DataJSON"] = JSON.parse(c["collaborations"][z]["JSON"]);
        var n = null;
        for(var i=0; i < self.tabButtons[cs.ID].length; i++){
          if(c["collaborations"][z] == self.tabButtons[cs.ID][i].classCollaboration){
            n = self.tabButtons[cs.ID][i];
            break;
          }
        }
        if(n){
          var lastTime = self.getLastOpenTime("classdoc",cs.ID+'-'+c["collaborations"][z].ID);
          var d = new Date().fromMysqlFormat(c["collaborations"][z].Changed);
          n.isNew = d > lastTime;
          n.text  = c["collaborations"][z].DataJSON.Name;          
          n.color = c["collaborations"][z].DataJSON.Color;          
          n.icon  = c["collaborations"][z].DataJSON.Icon;      
          n.fontColor = c["collaborations"][z].teacherOnly == 1 ? 'red' : '';  
        }else{
          var lastTime = self.getLastOpenTime("classdoc",cs.ID+'-'+c["collaborations"][z].ID);
          var d = new Date().fromMysqlFormat(c["collaborations"][z].Changed);
          var config = {
            isNew:d > lastTime,
            classCollaboration:c["collaborations"][z],
            fontColor:c["collaborations"][z].teacherOnly == 1 ? 'red' : '',
            icon: c["collaborations"][z].DataJSON.Icon,
            color:c["collaborations"][z].DataJSON.Color,
            text: c["collaborations"][z].DataJSON.Name,
            click:function(button,ev){
              // show document
              self.showClassDocument(button.classCollaboration,ev);
            }            
          };
          self.addTabButton(cs.ID,config);          
        }
      }

    };

    self.showClassDocument = function(it,ev){
      self.showTextEditor(it.DataJSON.Name, '', null, null, false,false, it.DataJSON.URL, null, it, false, false, ev);
    };

    self.openClassDocumentFromHint = function(hint, it, index, ev){
      // hash the current text template so we will create a new document, when the hash changes
      function hashCode(str) {
          let hash = 0;
          for (let i = 0, len = str.length; i < len; i++) {
              let chr = str.charCodeAt(i);
              hash = (hash << 5) - hash + chr;
              hash |= 0; // Convert to 32bit integer
          }
          if(hash < 0) hash = '00'+Math.abs(hash);
          return hash;
      }

      if(!self.currentClass)
        self.alert('<div style="max-width:500px">'+$filter('trans')('CLASSDOCUMENTONLYINCLASSHINT')+'</div>');
      else{
        self.showTextEditor((hint.text && hint.text != '' ? hint.text : it.Name), 
                            hint.Text, null, null, false, false,
                            "classdoc-"+self.currentClass.ID+'-'+'doc'+it.ID+'-'+hashCode(hint.Text ? hint.Text : ''), 
                            null, null, false,false, ev);
      }
    }

    self.classToolsDeleteDocument = function(d,ev){
      self.confirm($filter('trans')('CLASSDOCUMENTASKDELETE'),$filter('trans')('DELETE'),ev).then(function(){
        var docs = self.classToolSettings[self.currentClass.ID].docs;
        for(var i = 0; i < docs.length; i++){
          if(docs[i].URL == d.URL){
            docs.splice(i,1);
            self.sendClassToolSettings(self.currentClass.ID);
            return;
          }
        }
      });
    };

    self.showClassDocumentIntro = true;

    self.createClassDocument = function(ev){
      if(self.showClassDocumentIntro && 
         self.classContent[self.currentClass.ID] && 
         self.classContent[self.currentClass.ID].collaborations && 
         self.classContent[self.currentClass.ID].collaborations.length == 0){
         self.showClassDocumentIntro = false;
         self.openTeacherClassDocumentsIntro();
         return;       
      }   

      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclassdocument.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.document = {};
            $scope.document.Name = "";
            $scope.document.Color = "#eeeeee";
            $scope.document.Icon = "fa fa-file-text-o";
            $scope.document.Editable = true;
            $scope.teacherOnly = false;
            $scope.mode = 2;

            $scope.isEdit = false;
            $scope.iconList = self.taskIconList;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.colorChoice = self.folderColors;

            $scope.save = function(ev) {
              if(!$scope.document.Name || $scope.document.Name == "") return;
              if($scope.mode == 0) $scope.teacherOnly = true; else $scope.teacherOnly = false;
              if($scope.mode == 1) $scope.document.Editable = false; else $scope.document.Editable = true;

              $scope.document.URL = "classdoc-"+self.currentClass.ID+'-'+new Date().getTime();
              $scope.code = Math.round(Math.random()*900000)+100000;
              self.apiPost("ajax",{"action":"createClassCollaboration", 
                                            "classid":self.currentClass.ID, 
                                            "teacherOnly":$scope.teacherOnly ? 1 : 0, 
                                            "type":"doc", "code":$scope.code,
                                            "data":JSON.stringify($scope.document)}).then(function(data) {
                self.keepAliveCallback();
                self.closeDialog($scope.dialogElement);
                self.showClassDocument({ID:data.collaboration,Code:$scope.code,Class:self.currentClass.ID, DataJSON:$scope.document},ev);
                deferred.resolve($scope.document);
              });            
            };

            $scope.cancel = function(ev) {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.editClassDocument = function(it,ev){
      var deferred = $q.defer();
      self.showLoadingIndicator(ev,function(done){
        self.showDialog({
          templateUrl: "editclassdocument.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.document = JSON.parse(JSON.stringify(it.DataJSON));
            $scope.iconList = self.taskIconList;
            $scope.iconsLastUsed = self.lastUsedTaskIcons;
            $scope.colorChoice = self.folderColors;
            $scope.isEdit = true;
            $scope.mode = 2;
            if($scope.document.Editable == false) $scope.mode = 1;
            if(it.teacherOnly == "1") $scope.mode = 0;
            $scope.save = function(ev) {
              if(!$scope.document.Name || $scope.document.Name == "") return;
              if($scope.mode == 0) $scope.teacherOnly = true; else $scope.teacherOnly = false;
              if($scope.mode == 1) $scope.document.Editable = false; else $scope.document.Editable = true;
              self.apiPost("ajax",{"action":"updateClassCollaboration", 
                                   "ID":it.ID, 
                                   "teacherOnly":$scope.teacherOnly ? 1 : 0, 
                                   "code":it.Code,
                                   "data":JSON.stringify($scope.document)}).then(function(data) {
                self.keepAliveCallback();
                it.DataJSON = $scope.document; // replace
                self.closeDialog($scope.dialogElement);

                self.closeDialog(); // close the editor and reopen now
                $timeout(function(){
                  self.showClassDocument(it,null);
                },100);
                deferred.resolve($scope.document);
              });
            };

            $scope.delete = function(ev) {
              self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETECLASSDOCUMENT')+'</span>',$filter('trans')('DELETE'),null).then(function(){
                self.apiPost("ajax",{"action":"removeClassCollaboration", 
                                     "ID":it.ID, 
                                     "code":it.Code}).then(function(data) {
                  self.keepAliveCallback();
                  it.deleted = true;
                  self.closeDialog($scope.dialogElement);
                  deferred.resolve("DELETED");
                });
              });              
            };

            $scope.duplicate = function(target,ev) {
              self.apiPost("ajax",{"action":"duplicateClassCollaboration", 
                                   "ID":it.ID, 
                                   "target":target.ID,
                                   "code":it.Code}).then(function(data) {
                self.keepAliveCallback();
                self.closeDialog($scope.dialogElement);
                self.alert($filter('trans')('CLASSCOLLABORATIONDUPLICATED'));
                deferred.resolve("DUPLICATED");
              });
            };

            $scope.cancel = function(ev) {
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      });
      return deferred.promise;
    };

    self.deleteClassDocument = function(it){
      var deferred = $q.defer();

      self.confirm('<span style="color:red">'+$filter('trans')('ASKDELETECLASSDOCUMENT',it.Name)+'</span>',$filter('trans')('DELETE'),null).then(function(){
        self.apiPost("ajax",{"action":"removeClassFolder", "ID":it.ID })
         .then(function(data) {
            // we removed a folder
            if(self.currentClassFolder && self.currentClassFolder.ID == it.ID){
              self.closeClassFolder();
            }
            if(self.classContent && self.classContent[it.Class] && self.classContent[it.Class].folders){
              for(var i=0; i < self.classContent[it.Class].folders.length; i++)
                if(self.classContent[it.Class].folders[i].ID == it.ID){
                  self.classContent[it.Class].folders.splice(i,1);
                  break;
                }
            }
            self.keepAliveCallback();
            deferred.resolve();
         });
      });
      return deferred.promise;
    };    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTeacherNotesStudent = function(s, ev){
      var canChange = self.hasClassChangePermission(self.currentClass);
      if(!self.userViewData["IntroStudentNotes"] && canChange){
        self.userViewData["IntroStudentNotes"] = 1;
        self.updateUserViewData();
        self.openTeacherStudentNotesIntro().then(function(){
          self.openTeacherNotesStudent(s,ev);
        });
        return;
      } 

      self.apiPost("ajax",{action:'requestTeacherNotes', type:'student', id:s.ID, classid:self.currentClass.ID, noindicator:true}).then(function(data){
        if(data.name){
          self.showTextEditor($filter('trans')('TEACHERNOTES')+": "+s.Name+" "+s.Surname , data.text, null, null, false, false, data.name, function(text){
            if(text && canChange){
              text = text.replace(/<doc id="([^"]+)"><\/doc>/,"");
              self.apiPost("ajax",{action:'saveTeacherNotes', type:'student', id:s.ID, classid:self.currentClass.ID, text:text});
              s.hasTeacherNotes = text && text != '';
            }
          }, null, canChange ? false : true,false, ev);
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTeacherNotesTask = function(task, ev){
      var canChange = self.checkChangePermission(self.currentMainTopic);
      if(!self.userViewData["IntroNotes"] && canChange){
        self.userViewData["IntroNotes"] = 1;
        self.updateUserViewData();
        self.openTeacherNotesIntro().then(function(){
          self.openTeacherNotesTask(task,ev);
        });
        return;
      } 

      if(!task.ID){
        // new task
        self.showTextEditor($filter('trans')('TEACHERNOTES')+": "+task.Name , task.teacherNotes ? task.teacherNotes : "", null, null, false, false, null, function(text){
          if(text){
            text = text.replace(/<doc id="([^"]+)"><\/doc>/,"");
            task.teacherNotes = text; 
            task.hasTeacherNotes = text && text != '';
          }
        }, null, false,false, ev);
        return;
      }

      self.apiPost("ajax",{action:'requestTeacherNotes', type:'task', id:task.ID, noindicator:true}).then(function(data){
        if(data.name){
          self.showTextEditor($filter('trans')('TEACHERNOTES')+": "+task.Name , data.text, null, null, false, false, data.name, function(text){
            if(text && canChange){
              text = text.replace(/<doc id="([^"]+)"><\/doc>/,"");
              self.apiPost("ajax",{action:'saveTeacherNotes', type:'task', id:task.ID, text:text});
              task.hasTeacherNotes = text && text != '';
            }
          }, null, canChange ? false : true,false, ev);
        }
      });
    };

    self.openTeacherNotesLearningGoal = function(goal, ev){
      var canChange = self.checkChangePermission(self.currentMainTopic);
      if(!self.userViewData["IntroNotes"] && canChange){
        self.userViewData["IntroNotes"] = 1;
        self.updateUserViewData();
        self.openTeacherNotesIntro().then(function(){
          self.openTeacherNotesLearningGoal(goal,ev);
        });
        return;
      }

      self.apiPost("ajax",{action:'requestTeacherNotes', type:'goal', id:goal.ID, noindicator:true}).then(function(data){
        if(data.name){
          self.showTextEditor($filter('trans')('TEACHERNOTES')+": "+goal.Name , data.text, null, null, false, false, data.name, function(text){
            if(text && canChange){
              text = text.replace(/<doc id="([^"]+)"><\/doc>/,"");
              self.apiPost("ajax",{action:'saveTeacherNotes', type:'goal', id:goal.ID, text:text});            
              goal.hasTeacherNotes = text && text != '';
            }
          }, null, canChange ? false : true,false, ev);
        }
      });
    };
    
    self.checkHasTeacherNotes = function(type,it){
      it.hasTeacherNotes = false;
      if(self.user.Teacher == 1 && it.ID){
        self.apiPost("ajax",{action:'requestTeacherNotes',"noerror":1, type:type, id:it.ID, classid:self.currentClass ? self.currentClass.ID : 0, noindicator:true}).then(function(data){
          it.hasTeacherNotes = data && data.text != '';
        });
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.searchImageTerm = "";

    self.searchForImage = function(ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "searchForImage.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: false,
        escapeToClose: false,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.images = [];
          $scope.maxImages = 25;
          $scope.currentImage = null;
          $scope.selectType = 'all';     
          $scope.searching = false;

          $scope.fetchImages = function(){
            $scope.images = [];
            $scope.maxImages = 25;
            $scope.searching = true;
            if($.trim(self.searchImageTerm) == "") return;            
            self.apiPost("findImage",{s:self.searchImageTerm,type:$scope.selectType}).then(function(data){
              if(data.hits){
                $scope.images = data.hits;
              }
              $scope.searching = false;
            });
          }

          $scope.openImage = function(img){
            $scope.currentImage = img;
          };

          $scope.useImage = function(){
            self.showLoadingIndicator(null,function(done){
              if($scope.currentImage.cropBlob){
                self.closeDialog($scope.dialogElement);
                deferred.resolve({blob:$scope.currentImage.cropBlob, url:$scope.currentImage.largeImageURL});
                done();
              }else
              fetch($scope.currentImage.largeImageURL).then(function(response) { return response.blob()}).then(function(blob) {
                self.closeDialog($scope.dialogElement);
                deferred.resolve({blob:blob, url:$scope.currentImage.largeImageURL});
                done();
              });
            });
          };

          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };

          if(self.searchImageTerm){
            $scope.fetchImages(self.searchImageTerm);
          }
        }
      });            
      return deferred.promise;
    }    
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.generateQRCode = function(URL, caption, ev){
      self.showDialog({
        templateUrl: "generateQRCode.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.caption = caption ? caption : "";
          $scope.URL = URL;
          if($scope.URL.indexOf("http") === 0 || $scope.URL.indexOf("www.") === 0){
            $scope.URL = URL.replace(/ /g,"%20"); // replace spaces so links will work
          }
          $scope.errorCorrection = "Q";
          $scope.version = 4;
          function getQRCodeLevel(contentLength) {
            if (contentLength <= 17) {
              $scope.version = 4;
            } else if (contentLength <= 32) {
              $scope.version = 5;
            } else if (contentLength <= 53) {
              $scope.version = 6;
            } else if (contentLength <= 78) {
              $scope.version = 7;
            } else if (contentLength <= 106) {
              $scope.version = 8;
            } else if (contentLength <= 134) {
              $scope.version = 9;
            } else {
              $scope.version = 10;
              $scope.errorCorrection = "L";
            }
          }
          getQRCodeLevel($scope.URL.length);
          if($scope.URL.length > 250){
            self.alert($filter('trans')('QRCODETOOMUCHDATA'));
            self.closeDialog($scope.dialogElement);
          }
          $scope.download = function(ev) {
            var img = $('canvas',$('#generatedQRCode')).get(0).toDataURL('image/png');
            self.downloadFile(img,(caption ? caption.replace(/[^A-Za-z0-9öäüÖÄÜß\. \-_]/g,"").substring(0,20) +'-' : '')+'qrcode.png');
/*
            if(typeof cordova != "undefined"){
              self.tryCloseLastWindow();
              window.lastOpenWindow = window.open(img,self.getNewWindowName(),"location=yes,enableViewportScale=yes,hidden=no");
            }else{
              var anchor = document.createElement('a');            
              anchor.href = img.replace(/^data:image\/[^;]/, 'data:application/octet-stream');
              anchor.download = (caption ? caption.replace(/[^A-Za-z0-9öäüÖÄÜß\. \-_]/g,"").substring(0,20) +'-' : '')+'qrcode.png';
              anchor.click();            
            }
*/            
          };
          $scope.copy = function(){
            var img = new Image();
            img.src = $('canvas',$('#generatedQRCode')).get(0).toDataURL('image/png');
            copyImageToClipboard(img);
            self.alert($filter('trans')('COPYEDIMAGETOCLIPBOARD'));
          };
          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });      
    };
    self.createQRCodeFromContent = function(ev){
      self.showDialog({
        templateUrl: "inputQRCodeText.html",
        targetEvent: ev,
        skipHide:true, // keep other dialog open

        clickOutsideToClose: true,
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.linkURL = "";
          $scope.save = function(ev){
            self.closeDialog($scope.dialogElement);
            // extract domain
            var caption = $scope.linkURL;
            if($scope.linkURL.indexOf("http") === 0){
              var parts = $scope.linkURL.replace(/\/\//g,"/").split("/");
              caption = parts.length > 1 ? parts[1] : parts[0];
            }
            if($scope.linkURL.indexOf("www.") === 0){
              var parts = $scope.linkURL.split("/");
              caption = parts[0];
              $scope.linkURL = "https://"+$scope.linkURL;
            }
            self.generateQRCode($scope.linkURL,caption,ev);
          };
          $scope.cancel = function(ev) {
            self.closeDialog($scope.dialogElement);
          };
        }
      });   
    };
    self.createQRCodeFromFile = function(ev){
      self.takeUserMedia("file",null,function(results){
        if(results && results[0].URL != '') {
          var caption = results[0].Name;
          var parts = caption.split(".");
          parts.pop();
          caption = parts.join(".");
          self.generateQRCode("https://learningview.org/file/"+results[0].URL.replace("https://learningview.org/uploads/",""), caption,ev);
        }
      }, {dialogMode: 0});      
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    //1009
    //attributes; type, isUpload, url, name, duration
    self.addToRecentFiles = function(attributes) {
      var recentFilesMaxLength = 10;
      var tempRecentFilesMaxLength = 3;

      if(!self.userViewData.recentFiles) {
        self.userViewData.recentFiles = {};

        self.userViewData.recentFiles.imageUploads = [];
        self.userViewData.recentFiles.audioUploads = [];
        self.userViewData.recentFiles.videoUploads = [];
        self.userViewData.recentFiles.fileUploads = [];
      }

      if(!self.tempRecentFiles) {
        self.tempRecentFiles = {};

        self.tempRecentFiles.images = [];
        self.tempRecentFiles.audios = [];
        self.tempRecentFiles.videos = [];
        self.tempRecentFiles.files = [];
      }

      if(attributes.type) {
        //select matching array
        var typeRecentFilesArray = [];
        switch(attributes.type) {
          case "image":
              if(attributes.isUpload) {
                if(!self.userViewData.recentFiles.imageUploads) self.userViewData.recentFiles.imageUploads = [];
                typeRecentFilesArray = self.userViewData.recentFiles.imageUploads;
              }
              else typeRecentFilesArray = self.tempRecentFiles.images;
            break;
          case "audio":
              if(attributes.isUpload) {
                if(!self.userViewData.recentFiles.audioUploads) self.userViewData.recentFiles.audioUploads = [];
                typeRecentFilesArray = self.userViewData.recentFiles.audioUploads;
              }
              else typeRecentFilesArray = self.tempRecentFiles.audios;
            break;
          case "video":
              if(attributes.isUpload) {
                if(!self.userViewData.recentFiles.videoUploads) self.userViewData.recentFiles.videoUploads = [];
                typeRecentFilesArray = self.userViewData.recentFiles.videoUploads;
              }
              else typeRecentFilesArray = self.tempRecentFiles.videos;

            break;
          case "file":
              if(attributes.isUpload) {
                if(!self.userViewData.recentFiles.fileUploads) self.userViewData.recentFiles.fileUploads = [];
                typeRecentFilesArray = self.userViewData.recentFiles.fileUploads;
              }
              else typeRecentFilesArray = self.tempRecentFiles.files;
        }

        //delete recent file which has the same url
        for(var i = 0; i < typeRecentFilesArray.length; i++) {
          if((attributes.url && typeRecentFilesArray[i].url == attributes.url)) {
            typeRecentFilesArray.splice(i, 1);
            break;
          }
        }

        //create array with attributes
        var activity = {}

        activity.time = new Date().getTime();

        if(attributes.url) activity.url = attributes.url;
        if(attributes.name) activity.name = attributes.name;
        if(attributes.duration) activity.duration = attributes.duration;

        if(!attributes.isUpload) activity.isVisible = true;

        //remove dublicates in last viewed files
        if(attributes.isUpload) {
          if(typeRecentFilesArray)
          for(var i = 0; i < typeRecentFilesArray.length; i++) {
            if(typeRecentFilesArray[i].url == activity.url) {
              typeRecentFilesArray.splice(i, 1);
              i--;
            }
          }
        }

        typeRecentFilesArray.unshift(activity);

        if(typeRecentFilesArray.length > (attributes.isUpload ? recentFilesMaxLength : tempRecentFilesMaxLength)) {
          typeRecentFilesArray.pop();
        }

        if(attributes.isUpload) self.updateUserViewData();
      }
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.holdShift = false;
    self.shiftSelectedTasks = [];   
    document.addEventListener("keydown", function (event) {
      if (!document.activeElement ||
          (document.activeElement.nodeName !== 'INPUT' &&
           document.activeElement.nodeName !== 'TEXTAREA' &&
           !document.activeElement.isContentEditable)) {
        // Shift alleine gedrückt
        if (event.key === "Shift" && event.shiftKey && !event.metaKey && !event.ctrlKey && !event.altKey) {
          $timeout(function () {
            if (self.dialogStack.length === 0) {
              self.holdShift = true;
            }
          }, 0);
          return;
        }
        // Während Shift gehalten wird kommt eine andere Taste dazu
        if (self.holdShift && event.shiftKey && event.key !== "Shift") {
          $timeout(function () {
            self.holdShift = false;
          }, 0);
        }
      }
    });

    document.addEventListener("keyup", function (event) {
      if (!document.activeElement ||
          (document.activeElement.nodeName !== 'INPUT' &&
           document.activeElement.nodeName !== 'TEXTAREA' &&
           !document.activeElement.isContentEditable)) {
        // Shift losgelassen
        if (event.key === "Shift") {
          $timeout(function () {
            self.holdShift = false;
          }, 0);
        }
      }
    });     

    document.addEventListener("visibilitychange", function () {
      if (document.hidden) {
        $timeout(function(){
          self.holdShift = false;
          self.shiftSelectedTasks = [];
        },0);
      }
    });
    window.addEventListener("blur", function () {
      $timeout(function(){
        self.holdShift = false;
        self.shiftSelectedTasks = [];
      },0);
    });

    self.shiftSelectTasksFromGoal = function(goal){
      var allSelected = true;
      for(var i=0; i < goal.tasks.length; i++){
        if(!self.isShiftSelectedTask(goal.tasks[i])){
          allSelected = false;
          break;
        }
      }
      for(var i=0; i < goal.tasks.length; i++){
        if(allSelected){
          self.toggleShiftSelectTask(goal.tasks[i]);
        }else
          if(!self.isShiftSelectedTask(goal.tasks[i])){
            self.shiftSelectedTasks.push(goal.tasks[i]);
          }
      }
    };    
    self.toggleShiftSelectTask = function(it){
      for(var i=0; i < self.shiftSelectedTasks.length; i++){
        if(self.shiftSelectedTasks[i].ID == it.ID){
          self.shiftSelectedTasks.splice(i,1);
          return false;
        }
      }
      self.shiftSelectedTasks.push(it);
      return true;
    };
    self.isShiftSelectedTask = function(it){
      for(var i=0; i < self.shiftSelectedTasks.length; i++){
        if(self.shiftSelectedTasks[i].ID == it.ID) return true;
      }
      return false;
    };
    self.taskClicked = function(it,ev,scope){
      if(self.user.Teacher == 1 && (self.holdShift || self.shiftSelectedTasks.length > 0)){
        self.toggleShiftSelectTask(it);
        return;
      }
      if(self.preventDoubleClick()) return;
      if(ev.target){
        var p = ev.target;
        while(p && p.nodeName != 'BUTTON') p = p.parentNode;
        if(p) p.focus();
      }
      self.showLoadingIndicator(ev,function(done){
        if(scope.fromClassFolder == 1 && self.user.Teacher == 1 && self.currentClassFolderItem && self.currentClass){
          var student = false;
          for(var i=0; i < self.currentClass.students.length; i++){
            if(self.currentClassFolderItem.Owner == self.currentClass.students[i].ID){
              student = self.currentClass.students[i];
              break;
            }
          }
          if(student)
            self.openResultButtonWindow(it,student,ev,scope); else
            self.openTaskButtonWindow(it,ev,scope);
        }else
          self.openTaskButtonWindow(it,ev,scope);
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.goalStatusClicked = function(it,$mdOpenMenu,ev,scope){
      // teacher class status list menu opened
      var trigger = ev ? (ev.currentTarget || ev.target) : null;
      function clampMenuIntoViewport(attempt){
        if(!trigger || !document.body.contains(trigger) || attempt > 5) return;
        var owner = trigger.getAttribute && trigger.getAttribute("aria-owns");
        var menuContainer = owner ? document.getElementById(owner) : null;
        var activeMenus = document.querySelectorAll('.md-open-menu-container.md-active');
        var activeMenu = activeMenus && activeMenus.length > 0 ? activeMenus[activeMenus.length - 1] : null;
        if(menuContainer && menuContainer.parentNode && !menuContainer.classList.contains("md-open-menu-container") && menuContainer.parentNode.classList)
          menuContainer = menuContainer.parentNode.classList.contains("md-open-menu-container") ? menuContainer.parentNode : null;
        if(!menuContainer) menuContainer = activeMenu;

        if(menuContainer){
          self.limitPanelToViewport($(menuContainer));
          var menuContent = menuContainer.querySelector('md-menu-content, .md-menu-content');
          if(menuContent){
            var availableHeight = Math.max(120, (window.innerHeight || document.documentElement.clientHeight || 0) - 16);
            if(menuContent.getBoundingClientRect().height > availableHeight){
              menuContent.style.maxHeight = availableHeight + "px";
              menuContent.style.overflowY = "auto";
            }
          }
        }
        if(!menuContainer || !menuContent) $timeout(function(){ clampMenuIntoViewport(attempt + 1); }, 30);
      }

      scope.isStatusMenuOpen = false;
      self.showLoadingIndicator(ev,function(done){
        scope.isStatusMenuOpen = true;
        $timeout(function(){
          $mdOpenMenu(ev);
          $timeout(function(){
            clampMenuIntoViewport(0);
          }, 0);
          done();
        },10);
      });
    };
    self.taskStatusClicked = function(it,$mdOpenMenu,ev,scope){
      // teacher class status list menu opened
      scope.isStatusMenuOpen = false;
      self.showLoadingIndicator(ev,function(done){
        scope.isStatusMenuOpen = true;
        $timeout(function(){
          $mdOpenMenu(ev);
          done();
        },10);
      });
    };
    self.foldersStatusClicked = function($mdOpenMenu,ev,scope){
      // teacher class status list menu opened
      scope.isStatusMenuOpen = false;
      self.showLoadingIndicator(ev,function(done){
        scope.isStatusMenuOpen = true;
        $timeout(function(){
          $mdOpenMenu(ev);
          done();
        },10);
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.isSolvedByAllStudentsInClass = function(task,c){
      if(!c) c = self.currentClass;
      if(!c) return false;
      for(var i = 0; i < c.students.length; i++)
        if(self.getUserTaskStatus(c.students[i],task,true).Status != 'OK') return false;
      return true;
    }
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.resulttaskClicked = function(it,student,ev,scope){
      if(self.preventDoubleClick()) return;
      self.showLoadingIndicator(ev,function(done){
        scope.fromResults = true;
        self.openResultButtonWindow(it,student,ev,scope);
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openSelfTest = function(it,ev,reset,ispreview){
      if(!it.DataJSON.questions || it.DataJSON.questions.length == 0){
        self.alert("Für diesen Selbsttest wurden noch keine Fragen definiert.");
        return;
      }

      self.apiPost("ajax",{"action":"getTime"}).then(function(data) {
        var shifted = new Date().fromMysqlFormat(data.time);
        var status = self.getUserTaskStatus(it, self.user, true);
        if(status.Status != null && status.Status != ""  && status.Updated && self.user.Teacher == "0"){
          var minutes = Math.abs(moment(status.Updated).diff(moment(shifted),"minutes"));
          var r = parseInt(it.DataJSON.repeatTime || it.DataJSON.repeatTime === 0 ? it.DataJSON.repeatTime : 5);
          if(r == -1 && !(status.Status == null || status.Status == "" || status.Status == "w")){
            self.alert('<div style="max-width:500px">'+$filter('trans')('SELFTTESTNOREPEAT')+'</div>',ev);
            return;
          }
          if(r == 1440){
            if(!moment(status.Updated).isSame(moment(shifted),'day')) r = 0; // next day is fine
          }
          if(minutes < r){
            var minutesLeftToday = moment(shifted).endOf('day').diff(moment(shifted), 'minutes');
            if(r - minutes > minutesLeftToday){
              self.alert('<div style="max-width:500px">'+$filter('trans')('SELFTTESTTIMERTOMORROW')+'</div>',ev);
            }else{
              self.alert('<div style="max-width:500px">'+$filter('trans')('SELFTTESTTIMER',r-minutes)+'</div>',ev);
            }
            return;
          }
        }

        var wasCompleted = false;
        var startTime = (new Date()).getTime();

        self.showDialog({
          templateUrl: "selftest.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          onRemoving: function (event, removePromise) {
            if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          },

          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.currentQuestion = -1;
            $scope.canGoNext = ispreview ? true : false;
            $scope.canGoBack = false;
            $scope.item = JSON.parse(angular.toJson(it));

            for(var qi = 0; qi < $scope.item.DataJSON.questions.length; qi++){
              var qInit = $scope.item.DataJSON.questions[qi];
              if(qInit.media && qInit.media.type == 'audio'){
                if(typeof qInit.media.AudioPlayLimit == "undefined" || qInit.media.AudioPlayLimit === null){
                  qInit.media.AudioPlayLimit = '';
                }
                qInit._audioPlayCount = 0;
              }
            }

            // time limit 
            $scope.timeLimit = $scope.item.DataJSON.timeLimit ? parseInt($scope.item.DataJSON.timeLimit) : 0;
            if($scope.timeLimit > 0) {
              $scope.timeLeft = $scope.timeLimit;
              $scope.timerInterval = $interval(function(){
                if($scope.askSkipRightQuestions || $scope.askStartSingleTry) return; // not started yet
                $scope.timeLeft--;
                if($scope.timeLeft <= 0){
                  // finished by time
                  $scope.saveTestResult();
                }
              },1000);
            }

            $scope.showSolution = false;
            $scope.randomOrder = $scope.item.DataJSON.randomOrder == "1";
            $scope.randomNumber = $scope.item.DataJSON.randomOrder == "2" ? parseInt($scope.item.DataJSON.randomNumber ? $scope.item.DataJSON.randomNumber : 1) : 0;
            $scope.randomAnswerOrder = $scope.item.DataJSON.randomAnswerOrder == "1";

            $scope.currentState = [];
            for(var i=0; i < it.DataJSON.questions.length; i++)
              $scope.currentState.push("0,");


            var pa = status.Answer ? status.Answer.split('|') : [];
            if($scope.randomNumber) pa = []; // no old answers

            if(pa.length > 0) {
              $scope.canContinue = pa.shift(); // remove first item, as this is 3/5 value
  //          if(reset) p = []; // not load last answers
            }
            if($scope.item.DataJSON.showSolution != '1' &&
               $scope.item.DataJSON.showSolution != '2' &&
               $scope.item.DataJSON.showSolution != '3'){
              while(pa.length > 0) pa.pop(); // no save on solution = 0
            }

            $scope.askSkipRightQuestions = pa.length > 0;
            $scope.skipRightAnswers = false;

            if(status.Status == "OK") $scope.canContinue = false;

            $scope.resetAnswers = function(){
              while(pa.length > 0) pa.pop();
              $scope.askSkipRightQuestions = false;
              $scope.currentState = [];
              for(var i=0; i < it.DataJSON.questions.length; i++){
                $scope.currentState.push("0,");
                $scope.item.DataJSON.questions[i]._audioPlayCount = 0;
                if(it.DataJSON.questions[i].answers)
                  for(var z=0; z < it.DataJSON.questions[i].answers.length; z++)
                   delete $scope.item.DataJSON.questions[i].answers[z].selected;
              }
              $scope.answerListOrder = []; // reset too
              $scope.readLastAnswers();
              $scope.next();
            };

            $scope.onlyWrongAnswers = function(){
              $scope.askSkipRightQuestions = false;
              $scope.skipRightAnswers = true;
              $scope.readLastAnswers(true);
              $scope.next();
            };

            $scope.readLastAnswers = function(skipNext){
              $scope.item.typedIn = "";
              $scope.item.selectedIndex = -1;

              for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
                if(typeof (pa[z]) == "undefined") continue;
                $scope.currentState[z] = pa[z];
                var q = $scope.item.DataJSON.questions[z];

                if(q.type == 'mc'){
                  if(q.multi){
                    var n = pa[z].substring(2).split(",").map(Number);
                    for(var i=0; i < q.answers.length; i++){
                      q.answers[i].selected = n.indexOf(i+'') >= 0;
                    }
                  }else{
                    if(z == $scope.currentQuestion)
                      $scope.item.selectedIndex = parseInt(pa[z].substring(2)); // removes trailing 0/1 for correct;
                  }
                }
                if(q.type == 'input' && z == $scope.currentQuestion){
                  $scope.item.typedIn = pa[z].substring(2); // removes trailing 0/1 for correct
                }
                if(q.type == 'order' && z == $scope.currentQuestion){
                  $scope.answerListOrder = pa[z].substring(2).split(",").map(Number); // removes trailing 0/1 for correct
                }
                if(q.type == 'know' && z == $scope.currentQuestion){
                  $scope.item.typedIn = pa[z].substring(2); // removes trailing 0/1 for correct
                }
              }
              if(skipNext) return;

              var q = $scope.item.DataJSON.questions[$scope.currentQuestion];
              if($scope.currentState[$scope.currentQuestion] &&
                 $scope.currentState[$scope.currentQuestion] != "" &&
                 $scope.currentState[$scope.currentQuestion] != "0," &&
                 !(q.type == 'mc' && !q.multi && $scope.item.selectedIndex == -1)){
                  $scope.canGoNext = true; // we already have an input from last time
                  $scope.checkAnswer();
                  if($scope.skipRightAnswers && $scope.currentCorrect) {
                    $scope.next();
                }else{
                  if($scope.skipRightAnswers){
                    if(q.type == 'input' || q.type == 'know'){
                      $scope.item.typedIn = "";
                      $scope.canGoNext = false;                      
                    }
                    if(q.type == 'mc' && !q.multi){
                      $scope.item.selectedIndex = -1;
                      $scope.canGoNext = false;                      
                    }
                  }
                }
              }
            };

            $scope.questionListOrder = [];
            $scope.questionListOrderDone = [];
            for(var i = 0; i < $scope.item.DataJSON.questions.length; i++){
              $scope.questionListOrder.push(i);
            }

            if($scope.randomOrder){
              $scope.questionListOrder = shuffleArray($scope.questionListOrder);
            }
            if($scope.randomNumber){
              $scope.questionListOrder = shuffleArray($scope.questionListOrder);
              while($scope.questionListOrder.length > $scope.randomNumber) 
                $scope.questionListOrder.pop();
              if($scope.randomNumber > $scope.questionListOrder.length)
                $scope.randomNumber = $scope.questionListOrder.length;
            }

            $scope.checkAnswer = function(){
              var q = $scope.item.DataJSON.questions[$scope.currentQuestion];
              $scope.currentCorrect = true;
              $scope.currentAnswers = [];
              if(it.DataJSON.questions[$scope.currentQuestion].type == 'mc'){
                if(q.multi){
                  for(var i=0; i < q.answers.length; i++){
                    if(q.answers[i].correct && !q.answers[i].selected) $scope.currentCorrect = false;
                    if(!q.answers[i].correct && q.answers[i].selected) $scope.currentCorrect = false;
                    if(q.answers[i].selected) {
                      $scope.currentAnswers.push(i);
                    }
                  }
                }
                if(!q.multi){
                  $scope.currentAnswers.push($scope.item.selectedIndex);
                  $scope.currentCorrect = false;
                  var hasCorrect = false;
                  for(var i=0; i < q.answers.length; i++){
                    if(q.answers[i].correct && (q.answers[i].text != "" || q.answers[i].media)) hasCorrect = true;
                    if(q.answers[i].correct && i == $scope.item.selectedIndex) $scope.currentCorrect = true;
                  }
                  if(!hasCorrect) $scope.currentCorrect = true; // no correct answers in single choice
                }
              }

              if(it.DataJSON.questions[$scope.currentQuestion].type == 'input'){
                $scope.currentCorrect = false;
                var a = $scope.item.typedIn;
                var input = $.trim(a);
                input = input.replace(/\n/g,' ');
                input = input.replace(/[\u00A0\u202F]/g," ");
                input = input.replace(/[´’‘‘’]/g,"'");
                input = input.replace(/,\s+/g,",");
                input = input.replace(/[„“”]/g,'"');
                input = input.replace(/ +(?= )/g,'');
                input = input.replace(/[−˗➖﹣－\u2014\u2015\u203E\u2043\u23AF\u23E4\u2500\u2501]/g,'-');
                //input = input.toLowerCase();
                var count = 0;
                for(var i=0; i < q.answers.length; i++){
                  var c = $.trim(q.answers[i].text);
                  c = c.replace(/\n/g,' ');
                  c = c.replace(/[\u00A0\u202F]/g," ");
                  c = c.replace(/[´’‘‘’]/g,"'");
                  c = c.replace(/,\s+/g,",");
                  c = c.replace(/[„“”]/g,'"');
                  c = c.replace(/ +(?= )/g,'');
                  c = c.replace(/[−˗➖﹣－\u2014\u2015\u203E\u2043\u23AF\u23E4\u2500\u2501]/g,'-');
                  //c = c.toLowerCase();

                  if(q.mode == "eq" && input == c) {
                    $scope.currentCorrect = true;
                    break;
                  }
                  if(q.mode == "in" && input.indexOf(c) != -1) {
                    $scope.currentCorrect = true;
                    break;
                  }
                  if(q.mode == "all" && input.indexOf(c) != -1) {
                    count++;
                  }
                }
                if(q.mode == "all" && count == q.answers.length) $scope.currentCorrect = true;
                if(q.answers.length == 0) $scope.currentCorrect = true; // no answers available
                $scope.currentAnswers.push($.trim(a).replace(/\|/g,""));
              }

              if(it.DataJSON.questions[$scope.currentQuestion].type == 'order'){
                if(!$scope.answerListOrder || 
                    $scope.answerListOrder.length != it.DataJSON.questions[$scope.currentQuestion].answers.length){
                  $scope.answerListOrder = [];
                  for(var i = 0; i < it.DataJSON.questions[$scope.currentQuestion].answers.length; i++)
                    $scope.answerListOrder.push(i);
                  var current = $scope.answerListOrder.join("");
                  $scope.answerListOrder = shuffleArray($scope.answerListOrder);
                  // shuffle again if order is equal
                  if($scope.answerListOrder.join("") == current){
                    $scope.answerListOrder = shuffleArray($scope.answerListOrder);
                  }
                }
                // reorder equal items if exist, so that they can match the right order
                var changed = true;
                while(changed){
                  changed = false;
                  for(var z=0; z < $scope.answerListOrder.length; z++){
                    if($scope.answerListOrder[z] == z) continue; // correct already
                    for(var i=0; i < q.answers.length; i++){
                      if(i == $scope.answerListOrder[z]) continue;
                      if(JSON.stringify(q.answers[$scope.answerListOrder[z]]) == JSON.stringify(q.answers[i])){
                        // both are equal
                        if(i == z){
                          var t = $scope.answerListOrder[z];
                          var p = $scope.answerListOrder.indexOf(i);
                          $scope.answerListOrder[z] = i;
                          $scope.answerListOrder[p] = t;
                          changed = true;
                          break;
                        }
                      } 
                    }
                  }
                }

                var correct = true;              
                for(var i=0; i < q.answers.length; i++)
                  if($scope.answerListOrder[i]+"" != i) correct = false;
                $scope.currentCorrect = correct;
                $scope.currentAnswers.push($scope.answerListOrder.join(","));
              }

              if(it.DataJSON.questions[$scope.currentQuestion].type == 'know'){
                var a = $scope.item.typedIn;
                $scope.currentCorrect = a == 1;
                $scope.currentAnswers.push(a);
              }

              $scope.currentState[$scope.currentQuestion] = ($scope.currentCorrect ? "1":"0")+","+$scope.currentAnswers.join(",");
              pa[$scope.currentQuestion] = $scope.currentState[$scope.currentQuestion];
            };

            $scope.saveWorkInProgress = function(){
              var deferred = $q.defer();
              if(self.user.Teacher == "1") {
                deferred.resolve(true);
                return deferred.promise; // test only, do not save status
              }
              if($scope.randomNumber){
                deferred.resolve(true);
                return deferred.promise; // no save on random pick n questions
              }
              if($scope.questionListOrder.length == $scope.item.DataJSON.questions.length-1 && !$scope.showSolution){
                // no answer given yet
                deferred.resolve(true);
                return deferred.promise;
              }

              if($scope.item.DataJSON.showSolution != '1' &&
                 $scope.item.DataJSON.showSolution != '2' &&
                 $scope.item.DataJSON.showSolution != '3'){
                deferred.resolve(true);
                return deferred.promise; // no save on solution = 0
              }

              $scope.correct = 0;
              $scope.wrong = 0;
              for(var i = 0; i < $scope.currentState.length; i++){
                if($scope.currentState[i] && $scope.currentState[i].length > 0 &&
                   $scope.currentState[i][0] == "1") $scope.correct++; else $scope.wrong++;
              }

              var answer = $scope.correct+"/"+($scope.correct+$scope.wrong)+"|"+
                           $scope.currentState.join("|");

              if(!$scope.showSolution && $scope.item.DataJSON.showSolution != 0){
                // there is a solution but not shown yet, remove last input
                var a = answer.split("|");
                a.pop();   
                answer = a.join("|");        
              }

              if(status.Answer == answer) {
                deferred.resolve(true);
                return deferred.promise; // already saved equal answer
              }

              if((status.Status == null || status.Status == "" || status.Status == "w") && it.DataJSON.repeatTime == -1){
                // no repeat allowed, always save it
                self.storeInteractiveTaskResult(it,{status:"w", answer:answer, duration:Math.round(((new Date()).getTime()-startTime)/1000)},false); // no force journal
                deferred.resolve(true);
              }else
              if((status.Status == null || status.Status == "" || status.Status == "w") && it.DataJSON.repeatTime != -1 && it.DataJSON.repeatTime !== '0'){
                var mins = parseInt(it.DataJSON.repeatTime ? it.DataJSON.repeatTime : 5);
                self.confirm($filter('trans')('ASKCLOSETESTREPEAT',mins),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                  self.storeInteractiveTaskResult(it,{status:"w", answer:answer, duration:Math.round(((new Date()).getTime()-startTime)/1000)},false); // no force journal
                  deferred.resolve(true);
                },function(){
                  deferred.resolve(false);
                });
              }else{              
                self.confirm($filter('trans')('ASKSAVEWORKINPROGRESS'),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                  //self.currentTaskPartners = "";
                  self.storeInteractiveTaskResult(it,{status:"w", answer:answer, duration:Math.round(((new Date()).getTime()-startTime)/1000)},false); // no force journal
                  deferred.resolve(true);
                },function(){
                  deferred.resolve(false);
                });
              }  
              return deferred.promise;
            };

            $scope.clickBack = function(){
              if($scope.questionListOrderDone.length == 0) {
                $scope.canGoBack = false;
                return;
              }
              // add current question back to stack
              $scope.questionListOrder.unshift($scope.currentQuestion);
              var n = $scope.questionListOrderDone.pop();
              $scope.questionListOrder.unshift(n); // move to first position
              $scope.showSolution = false;
              $scope.currentQuestion = -1;
              $scope.next();
              $scope.canGoBack = $scope.questionListOrderDone.length > 0;
            };

            $scope.waitForTimer = false;
            $scope.clickNext = function(){
              // next clicked
              var hasNoAnswer = false;
              if(it.DataJSON.questions[$scope.currentQuestion].type == 'mc' && !it.DataJSON.questions[$scope.currentQuestion].multi){
                var hasNoAnswer = true;              
                if($scope.item.DataJSON.questions[$scope.currentQuestion].answers){
                  for(var i = 0; i < $scope.item.DataJSON.questions[$scope.currentQuestion].answers.length; i++){
                    if($scope.item.DataJSON.questions[$scope.currentQuestion].answers[i].text != "" ||
                       $scope.item.DataJSON.questions[$scope.currentQuestion].answers[i].media){
                      hasNoAnswer = false;
                      break;
                    }
                  }
                }
              }

              if($scope.item.DataJSON.showSolution == '3'){
                // do not go next if wrong
                if($scope.waitForTimer) return; // wait
                if($scope.showSolution || hasNoAnswer) {
                  $scope.showSolution = false;
                  $scope.next();
                  return;
                }
                $scope.showSolution = true;
                if(!$scope.currentCorrect) {
                  $scope.waitForTimer = true;
                  $timeout(function(){
                    $scope.waitForTimer = false;
                    $scope.showSolution = false;
                  },1000);
                }
                return;
              }    

              if($scope.item.DataJSON.showSolution != '1' && $scope.item.DataJSON.showSolution != '2' && $scope.item.DataJSON.showSolution != '3'){
                $scope.showSolution = false;
                $scope.next();
                return;
              }

              if(!$scope.showSolution){
                if(hasNoAnswer){
                  $scope.next();
                  return;
                }
                $scope.showSolution = true;
                return;
              }
              if($scope.showSolution){
                $scope.showSolution = false;
                $scope.next();
                return;
              }
            };

            $scope.getCurrentQuestionNumber = function(){
              return $scope.getTotalQuestionNumber() - $scope.questionListOrder.length;
            }
            $scope.getTotalQuestionNumber = function(){
              return $scope.randomNumber ? $scope.randomNumber : $scope.item.DataJSON.questions.length;
            }

            $scope.saveTestResult = function(){
              if($scope.timerInterval) $interval.cancel($scope.timerInterval);
              self.closeDialog($scope.dialogElement);
              $scope.correct = 0;
              $scope.wrong = 0;
              for(var i = 0; i < $scope.currentState.length; i++){
                if($scope.currentState[i] && $scope.currentState[i].length > 0 &&
                   $scope.currentState[i][0] == "1") $scope.correct++; else $scope.wrong++;
              }
              if($scope.randomNumber){
                $scope.wrong -= ($scope.currentState.length - $scope.randomNumber);
              }

              if($scope.item.DataJSON.showSolution != '3')
                self.alert('<div style="text-align:center"><i class="fa fa-4x fa-graduation-cap"></i><br><br><i class="fa fa-fw fa-check"></i> '+$filter('trans')('DONE')+'<br><br> '+$filter('trans')('TASKDONECORRECT',$scope.correct+" "+$filter('trans')('FROM')+" "+($scope.correct+$scope.wrong))+"</div>");
  
              if(self.user.Teacher == "1") return; // test only, do not save status

              var status = $scope.wrong == 0 ? 'OK' :"FAIL";
              self.currentTaskPartners = "";
              self.storeInteractiveTaskResult(it,{status:status, duration:Math.round(((new Date()).getTime()-startTime)/1000), 
                answer:$scope.correct+"/"+($scope.correct+$scope.wrong)+"|"+
                       $scope.currentState.join("|")},true); // force journal

              wasCompleted = true;
            }

            $scope.next = function() {
              if($scope.askStartSingleTry) {
                startTime = (new Date()).getTime();
                $scope.askStartSingleTry = false; // start
              }

              if($scope.currentQuestion >= 0) $scope.checkAnswer();
              // all questions answered
              if($scope.questionListOrder.length == 0){
                if(it.DataJSON.repeatTime == -1){
                  self.confirm($filter('trans')('ASKTESTSINGLETRYDONE'),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                    $scope.saveTestResult();
                  });
                }else
                  $scope.saveTestResult();
                return;
              }

              if($scope.currentQuestion != -1){
                $scope.questionListOrderDone.push($scope.currentQuestion);
                $scope.canGoBack = true;
              }

              $scope.currentQuestion = $scope.questionListOrder.shift();

              $scope.showAnswer = false;

              // can go next for multi on start
              $scope.canGoNext = ((it.DataJSON.questions[$scope.currentQuestion].type == 'mc' && it.DataJSON.questions[$scope.currentQuestion].multi) ||
                                  (it.DataJSON.questions[$scope.currentQuestion].type == 'order'));

              // check if there is no answer at all
              if(it.DataJSON.questions[$scope.currentQuestion].type == 'mc' && !it.DataJSON.questions[$scope.currentQuestion].multi){
                $scope.canGoNext = true;
                if($scope.item.DataJSON.questions[$scope.currentQuestion].answers){
                  for(var i = 0; i < $scope.item.DataJSON.questions[$scope.currentQuestion].answers.length; i++){
                    if($scope.item.DataJSON.questions[$scope.currentQuestion].answers[i].text != "" ||
                       $scope.item.DataJSON.questions[$scope.currentQuestion].answers[i].media){
                      $scope.canGoNext = false;
                      break;
                    }
                  }
                }
              }

              $scope.canGoNext = ispreview ? it.DataJSON.questions[$scope.currentQuestion].type != 'know' : $scope.canGoNext;

              $scope.answerListOrder = null;

              $scope.readLastAnswers();

              if($scope.answerListOrder == null){
                $scope.answerListOrder = [];

                if($scope.item.DataJSON.questions[$scope.currentQuestion].answers){
                  for(var i = 0; i < $scope.item.DataJSON.questions[$scope.currentQuestion].answers.length; i++)
                    $scope.answerListOrder.push(i);
                }

                if($scope.randomAnswerOrder || it.DataJSON.questions[$scope.currentQuestion].type == "order"){
                  var current = $scope.answerListOrder.join("");
                  $scope.answerListOrder = shuffleArray($scope.answerListOrder);
                  // shuffle again if order is equal
                  if($scope.answerListOrder.join("") == current){
                    $scope.answerListOrder = shuffleArray($scope.answerListOrder);
                  }
                }
              }

              $scope.checkAnswer();
            };

            $scope.chooseAnswer = function(q, a){
              $scope.canGoNext = true;
              $timeout(function(){ $scope.checkAnswer();},1);
            };

            $scope.chooseOrder = function(q){
              $scope.canGoNext = true;
              $timeout(function(){ $scope.checkAnswer();},1);
            };

            $scope.inputAnswer = function(q){
              var s = $scope.item.typedIn;
              if(!s || s.length == 0){
                $scope.canGoNext = false; return;
              }

              $scope.canGoNext = true;
              $timeout(function(){ $scope.checkAnswer();},1);
            };

            $scope.cancel = function() {
              if($scope.askStartSingleTry){
                if($scope.timerInterval) $interval.cancel($scope.timerInterval);
                self.closeDialog($scope.dialogElement);
                return;                
              }
              if(it.DataJSON.repeatTime == -1){
                self.confirm($filter('trans')('TESTSINGLETRYCANCELHINT'),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                  $scope.saveTestResult();
                });
                return;
              }
              $scope.saveWorkInProgress().then(function(result){
                if(result){
                  if($scope.timerInterval) $interval.cancel($scope.timerInterval);
                  self.closeDialog($scope.dialogElement);
                }
              });
            };

            $scope.readLastAnswers();

            if(status.Status == "w") {
              // continue from last time 
              $scope.askSkipRightQuestions = false;
              $scope.skipRightAnswers = false;
            } 
            if(it.DataJSON.repeatTime == -1){
              // no repeat
              $scope.askStartSingleTry = true;
            }
            if(!$scope.askSkipRightQuestions && !$scope.askStartSingleTry) $scope.next();
          }
        });
      });

    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.findLastHandInDate = function(t,student){
      var filterSettings = {WHERE:"task",WHEREITEM:t};
      var journalData =
          self.getStudentFilteredJournal(student, filterSettings);
      for(var i=0; i < journalData.length; i++){
        if(journalData[i].Type == "taskdone"){
          return journalData[i].Created;
        }
      }
      var status = self.getUserTaskStatus(t, student, true);
      return status.Created;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.openTestResults = function(it,student,ev,answerData){
      if(!it.DataJSON.questions || it.DataJSON.questions.length == 0){
        self.alert("Für diesen Selbsttest wurden noch keine Fragen definiert.");
        return;
      }
      var isOpen = true;
      self.showDialog({
        templateUrl: "testresults.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          isOpen = false;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.withData = answerData ? answerData : null;
          $scope.item = JSON.parse(angular.toJson(it));
          $scope.randomNumber = $scope.item.DataJSON.randomOrder == "2" ? parseInt($scope.item.DataJSON.randomNumber ? $scope.item.DataJSON.randomNumber : 1) : 0;
          $scope.students = [];
          if($scope.randomNumber > $scope.item.DataJSON.questions.length)
            $scope.randomNumber = $scope.item.DataJSON.questions.length;

          if(self.user.Teacher == 1 && self.currentClass == null)
            self.apiPost("ajax",{"action":"getStudentsTaskStatus", "ID":it.ID}).then(function(data) {
              if(data.status){
                for(var key in data.status){
                  self.updateUser({ID:key, taskStatus:[data.status[key]] });
                }
              }
            });

          $scope.getStudentFrameColor = function(sel, user){
            var status = self.getUserTaskStatus(it, user, true);
            if(sel && sel.ID == user.ID) return '#039AF4';
            if(status.FeedbackStatus == "OK") return '#00a248'; // dark green
            if(status.FeedbackStatus == "x") return '#ff0000'; // red
            if(status.Status == "OK") return '#30f085'; // light green
            if(status.Status != "" && status.Status != "w") return '#ffce36'; // orange
            return '#fff';
          };

          $scope.hasStudentCheckedAnswer = function(q,a){
            for(var i=0; i < q.answerDetails[a].length; i++){
              if(q.answerDetails[a][i].ID == $scope.selectedStudent.ID){
                return true;
              }
            }
            return false;
          };
          $scope.hasStudentAnswered = function(q){
            for(var i=0; i < q.results.length; i++){
              if(q.results[i].student.ID == $scope.selectedStudent.ID) {
                if(q.results[i].answer != '0,') return q.results[i];
              }
            }
            return false;
          }

          $scope.refresh = function(){
            $scope.students = [];
            function skipStudent(s){
              if($scope.withData) return false;
              if(self.currentClassResultStudentFilter &&
                 self.currentClassResultStudentFilter.length > 0){
                var isIn = false;
                for(var i=0; i < self.currentClassResultStudentFilter.length; i++){
                  if(self.currentClassResultStudentFilter[i] == s.ID) {
                    isIn = true; break;
                  }
                }
                if(!isIn) return true;
              }
              return false;
            }
            function findStudent(list,s){
              if(!list || !list.length) return null;
              for(var i=0; i < list.length; i++){
                if(list[i].ID == s.ID) return list[i];
              }
              return null;
            }

            if($scope.withData){
              var ts = self.getUserTaskStatus(it, student, true);
              ts = JSON.parse(JSON.stringify(ts));
              ts.Answer = $scope.withData;
              $scope.results = [{'student': student,'status': ts}];
            }else
              $scope.results = self.getClassTaskResultData(it);

            for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
              $scope.item.DataJSON.questions[z].results = [];
            }
            for(var i=0; i < $scope.results.length; i++){
              if(skipStudent($scope.results[i].student)) continue;
              if(self.currentClass){
                // inside class add all students to the list to see missing ones
                if(findStudent($scope.students,$scope.results[i].student) == null)
                   $scope.students.push($scope.results[i].student);
              }

              if($scope.results[i].status.Status == 'OK' ||
                 $scope.results[i].status.Status == 'FAIL' ||
                 $scope.results[i].status.Status == 'x' ||
                 $scope.results[i].status.Status == '?'){
                if(findStudent($scope.students,$scope.results[i].student) == null)
                   $scope.students.push($scope.results[i].student);
                var p = null;
                if($scope.results[i].status.Answer){
                  p = $scope.results[i].status.Answer.split("|");
                  p.shift(); // remove first 3/5 value
                }
                for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
                  $scope.item.DataJSON.questions[z].results.push({
                    'student':$scope.results[i].student,
                    'answer':p && p.length > z ? p[z] : '',
                    'updated':moment(self.findLastHandInDate($scope.item, $scope.results[i].student))});
                }
              }
            }
            for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
              var q = $scope.item.DataJSON.questions[z];
              q.combinedResults = null;
              q.answerDetails = null;


              if(q.type == 'mc'){
                q.combinedResults = [];
                q.answerDetails = [];
                var total = 0;
                var maxTotal = 0;
                for(var i=0; i < q.answers.length; i++) {q.combinedResults.push(0); q.answerDetails.push([]);}
                for(var i=0; i < q.results.length; i++){
                  if(q.multi){
                    if(!q.results[i].answer) continue;
                    var as = q.results[i].answer.substring(2).split(",").map(Number); // remove 0/1 at start
                    for(var t=0; t < as.length; t++){
                      if(as[t] === "") continue;
                      if(as[t] > q.answerDetails.length-1) continue;
                      if(skipStudent(q.results[i].student)) continue;
                      q.combinedResults[as[t]]++;
                      if(findStudent(q.answerDetails[as[t]],q.results[i].student) == null)
                         q.answerDetails[as[t]].push(q.results[i].student);
                      total++;
                    }
                  }else{
                    if(!q.results[i].answer) continue;
                    if(skipStudent(q.results[i].student)) continue;
                    var index = parseInt(q.results[i].answer.substring(2));
                    q.combinedResults[index]++;
                    if(q.answerDetails[index] &&
                       findStudent(q.answerDetails[index],q.results[i].student) == null)
                       q.answerDetails[index].push(q.results[i].student);
                    total++;
                  }
                }
                q.combinedResultsTotal = total;
                q.combinedResultsMax = 0;
                for(var i=0; i < q.answers.length; i++) {
                  q.combinedResultsMax = Math.max(q.combinedResultsMax, q.combinedResults[i]);
                }
                q.combinedResultsMax = q.combinedResultsMax*1.1; // to keep 10% free on the right
              }

              if(q.type == 'order'){
                q.combinedResults = [];
                q.answerDetails = [];
                var total = 0;
                var maxTotal = 0;
                q.combinedResults = 0;
                q.answerDetails = [];
                for(var i=0; i < q.results.length; i++){
                  if(skipStudent(q.results[i].student)) continue;
                  if(!q.results[i].answer) continue;
                  var as = q.results[i].answer[0];
                  if(as != "0" && as != "1") continue; // wrong data
                  if(as == 1){
                    q.combinedResults++;
                    if(findStudent(q.answerDetails[as],q.results[i].student) == null)
                      q.answerDetails.push(q.results[i].student);
                  }
                  total++;
                }
                q.combinedResultsTotal = total;
                q.combinedResultsMax = total*1.1; // to keep 10% free on the right                
              }

              if(q.type == 'know'){
                q.combinedResults = [];
                q.answerDetails = [];
                var total = 0;
                q.combinedResults["0"] = 0;
                q.combinedResults["1"] = 0;
                q.answerDetails["0"] = [];
                q.answerDetails["1"] = [];
                for(var i=0; i < q.results.length; i++){
                  if(skipStudent(q.results[i].student)) continue;
                  if(!q.results[i].answer) continue;
                  var as = q.results[i].answer.substring(2); // remove 0/1 at start
                  if(as != "0" && as != "1") continue; // wrong data
                  q.combinedResults[as]++;

                  if(findStudent(q.answerDetails[as],q.results[i].student) == null)
                    q.answerDetails[as].push(q.results[i].student);
                  total++;
                }
                q.combinedResultsTotal = total;
                q.combinedResultsMax = 0;
                q.combinedResultsMax = Math.max(q.combinedResultsMax, q.combinedResults["0"]);
                q.combinedResultsMax = Math.max(q.combinedResultsMax, q.combinedResults["1"]);
                q.combinedResultsMax = q.combinedResultsMax*1.1; // to keep 10% free on the right
              }
            }
            if(isOpen && !$scope.withData) $timeout($scope.refresh,2000);
          };

          $scope.exportTestResults = function(type,filter,format,ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportTest.php?format="+format+"&user="+self.user.ID+"&code="+self.user.Salt+"&taskid="+it.ID+"&classid="+(self.currentClass ? self.currentClass.ID : 0)+"&type="+type;
            if(filter && filter.length > 0){
              url += '&filter='+filter.join(",");
            }
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = window.cleanFilename("LearningViewExport_"+(self.currentClass ? self.currentClass.Name+"_" : "")+it.Name+"_"+moment().format('YYYY_MM_DD'));
            filename = filename + "." + format;
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          if(student) $scope.selectedStudent = student;
          $scope.refresh();
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openSurvey = function(it,ev,ispreview){
      if(!it.DataJSON.questions || it.DataJSON.questions.length == 0){
        self.alert("Für diese Umfrage wurden noch keine Fragen definiert.");
        return;
      }

      var status = self.getUserTaskStatus(it, self.user, true);
      var wasCompleted = false;
      var startTime = (new Date()).getTime();

      var startSurvey = function(){
        self.showDialog({
          templateUrl: "survey.html",
          targetEvent: ev,
          skipHide:true, // keep other dialog open

          clickOutsideToClose: false,
          escapeToClose: false,
          onRemoving: function (event, removePromise) {
            if(wasCompleted) self.openTaskStudentRatingDialog(t,null);
          },
          controller: function ($scope, $mdDialog) {
            $scope.self = self;
            $scope.canGoNext = ispreview ? true : false;
            $scope.currentQuestion = 0;
            $scope.item = JSON.parse(angular.toJson(it));

            var pa = status.Answer ? status.Answer.split('|') : [];

            $scope.currentState = [];
            for(var i=0; i < $scope.item.DataJSON.questions.length; i++){
              $scope.currentState.push([]);
              // convert to new media type
              if($scope.item.DataJSON.questions[i].type == 'media'){
                if(pa.length > i && pa[i] && pa[i] != "" && pa[i].indexOf("https://") === 0){
                  var typenow = "file";
                  if(pa[i].match(/(jpg|png)$/)) typenow = "image";
                  if(pa[i].match(/(mp4|m4v)$/)) typenow = "video";
                  if(pa[i].match(/(m4a)$/)) typenow = "audio";
                  pa[i] = typenow + ";" + pa[i];
                }
              }
              if($scope.item.DataJSON.questions[i].type == 'image' ||
                 $scope.item.DataJSON.questions[i].type == 'audio' ||
                 $scope.item.DataJSON.questions[i].type == 'video' ||
                 $scope.item.DataJSON.questions[i].type == 'file'){
                var typenow = $scope.item.DataJSON.questions[i].type;
                $scope.item.DataJSON.questions[i]["m_"+typenow] = 1;
                $scope.item.DataJSON.questions[i].type = "media";
                if(pa.length > i && pa[i] && pa[i] != "" && pa[i].indexOf("https://") === 0){
                  pa[i] = typenow + ";" + pa[i];
                }
              }
            }

            $scope.isEmptyQuestion = function(){
              var q = it.DataJSON.questions[$scope.currentQuestion];
              if(q && q.type == 'poll'){
                if(!q.answers) return true;
                var allEmpty = true;
                for(var i=0; i < q.answers.length; i++){
                  if(q.answers[i].media) return false;
                  if(q.answers[i].text != "" && q.answers[i].text) return false;
                }
                return true;
              }
              return false;
            };

            $scope.readLastAnswers = function(){
              for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
                if(typeof (pa[z]) == "undefined") continue;
                $scope.currentState[z] = pa[z];
              }

              var q = $scope.item.DataJSON.questions[$scope.currentQuestion];

              $scope.item.typedIn = "";
              $scope.item.selectedIndex = -1;

              if(q.type == 'scale'){
                $scope.item.rating = q.d ? parseInt(q.d) : ''; // self.roundNumber(q.s / 2); default
              }

              // no saved value
              if($scope.currentQuestion > pa.length-1) return;
              if(pa[$scope.currentQuestion] === '') return;
              if(typeof pa[$scope.currentQuestion] == "undefined") return;

              if(q.type == 'poll'){
                if(q.multi){
                  var n = pa[$scope.currentQuestion].split(",").map(Number);
                  for(var i=0; i < q.answers.length; i++){
                    q.answers[i].selected = n.indexOf(i+'') >= 0;
                  }
                }else{
                  $scope.item.selectedIndex = pa[$scope.currentQuestion];
                }
              }
              if(q.type == 'scale'){
                $scope.item.rating = parseInt(pa[$scope.currentQuestion]);
              }
              if(q.type == 'input'){
                $scope.item.typedIn = pa[$scope.currentQuestion];
              }
              $scope.canGoNext = true;
              $scope.currentState[$scope.currentQuestion] = pa[$scope.currentQuestion];
            };

            $scope.readLastAnswers(); // load first answer

            $scope.setAnswer = function(results) {
              $scope.currentState[$scope.currentQuestion] = results[0].Type + ";"+results[0].URL;
              pa[$scope.currentQuestion] = $scope.currentState[$scope.currentQuestion];
              isMedia = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf(results[0].Type+";https://learningview.org/uploads") === 0;
              if(isMedia || results[0].Type == "text"){ $scope.canGoNext = true; $scope.next(); }
            }

            $scope.takeText = function(){
              var isText = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf("text;") === 0;
              self.showTextEditor($filter('trans')('TEXTEDITOR'),isText ? $scope.currentState[$scope.currentQuestion].replace(/^text;/,"") : "",it,null,(it.Social == 'pair' || it.Social == 'group'),(it.Groups && it.Groups != ''),null,function(text){
                if(text !== null) {
                  $scope.setAnswer([{Type:"text", URL:text.replace(/\|/g,"")}]);
                }
              },null,false,false,null);
            };

            $scope.takePicture = function(){
              var isImage = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf("image;https://learningview.org/uploads") === 0;

              self.takeUserMedia("image",isImage ? $scope.currentState[$scope.currentQuestion].replace("image;https://learningview.org/uploads","https://learningview.org/uploads") : "", $scope.setAnswer, {dialogMode: 1});
            };

            $scope.takeAudio = function(){
              var isAudio = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf("audio;https://learningview.org/uploads") === 0;

              self.takeUserMedia("audio",isAudio ? $scope.currentState[$scope.currentQuestion].replace("audio;https://learningview.org/uploads","https://learningview.org/uploads") : "", $scope.setAnswer, {dialogMode: 1});
            };

            $scope.takeVideo = function(){
              var isVideo = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf("video;https://learningview.org/uploads") === 0;

              self.takeUserMedia("video",isVideo ? $scope.currentState[$scope.currentQuestion].replace("video;https://learningview.org/uploads","https://learningview.org/uploads") : "", $scope.setAnswer, {dialogMode: 1});
            };

            //1009
            $scope.takeFile = function(){
              var isFile = $scope.currentState[$scope.currentQuestion] && $scope.currentState[$scope.currentQuestion].indexOf("file;https://learningview.org/uploads") === 0;

              self.takeUserMedia("file",isFile ? $scope.currentState[$scope.currentQuestion].replace("file;https://learningview.org/uploads","https://learningview.org/uploads") : "", $scope.setAnswer, {dialogMode: 0});
            };

            $scope.back = function() {
              if($scope.currentQuestion == 0) return;
              $scope.currentQuestion--;
              $scope.canGoNext = ispreview ? true : false;
              $scope.readLastAnswers();
            };

            $scope.saveWorkInProgress = function(){
              if(self.user.Teacher == "1") return true; // test only, do not save status
              var answer = $scope.currentState.join("|");
              if(status.Answer == answer) return true; // already saved

              self.confirm($filter('trans')('ASKSAVEWORKINPROGRESS'),$filter('trans')('YES'),ev,$filter('trans')('NO')).then(function(){
                self.storeInteractiveTaskResult(it,{status:"w", answer:answer, duration:Math.round(((new Date()).getTime()-startTime)/1000)},false); // no force journal
              });
            };

            $scope.next = function() {
              if($scope.canGoNext == false && !$scope.isEmptyQuestion()) return;
              $scope.currentQuestion++;
              if($scope.currentQuestion >= $scope.item.DataJSON.questions.length ){
                self.closeDialog($scope.dialogElement);

                if(self.user.Teacher == "1") {
                  if($scope.item.DataJSON.Public == "1"){
                    self.openSurveyResults(it,null,ev);
                  }else{
                    self.alert('<div style="text-align:center"><i class="fa fa-4x fa-question-circle"></i><br><br><i class="fa fa-fw fa-check"></i> '+$filter('trans')('DONE')+'</div>');
                  }
                  return; // test only, do not save status
                }

                var status = "OK";
                self.storeInteractiveTaskResult(it,{status:status, duration:Math.round(((new Date()).getTime()-startTime)/1000),
                  answer:$scope.currentState.join("|")},true).then(function(){
                    if($scope.item.DataJSON.Public == "1"){
                      self.openSurveyResults(it,null,ev);
                    }else{
                      self.alert('<div style="text-align:center"><i class="fa fa-4x fa-question-circle"></i><br><br><i class="fa fa-fw fa-check"></i> '+$filter('trans')('DONE')+'</div>');
                    }                    
                  }); // force

                wasCompleted = true;
                return;
              }
              $scope.canGoNext = ispreview ? true : false;
              $scope.readLastAnswers();
            };

            $scope.typedAnswer = function(q){
              var s = $scope.item.typedIn;
              if(!s || s.length == 0 || (q.MaxLen && q.MaxLen != '' && s.length > parseInt(q.MaxLen))){
                $scope.canGoNext = false; return;
              }
              $scope.currentState[$scope.currentQuestion] = s.replace(/\|/g,"");
              pa[$scope.currentQuestion] = $scope.currentState[$scope.currentQuestion];
              $scope.canGoNext = true;
            };

            $scope.chooseAnswer = function(q, a){
              $scope.canGoNext = true;
              if(q.multi){
                $scope.currentState[$scope.currentQuestion] = [];
                for(var i=0; i < q.answers.length; i++){
                  if(q.answers[i].selected) $scope.currentState[$scope.currentQuestion].push(i);
                }
                $scope.currentState[$scope.currentQuestion] = $scope.currentState[$scope.currentQuestion].join(",");
              }
              if(!q.multi) $scope.currentState[$scope.currentQuestion] = a;
              pa[$scope.currentQuestion] = $scope.currentState[$scope.currentQuestion];
            };

            $scope.cancel = function() {
              $scope.saveWorkInProgress();
              self.closeDialog($scope.dialogElement);
            };
          }
        });
      };

      if(!ispreview && self.currentClass && (it.Social == 'pair' || it.Social == 'group')){
        self.currentTaskPartners = self.getUserTaskStatusColleagues(it,self.user);
        self.askTaskUserPartners(it,ev,self.currentTaskPartners).then(function(partners){
          self.currentTaskPartners = partners.join(",");
          startSurvey();
        });          
      } else {
        self.currentTaskPartners = '';
        startSurvey();
      }

    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.getClassTaskResultData = function(it,filter){
      if(!self.user) return [];
      var r = [];
      // data either for student or teacher
      if(self.user.Teacher != '1'){
        if(self.currentClass)
          for(var i=0; i < self.currentClass.students.length; i++){
            if(filter && filter.indexOf(self.currentClass.students[i].ID) == -1) continue;
            var ts = self.getUserTaskStatus(it,self.currentClass.students[i]);
            r.push({'student': self.currentClass.students[i],'status': ts});
          }
        if(self.user && self.user.ID == -1){
          var ts = self.getUserTaskStatus(it,self.user);
          r.push({'student': self.user,'status': ts});
        } 
      }else{
        // only from current open class
        if(self.currentClass){
          for(var i=0; i < self.currentClass.students.length; i++){
            if(filter && filter.indexOf(self.currentClass.students[i].ID) == -1) continue;
            var ts = self.getUserTaskStatus(it,self.currentClass.students[i]);
            r.push({'student': self.currentClass.students[i],'status': ts});
          }
        }else{
          // from all classes
          for(var z=0; z < self.classList.length; z++){
            for(var i=0; i < self.classList[z].students.length; i++){
              if(filter && filter.indexOf(self.classList[z].students[i].ID) == -1) continue;
              var ts = self.getUserTaskStatus(it,self.classList[z].students[i]);
              var isThere = false;
              for(var x=0; x < r.length; x++){
                if(r[x].student.ID == self.classList[z].students[i].ID) {
                  isThere = true; break;
                }
              }
              if(!isThere)
                r.push({'student': self.classList[z].students[i],'status': ts});
            }
          }
        }
      }
      return r;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openCollectionResults = function(it,student,ev){
      self.openCollectionResultsOpen = true;
      self.showDialog({
        templateUrl: "collectionresults.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          self.openCollectionResultsOpen = false;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.task = it; //JSON.parse(angular.toJson(it));
          $scope.students = [];

          //1010
          if(self.user.Teacher != 1) {
            $timeout(function(){
              var possibleTypes = [];
              if($scope.task.DataJSON.collectText) possibleTypes.push('text');
              if($scope.task.DataJSON.collectImage) possibleTypes.push('image');
              if($scope.task.DataJSON.collectAudio) possibleTypes.push('audio');
              if($scope.task.DataJSON.collectVideo) possibleTypes.push('video');
              if($scope.task.DataJSON.collectFile) possibleTypes.push('file');

              self.addDropHandler($scope, $scope.dialogElement, possibleTypes, true, true, function(results) {
                //5555
                $scope.uploadCollectionItem(results, ev);
              });
            },0);
          }

          $scope.exportClassTaskResults = function(filter, ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportUploads.php?user="+self.user.ID+"&code="+self.user.Salt+"&classid="+self.currentClass.ID+"&taskid="+$scope.task.ID;
            if(filter && filter.length > 0){
              url += '&filter='+filter.join(",");
            }
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = window.cleanFilename("LearningViewExport_"+self.currentClass.Name+"_"+$scope.task.Name)+".zip";
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          $scope.getStudentFrameColor = function(sel, user){
            var status = self.getUserTaskStatus(it, user, true);
            if(sel && sel.ID == user.ID) return '#039AF4';
            if(status.FeedbackStatus == "OK") return '#00a248'; // dark green
            if(status.FeedbackStatus == "x") return '#ff0000'; // red
            if(status.Status == "OK") return '#30f085'; // light green
            if(status.Status != "" && status.Status != "w") return '#ffce36'; // orange
            return '#fff';
          };


          $scope.showItemFeedbacks = function(result,item,ev){
            var parent = $scope;
            self.showDialog({
              templateUrl: "collectionitemfeebacks.html",
              targetEvent: ev,
              clickOutsideToClose: false,
              escapeToClose: false,
              skipHide:true, // keep other dialog open
              onRemoving: function () {

              },
              controller: function ($scope, $mdDialog) {
                setTimeout(function(){
                  $('.md-dialog-container').last().on("click",function(event){
                    if($scope.isEditing) return;
                    if(event.target == this){
                      // clicked outside on background
                      // close if possible now
                      self.closeDialog($scope.dialogElement);
                    }
                  });
                },100);

                self.addFeedbackController($scope);

                $scope.$watch("isEditing", function(value) {
                  if(value) {
                    //1010
                    $timeout(function(){
                      self.addDropHandler($scope, $scope.dialogElement, ["audio", "text"], false, true, $scope.addFeedbackFromFiles);
                    });
                  }
                  else {
                    for(var i = self.dropHandler.length - 1; i >= 0 ; i--) {
                      if(self.dropHandler[i].dialog == $scope.dialogElement) {
                        self.dropHandler.splice(i, 1);
                      }
                    }
                  }
                });

                $scope.self = self;
                $scope.parent = parent;
                $scope.result = result;
                $scope.item = item;

                $scope.currentStars = 0;
                $scope.currentReview = "";
                $scope.isEditing = false;
                $scope.isRecording = false;

                $scope.changeToRecording = function(notRecording, lastAnswer){
                  $scope.currentTaskAnswer = lastAnswer ? lastAnswer : ""; // used for record scope
                  self.addAudioRecorderScope($scope, null, true);
                  $scope.isRecording = notRecording ? false : true;
                  $scope.currentReview = '';
                };

                if(item.Feedbacks)
                  for(var i=0; i < item.Feedbacks.length; i++){
                    if(item.Feedbacks[i].User == self.user.ID){
                      $scope.currentStars = item.Feedbacks[i].Stars;
                      $scope.currentReview = item.Feedbacks[i].Content;
                      if(item.Feedbacks[i].Content.indexOf('://learningview.org') > 0 && item.Feedbacks[i].Content.indexOf('.m4a') > 0)
                        $scope.changeToRecording(null, item.Feedbacks[i].Content);
                    }
                  }

                $scope.cancel = function() {
                  self.closeDialog($scope.dialogElement);
                };

                $scope.deleteItemFeedback = function(it,ev){
                  self.confirm($filter('trans')('REMOVECOLLECTIONITEMFEEDBACK'),$filter('trans')('DELETE'),ev).then(function(){
                    it.Content = "";
                    var action = {"action":"saveUserCollectionItemFeedback",
                                  "ID":parent.task.ID,
                                  "item":JSON.stringify(item),
                                  "user": result.student.ID,
                                  "feedback":JSON.stringify(it),
                                  "classid":self.currentClass.ID};
                    self.apiPost("ajax",action).then(function(){
                      self.keepAliveCallback().then(function(){
                        if($scope.item.Feedbacks){
                          var p = $scope.item.Feedbacks.indexOf(it);
                          if(p >= 0) $scope.item.Feedbacks.splice(p,1);
                        }
                        parent.refresh();
                      });
                    });
                  });
                };

                $scope.saveItemFeedback = function(ev){
                  var saveNow = function(){
                    var feedback = {Content:$scope.currentReview,
                                    Stars:$scope.currentStars};
                    var action = {"action":"saveUserCollectionItemFeedback",
                                  "ID":parent.task.ID,
                                  "item":JSON.stringify(item),
                                  "user": result.student.ID,
                                  "feedback":JSON.stringify(feedback),
                                  "classid":self.currentClass.ID};
                    self.apiPost("ajax",action).then(function(){
                      self.keepAliveCallback().then(function(){
                        parent.refresh();
                        self.closeDialog($scope.dialogElement);
                      });
                    });
                  };

                  var saveRecording = function(){
                    if($scope.isRecording){
                      // upload audio now
                      if($scope.audioURL.indexOf("blob:") == -1 &&
                         $scope.audioURL.indexOf("://learningview.org/") > 0){
                        $scope.currentReview = $scope.audioURL;
                        saveNow();
                      }else
                        self.uploadFile($scope.audioURL.indexOf("blob:") == 0 ? $scope.audioBlob : $scope.audioURL,
                          $scope.audioFilename, self.getMediaID(),'record',null,function(filename){
                          $scope.currentReview = filename;
                          saveNow();
                        });
                    } else saveNow();
                  };
                  if(self.user.Teacher == 1) saveRecording(); else
                  self.confirm($filter('trans')('PEERFEEDBACKREVIEWASKDONE'),$filter('trans')('PEERFEEDBACKREVIEWDONE'),ev).then(saveRecording);
                };
              }
            });
          };

          self.addCollectionRecorderScope($scope);

          $scope.countVisibleStudentCollectionItems = function(result){
            var c = 0;
            for(var i=0; i < result.collectionItems.length; i++){
              if($scope.selectedStudent == null && result.collectionItems[i].hideResult) continue;
              c++;
            }
            return c;
          }

          $scope.refresh = function(){
            $scope.gridMode = true;
            $scope.students = [];
            function skipStudent(s){
              if(self.currentClassResultStudentFilter &&
                 self.currentClassResultStudentFilter.length > 0){
                var isIn = false;
                for(var i=0; i < self.currentClassResultStudentFilter.length; i++){
                  if(self.currentClassResultStudentFilter[i] == s.ID) {
                    isIn = true; break;
                  }
                }
                if(!isIn) return true;
              }
              return false;
            }
            function findStudent(list,s){
              if(!list || !list.length) return null;
              for(var i=0; i < list.length; i++){
                if(list[i].ID == s.ID) return list[i];
              }
              return null;
            }
            // list of [student, status] for this task
            $scope.results = self.getClassTaskResultData(it);


            for(var i=0; i < $scope.results.length; i++){
              $scope.results[i].collectionItems = [];
              if(skipStudent($scope.results[i].student)) continue;
              if(findStudent($scope.students,$scope.results[i].student) == null){
                 $scope.students.push($scope.results[i].student);
              }

              if($scope.results[i].status.Answer &&
                 $scope.results[i].status.Answer != ""){
                try{
                  $scope.results[i].collectionItems =
                   JSON.parse($scope.results[i].status.Answer);

                  // remove double URLs fix
                  for(var x=0; x < $scope.results[i].collectionItems.length; x++){
                    for(var z=x+1; z < $scope.results[i].collectionItems.length; z++){
                      if($scope.results[i].collectionItems[x].URL ==
                         $scope.results[i].collectionItems[z].URL){
                        $scope.results[i].collectionItems.splice(z,1);
                        z--;
                      }
                    }
                  }

                }catch(e){}

                $scope.gridMode = $scope.gridMode && $scope.results[i].collectionItems.length <= 1;
              }
            }

            // find all items of students worked together and mark which one to display when selectedStudent == null
            function hideDoubleTeamEntries(result){
              if(!result.collectionItems || result.collectionItems.length == 0) return;
              for(var ii=0; ii < result.collectionItems.length; ii++){
                if(result.collectionItems[ii].team){
                  // this item was done by a team of students
                  var colleagues = result.collectionItems[ii].team.split(",").map(Number);
                  result.collectionItems[ii].colleagues = colleagues;
                  if(result.collectionItems[ii].hideResult) continue; // already hidden
                  for(var ci = 0; ci < colleagues.length; ci++){
                    if(colleagues[ci] == result.student.ID) continue; // not check self
                    var otherResults = null;
                    for(var zz = 0; zz < $scope.results.length; zz++){
                      if($scope.results[zz].student.ID == colleagues[ci]){
                        otherResults = $scope.results[zz];
                        break;
                      }
                    }
                    if(otherResults){
                      // search in all collection items of other person, if she does have the same
                      for(var zz=0; zz < otherResults.collectionItems.length; zz++){
                        if(otherResults.collectionItems[zz].URL == result.collectionItems[ii].URL){
                          otherResults.collectionItems[zz].hideResult = true;
                        }
                      }
                    }
                  }
                }
              }
            }

            // start with current user as he should be prefered here
            for(var i=0; i < $scope.results.length; i++){
              if($scope.results[i].student.ID == self.user.ID){
                hideDoubleTeamEntries($scope.results[i]);
              }
            }
            // no go for other users
            for(var i=0; i < $scope.results.length; i++){
              if($scope.results[i].student.ID != self.user.ID){
                hideDoubleTeamEntries($scope.results[i]);
              }
            }

            if(self.openCollectionResultsOpen) $timeout($scope.refresh,2000);
          };

          $scope.refresh();

          // preselect student
          if(student){
            for(var i=0; i < $scope.students.length; i++){
              if($scope.students[i].ID == student.ID){
                $scope.selectedStudent = $scope.students[i];
                break;
              }
            }
          }

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.openSurveyResults = function(it,student,ev, answerData){
      if(!it.DataJSON.questions || it.DataJSON.questions.length == 0){
        self.alert("Für diese Umfrage wurden noch keine Fragen definiert.");
        return;
      }
      var isOpen = true;
      self.showDialog({
        templateUrl: "surveyresults.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          isOpen = false;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.withData = answerData ? answerData : null;
          $scope.item = JSON.parse(angular.toJson(it));
          $scope.students = [];

          if(self.user.Teacher == 1 && self.currentClass == null)
            self.apiPost("ajax",{"action":"getStudentsTaskStatus", "ID":it.ID}).then(function(data) {
              if(data.status){
                for(var key in data.status){
                  self.updateUser({ID:key, taskStatus:[data.status[key]] });
                }
              }
            });

          $scope.getStudentFrameColor = function(sel, user){
            var status = self.getUserTaskStatus(it, user, true);
            if(sel && sel.ID == user.ID) return '#039AF4';
            if(status.FeedbackStatus == "OK") return '#00a248'; // dark green
            if(status.FeedbackStatus == "x") return '#ff0000'; // red
            if(status.Status == "OK") return '#30f085'; // light green
            if(status.Status != "" && status.Status != "w") return '#ffce36'; // orange
            return '#fff';
          }

          $scope.refresh = function(){
            $scope.students = [];
            function skipStudent(s){
              if($scope.withData) return false;
              if(self.currentClassResultStudentFilter &&
                 self.currentClassResultStudentFilter.length > 0){
                var isIn = false;
                for(var i=0; i < self.currentClassResultStudentFilter.length; i++){
                  if(self.currentClassResultStudentFilter[i] == s.ID) {
                    isIn = true; break;
                  }
                }
                if(!isIn) return true;
              }
              return false;
            }
            function findStudent(list,s){
              for(var i=0; i < list.length; i++){
                if(list[i].ID == s.ID) return list[i];
              }
              return null;
            }

            if($scope.withData){
              var ts = self.getUserTaskStatus(it, student, true);
              ts = JSON.parse(JSON.stringify(ts));
              ts.Answer = answerData;
              $scope.results = [{'student': student,'status': ts}];
            }else
              $scope.results = self.getClassTaskResultData(it);

            for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
              $scope.item.DataJSON.questions[z].results = [];
              // convert to new media type
              if($scope.item.DataJSON.questions[z].type == 'media'){
                for(var i=0; i < $scope.results.length; i++){
                  var p = $scope.results[i].status.Answer ?
                          $scope.results[i].status.Answer.split("|") : [];

                  if(p.length > z && p[z] && p[z] != "" && p[z].indexOf("https://") === 0){
                    var typenow = "file";
                    if(p[z].match(/(jpg|png)$/)) typenow = "image";
                    if(p[z].match(/(mp4|m4v)$/)) typenow = "video";
                    if(p[z].match(/(m4a)$/)) typenow = "audio";
                    p[z] = typenow + ";" + p[z];
                    $scope.results[i].status.Answer = p.join("|");
                  }
                }
              }

              if($scope.item.DataJSON.questions[z].type == 'image' ||
                 $scope.item.DataJSON.questions[z].type == 'audio' ||
                 $scope.item.DataJSON.questions[z].type == 'video' ||
                 $scope.item.DataJSON.questions[z].type == 'file'){
                var typenow = $scope.item.DataJSON.questions[z].type;
                $scope.item.DataJSON.questions[z]["m_"+typenow] = 1;
                $scope.item.DataJSON.questions[z].type = "media";

                for(var i=0; i < $scope.results.length; i++){
                  var p = $scope.results[i].status.Answer ?
                          $scope.results[i].status.Answer.split("|") : [];

                  if(p.length > z && p[z] && p[z] != "" && p[z].indexOf("https://") === 0){
                    p[z] = typenow + ";" + p[z];
                    $scope.results[i].status.Answer = p.join("|");
                  }
                }
              }
            }


            for(var i=0; i < $scope.results.length; i++){
              if(skipStudent($scope.results[i].student)) continue;
              if(self.currentClass){
                // inside class add all students to the list to see missing ones
                if(findStudent($scope.students,$scope.results[i].student) == null)
                   $scope.students.push($scope.results[i].student);
              }
              if($scope.results[i].status.Status == 'OK' ||
                 $scope.results[i].status.Status == 'x' ||
                 $scope.results[i].status.Status == '?'){
                // for all classes, add only complete results
                if(findStudent($scope.students,$scope.results[i].student) == null)
                   $scope.students.push($scope.results[i].student);
                var p = $scope.results[i].status.Answer ? $scope.results[i].status.Answer.split("|") : null;
                for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
                  $scope.item.DataJSON.questions[z].results.push({
                    'student':$scope.results[i].student,
                    'answer':p ? p[z] : '',
                    'updated':moment(self.findLastHandInDate($scope.item, $scope.results[i].student))});
                }
              }
            }
            for(var z=0; z < $scope.item.DataJSON.questions.length; z++){
              var q = $scope.item.DataJSON.questions[z];
              q.combinedResults = null;
              q.answerDetails = null;


              if(q.type == 'poll'){
                q.combinedResults = [];
                q.answerDetails = [];
                var total = 0;
                var maxTotal = 0;
                for(var i=0; i < q.answers.length; i++) {
                  q.combinedResults.push(0);
                  q.answerDetails.push([]);
                }
                for(var i=0; i < q.results.length; i++){
                  if(q.multi){
                    if(!q.results[i].answer) continue;
                    var as = q.results[i].answer.split(",");
                    for(var t=0; t < as.length; t++){
                      if(as[t] === "") continue;
                      if(as[t] > q.answerDetails.length-1) continue;
                      if(skipStudent(q.results[i].student)) continue;
                      q.combinedResults[as[t]]++;
                      if(findStudent(q.answerDetails[as[t]],q.results[i].student) == null)
                         q.answerDetails[as[t]].push(q.results[i].student);
                      total++;
                    }
                  }else{
                    if(!q.results[i].answer) continue;
                    if(skipStudent(q.results[i].student)) continue;
                    q.combinedResults[q.results[i].answer]++;
                    if(q.answerDetails[q.results[i].answer] &&
                       findStudent(q.answerDetails[q.results[i].answer],q.results[i].student) == null)
                       q.answerDetails[q.results[i].answer].push(q.results[i].student);
                    total++;
                  }
                }
                q.combinedResultsTotal = total;
                q.combinedResultsMax = 0;
                for(var i=0; i < q.answers.length; i++) {q.combinedResultsMax = Math.max(q.combinedResultsMax, q.combinedResults[i]); }
                q.combinedResultsMax = q.combinedResultsMax*1.1; // to keep 10% free on the right
              } 

              if(q.type == 'scale'){
                q.combinedResults = [];
                q.answerDetails = [];
                q.minVal = self.isNumber(q.r1) && self.isNumber(q.r2) ? q.r1 : 1;
                q.maxVal = self.isNumber(q.r1) && self.isNumber(q.r2) ? q.r2 : q.s;
                var total = 0;
                var maxTotal = 0;
                for(var i=0; i < q.maxVal-q.minVal+1; i++) {
                  q.combinedResults.push(0);
                  q.answerDetails.push([]);
                }
                for(var i=0; i < q.results.length; i++){
                  if(!q.results[i].answer) continue;
                  if(skipStudent(q.results[i].student)) continue;
                  var ar = parseInt(q.results[i].answer)-q.minVal;
                  q.combinedResults[ar]++;
                  if(q.answerDetails[ar] &&
                     findStudent(q.answerDetails[ar],q.results[i].student) == null)
                     q.answerDetails[ar].push(q.results[i].student);
                  total++;
                }
                q.combinedResultsTotal = total;
                q.combinedResultsMax = 0;
                for(var i=0; i < q.maxVal-q.minVal+1; i++) {q.combinedResultsMax = Math.max(q.combinedResultsMax, q.combinedResults[i]); }
                q.combinedResultsMax = q.combinedResultsMax*1.1; // to keep 10% free on the right
              }
            }
            if(isOpen && !$scope.withData) $timeout($scope.refresh,2000);
          };

          $scope.exportSurveyResults = function(type,filter,format,ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportSurvey.php?format="+format+"&user="+self.user.ID+"&code="+self.user.Salt+"&taskid="+it.ID+"&classid="+(self.currentClass ? self.currentClass.ID : 0)+"&type="+type;
            if(filter && filter.length > 0){
              url += '&filter='+filter.join(",");
            }
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = window.cleanFilename("LearningViewExport_"+(self.currentClass ? self.currentClass.Name+"_" : "")+it.Name+"_"+moment().format('YYYY_MM_DD'));
            filename = filename + "." + format;
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          if(student) $scope.selectedStudent = student;
          $scope.refresh();
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.openTaskUserList = function(it, ev){
      var isOpen = true;
      self.showDialog({
        templateUrl: "taskuserlist.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          isOpen = false;
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.item = JSON.parse(angular.toJson(it));
          $scope.students = [];

          $scope.getStudentFrameColor = function(user){
            var status = self.getUserTaskStatus(it, user, true);
            if(status.Status == "OK") return '#92eab9';
            if(status.Status == "?") return '#aaeab9';
            if(status.Status == "x") return '#ea9292';
            return '#fff';
          }

          $scope.refresh = function(){
            $scope.students = [];
            function findStudent(list,s){
              for(var i=0; i < list.length; i++){
                if(list[i].ID == s.ID) return list[i];
              }
              return null;
            }

            $scope.results = self.getClassTaskResultData(it);

            for(var i=0; i < $scope.results.length; i++){
              if($scope.results[i].status.Status == 'OK' ||
                 $scope.results[i].status.Status == 'x' ||
                 $scope.results[i].status.Status == '?'){
                if(findStudent($scope.students,$scope.results[i].student) == null)
                   $scope.students.push($scope.results[i].student);
              }
            }

            if(isOpen) $timeout($scope.refresh,2000);
          };
          $scope.refresh();
          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
          };
        }
      });
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.saveUserRubricStatus = function(rubric,row,col,status,input,goal,task){
      var deferred = $q.defer();
      var action = {"action":"saveUserRubricStatus", "ID":rubric.ID,"classid":self.currentClass.ID,
                    "row":row,"col":col,"status":status, "goal":goal ? goal.ID : 0, "task":task ? task.ID : 0};
      if(typeof input === "string") action.input = input; // input text send                   
      if(self.user.ID == -1){
        var cs = self.getUserRubricStatus(rubric, self.user);
        var maxID = 0;
        for(var i=0; i < cs.length; i++){
          maxID = Math.max(cs[i].ID,maxID);
        }
        cs.push({"ID":maxID+1, "Status":status, "Row":row,"Col":col,"Rubric":rubric.ID,
                 "Goal":goal ? goal.ID : 0, "Task":task ? task.ID : 0,
                 "User":self.user.ID,"Owner":self.user.ID,"Created":new Date().toMysqlFormat()});
        self.updateUser({ID:self.user.ID, rubricStatus:cs});
        deferred.resolve();
      }else
        self.apiPost("ajax",action).then(function(data){
          self.updateUser({ID:self.user.ID, rubricStatus:data.rubricStatus});
          deferred.resolve();
        });
      return deferred.promise;
    }

    self.publishTeacherRubricStatus = function(student,rubric,goal,task){
      var deferred = $q.defer();
      var action = {"action":"publishTeacherRubricStatus", "ID":rubric.ID, "classid":self.currentClass.ID,
                    "student":student.ID, "goal":goal ? goal.ID : 0, "task":task ? task.ID : 0};
      self.apiPost("ajax",action).then(function(data){
        deferred.resolve();
      });
      return deferred.promise;
    }

    self.saveTeacherRubricStatus = function(student,rubric,row,col,status,input,goal,task){
      var deferred = $q.defer();
      var action = {"action":"saveTeacherRubricStatus", "ID":rubric.ID, "classid":self.currentClass.ID,
                    "row":row,"col":col,"status":status, "student":student.ID, "goal":goal ? goal.ID : 0, "task":task ? task.ID : 0};
      if(typeof input === "string") action.input = input; // input text send                   
      self.apiPost("ajax",action).then(function(data){
        self.updateUser({ID:student.ID, rubricStatus:data.rubricStatus});
        deferred.resolve();
      });
      return deferred.promise;
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////        

    self.addUserRubricCellStatusScope = function($scope){
      if(!$scope.getCellStatus){        
        $scope.getCellStatus = function(r,c){
          var key = r.ID + "_"+c.ID;
          return self.users[$scope.student.ID] && 
                 self.users[$scope.student.ID].rubricStatusMapped[$scope.it.ID] &&
                 self.users[$scope.student.ID].rubricStatusMapped[$scope.it.ID][key] ?
                 self.users[$scope.student.ID].rubricStatusMapped[$scope.it.ID][key] : null;
        };   
        // only once     
        $scope.showMode = self.user.Teacher == 0 ? 'all':'teacher';
      }
      return $scope.getCellStatus;
    }

    self.isRubricSpannedRow = function(r){
      return r && r.span == 1;
    };

    self.isRubricSpannedColumn = function(c){
      return c && c.span == 1;
    };

    self.getRubricCellByRowCol = function(it, rowID, colID){
      if(!it || !it.DataJSON || !it.DataJSON.cells) return null;
      for(var i = 0; i < it.DataJSON.cells.length; i++){
        if(it.DataJSON.cells[i].row == rowID && it.DataJSON.cells[i].col == colID){
          return it.DataJSON.cells[i];
        }
      }
      return null;
    };

    // Exact match comparator for Angular's `filter` in rubric cell loops.
    // Prevents partial matches like "1" matching "10" and normalizes number/string IDs.
    self.rubricCellFilterComparator = function(actual, expected){
      if(expected === undefined || expected === null) return true;
      if(actual === undefined || actual === null) return false;
      return String(actual) === String(expected);
    };

    self.getRubricCellText = function(it, rowID, colID){
      var cell = self.getRubricCellByRowCol(it, rowID, colID);
      return cell && cell.Text ? cell.Text : "";
    };

    self.getRubricBodyColumnCount = function(it){
      var count = 0;
      var columns = it && it.DataJSON && it.DataJSON.columns ? it.DataJSON.columns : [];
      for(var i = 1; i < columns.length; i++){
        if(!self.isRubricSpannedColumn(columns[i])) count++;
      }
      return count;
    };

    self.getRubricRowNameColspan = function(it, r){
      if(!self.isRubricSpannedRow(r)) return null;
      return self.getRubricBodyColumnCount(it) + 1; // +1 for rubric-rowName column itself
    };

    self.getRubricColumnNameRowspan = function(it, c){
      if(!self.isRubricSpannedColumn(c)) return null;
      var rows = it && it.DataJSON && it.DataJSON.rows ? it.DataJSON.rows.length : 0;
      return rows; // header row + all visible body rows (rows[0] is header source)
    };

    self.showRubricCell = function(r, c){
      return !self.isRubricSpannedRow(r) && !self.isRubricSpannedColumn(c);
    };

    self.normalizeRubricGridSizeValue = function(value){
      if(value === undefined || value === null) return null;
      if(typeof value === "number"){
        if(!isFinite(value) || value <= 0) return null;
        return value + "px";
      }
      var s = $.trim(String(value));
      if(s === "") return null;
      if(/^\d+(\.\d+)?$/.test(s)){
        var n = parseFloat(s);
        if(!isFinite(n) || n <= 0) return null;
        return n + "px";
      }
      if(/^\d+(\.\d+)?(px|%|em|rem|vh|vw)$/.test(s)) return s;
      return null;
    };

    self.getRubricGridTableStyle = function(it){
      var width = self.normalizeRubricGridSizeValue(it && it.DataJSON ? it.DataJSON.width : null);
      var height = self.normalizeRubricGridSizeValue(it && it.DataJSON ? it.DataJSON.height : null);
      var style = { width: width ? width : "calc(100% - 4px)" };
      if(width) style["max-width"] = "none";
      if(height) style.height = height;
      return style;
    };

    self.resolveRubricInputDisplay = function(currentHistory, rubricInputDraft, draftKey, statusInput){
      if(currentHistory) return statusInput ? statusInput : "";
      if(rubricInputDraft && draftKey !== undefined && draftKey !== null && rubricInputDraft[draftKey] !== undefined){
        return rubricInputDraft[draftKey];
      }
      return statusInput ? statusInput : "";
    };

    self.getRubricGridRowHeightStyle = function(r){
      if(r && r.heightPx !== undefined && r.heightPx !== null && r.heightPx !== ""){
        var hp = parseFloat(r.heightPx);
        if(isFinite(hp) && hp > 0) return hp + "px";
      }
      if(r && r.heightEm !== undefined && r.heightEm !== null && r.heightEm !== ""){
        var he = parseFloat(r.heightEm);
        if(isFinite(he) && he > 0) return he + "em";
      }
      return "";
    };

    self.showRubricGridCell = function(it, rowIndex, colIndex){
      var rows = it && it.DataJSON && it.DataJSON.rows ? it.DataJSON.rows : [];
      var cols = it && it.DataJSON && it.DataJSON.columns ? it.DataJSON.columns : [];
      if(rowIndex < 0 || rowIndex >= rows.length) return false;
      if(colIndex < 0 || colIndex >= cols.length) return false;

      var r = rows[rowIndex];
      var c = cols[colIndex];

      // Zellen unter einer span-Spalte werden vom rowspan der Kopfzelle abgedeckt.
      if(rowIndex > 0 && self.isRubricSpannedColumn(c)) return false;
      // Zellen rechts von einer span-Zeile werden vom colspan der ersten Zelle abgedeckt.
      if(colIndex > 0 && self.isRubricSpannedRow(r)) return false;
      return true;
    };
    
    self.getRubricGridColumnMenuRowIndex = function(it){
      var rows = it && it.DataJSON && it.DataJSON.rows ? it.DataJSON.rows : [];
      for(var i = 0; i < rows.length; i++){
        if(!self.isRubricSpannedRow(rows[i])) return i;
      }
      return rows.length > 0 ? 0 : -1;
    };

    self.getRubricGridRowMenuColumnIndex = function(it){
      var cols = it && it.DataJSON && it.DataJSON.columns ? it.DataJSON.columns : [];
      for(var i = 0; i < cols.length; i++){
        if(!self.isRubricSpannedColumn(cols[i])) return i;
      }
      return cols.length > 0 ? 0 : -1;
    };

    self.isRubricGridColumnMenuRow = function(it, rowIndex){
      return rowIndex === self.getRubricGridColumnMenuRowIndex(it);
    };

    self.isRubricGridRowMenuColumn = function(it, colIndex){
      return colIndex === self.getRubricGridRowMenuColumnIndex(it);
    };

    self.showRubricGridMenuCell = function(it, rowIndex, colIndex){
      return self.isRubricGridColumnMenuRow(it, rowIndex) || self.isRubricGridRowMenuColumn(it, colIndex);
    };
    self.getRubricGridColspan = function(it, r, c, rowIndex, colIndex){
      if(colIndex !== 0) return null;
      if(!self.isRubricSpannedRow(r)) return null;
      return self.getRubricBodyColumnCount(it) + 1;
    };

    self.getRubricGridRowspan = function(it, r, c, rowIndex, colIndex){
      if(rowIndex !== 0) return null;
      if(!self.isRubricSpannedColumn(c)) return null;
      var rows = it && it.DataJSON && it.DataJSON.rows ? it.DataJSON.rows.length : 0;
      return rows > 0 ? rows : null;
    };

    self.isRubricCellClickable = function(r, c){
      return !(r && r.inactive == 1) && !(c && c.inactive == 1);
    };
    self.isRubricCellInput = function(r,c){
      var rowInput = !!(r && r.input == 1);
      var colInput = !!(c && c.input == 1);
      if(!rowInput && !colInput) return false;

      var rowInactive = !!(r && r.inactive == 1);
      var colInactive = !!(c && c.inactive == 1);
      if(!rowInactive && !colInactive) return true;

      // Merged "span" cells can be represented by an inactive helper row/column.
      // In that case, keep input enabled for the visible merged cell.
      var allowByRowSpanInput = rowInput && !!(r && r.span == 1);
      var allowByColSpanInput = colInput && !!(c && c.span == 1);
      return allowByRowSpanInput || allowByColSpanInput;
    }

    ///////////////////////////////////////////////////////////////////////////////////////////////////        

    self.openStudentRubric = function(it,student,colleagues,goal,task,ev){
      var deferred = $q.defer();
      var autoRefresh = null;
      self.showDialog({
        templateUrl: "showStudentRubric.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          if(autoRefresh) $interval.cancel(autoRefresh);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.student = student;
          $scope.it = it;
          $scope.historySlider = {v:0};
          $scope.history = [];
          $scope.currentHistory = null;
          $scope.showMode = self.user.Teacher == 1 ? "teacher" : "all";
          $scope.task = task;
          $scope.goal = goal;

          if(colleagues && colleagues != ''){
            $scope.colleagues = [];
            $scope.colleagues.push(student);
            var ids = colleagues.split(",");
            for(var i=0; i < self.currentClass.students.length; i++){
              var found = false;
              for(var z=0; z < ids.length; z++){
                if(self.currentClass.students[i].ID == ids[z]){
                  found = true;
                  break;
                }
              }
              if(found) $scope.colleagues.push(self.currentClass.students[i]);
            }
          }

          $scope.setShowMode = function(v){
            $scope.showMode = v;
            $scope.refreshHistory();
            $scope.currentHistory = null;
          }

          $scope.exportRubric = function(format, rubric, student, ev){
            $scope.waitForDownload = true;
            var url = "https://learningview.org/api/exportRubric.php?user="+self.user.ID+"&code="+self.user.Salt+"&rubric="+encodeURIComponent(rubric.GUID)+"&format="+format+"&mode="+$scope.showMode+(student ? '&student='+student.ID :'')+($scope.currentHistory ? "&historydate="+$scope.currentHistory.d : '')+(task ? "&task="+task : "");
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = rubric.Name + (student ? "_"+student.Name+"_"+student.Surname : "");
            filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
            var filename = window.cleanFilename('LearningView_'+filename+"_"+moment().format('YYYY_MM_DD'))+(format == "pdf" ? ".pdf" : ".xlsx");
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          autoRefresh = $interval(function () {
            self.updateRubricsStatus().then(function(){
              $scope.refreshHistory();
            });
          }, 10000);
          
          $scope.$watch('historySlider.v', function(newVal, oldVal) {
            if (newVal !== oldVal && newVal !== undefined) {
              $scope.openHistory($scope.history[-newVal]);
            }
          });

          $scope.openHistory = function(h){
            $scope.cellStatusCache = {};
            $scope.currentHistory = h;
            if(h)
              $scope.historySlider.v = -$scope.history.indexOf(h); else
              $scope.historySlider.v = 0;
            // first = none
            if($scope.history.length > 0 && $scope.history[0].d == h.d){
              $scope.currentHistory = null;
            }
          };

          $scope.refreshHistory = function(){
            $scope.history = [];
            var isStillThere = false;
            var dates = [];
            var d = null;
            var cs = self.getUserRubricStatus(it, $scope.student);
            if($scope.showMode != "none")
            for(var i=0; i < cs.length; i++){
              d = cs[i].Created.slice(0,10);
              if(dates.indexOf(d) != -1) continue; // already there
              dates.push(d);
              $scope.history.push({d:d});
              if($scope.currentHistory && $scope.currentHistory.d == d) isStillThere = $scope.history[$scope.history.length-1];
            }                      
            if(d){
              // add an empty date before any changes made
              var dd = new Date(d);
              dd.setTime(dd.getTime() - (24*60*60*1000));
              d = dd.toMysqlFormat().slice(0,10);
              $scope.history.push({d:d});
              if($scope.currentHistory && $scope.currentHistory.d == d) isStillThere = $scope.history[$scope.history.length-1];
            }  
            $scope.history.sort(function(a,b){
              return new Date(a.d) < new Date(b.d) ? 1 : (new Date(a.d) > new Date(b.d) ? -1 : 0);
            });
            if($scope.history.length == 0){
              $scope.showHistory = false;
              $scope.currentHistory = null;
              $scope.historySlider.v = 0;
              return;
            }
            if($scope.currentHistory && !isStillThere){
              $scope.openHistory($scope.history[0]);
            }
            if($scope.currentHistory && isStillThere){
              $scope.openHistory(isStillThere);
            }
          };

          $scope.refreshHistory();

          $scope.cellStatusCache = {};
          $scope.rubricInputDraft = {};
          $scope.getRubricInputKey = function(r,c,role){
            var studentID = $scope.student && $scope.student.ID ? $scope.student.ID : 0;
            return role + "_" + studentID + "_" + r.ID + "_" + c.ID;
          };
          $scope.ensureRubricInputDraft = function(r,c,status){
            if(!self.isRubricCellInput(r,c)) return;
            var cs = status ? status : $scope.getCellStatus(r,c);
            if(!cs) cs = {student:null, teacher:null};
            var studentKey = $scope.getRubricInputKey(r,c,'student');
            var teacherKey = $scope.getRubricInputKey(r,c,'teacher');
            if($scope.rubricInputDraft[studentKey] === undefined){
              $scope.rubricInputDraft[studentKey] = cs.student && typeof cs.student.Input === "string" ? cs.student.Input : "";
            }
            if($scope.rubricInputDraft[teacherKey] === undefined){
              $scope.rubricInputDraft[teacherKey] = cs.teacher && typeof cs.teacher.Input === "string" ? cs.teacher.Input : "";
            }
          };
          $scope.saveRubricCellInput = function(r,c,role){
            if(!self.isRubricCellInput(r,c) || $scope.currentHistory) return;
            var cs = $scope.getCellStatus(r,c);
            var key = $scope.getRubricInputKey(r,c,role);
            var inputText = $scope.rubricInputDraft[key];
            if(inputText === undefined || inputText === null) inputText = "";
            if(typeof inputText !== "string") inputText = "" + inputText;
            inputText = self.trimHTML(inputText);
            $scope.rubricInputDraft[key] = inputText;

            if(role == "teacher"){
              var teacherStatus = "";
              if(inputText && inputText !== ""){
                teacherStatus = "o"; // always o
              }
              self.saveTeacherRubricStatus($scope.student,it,r.ID,c.ID,teacherStatus,inputText,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};
              });
            }else{
              var studentStatus = inputText && inputText !== "" ? "x" : "";
              self.saveUserRubricStatus(it,r.ID,c.ID,studentStatus,inputText,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};
              });
            }
          };
          $scope.hasRubricInputCells = function(){
            if(!it || !it.DataJSON || !it.DataJSON.rows || !it.DataJSON.columns) return false;
            for(var ri = 0; ri < it.DataJSON.rows.length; ri++){
              for(var ci = 0; ci < it.DataJSON.columns.length; ci++){
                if(!self.showRubricGridCell(it, ri, ci)) continue;
                if(self.isRubricCellInput(it.DataJSON.rows[ri], it.DataJSON.columns[ci])) return true;
              }
            }
            return false;
          };
          $scope.showRubricInputToolbar = function(){
            if($scope.currentHistory) return false;
            if(!$scope.hasRubricInputCells()) return false;
            if(self.user.Teacher == 1) return $scope.showMode == "all" || $scope.showMode == "teacher";
            return $scope.showMode == "all" || $scope.showMode == "student";
          };

          $scope.getCellStatus = function(r,c){
            var cacheKey = r.ID + '_' + c.ID;
            if ($scope.cellStatusCache[cacheKey]) {
              return $scope.cellStatusCache[cacheKey];
            }
            var cs = self.getUserRubricStatus(it, $scope.student);
            var status = {'student':null,'teacher':null};
            for(var i=0; i < cs.length; i++){
              if($scope.currentHistory && $scope.currentHistory.d < cs[i].Created.slice(0,10)) continue; // not yet 

              if(cs[i].Row == r.ID && cs[i].Col == c.ID){ 
                // newst is first
                if(cs[i].Owner == $scope.student.ID && status.student == null)
                  status.student = cs[i];
                if(cs[i].Owner != $scope.student.ID && status.teacher == null)
                  status.teacher = cs[i];
                if(status.student && status.teacher) break;
              }
            }
            $scope.cellStatusCache[cacheKey] = status;
            return status;
          }

          $scope.$watch(function() {
            return self.getUserRubricStatus(it, $scope.student).length;
          }, function(newVal, oldVal) {
            if (newVal !== oldVal) {
              $scope.refreshHistory();
              $scope.cellStatusCache = {};
            }
          });

          $scope.hasFilledRubricCells = function(){
            for(var i=0; i < it.DataJSON.cells.length; i++){
              var r = {ID:it.DataJSON.cells[i].row};
              var c = {ID:it.DataJSON.cells[i].col};
              var cs = $scope.getCellStatus(r,c);
              if(self.user.Teacher == 1)
                if(cs.teacher && cs.teacher.Status != ""){
                  return true;
                }
              if(self.user.Teacher == 0)
                if(cs.student && cs.student.Status != ""){
                  return true;
                }
            }
          }

          $scope.hasPending = function(){
            if(self.user.Teacher == 1 && !$scope.currentHistory){
              for(var i=0; i < it.DataJSON.cells.length; i++){
                var r = {ID:it.DataJSON.cells[i].row};
                var c = {ID:it.DataJSON.cells[i].col};
                var cs = $scope.getCellStatus(r,c);
                if(cs.teacher && cs.teacher.Status == "o"){
                  return true;
                }
              }
            }
            return false;
          };

          $scope.publishPending = function(){
            if(self.user.Teacher == 1 && !$scope.currentHistory){
              var done = 0;
              var sendPublished = false;
              for(var i=0; i < it.DataJSON.cells.length; i++){
                var r = {ID:it.DataJSON.cells[i].row};
                var c = {ID:it.DataJSON.cells[i].col};
                var cs = $scope.getCellStatus(r,c);
                if(cs.teacher && cs.teacher.Status == "o"){
                  done++;
                  if(!sendPublished){
                    sendPublished = true;
                    self.publishTeacherRubricStatus($scope.student,it,goal,task);
                  }
                  self.saveTeacherRubricStatus($scope.student,it,r.ID,c.ID,"x",cs.teacher.Input,goal,task).then(function(){
                    done--;
                    if(done == 0){
                      $scope.currentHistory = null;
                      $scope.refreshHistory();
                      $scope.cellStatusCache = {};
                    }
                  });
                }
              }
            }
          };

          $scope.selectStudent = function(s) {
            $scope.student = s;
            $scope.currentHistory = null;
            $scope.refreshHistory();
            $scope.rubricInputDraft = {};
            $scope.cellStatusCache = {};
            $scope.reloadStudent = true;
            $timeout(function(){ $scope.reloadStudent = false; },1);
          };

          $scope.clickCell = function(r,c){
            var sel = window.getSelection && window.getSelection();
            if(sel && sel.toString().length > 0) return; // selecting text not trigger
            if(r.inactive || c.inactive) return; // inactive
            if($scope.showMode == "none") return;
            if($scope.showMode == "teacher" && self.user.Teacher == 0) return;
            if($scope.showMode == "student" && self.user.Teacher == 1) return;

            if($scope.currentHistory){
              $scope.openHistory($scope.history[0]);
              return;
            }
            var cs = $scope.getCellStatus(r,c);
            if(self.user.Teacher == 1){
              var status = (cs.teacher && (cs.teacher.Status == "x" || cs.teacher.Status == "o")) ? "" : "o";
              self.saveTeacherRubricStatus($scope.student,it,r.ID,c.ID,status,cs.teacher ? cs.teacher.Input : false, goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};                
              });
            }else{
              var status = cs.student && cs.student.Status == "x" ? "" : "x";
              self.saveUserRubricStatus(it,r.ID,c.ID,status,cs.student ? cs.student.Input : false,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};                
              });
            }
          }

          $scope.resetRubric = function(ev){
            self.confirm($filter('trans')('ASKRESETRUBRIC'),$filter('trans')('OK'),ev).then(function(){
              var p = {"ID":it.ID};
              if(task) p["task"] = task.ID;
              if(goal) p["goal"] = goal.ID;
              if(self.user.Teacher == 0)
                p["action"] = "resetUserRubricStatus";
              if(self.user.Teacher == 1){
                p["action"] = "resetTeacherRubricStatus";
                p["student"] = $scope.student.ID;
              }

              self.apiPost("ajax",p).then(function(data) {
                $scope.rubricInputDraft = {};
                $scope.cellStatusCache = {};
                self.updateRubricsStatus().then(function(){
                  $scope.rubricInputDraft = {};
                  $scope.cellStatusCache = {};
                  $scope.refreshHistory();
                });
              });          
            });
          }

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve();            
          };

          $scope.selectStudent(student);
        }
      });
      return deferred.promise;
    };

    self.openClassRubric = function(it,c,goal,task,ev){
      var deferred = $q.defer();
      var autoRefresh = null;
      self.showDialog({
        templateUrl: "showClassRubric.html",
        targetEvent: ev,
        clickOutsideToClose: true,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
          if(autoRefresh) $interval.cancel(autoRefresh);
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.c = c ? c : self.currentClass;
          $scope.it = it;
          $scope.history = [];
          $scope.currentHistory = null;
          $scope.cellStatusCache = {};
          $scope.showMode = "teacher";
          $scope.selectedStudent = null;
          $scope.historySlider = {v:0};
          $scope.task = task;
          $scope.goal = goal;

          $scope.setShowMode = function(v){
            $scope.showMode = v;
            $scope.refreshHistory();
            $scope.currentHistory = null;
          }

          $scope.exportRubric = function(format, rubric, student, ev){
            $scope.waitForDownload = true;
            var studentsFilterParam = "";
            if(!student) studentsFilterParam = "&classid="+$scope.c.ID;
            if(!student &&
               self.currentClassResultStudentFilter &&
               self.currentClassResultStudentFilter.length > 0){
              var filteredStudents = [];
              for(var si = 0; si < $scope.c.students.length; si++){
                filteredStudents.push($scope.c.students[si].ID);
              }
              if(filteredStudents.length > 0){
                studentsFilterParam += "&students="+filteredStudents.join(",");
              }
            }
            var url = "https://learningview.org/api/exportRubric.php?user="+self.user.ID+"&code="+self.user.Salt+"&rubric="+encodeURIComponent(rubric.GUID)+"&format="+format+"&mode="+$scope.showMode+(student ? '&student='+student.ID :'')+studentsFilterParam+($scope.currentHistory ? "&historydate="+$scope.currentHistory.d : '')+(task ? "&task="+task : "");
            var frame = $('<iframe frameborder="0" allowfullscreen="1" allow="autoplay; encrypted-media" src="'+url+'" style="position:absolute;left:-100px;top:0;width:1px;height:1px"></iframe>');
            function checkDownload(){
              if(document.cookie.indexOf("fileDownload=true") > -1) {
                var cookieData = "fileDownload=; path=/; expires=" + new Date(0).toUTCString() + ";";
                document.cookie = cookieData;
                setTimeout(function(){ frame.remove();},1000);
                $scope.waitForDownload = false;
              }else
                $timeout(checkDownload,100);
            }
            var filename = rubric.Name + (student ? "_"+student.Name+"_"+student.Surname : "");
            filename = filename.replace(/[^\w\d\-_~;\[\]\(\).]/g, '_');
            var filename = window.cleanFilename('LearningView_'+filename+"_"+moment().format('YYYY_MM_DD'))+(format == "pdf" ? ".pdf" : ".xlsx");
            if(window.electron){
              window.downloadElectronSaveAs(url,filename,function(){
                $timeout(function(){$scope.waitForDownload = false;},0);
              });
            }else
            if(typeof cordova != "undefined"){
              self.downloadFile(url,filename,true);
              $timeout(function(){$scope.waitForDownload = false;},500);
            }else{
              $('body').append(frame);
              checkDownload();
            }
          };

          $scope.refresh = function(clearall){
            self.updateRubricsStatus().then(function(){
              if(clearall){
                $scope.rubricInputDraft = {};
              }
              $scope.refreshHistory();
              $scope.cellStatusCache = {};
            });
          };

          autoRefresh = $interval(function () {
            $scope.refresh();
          }, 10000);
          
          $scope.$watch('historySlider.v', function(newVal, oldVal) {
            if (newVal !== oldVal && newVal !== undefined) {
              $scope.openHistory($scope.history[-newVal]);
            }
          });

          $scope.openHistory = function(h){
            $scope.cellStatusCache = {};
            $scope.currentHistory = h;
            if(h)
              $scope.historySlider.v = -$scope.history.indexOf(h); else
              $scope.historySlider.v = 0;
            // first = none
            if($scope.history.length > 0 && $scope.history[0].d == h.d){
              $scope.currentHistory = null;
            }
          };

          $scope.refreshHistory = function(){
            $scope.history = [];
            var isStillThere = false;
            var dates = [];
            var d = null;
            if($scope.showMode != "none")
            for(var s = 0; s < $scope.c.students.length; s++){
              if($scope.selectedStudent && $scope.selectedStudent.ID != $scope.c.students[s].ID) continue;
              if(self.currentClassResultStudentFilter &&
                 self.currentClassResultStudentFilter.length > 0 &&
                 self.currentClassResultStudentFilter.indexOf($scope.c.students[s].ID) == -1) continue;
              var cs = self.getUserRubricStatus(it, $scope.c.students[s]);
              for(var i=0; i < cs.length; i++){
                if($scope.showMode == "student" && cs[i].Owner != cs[i].User) continue;
                if($scope.showMode == "teacher" && cs[i].Owner == cs[i].User) continue;
                if(cs[i].Status == 'o' && self.user.Teacher == 0) continue;
                d = cs[i].Created.slice(0,10);
                if(dates.indexOf(d) != -1) continue; // already there
                dates.push(d);
                $scope.history.push({d:d});
                if($scope.currentHistory && $scope.currentHistory.d == d) isStillThere = $scope.history[$scope.history.length-1];
              }          
            }
            if($scope.history.length == 0){
              $scope.showHistory = false;
              $scope.currentHistory = null;
              $scope.historySlider.v = 0;
              return;
            }

            $scope.history.sort(function(a,b){
              return new Date(a.d) < new Date(b.d) ? 1 : (new Date(a.d) > new Date(b.d) ? -1 : 0);
            });

            d = $scope.history[$scope.history.length-1].d; 
            // add an empty date before any changes made
            var dd = new Date(d);
            dd.setTime(dd.getTime() - (24*60*60*1000));
            d = dd.toMysqlFormat().slice(0,10);
            $scope.history.push({d:d});
            if($scope.currentHistory && $scope.currentHistory.d == d) isStillThere = $scope.history[$scope.history.length-1];

            if($scope.currentHistory && !isStillThere){
              $scope.openHistory($scope.history[0]);
            }
            if($scope.currentHistory && isStillThere){
              $scope.openHistory(isStillThere);
            }
          };

          $scope.refreshHistory();

          $scope.rubricInputDraft = {};
          $scope.getRubricInputKey = function(r,c,studentID,role){
            return role + "_" + studentID + "_" + r.ID + "_" + c.ID;
          };
          $scope.ensureRubricInputDraft = function(r,c,statusByStudent){
            if(!self.isRubricCellInput(r,c) || !$scope.selectedStudent) return;
            var ss = statusByStudent ? statusByStudent : $scope.getCellStatus(r,c);
            var cs = ss[$scope.selectedStudent.ID] ? ss[$scope.selectedStudent.ID] : {student:null, teacher:null};
            var studentKey = $scope.getRubricInputKey(r,c,$scope.selectedStudent.ID,'student');
            var teacherKey = $scope.getRubricInputKey(r,c,$scope.selectedStudent.ID,'teacher');
            if($scope.rubricInputDraft[studentKey] === undefined){
              $scope.rubricInputDraft[studentKey] = cs.student && typeof cs.student.Input === "string" ? cs.student.Input : "";
            }
            if($scope.rubricInputDraft[teacherKey] === undefined){
              $scope.rubricInputDraft[teacherKey] = cs.teacher && typeof cs.teacher.Input === "string" ? cs.teacher.Input : "";
            }
          };
          $scope.preloadSelectedStudentRubricInputDraft = function(){
            if(!$scope.selectedStudent || !it || !it.DataJSON || !it.DataJSON.rows || !it.DataJSON.columns) return;
            for(var ri = 0; ri < it.DataJSON.rows.length; ri++){
              for(var ci = 0; ci < it.DataJSON.columns.length; ci++){
                if(!self.showRubricGridCell(it, ri, ci)) continue;
                var r = it.DataJSON.rows[ri];
                var c = it.DataJSON.columns[ci];
                if(!self.isRubricCellInput(r,c)) continue;
                $scope.ensureRubricInputDraft(r,c,$scope.getCellStatus(r,c));
              }
            }
          };
          $scope.saveRubricCellInput = function(r,c,role){
            if(!self.isRubricCellInput(r,c) || !$scope.selectedStudent || $scope.currentHistory) return;
            var ss = $scope.getCellStatus(r,c);
            var cs = ss[$scope.selectedStudent.ID] ? ss[$scope.selectedStudent.ID] : {student:null, teacher:null};
            var key = $scope.getRubricInputKey(r,c,$scope.selectedStudent.ID,role);
            var inputText = $scope.rubricInputDraft[key];
            if(inputText === undefined || inputText === null) inputText = "";
            if(typeof inputText !== "string") inputText = "" + inputText;
            inputText = self.trimHTML(inputText);
            $scope.rubricInputDraft[key] = inputText;

            var status = "";
            if(role == "teacher"){
              if(inputText && inputText !== ""){
                status = "o"; // always o
              }
            }else{
              status = inputText && inputText !== "" ? "x" : "";
            }

            if(role == "teacher"){
              self.saveTeacherRubricStatus($scope.selectedStudent,it,r.ID,c.ID,status,inputText,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};
              });
            }else{
              self.saveUserRubricStatus(it,r.ID,c.ID,status,inputText,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};
              });
            }
          };
          $scope.hasRubricInputCells = function(){
            if(!it || !it.DataJSON || !it.DataJSON.rows || !it.DataJSON.columns) return false;
            for(var ri = 0; ri < it.DataJSON.rows.length; ri++){
              for(var ci = 0; ci < it.DataJSON.columns.length; ci++){
                if(!self.showRubricGridCell(it, ri, ci)) continue;
                if(self.isRubricCellInput(it.DataJSON.rows[ri], it.DataJSON.columns[ci])) return true;
              }
            }
            return false;
          };
          $scope.showRubricInputToolbar = function(){
            if(!$scope.selectedStudent || $scope.currentHistory) return false;
            if(!$scope.hasRubricInputCells()) return false;
            if(self.user.Teacher == 1) return $scope.showMode == "all" || $scope.showMode == "teacher";
            return $scope.showMode == "all" || $scope.showMode == "student";
          };

          $scope.selectStudent = function(s) {
            var was = $scope.selectedStudent;
            $scope.selectedStudent = s;
            $scope.currentHistory = null;
            $scope.refreshHistory();
            $scope.rubricInputDraft = {};
            $scope.cellStatusCache = {};
            $scope.preloadSelectedStudentRubricInputDraft();
            $scope.showHistory = false;
            if(s == null) $scope.setShowMode('teacher');
            if(s != null && was == null) $scope.setShowMode('teacher');
            $scope.reloadStudent = true;
            $timeout(function(){ $scope.reloadStudent = false; },1);
          };

          $scope.hasFilledRubricCells = function(){
            for(var i=0; i < it.DataJSON.cells.length; i++){
              var r = {ID:it.DataJSON.cells[i].row};
              var c = {ID:it.DataJSON.cells[i].col};
              var cs = $scope.getCellStatus(r,c);
              if(self.user.Teacher == 1)
                if(cs[$scope.selectedStudent.ID] && cs[$scope.selectedStudent.ID].teacher && cs[$scope.selectedStudent.ID].teacher.Status != ""){
                  return true;
                }
              if(self.user.Teacher == 0)
                if(cs[$scope.selectedStudent.ID] && cs[$scope.selectedStudent.ID].student && cs[$scope.selectedStudent.ID].student.Status != ""){
                  return true;
                }
            }
          };

          $scope.hasPending = function(){
            if(self.user.Teacher == 1 && !$scope.currentHistory && $scope.selectedStudent){
              for(var i=0; i < it.DataJSON.cells.length; i++){
                var r = {ID:it.DataJSON.cells[i].row};
                var c = {ID:it.DataJSON.cells[i].col};
                var cs = $scope.getCellStatus(r,c);
                if(cs[$scope.selectedStudent.ID] && cs[$scope.selectedStudent.ID].teacher && cs[$scope.selectedStudent.ID].teacher.Status == "o"){
                  return true;
                }
              }
            }
            return false;
          };

          $scope.publishPending = function(){
            if(self.user.Teacher == 1 && !$scope.currentHistory && $scope.selectedStudent){
              var done = 0;
              var sendPublished = false;
              for(var i=0; i < it.DataJSON.cells.length; i++){
                var r = {ID:it.DataJSON.cells[i].row};
                var c = {ID:it.DataJSON.cells[i].col};
                var cs = $scope.getCellStatus(r,c);
                if(cs[$scope.selectedStudent.ID] && cs[$scope.selectedStudent.ID].teacher && cs[$scope.selectedStudent.ID].teacher.Status == "o"){
                  done++;
                  if(!sendPublished){
                    sendPublished = true;
                    self.publishTeacherRubricStatus($scope.selectedStudent,it,goal,task);
                  }
                  self.saveTeacherRubricStatus($scope.selectedStudent,it,r.ID,c.ID,"x",cs[$scope.selectedStudent.ID].teacher.Input,goal,task).then(function(){
                    done--;
                    if(done == 0){
                      $scope.currentHistory = null;
                      $scope.refreshHistory();
                      $scope.cellStatusCache = {};
                    }
                  });
                }
              }
            }
          };

          $scope.getCellStatusNumber = function(r,c,type){
            var ss = $scope.getCellStatus(r,c);
            var c = 0;
            if(type == "student")
              for(var s in ss)
                if(ss[s].student && ss[s].student.Status == "x") c++;

            if(type == "teacher")
              for(var s in ss)
                if(ss[s].teacher && ss[s].teacher.Status == "x") c++;

            return c;
          };

          $scope.getCellStatus = function(r,c){
            var cacheKey = r.ID + '_' + c.ID;
            if ($scope.cellStatusCache[cacheKey]) {
              return $scope.cellStatusCache[cacheKey];
            }
            var ss = {};
            for(var s = 0; s < $scope.c.students.length; s++){
              if($scope.selectedStudent && $scope.selectedStudent.ID != $scope.c.students[s].ID) continue;
              if(self.currentClassResultStudentFilter &&
                 self.currentClassResultStudentFilter.length > 0 &&
                 self.currentClassResultStudentFilter.indexOf($scope.c.students[s].ID) == -1) continue;
              var cs = self.getUserRubricStatus(it, $scope.c.students[s]);
              var status = {'student':null,'teacher':null};
              for(var i=0; i < cs.length; i++){
                if(cs[i].Status == 'o' && self.user.Teacher == 0) continue;
                if($scope.currentHistory && $scope.currentHistory.d < cs[i].Created.slice(0,10)) continue; // not yet 

                if(cs[i].Row == r.ID && cs[i].Col == c.ID){ 
                  // newst is first
                  if(cs[i].Owner == $scope.c.students[s].ID && status.student == null)
                    status.student = cs[i];
                  if(cs[i].Owner != $scope.c.students[s].ID && status.teacher == null)
                    status.teacher = cs[i];
                  if(status.student && status.teacher) break;
                }
              }
              ss[$scope.c.students[s].ID] = status;
            }
            $scope.cellStatusCache[cacheKey] = ss;
            return ss;
          }

          $scope.clickCell = function(r,c,ev){
            var sel = window.getSelection && window.getSelection();
            if(sel && sel.toString().length > 0) return; // selecting text not trigger
            if(r.inactive || c.inactive) return; // inactive
            if($scope.showMode == "none") return; // no clicks now
            if($scope.showMode == "student") return; // no clicks now
            if($scope.selectedStudent){
              if($scope.currentHistory){
                $scope.openHistory($scope.history[0]);
                return;
              }             
              var cs = $scope.getCellStatus(r,c)[$scope.selectedStudent.ID];
              if(!cs) return;
              var status = (cs.teacher && (cs.teacher.Status == "x" || cs.teacher.Status == "o")) ? "" : "o";
              self.saveTeacherRubricStatus($scope.selectedStudent,it,r.ID,c.ID,status,cs.teacher ? cs.teacher.Input : false,goal,task).then(function(){
                $scope.currentHistory = null;
                $scope.refreshHistory();
                $scope.cellStatusCache = {};                
              });

              return;
            }


            var parent = $scope;
            // show panel with all students 
            // will open up a context menu for text elements to be translated or read aloud

            var position = $mdPanel.newPanelPosition()
                .absolute().relativeTo(ev.target)
                .addPanelPosition('align-end', 'below')
                .addPanelPosition('align-end', 'center')
                .addPanelPosition('align-end', 'above');

            var panelAnimation = $mdPanel.newPanelAnimation()
                .openFrom(ev)
                .withAnimation($mdPanel.animation.FADE);

            var config = {
              attachTo: angular.element(document.body),
              onDomAdded: function(e){
                var menu = e[1];
                self.limitPanelToViewport(menu._panelEl);
                var container = menu._panelContainer.get(0);
                container.addEventListener("click", function (e) {
                  if (e.target === container) {
                    menu.close();
                  }
                });          
              },
              templateUrl: "rubricClassCellContextMenu.html",
              controller: function ($scope, $mdPanel, mdPanelRef) {
                $scope.self = self;
                $scope.results = [];
                $scope.studentsForMenu = [];
                $scope.showMode = parent.showMode;
                var ss = parent.getCellStatus(r,c);
                for(var i=0; i < parent.c.students.length; i++){
                  if(self.currentClassResultStudentFilter &&
                     self.currentClassResultStudentFilter.length > 0 &&
                     self.currentClassResultStudentFilter.indexOf(parent.c.students[i].ID) == -1) continue;
                  $scope.studentsForMenu.push(parent.c.students[i]);
                }
                if(parent.showMode == "teacher")
                  for(var s in ss)
                    $scope.results[s] = (ss[s].teacher && ss[s].teacher.Status == "x") ? 1 : 0;
                if(parent.showMode == "student")
                  for(var s in ss)
                    $scope.results[s] = (ss[s].student && ss[s].student.Status == "x") ? 1 : 0;


                $scope.clicked = function(s,ev){
                  if(parent.showMode == "teacher"){
                    if(parent.currentHistory){
                      mdPanelRef.close();
                      self.confirm($filter('trans')('HISTORICDATACHANGEHINT'),$filter('trans')('OK'),ev).then(function(){
                        parent.openHistory(parent.history[0]);
                      });
                      return;
                    }
                    self.saveTeacherRubricStatus(s,it,r.ID,c.ID,$scope.results[s.ID] == 0 ? 'x' : '', ss[s.ID].teacher ? ss[s.ID].teacher.Input : false,goal,task).then(function(){
                      parent.currentHistory = null;
                      parent.refreshHistory();
                      parent.cellStatusCache = {};                
                      $scope.results[s.ID] = $scope.results[s.ID] == 0 ? 1 : 0;
                    });
                  }
                };
                $scope.close = function(){
                  mdPanelRef.close();
                };
              },
              position: position,
              openFrom: ev,
              animation: panelAnimation,
              clickOutsideToClose: true,
              escapeToClose: true,
              focusOnOpen: true,
              zIndex: 100
            };

            self.showPanel(config);            
          }

          $scope.resetRubric = function(ev){
            self.confirm($filter('trans')('ASKRESETRUBRIC'),$filter('trans')('OK'),ev).then(function(){
              var p = {"ID":it.ID};
              if(task) p["task"] = task.ID;
              if(goal) p["goal"] = goal.ID;
              if(self.user.Teacher == 0)
                p["action"] = "resetUserRubricStatus";
              if(self.user.Teacher == 1){
                p["action"] = "resetTeacherRubricStatus";
                p["student"] = $scope.selectedStudent.ID;
              }

              self.apiPost("ajax",p).then(function(data) {       
                $scope.rubricInputDraft = {};
                $scope.cellStatusCache = {};         
                $scope.refresh(true);
              });          
            });
          }

          $scope.cancel = function() {
            self.closeDialog($scope.dialogElement);
            deferred.resolve();            
          };
        }
      });
      return deferred.promise;      
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////        

    self.showRubric = function(it, student, colleagues, goal, task, ev){
      var action = "";
      var editContext = {};
      if(task && task.ID){
        editContext.fromTask = task.ID;
      }else
      if(goal && goal.ID){
        editContext.fromGoal = goal.ID;
      }
      if(self.currentClass && self.user.Teacher == 0) {
        action = "openStudentRubric";
      }else
      if(self.currentClass && self.user.Teacher == 1 && student && student.ID != self.user.ID) {
        action = "openStudentRubric";
      }else
      if(self.currentClass && self.user.Teacher == 1) {
        action = "openClassRubric";
      }else
      if(!self.currentClass && self.user.ID == it.Owner){
        action = "editRubric";
      }else
      if(!self.currentClass && self.user.ID != it.Owner){
        var sourceMainTopic = null;
        if(task && task.ID){
          var taskRef = self.getTaskByID(task.ID,null,true);
          if(taskRef && taskRef.mainTopic) sourceMainTopic = taskRef.mainTopic;
        }else
        if(goal && goal.ID){
          var goalRef = self.getGoalByID(goal.ID);
          if(goalRef && goalRef.mainTopic) sourceMainTopic = goalRef.mainTopic;
        }
        if(!sourceMainTopic && self.currentMainTopic) sourceMainTopic = self.currentMainTopic;

        if(sourceMainTopic && self.checkChangePermission(sourceMainTopic)){
          action = "editRubric";
        }else{
          // ask for copy
          self.confirm($filter('trans')('ASKDUPLICATERUBRIC'),$filter('trans')('DUPLICATE'),ev).then(function(){
            var n = JSON.parse(angular.toJson(it));
            n.ID = -1;          
            n.Name = n.Name + " (Kopie)";
            self.editRubric(n,ev).then(function(r){
              if(goal) self.editLearningGoalRubrics(goal,ev);
            });
          });
          return;
        }
      }
      self.showLoadingIndicator(null,function(done){
        if(student && student.ID && self.currentClass){
          for(var i=0; i < self.currentClass.students.length;i++){
            if(self.currentClass.students[i].ID == student.ID){
              student = self.currentClass.students[i];
            }
          }
        }
        if(action == "editRubric"){
          done();
          self.editRubric(it,ev,editContext);
        }else
          self.updateRubricsStatus().then(function(){
            // fetch also status in those cases
            done();
            if(action == "openStudentRubric"){
              self.openStudentRubric(it,student,colleagues,goal,task,ev);
            }else
            if(action == "openClassRubric"){
              self.openClassRubric(it,self.currentClass,goal,task,ev);
            }
          });
      });
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////    
    self.editRubric = function(it,ev,context){
      var deferred = $q.defer();
      var editContext = context ? JSON.parse(angular.toJson(context)) : {};

      self.showDialog({
        templateUrl: "editRubric.html",
        targetEvent: ev,
        clickOutsideToClose: false,
        skipHide:true, // keep other dialog open
        onRemoving: function () {
        },
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          $scope.it = JSON.parse(angular.toJson(it)); // copy
          $scope.lastVersion = angular.toJson(it);

          var ensureRubricData = function(){
            if(!$scope.it.DataJSON) $scope.it.DataJSON = {};
            var data = $scope.it.DataJSON;
            if(!data.rows) data.rows = [];
            if(!data.columns) data.columns = [];
            if(!data.cells) data.cells = [];
            if(!data.rowID) data.rowID = 0;
            if(!data.colID) data.colID = 0;
            if(!data.cellID) data.cellID = 0;

            if(data.rows.length === 0){
              data.rowID++;
              data.rows.push({ID:data.rowID,inactive:1,span:0});
            }
            if(data.columns.length === 0){
              data.colID++;
              data.columns.push({ID:data.colID,inactive:1,span:0});
            }

            if(data.rows[0].inactive === undefined || data.rows[0].inactive === null) data.rows[0].inactive = 1;
            if(data.rows[0].span === undefined || data.rows[0].span === null) data.rows[0].span = 0;
            if(data.columns[0].inactive === undefined || data.columns[0].inactive === null) data.columns[0].inactive = 1;
            if(data.columns[0].span === undefined || data.columns[0].span === null) data.columns[0].span = 0;
          };

          var getRubricCellKey = function(rowID,colID){
            return rowID + "_" + colID;
          };

          var cloneRubricItem = function(item){
            var clone = {};
            for(var k in item) clone[k] = item[k];
            return clone;
          };

          var findRubricItemIndexById = function(items, id){
            for(var i = 0; i < items.length; i++){
              if(items[i].ID == id) return i;
            }
            return -1;
          };

          $scope.pickColor = function(r){
            self.pickColor(r && r.Color ? r.Color : "").then(function(color){
              r.Color = color;
            }).catch(function(){});
          };

          ensureRubricData();

          $scope.clipboardImportSupported = !!(navigator.clipboard && (navigator.clipboard.read || navigator.clipboard.readText));
          $scope.clipboardImportBusy = false;
          $scope.clipboardTableAvailable = false;
          $scope.clipboardTableCandidate = null;

          $scope.normalizeClipboardCellText = function(value){
            if(value === undefined || value === null) return "";
            var text = String(value);
            text = text.replace(/\u00a0/g, " ");
            text = text.replace(/\r\n?/g, "\n");
            text = text.replace(/\u200B/g, "");
            return $.trim(text);
          };

          $scope.clipboardItemHasType = function(item, type){
            if(!item || !item.types) return false;
            if(typeof item.types.indexOf === "function") return item.types.indexOf(type) !== -1;
            if(typeof item.types.contains === "function") return item.types.contains(type);
            return false;
          };

          $scope.clipboardBlobToText = function(blob){
            if(!blob) return Promise.resolve("");
            if(typeof blob.text === "function") return blob.text();
            return new Promise(function(resolve, reject){
              var reader = new FileReader();
              reader.onload = function(){ resolve(reader.result || ""); };
              reader.onerror = reject;
              reader.readAsText(blob);
            });
          };

          $scope.parseClipboardTableFromHtml = function(html){
            if(!html || $.trim(html) === "") return null;
            var parsedDoc = document.implementation.createHTMLDocument("");
            parsedDoc.body.innerHTML = html;
            var table = parsedDoc.querySelector("table");
            if(!table) return null;

            var rows = table.querySelectorAll("tr");
            if(!rows || rows.length === 0) return null;

            var matrix = [];
            var htmlMatrix = [];
            for(var r = 0; r < rows.length; r++){
              if(!matrix[r]) matrix[r] = [];
              if(!htmlMatrix[r]) htmlMatrix[r] = [];
              var cellNodes = rows[r].querySelectorAll("th,td");
              var colPos = 0;
              for(var c = 0; c < cellNodes.length; c++){
                while(typeof matrix[r][colPos] !== "undefined") colPos++;

                var cellNode = cellNodes[c];
                var rawText = "";
                if(cellNode.innerText !== undefined && cellNode.innerText !== null) rawText = cellNode.innerText;
                else rawText = cellNode.textContent || "";
                var cellText = $scope.normalizeClipboardCellText(rawText);
                var cellHtml = cellNode.innerHTML !== undefined && cellNode.innerHTML !== null ? String(cellNode.innerHTML) : "";
                cellHtml = cellHtml.replace(/\u200B/g, "");
                cellHtml = $.trim(cellHtml);

                var rowspan = parseInt(cellNode.getAttribute("rowspan"), 10);
                var colspan = parseInt(cellNode.getAttribute("colspan"), 10);
                if(!isFinite(rowspan) || rowspan < 1) rowspan = 1;
                if(!isFinite(colspan) || colspan < 1) colspan = 1;

                for(var rr = 0; rr < rowspan; rr++){
                  var targetRow = r + rr;
                  if(!matrix[targetRow]) matrix[targetRow] = [];
                  if(!htmlMatrix[targetRow]) htmlMatrix[targetRow] = [];
                  for(var cc = 0; cc < colspan; cc++){
                    var targetCol = colPos + cc;
                    if(typeof matrix[targetRow][targetCol] === "undefined"){
                      matrix[targetRow][targetCol] = (rr === 0 && cc === 0) ? cellText : "";
                      htmlMatrix[targetRow][targetCol] = (rr === 0 && cc === 0) ? cellHtml : "";
                    }
                  }
                }
                colPos += colspan;
              }
            }

            var maxCols = 0;
            for(var i = 0; i < matrix.length; i++){
              if(matrix[i] && matrix[i].length > maxCols) maxCols = matrix[i].length;
            }
            if(maxCols === 0) return null;
            for(var i = 0; i < matrix.length; i++){
              if(!matrix[i]) matrix[i] = [];
              if(!htmlMatrix[i]) htmlMatrix[i] = [];
              for(var z = 0; z < maxCols; z++){
                if(typeof matrix[i][z] === "undefined") matrix[i][z] = "";
                if(typeof htmlMatrix[i][z] === "undefined") htmlMatrix[i][z] = "";
                matrix[i][z] = $scope.normalizeClipboardCellText(matrix[i][z]);
                htmlMatrix[i][z] = String(htmlMatrix[i][z] || "");
              }
            }

            return {matrix: matrix, htmlMatrix: htmlMatrix, rowCount: matrix.length, colCount: maxCols, source: "html"};
          };

          $scope.parseClipboardTableFromPlainText = function(text){
            if(text === undefined || text === null) return null;
            var normalized = String(text).replace(/\r\n?/g, "\n");
            if($.trim(normalized) === "") return null;
            if(normalized.indexOf("\t") === -1) return null;

            var lines = normalized.split("\n");
            while(lines.length > 0 && $.trim(lines[0]) === "") lines.shift();
            while(lines.length > 0 && $.trim(lines[lines.length-1]) === "") lines.pop();
            if(lines.length === 0) return null;

            var matrix = [];
            var maxCols = 0;
            for(var i = 0; i < lines.length; i++){
              var cols = lines[i].split("\t");
              for(var z = 0; z < cols.length; z++){
                cols[z] = $scope.normalizeClipboardCellText(cols[z]);
              }
              if(cols.length > maxCols) maxCols = cols.length;
              matrix.push(cols);
            }
            if(maxCols === 0) return null;

            for(var i = 0; i < matrix.length; i++){
              while(matrix[i].length < maxCols) matrix[i].push("");
            }

            return {matrix: matrix, rowCount: matrix.length, colCount: maxCols, source: "text"};
          };

          $scope.readClipboardTableCandidate = function(){
            if(!$scope.clipboardImportSupported) return Promise.resolve(null);

            var fromReadApi = Promise.resolve(null);
            if(navigator.clipboard.read){
              fromReadApi = navigator.clipboard.read().then(function(items){
                if(!items || items.length === 0) return null;

                var sequence = Promise.resolve(null);
                for(var i = 0; i < items.length; i++){
                  (function(item){
                    if($scope.clipboardItemHasType(item, "text/html")){
                      sequence = sequence.then(function(found){
                        if(found) return found;
                        return item.getType("text/html")
                          .then($scope.clipboardBlobToText)
                          .then($scope.parseClipboardTableFromHtml)
                          .catch(function(){ return null; });
                      });
                    }
                  })(items[i]);
                }

                for(var i = 0; i < items.length; i++){
                  (function(item){
                    if($scope.clipboardItemHasType(item, "text/plain")){
                      sequence = sequence.then(function(found){
                        if(found) return found;
                        return item.getType("text/plain")
                          .then($scope.clipboardBlobToText)
                          .then($scope.parseClipboardTableFromPlainText)
                          .catch(function(){ return null; });
                      });
                    }
                  })(items[i]);
                }

                return sequence;
              }).catch(function(){
                // read() kann je nach Browser ohne Benutzeraktion blockiert sein.
                // Dann später mit readText() weiter versuchen.
                return null;
              });
            }

            return fromReadApi.then(function(found){
              if(found) return found;
              if(!navigator.clipboard.readText) return null;
              return navigator.clipboard.readText().then(function(text){
                var parsedFromText = $scope.parseClipboardTableFromPlainText(text);
                if(parsedFromText) return parsedFromText;
                return $scope.parseClipboardTableFromHtml(text);
              });
            });
          };

          $scope.checkClipboardTable = function(silent){
            if(!$scope.clipboardImportSupported){
              $scope.clipboardTableAvailable = false;
              $scope.clipboardTableCandidate = null;
              return Promise.resolve(null);
            }
            if($scope.clipboardImportBusy) return Promise.resolve($scope.clipboardTableCandidate);

            $scope.clipboardImportBusy = true;
            return $scope.readClipboardTableCandidate().then(function(candidate){
              $scope.clipboardTableCandidate = candidate;
              $scope.clipboardTableAvailable = !!candidate;
              return candidate;
            }).catch(function(){
              $scope.clipboardTableCandidate = null;
              $scope.clipboardTableAvailable = false;
              return null;
            }).then(function(result){
              $scope.clipboardImportBusy = false;
              $scope.$applyAsync();
              return result;
            });
          };

          $scope.convertClipboardTextToHTML = function(text){
            var normalized = $scope.normalizeClipboardCellText(text);
            if(normalized === "") return "";
            return $("<div>").text(normalized).html().replace(/\n/g, "<br>");
          };

          $scope.wrapElementChildrenWithTag = function(element, tagName){
            if(!element || !tagName) return;
            var wrapper = document.createElement(tagName);
            while(element.firstChild){
              wrapper.appendChild(element.firstChild);
            }
            element.appendChild(wrapper);
          };

          $scope.normalizeClipboardCellHtmlForRubric = function(html){
            if(html === undefined || html === null) return "";
            var normalizedHtml = String(html);
            if($.trim(normalizedHtml) === "") return "";

            normalizedHtml = window.DOMPurify ? DOMPurify.sanitize(normalizedHtml) : normalizedHtml;

            var root = document.createElement("div");
            root.innerHTML = normalizedHtml;
            var nodes = root.querySelectorAll("*");
            var nodeList = [];
            for(var i = 0; i < nodes.length; i++) nodeList.push(nodes[i]);

            for(var n = nodeList.length - 1; n >= 0; n--){
              var node = nodeList[n];
              if(!node || !node.style) continue;

              var fontWeight = (node.style.fontWeight || "").toLowerCase();
              var fontStyle = (node.style.fontStyle || "").toLowerCase();
              var textDecoration = ((node.style.textDecorationLine || "") + " " + (node.style.textDecoration || "")).toLowerCase();
              var verticalAlign = (node.style.verticalAlign || "").toLowerCase();

              var shouldWrapBold = false;
              if(fontWeight === "bold" || fontWeight === "bolder") shouldWrapBold = true;
              var weightValue = parseInt(fontWeight, 10);
              if(!isNaN(weightValue) && weightValue >= 600) shouldWrapBold = true;

              if(shouldWrapBold) $scope.wrapElementChildrenWithTag(node, "b");
              if(fontStyle === "italic" || fontStyle === "oblique") $scope.wrapElementChildrenWithTag(node, "i");
              if(textDecoration.indexOf("underline") !== -1) $scope.wrapElementChildrenWithTag(node, "u");
              if(textDecoration.indexOf("line-through") !== -1) $scope.wrapElementChildrenWithTag(node, "s");
              if(verticalAlign === "super") $scope.wrapElementChildrenWithTag(node, "sup");
              if(verticalAlign === "sub") $scope.wrapElementChildrenWithTag(node, "sub");
            }

            normalizedHtml = cleanHTMLStyles(root.innerHTML);
            return $.trim(normalizedHtml);
          };

          $scope.getClipboardCellHtml = function(candidate, rowIndex, colIndex){
            if(candidate && !candidate.normalizedHtmlMatrix){
              candidate.normalizedHtmlMatrix = [];
            }

            if(candidate &&
               candidate.normalizedHtmlMatrix &&
               candidate.normalizedHtmlMatrix[rowIndex] &&
               typeof candidate.normalizedHtmlMatrix[rowIndex][colIndex] !== "undefined"){
              return candidate.normalizedHtmlMatrix[rowIndex][colIndex];
            }

            var sourceHtml = "";
            if(candidate && candidate.htmlMatrix &&
               candidate.htmlMatrix[rowIndex] &&
               typeof candidate.htmlMatrix[rowIndex][colIndex] !== "undefined"){
              sourceHtml = String(candidate.htmlMatrix[rowIndex][colIndex] || "");
            }else
            if(candidate && candidate.matrix &&
               candidate.matrix[rowIndex] &&
               typeof candidate.matrix[rowIndex][colIndex] !== "undefined"){
              sourceHtml = $scope.convertClipboardTextToHTML(candidate.matrix[rowIndex][colIndex]);
            }

            var normalized = $scope.normalizeClipboardCellHtmlForRubric(sourceHtml);
            if(candidate){
              if(!candidate.normalizedHtmlMatrix[rowIndex]) candidate.normalizedHtmlMatrix[rowIndex] = [];
              candidate.normalizedHtmlMatrix[rowIndex][colIndex] = normalized;
            }
            return normalized;
          };

          $scope.ensureClipboardPreviewHtmlMatrix = function(candidate){
            if(!candidate || !candidate.matrix || candidate.matrix.length === 0){
              return candidate;
            }
            var previewHtmlMatrix = [];
            for(var r = 0; r < candidate.matrix.length; r++){
              previewHtmlMatrix[r] = [];
              var row = candidate.matrix[r] || [];
              for(var c = 0; c < row.length; c++){
                previewHtmlMatrix[r][c] = $scope.getClipboardCellHtml(candidate, r, c);
              }
            }
            candidate.previewHtmlMatrix = previewHtmlMatrix;
            return candidate;
          };

          $scope.replaceBase64ImagesInClipboardCandidate = function(candidate){
            if(!candidate || !candidate.htmlMatrix || candidate.htmlMatrix.length === 0){
              return Promise.resolve(candidate);
            }
            var updates = [];
            for(var r = 0; r < candidate.htmlMatrix.length; r++){
              for(var c = 0; c < candidate.htmlMatrix[r].length; c++){
                (function(rowIndex, colIndex){
                  var html = String(candidate.htmlMatrix[rowIndex][colIndex] || "");
                  if(html.indexOf("data:image/") === -1) return;
                  updates.push(self.replaceBase64Images(html).then(function(updatedHtml){
                    candidate.htmlMatrix[rowIndex][colIndex] = updatedHtml;
                    if(candidate.normalizedHtmlMatrix &&
                       candidate.normalizedHtmlMatrix[rowIndex] &&
                       typeof candidate.normalizedHtmlMatrix[rowIndex][colIndex] !== "undefined"){
                      delete candidate.normalizedHtmlMatrix[rowIndex][colIndex];
                    }
                  }));
                })(r, c);
              }
            }
            return Promise.all(updates).then(function(){
              $scope.ensureClipboardPreviewHtmlMatrix(candidate);
              return candidate;
            });
          };

          $scope.addRubricFilesToFocusedEditor = function(multipleAnswers){
            if(!multipleAnswers || multipleAnswers.length === 0) return;
            var hasEditorFocus = !!(document.activeElement && $(document.activeElement).closest(".nw-editor").length === 1);
            var hasEditorSelection = false;
            var sel = window.getSelection ? window.getSelection() : null;
            if(sel && sel.rangeCount > 0){
              var anchorNode = sel.anchorNode || sel.focusNode;
              var nodeEl = anchorNode && anchorNode.nodeType === 3 ? anchorNode.parentNode : anchorNode;
              if(nodeEl && $(nodeEl).closest(".nw-editor").length === 1){
                hasEditorSelection = true;
              }
            }
            if(!hasEditorFocus && !hasEditorSelection) return;

            for(var i = 0; i < multipleAnswers.length; i++){
              var item = multipleAnswers[i];
              if(!item) continue;

              var html = "";
              if(item.Type == "image" && item.URL){
                html = '<br><img src="' + item.URL + '"><br>';
              }else
              if(item.Type == "audio" && item.URL){
                html = '<b class="fa fa-fw fa-volume-up inlineAudio" src="' + item.URL + '"></b> ';
              }else
              if(item.Type == "video" && item.URL){
                html = '<br><video controls controlslist="nodownload" class="inlineVideo" src="' + item.URL + '"></video><br>';
              }else
              if(item.Text){
                html = $("<div>").text(item.Text).html().replace(/\n/g, "<br>");
              }

              if(html !== ""){
                pasteHtmlAtCaret(html);
              }
            }
          };

          $scope.buildRubricDataFromTable = function(candidate){
            if(!candidate || !candidate.matrix || candidate.matrix.length === 0) return null;
            var rowCount = candidate.matrix.length;
            var colCount = candidate.colCount || 0;
            if(colCount <= 0) return null;

            var data = {rows: [],columns: [],cells: [],rowID: 0,colID: 0,cellID: 0,autoWidths: 0};

            var width = 100 / colCount;
            for(var c = 0; c < colCount; c++){
              data.colID++;
              var col = {ID:data.colID, width: width.toFixed(2)};
              if(c === 0){
                col.inactive = 1;
                col.span = 0;
              }else{
                col.multi = 1;
              }
              data.columns.push(col);
            }

            for(var r = 0; r < rowCount; r++){
              data.rowID++;
              var row = {ID:data.rowID};
              if(r === 0){
                row.inactive = 1;
                row.span = 0;
              }
              data.rows.push(row);
            }

            for(var r = 0; r < rowCount; r++){
              for(var c = 0; c < colCount; c++){
                data.cellID++;
                data.cells.push({
                  ID: data.cellID,
                  row: data.rows[r].ID,
                  col: data.columns[c].ID,
                  Text: $scope.getClipboardCellHtml(candidate, r, c)
                });
              }
            }
            return data;
          };

          $scope.showClipboardPreviewDialog = function(candidate, ev){
            $scope.ensureClipboardPreviewHtmlMatrix(candidate);
            var previewDeferred = $q.defer();
            self.showDialog({
              template:
                '<md-dialog style="width:900px;max-width:95vw;">' +
                '  <md-toolbar layout="row" layout-align="space-between center">' +
                '    <span style="margin:8px 16px">{{\'RUBRICCLIPBOARDPREVIEWTITLE\' | trans}}</span>' +
                '    <md-button class="md-icon-button" aria-label="{{\'CANCEL\' | trans}}" ng-click="cancel()"><i class="fa fa-fw fa-times"></i></md-button>' +
                '  </md-toolbar>' +
                '  <md-content style="padding:16px;max-height:70vh;overflow:auto">' +
                '    <div style="margin-bottom:8px;color:rgba(0,0,0,0.65)">{{\'RUBRICCLIPBOARDPREVIEWSIZE\' | trans:preview.rowCount:preview.colCount}}</div>' +
                '    <table style="width:100%;border-collapse:collapse;font-size:14px;">' +
                '      <tr ng-repeat="row in preview.previewHtmlMatrix track by $index">' +
                '        <td ng-repeat="cell in row track by $index" style="border:1px solid #ddd;padding:6px;vertical-align:top;white-space:pre-wrap;min-width:5.5em;" ng-bind-html="preview.trustedPreviewHtmlMatrix[$parent.$index][$index]"></td>' +
                '      </tr>' +
                '    </table>' +
              '  </md-content>' +
                '  <md-dialog-actions>' +
                '    <md-button ng-click="cancel()">{{\'CANCEL\' | trans}}</md-button>' +
                '    <md-button class="md-primary" ng-click="confirm()">{{\'RUBRICCLIPBOARDREPLACEGRID\' | trans}}</md-button>' +
                '  </md-dialog-actions>' +
                '</md-dialog>',
              targetEvent: ev,
              clickOutsideToClose: false,
              skipHide: true,
              controller: function ($scope, $sce) {
                $scope.preview = candidate;
                $scope.preview.trustedPreviewHtmlMatrix = [];
                for(var r = 0; r < $scope.preview.previewHtmlMatrix.length; r++){
                  if(!$scope.preview.trustedPreviewHtmlMatrix[r]) $scope.preview.trustedPreviewHtmlMatrix[r] = [];
                  for(var c = 0; c < $scope.preview.previewHtmlMatrix[r].length; c++){
                    $scope.preview.trustedPreviewHtmlMatrix[r][c] =
                      $sce.trustAsHtml(String($scope.preview.previewHtmlMatrix[r][c] || ""));
                  }
                }
                $scope.confirm = function(){
                  previewDeferred.resolve();
                  self.closeDialog($scope.dialogElement);
                };
                $scope.cancel = function(){
                  previewDeferred.reject();
                  self.closeDialog($scope.dialogElement);
                };
              }
            });
            return previewDeferred.promise;
          };

          $scope.importFromClipboard = function(ev){
            $scope.checkClipboardTable(false).then(function(candidate){
              if(!candidate){
                $scope.$applyAsync();
                return;
              }

              $scope.showClipboardPreviewDialog(candidate, ev).then(function(){
                $scope.replaceBase64ImagesInClipboardCandidate(candidate).then(function(){
                  var newData = $scope.buildRubricDataFromTable(candidate);
                  if(!newData){
                    self.alert($filter('trans')('RUBRICCLIPBOARDIMPORTFAILED'));
                    return;
                  }

                  $scope.it.DataJSON = newData;
                  $scope.it.DataJSON.width = 200*$scope.it.DataJSON.columns.length;
                  $scope.refreshCells();
                  if($scope.it.DataJSON.rows.length > 0 && $scope.it.DataJSON.columns.length > 0){
                    $scope.currentEditCell = $scope.getOrCreateCell($scope.it.DataJSON.rows[0].ID, $scope.it.DataJSON.columns[0].ID);
                  }
                  $scope.$applyAsync();
                }).catch(function(){
                  self.alert($filter('trans')('RUBRICCLIPBOARDIMPORTFAILED'));
                });
              });
            });
          };

          if($scope.clipboardImportSupported){
            $scope.checkClipboardTable(true);
            $scope.checkClickboardInterval = $interval(function(){
              $scope.checkClipboardTable(true);
            },1000);
            $scope.$on("$destroy", function(){
              $interval.cancel($scope.checkClickboardInterval);
            });
          }

          $scope.findRubricCell = function(rowID,colID){
            for(var i=0; i < $scope.it.DataJSON.cells.length; i++){
              if($scope.it.DataJSON.cells[i].row == rowID && $scope.it.DataJSON.cells[i].col == colID){
                return $scope.it.DataJSON.cells[i];
              }
            }
            return null;
          };

          $scope.getOrCreateCell = function(rowID,colID){
            var existing = $scope.findRubricCell(rowID,colID);
            if(existing) return existing;

            var cc = {col:colID,row:rowID,"Text":""};
            $scope.it.DataJSON.cellID++;
            cc.ID = $scope.it.DataJSON.cellID;
            $scope.it.DataJSON.cells.push(cc);
            return cc;
          };

          $scope.cellHasTextContent = function(cell){
            if(!cell || cell.Text === undefined || cell.Text === null) return false;
            var html = String(cell.Text);
            if($.trim(html) === "") return false;

            var probe = $("<div>").html(html);
            if($.trim(probe.text()) !== "") return true;
            // Keep non-text content (images/media/links/tables/lists) as content.
            if(probe.find("img,video,audio,iframe,table,ul,ol,li,a").length > 0) return true;
            return false;
          };

          $scope.columnHasTextContent = function(column){
            if(!column || !column.ID || !$scope.it || !$scope.it.DataJSON || !$scope.it.DataJSON.cells) return false;
            for(var i=0; i < $scope.it.DataJSON.cells.length; i++){
              var cell = $scope.it.DataJSON.cells[i];
              if(cell.col == column.ID && $scope.cellHasTextContent(cell)) return true;
            }
            return false;
          };

          $scope.rowHasTextContent = function(row){
            if(!row || !row.ID || !$scope.it || !$scope.it.DataJSON || !$scope.it.DataJSON.cells) return false;
            for(var i=0; i < $scope.it.DataJSON.cells.length; i++){
              var cell = $scope.it.DataJSON.cells[i];
              if(cell.row == row.ID && $scope.cellHasTextContent(cell)) return true;
            }
            return false;
          };

          $scope.toggleColumnInactive = function(column){
            if(!column) return;
            column.inactive = column.inactive == 1 ? 0 : 1;
            if(column.inactive == 1){
              column.span = $scope.columnHasTextContent(column) ? 0 : 1;
            }
          };

          $scope.toggleRowInactive = function(row){
            if(!row) return;
            row.inactive = row.inactive == 1 ? 0 : 1;
            if(row.inactive == 1){
              row.span = $scope.rowHasTextContent(row) ? 0 : 1;
            }
          };

          $scope.ensureRubricSizing = function(initRowHeights, forceColumnSizing){
            var cols = $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            var autoColumnSizing = (!forceColumnSizing && parseInt($scope.it.DataJSON.autoWidths, 10) === 1);
            if(cols.length > 0 && !autoColumnSizing){
              var sumWidth = 0;
              var valid = true;
              for(var i=0; i < cols.length; i++){
                var w = parseFloat(cols[i].width);
                if(!isFinite(w) || w <= 0){
                  valid = false;
                  break;
                }
                sumWidth += w;
              }
              if(!valid || sumWidth <= 0){
                var even = 100 / cols.length;
                for(var i=0; i < cols.length; i++) cols[i].width = even.toFixed(2);
              }else{
                for(var i=0; i < cols.length; i++){
                  cols[i].width = ((parseFloat(cols[i].width) / sumWidth) * 100).toFixed(2);
                }
              }
            }

            if(initRowHeights){
              var rows = $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
              for(var i=0; i < rows.length; i++){
                var h = parseFloat(rows[i].heightEm);
                if(!isFinite(h) || h <= 0){
                  rows[i].heightEm = i === 0 ? 2.5 : 3.0;
                }
              }
            }
          };

          $scope.bumpUnlimitColumnWidth = function(c){
            if(!c) return;
            var cols = $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            if(cols.length <= 1) return;
            var index = cols.indexOf(c);
            if(index < 0) return;

            $scope.it.DataJSON.autoWidths = 0;
            $scope.ensureRubricSizing(false, true);

            var current = parseFloat(c.width);
            if(!isFinite(current) || current <= 0) current = 100 / cols.length;
            var even = 100 / cols.length;
            var minOther = Math.max(1.2, even * 0.25);
            var target = Math.max(current * 1.4, even * 1.7);
            var maxTarget = 100 - minOther * (cols.length - 1);
            if(target > maxTarget) target = maxTarget;
            if(target < current) target = current;

            var restCurrent = 100 - current;
            c.width = target;

            if(restCurrent <= 0){
              var each = (100 - target) / (cols.length - 1);
              for(var i=0; i < cols.length; i++){
                if(i === index) continue;
                cols[i].width = each;
              }
            }else{
              var scale = (100 - target) / restCurrent;
              for(var i=0; i < cols.length; i++){
                if(i === index) continue;
                var w = parseFloat(cols[i].width);
                if(!isFinite(w) || w <= 0) w = even;
                cols[i].width = w * scale;
              }
            }

            $scope.ensureRubricSizing(false, true);
          };

          $scope.toggleColumnUnlimit = function(c){
            if(!c) return;
            c.unlimit = c.unlimit == 1 ? 0 : 1;
            if(c.unlimit == 1){
              $scope.bumpUnlimitColumnWidth(c);
            }
          };

          $scope.startResizeColumn = function(c,ev){
            if(!c) return;
            var cols = $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            var index = cols.indexOf(c);
            if(index < 0) return;
            $scope.it.DataJSON.autoWidths = 0;
            $scope.ensureRubricSizing(false, true);

            var startX = ev.clientX;
            var table = ev.target;
            while(table && table.tagName !== "TABLE") table = table.parentNode;
            if(!table) return;

            var colNodes = table.querySelectorAll("colgroup col");
            if(!colNodes || colNodes.length !== cols.length) return;

            var widthsPx = [];
            var totalPx = 0;
            for(var i=0; i < cols.length; i++){
              var wpx = colNodes[i].getBoundingClientRect().width;
              if(!isFinite(wpx) || wpx <= 0){
                var wPct = parseFloat(cols[i].width);
                if(!isFinite(wPct) || wPct <= 0) wPct = 100 / cols.length;
                var tableWidthFallback = table.getBoundingClientRect().width;
                wpx = (wPct / 100) * (tableWidthFallback > 0 ? tableWidthFallback : 1);
              }
              widthsPx.push(wpx);
              totalPx += wpx;
            }
            if(totalPx <= 0) return;

            // During drag we work in absolute pixels so table width can grow beyond viewport/container.
            for(var i=0; i < colNodes.length; i++){
              colNodes[i].style.width = widthsPx[i] + "px";
            }
            table.style.width = totalPx + "px";
            table.style.maxWidth = "none";

            var startColPx = widthsPx[index];
            var minPx = 16; // approx 1em minimum width

            ev.preventDefault();
            ev.stopPropagation();

            var onMove = function(e){
              var deltaPx = e.clientX - startX;
              var nextColPx = startColPx + deltaPx;
              if(nextColPx < minPx) nextColPx = minPx;
              widthsPx[index] = nextColPx;

              var nextTotalPx = 0;
              for(var z=0; z < widthsPx.length; z++) nextTotalPx += widthsPx[z];
              colNodes[index].style.width = nextColPx + "px";
              table.style.width = nextTotalPx + "px";
            };

            var onUp = function(){
              document.removeEventListener("mousemove", onMove);
              document.removeEventListener("mouseup", onUp);

              var finalTotalPx = 0;
              for(var i=0; i < widthsPx.length; i++) finalTotalPx += widthsPx[i];
              if(finalTotalPx <= 0) return;

              for(var i=0; i < cols.length; i++){
                cols[i].width = ((widthsPx[i] / finalTotalPx) * 100).toFixed(2);
              }
              // Keep table width as absolute pixel value; only columns are persisted as percentages.
              table.style.width = finalTotalPx + "px";
              table.style.maxWidth = "none";
              $scope.it.DataJSON.width = Math.round(finalTotalPx * 100) / 100;
              $scope.$applyAsync();
            };

            document.addEventListener("mousemove", onMove);
            document.addEventListener("mouseup", onUp);
          };

          $scope.resetResizeColumn = function(c,ev){
            if(ev){
              ev.preventDefault();
              ev.stopPropagation();
            }
            var table = ev ? ev.target : null;
            while(table && table.tagName !== "TABLE") table = table.parentNode;
            var cols = $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            if(cols.length === 0) return;
            $scope.it.DataJSON.autoWidths = 1;
            for(var i=0; i < cols.length; i++){
              delete cols[i].width;
            }
            delete $scope.it.DataJSON.width;
            if(table){
              table.style.width = "100%";
              table.style.maxWidth = "";
            }
            $scope.$applyAsync();
          };

          $scope.startResizeRow = function(r,ev){
            if(!r) return;
            var rows = $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var index = rows.indexOf(r);
            if(index < 0) return;
            $scope.ensureRubricSizing(true);

            var startY = ev.clientY;
            var table = ev.target;
            while(table && table.tagName !== "TABLE") table = table.parentNode;
            if(!table) return;

            var rowNodes = table.querySelectorAll("tr.rubric-row");
            if(!rowNodes || rowNodes.length !== rows.length) return;

            var heightsPx = [];
            var totalPx = 0;
            for(var i=0; i < rows.length; i++){
              var hpx = rowNodes[i].getBoundingClientRect().height;
              if(!isFinite(hpx) || hpx <= 0){
                var hpxFallback = parseFloat(rows[i].heightPx);
                if(!isFinite(hpxFallback) || hpxFallback <= 0){
                  var hemFallback = parseFloat(rows[i].heightEm);
                  if(!isFinite(hemFallback) || hemFallback <= 0) hemFallback = (i === 0 ? 2.5 : 3.0);
                  hpxFallback = hemFallback * 16;
                }
                hpx = hpxFallback;
              }
              heightsPx.push(hpx);
              totalPx += hpx;
            }
            if(totalPx <= 0) return;

            // During drag we work in absolute pixels so row resizing can increase total table height.
            for(var i=0; i < rowNodes.length; i++){
              rowNodes[i].style.height = heightsPx[i] + "px";
            }
            table.style.height = totalPx + "px";

            var startRowPx = heightsPx[index];
            var minPx = 16; // approx 1em minimum row height

            ev.preventDefault();
            ev.stopPropagation();

            var onMove = function(e){
              var deltaPx = e.clientY - startY;
              var nextRowPx = startRowPx + deltaPx;
              if(nextRowPx < minPx) nextRowPx = minPx;
              heightsPx[index] = nextRowPx;

              var nextTotalPx = 0;
              for(var z=0; z < heightsPx.length; z++) nextTotalPx += heightsPx[z];
              rowNodes[index].style.height = nextRowPx + "px";
              table.style.height = nextTotalPx + "px";
            };

            var onUp = function(){
              document.removeEventListener("mousemove", onMove);
              document.removeEventListener("mouseup", onUp);

              var finalTotalPx = 0;
              for(var i=0; i < heightsPx.length; i++) finalTotalPx += heightsPx[i];
              if(finalTotalPx <= 0) return;

              // Keep absolute row heights in px (no percent redistribution).
              for(var i=0; i < rows.length; i++){
                var px = Math.round(heightsPx[i] * 100) / 100;
                rows[i].heightPx = px;
                // Keep em as compatibility fallback for older render/export paths.
                rows[i].heightEm = Math.round((px / 16) * 1000) / 1000;
                delete rows[i].heightPct;
              }
              table.style.height = finalTotalPx + "px";
              $scope.it.DataJSON.height = Math.round(finalTotalPx * 100) / 100;
              $scope.$applyAsync();
            };

            document.addEventListener("mousemove", onMove);
            document.addEventListener("mouseup", onUp);
          };

          $scope.resetResizeRow = function(r,ev){
            if(ev){
              ev.preventDefault();
              ev.stopPropagation();
            }
            var table = ev ? ev.target : null;
            while(table && table.tagName !== "TABLE") table = table.parentNode;
            if(!r) return;
            var rows = $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var index = rows.indexOf(r);
            if(index < 0) return;
            delete rows[index].heightPx;
            delete rows[index].heightEm;
            delete rows[index].heightPct;
            delete $scope.it.DataJSON.height;
            if(table){
              table.style.height = "";
            }
            $scope.$applyAsync();
          };

          $scope.getCurrentEditRowIndex = function(){
            if(!$scope.currentEditRow || !$scope.it || !$scope.it.DataJSON || !$scope.it.DataJSON.rows) return -1;
            return $scope.it.DataJSON.rows.indexOf($scope.currentEditRow);
          };

          $scope.getCurrentEditColumnIndex = function(){
            if(!$scope.currentEditColumn || !$scope.it || !$scope.it.DataJSON || !$scope.it.DataJSON.columns) return -1;
            return $scope.it.DataJSON.columns.indexOf($scope.currentEditColumn);
          };

          $scope.hasRubricCellSelection = function(){
            return !!($scope.currentEditCell && $scope.currentEditRow && $scope.currentEditColumn);
          };

          $scope.syncCurrentRubricSelectionFromCell = function(){
            if(!$scope.currentEditCell){
              $scope.currentEditRow = null;
              $scope.currentEditColumn = null;
              return;
            }
            var rows = ($scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows) ? $scope.it.DataJSON.rows : [];
            var cols = ($scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns) ? $scope.it.DataJSON.columns : [];
            var rowIndex = findRubricItemIndexById(rows, $scope.currentEditCell.row);
            var colIndex = findRubricItemIndexById(cols, $scope.currentEditCell.col);
            $scope.currentEditRow = rowIndex >= 0 ? rows[rowIndex] : null;
            $scope.currentEditColumn = colIndex >= 0 ? cols[colIndex] : null;
          };

          $scope.$watch("currentEditCell", function(){
            $scope.syncCurrentRubricSelectionFromCell();
          });

          $scope.isCaretAtRubricEditorBoundary = function(event, atStart){
            if(!event) return false;
            var target = event.target || null;
            var editable = null;
            if(target && target.closest){
              editable = target.closest(".ng-wig-editable");
            }
            if(!editable) return false;

            var sel = window.getSelection ? window.getSelection() : null;
            if(!sel || !sel.rangeCount) return false;
            var range = sel.getRangeAt(0);
            if(!editable.contains(range.startContainer) || !editable.contains(range.endContainer)) return false;

            // Treat full-cell selection as both start and end.
            if(!sel.isCollapsed){
              var full = document.createRange();
              full.selectNodeContents(editable);
              var startsAtOrBefore = range.compareBoundaryPoints(Range.START_TO_START, full) <= 0;
              var endsAtOrAfter = range.compareBoundaryPoints(Range.END_TO_END, full) >= 0;
              return startsAtOrBefore && endsAtOrAfter;
            }
            var probe = document.createRange();
            if(atStart){
              probe.selectNodeContents(editable);
              probe.setEnd(range.startContainer, range.startOffset);
            }else{
              probe.selectNodeContents(editable);
              probe.setStart(range.startContainer, range.startOffset);
            }
            // Ignore zero-width chars and whitespace-only artifacts (e.g. list block newlines).
            var content = probe.toString().replace(/\u200B/g, ""); //.replace(/\s+/g, "");
            return content.length === 0;
          };

          $scope.persistCurrentRubricEditorContent = function(event){
            if(!$scope.currentEditCell || !event) return;
            var target = event.target || null;
            var editable = null;
            if(target && target.closest){
              editable = target.closest(".ng-wig-editable");
            }
            if(!editable) return;
            $scope.currentEditCell.Text = editable.innerHTML;
          };

          $scope.resolveRubricCellEditor = function(targetRowId, targetColId){
            var root = $scope.dialogElement && $scope.dialogElement[0] ? $scope.dialogElement[0] : document;
            if(targetRowId !== undefined && targetRowId !== null &&
               targetColId !== undefined && targetColId !== null){
              var cell = root.querySelector(
                ".rubric-cell[data-row-id='" + targetRowId + "'][data-col-id='" + targetColId + "']"
              );
              if(cell){
                var byCell = cell.querySelector(".ng-wig-editable");
                if(byCell) return byCell;
              }
              return null;
            }
            var current = root.querySelector(".rubric-cell.rubric-current-row.rubric-current-col .ng-wig-editable");
            if(current) return current;
            return root.querySelector(".rubric-cell .ng-wig-editable");
          };

          $scope.focusRubricCellEditor = function(placeAtEnd, targetRowId, targetColId, selectAll){
            $timeout(function(){
              var setCaret = function(attempt){
                var editor = $scope.resolveRubricCellEditor(targetRowId, targetColId);
                if(!editor){
                  if((attempt || 0) < 2){
                    $timeout(function(){ setCaret((attempt || 0) + 1); }, 20);
                  }
                  return;
                }
                editor.focus();
                var sel = window.getSelection ? window.getSelection() : null;
                if(!sel || !document.createRange) return;
                var range = document.createRange();

                if(selectAll){
                  range.selectNodeContents(editor);
                  sel.removeAllRanges();
                  sel.addRange(range);
                  return;
                }

                var walker = document.createTreeWalker(
                  editor,
                  NodeFilter.SHOW_TEXT,
                  {
                    acceptNode: function(node){
                      if(!node || !node.nodeValue) return NodeFilter.FILTER_SKIP;
                      var cleaned = node.nodeValue.replace(/\u200B/g, "").replace(/\s+/g, "");
                      return cleaned.length > 0 ?
                        NodeFilter.FILTER_ACCEPT :
                        NodeFilter.FILTER_SKIP;
                    }
                  }
                );

                var textNode = null;
                if(placeAtEnd){
                  var current = null;
                  while((current = walker.nextNode())) textNode = current;
                }else{
                  textNode = walker.nextNode();
                }

                if(textNode){
                  var offset = placeAtEnd ? textNode.nodeValue.length : 0;
                  range.setStart(textNode, offset);
                }else{
                  range.selectNodeContents(editor);
                  range.collapse(!placeAtEnd);
                }
                range.collapse(true);
                sel.removeAllRanges();
                sel.addRange(range);
              };

              setCaret(0);
              // One short post-focus correction for ng-wig/list blocks.
              $timeout(function(){ setCaret(3); }, 20);
            }, 0);
          };

          $scope.focusRubricCellEditorFromPoint = function(clientX, clientY, targetRowId, targetColId){
            $timeout(function(){
              var setCaretFromPoint = function(attempt){
                var editor = $scope.resolveRubricCellEditor(targetRowId, targetColId);
                if(!editor){
                  if((attempt || 0) < 4){
                    $timeout(function(){ setCaretFromPoint((attempt || 0) + 1); }, 20);
                  }
                  return;
                }

                editor.focus();
                var sel = window.getSelection ? window.getSelection() : null;
                if(!sel || !document.createRange) return;
                var range = null;

                if(document.caretPositionFromPoint){
                  var pos = document.caretPositionFromPoint(clientX, clientY);
                  if(pos && pos.offsetNode && editor.contains(pos.offsetNode)){
                    range = document.createRange();
                    range.setStart(pos.offsetNode, pos.offset);
                    range.collapse(true);
                  }
                }

                if(!range && document.caretRangeFromPoint){
                  var r = document.caretRangeFromPoint(clientX, clientY);
                  if(r && r.startContainer && editor.contains(r.startContainer)){
                    range = r.cloneRange ? r.cloneRange() : r;
                    range.collapse(true);
                  }
                }

                if(!range){
                  range = document.createRange();
                  range.selectNodeContents(editor);
                  range.collapse(false);
                }

                sel.removeAllRanges();
                sel.addRange(range);
              };

              setCaretFromPoint(0);
              $timeout(function(){ setCaretFromPoint(5); }, 20);
            }, 0);
          };

          $scope.moveRubricEditorToCell = function(targetRow, targetCol, placeAtEnd, selectAll){
            if(!targetRow || !targetCol) return false;
            $scope.editCell(targetRow, targetCol);
            $scope.focusRubricCellEditor(placeAtEnd === true, targetRow.ID, targetCol.ID, selectAll);
            return true;
          };

          $scope.findNextVisibleRubricCell = function(fromRowIndex, fromColIndex){
            var rows = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var cols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            for(var ri = fromRowIndex; ri < rows.length; ri++){
              var startCol = (ri === fromRowIndex) ? fromColIndex + 1 : 0;
              for(var ci = startCol; ci < cols.length; ci++){
                if(!self.isRubricCellInput(rows[ri], cols[ci]) && self.showRubricGridCell($scope.it, ri, ci)) return {ri:ri, ci:ci};
              }
            }
            return null;
          };

          $scope.findPrevVisibleRubricCell = function(fromRowIndex, fromColIndex){
            var rows = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var cols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            for(var ri = fromRowIndex; ri >= 0; ri--){
              var startCol = (ri === fromRowIndex) ? fromColIndex - 1 : cols.length - 1;
              for(var ci = startCol; ci >= 0; ci--){
                if(!self.isRubricCellInput(rows[ri], cols[ci]) && self.showRubricGridCell($scope.it, ri, ci)) return {ri:ri, ci:ci};
              }
            }
            return null;
          };

          $scope.findVisibleRubricCellInDirection = function(fromRowIndex, fromColIndex, rowStep, colStep){
            var rows = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var cols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            var ri = fromRowIndex + rowStep;
            var ci = fromColIndex + colStep;
            while(ri >= 0 && ri < rows.length && ci >= 0 && ci < cols.length){
              if(!self.isRubricCellInput(rows[ri], cols[ci]) && self.showRubricGridCell($scope.it, ri, ci)) return {ri:ri, ci:ci};
              ri += rowStep;
              ci += colStep;
            }
            return null;
          };

          $scope.getFirstVisibleRubricColIndex = function(rowIndex){
            var cols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            for(var ci = 0; ci < cols.length; ci++){
              if(self.showRubricGridCell($scope.it, rowIndex, ci)) return ci;
            }
            return -1;
          };

          $scope.handleRubricCellEditorKeydown = function(event, r, c){
            if(!event || !r || !c) return;
            var rows = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
            var cols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
            var ri = rows.indexOf(r);
            var ci = cols.indexOf(c);
            if(ri < 0 || ci < 0) return;

            var key = event.key || "";
            var keyCode = event.which || event.keyCode || 0;
            if(event.altKey || event.ctrlKey || event.metaKey) return;
            var atStart = $scope.isCaretAtRubricEditorBoundary(event, true);
            var atEnd = $scope.isCaretAtRubricEditorBoundary(event, false);
            var target = null;

            if((key === "ArrowLeft" || keyCode === 37) && atStart && !event.repeat){
              target = $scope.findVisibleRubricCellInDirection(ri, ci, 0, -1);
              if(target){
                event.preventDefault();
                event.stopPropagation();
                $scope.persistCurrentRubricEditorContent(event);
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], true);
              }
              return;
            }

            if((key === "ArrowRight" || keyCode === 39) && atEnd && !event.repeat){
              target = $scope.findVisibleRubricCellInDirection(ri, ci, 0, 1);
              if(target){
                event.preventDefault();
                event.stopPropagation();
                $scope.persistCurrentRubricEditorContent(event);
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], false);
              }
              return;
            }

            if((key === "ArrowUp" || keyCode === 38) && atStart && !event.repeat){
              target = $scope.findVisibleRubricCellInDirection(ri, ci, -1, 0);
              if(target){
                event.preventDefault();
                event.stopPropagation();
                $scope.persistCurrentRubricEditorContent(event);
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], true);
              }
              return;
            }

            if((key === "ArrowDown" || keyCode === 40) && atEnd && !event.repeat){
              target = $scope.findVisibleRubricCellInDirection(ri, ci, 1, 0);
              if(target){
                event.preventDefault();
                event.stopPropagation();
                $scope.persistCurrentRubricEditorContent(event);
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], false);
              }
              return;
            }

            if((key === "Tab" || keyCode === 9) && !event.shiftKey){
              event.preventDefault();
              event.stopPropagation();
              if(event.stopImmediatePropagation) event.stopImmediatePropagation();
              $scope.persistCurrentRubricEditorContent(event);
              target = $scope.findNextVisibleRubricCell(ri, ci);
              if(target){
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], false, true);
                return;
              }
              $scope.addRow();
              var newRows = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.rows ? $scope.it.DataJSON.rows : [];
              var newCols = $scope.it && $scope.it.DataJSON && $scope.it.DataJSON.columns ? $scope.it.DataJSON.columns : [];
              var newRi = newRows.length - 1;
              var firstCi = $scope.getFirstVisibleRubricColIndex(newRi);
              if(newRi >= 0 && firstCi >= 0){
                $scope.moveRubricEditorToCell(newRows[newRi], newCols[firstCi], false);
              }
              return;
            }

            if((key === "Tab" || keyCode === 9) && event.shiftKey){
              event.preventDefault();
              event.stopPropagation();
              if(event.stopImmediatePropagation) event.stopImmediatePropagation();
              $scope.persistCurrentRubricEditorContent(event);
              target = $scope.findPrevVisibleRubricCell(ri, ci);
              if(target){
                $scope.moveRubricEditorToCell(rows[target.ri], cols[target.ci], true, true);
              }
            }
          };
          
          $scope.unselectAll = function(){
            $timeout(function(){
              $scope.currentEditCell = null; 
              $scope.currentEditColumn = null; 
              $scope.currentEditRow = null;              
            },100);
          };

          $scope.moveColumn = function(c,dir){
            var index = $scope.it.DataJSON.columns.indexOf(c);
            if (index === -1) return; // item not found

            var newIndex = index + dir;
            if (newIndex < 0 || newIndex >= $scope.it.DataJSON.columns.length) return; // out of bounds

            // remove item and insert at new position
            $scope.it.DataJSON.columns.splice(index, 1);
            $scope.it.DataJSON.columns.splice(newIndex, 0, c);
          };

          $scope.removeColumn = function(c,ev){
            var index = $scope.it.DataJSON.columns.indexOf(c);
            if (index === -1) return; // item not found
            self.confirm($filter('trans')('DELETECOLUMN')+"?",$filter('trans')('DELETE'),ev).then(function(){
              $scope.it.DataJSON.columns.splice(index, 1);
              $scope.refreshCells();
            });
          };
          $scope.duplicateColumn = function(c,ev){
            var index = $scope.it.DataJSON.columns.indexOf(c);
            if (index === -1) return; // item not found
            $scope.it.DataJSON.colID++;

            var nc = cloneRubricItem(c);
            nc.ID = $scope.it.DataJSON.colID;
            $scope.it.DataJSON.columns.splice(index+1,0,nc);
            $scope.refreshCells();
            // copy all cells too now
            for(var r=0; r < $scope.it.DataJSON.rows.length; r++){
              var rowID = $scope.it.DataJSON.rows[r].ID;
              var sourceCell = $scope.findRubricCell(rowID, c.ID);
              var targetCell = $scope.findRubricCell(rowID, nc.ID);
              if(sourceCell && targetCell){
                targetCell.Text = sourceCell.Text;
              }
            }
          };
          $scope.moveRow = function(r,dir){
            var index = $scope.it.DataJSON.rows.indexOf(r);
            if (index === -1) return; // item not found

            var newIndex = index + dir;
            if (newIndex < 0 || newIndex >= $scope.it.DataJSON.rows.length) return; // out of bounds

            // remove item and insert at new position
            $scope.it.DataJSON.rows.splice(index, 1);
            $scope.it.DataJSON.rows.splice(newIndex, 0, r);
          };

          $scope.removeRow = function(r,ev){            
            var index = $scope.it.DataJSON.rows.indexOf(r);
            if (index === -1) return; // item not found
            self.confirm($filter('trans')('DELETEROW')+"?",$filter('trans')('DELETE'),ev).then(function(){
              $scope.it.DataJSON.rows.splice(index, 1);
              $scope.refreshCells();
            });
          };

          $scope.duplicateRow = function(r,ev){
            var index = $scope.it.DataJSON.rows.indexOf(r);
            if (index === -1) return; // item not found
            $scope.it.DataJSON.rowID++;

            var nr = cloneRubricItem(r);
            nr.ID = $scope.it.DataJSON.rowID;
            $scope.it.DataJSON.rows.splice(index+1,0,nr);
            $scope.refreshCells();
            // copy all cells too now
            for(var c=0; c < $scope.it.DataJSON.columns.length; c++){
              var colID = $scope.it.DataJSON.columns[c].ID;
              var sourceCell = $scope.findRubricCell(r.ID, colID);
              var targetCell = $scope.findRubricCell(nr.ID, colID);
              if(sourceCell && targetCell){
                targetCell.Text = sourceCell.Text;
              }
            }
          };

          $scope.editColumn = function(c){
            $scope.currentEditCell = null;
            $scope.currentEditRow = null;
            $scope.currentEditColumn = c;
            if(c && c.ID){
              if($scope.it.DataJSON.rows.length > 0){
                $scope.currentEditCell = $scope.getOrCreateCell($scope.it.DataJSON.rows[0].ID, c.ID);
              }
            }else{
              if($scope.it.DataJSON.rows.length > 0 && $scope.it.DataJSON.columns.length > 0){
                $scope.currentEditCell = $scope.getOrCreateCell($scope.it.DataJSON.rows[0].ID, $scope.it.DataJSON.columns[0].ID);
              }
            }
          };
          $scope.editRow = function(r){
            $scope.currentEditCell = null;
            $scope.currentEditColumn = null;
            $scope.currentEditRow = r;
            if(r && r.ID){
              if($scope.it.DataJSON.columns.length > 0){
                $scope.currentEditCell = $scope.getOrCreateCell(r.ID, $scope.it.DataJSON.columns[0].ID);
              }
            }
          };
          $scope.editCell = function(r,c,ev){
            $scope.rubricMenuOpenTarget = "";
            $scope.currentEditRow = r;
            $scope.currentEditColumn = c;
            $scope.currentEditCell = $scope.getOrCreateCell(r.ID, c.ID);
            if(ev && ev.clientX !== undefined && ev.clientY !== undefined){
              $scope.focusRubricCellEditorFromPoint(ev.clientX, ev.clientY, r.ID, c.ID);
            }
          };

          $scope.addRow = function(preset){            
            $scope.it.DataJSON.rowID++;
            var multi = 0;
            if($scope.it.DataJSON.rows.length > 0) 
               multi = $scope.it.DataJSON.rows[$scope.it.DataJSON.rows.length-1].multi == 1 ? 1 : 0;
            var r = {ID:$scope.it.DataJSON.rowID};
            if(multi) r.multi = multi;
            if(preset == "feedback"){
              r.input = 1;
              r.span = 1; 
            }
            if(preset == "feedbacks"){
              r.input = 1;
            }
            if(preset == "headline"){
              r.inactive = 1;
              r.span = 1;  
              r.Color = '#f3f3f3';   
              for(var i=0; i < $scope.it.DataJSON.rows.length; i++){
                if($scope.it.DataJSON.rows[i].span == 1 && $scope.it.DataJSON.rows[i].inactive == 1){
                  if($scope.it.DataJSON.rows[i].Color)
                    r.Color = $scope.it.DataJSON.rows[i].Color;
                  if($scope.it.DataJSON.rows[i].Align)
                    r.Align = $scope.it.DataJSON.rows[i].Align;
                  if($scope.it.DataJSON.rows[i].vAlign)
                    r.vAlign = $scope.it.DataJSON.rows[i].vAlign;
                }
              }         
            }
            $scope.it.DataJSON.rows.push(r);            
            $scope.refreshCells();
          };

          $scope.addColumn = function(preset){            
            $scope.it.DataJSON.colID++;
            var multi = 1;
            if($scope.it.DataJSON.columns.length > 0) 
               multi = $scope.it.DataJSON.columns[$scope.it.DataJSON.columns.length-1].multi == 0 ? 0 : 1;
            var r = {ID:$scope.it.DataJSON.colID};
            if(multi) r.multi = multi;
            if($scope.it.DataJSON.columns.length > 0){
              var lastCol = $scope.it.DataJSON.columns[$scope.it.DataJSON.columns.length-1];
              var lastWidth = parseFloat(lastCol.width);
              if(isFinite(lastWidth) && lastWidth > 0) r.width = lastWidth;
            }
            if(preset == "feedbacks"){
              r.input = 1;
            }
            $scope.it.DataJSON.columns.push(r);
            $scope.refreshCells();
          };

          $scope.addColumns = function(preset){       
            var makeCols = function(n,icons){
              var r = [];
              var firstRow = $scope.it.DataJSON.rows[0];
              for(var i=0; i < n; i++){
                $scope.addColumn();
                var c = $scope.it.DataJSON.columns[$scope.it.DataJSON.columns.length-1];
                delete(c.width);
                if(firstRow){
                  var targetCell = $scope.findRubricCell(firstRow.ID, c.ID);
                  targetCell.Text = '<i class="certificateBadge '+icons[i]+'" contenteditable="false">&nbsp;</i>';
                }
                r.push(c);
              }
              return r;
            } 
            if(preset == "dots"){
              makeCols(3,['redEmpty','yellowEmpty','greenEmpty']);
            }
            if(preset == "similies"){
              makeCols(4,['smilie4','smilie3','smilie2','smilie1']);
            }
            if(preset == "plants"){
              makeCols(5,['plant1','plant2','plant3','plant4','plant5']);
            }
            if(preset == "bars"){
              makeCols(5,['bar1','bar2','bar3','bar4','bar5']);
            }
          };

          $scope.addRowBelow = function(r){
            var p = findRubricItemIndexById($scope.it.DataJSON.rows, r.ID);
            if(p == -1) return;
            var nr = JSON.parse(angular.toJson(r));
            $scope.it.DataJSON.rowID++;      
            nr.ID = $scope.it.DataJSON.rowID;      
            $scope.it.DataJSON.rows.splice(p+1,0,nr);
            $scope.refreshCells();
          };

          $scope.addColumnRight = function(c){            
            var p = findRubricItemIndexById($scope.it.DataJSON.columns, c.ID);
            if(p == -1) return;
            var nc = JSON.parse(angular.toJson(c));
            $scope.it.DataJSON.colID++;      
            nc.ID = $scope.it.DataJSON.colID;      
            $scope.it.DataJSON.columns.splice(p+1,0,nc);
            $scope.refreshCells();
          };
      
          $scope.refreshCells = function(){
            var data = $scope.it.DataJSON;
            var rows = data.rows || [];
            var cols = data.columns || [];
            var validCells = {};
            var existingCells = {};

            for(var i=0; i < data.cells.length; i++){
              var existingKey = getRubricCellKey(data.cells[i].row, data.cells[i].col);
              if(typeof existingCells[existingKey] === "undefined") existingCells[existingKey] = data.cells[i];
            }

            for(var c=0; c < cols.length; c++){
              var colID = cols[c].ID;
              for(var r=0; r < rows.length; r++){
                var rowID = rows[r].ID;
                var key = getRubricCellKey(rowID, colID);
                validCells[key] = true;
                if(typeof existingCells[key] !== "undefined") continue;

                var cc = {col:colID,row:rowID,"Text":""};
                data.cellID++;
                cc.ID = data.cellID;
                data.cells.push(cc);
                existingCells[key] = cc;
              }
            }

            for(var i=0; i < data.cells.length; i++){
              var cellKey = getRubricCellKey(data.cells[i].row, data.cells[i].col);
              if(!validCells[cellKey]){
                data.cells.splice(i,1);
                i--;
              }
            }
            $scope.ensureRubricSizing();
          };

          $timeout(function(){
            self.addDropHandler($scope, $scope.dialogElement, null, true, false, $scope.addRubricFilesToFocusedEditor);
          });
          
          $scope.refreshCells();


          $scope.save = function(ev) {
            self.closeDialog($scope.dialogElement);
            $scope.refreshCells();
            $scope.it.Description = self.trimHTML($scope.it.Description);
            // save to server
            if($scope.it.ID == -1){
              self.apiPost("ajax",{"action":"createRubric", "Name":$.trim($scope.it.Name),"Description":$scope.it.Description, "Data":angular.toJson($scope.it.DataJSON)}).then(function(data) {
                self.updateRubricsData(data.rubrics);
                if(!data.rubric){
                  data.rubric = data.rubrics[data.rubrics.length-1];
                }
                deferred.resolve(data.rubric);
              });
            }else{
              var updatePayload = {"action":"updateRubric", "ID":$scope.it.ID, "Name":$.trim($scope.it.Name),"Description":$scope.it.Description, "Data":angular.toJson($scope.it.DataJSON)};
              if(editContext && editContext.fromTask){
                var fromTaskID = parseInt(editContext.fromTask,10);
                if(!isNaN(fromTaskID)) updatePayload.fromTask = fromTaskID;
              }else
              if(editContext && editContext.fromGoal){
                var fromGoalID = parseInt(editContext.fromGoal,10);
                if(!isNaN(fromGoalID)) updatePayload.fromGoal = fromGoalID;
              }
              self.apiPost("ajax",updatePayload).then(function(data) {
                if(data && data.rubrics) self.updateRubricsData(data.rubrics);

                var finalizeUpdate = function(){
                  var updatedRubric = self.getRubricByID($scope.it.ID);
                  deferred.resolve(updatedRubric ? updatedRubric : $scope.it);
                };

                var rubricOwnerID = parseInt($scope.it.Owner,10);
                var currentUserID = parseInt(self.user.ID,10);
                var isForeignRubric = !isNaN(rubricOwnerID) && !isNaN(currentUserID) && rubricOwnerID != currentUserID;
                var rubricGuid = $scope.it.GUID ? $.trim(String($scope.it.GUID)) : "";

                if(isForeignRubric && rubricGuid != ""){
                  self.apiPost("ajax",{"action":"getRubrics", "guids":rubricGuid}).then(function(result){
                    if(result && result.rubrics) self.updateRubricsData(result.rubrics);
                    finalizeUpdate();
                  }, function(){
                    finalizeUpdate();
                  });
                }else{
                  finalizeUpdate();
                }
              });
            }
          };

          $scope.cancel = function(ev) {
            if($scope.lastVersion != angular.toJson($scope.it)){
              // changed
              self.confirm($filter('trans')('ASKRUBRICSAVE'),$filter('trans')('DISCARD'),ev,$filter('trans')('BACK')).then(function(){
                self.closeDialog($scope.dialogElement);
              });
            }else
              self.closeDialog($scope.dialogElement);
          };
        }
      });
      return deferred.promise;
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.currentMainTopic = null;
    self.currentTopic = null;
    self.currentClass = null;
    self.currentClassStudentSelection = [];
    self.currentStudent = null;
    ///////////////////////////////////////////////////////////////////////////////////////////////////
    self.toggleCurrentClassStudentSelectionGoal = function(id,g){
      if(id == "*"){
        var students = [];
        for(var i=0; i < self.currentClass.students.length; i++){
          if(self.currentClassResultStudentFilter &&
             self.currentClassResultStudentFilter.length > 0){
            // filter is used, skip not in list
            if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) == -1) continue;
          }
          if(g){
            if(self.isUserLearningGoalVisibleDeep(
              self.currentMainTopic, self.currentTopic, g,
              self.currentClass.students[i]))
              students.push(self.currentClass.students[i].ID);
          }else students.push(self.currentClass.students[i].ID);
        }

        if(self.currentClassStudentSelection.length == students.length){
          self.currentClassStudentSelection = [];
        }else{
          self.currentClassStudentSelection = [];
          for(var i=0; i < students.length; i++){
            self.currentClassStudentSelection.push(students[i]);
          }
        }
      }else{
        for(var i=0; i < self.currentClass.students.length; i++){
          if(self.currentClassResultStudentFilter &&
             self.currentClassResultStudentFilter.length > 0){
            // filter is used, skip not in list
            if(self.currentClassResultStudentFilter.indexOf(self.currentClass.students[i].ID) == -1) continue;
          }
          if(self.currentClass.students[i].ID == id){
            if(g){
              if(!self.isUserLearningGoalVisibleDeep(
                self.currentMainTopic, self.currentTopic, g,
                self.currentClass.students[i])) return;
            }
          }
        }
        var p = self.currentClassStudentSelection.indexOf(id);
        if(p == -1){
          self.currentClassStudentSelection.push(id);
        }else{
          self.currentClassStudentSelection.splice(p,1);
        }
      }
    };
    ///////////////////////////////////////////////////////////////////////////////////////////////////
