    self.editJournalItem = function(it,ev){
      var deferred = $q.defer();
      self.showDialog({
        templateUrl: "writejournalitem.html",
        targetEvent: ev,
        clickOutsideToClose: false,
        escapeToClose: false,
        skipHide:true, // keep other dialog open
        controller: function ($scope, $mdDialog) {
          $scope.self = self;
          var data = it.DataJSON;
          var oldData = data.Text;
          $scope.Text = {input:data.Text};
          $scope.isCordova = !(typeof cordova == "undefined");
          $scope.attachtotype = null;
          $scope.attachto = null;


          if(data.URL){
            $scope.attachment = data;
          }else{
            $scope.attachment = null;
          }

          $scope.removeAttachment = function(){
            $scope.attachment = null;
          };

          $scope.uploadFileSubmit = function(e,type){
            e = e && e.target && !e.files ? e.target : e;
            if(e.files.length == 0) return;
            if(!self.checkFileType(e.files[0],type)) return;
            var filename = e.files[0].name;
            e.files[0].myType = type;
            self.uploadFileInput(e,function(result){
              var d = {};
              d.URL = result;
              d.Media = type ? type : "file";
              d.Name = filename;
              $scope.attachment = d;
            });
            $(e).val('');
          };

          $scope.takeMedia = function(type, name = ''){
            var dM = 0;
            if(type == 'audio' || type == 'video') dM = 1;

            self.takeUserMedia(type,null,function(results){
              /*var d = {};
              if(type == "file"){
                d.URL = result;
                d.Name = filename;
                d.Media = type;
              }else{
                d.URL = result;
                d.Media = type;
              }*/
              $scope.attachment = results[0].URL;
            }, {dialogMode:dM});
          };

          $scope.save = function() {
            // try save now
            if($.trim($scope.Text.input) == "" && !$scope.attachment) { $('#inputText').focus(); return;}
            var d = {};
            if($scope.attachment){
              d.URL = $scope.attachment.URL;
              d.Media = $scope.attachment.Media;
              d.Name = $scope.attachment.Name;
            }
            d.Text = $scope.Text.input;

            if(data.goalid) d.goalid = data.goalid;
            if(data.taskid) d.taskid = data.taskid;

            self.apiPost("ajax",{"action":"updateJournalItem","itemid":it.ID, "Text":(angular.toJson(d)), "teacherid":self.user.ID })
              .then(function(data) {
                self.keepAliveCallback();
                self.closeDialog($scope.dialogElement);
                it.DataJSON.Text = d.Text;
                if($scope.attachment){
                  it.DataJSON.URL = $scope.attachment.URL;
                  it.DataJSON.Media = $scope.attachment.Media;
                  it.DataJSON.Name = $scope.attachment.Name;
                }
                deferred.resolve();
             });
          };


          $scope.cancel = function() {
            if($scope.Text.input != oldData)
              self.confirm($filter('trans')('ASKCANCELEDIT'),$filter('trans')('OK'),ev).then(function(){
                self.closeDialog($scope.dialogElement);
                deferred.reject("cancel");
              });
            if($scope.Text.input == oldData) {
              self.closeDialog($scope.dialogElement);
              deferred.reject("cancel");
            }
          };

        }
      });
      return deferred.promise;
    };

