    self.getTopicFromTask = function(task){
      if(!task) return null;
      var goalid = task.LearningGoal;

      if(self.classList)
      for(var c=0; c < self.classList.length; c++){
        if(self.classContent[self.classList[c].ID] && self.classContent[self.classList[c].ID].mainTopics)
        for(var i=0; i < self.classContent[self.classList[c].ID].mainTopics.length; i++){
          if(self.classContent[self.classList[c].ID].mainTopics[i].topics)
          for(var z=0; z < self.classContent[self.classList[c].ID].mainTopics[i].topics.length; z++){
            if(self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals)
            for(var g=0; g < self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals.length; g++){
              if(self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals[g].ID == goalid){
                return self.classContent[self.classList[c].ID].mainTopics[i].topics[z];
              }
/*
              if(self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals[g].tasks)
              for(var t=0; t < self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals[g].tasks.length; t++){
                if(self.classContent[self.classList[c].ID].mainTopics[i].topics[z].goals[g].tasks[t].ID == task.ID)
                  return self.classContent[self.classList[c].ID].mainTopics[i].topics[z];
              }
*/
            }
          }
        }
      }

      // teacher my content
      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        if(self.userContent.mainTopics[i].topics)
        for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
          if(self.userContent.mainTopics[i].topics[z].goals)
          for(var g=0; g < self.userContent.mainTopics[i].topics[z].goals.length; g++){
            if(self.userContent.mainTopics[i].topics[z].goals[g].ID == goalid){
              return self.userContent.mainTopics[i].topics[z];
            }
            /*
            if(self.userContent.mainTopics[i].topics[z].goals[g].tasks)
            for(var t=0; t < self.userContent.mainTopics[i].topics[z].goals[g].tasks.length; t++){
              if(self.userContent.mainTopics[i].topics[z].goals[g].tasks[t].ID == task.ID) return self.userContent.mainTopics[i].topics[z];
            }
            */
          }
        }
      }
      return null;
    };

    ///////////////////////////////////////////////////////////////////////////////////////////////////

    self.getMainTopicFromTopic = function(topic){
      if(!topic) return null;

      if(self.classList)
      for(var c=0; c < self.classList.length; c++){
        if(self.classContent[self.classList[c].ID] && self.classContent[self.classList[c].ID].mainTopics)
        for(var i=0; i < self.classContent[self.classList[c].ID].mainTopics.length; i++){
          for(var z=0; z < self.classContent[self.classList[c].ID].mainTopics[i].topics.length; z++){
            if(self.classContent[self.classList[c].ID].mainTopics[i].topics[z].ID == topic.ID) return self.classContent[self.classList[c].ID].mainTopics[i];
          }
        }
      }

      if(self.userContent && self.userContent.mainTopics)
      for(var i=0; i < self.userContent.mainTopics.length; i++){
        for(var z=0; z < self.userContent.mainTopics[i].topics.length; z++){
          if(self.userContent.mainTopics[i].topics[z].ID == topic.ID) return self.userContent.mainTopics[i];
        }
      }
      return null;
    };
